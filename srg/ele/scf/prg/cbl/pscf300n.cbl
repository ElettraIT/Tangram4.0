      *    *===========================================================*
      *    * Routine di allineamento a destra del numero documento     *
      *    *-----------------------------------------------------------*
       all-num-doc-000.
      *              *-------------------------------------------------*
      *              * Se numero documento a spazi : uscita            *
      *              *-------------------------------------------------*
           move      spaces               to   w-ndo-num-all          .
           if        w-ndo-num-ori        =    spaces
                     go to  all-num-doc-999.
      *                  *---------------------------------------------*
      *                  * Ciclo per trovare il primo carattere non    *
      *                  * blank partendo da destra                    *
      *                  *---------------------------------------------*
           move      11                   to   w-ndo-ctr-001          .
       all-num-doc-100.
           subtract  1                    from w-ndo-ctr-001          .
           if        w-ndo-ctr-001        =    zero
                     go to all-num-doc-200.
           if        w-ndo-ori-chr
                    (w-ndo-ctr-001)       =    spaces
                     go to  all-num-doc-100.
       all-num-doc-200.
      *                  *---------------------------------------------*
      *                  * Ciclo per formare il nuovo numero allineato *
      *                  * a destra                                    *
      *                  *---------------------------------------------*
           move      10                   to   w-ndo-ctr-002          .
       all-num-doc-300.
           move      w-ndo-ori-chr
                    (w-ndo-ctr-001)       to   w-ndo-all-chr
                                              (w-ndo-ctr-002)
           subtract  1                    from w-ndo-ctr-001          .
           subtract  1                    from w-ndo-ctr-002          .
           if        w-ndo-ctr-001        =    zero
                     go to all-num-doc-999
           else      go to all-num-doc-300.
       all-num-doc-999.
           exit.

