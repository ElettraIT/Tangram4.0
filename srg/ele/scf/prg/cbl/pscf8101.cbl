           if        w-buf-rig-rcc-iva    >    100
                     go to prn-liv-det-rcc-340.
      *
           if        w-buf-rig-rcc-ibl    =    zero
                     move  w-buf-rig-rcc-ibq
                                          to   w-buf-rig-rcc-ibl      .
      *
