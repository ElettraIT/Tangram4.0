           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *              *-------------------------------------------------*
      *              * Rilascio record [ocr]                           *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
       agg-rec-ocr-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento record [ocp] per quanto riguarda la quanti- *
      *    * ta' assegnata alla riga ordini cliente                    *
      *    *-----------------------------------------------------------*
       agg-rec-ocp-000.
      *              *-------------------------------------------------*
      *              * Test se necessario                              *
      *              *-------------------------------------------------*
           if        rf-osr-coc-prt       =    zero or
                     rf-osr-coc-prg       =    zero
                     go to agg-rec-ocp-999.
      *              *-------------------------------------------------*
      *              * Ottenimento record [ocp]                        *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-osr-coc-prt       to   rf-ocp-num-prt         .
           move      rf-osr-coc-prg       to   rf-ocp-num-prg         .
           move      001                  to   rf-ocp-prg-frm         .
           move      "pgm/orc/fls/ioc/obj/iofocp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocp                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-ocp-999.
      *              *-------------------------------------------------*
      *              * Test se record di assegnazione alla giacenza    *
      *              *-------------------------------------------------*
           if        rf-ocp-dat-ass       not  = zero
                     go to agg-rec-ocp-900.
      *              *-------------------------------------------------*
      *              * Aggiornamento dati record [ocp]                 *
      *              *-------------------------------------------------*
           subtract  rf-osr-qta-ven       from rf-ocp-qta-ass         .
           if        rf-ocp-qta-ass       <    zero
                     move  zero           to   rf-ocp-qta-ass         .
      *              *-------------------------------------------------*
      *              * Aggiornamento record [ocp]                      *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocp                 .
       agg-rec-ocp-900.
      *              *-------------------------------------------------*
      *              * Rilascio record [ocp]                           *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocp                 .
       agg-rec-ocp-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [osx]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-osx-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento valori record                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero protocollo                           *
      *                  *---------------------------------------------*
           move      w-att-ods-prt-num    to   rf-osx-num-prt         .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osx                 .
       wrt-rec-osx-999.
           exit.

