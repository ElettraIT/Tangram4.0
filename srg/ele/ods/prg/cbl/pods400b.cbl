      *    *-----------------------------------------------------------*
       prn-fin-lr1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-fin-lr1-100.
      *              *-------------------------------------------------*
      *              * Eventuale scrittura dati ordine di spedizione   *
      *              * generato in rullino messaggi                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if        w-rot-l01-tip-rec    not  = "TES"
                     go to prn-fin-lr1-500.
           if        w-ipc-snx-log-val    not  = "S"
                     go to prn-fin-lr1-500.
      *                  *---------------------------------------------*
      *                  * Intestazione rullino                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        w-prn-flg-irm        not  = spaces
                     go to prn-fin-lr1-120.
           move      "#"                  to   w-prn-flg-irm          .
      *                      *-----------------------------------------*
      *                      * Esecuzione                              *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Ordini di spedizione generati:"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "WR"                 to   m-ope                  .
           move      "------------------------------"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-fin-lr1-120.
      *                  *---------------------------------------------*
      *                  * Riga rullino                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing numero protocollo               *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-prn-prt-ods        to   w-prn-fin-lr1-xnp      .
           move      w-prn-fin-lr1-xsa    to   w-prn-fin-lr1-wsa      .
           move      w-prn-fin-lr1-xpr    to   w-prn-fin-lr1-wpr      .
           move      w-prn-fin-lr1-wnp    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa in m-msg           *
      *                      *-----------------------------------------*
           move      spaces               to   m-msg                  .
           string    "- Protocollo nr. "
                                delimited by   size
                     v-edt
                                delimited by   spaces
                                          into m-msg                  .
      *                      *-----------------------------------------*
      *                      * Stampa stringa in m-msg                 *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-fin-lr1-500.
      *              *-------------------------------------------------*
      *              * Eventuale stampa del documento                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if        w-rot-l01-tip-rec    not  = "RIG"
                     go to prn-fin-lr1-999.
           if        w-ipc-snx-stp-val    not  = "S"
                     go to prn-fin-lr1-999.
      *                  *---------------------------------------------*
      *                  * Esecuzione stampa documento                 *
      *                  *---------------------------------------------*
           perform   exe-mod-stp-000      thru exe-mod-stp-999        .
       prn-fin-lr1-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione modulo di stampa documento                     *
      *    *-----------------------------------------------------------*
       exe-mod-stp-000.
      *              *-------------------------------------------------*
      *              * Preparazione variabile "inp-mst"                *
      *              *-------------------------------------------------*
           move      spaces               to   w-inp-mst              .
           move      "ST"                 to   w-inp-mst-ope          .
           move      w-prn-prt-ods        to   w-inp-mst-prt          .
           move      "N"                  to   w-inp-mst-ejc          .
      *              *-------------------------------------------------*
      *              * Scrittura variabile "inp-mst"                   *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "inp-mst"            to   s-var                  .
           move      "="                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      80                   to   s-car                  .
           move      w-inp-mst            to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo del modulo di stampa documento         *
      *              *-------------------------------------------------*
           move      "pgm/ods/prg/obj/pods300s"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
      *              *-------------------------------------------------*
      *              * Controllo esito operazione di Stampa            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura variabile di ritorno "out-mst"      *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "out-mst"            to   s-var                  .
           move      "="                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     go to exe-mod-stp-400.
           move      s-alf                to   w-out-mst              .
           if        w-out-mst-stp        =    spaces
                     go to exe-mod-stp-400.
           if        w-out-mst-stp        =    "N"
                     go to exe-mod-stp-600
           else if   w-out-mst-stp        =    "E"
                     go to exe-mod-stp-800
           else      go to exe-mod-stp-400.
       exe-mod-stp-400.
      *                  *---------------------------------------------*
      *                  * Aggiornamento record testata [ost]          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio record [ost] attuale        *
      *                      *-----------------------------------------*
           move      rf-ost               to   w-sav-rec-ost          .
      *                      *-----------------------------------------*
      *                      * Ottenimento record [ost]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-prn-prt-ods        to   rf-ost-num-prt         .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                      *-----------------------------------------*
      *                      * Aggiornamento contatore copie stampate  *
      *                      *-----------------------------------------*
           if        rf-ost-ctr-stp       <    99
                     add  1               to   rf-ost-ctr-stp         .
      *                      *-----------------------------------------*
      *                      * Update record [ost]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                      *-----------------------------------------*
      *                      * Rilascio record [ost]                   *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * Ripristino record [ost] salvato             *
      *                  *---------------------------------------------*
           move      w-sav-rec-ost        to   rf-ost                 .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     exe-mod-stp-999.
       exe-mod-stp-600.
      *                  *---------------------------------------------*
      *                  * Se documento da stampare non trovato        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Scrittura messaggio                     *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Documento da stampare non trovato !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           go to     exe-mod-stp-999.
       exe-mod-stp-800.
      *                  *---------------------------------------------*
      *                  * Se errore grave in stampa documento         *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Errore grave in stampa documento !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           go to     exe-mod-stp-999.
       exe-mod-stp-999.
           exit.

