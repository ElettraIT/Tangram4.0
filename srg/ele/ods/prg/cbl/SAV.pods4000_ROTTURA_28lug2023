      *                  * Spese in chiusura                           *
      *                  *---------------------------------------------*
           if        rf-oct-spe-snx (1)   =    0 or
                     rf-oct-spe-per (1)   not  = w-tot-spe-per (1)
                     move  zero           to   w-tot-spe-per (1)      .
           if        rf-oct-spe-snx (2)   =    0 or
                     rf-oct-spe-per (2)   not  = w-tot-spe-per (2)
                     move  zero           to   w-tot-spe-per (2)      .
           if        rf-oct-spe-snx (3)   =    0 or
                     rf-oct-spe-per (3)   not  = w-tot-spe-per (3)
                     move  zero           to   w-tot-spe-per (3)      .
           if        rf-oct-spe-snx (4)   =    0 or
                     rf-oct-spe-per (4)   not  = w-tot-spe-per (4)
                     move  zero           to   w-tot-spe-per (4)      .
           if        rf-oct-spe-snx (5)   =    0 or
                     rf-oct-spe-per (5)   not  = w-tot-spe-per (5)
                     move  zero           to   w-tot-spe-per (5)      .
           if        rf-oct-spe-snx (6)   =    0 or
                     rf-oct-spe-per (6)   not  = w-tot-spe-per (6)
                     move  zero           to   w-tot-spe-per (6)      .
       agg-tot-ods-200.
      *              *-------------------------------------------------*
