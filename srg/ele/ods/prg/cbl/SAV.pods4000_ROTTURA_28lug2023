                     add   rf-oct-spe-imp (4)
                                          to   w-tot-spe-imp (4)      .
           if        rf-oct-spe-snx (5)   =    1
                     add   rf-oct-spe-imp (5)
                                          to   w-tot-spe-imp (5)      .
           if        rf-oct-spe-snx (6)   =    1
