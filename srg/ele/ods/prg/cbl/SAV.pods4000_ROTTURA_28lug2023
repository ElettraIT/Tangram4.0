      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Forzatura al valore 'S'                 *
      *                      *-----------------------------------------*
           move      "S"                  to   ky2-flg-fzs            .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     agg-tot-ods-440.
       agg-tot-ods-424.
      *                  *---------------------------------------------*
      *                  * Se tipo riga : diverso da 'A'               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valore                  *
      *                      *-----------------------------------------*
           move      spaces               to   ky2-flg-fzs            .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     agg-tot-ods-440.
       agg-tot-ods-440.
      *              *-------------------------------------------------*
      *              * Aggiornamento totalizzatori per tipo prodotto   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di omaggio : no totalizzazione      *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-iva       >    900
                     go to agg-tot-ods-460.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo riga          *
      *                  *---------------------------------------------*
           if        ky2-tip-rig-tpr      =    "P"
                     go to agg-tot-ods-442
           else if   ky2-tip-rig-tpr      =    "M" or
                     ky2-tip-rig-tpr      =    "S"
                     go to agg-tot-ods-444
           else if   ky2-tip-rig-tpr      =    "A"
                     go to agg-tot-ods-446.
       agg-tot-ods-442.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'P' o 'PN'                     *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-pro       =    01
                     add  ky2-imp-rig     to   w-tot-tot-rig (1)
           else if   rf-ocr-tip-pro       =    02
                     add  ky2-imp-rig     to   w-tot-tot-rig (2)
           else if   rf-ocr-tip-pro       =    03
                     add  ky2-imp-rig     to   w-tot-tot-rig (3)
           else if   rf-ocr-tip-pro       =    09
                     add  ky2-imp-rig     to   w-tot-tot-rig (9)      .
           go to     agg-tot-ods-460.
       agg-tot-ods-444.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'M' o 'S'                      *
      *                  *---------------------------------------------*
           add       ky2-imp-rig          to   w-tot-tot-rig (1)      .
           go to     agg-tot-ods-460.
       agg-tot-ods-446.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           add       ky2-imp-rig          to   w-tot-tot-rta          .
           go to     agg-tot-ods-460.
       agg-tot-ods-460.
      *              *-------------------------------------------------*
      *              * Aggiornamento totale lordo righe ordine evase   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di omaggio : no aggiornamento       *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-iva       >    900
                     go to agg-tot-ods-480.
      *                  *---------------------------------------------*
      *                  * Esecuzione                                  *
      *                  *---------------------------------------------*
           if       (ky2-tip-rig-tpr      =    "P" ) and
                    (ky2-tip-pro          =    01 or
                     ky2-tip-pro          =    02 or
                     ky2-tip-pro          =    03 or
                     ky2-tip-pro          =    09  )
                     add  ky2-imp-rig     to   w-agg-tot-ods-tle
           else if   ky2-tip-rig-tpr      =    "M" or
                     ky2-tip-rig-tpr      =    "S"
                     add  ky2-imp-rig     to   w-agg-tot-ods-tle      .
       agg-tot-ods-480.
      *              *-------------------------------------------------*
      *              * Riscrittura record [ky2]                        *
      *              *-------------------------------------------------*
           rewrite   ky2-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione file [ky2]                 *
      *              *-------------------------------------------------*
           go to     agg-tot-ods-320.
       agg-tot-ods-600.
      *              *-------------------------------------------------*
      *              * Determinazione sconto in chiusura relativo alle *
      *              * righe ordine evase                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione iniziale                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-agg-tot-ods-qsc      .
      *                  *---------------------------------------------*
      *                  * Se sconto in chiusura dell'intero ordine a  *
      *                  * zero : nessuna determinazione               *
      *                  *---------------------------------------------*
           if        rf-oct-tot-scc       =    zero
                     go to agg-tot-ods-620.
      *                  *---------------------------------------------*
      *                  * Determinazione totale lordo dell'intero or- *
      *                  * dine                                        *
      *                  *---------------------------------------------*
           add       rf-oct-tot-rig (1)
                     rf-oct-tot-rig (2)
                     rf-oct-tot-rig (3)
                     rf-oct-tot-rig (9)
                                        giving w-agg-tot-ods-tlo      .
      *                  *---------------------------------------------*
      *                  * Se totale lordo dell'intero ordine a zero : *
      *                  * nessuna determinazione                      *
      *                  *---------------------------------------------*
           if        w-agg-tot-ods-tlo    =    zero
                     go to agg-tot-ods-620.
      *                  *---------------------------------------------*
      *                  * Se totale lordo righe evase a zero : nes-   *
      *                  * suna determinazione                         *
      *                  *---------------------------------------------*
           if        w-agg-tot-ods-tle    =    zero
                     go to agg-tot-ods-620.
      *                  *---------------------------------------------*
      *                  * Se totale lordo righe evase pari al totale  *
      *                  * lordo intero ordine : sconto in chiusura    *
      *                  * pari a quello dell'intero ordine            *
      *                  *---------------------------------------------*
           if        w-agg-tot-ods-tle    =    w-agg-tot-ods-tlo
                     move  rf-oct-tot-scc to   w-agg-tot-ods-qsc
                     go to agg-tot-ods-620.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  rf-oct-tot-scc       by   w-agg-tot-ods-tle
                                        giving w-agg-tot-ods-s18      .
           divide    w-agg-tot-ods-tlo    into w-agg-tot-ods-s18
                                        giving w-agg-tot-ods-qsc
                                               rounded                .
      *                  *---------------------------------------------*
      *                  * Se importo calcolato maggiore dello sconto  *
      *                  * in chiusura dell'intero ordine : sconto in  *
      *                  * chiusura pari a quello dell'intero ordine   *
      *                  *---------------------------------------------*
           if        w-agg-tot-ods-tlo    >    zero      and
                     w-agg-tot-ods-qsc    >    rf-oct-tot-scc
                     move  rf-oct-tot-scc to   w-agg-tot-ods-qsc
           else if   rf-oct-tot-scc       <    zero      and
                     w-agg-tot-ods-qsc    <    rf-oct-tot-scc
                     move  rf-oct-tot-scc to   w-agg-tot-ods-qsc      .
       agg-tot-ods-620.
      *              *-------------------------------------------------*
      *              * Aggiornamento importo sconto in chiusura        *
      *              *-------------------------------------------------*
           add       w-agg-tot-ods-qsc    to   w-tot-tot-scc          .
       agg-tot-ods-999.
           exit.

