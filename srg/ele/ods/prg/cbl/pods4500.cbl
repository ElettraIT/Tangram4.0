      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tra-cur-lun    to   v-car                  .
           move      w-exp-tra-cur-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tra-cur-tbl    to   v-txt                  .
           move      10                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
      *
           if        w-tes-tra-cur        =    10
                     move  01             to   v-num
           else if   w-tes-tra-cur        =    20
                     move  02             to   v-num
           else if   w-tes-tra-cur        =    30
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
______*              move  "E"            to   w-cnt-tus-acc-key
                     go to acc-tra-cur-999.
