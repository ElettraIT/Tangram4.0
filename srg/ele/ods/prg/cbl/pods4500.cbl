      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino                                  *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHARC    "         to   f-key                  .
           move      w-rip-str-orc-dpz    to   rf-ocr-cod-dpz         .
           move      w-rip-str-orc-rch    to   rf-ocr-flg-rch         .
           move      w-rip-str-orc-tip    to   rf-ocr-tip-arc         .
           move      w-rip-str-orc-cod    to   rf-ocr-cod-arc         .
           move      w-rip-str-orc-prt    to   rf-ocr-num-prt         .
           move      w-rip-str-orc-prg    to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
