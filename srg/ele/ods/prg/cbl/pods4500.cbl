                     move  10             to   w-tes-tra-cur    
           else if   v-num                =    02
                     move  20             to   w-tes-tra-cur    
           else if   v-num                =    03
                     move  30             to   w-tes-tra-cur    
           else      move  zero           to   w-tes-tra-cur          .
