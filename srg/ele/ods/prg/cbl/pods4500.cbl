                                  with pointer w-vis-nos-coc-pnt      .
       vis-nos-coc-800.
      *              *-------------------------------------------------*
      *              * Stampa stringa                                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-vis-nos-coc-pnt    to   v-car                  .
           move      20                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-vis-nos-coc-x40    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-nos-coc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna richiesta           *
      *    *-----------------------------------------------------------*
       vis-dcn-ric-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      20                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-rig-dcn-ric        to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-dcn-ric-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero e data ordine cliente      *
      *    *-----------------------------------------------------------*
       vis-rif-ocl-000.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing data ordine cliente                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-ocl-dat        to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (3)      .   
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      w-rig-ocl-num        to   w-all-str-cat (1)      .
      *
           if        w-rig-ocl-dat        =    zero
                     move  spaces         to   w-all-str-cat (2)
           else      move  "del"          to   w-all-str-cat (2)      .
      *
           if        w-rig-ocl-rif        =    spaces
                     move  spaces         to   w-all-str-cat (4)
                     move  spaces         to   w-all-str-cat (5)
           else      move  "-"            to   w-all-str-cat (4)
                     move  w-rig-ocl-rif  to   w-all-str-cat (5)      .
      *
           perform   all-str-csb-000      thru all-str-csb-999        .
       vis-rif-ocl-040.
      *              *-------------------------------------------------*
      *              * Stampa stringa                                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      45                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-rif-ocl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna prevista            *
      *    *-----------------------------------------------------------*
       vis-dcn-prv-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      21                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-rig-dcn-prv        to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-dcn-prv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Quanti- *
      *    * ta' assegnata                                             *
      *    *-----------------------------------------------------------*
       acc-qta-ass-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se tipo riga a spaces o 'C'            *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig        not  = spaces
                     go to acc-qta-ass-050.
      *                      *-----------------------------------------*
      *                      * Se tipo uscita da impostazione prece-   *
      *                      * dente e' Up e numero riga da accettare  *
      *                      * superiore alla 2 : Uscita per Up        *
      *                      *-----------------------------------------*
           if        w-sav-tip-usc        =    "U" and
                     w-cnt-cor-nrg-dac    >    2
                     move  "U"            to   w-cnt-tus-acc-rig
                     move  spaces         to   w-sav-tip-usc
                     go to acc-qta-ass-999.
      *                      *-----------------------------------------*
      *                      * Altrimenti uscita per Down              *
      *                      *-----------------------------------------*
           move      "D"                  to   w-cnt-tus-acc-rig      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-qta-ass-999.
       acc-qta-ass-050.
      *                  *---------------------------------------------*
      *                  * Determinazione numero linea assoluta a vi-  *
      *                  * deo                                         *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-ass        to   w-sav-qta-ass          .
       acc-qta-ass-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-qta-ass        to   w-rig-qta-ass          .
      *                  *---------------------------------------------*
      *                  * Parametri di accettazione                   *
      *                  *---------------------------------------------*
           move      "A"                  to   w-acc-qta-ass-ope      .
           if        w-rig-tip-rig        =    "P"
                     perform acc-qta-ass-qta-000
                                          thru acc-qta-ass-qta-999
           else      perform acc-qta-ass-aoc-000
                                          thru acc-qta-ass-aoc-999    .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso, a meno che non   *
      *                      *        si sia alla riga numero 1        *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    >    1
                     move  "UP  "         to   v-pfk (01)
           else      move  spaces         to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : non ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)
           else      move  spaces         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : mai ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso, a meno che non   *
      *                      *        si sia alla pagina numero 1      *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    >    w-lin-num-lin-vis
                     move  "PRSC"         to   v-pfk (07)
           else      move  spaces         to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)
           else      move  spaces         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = w-rlt-sup-max
                     move  "TAB "         to   v-pfk (10)
           else      move  spaces         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "SLCT"               to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      "N"                  to   w-acc-qta-ass-ope      .
           if        w-rig-tip-rig        =    "P"
                     perform acc-qta-ass-qta-000
                                          thru acc-qta-ass-qta-999
           else      perform acc-qta-ass-aoc-000
                                          thru acc-qta-ass-aoc-999    .
       acc-qta-ass-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-qta-ass-400.
       acc-qta-ass-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-qta-ass-300
           else      go to acc-qta-ass-350.
       acc-qta-ass-300.
      *                  *---------------------------------------------*
      *                  * Se riga di commento                         *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig        not  = "C"
                     go to acc-qta-ass-305.
           if        w-rig-qta-ass        =    zero
                     move  1              to   w-rig-qta-ass
           else      move  zero           to   w-rig-qta-ass          .
           go to     acc-qta-ass-338.
       acc-qta-ass-305.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che sia stato variato  *
      *                  * il campo di impostazione                    *
      *                  *---------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-qta-ass-310
           else      go to acc-qta-ass-320.
       acc-qta-ass-310.
      *                  *---------------------------------------------*
      *                  * Se e' stato variato il campo di impostazio- *
      *                  * ne : trattamento tasto SLCT per posiziona-  *
      *                  * mento su riga                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Conversione numero riga impostato in    *
      *                      * formato numerico                        *
      *                      *-----------------------------------------*
           move      v-num                to   w-cnt-slc-rap-num      .
      *                      *-----------------------------------------*
      *                      * Se numero riga impostato minore di 1 o  *
      *                      * maggiore del massimo : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-rlt-sup-max
                     go to acc-qta-ass-100.
      *                          *-------------------------------------*
      *                          * Se numero riga impostato pari a nu- *
      *                          * numero riga attuale : reimpostazio- *
      *                          * ne                                  *
      *                          *-------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-qta-ass-100.
      *                          *-------------------------------------*
      *                          * Preparazione parametri e uscita     *
      *                          *-------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-qta-ass-999.
       acc-qta-ass-320.
      *                  *---------------------------------------------*
      *                  * Se non e' stato variato il campo di impo-   *
      *                  * stazione : trattamento tasto SLCT per in-   *
      *                  * versione del campo                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se quantita' assegnata gia' esistente   *
      *                      *-----------------------------------------*
           if        w-rig-qta-ass        =    zero
                     go to acc-qta-ass-335.
      *                          *-------------------------------------*
      *                          * Normalizzazione quantita' assegnata *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-qta-ass          .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-qta-ass-338.
       acc-qta-ass-335.
      *                      *-----------------------------------------*
      *                      * Se quantita' assegnata non esistente    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' assegnata pari alla quan- *
      *                          * tita' da evadere                    *
      *                          *-------------------------------------*
           move      w-rig-qta-dev        to   w-rig-qta-ass          .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-qta-ass-338.
       acc-qta-ass-338.
      *                      *-----------------------------------------*
      *                      * Visualizzazione quantita' assegnata     *
      *                      *-----------------------------------------*
           perform   vis-qta-ass-000      thru vis-qta-ass-999        .
      *                          *-------------------------------------*
      *                          * Uscita come per Return              *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
           go to     acc-qta-ass-999.
       acc-qta-ass-350.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-qta-ass-375.
      *                  *---------------------------------------------*
      *                  * Find su archivio ordini clienti             *
      *                  *---------------------------------------------*
           move      w-rig-num-pro        to   w-fnd-arc-orc-pro      .
           move      02                   to   w-fnd-arc-orc-tip      .
           move      w-tes-cod-dpz        to   w-fnd-arc-orc-dpz      .
      *
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-fnd-arc-orc-dat      .
      *
           perform   fnd-arc-orc-000      thru fnd-arc-orc-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-qta-ass-100.
       acc-qta-ass-375.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-qta-ass-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-ass-999
                     else    go to acc-qta-ass-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ass-999.
       acc-qta-ass-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      "W"                  to   w-acc-qta-ass-ope      .
           if        w-rig-tip-rig        =    "P"
                     perform acc-qta-ass-qta-000
                                          thru acc-qta-ass-qta-999
           else      perform acc-qta-ass-aoc-000
                                          thru acc-qta-ass-aoc-999    .
      *                  *---------------------------------------------*
      *                  * Valore negativo non ammesso                 *
      *                  *---------------------------------------------*
           if        w-rig-qta-ass        <    zero
                     go to acc-qta-ass-100.
       acc-qta-ass-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-ass-800.
       acc-qta-ass-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' assegnata               *
      *    *-----------------------------------------------------------*
       vis-qta-ass-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "V"                  to   w-acc-qta-ass-ope      .
           if        w-rig-tip-rig        =    "P"
                     perform acc-qta-ass-qta-000
                                          thru acc-qta-ass-qta-999
           else      perform acc-qta-ass-aoc-000
                                          thru acc-qta-ass-aoc-999    .
       vis-qta-ass-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Quanti- *
      *    * ta' assegnata                                             *
      *    *                                                           *
      *    * Subroutine per accettazione quantita'                     *
      *    *-----------------------------------------------------------*
       acc-qta-ass-qta-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-acc-qta-ass-ope    =    "A"
                     go to acc-qta-ass-qta-100
           else if   w-acc-qta-ass-ope    =    "N"
                     go to acc-qta-ass-qta-200
           else if   w-acc-qta-ass-ope    =    "W"
                     go to acc-qta-ass-qta-300
           else      go to acc-qta-ass-qta-500.
       acc-qta-ass-qta-100.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri                                   *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-rig-dec-qta        to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      50                   to   v-pos                  .
           move      "GB"                 to   v-edm                  .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-ass-qta-900.
       acc-qta-ass-qta-200.
      *              *-------------------------------------------------*
      *              * Accettazione - segue                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore accettato                            *
      *                  *---------------------------------------------*
           move      w-rig-qta-ass        to   v-num                  .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-ass-qta-900.
       acc-qta-ass-qta-300.
      *              *-------------------------------------------------*
      *              * Accettazione - segue                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In campo                                    *
      *                  *---------------------------------------------*
           move      v-num                to   w-rig-qta-ass          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-ass-qta-900.
       acc-qta-ass-qta-500.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-rig-dec-qta        to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      50                   to   v-pos                  .
           move      "GB"                 to   v-edm                  .
           move      w-rig-qta-ass        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-ass-qta-900.
       acc-qta-ass-qta-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-qta-ass-qta-999.
       acc-qta-ass-qta-999.
