           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      10                   to   v-lin                  .
           add       w-acc-dat-vis-ctr    to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-dat-vis
                    (1, w-acc-dat-vis-ctr)
                                          to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-dat-vis-200.
       vis-dat-vis-999.
           exit.

