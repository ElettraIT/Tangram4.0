      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "ele/com/fls/ioc/obj/iofhvc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hvc                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Campi chiave                                *
      *                  *---------------------------------------------*
           move      w-tes-cod-cli        to   rf-hvc-cod-cli         .
      *                  *---------------------------------------------*
      *                  * Campi non chiave                            *
      *                  *---------------------------------------------*
           move      w-tes-dat-vis (1, 01)
                                          to   rf-hvc-dat-vis (01)    .
           move      w-tes-dat-vis (1, 02)
                                          to   rf-hvc-dat-vis (02)    .
           move      w-tes-dat-vis (1, 03)
                                          to   rf-hvc-dat-vis (03)    .
           move      w-tes-dat-vis (1, 04)
                                          to   rf-hvc-dat-vis (04)    .
           move      w-tes-dat-vis (1, 05)
                                          to   rf-hvc-dat-vis (05)    .
           move      w-tes-dat-vis (1, 06)
                                          to   rf-hvc-dat-vis (06)    .
           move      w-tes-dat-vis (1, 07)
                                          to   rf-hvc-dat-vis (07)    .
           move      w-tes-dat-vis (1, 08)
                                          to   rf-hvc-dat-vis (08)    .
           move      w-tes-dat-vis (1, 09)
                                          to   rf-hvc-dat-vis (09)    .
           move      w-tes-dat-vis (1, 10)
                                          to   rf-hvc-dat-vis (10)    .
           move      w-tes-alx-alf (1)    to   rf-hvc-alx-alf         .
           move      w-tes-alx-num (1)    to   rf-hvc-alx-num         .
       cmp-rec-hvc-999.
           exit.

      *    *===========================================================*
