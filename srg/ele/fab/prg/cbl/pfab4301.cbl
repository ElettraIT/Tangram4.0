      *              *-------------------------------------------------*
      *              * Se numero clienti movimentati inferiore al mi-  *
      *              * nimo richiesto : quantita' fatturata a zero     *
      *              *-------------------------------------------------*
           move      w-det-qta-fat-qfp    to   w-det-snx-ste-qta      .
           if        w-det-qta-fat-clm    <    rr-ncl-mdc
                     move  zero           to   w-det-qta-fat-qfp      .
       prn-sel-rec-300.
      *              *-------------------------------------------------*
      *              * Determinazione scorta minima                    *
      *              *-------------------------------------------------*
           move      w-det-qta-fat-qfp    to   w-det-sco-min-qtt      .
           move      w-det-num-mcp-nme    to   w-det-sco-min-nme      .
           move      rr-pdv-mme           to   w-det-sco-min-pdv      .
           move      w-det-dat-ort-tam    to   w-det-sco-min-tag      .
           move      rf-dcp-dec-qta       to   w-det-sco-min-deq      .
           move      w-ref-fab-430-pdt    to   w-det-sco-min-pdt      .
           perform   det-sco-min-000      thru det-sco-min-999        .
       prn-sel-rec-400.
      *              *-------------------------------------------------*
      *              * Lettura valore precedente                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [fbs]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fab/fls/ioc/obj/ioffbs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fbs                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [fbs]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "MAGDPZ    "         to   f-key                  .
           move      01                   to   rf-fbs-tip-mag         .
           move      rf-dcp-num-pro       to   rf-fbs-num-mag         .
           move      spaces               to   rf-fbs-var-mag         .
           move      rr-dpz-inu           to   rf-fbs-cod-dpz         .
           move      "pgm/fab/fls/ioc/obj/ioffbs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fbs                 .
       prn-sel-rec-600.
      *              *-------------------------------------------------*
      *              * Confronto con valori minimo e massimo determi-  *
      *              * nati                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se richiesto azzeramento               *
      *                  *---------------------------------------------*
           if        rr-agg-ana           =    04
                     go to prn-sel-rec-800.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-fbs-sco-min (1)   >    w-det-sco-min-smn or
                     rf-fbs-sco-min (1)   <    w-det-sco-min-smx
                     go to prn-sel-rec-900.
       prn-sel-rec-800.
      *                  *---------------------------------------------*
      *                  * Se stampa anche esclusi                     *
      *                  *---------------------------------------------*
           if        rr-snx-ste           =    02
                     move  "#"            to   w-det-snx-ste-flg
           else      move  "#"            to   w-cnt-prn-flg-sub      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
      *    * Determinazione data orizzonte temporale per un prodotto   *
      *    *-----------------------------------------------------------*
       det-dat-ort-000.
      *              *-------------------------------------------------*
      *              * Data orizzonte temporale pari a data di base    *
      *              *-------------------------------------------------*
           move      w-det-dat-ort-dtb    to   w-det-dat-ort-dat      .
      *              *-------------------------------------------------*
      *              * Lettura record [aaq] per il prodotto in esame   *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-dat-ort-tpm    to   rf-aaq-tip-mag         .
           move      w-det-dat-ort-cnm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
           if        f-sts                not  = e-not-err
                     move  zero           to   rf-aaq-tmp-apv         .
       det-dat-ort-100.
      *              *-------------------------------------------------*
      *              * Bufferizzazione tempo di approvigionamento me-  *
      *              * dio in giorni                                   *
      *              *-------------------------------------------------*
           move      rf-aaq-tmp-apv       to   w-det-dat-ort-tam      .
      *              *-------------------------------------------------*
      *              * Eventuale aggiustamento tempo di approvigiona-  *
      *              * mento medio in giorni con valore di default     *
      *              *-------------------------------------------------*
           if        w-ref-def-tam        not  = zero and
                     w-det-dat-ort-tam    =    zero
                     move  w-ref-def-tam  to   w-det-dat-ort-tam      .
      *              *-------------------------------------------------*
      *              * Determinazione data maggiorata del numero gior- *
      *              * ni di approvigionamento                         *
      *              *-------------------------------------------------*
           move      w-det-dat-ort-dat    to   w-det-dat-nrg-dtb      .
           move      w-det-dat-ort-tam    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-det-dat-ort-dat      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione altri valori dedotti da record  *
      *              * [aaq]                                           *
      *              *-------------------------------------------------*
           move      rf-aaq-lot-acq       to   w-det-dat-ort-lda      .
       det-dat-ort-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' fatturate nel periodo            *
      *    *-----------------------------------------------------------*
       det-qta-fat-000.
      *              *-------------------------------------------------*
      *              * Ciclo per [bit] su bolle diverse                *
      *              *                                                 *
      *              * ELETTRA                                         *
      *              *-------------------------------------------------*
           perform   det-qta-fat-bit-000  thru det-qta-fat-bit-999    .
       det-qta-fat-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qta-fat-999.
       det-qta-fat-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' fatturate nel periodo            *
      *    *                                                           *
      *    * Ciclo per [bit] su bolle diverse                          *
      *    *-----------------------------------------------------------*
       det-qta-fat-bit-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-qta-fat-qfp      .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero elementi in tabella     *
      *              * clienti movimentati                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-qta-fat-ele      .
       det-qta-fat-bit-100.
      *              *-------------------------------------------------*
      *              * Start su file [bir]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      01                   to   rf-bir-cod-dpz         .
           move      w-det-qta-fat-tpm    to   rf-bir-tip-mag         .
           move      w-det-qta-fat-cnm    to   rf-bir-num-pro         .
           move      w-det-qta-fat-dti    to   rf-bir-dat-doc         .
           move      zero                 to   rf-bir-num-doc         .
           move      zero                 to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-qta-fat-bit-200.
       det-qta-fat-bit-120.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bir]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-qta-fat-bit-200.
       det-qta-fat-bit-130.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-bir-tip-mag       not  = w-det-qta-fat-tpm or
                     rf-bir-num-pro       not  = w-det-qta-fat-cnm or
                     rf-bir-dat-doc       >    w-det-qta-fat-dtf
                     go to det-qta-fat-bit-200.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su codice dipendenza              *
      *                  *---------------------------------------------*
           if        rf-bir-cod-dpz       not  = 01
                     go to det-qta-fat-bit-120.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo documento                 *
      *                  *                                             *
      *                  * Aggiornamento - Giorgio 12/12/24            *
      *                  *                                             *
      *                  * ELETTRA                                     *
      *                  *---------------------------------------------*
           if        rf-bir-cod-tmb       not  = "BILFS"  and
                     rf-bir-cod-tmb       not  = "BIOFS"  and
                     rf-bir-cod-tmb       not  = "BIRFS"  and
                     rf-bir-cod-tmb       not  = "BIVFS"  and
                     rf-bir-cod-tmb       not  = "BNFFS"  and
                     rf-bir-cod-tmb       not  = "BSOFS"  and
                     rf-bir-cod-tmb       not  = "BVFO "  and
                     rf-bir-cod-tmb       not  = "BVFS "  and
                     rf-bir-cod-tmb       not  = "BRVE "
                     go to det-qta-fat-bit-120.
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        rf-bir-tip-rig (1:1) not  = "P" or
                     rf-bir-tip-rig (2:1) not  = " "
                     go to det-qta-fat-bit-120.
      *                  *---------------------------------------------*
      *                  * Test su mese da escludere                   *
      *                  *---------------------------------------------*
           move      rf-bir-dat-doc       to   w-det-qta-fat-wdt      .
           if        w-det-qta-fat-mde    not  = zero and
                     w-det-qta-fat-wme    =    w-det-qta-fat-mde
                     go to det-qta-fat-bit-120.
      *              *-------------------------------------------------*
      *              * Aggiornamento quantita' fatturata nel periodo   *
      *              * in funzione del tipo documento                  *
      *              *-------------------------------------------------*
           if        rf-bir-cod-tmb       =    "BRVE "
                     subtract rf-bir-qta-ven
                                          from w-det-qta-fat-qfp
           else      add      rf-bir-qta-ven
                                          to   w-det-qta-fat-qfp      .
       det-qta-fat-bit-140.
      *              *-------------------------------------------------*
      *              * Aggiornamento tabella clienti movimentati       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-qta-fat-c01      .
       det-qta-fat-bit-142.
           add       1                    to   w-det-qta-fat-c01      .
           if        w-det-qta-fat-c01    >    w-det-qta-fat-ele
                     go to det-qta-fat-bit-144.
           if        rf-bir-cod-arc       =    w-det-qta-fat-cli
                                              (w-det-qta-fat-c01)
                     go to det-qta-fat-bit-150.
           go to     det-qta-fat-bit-142.
       det-qta-fat-bit-144.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione nuovo elemento              *
      *                  *---------------------------------------------*
           if        w-det-qta-fat-ele    <    w-det-qta-fat-max
                     add   1              to   w-det-qta-fat-ele      .
           move      rf-bir-cod-arc       to   w-det-qta-fat-cli
                                              (w-det-qta-fat-ele)     .
       det-qta-fat-bit-150.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [bir]     *
      *              *-------------------------------------------------*
           go to     det-qta-fat-bit-120.
       det-qta-fat-bit-200.
      *              *-------------------------------------------------*
      *              * Clienti movimentati nel periodo                 *
      *              *-------------------------------------------------*
           move      w-det-qta-fat-ele    to   w-det-qta-fat-clm      .
       det-qta-fat-bit-999.
           exit.

      *    *===========================================================*
      *    * Determinazione scorta minima per il prodotto              *
      *    *-----------------------------------------------------------*
       det-sco-min-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sco-min-qsm      .
           move      zero                 to   w-det-sco-min-smx      .
           move      zero                 to   w-det-sco-min-smn      .
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        w-det-sco-min-nme    =    zero or
                     w-det-sco-min-qtt    =    zero
                     go to det-sco-min-999.
      *              *-------------------------------------------------*
      *              * Determinazione media mensile del periodo        *
      *              *-------------------------------------------------*
           divide    w-det-sco-min-nme    into w-det-sco-min-qtt
                                        giving w-det-sco-min-wqt      .
       det-sco-min-100.
      *              *-------------------------------------------------*
      *              * Aggiustamento quantita' media mensile con il    *
      *              * coefficiente di variazione                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-det-sco-min-pdv    =    zero or
                     w-det-sco-min-wqt    =    zero
                     go to det-sco-min-200.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  w-det-sco-min-pdv    by   w-det-sco-min-wqt      .
       det-sco-min-200.
      *              *-------------------------------------------------*
      *              * Determinazione numero mesi per approvigionamen- *
      *              * to                                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-det-sco-min-tag    =    zero
                     go to det-sco-min-300.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda della modalita' di e-  *
      *                  * spressione tempo di consegna                *
      *                  *---------------------------------------------*
           if        w-prs-mde-tdc        =    1
                     go to det-sco-min-240
           else      go to det-sco-min-220.
       det-sco-min-220.
      *                  *---------------------------------------------*
      *                  * Modalita' di espressione : Giorni           *
      *                  *---------------------------------------------*
           divide    30                   into w-det-sco-min-tag
                                        giving w-det-sco-min-tam
                                               rounded                .
           go to     det-sco-min-260.
       det-sco-min-240.
      *                  *---------------------------------------------*
      *                  * Modalita' di espressione : Settimane        *
      *                  *---------------------------------------------*
           divide    28                   into w-det-sco-min-tag
                                        giving w-det-sco-min-tam
                                               rounded                .
           go to     det-sco-min-260.
       det-sco-min-260.
      *                  *---------------------------------------------*
      *                  * Aggiustamento scorta minima                 *
      *                  *---------------------------------------------*
           multiply  w-det-sco-min-tam    by   w-det-sco-min-wqt      .
       det-sco-min-300.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           if        w-det-sco-min-deq    =    0
                     move  w-det-sco-min-wq0
                                          to   w-det-sco-min-qsm
           else if   w-det-sco-min-deq    =    1
                     move  w-det-sco-min-wq1
                                          to   w-det-sco-min-qsm
           else if   w-det-sco-min-deq    =    2
                     move  w-det-sco-min-wq2
                                          to   w-det-sco-min-qsm
           else if   w-det-sco-min-deq    =    3
                     move  w-det-sco-min-wq3
                                          to   w-det-sco-min-qsm      .
       det-sco-min-400.
      *              *-------------------------------------------------*
      *              * Determinazione valori di tolleranza minimo e    *
      *              * massimo                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione valori                     *
      *                  *---------------------------------------------*
           move      w-det-sco-min-qsm    to   w-det-sco-min-smx      .
           move      w-det-sco-min-qsm    to   w-det-sco-min-smn      .
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-det-sco-min-pdt    =    zero
                     go to det-sco-min-500.
      *                  *---------------------------------------------*
      *                  * Determinazione quantita' di scostamento     *
      *                  *---------------------------------------------*
           multiply  w-det-sco-min-qsm    by   w-det-sco-min-pdt
                                        giving w-det-sco-min-wqs      .
           divide 100                     into w-det-sco-min-wqs
                                               rounded                .
      *                  *---------------------------------------------*
      *                  * Aggiustamento numero decimali               *
      *                  *---------------------------------------------*
           move      w-det-sco-min-wqs    to   w-det-sco-min-wqt      .
           if        w-det-sco-min-deq    =    0
                     move  w-det-sco-min-wq0
                                          to   w-det-sco-min-wqs
           else if   w-det-sco-min-deq    =    1
                     move  w-det-sco-min-wq1
                                          to   w-det-sco-min-wqs
           else if   w-det-sco-min-deq    =    2
                     move  w-det-sco-min-wq2
                                          to   w-det-sco-min-wqs
           else if   w-det-sco-min-deq    =    3
                     move  w-det-sco-min-wq3
                                          to   w-det-sco-min-wqs      .
      *                  *---------------------------------------------*
      *                  * Completamento valore massimo                *
      *                  *---------------------------------------------*
           add       w-det-sco-min-wqs    to   w-det-sco-min-smx      .
      *                  *---------------------------------------------*
      *                  * Completamento valore minimo                 *
      *                  *---------------------------------------------*
           subtract  w-det-sco-min-wqs    from w-det-sco-min-smn      .
       det-sco-min-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-sco-min-999.
       det-sco-min-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Composizione area per rotture      *
      *    *-----------------------------------------------------------*
       prn-cmp-rot-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo ordinamento     *
      *              *-------------------------------------------------*
           if        w-tip-ord-tip-ord    =    01 or
                     w-tip-ord-tip-ord    =    02
                     go to prn-cmp-rot-300
           else if   w-tip-ord-tip-ord    =    03 or
                     w-tip-ord-tip-ord    =    04
                     go to prn-cmp-rot-600.
       prn-cmp-rot-300.
      *              *-------------------------------------------------*
      *              * Se tipo ordinamento :                           *
      *              * - Per classe, gruppo, sottogruppo, codice ma-   *
      *              *   gazzino                                       *
      *              * - Per classe, gruppo, sottogruppo, descrizione  *
      *              *   magazzino                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura classe        *
      *                  *---------------------------------------------*
           move      rf-dcp-cla-pro       to   w-rot-l03-cod-cla      .
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura gruppo        *
      *                  *---------------------------------------------*
           move      rf-dcp-gru-pro       to   w-rot-l02-cod-gru      .
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura sottogruppo   *
      *                  *---------------------------------------------*
           move      rf-dcp-sgr-pro       to   w-rot-l01-cod-sgr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-cmp-rot-999.
       prn-cmp-rot-600.
      *              *-------------------------------------------------*
      *              * Se tipo ordinamento :                           *
      *              * - Per codice magazzino                          *
      *              * - Per descrizione magazzino                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura classe         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l03-cod-cla      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura gruppo         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l02-cod-gru      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura sottogruppo    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l01-cod-sgr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-cmp-rot-999.
       prn-cmp-rot-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per inizio ciclo        *
      *    *-----------------------------------------------------------*
       prn-ini-cic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-ini-cic-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo ordinamento       *
      *              *-------------------------------------------------*
           if        w-tip-ord-tip-ord    =    01 or
                     w-tip-ord-tip-ord    =    02
                     go to prn-ini-cic-300
           else if   w-tip-ord-tip-ord    =    03 or
                     w-tip-ord-tip-ord    =    04
                     go to prn-ini-cic-600.
       prn-ini-cic-300.
      *              *-------------------------------------------------*
      *              * Se ordinamento per Classe, gruppo e sottogruppo *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero di linee effettive im-  *
      *                  * pegnate dalla fincatura per il dettaglio e  *
      *                  * la relativa sottolineatura                  *
      *                  *---------------------------------------------*
           move      2                    to   w-cgs-det-idf          .
      *                  *---------------------------------------------*
      *                  * Preparazione segnali di richiesta intesta-  *
      *                  * zione per inizio classe gruppo sottogruppo  *
      *                  *---------------------------------------------*
           if        rr-tip-slp           =    02
                     move  "S"            to   w-cgs-cla-int
                     move  "N"            to   w-cgs-gru-int
                     move  "N"            to   w-cgs-sgr-int
