      *    *===========================================================*
      *    * Determinazione numero mesi compresi nel periodo di rife-  *
      *    * rimento                                                   *
      *    *-----------------------------------------------------------*
       det-num-mcp-000.
      *              *-------------------------------------------------*
      *              * Determinazione mese/anno della data finale      *
      *              *-------------------------------------------------*
           move      w-det-num-mcp-dtf    to   w-det-num-mcp-wdt      .
           move      w-det-num-mcp-wme    to   w-det-num-mcp-wmf      .
           move      w-det-num-mcp-wsa    to   w-det-num-mcp-waf      .
      *              *-------------------------------------------------*
      *              * Data iniziale in work di comodo ridefinita      *
      *              *-------------------------------------------------*
           move      w-det-num-mcp-dti    to   w-det-num-mcp-wdt      .
      *              *-------------------------------------------------*
      *              * Inizializzazione valore in uscita               *
      *              *-------------------------------------------------*
           if        w-det-num-mcp-mde    not  = zero and
                     w-det-num-mcp-wme    =    w-det-num-mcp-mde
                     move  zero           to   w-det-num-mcp-nme
           else      move  1              to   w-det-num-mcp-nme      .
       det-num-mcp-100.
      *              *-------------------------------------------------*
      *              * Ciclo di incremento mese                        *
      *              *-------------------------------------------------*
           add       1                    to   w-det-num-mcp-wme      .
           if        w-det-num-mcp-wme    >    12
                     move  01             to   w-det-num-mcp-wme
                     add   1              to   w-det-num-mcp-wsa      .
      *              *-------------------------------------------------*
      *              * Test se raggiunto il mese/anno della data fina- *
      *              * le                                              *
      *              *-------------------------------------------------*
           if        w-det-num-mcp-wme    not  < w-det-num-mcp-wmf and
                     w-det-num-mcp-wsa    =    w-det-num-mcp-waf
                     go to det-num-mcp-200.
      *              *-------------------------------------------------*
      *              * Test se mese da escludere                       *
      *              *-------------------------------------------------*
           if        w-det-num-mcp-mde    not  = zero and
                     w-det-num-mcp-wme    =    w-det-num-mcp-mde
                     go to det-num-mcp-100.
      *              *-------------------------------------------------*
      *              * Incremento numero mesi                          *
      *              *-------------------------------------------------*
           add       1                    to   w-det-num-mcp-nme      .
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-num-mcp-100.
       det-num-mcp-200.
      *              *-------------------------------------------------*
      *              * Incremento numero mesi per l'ultima volta       *
      *              *-------------------------------------------------*
           if        w-det-num-mcp-mde    not  = zero and
                     w-det-num-mcp-wme    =    w-det-num-mcp-mde
                     go to det-num-mcp-999
           else      add   1              to   w-det-num-mcp-nme      .
       det-num-mcp-999.
           exit.

