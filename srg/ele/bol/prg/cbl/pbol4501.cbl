      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su archivio [bit]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FATARC     "        to   f-key                  .
           move      "S"                  to   rf-bit-fat-snx         .
           move      zero                 to   rf-bit-fat-dat         .
           move      zero                 to   rf-bit-fat-num         .
           move      zero                 to   rf-bit-fat-npb         .
           move      "C"                  to   rf-bit-tip-arc         .
           move      zero                 to   rf-bit-arc-plf         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Read-next su archivio [bit]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su data documento                  *
      *                      *-----------------------------------------*
           if        rf-bit-fat-snx       not  = "S"  or
                     rf-bit-fat-dat       not  = zero or
                     rf-bit-fat-num       not  = zero or
                     rf-bit-fat-npb       not  = zero or
                     rf-bit-tip-arc       not  = "C"
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record [bit]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza : se diverso, *
      *                      * a riciclo                               *
      *                      *-----------------------------------------*
           if        rf-bit-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Normalizzazione anagrafica cliente      *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica cliente principale   *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-bit-cod-arc       to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Test su codice categoria                *
      *                      *-----------------------------------------*
           if        rr-cod-zs2           =    zero
                     go to stp-srt-inp-500.
           if        rf-dcc-cod-cat       not  = rr-cod-zs2
                     go to stp-srt-inp-100.
       stp-srt-inp-500.
      *                      *-----------------------------------------*
      *                      * Normalizzazione anagrafica categoria    *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zst                 .
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica categoria            *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLS    "         to   f-key                  .
           move      02                   to   rf-zst-tip-cls         .
           move      rf-dcc-cod-cat       to   rf-zst-cod-cls         .
           move      "pgm/dcc/fls/ioc/obj/iofzst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zst                 .
           if        f-sts                not  = e-not-err
                     move  "(Senza categoria)"
                                          to   rf-zst-des-cls         .
       stp-srt-inp-600.
      *                  *---------------------------------------------*
      *                  * Preparazione record di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione iniziale                *
      *                      *-----------------------------------------*
           move      spaces               to   srt-rec                .
      *                      *-----------------------------------------*
      *                      * Chiave di sort                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Descrizione categoria               *
      *                          *-------------------------------------*
           move      rf-zst-des-cls       to   srt-des-zs2            .
      *                          *-------------------------------------*
      *                          * Codice categoria                    *
      *                          *-------------------------------------*
           move      rf-dcc-cod-cat       to   srt-cod-zs2            .
      *                          *-------------------------------------*
      *                          * Ragione sociale cliente in chiave   *
      *                          *-------------------------------------*
           move      rf-dcc-rag-key       to   srt-rag-key            .
      *                          *-------------------------------------*
      *                          * Codice cliente                      *
      *                          *-------------------------------------*
           move      rf-bit-cod-arc       to   srt-cod-cli            .
      *                          *-------------------------------------*
      *                          * Data documento                      *
      *                          *-------------------------------------*
           move      rf-bit-dat-doc       to   srt-dat-doc            .
      *                          *-------------------------------------*
      *                          * Numero documento                    *
      *                          *-------------------------------------*
           move      rf-bit-num-doc       to   w-det-num-doc          .
           move      w-det-num-doc-prg    to   srt-num-doc            .
      *                      *-----------------------------------------*
      *                      * Dati di sort                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ragione sociale cliente             *
      *                          *-------------------------------------*
           move      rf-dcc-rag-soc       to   srt-rag-soc            .
      *                          *-------------------------------------*
      *                          * Tipo documento                      *
      *                          *-------------------------------------*
           move      rf-bit-cod-tmb       to   srt-tip-doc            .
      *                          *-------------------------------------*
      *                          * Codice dipendenza cliente           *
      *                          *-------------------------------------*
           move      rf-bit-dpz-arc       to   srt-dpz-cli            .
      *                          *-------------------------------------*
      *                          * Elementi valuta documento           *
      *                          *-------------------------------------*
           move      rf-bit-sgl-vpf       to   srt-sgl-vpf            .
           move      rf-bit-dec-vpf       to   srt-dec-vpf            .
           move      rf-bit-tdc-vpf       to   srt-tdc-vpf            .
           move      rf-bit-cdc-vpf       to   srt-cdc-vpf            .
      *                          *-------------------------------------*
      *                          * Determinazione totale documento     *
      *                          *-------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *                          *-------------------------------------*
      *                          * Eventuale inversione del segno nel  *
      *                          * caso di Bolla di Reso su vendita da *
      *                          * Cliente                             *
      *                          *-------------------------------------*
           if        rf-bit-dri-mgd       not  = zero and
                     rf-bit-nri-mgd       not  = spaces
                     multiply -1          by   w-det-tot-doc-tot      .
      *                          *-------------------------------------*
      *                          * Totale documento                    *
      *                          *-------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-doc            .
      *                          *-------------------------------------*
      *                          * Data inizio trasporto               *
      *                          *-------------------------------------*
           move      rf-bit-dat-itr       to   srt-dat-itr            .
       stp-srt-inp-800.
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Riciclo a record [bit] successivo           *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

