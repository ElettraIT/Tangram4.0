           move      w-exp-snx-dcn-num    to   v-ldt                  .
           move      "SN#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-exp-snx-dcn-tbl    to   v-txt                  .
      *
           if        w-rig-snx-dcn        =    "#"
                     move  1              to   v-num
           else if   w-rig-snx-dcn        =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
