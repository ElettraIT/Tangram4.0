           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Griglia vuota per il dettaglio 2            *
      *                  *---------------------------------------------*
           perform   gri-vuo-de2-000      thru gri-vuo-de2-999        .
      *                  *---------------------------------------------*
      *                  * Indirizzo                                   *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      002                  to   p-pos                  .
           move      w-inl-dcm-via        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-liv-det-600.
      *              *-------------------------------------------------*
      *              * Riga 3                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Griglia vuota per il dettaglio 3            *
      *                  *---------------------------------------------*
           perform   gri-vuo-de3-000      thru gri-vuo-de3-999        .
      *                  *---------------------------------------------*
      *                  * Localita'                                   *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      002                  to   p-pos                  .
           move      w-inl-dcm-loc        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-liv-det-900.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura dettaglio                        *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-stp-amp-lin    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "+----------------------------------------+--------
      -              "--+--------+-----+--+------+----------+-+---------
      -              "------+----------+----------+   "
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     sta-liv-det-999.
       sta-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *                                                           *
      *    * Subroutine di determinazione volume                       *
      *    *-----------------------------------------------------------*
       det-col-vol-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [bix]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbix"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bix                 .
      *              *-------------------------------------------------*
      *              * Lettura record [bix]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bit-num-prt       to   rf-bix-num-prt         .
           move      zero                 to   rf-bix-num-prg         .
           move      11                   to   rf-bix-tip-rec         .
           move      "pgm/bol/fls/ioc/obj/iofbix"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bix                 .
       det-col-vol-030.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           if        rf-bix-des-400       =    spaces
                     move  spaces         to   w-all-str-alf
                     go to det-col-vol-900.
       det-col-vol-050.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vol-col-vlm      .
           move      spaces               to   w-det-vol-col-err      .
           move      rf-bix-des-400       to   w-det-vol-col-ele      .
       det-col-vol-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per 9 righe da 16 caratteri  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vol-col-vol      .
           move      zero                 to   w-det-vol-col-wol      .
           move      zero                 to   w-det-vol-col-el1      .
           move      zero                 to   w-det-vol-col-el2      .
           move      zero                 to   w-det-vol-col-el3      .
           move      zero                 to   w-det-vol-col-coe      .
           move      spaces               to   w-det-vol-col-coa      .
      *
           move      zero                 to   w-det-vol-col-ctr      .
       det-col-vol-200.
           add       1                    to   w-det-vol-col-ctr      .
           if        w-det-vol-col-ctr    >    8
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Test su contenuto riga                          *
      *              *-------------------------------------------------*
           if        det-vol-col-dim
                    (w-det-vol-col-ctr)   =    spaces
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Eventuale coefficiente                          *
      *              *-------------------------------------------------*
           move      det-vol-col-dim
                    (w-det-vol-col-ctr)
                    (15 : 02)             to   w-det-vol-col-coa      .
      *              *-------------------------------------------------*
      *              * Conversione coefficiente                        *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      02                   to   v-car                  .
           move      w-det-vol-col-coa    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-coe      .
      *              *-------------------------------------------------*
      *              * Sostituzione eventuali 'X' con 'x'              *
      *              *-------------------------------------------------*
           inspect   det-vol-col-dim
                    (w-det-vol-col-ctr)
                                     replacing all "X" by   "x"       .
      *              *-------------------------------------------------*
      *              * Split della riga                                *
      *              *-------------------------------------------------*
           move      det-vol-col-dim
                    (w-det-vol-col-ctr)
                    (01 : 14)             to   w-all-str-alf          .
           move      "x"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
      *              *-------------------------------------------------*
      *              * Test che contenga 3 elementi                    *
      *              *-------------------------------------------------*
           if        w-all-str-num        not  = 3
                     move  "#"            to   w-det-vol-col-err
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Conversione elemento 1                          *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      04                   to   v-car                  .
           move      w-all-str-cat (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-el1      .
      *              *-------------------------------------------------*
      *              * Conversione elemento 2                          *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      04                   to   v-car                  .
           move      w-all-str-cat (2)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-el2      .
      *              *-------------------------------------------------*
      *              * Conversione elemento 3                          *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      04                   to   v-car                  .
           move      w-all-str-cat (3)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-el3      .
      *              *-------------------------------------------------*
      *              * Test che tutti gli elementi siano diversi da    *
      *              * zero                                            *
      *              *-------------------------------------------------*
           if        w-det-vol-col-el1    =    zero or
                     w-det-vol-col-el2    =    zero or
                     w-det-vol-col-el3    =    zero
                     move  "#"            to   w-det-vol-col-err
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Calcolo del volume                              *
      *              *-------------------------------------------------*
           multiply  w-det-vol-col-el1    by   w-det-vol-col-el2
                                        giving w-det-vol-col-wol      .
           multiply  w-det-vol-col-el3    by   w-det-vol-col-wol
                                        giving w-det-vol-col-vol      .
      *
           divide    1000000              into w-det-vol-col-vol
                                               rounded                .
      *              *-------------------------------------------------*
      *              * Eventuale moltiplicatore                        *
      *              *-------------------------------------------------*
           if        w-det-vol-col-coe    >    zero
                     multiply  w-det-vol-col-coe 
                                          by   w-det-vol-col-vol      .
      *              *-------------------------------------------------*
      *              * Cumulo del volume                               *
      *              *-------------------------------------------------*
           add       w-det-vol-col-vol    to   w-det-vol-col-vlm      .
       det-col-vol-600.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-col-vol-200.
       det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Editing valore calcolato                        *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-det-vol-col-vlm    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   w-det-vol-col-ved      .
      *              *-------------------------------------------------*
      *              * Test se errore                                  *
      *              *-------------------------------------------------*
           if        w-det-vol-col-vlm    =    zero or
                     w-det-vol-col-err    not  = spaces
                     move  "ERR!"         to   w-det-vol-col-ved      .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      15                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      space                to   w-all-str-cat (1)      .
           move      w-det-vol-col-ved    to   w-all-str-cat (2)      .
           move      "mc."                to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
       det-col-vol-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-col-vol-999.
       det-col-vol-999.
           exit.

