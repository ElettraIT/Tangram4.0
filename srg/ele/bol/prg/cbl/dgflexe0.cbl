           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *              *-------------------------------------------------*
      *              * [fnt]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *              *-------------------------------------------------*
      *              * [dcf]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * [age]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
      *              *-------------------------------------------------*
      *              * [ada]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *              *-------------------------------------------------*
      *              * [gxc]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *              *-------------------------------------------------*
      *              * Open modulo di determinazione contatti          *
      *              *-------------------------------------------------*
           perform   con-arc-tip-opn-000  thru con-arc-tip-opn-999    .
       opn-999.
           exit.

      *    *===========================================================*
      *    * Close                                                     *
      *    *-----------------------------------------------------------*
       cls-000.
      *              *-------------------------------------------------*
      *              * Decremento contatore Open modulo                *
      *              *-------------------------------------------------*
           subtract  1                    from w-nol-ctr-opn          .
      *              *-------------------------------------------------*
      *              * [bit]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *              *-------------------------------------------------*
      *              * [bix]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbix"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bix                 .
      *              *-------------------------------------------------*
      *              * [vet]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofvet"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vet                 .
      *              *-------------------------------------------------*
      *              * [cli]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *              *-------------------------------------------------*
      *              * [dcc]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *              *-------------------------------------------------*
      *              * [fnt]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *              *-------------------------------------------------*
      *              * [dcf]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * [age]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
      *              *-------------------------------------------------*
      *              * [ada]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *              *-------------------------------------------------*
      *              * [gxc]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *              *-------------------------------------------------*
      *              * Close modulo di determinazione contatti         *
      *              *-------------------------------------------------*
           perform   con-arc-tip-cls-000  thru con-arc-tip-cls-999    .
       cls-999.
           exit.

      *    *===========================================================*
      *    * Test cancellabilita' modulo                               *
      *    *-----------------------------------------------------------*
       tcm-000.
      *              *-------------------------------------------------*
      *              * Se il contatore di Open e' a zero il modulo e'  *
      *              * cancellabile, altrimenti non lo e'              *
      *              *-------------------------------------------------*
           if        w-nol-ctr-opn        =    zero
                     move  spaces         to   d-gfl-exe-exi-sts
           else      move  "#"            to   d-gfl-exe-exi-sts      .
       tcm-999.
           exit.

      *    *===========================================================*
      *    * Generazione file per vettore                              *
      *    *-----------------------------------------------------------*
       gfl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [bit]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *              *-------------------------------------------------*
      *              * Lettura record [bit]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT     "        to   f-key                  .
           move      d-gfl-exe-prt-bit    to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
       gfl-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del codice vettore       *
      *              *-------------------------------------------------*
           if        rf-bit-cod-vet       =    15 or
                     rf-bit-cod-vet       =    10
                     perform  gfl-exc-000 thru gfl-exc-999
           else if   rf-bit-cod-vet       =    11
                     perform  gfl-brt-000 thru gfl-brt-999
           else      go to    gfl-900.
       gfl-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     gfl-999.
       gfl-999.
           exit.

      *    *===========================================================*
      *    * Generazione file per vettore                              *
      *    *                                                           *
      *    * Subroutine per Executive e TNT                            *
      *    *-----------------------------------------------------------*
       gfl-exc-000.
      *              *-------------------------------------------------*
      *              * Open file sequenziale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Pathname di base da segreteria              *
      *                  *---------------------------------------------*
           move      "PB"                 to   s-ope                  .
           move      "asc "               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                          using s                     .
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-det-pth-fso-pth      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del corriere           *
      *                  *---------------------------------------------*
           if        rf-bit-cod-vet       =    15
                     go to gfl-exc-100
           else if   rf-bit-cod-vet       =    10
                     go to gfl-exc-120
           else      go to gfl-exc-100.
       gfl-exc-100.
      *                  *---------------------------------------------*
      *                  * Se Executive                                *
      *                  *---------------------------------------------*
           string    s-pat      delimited by   spaces
                     "/executive/tmp/"
                                delimited by   size
                     rf-bit-num-prt
                                delimited by   size
                                          into w-det-pth-fso-pth      .
           go to     gfl-exc-150.
       gfl-exc-120.
           move      rf-bit-num-doc       to   w-num-ext              .
      *                  *---------------------------------------------*
      *                  * Se TNT                                      *
      *                  *---------------------------------------------*
           string    s-pat      delimited by   spaces
                     "/executive/TNT/tmp/"
                                delimited by   size
                     w-num-ext-num
                                delimited by   size
                     ".txt"
                                delimited by   size
                                          into w-det-pth-fso-pth      .
           go to     gfl-exc-150.
       gfl-exc-150.
      *                  *---------------------------------------------*
      *                  * Apertura del file in output                 *
      *                  *---------------------------------------------*
           move      "OO"                 to   g-ope                  .
           move      "seq "               to   g-nam                  .
           move      w-det-pth-fso-pth    to   g-pat                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Determinazione destinatario bolla           *
      *                  *---------------------------------------------*
           perform   det-dst-bol-000      thru det-dst-bol-999        .
       gfl-exc-200.
      *              *-------------------------------------------------*
      *              * Normalizzazione record di output                *
      *              *-------------------------------------------------*
           move      spaces               to   w-oex                  .
      *              *-------------------------------------------------*
      *              * Preparazione record di output                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ragione sociale                             *
      *                  *---------------------------------------------*
           move      w-inl-dcm-rs1        to   w-oex-rag-soc          .
      *                  *---------------------------------------------*
      *                  * Indirizzo                                   *
      *                  *---------------------------------------------*
           move      w-inl-dcm-via        to   w-oex-via-dcc          .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [gxc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [gxc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      w-inl-dcm-cmn        to   rf-gxc-cod-cmn         .
           move      w-inl-dcm-fzn        to   rf-gxc-cod-fzn         .
           move      w-inl-dcm-lct        to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                  *---------------------------------------------*
      *                  * Test se record esistente                    *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to gfl-exc-220
           else      go to gfl-exc-240.
       gfl-exc-220.
      *                  *---------------------------------------------*
      *                  * Record esistente                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Localita'                               *
      *                      *-----------------------------------------*
           move      rf-gxc-des-cfl       to   w-oex-loc-dcc          .                                               
      *                      *-----------------------------------------*
      *                      * CAP                                     *
      *                      *-----------------------------------------*
           move      rf-gxc-cap-avp       to   w-oex-cap-dcc          .
      *                      *-----------------------------------------*
      *                      * Provincia                               *
      *                      *-----------------------------------------*
           move      rf-gxc-cod-prv       to   w-oex-prv-dcc          .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     gfl-exc-260.
       gfl-exc-240.
      *                  *---------------------------------------------*
      *                  * Record non esistente                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se localita' a spazi : oltre            *
      *                      *-----------------------------------------*
           if        w-inl-dcm-loc        =    spaces
                     move  spaces         to   w-oex-prv-dcc
                     move  spaces         to   w-oex-cap-dcc
                     move  spaces         to   w-oex-loc-dcc
                     go to gfl-exc-260.
      *                      *-----------------------------------------*
      *                      * Provincia                               *
      *                      *-----------------------------------------*
           move      w-inl-dcm-loc        to   w-wrk-loc              .
           move      40                   to   w-wrk-pnt              .
       gfl-exc-242.
           if        w-wrk-loc-chr
                    (w-wrk-pnt)           =    spaces
                     subtract 1           from w-wrk-pnt
