      *
           if        w-let-arc-osx-flg    not  = spaces
                     go to buf-rig-ods-308.
      *
           move      w-let-arc-osx-des    to   w-buf-rig-ods-wde      .
      *
           go to     buf-rig-ods-350.
       buf-rig-ods-308.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del flag di e-   *
      *                      * stensione alla descrizione              *
      *                      *-----------------------------------------*
           if        rf-osr-des-ext       =    0
                     go to buf-rig-ods-310
           else if   rf-osr-des-ext       =    1
                     go to buf-rig-ods-320
           else if   rf-osr-des-ext       =    2
