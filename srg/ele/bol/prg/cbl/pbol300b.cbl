           if        w-bro-ctr-001        =    w-bro-num-ele
                     go to car-rig-cat-obr-999.
           move      w-bro-ctr-001        to   w-bro-ctr-002
                                               w-bro-ctr-003          .
           move      w-bro-num-prg
                    (w-bro-ctr-001)       to   w-bro-ctr-svk          .
       car-rig-cat-obr-200.
           add       1                    to   w-bro-ctr-002          .
           if        w-bro-ctr-002        >    w-bro-num-ele
                     go to car-rig-cat-obr-300.
           if        w-bro-num-prg
                    (w-bro-ctr-002)       >    w-bro-ctr-svk
                     go to car-rig-cat-obr-200.
           move      w-bro-ctr-002        to   w-bro-ctr-003          .
           move      w-bro-num-prg
                    (w-bro-ctr-002)       to   w-bro-ctr-svk          .
           go to     car-rig-cat-obr-200.
       car-rig-cat-obr-300.
           move      w-bro-ctr-001        to   w-bro-ctr-004          .          
           if        w-bro-ctr-svk        >    w-bro-num-prg
                                              (w-bro-ctr-004)
                     go to car-rig-cat-obr-100.
           move      w-bro-sng-ele
                    (w-bro-ctr-003)       to   w-bro-sng-ele
                                              (w-bro-max-ele)         .
           move      w-bro-sng-ele
                    (w-bro-ctr-004)       to   w-bro-sng-ele
                                              (w-bro-ctr-003)         .
           move      w-bro-sng-ele
                    (w-bro-max-ele)       to   w-bro-sng-ele
                                              (w-bro-ctr-004)         .
           go to     car-rig-cat-obr-100.
       car-rig-cat-obr-999.
