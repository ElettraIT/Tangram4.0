           move      spaces               to   w-bro-flg-ids
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Flag di forzatura a saldo                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-bro-flg-fzs
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Quantita' residua                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-bro-qta-res
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Si/No addebito o commento                   *
      *                  *---------------------------------------------*
           move      w-ref-def-snc        to   w-bro-snx-aoc
                                              (w-bro-num-ele)         .
       buf-rig-ods-400.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale file [ocr]       *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-200.
       buf-rig-ods-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-999.
       buf-rig-ods-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione righe ordine di spedizione da trattare    *
      *    *                                                           *
      *    * Subroutine di preparazione castelletto righe in memoria   *
      *    *-----------------------------------------------------------*
       buf-rig-ods-pcr-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore elementi              *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-rig-ods-ctr      .
      *              *-------------------------------------------------*
      *              * Normalizzazione comodi di visualizzazione       *
      *              *-------------------------------------------------*
           move      "NO"                 to   w-edt-qta-inc-ope      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
       buf-rig-ods-pcr-100.
      *              *-------------------------------------------------*
      *              * Start su file [osr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-buf-rig-ods-prt    to   rf-osr-num-prt         .
           move      zero                 to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito della start                   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to buf-rig-ods-pcr-900.
       buf-rig-ods-pcr-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [ocr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to buf-rig-ods-pcr-900.
       buf-rig-ods-pcr-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-osr-num-prt       not  = w-buf-rig-ods-prt
                     go to buf-rig-ods-pcr-900.
       buf-rig-ods-pcr-400.
       buf-rig-ods-pcr-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-rig-ods-ctr      .
      *              *-------------------------------------------------*
      *              * Test sul contatore                              *
      *              *-------------------------------------------------*
           if        w-buf-rig-ods-ctr    >    w-buf-rig-ods-max
                     go to buf-rig-ods-pcr-900.
       buf-rig-ods-pcr-520.
      *              *-------------------------------------------------*
      *              * Preparazione chiave e dati per il buffer        *
      *              *-------------------------------------------------*
           perform   buf-rig-ods-obk-000  thru buf-rig-ods-obk-999    .
       buf-rig-ods-pcr-600.
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-pcr-200.
       buf-rig-ods-pcr-900.
      *              *-------------------------------------------------*
      *              * Ordinamento finale delle righe bufferizzate     *
      *              *-------------------------------------------------*
           perform   buf-rig-ods-obr-000  thru buf-rig-ods-obr-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-pcr-999.
       buf-rig-ods-pcr-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione righe ordine di spedizione da trattare    *
      *    *                                                           *
      *    * Preparazione chiave per bufferizzazione righe             *
      *    *-----------------------------------------------------------*
       buf-rig-ods-obk-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare chiave              *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-rig-ods-kal
                                              (w-buf-rig-ods-ctr)     .
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare dati                *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-rig-ods-prg
                                              (w-buf-rig-ods-ctr)     .
      *              *-------------------------------------------------*
      *              * Ridefinizione tipo riga                         *
      *              *-------------------------------------------------*
           move      rf-osr-tip-rig       to   w-buf-rig-ods-wtr      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione delle personalizzazioni  *
      *              *-------------------------------------------------*
           if        w-prs-arg-orc-tor    =    "01"
                     go to buf-rig-ods-obk-010
           else if   w-prs-arg-orc-tor    =    "03"
                     go to buf-rig-ods-obk-030
           else if   w-prs-arg-orc-tor    =    "11"
                     go to buf-rig-ods-obk-110
           else if   w-prs-arg-orc-tor    =    "13"
                     go to buf-rig-ods-obk-130
           else if   w-prs-arg-orc-tor    =    "91" and
                     w-acc-tip-ord        =    01
                     go to buf-rig-ods-obk-010
           else if   w-prs-arg-orc-tor    =    "91" and
                     w-acc-tip-ord        =    02
                     go to buf-rig-ods-obk-030
           else if   w-prs-arg-orc-tor    =    "91" and
                     w-acc-tip-ord        =    03
                     go to buf-rig-ods-obk-110
           else      go to buf-rig-ods-obk-010.
       buf-rig-ods-obk-010.
      *              *-------------------------------------------------*
      *              * Se ordinamento per progressivo riga             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione chiave di ordinamento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg-01
                                              (w-buf-rig-ods-ctr)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-rig-ods-obk-900.
       buf-rig-ods-obk-030.
      *              *-------------------------------------------------*
      *              * Se ordinamento per codice alfanumerico prodotto *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione chiave di ordinamento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo riga non "P"                    *
      *                      *-----------------------------------------*
           if        w-buf-rig-ods-wtp    =    "P"
                     go to buf-rig-ods-obk-032.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice prodotto         *
      *                      *-----------------------------------------*
           move      all "z"              to   w-buf-rig-ods-alf-03
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * A bufferizzazione progressivo riga      *
      *                      *-----------------------------------------*
           go to     buf-rig-ods-obk-034.
       buf-rig-ods-obk-032.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice prodotto         *
      *                      *-----------------------------------------*
           move      rf-osr-alf-pro       to   w-buf-rig-ods-alf-03
                                              (w-buf-rig-ods-ctr)     .
       buf-rig-ods-obk-034.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg-03
                                              (w-buf-rig-ods-ctr)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-rig-ods-obk-900.
       buf-rig-ods-obk-110.
      *              *-------------------------------------------------*
      *              * Se ordinamento per ubicazione                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine                                  *
      *                  *---------------------------------------------*
           perform   buf-rig-ods-o11-000  thru buf-rig-ods-o11-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-rig-ods-obk-900.
       buf-rig-ods-obk-130.
      *              *-------------------------------------------------*
      *              * Se ordinamento per ubicazione, tramite indice   *
      *              * di percorso                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine                                  *
      *                  *---------------------------------------------*
           perform   buf-rig-ods-o13-000  thru buf-rig-ods-o13-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-rig-ods-obk-900.
       buf-rig-ods-obk-900.
      *              *-------------------------------------------------*
      *              * Preparazione dati di ordinamento                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione progressivo riga            *
      *                  *---------------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg
                                              (w-buf-rig-ods-ctr)     .
       buf-rig-ods-obk-990.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-obk-999.
       buf-rig-ods-obk-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione righe ordine da trattare                  *
      *    *                                                           *
      *    * Ordinamento righe bufferizzate - tipo '11'                *
      *    *-----------------------------------------------------------*
       buf-rig-ods-o11-000.
      *              *-------------------------------------------------*
      *              * Se ordinamento per percorso di ubicazione,      *
      *              * codice prodotto                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione chiave di ordinamento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo riga non "P"                    *
      *                      *-----------------------------------------*
           if        w-buf-rig-ods-wtp    =    "P"
                     go to buf-rig-ods-o11-200.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione ubicazione              *
      *                      *-----------------------------------------*
           move      all "z"              to   w-buf-rig-ods-ubi-11
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice prodotto         *
      *                      *-----------------------------------------*
           move      rf-osr-alf-pro       to   w-buf-rig-ods-alf-11
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg-11
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     buf-rig-ods-o11-990.
       buf-rig-ods-o11-200.
      *                      *-----------------------------------------*
      *                      * Determinazione ubicazione               *
      *                      *                                         *
      *                      * N.B.: Attualmente si prende il codice   *
      *                      *       dipendenza 01 cioe' la sede       *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-prm-ubi-tip-ope      .
           move      01                   to   d-prm-ubi-cod-dpz      .
           move      01                   to   d-prm-ubi-tip-mag      .
           move      rf-osr-num-pro       to   d-prm-ubi-num-mag      .
           move      rf-osr-sgl-vrn       to   d-prm-ubi-var-mag      .
           perform   det-prm-ubi-cll-000  thru det-prm-ubi-cll-999    .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione ubicazione              *
      *                      *-----------------------------------------*
           move      d-prm-ubi-ubi-lit    to   w-buf-rig-ods-ubi-11
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice prodotto         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Per righe 'PN'                      *
      *                          *-------------------------------------*
           if        rf-osr-tip-rig       =    "P    "
                     go to  buf-rig-ods-o11-300.
      *                          *-------------------------------------*
      *                          * Normalizzazione record [dcp]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                          *-------------------------------------*
      *                          * Lettura record [dcp]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rf-osr-num-pro       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           move      rf-dcp-alf-pro       to   rf-osr-alf-pro         .
       buf-rig-ods-o11-300.
           move      rf-osr-alf-pro       to   w-buf-rig-ods-alf-11
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg-11
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     buf-rig-ods-o11-990.
       buf-rig-ods-o11-990.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-o11-999.
       buf-rig-ods-o11-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione righe ordine da trattare                  *
      *    *                                                           *
      *    * Ordinamento righe bufferizzate - tipo '13'                *
      *    *-----------------------------------------------------------*
       buf-rig-ods-o13-000.
      *              *-------------------------------------------------*
      *              * Se ordinamento per percorso di ubicazione,      *
      *              * tramite indice di percorso                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione chiave di ordinamento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo riga non "P"                    *
      *                      *-----------------------------------------*
           if        rf-osr-tip-rig       =    "P    "
                     go to buf-rig-ods-o13-200.
      *                      *-----------------------------------------*
      *                      * Indice ubicazione                       *
      *                      *-----------------------------------------*
           move      9999999              to   w-buf-rig-ods-inx-13
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice prodotto         *
      *                      *-----------------------------------------*
           move      all "z"              to   w-buf-rig-ods-cap-13
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg-13
                                              (w-buf-rig-ods-ctr)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-rig-ods-o13-900.
       buf-rig-ods-o13-200.
      *                      *-----------------------------------------*
      *                      * Determinazione ubicazione               *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-prm-ubi-tip-ope      .
           move      01                   to   d-prm-ubi-cod-dpz      .
           move      01                   to   d-prm-ubi-tip-mag      .
           move      rf-osr-num-pro       to   d-prm-ubi-num-mag      .
           move      rf-osr-sgl-vrn       to   d-prm-ubi-var-mag      .
           perform   det-prm-ubi-cll-000  thru det-prm-ubi-cll-999    .
      *                      *-----------------------------------------*
      *                      * Aggiustamento ubicazione                *
      *                      *-----------------------------------------*
           if        d-prm-ubi-ubi-lit    =    spaces
                     move  all "z"        to   d-prm-ubi-ubi-lit      .
      *                      *-----------------------------------------*
      *                      * Indice di percorso                      *
      *                      *-----------------------------------------*
           move      d-prm-ubi-ubi-inx    to   w-buf-rig-ods-inx-13
                                              (w-buf-rig-ods-ctr)     .
           if        w-buf-rig-ods-inx-13
                    (w-buf-rig-ods-ctr)   =    zero
                     move  9999999        to   w-buf-rig-ods-inx-13
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice prodotto         *
      *                      *-----------------------------------------*
           move      rf-osr-alf-pro       to   w-buf-rig-ods-cap-13
                                              (w-buf-rig-ods-ctr)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-buf-rig-ods-prg-13
                                              (w-buf-rig-ods-ctr)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-rig-ods-o13-900.
       buf-rig-ods-o13-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-rig-ods-o13-999.
       buf-rig-ods-o13-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione righe ordine da trattare                  *
      *    *                                                           *
      *    * Ordinamento righe bufferizzate                            *
      *    *-----------------------------------------------------------*
       buf-rig-ods-obr-000.
      *              *-------------------------------------------------*
      *              * Test se almeno due codici da ordinare           *
      *              *-------------------------------------------------*
           if        w-buf-rig-ods-ctr    <    2
                     go to buf-rig-ods-obr-999.
       buf-rig-ods-obr-050.
      *              *-------------------------------------------------*
      *              * Ciclo di ordinamento                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-rig-ods-c01      .
       buf-rig-ods-obr-100.
           add       1                    to   w-buf-rig-ods-c01      .
           if        w-buf-rig-ods-c01    =    w-buf-rig-ods-ctr
                     go to buf-rig-ods-obr-999.
           move      w-buf-rig-ods-c01    to   w-buf-rig-ods-c02
                                               w-buf-rig-ods-c03      .
           move      w-buf-rig-ods-key
                    (w-buf-rig-ods-c01)   to   w-buf-rig-ods-svk      .
       buf-rig-ods-obr-200.
           add       1                    to   w-buf-rig-ods-c02      .
           if        w-buf-rig-ods-c02    >    w-buf-rig-ods-ctr
                     go to buf-rig-ods-obr-300.
           if        w-buf-rig-ods-key
                    (w-buf-rig-ods-c02)   >    w-buf-rig-ods-svk
                     go to buf-rig-ods-obr-200.
           move      w-buf-rig-ods-c02    to   w-buf-rig-ods-c03      .
           move      w-buf-rig-ods-key
                    (w-buf-rig-ods-c02)   to   w-buf-rig-ods-svk      .
           go to     buf-rig-ods-obr-200.
       buf-rig-ods-obr-300.
           move      w-buf-rig-ods-c01    to   w-buf-rig-ods-c04      .          
           if        w-buf-rig-ods-svk    >    w-buf-rig-ods-key
                                              (w-buf-rig-ods-c04)
                     go to buf-rig-ods-obr-100.
           move      w-buf-rig-ods-ele
                    (w-buf-rig-ods-c03)   to   w-buf-rig-ods-ele
                                              (w-buf-rig-ods-max)     .
           move      w-buf-rig-ods-ele
                    (w-buf-rig-ods-c04)   to   w-buf-rig-ods-ele
                                              (w-buf-rig-ods-c03)     .
           move      w-buf-rig-ods-ele
                    (w-buf-rig-ods-max)   to   w-buf-rig-ods-ele
                                              (w-buf-rig-ods-c04)     .
           go to     buf-rig-ods-obr-100.
       buf-rig-ods-obr-999.
           exit.

      *    *===========================================================*
      *    * Composizione descrizione per riga di scroll               *
      *    *-----------------------------------------------------------*
       cpz-des-rgs-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se si sta trattando un co- *
      *              * dice di magazzino oppure no                     *
      *              *-------------------------------------------------*
           if       (w-buf-rig-ods-wtp    =    "P" or
                     w-buf-rig-ods-wtp    =    "S" or
                     w-buf-rig-ods-wtp    =    "M"  ) and
                     w-buf-rig-ods-wtf    =    spaces
                     go to cpz-des-rgs-200.
       cpz-des-rgs-100.
      *              *-------------------------------------------------*
      *              * Se non si sta trattando un codice di magazzino  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessuna azione, in quanto la descrizione    *
      *                  * gia' composta va' bene                      *
      *                  *---------------------------------------------*
           go to     cpz-des-rgs-999.
       cpz-des-rgs-200.
      *              *-------------------------------------------------*
      *              * Se si sta trattando un codice di magazzino      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare dell'area di    *
      *                  * lavoro per la composizione                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-des-scr-000          .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore della per-  *
      *                  * sonalizzazione del tipo di visualizzazione  *
      *                  * della riga di scroll                        *
      *                  *---------------------------------------------*
           if        w-prs-rig-scr-des    =    00
                     go to cpz-des-rgs-400
           else if   w-prs-rig-scr-des    =    01
                     go to cpz-des-rgs-420
           else if   w-prs-rig-scr-des    =    02
                     go to cpz-des-rgs-440
           else if   w-prs-rig-scr-des    =    03
                     go to cpz-des-rgs-460
           else if   w-prs-rig-scr-des    =    04
                     go to cpz-des-rgs-480
           else if   w-prs-rig-scr-des    =    05
                     go to cpz-des-rgs-500
           else if   w-prs-rig-scr-des    =    06
                     go to cpz-des-rgs-520
           else      go to cpz-des-rgs-400.
       cpz-des-rgs-400.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 00              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
