           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     go to car-rig-cat-552
           else if   w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to car-rig-cat-554.
       car-rig-cat-552.
      *                              *---------------------------------*
