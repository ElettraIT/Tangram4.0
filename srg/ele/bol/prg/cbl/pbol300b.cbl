      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-ods-ape-999.
       ctl-ods-ape-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [osr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-ods-ape-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-osr-cod-dpz       not  = w-ctl-ods-ape-dpz or
                     rf-osr-flg-rch       not  = spaces            or
                     rf-osr-tip-arc       not  = w-ctl-ods-ape-tar or
                     rf-osr-cod-arc       not  = w-ctl-ods-ape-arc
                     go to ctl-ods-ape-999.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se ordine di spedizione pari a quello in e- *
      *                  * same : riciclo                              *
      *                  *---------------------------------------------*
           if        rf-osr-num-prt       =    w-ctl-ods-ape-prr
                     go to ctl-ods-ape-100.
