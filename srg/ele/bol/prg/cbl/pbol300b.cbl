           move      zero                 to   w-ctl-ods-ape-prt
                                              (w-ctl-ods-ape-num)     .
           move      zero                 to   w-ctl-ods-ape-dat
                                              (w-ctl-ods-ape-num)     .
           go to     ctl-ods-ape-030.
       ctl-ods-ape-050.
      *              *-------------------------------------------------*
      *              * Start su file [osr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHARC    "         to   f-key                  .
           move      w-ctl-ods-ape-dpz    to   rf-osr-cod-dpz         .
           move      spaces               to   rf-osr-flg-rch         .
           move      w-ctl-ods-ape-tar    to   rf-osr-tip-arc         .
