                     w-rig-tip-pro (1)    =    02 or
                     w-rig-tip-pro (1)    =    03 or
                     w-rig-tip-pro (1)    =    09
                     add  w-rig-imp-rig (1)
                                          to   w-eos-tot-lor
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M" or
                     w-rig-tip-rig-tpr (1)
                                          =    "S"
                     add  w-rig-imp-rig (1)
                                          to   w-eos-tot-lor          .
       car-rig-cat-680.
