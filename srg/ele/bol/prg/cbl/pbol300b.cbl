      *              *-------------------------------------------------*
           move      rf-osr-tip-rig       to   w-ctl-ods-ape-wtr      .
      *              *-------------------------------------------------*
      *              * Se tipo riga "C" : riciclo                      *
      *              *-------------------------------------------------*
           if        w-ctl-ods-ape-wtp    =   "C"
                     go to ctl-ods-ape-100.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' da spedire riga ordine *
      *              * di spedizione                                   *
      *              *-------------------------------------------------*
           move      "DT"                 to   d-qds-ros-tip-ope      .
           perform   det-qds-ros-cll-000  thru det-qds-ros-cll-999    .
      *              *-------------------------------------------------*
      *              * Se tipo riga "A"                                *
      *              *-------------------------------------------------*
           if        w-ctl-ods-ape-wtp    not  = "A"
                     go to ctl-ods-ape-120.
      *                  *---------------------------------------------*
      *                  * Se flag di riga di addebito aperta o chiusa *
      *                  * indica 'Chiusa' : riciclo                   *
      *                  *---------------------------------------------*
           if        d-qds-ros-rda-aoc    =    "C"
                     go to ctl-ods-ape-100.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     ctl-ods-ape-200.
       ctl-ods-ape-120.
      *              *-------------------------------------------------*
      *              * Se quantita' da spedire minore o uguale a zero: *
      *              * riciclo                                         *
      *              *-------------------------------------------------*
           if        d-qds-ros-qta-dsp    not  > zero
                     go to ctl-ods-ape-100.
       ctl-ods-ape-200.
      *              *-------------------------------------------------*
      *              * Incremento contatore ordini di spedizione       *
      *              *-------------------------------------------------*
           if        w-ctl-ods-ape-ctr    <    99999
                     add   1              to   w-ctl-ods-ape-ctr      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
           if        w-ctl-ods-ape-ctr    not  > w-ctl-ods-ape-max
                     move  rf-osr-num-prt to   w-ctl-ods-ape-prt
                                              (w-ctl-ods-ape-ctr)
                     move  rf-osr-dat-doc to   w-ctl-ods-ape-dat
                                              (w-ctl-ods-ape-ctr)     .
      *              *-------------------------------------------------*
      *              * Restart su file [osr] su prossimo ordine        *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHARC    "         to   f-key                  .
           move      w-ctl-ods-ape-dpz    to   rf-osr-cod-dpz         .
           move      spaces               to   rf-osr-flg-rch         .
           move      w-ctl-ods-ape-tar    to   rf-osr-tip-arc         .
           move      w-ctl-ods-ape-arc    to   rf-osr-cod-arc         .
           move      rf-osr-num-prt       to   rf-osr-num-prt         .
           move      99999                to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-ods-ape-999.
      *              *-------------------------------------------------*
      *              * A riciclo su lettura sequenziale record [osr]   *
      *              *-------------------------------------------------*
           go to     ctl-ods-ape-100.
       ctl-ods-ape-999.
           exit.

