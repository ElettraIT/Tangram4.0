      *    *===========================================================*
      *    * Accettazione campo saldaconto : Quantita' in bolla        *
      *    *-----------------------------------------------------------*
       acc-qta-bol-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-bro-tip-rig
                    (w-sdc-ctr-rig)       =    "A" or
                     w-bro-tip-rig
                    (w-sdc-ctr-rig)       =    "C"
                     go to acc-qta-bol-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-bro-qta-bol
                    (w-sdc-ctr-rig)       to   w-sav-qta-bol          .
           move      w-bro-flg-fzs
                    (w-sdc-ctr-rig)       to   w-sav-flg-fzs          .
       acc-qta-bol-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-bro-dec-qta
                    (w-sdc-ctr-rig)       >    2
                     move  2              to   v-dec
           else      move  w-bro-dec-qta
                          (w-sdc-ctr-rig) to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      54                   to   v-pos                  .
           if        w-sdc-ctr-rig        >    1      
                     move   "UP  "        to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-sdc-npg-dat        >    1
                     move   "PRSC"        to   v-pfk (07)             .
           if        w-sdc-npg-dat        <    w-sdc-npg-max
                     move   "NXSC"        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
           if        w-sdc-ctr-rig        <    w-bro-num-ele
                     move   "TAB "        to   v-pfk (10)             .
           move      "SLCT"               to   v-pfk (11)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-bro-qta-bol
                    (w-sdc-ctr-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     go to acc-qta-bol-999.
       acc-qta-bol-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-bro-qta-bol
                                              (w-sdc-ctr-rig)         .
       acc-qta-bol-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' fra segno quantita'*
      *                  * in bolla e segno quantita' da evadere       *
      *                  *---------------------------------------------*
           if        w-bro-qta-dsp
                    (w-sdc-ctr-rig)       >    zero and
                     w-bro-qta-bol
                    (w-sdc-ctr-rig)       <    zero
                     go to acc-qta-bol-100
           else if   w-bro-qta-dsp
                    (w-sdc-ctr-rig)       <    zero and
                     w-bro-qta-bol
                    (w-sdc-ctr-rig)       >    zero
                     go to acc-qta-bol-100.
       acc-qta-bol-440.
      *                  *---------------------------------------------*
      *                  * Se Slct : controllo che il valore impostato *
      *                  * sia uguale al precedente                    *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-qta-bol-600.
           if        w-bro-qta-bol
                    (w-sdc-ctr-rig)       not  = w-sav-qta-bol
                     move   w-sav-qta-bol to   w-bro-qta-bol
                                              (w-sdc-ctr-rig)
                     go to  acc-qta-bol-100.
       acc-qta-bol-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Quantita' da evadere e quantita' in bolla   *
      *                  * in work di comodo senza segno               *
      *                  *---------------------------------------------*
           move      w-bro-qta-dsp
                    (w-sdc-ctr-rig)       to   w-qss-qta-dsp          .
           move      w-bro-qta-bol
                    (w-sdc-ctr-rig)       to   w-qss-qta-bol          .
      *                  *---------------------------------------------*
      *                  * Se Slct                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to  acc-qta-bol-620.
      *                      *-----------------------------------------*
      *                      * Se valore gia' presente                 *
      *                      *-----------------------------------------*
           if        w-bro-qta-bol
                    (w-sdc-ctr-rig)       =    zero
                     go to acc-qta-bol-610.
      *                          *-------------------------------------*
      *                          * Quantita' in bolla                  *
      *                          *-------------------------------------*
           move      zero                 to   w-bro-qta-bol
                                              (w-sdc-ctr-rig)         .
           move      zero                 to   w-qss-qta-bol          .
      *                          *-------------------------------------*
      *                          * Flag di saldo forzato               *
      *                          *-------------------------------------*
           move      spaces               to   w-bro-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-700.
       acc-qta-bol-610.
      *                      *-----------------------------------------*
      *                      * Se valore non presente                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' in bolla                  *
      *                          *-------------------------------------*
           move      w-bro-qta-dsp
                    (w-sdc-ctr-rig)       to   w-bro-qta-bol
                                              (w-sdc-ctr-rig)         .
           move      w-bro-qta-dsp
                    (w-sdc-ctr-rig)       to   w-qss-qta-bol          .
      *                          *-------------------------------------*
      *                          * Flag di saldo forzato               *
      *                          *-------------------------------------*
           move      spaces               to   w-bro-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-700.
       acc-qta-bol-620.
      *                  *---------------------------------------------*
      *                  * Se Return o altri tasti funzione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di saldo forzato                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se valore impostato pari al prece-  *
      *                          * dente : nessuna variazione          *
      *                          *-------------------------------------*
           if        w-bro-qta-bol
                    (w-sdc-ctr-rig)        not  = w-sav-qta-bol
                     go to  acc-qta-bol-650.
           go to     acc-qta-bol-700.
       acc-qta-bol-650.
      *                          *-------------------------------------*
      *                          * Se valore impostato diverso dal     *
      *                          * precedente                          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in bolla maggiore  *
      *                              * o uguale a quella da evadere :  *
      *                              * spaces                          *
      *                              *---------------------------------*
           if        w-qss-qta-bol        <    w-qss-qta-dsp
                     go to  acc-qta-bol-655.
           move      spaces               to   w-bro-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-700.
       acc-qta-bol-655.
      *                              *---------------------------------*
      *                              * Altrimenti : valore inalterato  *
      *                              *---------------------------------*
           go to     acc-qta-bol-700.
       acc-qta-bol-700.
      *                  *---------------------------------------------*
      *                  * Trattamento altri valori riga               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag indicatore di residuo              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato a 'S'      *
      *                          *-------------------------------------*
           if        w-bro-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     go to acc-qta-bol-710.
           move      spaces               to   w-bro-flg-idr
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-720.
       acc-qta-bol-710.
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato diverso da *
      *                          * 'S'                                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in bolla maggiore  *
      *                              * o uguale a quella da evadere :  *
      *                              * spaces                          *
      *                              *---------------------------------*
           if        w-qss-qta-bol        <    w-qss-qta-dsp
                     go to  acc-qta-bol-715.
           move      spaces               to   w-bro-flg-idr
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-720.
       acc-qta-bol-715.
      *                              *---------------------------------*
      *                              * Altrimenti : il valore viene    *
      *                              * forzato a '<'                   *
      *                              *---------------------------------*
           move      "<"                  to   w-bro-flg-idr
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-720.
       acc-qta-bol-720.
      *                      *-----------------------------------------*
      *                      * Flag indicatore di saldo                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato a 'S'      *
      *                          *-------------------------------------*
           if        w-bro-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     go to acc-qta-bol-730.
           move      "S"                  to   w-bro-flg-ids
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-740.
       acc-qta-bol-730.
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato diverso da *
      *                          * 'S'                                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in bolla minore    *
      *                              * o uguale a quella da evadere :  *
      *                              * viene forzato il valore spaces  *
      *                              *---------------------------------*
           if        w-qss-qta-bol        >    w-qss-qta-dsp
                     go to  acc-qta-bol-735.
           move      spaces               to   w-bro-flg-ids
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-740.
       acc-qta-bol-735.
      *                              *---------------------------------*
      *                              * Altrimenti : il valore viene    *
      *                              * forzato a "+"                   *
      *                              *---------------------------------*
           move      "+"                  to   w-bro-flg-ids
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-740.
       acc-qta-bol-740.
      *                      *-----------------------------------------*
      *                      * Quantita' residua                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato a 'S'      *
      *                          *-------------------------------------*
           if        w-bro-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     go to acc-qta-bol-750.
           move      zero                 to   w-bro-qta-res
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-760.
       acc-qta-bol-750.
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato diverso da *
      *                          * 'S'                                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in bolla maggiore  *
      *                              * o uguale a quella da evadere :  *
      *                              * spaces                          *
      *                              *---------------------------------*
           if        w-qss-qta-bol        <    w-qss-qta-dsp
                     go to  acc-qta-bol-755.
           move      zero                 to   w-bro-qta-res
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-760.
       acc-qta-bol-755.
      *                              *---------------------------------*
      *                              * Altrimenti : il valore e' pari  *
      *                              * alla differenza tra quantita'   *
      *                              * da evadere e quantita' in bolla *
      *                              *---------------------------------*
           subtract  w-bro-qta-bol
                    (w-sdc-ctr-rig)       from w-bro-qta-dsp
                                              (w-sdc-ctr-rig)
                                        giving w-bro-qta-res
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-bol-760.
       acc-qta-bol-760.
      *                  *---------------------------------------------*
      *                  * Visualizzazione valori riga                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Quantita' in bolla                      *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-bro-dec-qta
                    (w-sdc-ctr-rig)       >    2
                     move  2              to   v-dec
           else      move  w-bro-dec-qta
                          (w-sdc-ctr-rig) to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-bro-qta-bol
                    (w-sdc-ctr-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Flag indicatore di residuo              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-bro-flg-idr
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Flag indicatore di saldo                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-bro-flg-ids
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Quantita' residua                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing quantita'                   *
      *                          *-------------------------------------*
           move      "ED"                 to   w-edt-qta-inc-ope      .
           move      w-bro-qta-res
                    (w-sdc-ctr-rig)       to   w-edt-qta-inc-qta      .
           move      w-bro-dec-qta
                    (w-sdc-ctr-rig)       to   w-edt-qta-inc-dec      .
           move      "S"                  to   w-edt-qta-inc-sgn      .
           move      11                   to   w-edt-qta-inc-car      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      70                   to   v-pos                  .
           move      w-edt-qta-inc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-qta-bol-800.
       acc-qta-bol-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo saldaconto : Si/No Addebito o Commento *
      *    *-----------------------------------------------------------*
       acc-snx-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-bro-tip-rig
                    (w-sdc-ctr-rig)       not  = "A" and
                     w-bro-tip-rig
                    (w-sdc-ctr-rig)       not  = "C"
                     go to acc-snx-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-bro-snx-aoc
                    (w-sdc-ctr-rig)       to   w-sav-snx-aoc          .
       acc-snx-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      59                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
           if        w-sdc-ctr-rig        >    1      
                     move   "UP  "        to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-sdc-npg-dat        <    w-sdc-npg-max
                     move   "NXSC"        to   v-pfk (06)             .
           if        w-sdc-npg-dat        >    1
                     move   "PRSC"        to   v-pfk (07)             .
           if        w-sdc-ctr-rig        <    w-bro-num-ele
                     move   "TAB "        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
       acc-snx-aoc-150.
           move      "SLCT"               to   v-pfk (10)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-bro-snx-aoc
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     go to acc-snx-aoc-999.
       acc-snx-aoc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-bro-snx-aoc
                                              (w-sdc-ctr-rig)         .
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to  acc-snx-aoc-400.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bro-snx-aoc
                    (w-sdc-ctr-rig)       not  = w-sav-snx-aoc
                     move   w-sav-snx-aoc to   w-bro-snx-aoc
                                              (w-sdc-ctr-rig)
                     go to  acc-snx-aoc-100.
      *                  *---------------------------------------------*
      *                  * Se valore presente lo si abblenca, altri-   *
      *                  * menti lo si forza a 'S'                     *
      *                  *---------------------------------------------*
           if        w-bro-snx-aoc
                    (w-sdc-ctr-rig)       not  = spaces
                     move  spaces         to   w-bro-snx-aoc
                                              (w-sdc-ctr-rig)
           else      move  "S"            to   w-bro-snx-aoc
                                              (w-sdc-ctr-rig)         .
       acc-snx-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-bro-snx-aoc
                    (w-sdc-ctr-rig)       not  = "S" and
                     w-bro-snx-aoc
                    (w-sdc-ctr-rig)       not  = "N" and
                     w-bro-snx-aoc
                    (w-sdc-ctr-rig)       not  = spaces
                     go to acc-snx-aoc-100.
       acc-snx-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore                      *
      *                  *---------------------------------------------*
           if        w-bro-snx-aoc
                    (w-sdc-ctr-rig)       =    "N"
                     move  spaces         to   w-bro-snx-aoc
                                              (w-sdc-ctr-rig)         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione Si/No addebito o commento   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      59                   to   v-pos                  .
           if        w-bro-snx-aoc
                    (w-sdc-ctr-rig)       =    "S"
                     move  "Si"           to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-snx-aoc-800.
       acc-snx-aoc-999.
           exit.

      *    *===========================================================*
      *    * Caricamento righe in catena                               *
      *    *-----------------------------------------------------------*
       car-rig-cat-000.
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Ri-ordinamento finale delle righe bufferizzate  *
      *              *-------------------------------------------------*
           perform   car-rig-cat-obr-000  thru car-rig-cat-obr-999    .
       car-rig-cat-050.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer righe ordine          *
      *              *-------------------------------------------------*
           move      zero                 to   w-crc-wrk-ctr          .
       car-rig-cat-100.
           add       1                    to   w-crc-wrk-ctr          .
           if        w-crc-wrk-ctr        >    w-bro-num-ele
                     go to car-rig-cat-700.
      *                  *---------------------------------------------*
      *                  * Selezione su righe ordine nel buffer        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo riga    *
      *                      *-----------------------------------------*
           if        w-bro-tip-rig
                    (w-crc-wrk-ctr)       =    "A" or
                     w-bro-tip-rig
                    (w-crc-wrk-ctr)       =    "C"
                     go to car-rig-cat-110
           else      go to car-rig-cat-120.
       car-rig-cat-110.
      *                      *-----------------------------------------*
      *                      * Se riga di Addebito o Commento          *
      *                      *-----------------------------------------*
           if        w-bro-snx-aoc
                    (w-crc-wrk-ctr)       not  = "S"
                     go to car-rig-cat-100.
           go to     car-rig-cat-150.
       car-rig-cat-120.
      *                      *-----------------------------------------*
      *                      * Se altro tipo riga                      *
      *                      *-----------------------------------------*
           if        w-bro-qta-bol
                    (w-crc-wrk-ctr)       =    zero
                     go to car-rig-cat-100.
           go to     car-rig-cat-150.
       car-rig-cat-150.
      *                  *---------------------------------------------*
      *                  * Append in catena                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Append non possibile : uscita con    *
      *                      * errore                                  *
      *                      *-----------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to  car-rig-cat-900.
      *                      *-----------------------------------------*
      *                      * Append                                  *
      *                      *-----------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-rig-cat-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [osr]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [osr]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-gen-prt-ods        to   rf-osr-num-prt         .
           move      w-bro-num-prg
                    (w-crc-wrk-ctr)       to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
       car-rig-cat-300.
      *                  *---------------------------------------------*
      *                  * Composizione riga                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori contenuti direttamente in re-    *
      *                      * cord [osr]                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori da bufferizzare comunque     *
      *                          *-------------------------------------*
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
           move      rf-osr-bld-flb       to   w-rig-bld-flb (1)      .
           move      rf-osr-bld-tpb       to   w-rig-bld-tpb (1)      .
           move      rf-osr-bld-rgb       to   w-rig-bld-rgb (1)      .
           move      rf-osr-tip-rig       to   w-rig-tip-rig (1)      .
           perform   dec-tip-rig-000      thru dec-tip-rig-999        .
           move      rf-osr-tip-mag       to   w-rig-tip-mag (1)      .
           move      rf-osr-num-pro       to   w-rig-num-pro (1)      .
           move      rf-osr-alf-pro       to   w-rig-alf-pro (1)      .
           move      rf-osr-sgl-vrn       to   w-rig-sgl-vrn (1)      .
           move      rf-osr-cop-scl       to   w-rig-cop-scl (1)      .
           move      rf-osr-des-ext       to   w-rig-des-ext (1)      .
           move      rf-osr-des-rig       to   w-rig-des-rig (1)      .
           move      rf-osr-tip-pro       to   w-rig-tip-pro (1)      .
           move      rf-osr-umi-ven       to   w-rig-umi-ven (1)      .
           move      rf-osr-dec-qta       to   w-rig-dec-qta (1)      .
           move      rf-osr-snx-2qt       to   w-rig-snx-2qt (1)      .
           move      rf-osr-dec-2qt       to   w-rig-dec-2qt (1)      .
           move      rf-osr-qta-a02       to   w-rig-qta-a02 (1)      .
           move      rf-osr-flg-puq       to   w-rig-flg-puq (1)      .
           move      rf-osr-snx-3qt       to   w-rig-snx-3qt (1)      .
           move      rf-osr-dec-3qt       to   w-rig-dec-3qt (1)      .
           move      rf-osr-qta-a03       to   w-rig-qta-a03 (1)      .
           move      rf-osr-ocl-dat       to   w-rig-ocl-dat (1)      .
           move      rf-osr-ocl-num       to   w-rig-ocl-num (1)      .
           move      rf-osr-cmc-tip       to   w-rig-cmc-tip (1)      .
           move      rf-osr-cmc-dat       to   w-rig-cmc-dat (1)      .
           move      rf-osr-cmc-num       to   w-rig-cmc-num (1)      .
           move      rf-osr-coc-tip       to   w-rig-coc-tip (1)      .
           move      rf-osr-coc-dat       to   w-rig-coc-dat (1)      .
           move      rf-osr-coc-num       to   w-rig-coc-num (1)      .
           move      rf-osr-coc-prt       to   w-rig-coc-prt (1)      .
           move      rf-osr-coc-prg       to   w-rig-coc-prg (1)      .
           move      rf-osr-coc-fzs       to   w-rig-coc-fzs (1)      .
           move      w-gen-prt-ods        to   w-rig-ods-prt (1)      .
           move      w-bro-num-prg
                    (w-crc-wrk-ctr)       to   w-rig-ods-prg (1)      .
      *                          *-------------------------------------*
      *                          * Valori da bufferizzare solo se do-  *
      *                          * cumento che interessa la fattura-   *
      *                          * zione                               *
      *                          *-------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to car-rig-cat-400.
           move      rf-osr-cod-iva       to   w-rig-coi-rig (1)      .
           move      rf-osr-ctp-ven       to   w-rig-ctv-rig (1)      .
           move      rf-osr-dec-prz       to   w-rig-dec-prz (1)      .
           move      rf-osr-sgl-vps       to   w-rig-sgl-vps (1)      .
           move      rf-osr-dec-vps       to   w-rig-dec-vps (1)      .
           move      rf-osr-tdc-vps       to   w-rig-tdc-vps (1)      .
           move      rf-osr-prz-lrs       to   w-rig-prz-lrs (1)      .
