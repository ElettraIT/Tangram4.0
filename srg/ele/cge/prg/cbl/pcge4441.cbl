      *              *-------------------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  rf-sdb-dat-ddr to   rf-sdb-dts-sdb         .
           if        rf-sdb-dts-sdb       >    w-gen-dat-scd
                     move  rf-sdb-dts-sdb to   w-gen-dat-scd          .
                     
                     
                     
      *              *-------------------------------------------------*
      *              * Codice archivio                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      rf-sdb-cod-dbt       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Data scadenza                                   *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      rf-sdb-dts-sdb       to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
                                         
                                         
                                         
                                         
                                         
                                         
       stp-srt-inp-sdb-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-sdb-200.
       stp-srt-inp-sdb-900.
