      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione data T0                      *
      *                  *---------------------------------------------*
           move      1140101              to   w-gen-dat-t00          .
      *                  *---------------------------------------------*
      *                  * Determinazione data T1                      *
      *                  *                                             *
      *                  * Primo giorno del mese successivo a quello   *
      *                  * di selezione iniziale, relativo all'anno    *
      *                  * precedente                                  *
      *                  *                                             *
      *                  * Esempio                                     *
      *                  *                                             *
      *                  * Data iniziale : 01/04/16 Data T1 : 01/05/15 *
      *                  *---------------------------------------------*
           move      rr-dat-fin           to   w-gen-dat-t01          .
      *                      *-----------------------------------------*
      *                      * Incremento di un giorno                 *
      *                      *-----------------------------------------*
           move      w-gen-dat-t01        to   w-det-dat-nrg-dtb      .
           move      1                    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-gen-dat-t01          .
      *                      *-----------------------------------------*
      *                      * Decremento di un anno                   *
      *                      *-----------------------------------------*
           move      w-gen-dat-t01        to   s-dat                  .
           subtract  1                    from s-saa                  .
           move      s-dat                to   w-gen-dat-t01          .
      *                  *---------------------------------------------*
      *                  * Determinazione data T2                      *
      *                  *                                             *
      *                  * Pari alla data finale richiesta             *
      *                  *---------------------------------------------*
           move      rr-dat-fin           to   w-gen-dat-t02          .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su [mgr] per data registrazione           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATREG"             to   f-key                  .
           move      w-gen-dat-t00        to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [mgr]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test max su [mgr]                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se oltre data massima : ad uscita           *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-reg       >    rr-dat-fin
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [mgr]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        rf-mgr-tip-arc       not  = "C"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su causali ammesse                     *
      *                  *---------------------------------------------*
           if        rf-mgr-cod-cau       not  = 002 and
                     rf-mgr-cod-cau       not  = 003 and
                     rf-mgr-cod-cau       not  = 004 and
                     rf-mgr-cod-cau       not  = 006 and
                     rf-mgr-cod-cau       not  = 031 and
                     rf-mgr-cod-cau       not  = 035 and
                     rf-mgr-cod-cau       not  = 041 and
                     rf-mgr-cod-cau       not  = 042 and
                     rf-mgr-cod-cau       not  = 100 and
                     rf-mgr-cod-cau       not  = 102 and
                     rf-mgr-cod-cau       not  = 105 and
                     rf-mgr-cod-cau       not  = 120 and
                     rf-mgr-cod-cau       not  = 123 and
                     rf-mgr-cod-cau       not  = 124 and
                     rf-mgr-cod-cau       not  = 129 and
                     rf-mgr-cod-cau       not  = 130 and
                     rf-mgr-cod-cau       not  = 140 and
                     rf-mgr-cod-cau       not  = 199 and
                     rf-mgr-cod-cau       not  = 201
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su anagrafica cliente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se cliente da scartare             *
      *                      *-----------------------------------------*
           if        rf-mgr-cod-arc       =   0000001
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Normalizzazione record file [cli]       *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                      *-----------------------------------------*
      *                      * Lettura record record file [cli]        *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      rf-mgr-cod-arc       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                      *-----------------------------------------*
      *                      * Se lettura errata: riciclo              *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test su codice nazione                  *
      *                      *-----------------------------------------*
           if        rf-cli-cod-naz       not  = "IT" and
                     rf-cli-cod-naz       not  = "SM"
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari alla scrittura del       *
      *              * record di sort                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione della data di scadenza      *
      *                  *---------------------------------------------*
           move      zero                 to   w-gen-dat-scd          .
      *                  *---------------------------------------------*
      *                  * Determinazione della data di scadenza per   *
      *                  * i movimenti relativi alle scadenze tramite  *
      *                  * lettura della descrizione causale da [mgt]  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su causale                         *
      *                      *-----------------------------------------*
           if        rf-mgr-cod-cau       not  = 102 and
                     rf-mgr-cod-cau       not  = 120 and
                     rf-mgr-cod-cau       not  = 123 and
                     rf-mgr-cod-cau       not  = 124
                     go to stp-srt-inp-520.
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [mgt]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [mgt]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DATREG"             to   f-key                  .
           move      rf-mgr-dat-reg       to   rf-mgt-dat-reg         .
           move      rf-mgr-num-prt       to   rf-mgt-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                      *-----------------------------------------*
      *                      * Scorporo data scadenza da descrizione   *
      *                      * causale                                 *
      *                      *-----------------------------------------*
           if        rf-mgr-cod-cau       =    102
                     move rf-mgt-des-cau (13 : 08)
                                          to   w-gen-dat-ext-txt
           else if   rf-mgr-cod-cau       =    120
                     move rf-mgt-des-cau (32 : 08)
                                          to   w-gen-dat-ext-txt
           else if   rf-mgr-cod-cau       =    123
                     move rf-mgt-des-cau (23 : 08)
                                          to   w-gen-dat-ext-txt                              
           else if   rf-mgr-cod-cau       =    124
                     move rf-mgt-des-cau (13 : 08)
                                          to   w-gen-dat-ext-txt      .
      *                      *-----------------------------------------*
      *                      * Controllo data                          *
      *                      *-----------------------------------------*
           move      "CD"                 to   s-ope                  .
           move      w-gen-dat-ext-gio    to   s-gio                  .
           move      w-gen-dat-ext-mes    to   s-mes                  .
           move      w-gen-dat-ext-ann    to   s-ann                  .
           move      1                    to   s-sec                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     move zero            to   s-dat
           else      move s-dat           to   w-gen-dat-scd          .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-600.                          
       stp-srt-inp-520.
      *                  *---------------------------------------------*
      *                  * Determinazione della data di scadenza per   *
      *                  * le fatture tramite scansione di [sdb]       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su causale                         *
      *                      *-----------------------------------------*
           if        rf-mgr-cod-cau       not  = 002 and
                     rf-mgr-cod-cau       not  = 003 and
                     rf-mgr-cod-cau       not  = 004 and
                     rf-mgr-cod-cau       not  = 006
                     go to stp-srt-inp-600.
      *                      *-----------------------------------------*
      *                      * Subroutine di scansione                 *
      *                      *-----------------------------------------*
           perform   stp-srt-inp-sdb-000  thru stp-srt-inp-sdb-999    .
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record di sort              *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice cliente                          *
      *                      *-----------------------------------------*
           move      rf-mgr-cod-arc       to   srt-cod-cli            .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      rf-mgr-dat-rif       to   srt-dat-rif            .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      rf-mgr-num-rif       to   srt-num-rif            .
      *                      *-----------------------------------------*
      *                      * Data registrazione                      *
      *                      *-----------------------------------------*
           move      rf-mgr-dat-reg       to   srt-dat-reg            .
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      rf-mgr-num-prt       to   srt-num-prt            .
      *                      *-----------------------------------------*
      *                      * Numero progressivo                      *
      *                      *-----------------------------------------*
           move      rf-mgr-num-prg       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      rf-mgr-dat-doc       to   srt-dat-doc            .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      rf-mgr-num-doc       to   srt-num-doc            .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      w-gen-dat-scd        to   srt-dat-scd            .
      *                      *-----------------------------------------*
      *                      * Record [mgr]                            *
      *                      *-----------------------------------------*
           move      rf-mgr               to   srt-rec-mgr            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
