      *    *===========================================================*
      *    * Routine lettura codice archivio :                         *
      *    * - C : Clienti                                             *
      *    * - F : Fornitori                                           *
      *    * - D : Nostre dipendenze                                   *
      *    *-----------------------------------------------------------*
       let-arc-cfd-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo archivio          *
      *              *-------------------------------------------------*
           if        w-let-arc-cfd-tip    =    spaces or
                     w-let-arc-cfd-tip    =    "N"
                     go to let-arc-cfd-100
           else if   w-let-arc-cfd-tip    =    "C"
                     go to let-arc-cfd-200
           else if   w-let-arc-cfd-tip    =    "F"
                     go to let-arc-cfd-300
           else if   w-let-arc-cfd-tip    =    "D"
                     go to let-arc-cfd-400
           else      go to let-arc-cfd-900.
       let-arc-cfd-100.
      *              *-------------------------------------------------*
      *              * Se tipo archivio Spaces                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di lettura a Spaces                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-cfd-flg      .
      *                  *---------------------------------------------*
      *                  * Descrizione archivio a Spaces               *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-cfd-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-cfd-999.
       let-arc-cfd-200.
      *              *-------------------------------------------------*
      *              * Se tipo archivio 'C' : Clienti                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione lettura archivio Clienti       *
      *                  *---------------------------------------------*
           move      w-let-arc-cfd-cod    to   w-let-arc-cli-cod      .
      *                  *---------------------------------------------*
      *                  * Lettura archivio Clienti                    *
      *                  *---------------------------------------------*
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                  *---------------------------------------------*
      *                  * Spostamenti in area di uscita               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di lettura                         *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-flg    to   w-let-arc-cfd-flg      .
      *                      *-----------------------------------------*
      *                      * Ragione sociale                         *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-rag    to   w-let-arc-cfd-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-cfd-999.
       let-arc-cfd-300.
      *              *-------------------------------------------------*
      *              * Se tipo archivio 'F' : Fornitori                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione lettura archivio Fornitori     *
      *                  *---------------------------------------------*
           move      w-let-arc-cfd-cod    to   w-let-arc-fnt-cod      .
      *                  *---------------------------------------------*
      *                  * Lettura archivio Fornitori                  *
      *                  *---------------------------------------------*
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Spostamenti in area di uscita               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di lettura                         *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-flg    to   w-let-arc-cfd-flg      .
      *                      *-----------------------------------------*
      *                      * Ragione sociale                         *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-rag    to   w-let-arc-cfd-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-cfd-999.
       let-arc-cfd-400.
      *              *-------------------------------------------------*
      *              * Se tipo archivio 'D' : Nostre dipendenze        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione lettura archivio Nostre dipen- *
      *                  * denze                                       *
      *                  *---------------------------------------------*
           move      w-let-arc-cfd-cod    to   w-let-arc-dpz-cod      .
      *                  *---------------------------------------------*
      *                  * Lettura archivio Nostre dipendenze          *
      *                  *---------------------------------------------*
           perform   let-arc-dpz-000      thru let-arc-dpz-999        .
      *                  *---------------------------------------------*
      *                  * Spostamenti in area di uscita               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di lettura                         *
      *                      *-----------------------------------------*
           move      w-let-arc-dpz-flg    to   w-let-arc-cfd-flg      .
      *                      *-----------------------------------------*
      *                      * Descrizione                             *
      *                      *-----------------------------------------*
           move      w-let-arc-dpz-des    to   w-let-arc-cfd-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-cfd-999.
       let-arc-cfd-900.
      *              *-------------------------------------------------*
      *              * Se tipo archivio non riconosciuto               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di lettura a non-trovato               *
      *                  *---------------------------------------------*
           move      "#"                  to   w-let-arc-cfd-flg      .
      *                  *---------------------------------------------*
      *                  * Descrizione archivio a non-trovato          *
      *                  *---------------------------------------------*
           move      all   "."            to   w-let-arc-cfd-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-cfd-999.
       let-arc-cfd-999.
           exit.

