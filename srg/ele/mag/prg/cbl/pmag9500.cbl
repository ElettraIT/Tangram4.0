      *              *-------------------------------------------------*
      *              * Da determinazioni su valori precedenti          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data di registrazione minima                *
      *                  * - Se ultimo inventario di fine esercizio    *
      *                  *   concluso : giorno successivo alla data    *
      *                  *   inventario di fine esercizio              *
      *                  * - Se ultimo inventario di fine esercizio    *
      *                  *   non ancora concluso : giorno successivo   *
      *                  *   alla data di fine esercizio precedente    *
      *                  *   quello dell'ultimo inventario             *
      *                  * - Se superiore a quelle fin qui determina-  *
      *                  *   te : giorno successivo alla data ultimo   *
      *                  *   consolidamento costo medio continuo       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se ultimo inventario gia' concluso      *
      *                      *-----------------------------------------*
           if        w-dnu-ife-ife-flg    not  = spaces
                     go to num-mag-300-520.
      *                          *-------------------------------------*
      *                          * Data registrazione minima uguale a  *
      *                          * data ultimo inventario di fine e-   *
      *                          * sercizio                            *
      *                          *-------------------------------------*
           move      w-dnu-ife-ife-dti    to   w-dnu-dtr-dtr-min      .
           go to     num-mag-300-540.
       num-mag-300-520.
      *                      *-----------------------------------------*
      *                      * Se ultimo inventario ancora in corso    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione ultimo giorno eser-  *
      *                          * cizio precedente                    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Lettura personalizzazione       *
      *                              *---------------------------------*
           move      "P:"                 to   s-ope                  .
           move      "pgm/cge[mes-chi]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  12             to   s-num                  .
           if        s-num                <    01 or
                     s-num                >    12
                     move  12             to   s-num                  .
      *                              *---------------------------------*
      *                              * Determinazione                  *
      *                              *---------------------------------*
           subtract  1                    from w-dnu-ife-ife-ese
                                        giving s-saa                  .
           move      s-num                to   s-mes                  .
           move      31                   to   s-gio                  .
       num-mag-300-525.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to num-mag-300-525.
           move      s-dat                to   w-dnu-dtr-dtr-min      .
       num-mag-300-540.
      *                      *-----------------------------------------*
      *                      * Test su data ultimo consolidamento co-  *
      *                      * sto medio continuo                      *
      *                      *-----------------------------------------*
           if        w-dnu-cmc-dat-con    >    w-dnu-dtr-dtr-min
                     move  w-dnu-cmc-dat-con
                                          to   w-dnu-dtr-dtr-min      .
      *                      *-----------------------------------------*
      *                      * Determinazione giorno successivo a      *
      *                      * quello determinato                      *
      *                      *-----------------------------------------*
           if        w-dnu-dtr-dtr-min    =    zero
                     go to num-mag-300-999.
           move      w-dnu-dtr-dtr-min    to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to num-mag-300-580.
           move      1                    to   s-gio                  .
           add       1                    to   s-mes                  .
           if        s-mes                not  > 12
                     go to num-mag-300-580.
           move      1                    to   s-mes                  .
           add       1                    to   s-saa                  .
       num-mag-300-580.
           move      s-dat                to   w-dnu-dtr-dtr-min      .
______     move      zero                 to   w-dnu-dtr-dtr-min      .
       num-mag-300-999.
           exit.

