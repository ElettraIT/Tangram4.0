      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del valore del numero pro- *
      *              * tocollo                                         *
      *              *-------------------------------------------------*
           if        w-tes-num-prt        =    zero
                     go to rou-let-reg-100
           else      go to rou-let-reg-300.
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Se numero protocollo a zero : inserimento       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Attribuzione numero di protocollo per ge-   *
      *                  * stione magazzino                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione secolo ed anno             *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   w-prt-mag-ann-ese      .
      *                      *-----------------------------------------*
      *                      * Preparazione codice dipendenza          *
      *                      *-----------------------------------------*
           move      w-tes-cod-dpz        to   w-prt-mag-cod-dpz      .
      *                      *-----------------------------------------*
      *                      * Richiamo routine di attribuzione        *
      *                      *-----------------------------------------*
           perform   att-prt-mag-000      thru att-prt-mag-999        .
      *                      *-----------------------------------------*
      *                      * Numero protocollo completo, in formato  *
      *                      * s.aa.dd.nnnnnn, in campo di destinazio- *
      *                      * ne                                      *
      *                      *-----------------------------------------*
           move      w-prt-mag-num-prt    to   w-tes-num-prt          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero di protocollo        *
      *                  *---------------------------------------------*
           perform   vis-num-prt-000      thru vis-num-prt-999        .
       rou-let-reg-120.
      *                  *---------------------------------------------*
      *                  * Controllo trattamento valore per la causale *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se si e' in periodo di inventario di    *
      *                      * fine anno                               *
      *                      *-----------------------------------------*
           if        w-dnu-ife-ife-flg    =    spaces
                     go to rou-let-reg-140.
      *                          *-------------------------------------*
      *                          * Se data registrazione inferiore o   *
      *                          * pari alla data inventario           *
      *                          *-------------------------------------*
           if        w-tes-dat-reg        >    w-dnu-ife-ife-dti
                     go to rou-let-reg-130.
      *                              *---------------------------------*
      *                              * Ammesse causali con trattamento *
      *                              * valore come costi aggiuntivi o  *
      *                              * di rettifica costi              *
      *                              *---------------------------------*
           if        w-tes-cau-trt-val    =    "C" or
                     w-tes-cau-trt-val    =    "R"
                     go to rou-let-reg-200.
      *                                  *-----------------------------*
      *                                  * A trattamento errore        *
      *                                  *-----------------------------*
           go to     rou-let-reg-180.
       rou-let-reg-130.
      *                          *-------------------------------------*
      *                          * Se data registrazione superiore     *
      *                          * alla data inventario                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Ammessi tutti i tipi trattamen- *
      *                              * to valore per le causali        *
      *                              *---------------------------------*
           go to     rou-let-reg-200.
       rou-let-reg-140.
      *                      *-----------------------------------------*
      *                      * Se non si e' in periodo di inventario   *
      *                      * di fine anno                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ammessi tutti i tipi trattamento    *
      *                          * valore per le causali tranne che    *
      *                          * quelli relativi ai costi aggiunti-  *
      *                          * vi o rettifiche costo di fine eser- *
      *                          * cizio                               *
      *                          *-------------------------------------*
           if        w-tes-cau-trt-val    not  = "X" and
                     w-tes-cau-trt-val    not  = "Y"
                     go to rou-let-reg-200.
      *                              *---------------------------------*
      *                              * A trattamento errore            *
      *                              *---------------------------------*
           go to     rou-let-reg-180.
       rou-let-reg-180.
      *                  *---------------------------------------------*
      *                  * Trattamento errore se esito controllo nega- *
      *                  * tivo                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Tipo trattamento valore per la causale non ammesso
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Ripristino numero protocollo, se possi- *
      *                      * bile                                    *
      *                      *-----------------------------------------*
           perform   rip-prt-mag-000      thru rip-prt-mag-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-200.
      *                  *---------------------------------------------*
      *                  * Flag di accettazione quantita' : Si         *
      *                  *---------------------------------------------*
           move      "S"                  to   w-tes-fda-qta          .
      *                  *---------------------------------------------*
      *                  * Preparazione dei valori di testata presi    *
      *                  * automaticamente dalla causale, con visua-   *
      *                  * lizzazione dei corrispondenti valori        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Conto merce effettivo e relativa de-    *
      *                      * scrizione                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione                        *
      *                          *-------------------------------------*
           move      w-tes-cau-cod-mic    to   w-tes-ctm-cod (1)      .
           move      w-tes-ctm-cod (1)    to   w-let-arc-zmm-cod      .
           perform   let-arc-zmm-000      thru let-arc-zmm-999        .
           move      w-let-arc-zmm-des    to   w-tes-ctm-cod-des (1)  .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           if        w-tes-ctm-cod (1)    =    spaces
                     go to rou-let-reg-220.
           perform   vis-cod-mic-000      thru vis-cod-mic-999        .
           perform   vis-des-mic-000      thru vis-des-mic-999        .
       rou-let-reg-220.
      *                      *-----------------------------------------*
      *                      * Tipo archivio effettivo                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione                        *
      *                          *-------------------------------------*
           move      w-tes-cau-def-tar    to   w-tes-arc-tip (1)      .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           if        w-tes-arc-tip (1)    =    spaces
                     go to rou-let-reg-240.
           perform   vis-tip-arc-000      thru vis-tip-arc-999        .
       rou-let-reg-240.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se numero protocollo diverso da zero : modifica *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura testata registrazione indicata dal- *
      *                  * la data di registrazione, e dal numero pro- *
      *                  * tocollo impostati                           *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DATREG    "         to   f-key                  .
           move      w-tes-dat-reg        to   rf-mmt-dat-reg         .
           move      w-tes-num-prt        to   rf-mmt-num-prt         .
           move      "pgm/mag/fls/ioc/obj/iofmmt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmt                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se registrazione esi-  *
      *                  * stente oppure no                            *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-350.
       rou-let-reg-325.
      *                  *---------------------------------------------*
      *                  * Se registrazione non esistente              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Segnalazione di errore                  *
      *                      *-----------------------------------------*
           move      "Movimento di magazzino non esistente              
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-350.
      *                  *---------------------------------------------*
      *                  * Se registrazione esistente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : Modifica           *
      *                      *-----------------------------------------*
