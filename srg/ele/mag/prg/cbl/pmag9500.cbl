      *    *===========================================================*
      *    * Accettazione campo riga corpo espansa : Quantita' per il  *
      *    *                                         movimento         *
      *    *-----------------------------------------------------------*
       acc-qta-mov-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su flag di accettazione quantita'  *
      *                      *-----------------------------------------*
           if        w-tes-fda-qta        not  = "S"
                     go to acc-qta-mov-999.
      *                      *-----------------------------------------*
      *                      * Test su trattamento valore causale      *
      *                      *-----------------------------------------*
           if        w-tes-cau-trt-val    =    "C" or
                     w-tes-cau-trt-val    =    "X" or
                     w-tes-cau-trt-val    =    "R" or
                     w-tes-cau-trt-val    =    "Y"
                     go to acc-qta-mov-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-mov (1)    to   w-sav-qta-mov          .
       acc-qta-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-qta-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-qta-mov-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-mov-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-mov-999.
      *              *-------------------------------------------------*
      *              * Valore impostato in destinazione                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-mov (1)      .
       acc-qta-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-mov-410.
      *                  *---------------------------------------------*
      *                  * Se quantita' a zero : reimpostazione        *
      *                  *---------------------------------------------*
           if        w-rig-qta-mov (1)    =    zero
                     go to acc-qta-mov-100.
       acc-qta-mov-420.
      *                  *---------------------------------------------*
      *                  * Controllo su numero decimali quantita'      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Quantita' in campo di comodo ridefinito *
      *                      *-----------------------------------------*
           move      w-rig-qta-mov (1)    to   w-ctl-dec-qta-qta      .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del numero decima- *
      *                      * li quantita' da anagrafica              *
      *                      *-----------------------------------------*
           if        w-rig-num-mag-ndq (1)
                                          =    0
                     go to acc-qta-mov-422
           else if   w-rig-num-mag-ndq (1)
                                          =    1
                     go to acc-qta-mov-424
           else if   w-rig-num-mag-ndq (1)
                                          =    2
                     go to acc-qta-mov-426
           else      go to acc-qta-mov-428.
       acc-qta-mov-422.
      *                      *-----------------------------------------*
      *                      * Se numero decimali quantita' da anagra- *
      *                      * fica : 0                                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test e deviazione secondo l'esito   *
      *                          *-------------------------------------*
           if        w-ctl-dec-qta-003    =    zero  and
                     w-ctl-dec-qta-002    =    zero  and
                     w-ctl-dec-qta-001    =    zero
                     go to acc-qta-mov-440
           else      go to acc-qta-mov-430.
       acc-qta-mov-424.
      *                      *-----------------------------------------*
      *                      * Se numero decimali quantita' da anagra- *
      *                      * fica : 1                                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test e deviazione secondo l'esito   *
      *                          *-------------------------------------*
           if        w-ctl-dec-qta-003    =    zero  and
                     w-ctl-dec-qta-002    =    zero
                     go to acc-qta-mov-440
           else      go to acc-qta-mov-430.
       acc-qta-mov-426.
      *                      *-----------------------------------------*
      *                      * Se numero decimali quantita' da anagra- *
      *                      * fica : 2                                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test e deviazione secondo l'esito   *
      *                          *-------------------------------------*
           if        w-ctl-dec-qta-003    =    zero
                     go to acc-qta-mov-440
           else      go to acc-qta-mov-430.
       acc-qta-mov-428.
      *                      *-----------------------------------------*
      *                      * Se numero decimali quantita' da anagra- *
      *                      * fica : 3                                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Sempre esito Ok                     *
      *                          *-------------------------------------*
           go to     acc-qta-mov-440.
       acc-qta-mov-430.
      *                      *-----------------------------------------*
      *                      * Se numero decimali quantita' impostato  *
      *                      * errato                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Segnalazione di errore con box e    *
      *                          * rientro a reimpostazione            *
      *                          *-------------------------------------*
           if        w-rig-num-mag-ndq (1)
                                          =    0
                     go to acc-qta-mov-432
           else if   w-rig-num-mag-ndq (1)
                                          =    1
                     go to acc-qta-mov-434
           else if   w-rig-num-mag-ndq (1)
                                          =    2
                     go to acc-qta-mov-436.
       acc-qta-mov-432.
           move      "Non e' ammessa l'impostazione di cifre decimali   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-qta-mov-100.
       acc-qta-mov-434.
           move      "Non e' ammessa l'impostazione di piu' di una cifra
      -              "decimale       "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-qta-mov-100.
       acc-qta-mov-436.
           move      "Non e' ammessa l'impostazione di piu' di due cifre
      -              "decimali       "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-qta-mov-100.
       acc-qta-mov-440.
      *                      *-----------------------------------------*
      *                      * Se numero decimali quantita' impostato  *
      *                      * esatto                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A dipendenze da impostazione        *
      *                          *-------------------------------------*
           go to     acc-qta-mov-600.
       acc-qta-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-mov-625.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-qta-mov (1)    =    w-sav-qta-mov
                     go to acc-qta-mov-800.
       acc-qta-mov-650.
      *                  *---------------------------------------------*
      *                  * Trattamento valore movimento                *
      *                  *---------------------------------------------*
       acc-qta-mov-655.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-arg-mag-trp    =    "S"
                     go to acc-qta-mov-660.
      *
           if        w-tes-cau-trt-val    =    "N" or
                     w-tes-cau-trt-val    =    "S" or
                     w-tes-cau-trt-val    =    "C" or
                     w-tes-cau-trt-val    =    "X" or
                     w-tes-cau-trt-val    =    "R" or
                     w-tes-cau-trt-val    =    "Y"
                     go to acc-qta-mov-800.
       acc-qta-mov-660.
           if        w-rig-cun-mov (1)    =    zero
                     go to acc-qta-mov-800.
       acc-qta-mov-665.
      *                      *-----------------------------------------*
      *                      * Determinazione nuovo valore movimento   *
      *                      *-----------------------------------------*
           multiply  w-rig-qta-mov (1)    by   w-rig-val-mov (1)
                                        giving w-acc-qta-mov-w01      .
           divide    w-sav-qta-mov        into w-acc-qta-mov-w01
                                               rounded                .
           move      w-acc-qta-mov-w01    to   w-rig-val-mov (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione nuovo valore movimento  *
      *                      *-----------------------------------------*
           perform   vis-val-mov-000      thru vis-val-mov-999        .
       acc-qta-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-mov-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-mov-100.
       acc-qta-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' per il movimento        *
      *    *-----------------------------------------------------------*
       vis-qta-mov-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      w-rig-qta-mov (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-mov-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo espansa : Costo unitario    *
      *    *                                         movimento         *
      *    *-----------------------------------------------------------*
       acc-cun-mov-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cun-mov-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-arg-mag-trp    =    "S"
                     go to acc-cun-mov-050.
      *
           if        w-tes-cau-trt-val    =    "N" or
                     w-tes-cau-trt-val    =    "S" or
                     w-tes-cau-trt-val    =    "C" or
                     w-tes-cau-trt-val    =    "X" or
                     w-tes-cau-trt-val    =    "R" or
                     w-tes-cau-trt-val    =    "Y"
                     go to acc-cun-mov-999.
       acc-cun-mov-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-cun-mov (1)    to   w-sav-cun-mov          .
       acc-cun-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-cun-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cun-mov-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cun-mov-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cun-mov-999.
       acc-cun-mov-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in destinazione                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-cun-mov (1)      .
       acc-cun-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cun-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-cun-mov (1)    =    w-sav-cun-mov
                     go to acc-cun-mov-800.
      *                  *---------------------------------------------*
      *                  * Determinazione valore per il movimento      *
      *                  *---------------------------------------------*
           if        w-rig-cun-mov (1)    =    zero
                     go to acc-cun-mov-800.
           multiply  w-rig-qta-mov (1)    by   w-rig-cun-mov (1)
                                        giving w-rig-val-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore per il movimento     *
      *                  *---------------------------------------------*
           perform   vis-val-mov-000      thru vis-val-mov-999        .
       acc-cun-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cun-mov-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cun-mov-100.
       acc-cun-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Costo unitario movimento          *
      *    *-----------------------------------------------------------*
       vis-cun-mov-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      w-rig-cun-mov (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cun-mov-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo espansa : Valore movimento  *
      *    *-----------------------------------------------------------*
       acc-val-mov-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-val-mov-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-arg-mag-trp    =    "S"
                     go to acc-val-mov-100.
      *
           if        w-tes-cau-trt-val    =    "N" or
                     w-tes-cau-trt-val    =    "S"
                     go to acc-val-mov-999.
           if        w-tes-cau-trt-val    =    "I" and
                     w-rig-cun-mov (1)    not  = zero
                     go to acc-val-mov-999.
       acc-val-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-val-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-val-mov-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-val-mov-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-val-mov-999.
      *              *-------------------------------------------------*
      *              * Valore impostato in destinazione                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-val-mov (1)      .
       acc-val-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso se trattamento    *
      *                  * valore come costo aggiuntivo o di rettifica *
      *                  * costi sia dell'esercizio che di fine anno   *
      *                  *---------------------------------------------*
           if       (w-tes-cau-trt-val    =    "C" or
                     w-tes-cau-trt-val    =    "X" or
                     w-tes-cau-trt-val    =    "R" or
                     w-tes-cau-trt-val    =    "Y"  ) and
                     w-rig-val-mov (1)    =    zero
                     go to acc-val-mov-100.
       acc-val-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione costo unitario movimento     *
      *                  *---------------------------------------------*
           if        w-tes-cau-trt-val    =    "C" or
                     w-tes-cau-trt-val    =    "X" or
                     w-tes-cau-trt-val    =    "R" or
                     w-tes-cau-trt-val    =    "Y"
                     go to acc-val-mov-800.
           if        w-rig-qta-mov (1)    =    zero
                     go to acc-val-mov-800.
           divide    w-rig-qta-mov (1)    into w-rig-val-mov (1)
                                        giving w-rig-cun-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione costo unitario movimento    *
      *                  *---------------------------------------------*
           perform   vis-cun-mov-000      thru vis-cun-mov-999        .
       acc-val-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-val-mov-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-val-mov-100.
       acc-val-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Valore movimento                  *
      *    *-----------------------------------------------------------*
       vis-val-mov-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
