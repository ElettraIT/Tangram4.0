      *    *===========================================================*
      *    * Accettazione campo testata : Codice merce in conto        *
      *    *-----------------------------------------------------------*
       acc-cod-mic-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-mic-010.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare :                *
      *                  * - Se tipo trattamento conto merce per la    *
      *                  *   causale pari a zero o 02 : no accetta-    *
      *                  *   zione                                     *
      *                  * - Altrimenti : si' accettazione             *
      *                  *---------------------------------------------*
           if        w-tes-cau-trt-mic    =    zero or
                     w-tes-cau-trt-mic    =    02
                     go to acc-cod-mic-020
           else      go to acc-cod-mic-030.
       acc-cod-mic-020.
      *                  *---------------------------------------------*
      *                  * Se campo da non accettare                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione del   *
      *                      * codice merce in conto                   *
      *                      *-----------------------------------------*
           if        w-tes-ctm-cod (1)    =    spaces
                     go to acc-cod-mic-025.
           move      spaces               to   w-tes-ctm-cod (1)      .
           move      w-tes-ctm-cod (1)    to   w-let-arc-zmm-cod      .
           perform   let-arc-zmm-000      thru let-arc-zmm-999        .
           move      w-let-arc-zmm-des    to   w-tes-ctm-cod-des (1)  .
           perform   vis-cod-mic-000      thru vis-cod-mic-999        .
           perform   vis-des-mic-000      thru vis-des-mic-999        .
       acc-cod-mic-025.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cod-mic-999.
       acc-cod-mic-030.
      *                  *---------------------------------------------*
      *                  * Se campo da accettare                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     acc-cod-mic-100.
       acc-cod-mic-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-zmm-ope      .
           move      w-tes-ctm-cod (1)    to   w-cod-des-zmm-cod      .
           move      07                   to   w-cod-des-zmm-lin      .
           move      30                   to   w-cod-des-zmm-pos      .
           move      07                   to   w-cod-des-zmm-dln      .
           move      41                   to   w-cod-des-zmm-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-zmm-cll-000  thru cod-des-zmm-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-zmm-foi-000  thru cod-des-zmm-foi-999    .
       acc-cod-mic-110.
           perform   cod-des-zmm-cll-000  thru cod-des-zmm-cll-999    .
           if        w-cod-des-zmm-ope    =    "F+"
                     go to acc-cod-mic-115.
           if        w-cod-des-zmm-ope    =    "AC"
                     go to acc-cod-mic-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-mic-115.
           perform   cod-des-zmm-foi-000  thru cod-des-zmm-foi-999    .
           go to     acc-cod-mic-110.
       acc-cod-mic-120.
           move      w-cod-des-zmm-cod    to   v-alf                  .
       acc-cod-mic-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-mic-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-mic-999.
       acc-cod-mic-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ctm-cod (1)      .
       acc-cod-mic-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura codice merce in conto               *
      *                  *---------------------------------------------*
           move      w-tes-ctm-cod (1)    to   w-let-arc-zmm-cod      .
           perform   let-arc-zmm-000      thru let-arc-zmm-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zmm-des    to   w-tes-ctm-cod-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-mic-000      thru vis-des-mic-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se record esistente o  *
      *                  * non esistente                               *
      *                  *---------------------------------------------*
           if        w-let-arc-zmm-flg    =    spaces
                     go to acc-cod-mic-450.
       acc-cod-mic-425.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-mic-100.
       acc-cod-mic-450.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del valore         *
      *                      *-----------------------------------------*
           if        w-tes-ctm-cod (1)    =    spaces
                     go to acc-cod-mic-500.
       acc-cod-mic-475.
      *                      *-----------------------------------------*
      *                      * Se valore diverso da spaces             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     acc-cod-mic-600.
       acc-cod-mic-500.
      *                      *-----------------------------------------*
      *                      * Se valore a spaces                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il tipo trattamento merce in     *
      *                          * conto e' 01 : continuazione         *
      *                          *-------------------------------------*
           if        w-tes-cau-trt-mic    =    01
                     go to acc-cod-mic-600.
      *                          *-------------------------------------*
      *                          * Altrimenti reimpostazione, a meno   *
      *                          * che non si sia in Up                *
      *                          *-------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-cod-mic-600
           else      go to acc-cod-mic-100.
       acc-cod-mic-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-mic-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-mic-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-mic-100.
       acc-cod-mic-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice merce in conto     *
      *    *-----------------------------------------------------------*
       vis-cod-mic-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ctm-cod (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
