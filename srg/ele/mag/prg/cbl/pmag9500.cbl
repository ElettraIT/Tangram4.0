           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      04                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-num-prt        to   w-red-prt-mag-prt      .
           move      w-red-prt-mag-saa    to   w-red-prt-mag-acs      .
           move      w-red-prt-mag-nnn    to   w-red-prt-mag-acn      .
           move      w-red-prt-mag-acc    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
