      *    *-----------------------------------------------------------*
       cmp-rec-mmt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmt                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Terna da segreteria                         *
      *                  * - Data di sistema di ultimo inserimento/mo- *
      *                  *   difica                                    *
      *                  * - Codice utente di ultimo inserimento/modi- *
      *                  *   fica                                      *
      *                  * - Codice fase di ultimo inserimento/modifi- *
      *                  *   ca                                        *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-mmt-ide-dat         .
           move      s-ute                to   rf-mmt-ide-ute         .
           move      s-fas                to   rf-mmt-ide-fas         .
      *                  *---------------------------------------------*
      *                  * Data di registrazione                       *
      *                  *---------------------------------------------*
           move      w-tes-dat-reg        to   rf-mmt-dat-reg         .
      *                  *---------------------------------------------*
      *                  * Numero protocollo                           *
      *                  *---------------------------------------------*
           move      w-tes-num-prt        to   rf-mmt-num-prt         .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza                           *
      *                  *---------------------------------------------*
           move      w-tes-cod-dpz        to   rf-mmt-cod-dpz         .
      *                  *---------------------------------------------*
      *                  * Codice causale                              *
      *                  *---------------------------------------------*
           move      w-tes-cau-cod        to   rf-mmt-cod-cau         .
      *                  *---------------------------------------------*
      *                  * Trattamento valore per il movimento         *
      *                  *---------------------------------------------*
           move      w-tes-cau-trt-val    to   rf-mmt-trt-val         .
      *                  *---------------------------------------------*
      *                  * Tipo movimentazione di magazzino            *
      *                  *---------------------------------------------*
           move      w-tes-cau-tip-mdm    to   rf-mmt-tip-mdm         .
      *                  *---------------------------------------------*
      *                  * Tipo trattamento conto merce                *
      *                  *---------------------------------------------*
           move      w-tes-cau-trt-mic    to   rf-mmt-trt-mic         .
      *                  *---------------------------------------------*
      *                  * Tipo conto merce                            *
      *                  *---------------------------------------------*
           move      w-tes-cau-tip-mic    to   rf-mmt-tip-mic         .
      *                  *---------------------------------------------*
      *                  * Default codice conto merce                  *
      *                  *---------------------------------------------*
           move      w-tes-cau-cod-mic    to   rf-mmt-cod-mic         .
      *                  *---------------------------------------------*
      *                  * Si/no possibilita' di variare il default    *
      *                  * per il codice conto merce                   *
      *                  *---------------------------------------------*
           move      w-tes-cau-snv-mic    to   rf-mmt-snv-mic         .
      *                  *---------------------------------------------*
      *                  * Tipo archivio di default                    *
      *                  *---------------------------------------------*
           move      w-tes-cau-def-tar    to   rf-mmt-def-tar         .
      *                  *---------------------------------------------*
      *                  * Si/no possibilita' di variare il default    *
      *                  * per il tipo archivio                        *
      *                  *---------------------------------------------*
           move      w-tes-cau-snv-tar    to   rf-mmt-snv-tar         .
      *                  *---------------------------------------------*
      *                  * Lista dei tipi archivio ammessi             *
      *                  *---------------------------------------------*
           move      w-tes-cau-lst-tar    to   rf-mmt-lst-tar         .
      *                  *---------------------------------------------*
      *                  * Codice dislocazione di default              *
      *                  *---------------------------------------------*
           move      w-tes-cau-def-dsl    to   rf-mmt-def-dsl         .
      *                  *---------------------------------------------*
      *                  * Codice dislocazione di dislocazione di de-  *
      *                  * fault                                       *
      *                  *---------------------------------------------*
           move      w-tes-cau-def-dsd    to   rf-mmt-def-dsd         .
      *                  *---------------------------------------------*
      *                  * Si/no possibilita' di variare i defaults    *
      *                  * per i codici dislocazione                   *
      *                  *---------------------------------------------*
           move      w-tes-cau-snv-dsl    to   rf-mmt-snv-dsl         .
      *                  *---------------------------------------------*
      *                  * Codice conto merce effettivo                *
      *                  *---------------------------------------------*
           move      w-tes-ctm-cod (1)    to   rf-mmt-cod-ctm         .
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
           move      w-tes-dat-doc (1)    to   rf-mmt-dat-doc         .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      w-tes-num-doc (1)    to   rf-mmt-num-doc         .
      *                  *---------------------------------------------*
      *                  * Codice dislocazione effettivo               *
      *                  *---------------------------------------------*
           move      w-tes-cod-dsl (1)    to   rf-mmt-cod-dsl         .
      *                  *---------------------------------------------*
      *                  * Codice dislocazione di destinazione effet-  *
      *                  * tivo                                        *
      *                  *---------------------------------------------*
           move      w-tes-cod-dsd (1)    to   rf-mmt-cod-dsd         .
      *                  *---------------------------------------------*
      *                  * Tipo archivio effettivo                     *
      *                  *---------------------------------------------*
           move      w-tes-arc-tip (1)    to   rf-mmt-tip-arc         .
      *                  *---------------------------------------------*
      *                  * Codice archivio                             *
      *                  *---------------------------------------------*
           move      w-tes-arc-cod (1)    to   rf-mmt-cod-arc         .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza relativo al codice archi- *
      *                  * vio                                         *
      *                  *---------------------------------------------*
           move      w-tes-arc-dpz (1)    to   rf-mmt-dpz-arc         .
      *                  *---------------------------------------------*
      *                  * Flags di elaborazione, sia bloccanti che    *
      *                  * non bloccanti                               *
      *                  *---------------------------------------------*
           move      w-tes-flg-ela (1)    to   rf-mmt-flg-ela         .
      *                  *---------------------------------------------*
      *                  * Flag di sottoponibilita' a pulizia          *
      *                  *---------------------------------------------*
           move      w-tes-flg-pul (1)    to   rf-mmt-flg-pul         .
      *                  *---------------------------------------------*
      *                  * Area libera per espansioni speciali         *
      *                  *---------------------------------------------*
           move      w-tes-alx-exp (1)    to   rf-mmt-alx-exp         .
       cmp-rec-mmt-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record testata [mmt]                            *
      *    *-----------------------------------------------------------*
       wrt-rec-mmt-000.
