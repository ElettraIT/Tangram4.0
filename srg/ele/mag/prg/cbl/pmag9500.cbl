      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Tipo    *
      *    *                                    codice di magazzino    *
      *    *-----------------------------------------------------------*
       acc-tip-mag-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-mag-010.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-tip-mag (1)    =    01
                     move  "P  "          to   w-sav-tip-mag
           else if   w-rig-tip-mag (1)    =    02
                     move  "S  "          to   w-sav-tip-mag
           else if   w-rig-tip-mag (1)    =    03
                     move  "M  "          to   w-sav-tip-mag
           else if   w-rig-tip-mag (1)    =    04
                     move  "V  "          to   w-sav-tip-mag
           else      move  spaces         to   w-sav-tip-mag          .
       acc-tip-mag-020.
      *                  *---------------------------------------------*
      *                  * Preparazione area di supporto per accetta-  *
      *                  * zione tipo codice di magazzino              *
      *                  *---------------------------------------------*
           move      w-sav-tip-mag        to   w-acc-def-mag          .
       acc-tip-mag-030.
      *                  *---------------------------------------------*
      *                  * Preparazione del valore di default          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore precedente non nullo : nessu- *
      *                      * na preparazione per il default          *
      *                      *-----------------------------------------*
           if        w-acc-def-mag        not  = spaces
                     go to acc-tip-mag-040.
      *                      *-----------------------------------------*
      *                      * Se le personalizzazioni indicano che    *
      *                      * - la gestione [dps] non e' attiva       *
      *                      * - la gestione [dpm] non e' attiva       *
      *                      * - la gestione [mtv] non e' attiva       *
      *                      * si pone il default per il [dcp], ovvero *
      *                      * per il prodotto finito                  *
      *                      *-----------------------------------------*
           if        w-prs-arg-dps-snx    not  = "S" and
                     w-prs-arg-dpm-snx    not  = "S" and
                     w-prs-arg-mtv-snx    not  = "S"
                     move  "P  "          to   w-acc-def-mag
                     go to acc-tip-mag-040.
      *                      *-----------------------------------------*
      *                      * Preparazione default                    *
      *                      *-----------------------------------------*
           move      w-tes-cau-def-tco    to   w-acc-def-mag          .
      *                      *-----------------------------------------*
      *                      * Normalizzazione default                 *
      *                      *-----------------------------------------*
           if        w-acc-def-mag        not  = spaces and
                     w-acc-def-mag        not  = "P  "  and
                     w-acc-def-mag        not  = "S  "  and
                     w-acc-def-mag        not  = "M  "  and
                     w-acc-def-mag        not  = "V  "
                     move  spaces         to   w-acc-def-mag          .
       acc-tip-mag-040.
      *                  *---------------------------------------------*
      *                  * Preparazione area w-exp per accettazione    *
      *                  * mediante pop-up dei soli tipi codice di     *
      *                  * magazzino ammessi                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se la lista dei tipi codice di magazzi- *
      *                      * no e' a Spaces : si accettano tutti i   *
      *                      * tipi codice di magazzino                *
      *                      *-----------------------------------------*
           if        w-tes-cau-lst-tco    not  = spaces
                     go to acc-tip-mag-044.
       acc-tip-mag-042.
           move      w-exp-tip-mag-tbl    to   w-exp-tip-cam-num      .
           move      w-exp-tip-mag-tbl    to   w-exp-tip-cam-tbl      .
           move      w-exp-tip-mag-ast    to   w-exp-tip-cam-ass      .
           go to     acc-tip-mag-080.
       acc-tip-mag-044.
      *                      *-----------------------------------------*
      *                      * Altrimenti si prepara l'area con i soli *
      *                      * tipi codice di magazzino ammessi        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione iniziale            *
      *                          *-------------------------------------*
           move      spaces               to   w-exp-tip-cam-ass      .
      *                          *-------------------------------------*
      *                          * Tipo codice di magazzino 'P' : se   *
      *                          * presente nella lista tipi codice    *
      *                          * di magazzino ammessi per la causa-  *
      *                          * le lo si inserisce nella lista, in  *
      *                          * caso contrario non lo si inserisce  *
      *                          *-------------------------------------*
           move      zero                 to   w-exp-tip-cam-c01      .
           inspect   w-tes-cau-lst-tco
                                      tallying w-exp-tip-cam-c01
                     for                  all  "P"                    .
           if        w-exp-tip-cam-c01    >    zero
                     move  "P"            to   w-exp-tip-cam-tcm (1)  .
      *                          *-------------------------------------*
      *                          * Tipo codice di magazzino 'S' : se   *
      *                          * presente nella lista tipi codice    *
      *                          * di magazzino ammessi per la causa-  *
      *                          * le lo si inserisce nella lista, in  *
      *                          * caso contrario non lo si inserisce; *
      *                          * se pero' la gestione [dps] non e'   *
      *                          * attiva, comunque non lo si inseri-  *
      *                          * sce                                 *
      *                          *-------------------------------------*
           if        w-prs-arg-dps-snx    not  = "S"
                     go to acc-tip-mag-045.
           move      zero                 to   w-exp-tip-cam-c01      .
           inspect   w-tes-cau-lst-tco
                                      tallying w-exp-tip-cam-c01
                     for                  all  "S"                    .
           if        w-exp-tip-cam-c01    >    zero
                     move  "S"            to   w-exp-tip-cam-tcm (2)  .
       acc-tip-mag-045.
      *                          *-------------------------------------*
      *                          * Tipo codice di magazzino 'M' : se   *
      *                          * presente nella lista tipi codice    *
      *                          * di magazzino ammessi per la causa-  *
      *                          * le lo si inserisce nella lista, in  *
      *                          * caso contrario non lo si inserisce; *
      *                          * se pero' la gestione [dpm] non e'   *
      *                          * attiva, comunque non lo si inseri-  *
      *                          * sce                                 *
      *                          *-------------------------------------*
           if        w-prs-arg-dpm-snx    not  = "S"
                     go to acc-tip-mag-046.
           move      zero                 to   w-exp-tip-cam-c01      .
           inspect   w-tes-cau-lst-tco
                                      tallying w-exp-tip-cam-c01
                     for                  all  "M"                    .
           if        w-exp-tip-cam-c01    >    zero
                     move  "M"            to   w-exp-tip-cam-tcm (3)  .
       acc-tip-mag-046.
      *                          *-------------------------------------*
      *                          * Tipo codice di magazzino 'V' : se   *
      *                          * presente nella lista tipi codice    *
      *                          * di magazzino ammessi per la causa-  *
      *                          * le lo si inserisce nella lista, in  *
      *                          * caso contrario non lo si inserisce; *
      *                          * se pero' la gestione [mtv] non e'   *
      *                          * attiva, comunque non lo si inseri-  *
      *                          * sce                                 *
      *                          *-------------------------------------*
           if        w-prs-arg-mtv-snx    not  = "S"
                     go to acc-tip-mag-047.
           move      zero                 to   w-exp-tip-cam-c01      .
           inspect   w-tes-cau-lst-tco
                                      tallying w-exp-tip-cam-c01
                     for                  all  "V"                    .
           if        w-exp-tip-cam-c01    >    zero
                     move  "V"            to   w-exp-tip-cam-tcm (4)  .
       acc-tip-mag-047.
      *                          *-------------------------------------*
      *                          * Se la lista cosi' determinata ri-   *
      *                          * sulta vuota si accettano tutti i    *
      *                          * tipi codice di magazzino            *
      *                          *-------------------------------------*
           if        w-exp-tip-cam-ass    =    spaces
                     go to acc-tip-mag-042.
       acc-tip-mag-048.
      *                          *-------------------------------------*
      *                          * Compattamento della lista dei tipi  *
      *                          * codice di magazzino ammessi         *
      *                          *-------------------------------------*
           if        w-exp-tip-cam-tcm (1)
                                          =    spaces
                     move  w-exp-tip-cam-tcm (2)
                                          to   w-exp-tip-cam-tcm (1)
                     move  w-exp-tip-cam-tcm (3)
                                          to   w-exp-tip-cam-tcm (2)
                     move  w-exp-tip-cam-tcm (4)
                                          to   w-exp-tip-cam-tcm (3)
                     move  spaces         to   w-exp-tip-cam-tcm (4)  .
           if        w-exp-tip-cam-tcm (2)
                                          =    spaces
                     move  w-exp-tip-cam-tcm (3)
                                          to   w-exp-tip-cam-tcm (2)
                     move  w-exp-tip-cam-tcm (4)
                                          to   w-exp-tip-cam-tcm (3)
                     move  spaces         to   w-exp-tip-cam-tcm (4)  .
           if        w-exp-tip-cam-tcm (3)
                                          =    spaces
                     move  w-exp-tip-cam-tcm (4)
                                          to   w-exp-tip-cam-tcm (3)
                     move  spaces         to   w-exp-tip-cam-tcm (4)  .
       acc-tip-mag-050.
      *                          *-------------------------------------*
      *                          * Preparazione del numero di elementi *
      *                          * in tabella tipi codice di magazzi-  *
      *                          * no ammessi                          *
      *                          *-------------------------------------*
           move      zero                 to   w-exp-tip-cam-c01      .
           inspect   w-exp-tip-cam-ass
                                      tallying w-exp-tip-cam-c01
                     for                  all  spaces                 .
           move      04                   to   w-exp-tip-cam-num      .
           subtract  w-exp-tip-cam-c01    from w-exp-tip-cam-num      .
       acc-tip-mag-052.
      *                          *-------------------------------------*
      *                          * Preparazione delle descrizioni re-  *
      *                          * lative ai tipi codice di magazzino  *
      *                          * ammessi                             *
      *                          *-------------------------------------*
           move      zero                 to   w-exp-tip-cam-c01      .
       acc-tip-mag-054.
           add       1                    to   w-exp-tip-cam-c01      .
           if        w-exp-tip-cam-c01    >    04
                     go to acc-tip-mag-080.
           move      zero                 to   w-exp-tip-cam-i01      .
           inspect   w-exp-tip-mag-ast
                                      tallying w-exp-tip-cam-i01
                     for   characters   before
                                       initial w-exp-tip-cam-tcm
                                              (w-exp-tip-cam-c01)     .
           if        w-exp-tip-cam-i01    =    w-exp-tip-mag-num
                     move  spaces         to   w-exp-tip-cam-ele
                                              (w-exp-tip-cam-c01)
                     go to acc-tip-mag-054.
           add       01                   to   w-exp-tip-cam-i01      .
           move      w-exp-tip-mag-ele
                    (w-exp-tip-cam-i01)   to   w-exp-tip-cam-ele
                                              (w-exp-tip-cam-c01)     .
           go to     acc-tip-mag-054.
       acc-tip-mag-080.
      *                  *---------------------------------------------*
      *                  * Preparazione flag di ammissibilita' per il  *
      *                  * tasto Find                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non New : no                    *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     move  spaces         to   w-acc-fnd-mag
                     go to acc-tip-mag-100.
      *                      *-----------------------------------------*
      *                      * Se esiste un default per il tipo codi-  *
      *                      * ce di magazzino, e questo non e' varia- *
      *                      * bile : no                               *
      *                      *-----------------------------------------*
           if       (w-tes-cau-def-tco    =    "P  " or
                     w-tes-cau-def-tco    =    "S  " or
                     w-tes-cau-def-tco    =    "M  " or
                     w-tes-cau-def-tco    =    "V  "  ) and
                    (w-tes-cau-snv-tco    =    "N"    )
                     move  spaces         to   w-acc-fnd-mag
                     go to acc-tip-mag-100.
      *                      *-----------------------------------------*
      *                      * Se esiste un solo elemento nella tabel- *
      *                      * la di accettazione mediante pop-up : no *
      *                      *-----------------------------------------*
           if        w-exp-tip-cam-num    not  > 1
                     move  spaces         to   w-acc-fnd-mag
                     go to acc-tip-mag-100.
      *                      *-----------------------------------------*
      *                      * In tutti gli altri casi si ammette la   *
      *                      * possibilita' di Find                    *
      *                      *-----------------------------------------*
           move      "S"                  to   w-acc-fnd-mag          .
       acc-tip-mag-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore in formato normale          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-acc-def-mag        to   w-acc-tip-mag          .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      25                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : ammesso solo se determinato pre- *
      *                      *        cedentemente                     *
      *                      *-----------------------------------------*
           if        w-acc-fnd-mag        not  = spaces
                     move  "FIND"         to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-acc-tip-mag        to   v-alf                  .
       acc-tip-mag-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                      *-----------------------------------------*
      *                      * Valore impostato in campo di accetta-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      v-alf                to   w-acc-tip-mag          .
       acc-tip-mag-205.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-mag-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-mag-250.
       acc-tip-mag-210.
      *                  *---------------------------------------------*
      *                  * Accettazione mediante pop-up                *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-cam-lun    to   v-car                  .
           move      w-exp-tip-cam-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-cam-tbl    to   v-txt                  .
           move      18                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      zero                 to   w-exp-tip-cam-c01      .
           inspect   w-exp-tip-cam-ass
                                      tallying w-exp-tip-cam-c01
                     for   characters   before
                                       initial w-acc-tip-mag          .
           if        w-exp-tip-cam-c01    not  < w-exp-tip-arc-num
                     move  zero           to   v-num
           else      move  w-exp-tip-cam-c01
                                          to   v-num
                     add   1              to   v-num                  .
           if        w-acc-tip-mag        =    spaces
                     move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura function-key a Spaces             *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Se valore non accettabile : reimpostazione  *
      *                  * mediante pop-up                             *
      *                  *---------------------------------------------*
           if        v-num                >    w-exp-tip-cam-num or
                     v-num                =    zero
                     go to acc-tip-mag-210.
      *                  *---------------------------------------------*
      *                  * Corrispondente alfanumerico del valore im-  *
      *                  * postato in campo di accettazione normale    *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-tip-cam-i01      .
           move      w-exp-tip-cam-tcm
                    (w-exp-tip-cam-i01)   to   w-acc-tip-mag          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore alfanumerico         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      w-acc-tip-mag        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * A post-accettazione normale                 *
      *                  *---------------------------------------------*
           go to     acc-tip-mag-205.
       acc-tip-mag-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-mag-300
           else      go to acc-tip-mag-350.
       acc-tip-mag-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      w-acc-tip-mag        to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-mag-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-mag-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-mag-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-mag-310.
       acc-tip-mag-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-mag-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-mag-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-mag-999.
       acc-tip-mag-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-mag-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
       acc-tip-mag-360.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                not  =    "DOWN"
                     go to acc-tip-mag-375.
           if        w-sav-tip-mag        not  = spaces
                     go to acc-tip-mag-365.
           move      zero                 to   w-rig-tip-mag (1)      .
           perform   vis-tip-mag-000      thru vis-tip-mag-999        .
       acc-tip-mag-365.
           move      "D"                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-mag-999.
       acc-tip-mag-375.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-mag-999
                     else    go to acc-tip-mag-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-mag-999.
       acc-tip-mag-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-acc-tip-mag        =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-mag-999
                     else  go to acc-tip-mag-100.
      *                  *---------------------------------------------*
      *                  * Se non e' uno dei tipi codice di magazzino  *
      *                  * previsti si tratta come per il tasto Slct   *
      *                  *---------------------------------------------*
           if        w-acc-tip-mag        not  = "P" and
                     w-acc-tip-mag        not  = "S" and
                     w-acc-tip-mag        not  = "M" and
                     w-acc-tip-mag        not  = "V"
                     go to acc-tip-mag-300.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-acc-tip-mag        not  = w-sav-tip-mag
                     go to acc-tip-mag-100.
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           if        w-acc-tip-mag        =    "P  "
                     move  01             to   w-rig-tip-mag (1)
           else if   w-acc-tip-mag        =    "S  "
                     move  02             to   w-rig-tip-mag (1)
           else if   w-acc-tip-mag        =    "M  "
                     move  03             to   w-rig-tip-mag (1)
           else if   w-acc-tip-mag        =    "V  "
                     move  04             to   w-rig-tip-mag (1)
           else      go to acc-tip-mag-100.
       acc-tip-mag-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-mag-800.
       acc-tip-mag-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo codice di magazzino          *
      *    *-----------------------------------------------------------*
       vis-tip-mag-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      25                   to   v-pos                  .
           if        w-rig-tip-mag (1)    =    01
                     move  "P  "          to   v-alf
           else if   w-rig-tip-mag (1)    =    02
                     move  "S  "          to   v-alf
