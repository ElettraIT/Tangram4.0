      *    *-----------------------------------------------------------*
       vis-des-mic-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-ctm-cod-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-mic-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo archivio                *
      *    *-----------------------------------------------------------*
       acc-tip-arc-000.
      *              *-------------------------------------------------*
      *              * Salvataggio del valore precedente               *
      *              *-------------------------------------------------*
           move      w-tes-arc-tip (1)    to   w-sav-arc-tip          .
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo trattamento conto merce e' 01,   *
      *                  * ovvero la causale puo' riferirsi ad un do-  *
      *                  * cumento di movimentazione di merce in con-  *
      *                  * to, ed inoltre e' stato impostato un codi-  *
      *                  * ce di merce in conto : si' accettazione     *
      *                  *---------------------------------------------*
           if        w-tes-cau-trt-mic    =    01   and
                     w-tes-ctm-cod (1)    not  = spaces
                     go to acc-tip-arc-025.
      *                  *---------------------------------------------*
      *                  * Se il tipo trattamento conto merce e' 03,   *
      *                  * ovvero la causale stessa e' di movimenta-   *
      *                  * zione di merce in conto : si' accettazione  *
      *                  *---------------------------------------------*
           if        w-tes-cau-trt-mic    =    03
                     go to acc-tip-arc-025.
      *                  *---------------------------------------------*
      *                  * Se tipo archivio di default 'N' e possibi-  *
      *                  * ta' di variare il tipo archivio a 'N' : no  *
      *                  * accettazione                                *
      *                  *---------------------------------------------*
           if        w-tes-cau-def-tar    =    "N" and
                     w-tes-cau-snv-tar    =    "N"
                     go to acc-tip-arc-999.
      *                  *---------------------------------------------*
      *                  * Se tipo archivio di default 'C' o 'F' o 'D' *
      *                  * e possibita' di variare il tipo archivio a  *
      *                  * 'N' : no accettazione, ma forzatura del     *
      *                  * valore di defualt e poi uscita              *
      *                  *---------------------------------------------*
           if       (w-tes-cau-def-tar    =    "C" or
                     w-tes-cau-def-tar    =    "F" or
                     w-tes-cau-def-tar    =    "D"  ) and
                    (w-tes-cau-snv-tar    =    "N"  )
                     go to acc-tip-arc-010
           else      go to acc-tip-arc-025.
       acc-tip-arc-010.
           if        w-tes-arc-tip (1)    =    w-tes-cau-def-tar
                     go to acc-tip-arc-999.
           move      w-tes-cau-def-tar    to   w-tes-arc-tip (1)      .
           perform   vis-tip-arc-000      thru vis-tip-arc-999        .
           go to     acc-tip-arc-999.
       acc-tip-arc-025.
      *              *-------------------------------------------------*
      *              * Preparazione area w-exp limitata ai soli tipi   *
      *              * archivio previsti                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se lista tipi archivio ammessi a Spaces :   *
      *                  * si accettano tutti i tipi archivio          *
      *                  *---------------------------------------------*
           if        w-tes-cau-lst-tar    not  = spaces
                     go to acc-tip-arc-035.
       acc-tip-arc-030.
           move      w-exp-tip-arc-num    to   w-exp-tip-aam-num      .
           move      w-exp-tip-arc-tbl    to   w-exp-tip-aam-tbl      .
           move      w-exp-tip-arc-ast    to   w-exp-tip-aam-ass      .
           go to     acc-tip-arc-075.
       acc-tip-arc-035.
      *                  *---------------------------------------------*
      *                  * Altrimenti si prepara l'area con i soli ti- *
      *                  * pi archivio ammessi                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione iniziale                *
      *                      *-----------------------------------------*
           move      spaces               to   w-exp-tip-aam-ass      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'No tipo archivio' :      *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cau-lst-tar
                                      tallying w-exp-tip-aam-c01
                     for                  all  "N"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "N"            to   w-exp-tip-aam-tar (1)  .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Clienti' :               *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cau-lst-tar
                                      tallying w-exp-tip-aam-c01
                     for                  all  "C"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "C"            to   w-exp-tip-aam-tar (2)  .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Fornitori' :             *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cau-lst-tar
                                      tallying w-exp-tip-aam-c01
                     for                  all  "F"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "F"            to   w-exp-tip-aam-tar (3)  .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Nostre dipendenze' :     *
      *                      * - Se esiste una sola dipendenza non lo  *
      *                      *   si inserisce nella lista              *
      *                      *-----------------------------------------*
           if        w-dpz-ctr-dpz        not  > 1
                     go to acc-tip-arc-040.
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Nostre dipendenze' :     *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cau-lst-tar
                                      tallying w-exp-tip-aam-c01
                     for                  all  "D"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "D"            to   w-exp-tip-aam-tar (4)  .
       acc-tip-arc-040.
      *                      *-----------------------------------------*
      *                      * Se la lista cosi' determinata risulta   *
      *                      * vuota si accettano tutti i tipi di ar-  *
      *                      * chivio                                  *
      *                      *-----------------------------------------*
           if        w-exp-tip-aam-ass    =    spaces
                     go to acc-tip-arc-030.
      *                      *-----------------------------------------*
      *                      * Compattamento della lista dei tipi ar-  *
      *                      * chivio ammessi e determinazione del nu- *
      *                      * mero di elementi in tabella             *
      *                      *-----------------------------------------*
           move      w-exp-tip-aam-ass    to   w-exp-tip-aam-wst      .
           move      spaces               to   w-exp-tip-aam-ass      .
           move      zero                 to   w-exp-tip-aam-num      .
           move      zero                 to   w-exp-tip-aam-c01      .
       acc-tip-arc-042.
           add       1                    to   w-exp-tip-aam-c01      .
           if        w-exp-tip-aam-c01    >    4
                     go to acc-tip-arc-045.
           if        w-exp-tip-aam-wtr
                    (w-exp-tip-aam-c01)   =    spaces
                     go to acc-tip-arc-042.
           add       1                    to   w-exp-tip-aam-num      .
           move      w-exp-tip-aam-wtr
                    (w-exp-tip-aam-c01)   to   w-exp-tip-aam-tar
                                              (w-exp-tip-aam-num)     .
           go to     acc-tip-arc-042.
       acc-tip-arc-045.
      *                      *-----------------------------------------*
      *                      * Preparazione delle descrizioni relative *
      *                      * ai tipi archivio ammessi                *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
       acc-tip-arc-050.
           add       1                    to   w-exp-tip-aam-c01      .
           if        w-exp-tip-aam-c01    >    04
                     go to acc-tip-arc-075.
           move      zero                 to   w-exp-tip-aam-i01      .
           inspect   w-exp-tip-arc-ast
                                      tallying w-exp-tip-aam-i01
                     for   characters   before
                                       initial w-exp-tip-aam-tar
                                              (w-exp-tip-aam-c01)     .
           if        w-exp-tip-aam-i01    =    w-exp-tip-arc-num
                     move  spaces         to   w-exp-tip-aam-ele
                                              (w-exp-tip-aam-c01)
                     go to acc-tip-arc-050.
           add       01                   to   w-exp-tip-aam-i01      .
           move      w-exp-tip-arc-ele
                    (w-exp-tip-aam-i01)   to   w-exp-tip-aam-ele
                                              (w-exp-tip-aam-c01)     .
           go to     acc-tip-arc-050.
       acc-tip-arc-075.
      *              *-------------------------------------------------*
      *              * Preparazione eventuale del valore di default    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore gia' presente : no preparazione   *
      *                  *---------------------------------------------*
           if        w-tes-arc-tip (1)    not  = spaces
                     go to acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Se default a Spaces : no preparazione       *
      *                  *---------------------------------------------*
           if        w-tes-cau-def-tar    =    spaces
                     go to acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Se default non compreso nella lista dei ti- *
      *                  * pi archivio previsti : no preparazione      *
      *                  *---------------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-exp-tip-aam-ass
                                      tallying w-exp-tip-aam-c01
                     for                  all  w-tes-cau-def-tar      .
           if        w-exp-tip-aam-c01    =    zero
                     go to acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Preparazione default                        *
      *                  *---------------------------------------------*
           move      w-tes-cau-def-tar    to   w-tes-arc-tip (1)      .
       acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Se la tabella dei tipi archivio ammessi e'  *
      *                  * formata da un solo elemento : si forza il   *
      *                  * valore corrispondente, si visualizza, e si  *
      *                  * esce                                        *
      *                  *---------------------------------------------*
           if        w-exp-tip-aam-num    not  = 1
                     go to acc-tip-arc-100.
           move      w-exp-tip-aam-tar (1)
                                          to   w-tes-arc-tip (1)      .
           perform   vis-tip-arc-000      thru vis-tip-arc-999        .
           go to     acc-tip-arc-999.
       acc-tip-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-aam-lun    to   v-car                  .
           move      w-exp-tip-aam-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-aam-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-exp-tip-aam-ass
                                      tallying w-exp-tip-aam-c01
                     for   characters   before
                                       initial w-tes-arc-tip (1)      .
           if        w-exp-tip-aam-c01    not  < w-exp-tip-arc-num
                     move  zero           to   v-num
           else      move  w-exp-tip-aam-c01
                                          to   v-num
                     add   1              to   v-num                  .
           if        w-tes-arc-tip (1)    =    spaces
                     move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-arc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-arc-999.
       acc-tip-arc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-exp-tip-aam-i01      .
           if        w-exp-tip-aam-i01    =    zero
                     move  spaces         to   w-tes-arc-tip (1)
           else      move  w-exp-tip-aam-tar
                          (w-exp-tip-aam-i01)
                                          to   w-tes-arc-tip (1)      .
       acc-tip-arc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se causale di movimen- *
      *                  * tazione merce in conto oppure no            *
      *                  *---------------------------------------------*
           if        w-tes-cau-trt-mic    =    02
                     go to acc-tip-arc-425
           else      go to acc-tip-arc-450.
       acc-tip-arc-425.
      *                  *---------------------------------------------*
      *                  * Se causale non di movimentazione merce in   *
      *                  * conto                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessun controllo, continuazione         *
      *                      *-----------------------------------------*
           go to     acc-tip-arc-600.
       acc-tip-arc-450.
      *                  *---------------------------------------------*
      *                  * Se causale di movimentazione merce in conto *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione ulteriore a seconda se il    *
      *                      * codice merce in conto e' obbligatorio   *
      *                      * o facoltativo                           *
      *                      *-----------------------------------------*
           if        w-tes-cau-trt-mic    =    03
                     go to acc-tip-arc-475
           else      go to acc-tip-arc-500.
       acc-tip-arc-475.
      *                      *-----------------------------------------*
      *                      * Se il codice merce in conto e' obbliga- *
      *                      * torio                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il tipo archivio esiste ma non   *
      *                          * e' ne' 'C' ne 'F' : messaggio di    *
      *                          * errore e reimpostazione             *
      *                          *-------------------------------------*
           if        w-tes-arc-tip (1)    not  = spaces and
                     w-tes-arc-tip (1)    not  = "C"    and
                     w-tes-arc-tip (1)    not  = "F"
                     go to acc-tip-arc-477
           else      go to acc-tip-arc-480.
       acc-tip-arc-477.
           move      "Tipo archivio non ammesso per movimentazione di me
      -              "rce in conto   "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-tip-arc-100.
       acc-tip-arc-480.
      *                          *-------------------------------------*
      *                          * Se il tipo archivio manca e non si  *
      *                          * e' in Up : messaggio di errore e    *
      *                          * reimpostazione                      *
      *                          *-------------------------------------*
           if        w-tes-arc-tip (1)    not  = spaces
                     go to acc-tip-arc-485.
           if        v-key                =    "UP  "
                     go to acc-tip-arc-485.
           move      "Il tipo archivio e' obbligatorio per i movimenti m
      -              "erce in conto  "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-tip-arc-100.
       acc-tip-arc-485.
      *                          *-------------------------------------*
      *                          * A dipendenze da impostazione        *
      *                          *-------------------------------------*
           go to     acc-tip-arc-600.
       acc-tip-arc-500.
      *                      *-----------------------------------------*
      *                      * Se il codice merce in conto e' facolta- *
      *                      * tivo                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se e' stato effettivamente imposta- *
      *                          * to un codice di merce in conto, si  *
      *                          * segue la stessa strada descritta    *
      *                          * per il codice merce in conto obbli- *
      *                          * gatorio, altrimenti non si esegue   *
      *                          * alcun controllo e si va' alle di-   *
      *                          * pendenze dall'impostazione          *
      *                          *-------------------------------------*
           if        w-tes-ctm-cod (1)    not  = spaces
                     go to acc-tip-arc-475
           else      go to acc-tip-arc-600.
       acc-tip-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra valore attuale e valore sal-  *
      *                  * vato ad inizio accettazione                 *
      *                  *---------------------------------------------*
           if        w-tes-arc-tip (1)    =    w-sav-arc-tip
                     go to acc-tip-arc-625
           else      go to acc-tip-arc-650.
       acc-tip-arc-625.
      *                  *---------------------------------------------*
      *                  * Se valore attuale pari al valore salvato ad *
      *                  * inizio accettazione                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessuna dipendenza, a controllo finale  *
      *                      * su eventuale tasto Do                   *
      *                      *-----------------------------------------*
           go to     acc-tip-arc-800.
       acc-tip-arc-650.
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal valore salva- *
      *                  * to ad inizio accettazione                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il valore precedente era Spaces op-  *
      *                      * pure 'N' : nessuna dipendenza,  a con-  *
      *                      * trollo finale su eventuale tasto Do     *
      *                      *-----------------------------------------*
           if        w-sav-arc-tip        =    spaces or
                     w-sav-arc-tip        =    "N"
                     go to acc-tip-arc-800.
       acc-tip-arc-655.
      *                      *-----------------------------------------*
      *                      * Normalizzazione codice archivio e de-   *
      *                      * scrizione per codice archivio, se ne-   *
      *                      * cessario                                *
      *                      *-----------------------------------------*
           if        w-tes-arc-cod (1)    =    zero
                     go to acc-tip-arc-660.
           move      zero                 to   w-tes-arc-cod (1)      .
           move      spaces               to   w-tes-arc-cod-des (1)  .
           perform   vis-cod-arc-000      thru vis-cod-arc-999        .
           perform   vis-des-arc-000      thru vis-des-arc-999        .
       acc-tip-arc-660.
      *                      *-----------------------------------------*
      *                      * Normalizzazione codice dipendenza per   *
      *                      * codice archivio, ragione sociale, in-   *
      *                      * dirizzo, localita', se necessario       *
      *                      *-----------------------------------------*
           if        w-tes-arc-dpz (1)    =    spaces
                     go to acc-tip-arc-675.
           move      spaces               to   w-tes-arc-dpz (1)      .
           move      spaces               to   w-tes-arc-dpz-rag (1)  .
           move      spaces               to   w-tes-arc-dpz-via (1)  .
           move      spaces               to   w-tes-arc-dpz-loc (1)  .
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-rag-dpz-000      thru vis-rag-dpz-999        .
           perform   vis-via-dpz-000      thru vis-via-dpz-999        .
           perform   vis-loc-dpz-000      thru vis-loc-dpz-999        .
       acc-tip-arc-675.
      *                      *-----------------------------------------*
      *                      * A controllo finale su tasto Do          *
      *                      *-----------------------------------------*
           go to     acc-tip-arc-800.
       acc-tip-arc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-arc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-arc-100.
       acc-tip-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo archivio             *
      *    *-----------------------------------------------------------*
       vis-tip-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-arc-lun    to   v-car                  .
           move      w-exp-tip-arc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-arc-tbl    to   v-txt                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           if        w-tes-arc-tip (1)    =    "N"
                     move  01             to   v-num
           else if   w-tes-arc-tip (1)    =    "C"
                     move  02             to   v-num
           else if   w-tes-arc-tip (1)    =    "F"
                     move  03             to   v-num
           else if   w-tes-arc-tip (1)    =    "D"
                     move  04             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-arc-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo archivio          *
      *              *-------------------------------------------------*
           if        w-tes-arc-tip (1)    =    "C"
                     go to acc-cod-arc-200
           else if   w-tes-arc-tip (1)    =    "F"
                     go to acc-cod-arc-400
           else if   w-tes-arc-tip (1)    =    "D"
                     go to acc-cod-arc-600
           else      go to acc-cod-arc-999.
       acc-cod-arc-200.
      *              *-------------------------------------------------*
      *              * Se tipo archivio : Cliente                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione codice Cliente                 *
      *                  *---------------------------------------------*
           perform   acc-cod-cli-000      thru acc-cod-cli-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-cod-arc-999.
       acc-cod-arc-400.
      *              *-------------------------------------------------*
      *              * Se tipo archivio : Fornitore                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione codice Fornitore               *
      *                  *---------------------------------------------*
           perform   acc-cod-fnt-000      thru acc-cod-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-cod-arc-999.
       acc-cod-arc-600.
      *              *-------------------------------------------------*
      *              * Se tipo archivio : Nostra dipendenza            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione codice Nostra dipendenza       *
      *                  *---------------------------------------------*
           perform   acc-cod-dpz-000      thru acc-cod-dpz-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-cod-arc-999.
       acc-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice dipendenza archivio   *
      *    *-----------------------------------------------------------*
       acc-dpz-arc-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo archivio          *
      *              *-------------------------------------------------*
           if        w-tes-arc-tip (1)    =    "C"
                     go to acc-dpz-arc-200
           else if   w-tes-arc-tip (1)    =    "F"
                     go to acc-dpz-arc-400
           else if   w-tes-arc-tip (1)    =    "D"
                     go to acc-dpz-arc-600
           else      go to acc-dpz-arc-999.
       acc-dpz-arc-200.
      *              *-------------------------------------------------*
      *              * Se tipo archivio : Cliente                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione codice dipendenza Cliente      *
      *                  *---------------------------------------------*
           perform   acc-dpz-cli-000      thru acc-dpz-cli-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-dpz-arc-999.
       acc-dpz-arc-400.
      *              *-------------------------------------------------*
      *              * Se tipo archivio : Fornitore                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione codice dipendenza Fornitore    *
      *                  *---------------------------------------------*
           perform   acc-dpz-fnt-000      thru acc-dpz-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-dpz-arc-999.
       acc-dpz-arc-600.
      *              *-------------------------------------------------*
      *              * Se tipo archivio : Nostra dipendenza            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-dpz-arc-999.
       acc-dpz-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente               *
      *    *-----------------------------------------------------------*
       acc-cod-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-cli-025.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-arc-cod (1)    to   w-sav-cod-cli          .
       acc-cod-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cli-ope      .
           move      w-tes-arc-cod (1)    to   w-cod-mne-cli-cod      .
           move      11                   to   w-cod-mne-cli-lin      .
           move      30                   to   w-cod-mne-cli-pos      .
           move      11                   to   w-cod-mne-cli-rln      .
           move      41                   to   w-cod-mne-cli-rps      .
           move      zero                 to   w-cod-mne-cli-vln      .
           move      zero                 to   w-cod-mne-cli-vps      .
           move      zero                 to   w-cod-mne-cli-lln      .
           move      zero                 to   w-cod-mne-cli-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
       acc-cod-cli-110.
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           if        w-cod-mne-cli-ope    =    "F+"
                     go to acc-cod-cli-115.
           if        w-cod-mne-cli-ope    =    "AC"
                     go to acc-cod-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cli-115.
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
           go to     acc-cod-cli-110.
       acc-cod-cli-120.
           move      w-cod-mne-cli-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
       acc-cod-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-arc-cod (1)      .
       acc-cod-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-cli-410.
      *                  *---------------------------------------------*
      *                  * Lettura file [cli]                          *
      *                  *---------------------------------------------*
           move      w-tes-arc-cod (1)    to   w-let-arc-cli-cod      .
