                                          to   rf-mmv-vnb-gea         .
           move      "S"                  to   rf-mmv-fdr-gea         .
      *                  *---------------------------------------------*
      *                  * Update record [mmv]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
      *                  *---------------------------------------------*
      *                  * Release record [mmv]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
       agg-val-dpm-800.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [dpm] *
      *                  *---------------------------------------------*
           go to     agg-val-dpm-100.
       agg-val-dpm-900.
      *              *-------------------------------------------------*
      *              * Close file [dpm]                                *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dpm/fls/ioc/obj/iofdpm"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dpm                 .
       agg-val-dpm-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento valore Lifo : Materiali vari                *
      *    *-----------------------------------------------------------*
       agg-val-mtv-000.
      *              *-------------------------------------------------*
      *              * Open file [mtv]                                 *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/mtv/fls/ioc/obj/iofmtv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mtv                 .
      *              *-------------------------------------------------*
      *              * Start su file [mtv]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMMTV    "         to   f-key                  .
           move      zero                 to   rf-mtv-num-mtv         .
           move      "pgm/mtv/fls/ioc/obj/iofmtv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mtv                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-val-mtv-900.
       agg-val-mtv-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mtv]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mtv/fls/ioc/obj/iofmtv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mtv                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-val-mtv-900.
      *              *-------------------------------------------------*
      *              * Selezione su record letto                       *
      *              *-------------------------------------------------*
       agg-val-mtv-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo giacenza di proprieta'     *
      *              * alla data, relativo al codice di magazzino      *
      *              *-------------------------------------------------*
       agg-val-mtv-210.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo                        *
      *                  *---------------------------------------------*
           move      "SL"                 to   d-sld-mag-tip-ope      .
           move      0100                 to   d-sld-mag-tip-sld      .
           move      rr-dat-fie           to   d-sld-mag-dat-sld      .
           move      "T"                  to   d-sld-mag-uot-dpz      .
           move      zero                 to   d-sld-mag-cod-dpz      .
           move      04                   to   d-sld-mag-tip-mag      .
           move      rf-mtv-num-mtv       to   d-sld-mag-num-mag      .
           move      "T"                  to   d-sld-mag-uot-var      .
           move      spaces               to   d-sld-mag-var-mag      .
           move      "pgm/mag/prg/obj/pmag300y"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-sld-mag              .
       agg-val-mtv-220.
      *                  *---------------------------------------------*
      *                  * Se errore di esecuzione nella determinazio- *
      *                  * ne del saldo si ignora il record            *
      *                  *---------------------------------------------*
           if        d-sld-mag-exi-sts    =    spaces
                     go to agg-val-mtv-230.
           go to     agg-val-mtv-800.
       agg-val-mtv-230.
      *                  *---------------------------------------------*
      *                  * Se saldo uguale a zero si ignora il record  *
      *                  *---------------------------------------------*
           if        d-sld-mag-sld-mag    =    zero
                     go to agg-val-mtv-800.
       agg-val-mtv-300.
      *              *-------------------------------------------------*
      *              * Determinazione del costo L.i.f.o. alla data,    *
      *              * relativo al codice di magazzino                 *
      *              *-------------------------------------------------*
       agg-val-mtv-310.
      *                  *---------------------------------------------*
      *                  * Determinazione costo L.i.f.o.               *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0004                 to   d-vun-mag-tip-val      .
           move      rr-dat-fie           to   d-vun-mag-dat-val      .
           move      04                   to   d-vun-mag-tip-mag      .
           move      rf-mtv-num-mtv       to   d-vun-mag-num-mag      .
           move      d-sld-mag-sld-mag    to   d-vun-mag-gia-prp      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
       agg-val-mtv-320.
      *                  *---------------------------------------------*
      *                  * Se errore di esecuzione nella determinazio- *
      *                  * ne si ignora il record                      *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    not  = "#"
                     go to agg-val-mtv-330.
           go to     agg-val-mtv-800.
       agg-val-mtv-330.
      *                  *---------------------------------------------*
      *                  * Se determinazione non eseguibile per rima-  *
      *                  * nenze finali negative si ignora il record   *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    not  = "N"
                     go to agg-val-mtv-340.
           go to     agg-val-mtv-800.
       agg-val-mtv-340.
      *                  *---------------------------------------------*
      *                  * Se determinazione eseguita ma rimanenza fi- *
      *                  * nale a zero si ignora il record             *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    not  = "Z"
                     go to agg-val-mtv-350.
           go to     agg-val-mtv-800.
       agg-val-mtv-350.
      *                  *---------------------------------------------*
      *                  * Se altro errore di esecuzione si ignora il  *
      *                  * record                                      *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    =    spaces or
                     d-vun-mag-exi-sts    =    "#"    or
                     d-vun-mag-exi-sts    =    "N"    or
                     d-vun-mag-exi-sts    =    "Z"
                     go to agg-val-mtv-360.
           go to     agg-val-mtv-800.
       agg-val-mtv-360.
      *              *-------------------------------------------------*
      *              * Test su numero scaglioni : se inferiore a due,  *
      *              * si ignora il record                             *
      *              *-------------------------------------------------*
           if        d-vun-mag-lif-nsc    >    1
                     go to agg-val-mtv-370.
           go to     agg-val-mtv-800.
       agg-val-mtv-370.
      *              *-------------------------------------------------*
      *              * Test su primo scaglione : se non relativo al-   *
      *              * l'esercizio richiesto, si ignora il record      *
      *              *-------------------------------------------------*
           move      rr-ann-ese           to   w-acc-ann-est-ann      .
           add       1900                 to   w-acc-ann-est-ann      .
           if        d-vun-mag-lif-ann (01)
                                          =    w-acc-ann-est-ann
                     go to agg-val-mtv-380.
           go to     agg-val-mtv-800.
       agg-val-mtv-380.
      *              *-------------------------------------------------*
      *              * Test su costo unitario primo scaglione : se non *
      *              * inferiore al costo dello scaglione successivo,  *
      *              * si ignora il record                             *
      *              *-------------------------------------------------*
           if        d-vun-mag-lif-vun (01)
                                          <    d-vun-mag-lif-vun (02)
                     go to agg-val-mtv-400.
           go to     agg-val-mtv-800.
       agg-val-mtv-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento record [mmv] dell'esercizio ri-   *
      *              * chiesto                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ottenimento record [mmv]                    *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "ESECOD    "         to   f-key                  .
           move      rr-ann-ese           to   rf-mmv-ann-ese         .
           move      04                   to   rf-mmv-tip-mag         .
           move      rf-mtv-num-mtv       to   rf-mmv-num-mag         .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
      *                  *---------------------------------------------*
      *                  * Se record non ottenuto, si ignora il record *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-val-mtv-800.
      *                  *---------------------------------------------*
      *                  * Aggiornamento dati Lifo per l'anno in corso *
      *                  *---------------------------------------------*
           move      d-vun-mag-lif-vun (01)
                                          to   rf-mmv-vnb-gea         .
           move      "S"                  to   rf-mmv-fdr-gea         .
      *                  *---------------------------------------------*
      *                  * Update record [mmv]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
      *                  *---------------------------------------------*
      *                  * Release record [mmv]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
       agg-val-mtv-800.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [mtv] *
      *                  *---------------------------------------------*
           go to     agg-val-mtv-100.
       agg-val-mtv-900.
      *              *-------------------------------------------------*
      *              * Close file [mtv]                                *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/mtv/fls/ioc/obj/iofmtv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mtv                 .
       agg-val-mtv-999.
           exit.

