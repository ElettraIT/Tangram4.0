      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento valore Lifo                                 *
      *    *-----------------------------------------------------------*
       agg-val-lif-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo magazzino ri-   *
      *              * chiesto                                         *
      *              *-------------------------------------------------*
           if        rr-tip-mag           =    01
                     go to agg-val-lif-100
           else if   rr-tip-mag           =    02
                     go to agg-val-lif-200
           else if   rr-tip-mag           =    03
                     go to agg-val-lif-300
           else if   rr-tip-mag           =    04
                     go to agg-val-lif-400.
       agg-val-lif-100.
      *              *-------------------------------------------------*
      *              * Tipo magazzino : Prodotti di vendita            *
      *              *-------------------------------------------------*
           perform   agg-val-dcp-000      thru agg-val-dcp-999        .
           go to     agg-val-lif-999.
       agg-val-lif-200.
      *              *-------------------------------------------------*
      *              * Tipo magazzino : Semilavorati                   *
      *              *-------------------------------------------------*
           perform   agg-val-dps-000      thru agg-val-dps-999        .
           go to     agg-val-lif-999.
       agg-val-lif-300.
      *              *-------------------------------------------------*
      *              * Tipo magazzino : Materie prime                  *
      *              *-------------------------------------------------*
           perform   agg-val-dpm-000      thru agg-val-dpm-999        .
           go to     agg-val-lif-999.
       agg-val-lif-400.
      *              *-------------------------------------------------*
      *              * Tipo magazzino : Materiali vari                 *
      *              *-------------------------------------------------*
           perform   agg-val-mtv-000      thru agg-val-mtv-999        .
           go to     agg-val-lif-999.
       agg-val-lif-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento valore Lifo : Prodotti di vendita           *
      *    *-----------------------------------------------------------*
       agg-val-dcp-000.
      *              *-------------------------------------------------*
      *              * Open file [dcp]                                 *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Start su file [dcp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRO    "         to   f-key                  .
           move      zero                 to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-val-dcp-900.
       agg-val-dcp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [dcp]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-val-dcp-900.
      *              *-------------------------------------------------*
      *              * Selezione su record letto                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo prodotto non indica una merce :  *
      *                  * si ignora il record                         *
      *                  *---------------------------------------------*
           if        rf-dcp-tip-pro       not  = 01
                     go to agg-val-dcp-100.
       agg-val-dcp-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo giacenza di proprieta'     *
      *              * alla data, relativo al codice di magazzino      *
      *              *-------------------------------------------------*
       agg-val-dcp-210.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo                        *
      *                  *---------------------------------------------*
           move      "SL"                 to   d-sld-mag-tip-ope      .
           move      0100                 to   d-sld-mag-tip-sld      .
           move      rr-dat-fie           to   d-sld-mag-dat-sld      .
           move      "T"                  to   d-sld-mag-uot-dpz      .
           move      zero                 to   d-sld-mag-cod-dpz      .
           move      01                   to   d-sld-mag-tip-mag      .
           move      rf-dcp-num-pro       to   d-sld-mag-num-mag      .
           move      "T"                  to   d-sld-mag-uot-var      .
           move      spaces               to   d-sld-mag-var-mag      .
           move      "pgm/mag/prg/obj/pmag300y"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-sld-mag              .
       agg-val-dcp-220.
      *                  *---------------------------------------------*
      *                  * Se errore di esecuzione nella determinazio- *
      *                  * ne del saldo si ignora il record            *
      *                  *---------------------------------------------*
           if        d-sld-mag-exi-sts    =    spaces
                     go to agg-val-dcp-230.
           go to     agg-val-dcp-800.
       agg-val-dcp-230.
      *                  *---------------------------------------------*
      *                  * Se saldo uguale a zero si ignora il record  *
      *                  *---------------------------------------------*
           if        d-sld-mag-sld-mag    =    zero
                     go to agg-val-dcp-800.
       agg-val-dcp-300.
      *              *-------------------------------------------------*
      *              * Determinazione del costo L.i.f.o. alla data,    *
      *              * relativo al codice di magazzino                 *
      *              *-------------------------------------------------*
       agg-val-dcp-310.
      *                  *---------------------------------------------*
      *                  * Determinazione costo L.i.f.o.               *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0004                 to   d-vun-mag-tip-val      .
           move      rr-dat-fie           to   d-vun-mag-dat-val      .
           move      01                   to   d-vun-mag-tip-mag      .
           move      rf-dcp-num-pro       to   d-vun-mag-num-mag      .
           move      d-sld-mag-sld-mag    to   d-vun-mag-gia-prp      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
       agg-val-dcp-320.
      *                  *---------------------------------------------*
      *                  * Se errore di esecuzione nella determinazio- *
      *                  * ne si ignora il record                      *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    not  = "#"
                     go to agg-val-dcp-330.
           go to     agg-val-dcp-800.
       agg-val-dcp-330.
      *                  *---------------------------------------------*
      *                  * Se determinazione non eseguibile per rima-  *
      *                  * nenze finali negative si ignora il record   *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    not  = "N"
                     go to agg-val-dcp-340.
           go to     agg-val-dcp-800.
       agg-val-dcp-340.
      *                  *---------------------------------------------*
