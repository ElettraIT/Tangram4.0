                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rou-ccl-att-205.
      *              *-------------------------------------------------*
      *              * Attesa di 5 minuti (300 secondi)                *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-ctr-att          .
       rou-ccl-att-210.
           add       1                    to   w-exe-ctr-att          .
           if        w-exe-ctr-att        >    300
                     go to rou-ccl-att-220.
      *                  *---------------------------------------------*
      *                  * Frazione di attesa da un secondo            *
      *                  *---------------------------------------------*
           call      "swd/mod/prg/obj/mwait0"                         .
       rou-ccl-att-212.
      *                  *---------------------------------------------*
      *                  * Accettazione del tasto per l'interruzione   *
      *                  * dell'attesa                                 *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           move      "AA"                 to   v-ope                  .
           move      21                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "[1] "               to   v-pfk (14)             .
           move      "[2] "               to   v-pfk (15)             .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Se attesa disattivata : ad uscita       *
      *                      *-----------------------------------------*
           if        v-key                =    spaces
                     go to rou-ccl-att-210.
       rou-ccl-att-214.
      *                      *-----------------------------------------*
      *                      * Se 'Pf1'                                *
      *                      *-----------------------------------------*
           if        v-key                not  = "[1] "
                     go to rou-ccl-att-216.
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     rou-ccl-att-300.
       rou-ccl-att-216.
      *                      *-----------------------------------------*
      *                      * Se 'Pf2'                                *
      *                      *-----------------------------------------*
           if        v-key                not  = "[2] "
                     go to rou-ccl-att-210.
      *                          *-------------------------------------*
      *                          * Flag di uscita                      *
      *                          *-------------------------------------*
           move      "#"                  to   w-exe-flg-ein          .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     rou-ccl-att-300.
       rou-ccl-att-220.
      *                  *---------------------------------------------*
      *                  * Ora di sistema                              *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Confronto con la data                       *
      *                  *---------------------------------------------*
           if        s-dat                not  > w-exe-dat-exe
                     go to rou-ccl-att-200.
      *                  *---------------------------------------------*
      *                  * Confronto con l'ora                         *
      *                  *---------------------------------------------*
           if        s-tim (1 : 4)        not  < w-exe-ora-exe
                     go to rou-ccl-att-300.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     rou-ccl-att-200.
       rou-ccl-att-300.
      *              *-------------------------------------------------*
      *              * Preparazione data inizio ciclo notturno         *
      *              *-------------------------------------------------*
           move      s-dat                to   w-gen-dat-icn          .
      *              *-------------------------------------------------*
      *              * Pulizia linea 23 e 24                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      23                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all spaces           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      24                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all spaces           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rou-ccl-att-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-ccl-att-999.
       rou-ccl-att-999.
           exit.

