                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-pgm-ric-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ofr-cod-dpz       not  = 01     or
                     rf-ofr-flg-rch       not  = spaces or
                     rf-ofr-tip-mag       not  = 01
                     go to exe-pgm-ric-300.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su tipo riga                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo riga in comodo ridefinito          *
      *                      *-----------------------------------------*
           move      rf-ofr-tip-rig       to   w-exe-pgm-ric-wtr      .
      *                      *-----------------------------------------*
      *                      * Test su tipo funzionamento              *
      *                      *-----------------------------------------*
           if        w-exe-pgm-ric-wtf    not  = spaces
                     go to exe-pgm-ric-180.
      *                  *---------------------------------------------*
      *                  * Selezione su quantita' da evadere           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' da evadere ri- *
      *                      * ga ordine fornitore                     *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-qev-rof-tip-ope      .
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-rof
                                               rf-ofr                 .
      *                      *-----------------------------------------*
      *                      * Test su quantita' ordinata              *
      *                      *-----------------------------------------*
           if        d-qev-rof-qta-ord    not  > zero
                     go to exe-pgm-ric-180.
      *                      *-----------------------------------------*
      *                      * Test su quantita' da ricevere           *
      *                      *-----------------------------------------*
           if        d-qev-rof-qta-dri    =    zero
                     go to exe-pgm-ric-180.
      *                  *---------------------------------------------*
      *                  * Selezione su data consegna prevista         *
      *                  *---------------------------------------------*
           if        rf-ofr-dcn-prv       >    w-gen-dat-att
                     go to exe-pgm-ric-180.
      *                  *---------------------------------------------*
      *                  * Continuazione per selezione superata        *
      *                  *---------------------------------------------*
           go to     exe-pgm-ric-200.
       exe-pgm-ric-180.
      *                  *---------------------------------------------*
      *                  * Se selezione non superata                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Release record [ofr]                    *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     exe-pgm-ric-100.
       exe-pgm-ric-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento data consegna prevista            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio data consegna confermata del    *
      *                  * fornitore                                   *
      *                  *                                             *
      *                  * Modifica del 24.10.22 richiesta da Fasolo:  *
      *                  * non si modifica la data richiesta           *
      *                  *                                             *
      *                  *---------------------------------------------*
______*    if        rf-ofr-flg-cnf       not  = "C"
______*              go to exe-pgm-ric-220.
______*    move      rf-ofr-dcn-prv       to   rf-ofr-dcn-ric         .
       exe-pgm-ric-220.
      *                  *---------------------------------------------*
      *                  * Incremento di 15 giorni della data consegna *
      *                  * prevista del fornitore                      *
      *                  *---------------------------------------------*
           move      w-gen-dat-att        to   w-det-dat-nrg-dtb      .
           move      15                   to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   rf-ofr-dcn-prv         .
      *                  *---------------------------------------------*
      *                  * Spostamento al giorno 6 del mese successivo *
      *                  *---------------------------------------------*
______*    move      w-gen-dat-att        to   s-dat                  .
______*    move      06                   to   s-gio                  .
______*    add       1                    to   s-mes                  .
______*    if        s-mes                >    12
______*              move  01             to   s-mes
______*              add    1             to   s-saa                  .
______*    move      s-dat                to   rf-ofr-dcn-prv         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento flag di conferma              *
      *                  *---------------------------------------------*
           if        rf-ofr-flg-cnf       =    "S"
                     move  "Z"            to   rf-ofr-flg-cnf
           else if   rf-ofr-flg-cnf       =    "Z"
                     move  "Z"            to   rf-ofr-flg-cnf
           else      move  "F"            to   rf-ofr-flg-cnf         .
      *                  *---------------------------------------------*
      *                  * Update record [ofr]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Release record [ofr]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     exe-pgm-ric-100.
       exe-pgm-ric-300.
      *              *-------------------------------------------------*
      *              * Release ultimo record [ofr]                     *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
       exe-pgm-ric-999.
           exit.

      *    *===========================================================*
      *    * Determinazione (data) + (nr. giorni) = (data)             *
      *    *-----------------------------------------------------------*
       det-dat-nrg-000.
      *              *-------------------------------------------------*
      *              * Data base in data in output                     *
      *              *-------------------------------------------------*
           move      w-det-dat-nrg-dtb    to   w-det-dat-nrg-dti      .
      *              *-------------------------------------------------*
      *              * Se numero giorni di incremento a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-det-dat-nrg-ngi    =    zero
                     go to det-dat-nrg-999.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di primo passaggio         *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-dat-nrg-fpp      .
      *              *-------------------------------------------------*
      *              * Inizializzazione progressivo giorni utilizzati  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dat-nrg-pgu      .
       det-dat-nrg-100.
      *              *-------------------------------------------------*
      *              * Ciclo di determinazione                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione data di fine mese            *
      *                  *---------------------------------------------*
           move      w-det-dat-nrg-dti    to   s-dat                  .
           move      31                   to   s-gio                  .
       det-dat-nrg-110.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to det-dat-nrg-110.
      *                  *---------------------------------------------*
      *                  * Aggiornamento data incrementata             *
      *                  *---------------------------------------------*
           move      s-dat                to   w-det-dat-nrg-dti      .
      *                  *---------------------------------------------*
      *                  * Determinazione numero giorni utilizzati     *
      *                  *---------------------------------------------*
       det-dat-nrg-120.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che sia il primo   *
      *                      * passaggio o no                          *
      *                      *-----------------------------------------*
           if        w-det-dat-nrg-fpp    =    spaces
                     go to det-dat-nrg-122
           else      go to det-dat-nrg-124.
       det-dat-nrg-122.
      *                      *-----------------------------------------*
      *                      * Primo passaggio                         *
      *                      *-----------------------------------------*
           move      "#"                  to   w-det-dat-nrg-fpp      .
           subtract  w-det-dat-nrg-dbg    from w-det-dat-nrg-dig
                                        giving w-det-dat-nrg-ngu      .
           go to     det-dat-nrg-130.
       det-dat-nrg-124.
      *                      *-----------------------------------------*
      *                      * Passaggio successivo al primo           *
      *                      *-----------------------------------------*
           move      w-det-dat-nrg-dig    to   w-det-dat-nrg-ngu      .
           go to     det-dat-nrg-130.
       det-dat-nrg-130.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivo giorni utilizzati *
      *                  *---------------------------------------------*
           add       w-det-dat-nrg-ngu    to   w-det-dat-nrg-pgu      .
      *                  *---------------------------------------------*
      *                  * Se progressivo giorni utilizzati superiore  *
      *                  * al numero giorni di incremento richiesti :  *
      *                  * a fine ciclo                                *
      *                  *---------------------------------------------*
           if        w-det-dat-nrg-pgu    not  < w-det-dat-nrg-ngi
                     go to det-dat-nrg-150.
      *                  *---------------------------------------------*
      *                  * Incremento mese/anno                        *
      *                  *---------------------------------------------*
           add       1                    to   w-det-dat-nrg-dim      .
           if        w-det-dat-nrg-dim    >    12
                     move  1              to   w-det-dat-nrg-dim
                     add   1              to   w-det-dat-nrg-dia      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-dat-nrg-100.
       det-dat-nrg-150.
      *              *-------------------------------------------------*
      *              * Fine ciclo                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero giorni in esubero ri- *
      *                  * spetto a quelli richiesti                   *
      *                  *---------------------------------------------*
           subtract  w-det-dat-nrg-ngi    from w-det-dat-nrg-pgu
                                        giving w-det-dat-nrg-ngu      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento giorno della data incrementa- *
      *                  * ta                                          *
      *                  *---------------------------------------------*
           subtract  w-det-dat-nrg-ngu    from w-det-dat-nrg-dig      .
       det-dat-nrg-999.
           exit.

