      *    *===========================================================*
      *    * Esecuzione consolidamento ordini di spedizione            *
      *    *-----------------------------------------------------------*
       cns-ord-spd-000.
      *              *-------------------------------------------------*
      *              * Apertura files e moduli                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * [ost]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * [osr]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Open modulo di determinazione quantita' da  *
      *                  * spedire riga ordine di spedizione           *
      *                  *---------------------------------------------*
           move      "OP"                 to   d-qds-ros-tip-ope      .
           move      "pgm/ods/prg/obj/dqdsros0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qds-ros
                                               rf-osr                 .
       cns-ord-spd-050.
      *              *-------------------------------------------------*
      *              * Start su file [ost]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZSCH    "         to   f-key                  .
           move      01                   to   rf-ost-cod-dpz         .
           move      spaces               to   rf-ost-flg-sch         .
           move      zero                 to   rf-ost-num-prt         .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to cns-ord-spd-900.
       cns-ord-spd-100.
      *              *-------------------------------------------------*
      *              * Ottenimento sequenziale record [ost]            *
      *              *-------------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to cns-ord-spd-900.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ost-cod-dpz       =    01     and
                     rf-ost-flg-sch       =    spaces
                     go to cns-ord-spd-120.
      *                  *---------------------------------------------*
      *                  * Release record [ost]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * A chiusura files                            *
      *                  *---------------------------------------------*
           go to     cns-ord-spd-900.
       cns-ord-spd-120.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [ost]                      *
      *              *-------------------------------------------------*
       cns-ord-spd-200.
      *                  *---------------------------------------------*
      *                  * Start su file [osr]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ost-num-prt       to   rf-osr-num-prt         .
           move      zero                 to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to cns-ord-spd-300.
       cns-ord-spd-220.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [osr]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to cns-ord-spd-300.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-osr-num-prt       not  = rf-ost-num-prt
                     go to cns-ord-spd-300.
       cns-ord-spd-240.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record [osr]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Selezione su tipo riga                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se tipo riga 'C' : riciclo          *
      *                          *-------------------------------------*
           if        rf-osr-tip-rig (1:1) =    "C"
                     go to cns-ord-spd-220.
      *                      *-----------------------------------------*
      *                      * Determinazione status della riga ordine *
      *                      * di spedizione                           *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-qds-ros-tip-ope      .
           move      "pgm/ods/prg/obj/dqdsros0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qds-ros
                                               rf-osr                 .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che si tratti o no *
      *                      * di una riga di addebito                 *
      *                      *-----------------------------------------*
           if        rf-osr-tip-rig (1:1) =    "A"
                     go to cns-ord-spd-242
           else      go to cns-ord-spd-244.
       cns-ord-spd-242.
      *                      *-----------------------------------------*
      *                      * Se riga di Addebito                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su status riga di addebito :   *
      *                          * se 'Aperta', riciclo                *
      *                          *-------------------------------------*
           if        d-qds-ros-rda-aoc    =    "A"
                     go to cns-ord-spd-220.
           go to     cns-ord-spd-260.
       cns-ord-spd-244.
      *                      *-----------------------------------------*
      *                      * Se riga non di Addebito                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Confronto tra quantita' in ordine e *
      *                          * quantita' ancora da spedire : se u- *
      *                          * guali, riciclo                      *
      *                          *-------------------------------------*
           if        d-qds-ros-qta-ord    =    d-qds-ros-qta-dsp
                     go to cns-ord-spd-220.
           go to     cns-ord-spd-260.
       cns-ord-spd-260.
      *                  *---------------------------------------------*
      *                  * Fine selezioni sul record [osr]             *
      *                  *---------------------------------------------*
