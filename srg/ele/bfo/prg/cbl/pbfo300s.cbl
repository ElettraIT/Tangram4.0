      *    *===========================================================*
      *    * Determinazione descrizione per la riga                    *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del flag di estensione   *
      *              *-------------------------------------------------*
           if        rf-bfr-des-ext       =    0
                     go to det-des-rig-100
           else if   rf-bfr-des-ext       =    1
                     go to det-des-rig-300
           else if   rf-bfr-des-ext       =    2
                     go to det-des-rig-600.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione contenuta in record [bfr]       *
      *                  *---------------------------------------------*
           move      rf-bfr-des-rig       to   w-stp-rig-des-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione in file [bfx]                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [bfx]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfx                 .
      *                  *---------------------------------------------*
      *                  * Lettura file [bfx]                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bfr-num-prt       to   rf-bfx-num-prt         .
           move      rf-bfr-num-prg       to   rf-bfx-num-prg         .
           move      11                   to   rf-bfx-tip-rec         .
           move      "pgm/bfo/fls/ioc/obj/iofbfx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfx                 .
           if        f-sts                =    e-not-err
                     move  rf-bfx-des-400 to   w-stp-rig-des-der
           else      move  spaces         to   w-stp-rig-des-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-600.
      *              *-------------------------------------------------*
      *              * Se estensione in file [pdx]                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori di comodo            *
      *                  *---------------------------------------------*
           move      spaces               to   w-stp-rig-des-der      .
           move      zero                 to   w-stp-rig-des-ctr      .
      *                  *---------------------------------------------*
      *                  * Tentativo di lettura di una descrizione     *
      *                  * legata al cliente                           *
      *                  *---------------------------------------------*
       det-des-rig-620.
      *                      *-----------------------------------------*
      *                      * Start su file [pdx]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TRCLNG"             to   f-key                  .
           move      03                   to   rf-pdx-tip-rec         .
           move      rf-bft-cod-arc       to   rf-pdx-cod-arc         .
           move      spaces               to   rf-pdx-cod-lng         .
           move      rf-bfr-num-mag       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                          *-------------------------------------*
      *                          * Se start errata : a fine tentativo  *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-680.
       det-des-rig-640.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale file [pdx]          *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                          *-------------------------------------*
      *                          * Se 'at end' : a fine tentativo      *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-680.
       det-des-rig-660.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-pdx-tip-rec       not  = 03             or
                     rf-pdx-cod-arc       not  = rf-bft-cod-arc or
                     rf-pdx-cod-lng       not  = spaces         or
                     rf-pdx-cod-num       not  = rf-bfr-num-mag or
                     rf-pdx-for-mat       not  = spaces
                     go to det-des-rig-680.
      *                          *-------------------------------------*
      *                          * Incremento contatore righe lette    *
      *                          *-------------------------------------*
           add       1                    to   w-stp-rig-des-ctr      .
           if        w-stp-rig-des-ctr    >    10
                     move  10             to   w-stp-rig-des-ctr      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione riga di descrizione *
      *                          *-------------------------------------*
           move      rf-pdx-des-pro       to   w-stp-rig-des-rgd
                                              (w-stp-rig-des-ctr)     .
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura [pdx]                *
      *                      *-----------------------------------------*
           go to     det-des-rig-640.
       det-des-rig-680.
      *                      *-----------------------------------------*
      *                      * Test su numero record letti : se zero a *
      *                      * lettura descrizione con codice lingua   *
      *                      *-----------------------------------------*
           if        w-stp-rig-des-ctr    =    zero
                     go to det-des-rig-700.
      *                      *-----------------------------------------*
      *                      * Altrimenti : uscita                     *
      *                      *-----------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-700.
      *                  *---------------------------------------------*
      *                  * Se codice lingua 'I  '                      *
      *                  *---------------------------------------------*
           if        rf-bfr-cod-lng       not  = "I  "
                     go to det-des-rig-800.
       det-des-rig-720.
      *                      *-----------------------------------------*
      *                      * Start su file [pdx]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TRCLNG"             to   f-key                  .
           move      01                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      "I  "                to   rf-pdx-cod-lng         .
           move      rf-bfr-num-mag       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione se non     *
      *                          * trovato : uscita                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-900.
       det-des-rig-740.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale file [pdx]          *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                          *-------------------------------------*
      *                          * Test se 'at end' : uscita           *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-900.
       det-des-rig-760.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-pdx-tip-rec       not  = 01             or
                     rf-pdx-cod-arc       not  = zero           or
                     rf-pdx-cod-lng       not  = "I  "          or
                     rf-pdx-cod-num       not  = rf-bfr-num-mag or
                     rf-pdx-for-mat       not  = spaces
                     go to det-des-rig-900.
      *                          *-------------------------------------*
      *                          * Incremento contatore righe lette    *
      *                          *-------------------------------------*
           add       1                    to   w-stp-rig-des-ctr      .
           if        w-stp-rig-des-ctr    >    10
                     move  10             to   w-stp-rig-des-ctr      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione riga di descrizione *
      *                          *-------------------------------------*
           move      rf-pdx-des-pro       to   w-stp-rig-des-rgd
                                              (w-stp-rig-des-ctr)     .
       det-des-rig-780.
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura [pdx]                *
      *                      *-----------------------------------------*
           go to     det-des-rig-740.
       det-des-rig-800.
      *                  *---------------------------------------------*
      *                  * Se codice lingua diverso da 'I  ' : tenta-  *
      *                  * tivo di lettura file [pdx] per descrizione  *
      *                  * in lingua estera                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Azzeramento numero records letti        *
      *                      *-----------------------------------------*
           move      zero                 to   w-stp-rig-des-ctr      .
       det-des-rig-820.
      *                      *-----------------------------------------*
      *                      * Start su file [pdx]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TRCLNG"             to   f-key                  .
           move      02                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      rf-bfr-cod-lng       to   rf-pdx-cod-lng         .
           move      rf-bfr-num-mag       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                          *-------------------------------------*
      *                          * Se start errata : a test su conta-  *
      *                          * tore                                *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-890.
       det-des-rig-840.
      *                      *-----------------------------------------*
      *                      * Read Next file [pdx]                    *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                          *-------------------------------------*
      *                          * Test se 'At end' : a test su conta- *
      *                          * tore                                *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-890.
       det-des-rig-860.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-pdx-tip-rec       not  = 02             or
                     rf-pdx-cod-arc       not  = zero           or
                     rf-pdx-cod-lng       not  = rf-bfr-cod-lng or
                     rf-pdx-cod-num       not  = rf-bfr-num-mag or
                     rf-pdx-for-mat       not  = spaces
                     go to det-des-rig-890.
      *                          *-------------------------------------*
      *                          * Incremento contatore righe lette    *
      *                          *-------------------------------------*
           if        w-stp-rig-des-ctr    <    10
                     add   1              to   w-stp-rig-des-ctr
           else      go to det-des-rig-890.
      *                          *-------------------------------------*
      *                          * Bufferizzazione descrizione         *
      *                          *-------------------------------------*
           move      rf-pdx-des-pro       to   w-stp-rig-des-rgd
                                              (rf-pdx-num-prg)        .
       det-des-rig-880.
      *                      *-----------------------------------------*
      *                      * Riciclo su Read Next [pdx]              *
      *                      *-----------------------------------------*
           go to     det-des-rig-840.
       det-des-rig-890.
      *                          *-------------------------------------*
      *                          * Test su numero record letti: se ze- *
      *                          * ro a lettura descrizione con codice *
      *                          * lingua 'I  '                        *
      *                          *-------------------------------------*
           if        w-stp-rig-des-ctr    =    zero
                     go to det-des-rig-720.
       det-des-rig-900.
