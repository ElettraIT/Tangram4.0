      *              * netto pari al valore in input : uscita          *
      *              *-------------------------------------------------*
           if        w-det-prz-net-psc (1)
                                          =    zero and
                     w-det-prz-net-psc (2)
                                          =    zero and
                     w-det-prz-net-psc (3)
                                          =    zero and
                     w-det-prz-net-psc (4)
                                          =    zero and
                     w-det-prz-net-psc (5)
                                          =    zero
