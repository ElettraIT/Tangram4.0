      *    *===========================================================*
      *    * Update testata ordine per ricalcolo dei totali documento  *
      *    *-----------------------------------------------------------*
       upd-rec-oct-000.
      *              *-------------------------------------------------*
      *              * Update testata in corso di trattamento          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [oct]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Ottenimento record [oct]                    *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-gen-prt-orc        to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totali                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Totali per tipo prodotto                *
      *                      *-----------------------------------------*
           move      w-gen-tot-rig (1)    to   rf-oct-tot-rig (1)     .
           move      w-gen-tot-rig (2)    to   rf-oct-tot-rig (2)     .
           move      w-gen-tot-rig (3)    to   rf-oct-tot-rig (3)     .
           move      w-gen-tot-rig (9)    to   rf-oct-tot-rig (9)     .
      *                      *-----------------------------------------*
      *                      * Totale documento lordo                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-gen-tot-lor          .
           add       w-gen-tot-rig (1)    to   w-gen-tot-lor          .
           add       w-gen-tot-rig (2)    to   w-gen-tot-lor          .
           add       w-gen-tot-rig (3)    to   w-gen-tot-lor          .
           add       w-gen-tot-rig (9)    to   w-gen-tot-lor          .
      *                      *-----------------------------------------*
      *                      * Sconto pagamento                        *
      *                      *-----------------------------------------*
           move      zero                 to   w-gen-tot-scp          .
           if        rf-oct-per-scp       not  = 0
                     multiply  rf-oct-per-scp
                                          by   w-gen-tot-lor
                                        giving w-gen-tot-scp          .
           divide    100                  into w-gen-tot-scp
                                       rounded                        .
      *                      *-----------------------------------------*
      *                      * Totale documento                        *
      *                      *-----------------------------------------*
           move      w-gen-tot-lor        to   rf-oct-tot-doc         .
           subtract  w-gen-tot-scp        from rf-oct-tot-doc         .
      *                  *---------------------------------------------*
      *                  * Update record [oct]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Rilascio record [oct]                       *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
       upd-rec-oct-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo ordini clienti  *
      *    *-----------------------------------------------------------*
       att-orc-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [orcprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-orc-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-orc-prt-saa      .
           move      w-att-orc-prt-saa    to   rn-orc-prt-scl-ann     .
           move      w-att-orc-prt-dpz    to   rn-orc-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [orcprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-orc-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-orc-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-orc-prt-000.
       att-orc-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-orc-prt-num-prt   to   w-att-orc-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-orc-prt-wpr      .
           if        w-att-orc-prt-wpr    =    zero
                     move  1              to   w-att-orc-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-orc-prt-saa    to   w-att-orc-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-orc-prt-dpz    to   w-att-orc-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-orc-prt-wnu    to   rn-orc-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-orc-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-orc-prt-num-prt   to   w-att-orc-prt-num      .
       att-orc-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero documento ordini clienti   *
