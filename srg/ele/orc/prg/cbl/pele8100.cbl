           else if   rf-ocr-tip-pro       =    02
                     add  rf-ocr-imp-rig  to   w-gen-tot-rig (02)
           else if   rf-ocr-tip-pro       =    03
                     add  rf-ocr-imp-rig  to   w-gen-tot-rig (03)
           else if   rf-ocr-tip-pro       =    09
                     add  rf-ocr-imp-rig  to   w-gen-tot-rig (09)  .
