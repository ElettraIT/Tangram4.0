      *    * Routine lettura archivio [dcp] e [pdx]                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcp/prg/cpy/ldcppdx0.lts"                   .

      *    *===========================================================*
      *    * Calcolo prezzo netto                                      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcalprz0.cps"                   .

      *    *===========================================================*
      *    * Routine di scrittura record di log                        *
      *    *-----------------------------------------------------------*
       wrt-rec-log-000.
      *              *-------------------------------------------------*
      *              * Open extend file log                            *
      *              *-------------------------------------------------*
           move      "OE"                 to   g-ope                  .
           move      "log "               to   g-nam                  .
           move      "/abd/asc/imp/roc_log.txt"
                                          to   g-pat                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *              *-------------------------------------------------*
      *              * Composizione record log                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-rec-log              .
      *                  *---------------------------------------------*
      *                  * Data e ora evento                           *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Data                                        *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      s-dat                to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-rec-log-dat          .
      *                  *---------------------------------------------*
      *                  * Ora                                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-rec-log-ora          .
           string    s-ora      delimited by   size
                     ":"        delimited by   size
                     s-min      delimited by   size
                     ":"        delimited by   size
                     s-scd      delimited by   size
                                          into w-rec-log-ora          .
      *                  *---------------------------------------------*
      *                  * Descrizione evento                          *
      *                  *---------------------------------------------*
           move      w-gen-des-log        to   w-rec-log-des          .
      *                  *---------------------------------------------*
      *                  * Scrittura record                            *
      *                  *---------------------------------------------*
           move      "PN"                 to   g-ope                  .
           move      w-rec-log            to   g-rec                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Close file log                              *
      *                  *---------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       wrt-rec-log-999.
           exit.
           

