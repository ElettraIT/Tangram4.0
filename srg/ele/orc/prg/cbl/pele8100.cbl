           move      zero                 to   rn-orc-ndo-num-doc     .
           move      zero                 to   rn-orc-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
           go to     att-orc-ndo-000.
       att-orc-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
