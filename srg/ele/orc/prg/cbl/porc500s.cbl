           move      41                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cod-pro-999.
       acc-cod-pro-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-cod-pro             .
           move      v-alf                to   rr-alf-pro             .
       acc-cod-pro-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-pro-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rr-cod-pro           to   w-let-arc-dcp-num      .
           move      rr-alf-pro           to   w-let-arc-dcp-alf      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione prodotto         *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-des    to   rr-cod-pro-des         .
       acc-cod-pro-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione prodotto        *
      *                  *---------------------------------------------*
           perform   vis-cod-pro-des-000  thru vis-cod-pro-des-999    .
       acc-cod-pro-430.
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-cod-pro-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        rr-cod-pro           =    zero
                     go to acc-cod-pro-100.
       acc-cod-pro-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-pro-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cod-pro-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cod-pro-100.
       acc-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice Prodotto                   *
      *    *-----------------------------------------------------------*
       vis-cod-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      rr-alf-pro           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione Prodotto finito       *
      *    *-----------------------------------------------------------*
       vis-cod-pro-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      rr-cod-pro-des       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Data elaborazione                          *
      *    *-----------------------------------------------------------*
       acc-dat-ela-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dat-ela-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      07                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      rr-dat-ela           to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dat-ela-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-dat-ela-999.
       acc-dat-ela-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   rr-dat-ela             .
       acc-dat-ela-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore zero non ammesso, ameno che non si   *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        rr-dat-ela           not  = zero
                     go to acc-dat-ela-600.
           if        v-key                =    "UP  "
                     go to acc-dat-ela-600
           else      go to acc-dat-ela-100.
       acc-dat-ela-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-ela-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-ela-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-ela-100.
       acc-dat-ela-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Data elaborazione                       *
      *    *-----------------------------------------------------------*
       vis-dat-ela-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      rr-dat-ela           to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-ela-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
      *              *-------------------------------------------------*
      *              * Controllo su codice prodotto                    *
      *              *-------------------------------------------------*
           if        rr-cod-pro           not  = zero
                     go to tdo-ric-sel-100.
           move      "Manca il codice prodotto !"
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su data elaborazione                  *
      *              *-------------------------------------------------*
           if        rr-dat-ela           not  = zero
                     go to tdo-ric-sel-200.
           move      "Manca la data di elaborazione !"
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Uscita per controlli tutti superati             *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      zero                 to   rr-cod-pro             .
           move      spaces               to   rr-alf-pro             .
           move      spaces               to   rr-cod-pro-des         .
           move      zero                 to   rr-dat-ela             .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione : Open files                               *
      *    *-----------------------------------------------------------*
       qry-opn-fls-000.
       qry-opn-fls-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione : Close files                              *
      *    *-----------------------------------------------------------*
       qry-cls-fls-000.
       qry-cls-fls-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : No                    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-exe-rou-srt      .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
       int-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' di fabbisogno/disponibilita' da  *
      *    * visualizzare nell'interrogazione                          *
      *    *-----------------------------------------------------------*
       det-qfd-dav-000.
      *              *-------------------------------------------------*
      *              * Determinazione date per tabella disponibilita'  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione data primo elemento         *
      *                  *---------------------------------------------*
           move      w-det-qfd-dav-dtb    to   w-det-qfd-dav-dfd (1)  .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione elementi successivi      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione data base per calcolo  *
      *                      *-----------------------------------------*
           move      w-det-qfd-dav-dtb    to   w-det-qfd-dav-wdb      .
      *                      *-----------------------------------------*
      *                      * Ciclo di scansione                      *
      *                      *-----------------------------------------*
           move      1                    to   w-det-qfd-dav-c01      .
       det-qfd-dav-020.
           add       1                    to   w-det-qfd-dav-c01      .
           if        w-det-qfd-dav-c01    >    15
                     go to det-qfd-dav-100.
      *                      *-----------------------------------------*
      *                      * Determinazione data incrementata        *
      *                      *-----------------------------------------*
           move      w-det-qfd-dav-wdb    to   w-det-dat-nrg-dtb      .
           move      w-det-qfd-dav-ngi    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione in tabella data incre-  *
      *                      * mentata                                 *
      *                      *-----------------------------------------*
           move      w-det-dat-nrg-dti    to   w-det-qfd-dav-dfd
                                              (w-det-qfd-dav-c01)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento data base per prossimo    *
      *                      * calcolo                                 *
      *                      *-----------------------------------------*
           move      w-det-dat-nrg-dti    to   w-det-qfd-dav-wdb      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     det-qfd-dav-020.
       det-qfd-dav-100.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' per tabella disponibi- *
      *              * lita'                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per scansione    *
      *                  * buffer dei fabbisogni/disponibilita'        *
      *                  *---------------------------------------------*
           move      1                    to   d-buf-fod-ctr-001      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione tabella disponibilita'   *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-qfd-dav-c01      .
       det-qfd-dav-120.
           add       1                    to   w-det-qfd-dav-c01      .
           if        w-det-qfd-dav-c01    >    15
                     go to det-qfd-dav-200.
      *                  *---------------------------------------------*
      *                  * Determinazione fabbisogno/disponibilita'    *
      *                  * alla data in esame                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se data in esame superiore alla data    *
      *                      * consegna prevista dell'ultimo elemento, *
      *                      * bufferizzazione quantita' dell'ultimo   *
      *                      * elemento                                *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dfd
                    (w-det-qfd-dav-c01)   >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-qfd
                                              (w-det-qfd-dav-c01)
                     go to det-qfd-dav-160.
      *                      *-----------------------------------------*
      *                      * Continuazione scansione buffer delle    *
      *                      * quantita' di fabbisogno/disponibilita'  *
      *                      *-----------------------------------------*
       det-qfd-dav-140.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001    >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-qfd
                                              (w-det-qfd-dav-c01)
                     go to det-qfd-dav-160.
      *                      *-----------------------------------------*
      *                      * Finche' la data in esame e' superiore   *
      *                      * alla data consegna prevista dell'ele-   *
      *                      * mento : riciclo                         *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dfd
                    (w-det-qfd-dav-c01)   >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-140.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dfd
                    (w-det-qfd-dav-c01)   <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-qfd
                                              (w-det-qfd-dav-c01)     .
       det-qfd-dav-160.
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione tabella delle disponi- *
      *                  * bilita'                                     *
      *                  *---------------------------------------------*
           go to     det-qfd-dav-120.
       det-qfd-dav-200.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qfd-dav-999.
       det-qfd-dav-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' di magazzino per mese            *
      *    *-----------------------------------------------------------*
       det-scm-mes-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-scm-mes-taa      .
           move      zero                 to   w-det-scm-mes-tva      .
           move      zero                 to   w-det-scm-mes-tca      .
      *              *-------------------------------------------------*
      *              * Determinazione secolo anno attuale              *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-det-scm-mes-sat      .
       det-scm-mes-100.
      *              *-------------------------------------------------*
      *              * Determinazione mese ed anno di partenza         *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *
           subtract  1                    from s-saa                  .
           move      1                    to   s-gio                  .
      *
           if        s-mes                >    2
                     subtract  2          from s-mes
           else      add       10         to   s-mes
                     subtract  1          from s-saa                  .
      *
           move      s-mes                to   w-det-scm-mes-sca      .
           move      s-saa                to   w-det-scm-saa-sca      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-scm-mes-c01      .
       det-scm-mes-120.
           add       1                    to   w-det-scm-mes-c01      .
           if        w-det-scm-mes-c01    >    w-det-scm-mes-max
                     go to det-scm-mes-400.
      *                  *---------------------------------------------*
      *                  * Anno                                        *
      *                  *---------------------------------------------*
           move      w-det-scm-saa-sca    to   w-det-scm-mes-tan
                                              (w-det-scm-mes-c01)     .
      *                  *---------------------------------------------*
      *                  * Mese                                        *
      *                  *---------------------------------------------*
           move      w-det-scm-mes-sca    to   w-det-scm-mes-tme
                                              (w-det-scm-mes-c01)     .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [hsp]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "ele/agb/fls/ioc/obj/iofhsp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hsp                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [hsp]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DPZPRO    "         to   f-key                  .
           move      w-det-scm-saa-sca    to   rf-hsp-ann-ese         .
           move      01                   to   rf-hsp-cod-dpz         .
           move      w-det-scm-mes-cnm    to   rf-hsp-num-pro         .
           move      spaces               to   rf-hsp-var-mag         .
           move      "ele/agb/fls/ioc/obj/iofhsp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hsp                 .
      *                  *---------------------------------------------*
      *                  * Quantita' vendita                           *
      *                  *---------------------------------------------*
           move      rf-hsp-qta-ven
                    (w-det-scm-mes-sca)   to   w-det-scm-mes-tqu
                                              (w-det-scm-mes-c01)     .
      *                  *---------------------------------------------*
      *                  * Quantita' acquisto                          *
      *                  *---------------------------------------------*
           add       rf-hsp-qta-acq
                    (w-det-scm-mes-sca)   to   w-det-scm-mes-tqu
                                              (w-det-scm-mes-c01)     .
      *                  *---------------------------------------------*
      *                  * Eventuale aggiornamento totali anno attuale *
      *                  *---------------------------------------------*
           if        rf-hsp-ann-ese       not  = w-det-scm-mes-sat
                     go to det-scm-mes-180.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale vendita                *
      *                  *---------------------------------------------*
           add       rf-hsp-qta-ven
                    (w-det-scm-mes-sca)   to   w-det-scm-mes-tva      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale acquisto               *
      *                  *---------------------------------------------*
           add       rf-hsp-qta-acq
                    (w-det-scm-mes-sca)   to   w-det-scm-mes-taa      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale carichi anno in corso  *
      *                  *---------------------------------------------*
           move      rf-hsp-prg-car       to   w-det-scm-mes-tca      .
       det-scm-mes-180.
      *                  *---------------------------------------------*
      *                  * Incremento mese e anno                      *
      *                  *---------------------------------------------*
           add       1                    to   w-det-scm-mes-sca      .
      *
           if        w-det-scm-mes-sca    >    12
                     move  01             to   w-det-scm-mes-sca
                     add   01             to   w-det-scm-saa-sca      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     det-scm-mes-120.
       det-scm-mes-400.
      *              *-------------------------------------------------*
      *              * Scansione bolle da fatturare con data odierna   *
      *              *-------------------------------------------------*
           perform   det-scm-mes-bit-000  thru det-scm-mes-bit-999    .
       det-scm-mes-600.
      *              *-------------------------------------------------*
      *              * Scansione fatture con data odierna              *
      *              *-------------------------------------------------*
           perform   det-scm-mes-fit-000  thru det-scm-mes-fit-999    .
       det-scm-mes-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-scm-mes-999.
       det-scm-mes-999.
           exit.

      *    *===========================================================*
      *    * Determinazione scarichi di magazzino per mese             *
      *    *                                                           *
      *    * Ciclo per [bit]                                           *
      *    *-----------------------------------------------------------*
       det-scm-mes-bit-000.
      *              *-------------------------------------------------*
      *              * Start su file [bit]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FATARC     "        to   f-key                  .
           move      "S"                  to   rf-bit-fat-snx         .
           move      zero                 to   rf-bit-fat-dat         .
