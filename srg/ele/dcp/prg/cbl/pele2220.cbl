           move      03                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      ";"                  to   w-all-str-cat (2)      .
           move      w-rdp-des-pro        to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           move      "WR"                 to   m-ope                  .
           move      w-all-str-alf        to   m-msg                  .
           move      "* OK *"             to   m-msg (75 : 06)        .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     prn-liv-det-900.
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri intestazione standard    *
      *              *-------------------------------------------------*
           move      "SIMULAZIONE GENERAZIONE LISTINO PER FLOPPY-DISK"
                                          to   w-cnt-tit-des-tit      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
      *              *-------------------------------------------------*
      *              * Intestazione standard                           *
      *              *-------------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                  *---------------------------------------------*
      *                  * Se uscita per interruzione forzata          *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione codice automatico progressivo     *
      *    *-----------------------------------------------------------*
       att-cod-aut-000.
      *              *-------------------------------------------------*
      *              * Lettura codice automatico per [dcp]             *
      *              *-------------------------------------------------*
           move      "Eg"                 to   s-ope                  .
           move      "dcp "               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to att-cod-aut-400.
       att-cod-aut-200.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "Ep"                 to   s-ope                  .
           move      "dcp "               to   s-nam                  .
           move      zero                 to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-cod-aut-000.
       att-cod-aut-400.
      *              *-------------------------------------------------*
      *              * Record esistente                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione del valore pre incremento    *
      *                  *---------------------------------------------*
           move      s-num                to   w-enc-dcp-val-pre      .
      *                  *---------------------------------------------*
      *                  * Incremento del valore                       *
      *                  *---------------------------------------------*
           move      w-enc-dcp-val-pre    to   w-enc-dcp-val-pos      .
           add       1                    to   w-enc-dcp-val-pos      .
       att-cod-aut-500.
      *                  *---------------------------------------------*
      *                  * Se l'incremento porta a zero si forza il    *
      *                  * valore a 1                                  *
      *                  *---------------------------------------------*
           if        w-enc-dcp-val-pos    =    zero
                     move  1              to   w-enc-dcp-val-pos      .
      *                  *---------------------------------------------*
      *                  * Controllo se esiste gia' un record con il   *
      *                  * codice pari al valore incrementato          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO    "         to   f-key                  .
           move      w-enc-dcp-val-pos    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                =    e-not-err
                     go to att-cod-aut-600
           else      go to att-cod-aut-700.
       att-cod-aut-600.
      *                  *---------------------------------------------*
      *                  * Se esiste gia' un record con il codice pari *
      *                  * al valore incrementato                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ulteriore incremento del valore         *
      *                      *-----------------------------------------*
           add       1                    to   w-enc-dcp-val-pos      .
      *                      *-----------------------------------------*
      *                      * Riciclo a controllo di esistenza        *
      *                      *-----------------------------------------*
           go to     att-cod-aut-500.
       att-cod-aut-700.
      *                  *---------------------------------------------*
      *                  * Se non esiste gia' un record con il codice  *
      *                  * pari al valore incrementato                 *
      *                  *---------------------------------------------*
           move      "Eu"                 to   s-ope                  .
           move      "dcp "               to   s-nam                  .
           move      w-enc-dcp-val-pos    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione di *
      *                      * attribuzione                            *
      *                      *-----------------------------------------*
           if        s-sts                not  = spaces
                     go to att-cod-aut-000.
       att-cod-aut-999.
           exit.

      *    *===========================================================*
      *    * Composizione del record [dcp]                             *
      *    *-----------------------------------------------------------*
       cmp-rec-dcp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione codice di comodo                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cod-cmp-num      .
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Lettura record campione                         *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rr-num-pro           to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     go to cmp-rec-dcp-900.
       cmp-rec-dcp-100.
      *              *-------------------------------------------------*
      *              * Attribuzione automatica del codice              *
      *              *-------------------------------------------------*
           perform   att-cod-aut-000      thru att-cod-aut-999        .
      *              *-------------------------------------------------*
      *              * Codice automatico in campo di destinazione      *
      *              *-------------------------------------------------*
           move      w-enc-dcp-val-pos    to   rf-dcp-num-pro         .
      *              *-------------------------------------------------*
      *              * Codice automatico in campo di comodo            *
      *              *-------------------------------------------------*
           move      w-enc-dcp-val-pos    to   w-det-cod-cmp-num      .
       cmp-rec-dcp-200.
      *              *-------------------------------------------------*
      *              * Campi non chiave                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Identificativi standard                     *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-dcp-ide-dat         .
           move      s-ute                to   rf-dcp-ide-ute         .
           move      s-fas                to   rf-dcp-ide-fas         .
       cmp-rec-dcp-210.
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Eventuale assemblaggio con prefisso     *
      *                      *-----------------------------------------*
           if        rr-pre-cod           =     spaces
                     go to cmp-rec-dcp-220.
      *                      *-----------------------------------------*
      *                      * Test se possibile assemblaggio          *
      *                      *-----------------------------------------*
           move      spaces               to   w-det-ass-cod-alf      .
           string    rr-pre-cod delimited by   spaces
                     w-rdp-cod-pro
                                delimited by   spaces
                                          into w-det-ass-cod-alf      .
           if        w-det-ass-cod-alf
                    (15 : 02)             =    spaces
                     go to cmp-rec-dcp-215.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     cmp-rec-dcp-220.
       cmp-rec-dcp-215.
      *                      *-----------------------------------------*
      *                      * Assemblaggio                            *
      *                      *-----------------------------------------*
           move      16                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      rr-pre-cod           to   w-all-str-cat (1)      .
           move      w-rdp-cod-pro        to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           go to     cmp-rec-dcp-222.
       cmp-rec-dcp-220.
      *                      *-----------------------------------------*
      *                      * Allineamento a sinistra del codice      *
      *                      *-----------------------------------------*
           move      16                   to   w-all-str-lun          .
           move      w-rdp-cod-pro        to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
       cmp-rec-dcp-222.
      *                      *-----------------------------------------*
      *                      * Memorizzazione                          *
      *                      *-----------------------------------------*
           move      w-all-str-alf        to   rf-dcp-alf-pro         .
      *                      *-----------------------------------------*
      *                      * Uppercase                               *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   w-upp-des              .
           perform   trf-des-upp-000      thru trf-des-upp-999        .
           move      w-upp-des            to   rf-dcp-alf-pro         .
      *                      *-----------------------------------------*
      *                      * Se ci sono blank-embedded : compatta-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   w-bla-emb-str          .
           perform   tst-bla-emb-000      thru tst-bla-emb-999        .
           if        w-bla-emb-flg        =    spaces
                     go to cmp-rec-dcp-240.
      *                      *-----------------------------------------*
      *                      * Compattamento                           *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   w-bla-emb-str          .
           move      spaces               to   w-upp-des              .
           move      zero                 to   w-bla-emb-ctr          .
           move      zero                 to   w-ctr                  .
       cmp-rec-dcp-230.
           add       1                    to   w-bla-emb-ctr          .
           if        w-bla-emb-ctr        >    14
                     go to cmp-rec-dcp-232.
           if        w-bla-emb-chr
                    (w-bla-emb-ctr)       =    spaces
                     go to cmp-rec-dcp-230.
           add       1                    to   w-ctr                  .
           move      w-bla-emb-chr
                    (w-bla-emb-ctr)       to   w-upp-chr
                                              (w-ctr)                 .
           go to     cmp-rec-dcp-230.
       cmp-rec-dcp-232.
           move      w-upp-des            to   rf-dcp-alf-pro         .
       cmp-rec-dcp-240.
      *                  *---------------------------------------------*
      *                  * Sinonimo                                    *
      *                  *---------------------------------------------*
           move      spaces               to   rf-dcp-syn-pro         .
      *                  *---------------------------------------------*
      *                  * Chiave alfanumerica libera per il prodotto  *
      *                  *---------------------------------------------*
           move      spaces               to   rf-dcp-klb-pro         .
      *                  *---------------------------------------------*
      *                  * Descrizione in chiave                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Allineamento a sinistra del testo       *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      w-rdp-des-pro        to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione                          *
      *                      *-----------------------------------------*
           move      w-all-str-alf        to   w-upp-des              .
           perform   trf-des-upp-000      thru trf-des-upp-999        .
           move      w-upp-des            to   rf-dcp-des-key         .
      *                  *---------------------------------------------*
      *                  * Descrizione interna                         *
      *                  *---------------------------------------------*
           move      w-all-str-alf        to   rf-dcp-des-pro         .
           move      zero                 to   rf-dcp-des-pdx         .
       cmp-rec-dcp-300.
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           if        w-rdp-umi-ven        =    "PCE"
                     move  "NR"           to   rf-dcp-umi-ven
           else if   w-rdp-umi-ven        =    "LM "
                     move  "MT"           to   rf-dcp-umi-ven         .
      *                  *---------------------------------------------*
      *                  * Prezzo di listino                           *
      *                  *---------------------------------------------*
           multiply  100                  by   w-rdp-prz-pub
                                        giving rf-dcp-prz-lst         .
       cmp-rec-dcp-700.
      *                  *---------------------------------------------*
      *                  * Tutti gli altri dati vengono ereditati dal  *
      *                  * prodotto campione                           *
      *                  *---------------------------------------------*
       cmp-rec-dcp-800.
      *              *-------------------------------------------------*
      *              * Scrittura record [dcp]                          *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       cmp-rec-dcp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cmp-rec-dcp-999.
       cmp-rec-dcp-999.
           exit.

