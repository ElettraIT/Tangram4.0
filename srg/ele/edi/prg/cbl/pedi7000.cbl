      *    *===========================================================*
      *    * Creazione archivio conferme ordine clienti per EDI        *
      *    *-----------------------------------------------------------*
       crz-arc-pre-000.
      *              *-------------------------------------------------*
      *              * Sort                                            *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   crz-arc-srt-000
                                          thru crz-arc-srt-999
                     output procedure     is   crz-arc-orc-000
                                          thru crz-arc-orc-999        .
       crz-arc-pre-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio conferme ordine clienti per EDI        *
      *    *                                                           *
      *    * Procedura di input                                        *
      *    *-----------------------------------------------------------*
       crz-arc-srt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatori                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-rec-num-orc          .
      *              *-------------------------------------------------*
      *              * Normalizzazione rottura su numero documento     *
      *              *-------------------------------------------------*
           move      zero                 to   w-rot-l01-num-doc      .
       crz-arc-srt-100.
      *              *-------------------------------------------------*
      *              * Start su file [oct]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      01                   to   rf-oct-cod-dpz         .
           move      "C"                  to   rf-oct-tip-arc         .
           move      rr-cod-cli           to   rf-oct-cod-arc         .
           move      rr-dem-min           to   rf-oct-dat-doc         .
           move      zero                 to   rf-oct-num-doc         .
           move      zero                 to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a uscita                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-srt-900.
       crz-arc-srt-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [oct]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : A uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-srt-900.
       crz-arc-srt-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su dipendenza                          *
      *                  *---------------------------------------------*
           if        rf-oct-cod-dpz       not  = 01
                     go to crz-arc-srt-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        rf-oct-tip-arc       not  = "C"
                     go to crz-arc-srt-900.
      *                  *---------------------------------------------*
      *                  * Test su codice archivio                     *
      *                  *---------------------------------------------*
           if        rf-oct-cod-arc       not  = rr-cod-cli or
                     rf-oct-dat-doc       >    rr-dem-max
                     go to crz-arc-srt-900.
       crz-arc-srt-400.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero documento                    *
      *                  *---------------------------------------------*
           if        rf-oct-num-doc       <    rr-ndo-min or
                     rf-oct-num-doc       >    rr-ndo-max
                     go to crz-arc-srt-200.
       crz-arc-srt-600.
      *              *-------------------------------------------------*
      *              * Composizione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record per Sort             *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           move      rf-oct-num-doc       to   srt-num-key            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-oct               to   srt-rec-oct            .
       crz-arc-srt-700.
      *              *-------------------------------------------------*
      *              * Rilascio record al Sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       crz-arc-srt-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale file [oct]       *
      *              *-------------------------------------------------*
           go to     crz-arc-srt-200.
       crz-arc-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     crz-arc-srt-999.
       crz-arc-srt-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio conferme ordine clienti per EDI        *
      *    *                                                           *
      *    * Procedura di output                                       *
      *    *-----------------------------------------------------------*
       crz-arc-orc-000.
       crz-arc-orc-200.
      *              *-------------------------------------------------*
      *              * Lettura record da sort                          *
      *              *-------------------------------------------------*
           return    srt   at end
                     go to crz-arc-orc-800.
       crz-arc-orc-300.
      *              *-------------------------------------------------*
      *              * Recupero record [oct]                           *
      *              *-------------------------------------------------*
           move      srt-rec-oct          to   rf-oct                 .
       crz-arc-orc-400.
      *              *-------------------------------------------------*
      *              * Test di rottura su protocollo documento         *
      *              *-------------------------------------------------*
           perform   crz-arc-orc-rot-000  thru crz-arc-orc-rot-999    .
       crz-arc-orc-700.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sort                         *
      *              *-------------------------------------------------*
           go to     crz-arc-orc-200.
       crz-arc-orc-800.
      *              *-------------------------------------------------*
      *              * Test su contatore documenti                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su contatore documenti creati          *
      *                  *---------------------------------------------*
           if        w-rec-num-orc        =    zero
                     go to crz-arc-orc-850.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     crz-arc-orc-900.
       crz-arc-orc-850.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Nessun documento entro i limiti assegnati"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     crz-arc-orc-900.
       crz-arc-orc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     crz-arc-orc-999.
       crz-arc-orc-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio conferme ordine clienti XML            *
      *    *                                                           *
      *    * Test di rottura su numero documento                       *
      *    *-----------------------------------------------------------*
       crz-arc-orc-rot-000.
      *              *-------------------------------------------------*
      *              * Test se primo passaggio                         *
      *              *-------------------------------------------------*
           if        w-rot-l01-num-doc    =    zero
                     go to crz-arc-orc-rot-200.
           if        w-rot-l01-num-doc    =    srt-num-key
                     go to crz-arc-orc-rot-600
           else      go to crz-arc-orc-rot-200.
       crz-arc-orc-rot-200.
      *              *-------------------------------------------------*
      *              * Se nuovo documento                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento contatore ordini                 *
      *                  *---------------------------------------------*
           add       1                    to   w-rec-num-orc          .
      *                  *---------------------------------------------*
      *                  * Aggiornamento rottura                       *
      *                  *---------------------------------------------*
           move      srt-num-key          to   w-rot-l01-num-doc      .
      *                  *---------------------------------------------*
      *                   * Generazione file 'XML'                     *
      *                  *---------------------------------------------*
           move      "EF"                 to   m-orc-xml-tip-ope      .
           move      rf-oct-num-prt       to   m-orc-xml-prt-oct      .
           perform   mod-orc-xml-cll-000  thru mod-orc-xml-cll-999    .
      *                  *---------------------------------------------*
      *                   * Invio file 'XML'                           *
      *                  *---------------------------------------------*
           perform   crz-arc-orc-inv-000  thru crz-arc-orc-inv-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     crz-arc-orc-rot-900.
       crz-arc-orc-rot-600.
      *              *-------------------------------------------------*
      *              * Se stesso documento                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     crz-arc-orc-rot-900.
       crz-arc-orc-rot-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     crz-arc-orc-rot-999.
       crz-arc-orc-rot-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio conferme ordine clienti XML            *
      *    *                                                           *
      *    * Invio documento                                           *
      *    *-----------------------------------------------------------*
       crz-arc-orc-inv-000.
      *              *-------------------------------------------------*
      *              * Test se invio previsto                          *
      *              *-------------------------------------------------*
      
      
      
           go to     crz-arc-orc-inv-900.
      
      
      
      
           if        rr-tip-exe           =    01
                     go to crz-arc-orc-inv-900.
       crz-arc-orc-inv-100.
      *              *-------------------------------------------------*
      *              * Recupero del pathname file generato             *
      *              *-------------------------------------------------*
       crz-arc-orc-inv-200.
      *              *-------------------------------------------------*
      *              * Composizione del comando di invio               *
      *              *-------------------------------------------------*
           move      spaces               to   o-shs                  .
           string    "t_ele_edi_out "
                                delimited by   size
______*              w-det-pth-fso-pt1
______*                         delimited by   spaces
                     " "
                                delimited by   size
                     rr-tip-exe-flg
                                delimited by   size
                     " | cat > /abd/asc/log/"
                                delimited by   size
                     rf-oct-num-prt
                                delimited by   spaces
                     ".log"
                                delimited by   size
                                          into o-shs                  .
      *              *-------------------------------------------------*
      *              * Chiamata al sistema effettiva                   *
      *              *-------------------------------------------------*
           move      "CU"                 to   o-ope                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
       crz-arc-orc-inv-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     crz-arc-orc-inv-999.
       crz-arc-orc-inv-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cli]                         *
      *    *-----------------------------------------------------------*
       let-arc-cli-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice cliente a zero                   *
      *              *-------------------------------------------------*
           if        w-let-arc-cli-cod    =    zero
                     go to let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      w-let-arc-cli-cod    to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-cli-400.
       let-arc-cli-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-cli-rag-soc       to   w-let-arc-cli-rag      .
           move      rf-cli-via-cli       to   w-let-arc-cli-via      .
           move      rf-cli-loc-cli       to   w-let-arc-cli-loc      .
           move      rf-cli-cod-cge       to   w-let-arc-cli-cge      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-cli-999.
       let-arc-cli-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-cli-flg      .
           move      all   "."            to   w-let-arc-cli-rag      .
           go to     let-arc-cli-600.
       let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-rag      .
       let-arc-cli-600.
           move      spaces               to   w-let-arc-cli-via      .
           move      spaces               to   w-let-arc-cli-loc      .
           move      zero                 to   w-let-arc-cli-cge      .
       let-arc-cli-999.
           exit.

