                     go to prs-stp-orf-800.
           if        w-prs-sof-sns
                    (w-prs-sof-ctr)       not  = "S" and
                     w-prs-sof-sns
                    (w-prs-sof-ctr)       not  = "N"
                     move  "S"            to   w-prs-sof-sns
                                              (w-prs-sof-ctr)         .
           go to     prs-stp-orf-720.
       prs-stp-orf-800.
       prs-stp-orf-999.
           exit.

