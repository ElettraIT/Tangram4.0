                     w-lpi-int-azi-pos    =    zero
                     go to int-pag-sta-200.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo intestazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-prs-sof-tin        =    "N"
                     go to int-pag-sta-120
           else if   w-prs-sof-tin        =    "R"
                     go to int-pag-sta-140
           else if   w-prs-sof-tin        =    "P"
                     go to int-pag-sta-160
