      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo stampato personalizzato        *
      *                  *---------------------------------------------*
           if        w-prs-sof-tst        not  = "L"
                     go to ref-stp-int-999.
      *                  *---------------------------------------------*
      *                  * Test su tipo intestazione personalizzata    *
      *                  *---------------------------------------------*
           if        w-prs-sof-tin        not  = "R"
                     go to ref-stp-int-999.
      *              *-------------------------------------------------*
      *              * Ciclo per 6 referenze                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-ref-stp-int-ctr      .
       ref-stp-int-500.
           add       1                    to   w-ref-stp-int-ctr      .
           if        w-ref-stp-int-ctr    >    8
                     go to ref-stp-int-999.
      *                  *---------------------------------------------*
      *                  * Lettura referenza multipla                  *
      *                  *---------------------------------------------*
           move      "R:"                 to   s-ope                  .
           move      w-ref-stp-int-ctr    to   s-num                  .
           move      "pgm/orf/mov/orf300s[int-orf]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        s-ves                =    spaces
                     move  s-alf          to   w-ref-stp-int-des
                                              (w-ref-stp-int-ctr)
           else      move  spaces         to   w-ref-stp-int-des
                                              (w-ref-stp-int-ctr)     .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     ref-stp-int-500.
       ref-stp-int-999.
           exit.

      *    *===========================================================*
      *    * Open files necessari alla stampa                          *
      *    *-----------------------------------------------------------*
       rou-opn-fls-000.
      *              *-------------------------------------------------*
      *              * Eventuale correzione ampiezza linea di stampa   *
      *              * in base all'ampiezza caratteri selezionata      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se l'ampiezza caratteri selezionata e' a    *
      *                  * zero, vuol dire che e' stata selezionata    *
      *                  * una stampante PostScript o HP-GL, quindi    *
      *                  * non si effettuano correzioni                *
      *                  *---------------------------------------------*
           if        p-sel-amc-sel        =    zero
                     go to rou-opn-fls-200.
      *                  *---------------------------------------------*
      *                  * Se l'ampiezza caratteri selezionata e'      *
      *                  * quella prestabilita a seconda del tipo mo-  *
      *                  * dulo, non si effettuano correzioni          *
      *                  *---------------------------------------------*
           if       (w-prs-sof-tmd        =    01    and
                     p-sel-amc-sel        =    12,00   ) or
                    (w-prs-sof-tmd        =    51    and
                     p-sel-amc-sel        =    15,00   )
                     go to rou-opn-fls-200.
       rou-opn-fls-100.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo modulo perso- *
      *                  * nalizzato                                   *
      *                  *---------------------------------------------*
           if        w-prs-sof-tmd        =    01
                     go to rou-opn-fls-110
           else if   w-prs-sof-tmd        =    51
                     go to rou-opn-fls-120
           else      go to rou-opn-fls-200.
       rou-opn-fls-110.
      *                  *---------------------------------------------*
      *                  * Tipo modulo : 01 - Senza codice prodotto    *
      *                  *---------------------------------------------*
           multiply  p-sel-als-sel        by   p-sel-amc-sel
                                        giving w-rou-opn-fls-wac      .
           divide    12,00                into w-rou-opn-fls-wac
                                     remainder w-rou-opn-fls-wre      .
           if        w-rou-opn-fls-wre    >    zero
                     add  1               to   w-rou-opn-fls-wac      .
           go to     rou-opn-fls-150.
       rou-opn-fls-120.
      *                  *---------------------------------------------*
      *                  * Tipo modulo : 51 - Con codice prodotto      *
      *                  *---------------------------------------------*
           multiply  p-sel-als-sel        by   p-sel-amc-sel
                                        giving w-rou-opn-fls-wac      .
           divide    15,00                into w-rou-opn-fls-wac
                                     remainder w-rou-opn-fls-wre      .
           if        w-rou-opn-fls-wre    >    zero
                     add  1               to   w-rou-opn-fls-wac      .
           go to     rou-opn-fls-150.
       rou-opn-fls-150.
      *                  *---------------------------------------------*
      *                  * Correzione ampiezza linea selezionata       *
      *                  *---------------------------------------------*
           move      w-rou-opn-fls-wac    to   p-sel-als-sel          .
       rou-opn-fls-200.
