      *    *===========================================================*
      *    * Stampa corpo documento : Determinazione del volume in     *
      *    *                          riga                             *
      *    *-----------------------------------------------------------*
       stp-cor-doc-dvr-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-cor-doc-tvr      .
      *              *-------------------------------------------------*
      *              * Test se necessario                              *
      *              *-------------------------------------------------*
           if        rf-yof-snx-stv       not  = "S"
                     go to stp-cor-doc-dvr-900.
       stp-cor-doc-dvr-100.
      *              *-------------------------------------------------*
      *              * Se si tratta di una riga di commento o di adde- *
      *              * bito : no                                       *
      *              *-------------------------------------------------*
           if        w-tip-rig-tpr        =    "C" or
                     w-tip-rig-tpr        =    "A"
                     go to stp-cor-doc-dvr-900.
       stp-cor-doc-ico-150.
      *              *-------------------------------------------------*
      *              * Se il tipo prodotto non e' pari a 'P': no       *
      *              *                                                 *
      *              * N.B.: Attualmente implementato solo per riga di *
      *              *       prodotto                                  *
      *              *-------------------------------------------------*
           if        w-tip-rig-tpr        not  = "P"
                     go to stp-cor-doc-dvr-900.
       stp-cor-doc-dvr-175.
      *              *-------------------------------------------------*
      *              * Se quantita' in ordine a zero : no              *
      *              *                                                 *
      *              * N.B.: Non si considera la trasformazione di     *
      *              *       unita' di misura                          *
      *              *-------------------------------------------------*
           if        rf-ofr-qta-ord       =    zero
                     go to stp-cor-doc-dvr-900.
       stp-cor-doc-ico-200.
      *              *-------------------------------------------------*
      *              * Normalizzazione anagrafica prodotto             *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Lettura anagrafica prodotto                     *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rf-ofr-num-mag       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Determinazione del volume in riga               *
      *              *                                                 *
      *              * N.B.: Attualmente il calcolo avviene secondo la *
      *              *       formula :                                 *
      *              *                                                 *
      *              *       (VOLUME PRODOTTO :                        *
      *              *        QTA' PER CONFEZIONE) x QTA' ORDINATA     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione confezione        *
      *                  *---------------------------------------------*
           if        rf-dcp-qta-cfz       =    zero
                     move  1              to   rf-dcp-qta-cfz         .
           divide    rf-dcp-qta-cfz       into rf-ofr-qta-ord
                                        giving w-stp-cor-doc-tvr      .
           multiply  rf-dcp-vol-uni       by   w-stp-cor-doc-tvr      .
      *                  *---------------------------------------------*
      *                  * Incremento totale volume                    *
      *                  *---------------------------------------------*
           add       w-stp-cor-doc-tvr    to   w-stp-pie-tvo          .
       stp-cor-doc-dvr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-cor-doc-dvr-999.
       stp-cor-doc-dvr-999.
           exit.

      *    *===========================================================*
      *    * Stampa corpo documento : Data di consegna                 *
      *    *-----------------------------------------------------------*
       stp-cor-doc-dtc-000.
      *              *-------------------------------------------------*
      *              * Se l'indicatore di stampa da eseguire indica di *
      *              * non stampare : uscita                           *
      *              *-------------------------------------------------*
           if        w-stp-cor-doc-i80    not  = "S"
                     go to stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-500.
      *              *-------------------------------------------------*
      *              * Se data di consegna a zero : uscita             *
      *              *-------------------------------------------------*
           if        rf-ofr-dcn-ric       =   zero
                     go to stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-600.
      *              *-------------------------------------------------*
      *              * Flag di stampa eseguita in On                   *
      *              *-------------------------------------------------*
           move      "S"                  to   w-stp-cor-doc-f80      .
       stp-cor-doc-dtc-700.
      *              *-------------------------------------------------*
      *              * Stampa data di consegna                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del formato di stam- *
      *                  * pa data consegna richiesta                  *
      *                  *---------------------------------------------*
           if        rf-ofr-fds-dcr       =    spaces
                     go to stp-cor-doc-dtc-710
           else if   rf-ofr-fds-dcr       =    "U"
                     go to stp-cor-doc-dtc-720
           else if   rf-ofr-fds-dcr       =    "A"
                     go to stp-cor-doc-dtc-730
           else if   rf-ofr-fds-dcr       =    "N"
                     go to stp-cor-doc-dtc-740.
       stp-cor-doc-dtc-710.
      *                  *---------------------------------------------*
      *                  * Formato di stampa data consegna richiesta : *
      *                  * Normale                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del formato di   *
      *                      * stampa data consegna generale           *
      *                      *-----------------------------------------*
           if        rf-oft-fds-dtc       =    01
                     go to stp-cor-doc-dtc-712
           else if   rf-oft-fds-dtc       =    02
                     go to stp-cor-doc-dtc-714
           else if   rf-oft-fds-dtc       =    03
                     go to stp-cor-doc-dtc-716
           else if   rf-oft-fds-dtc       =    04
                     go to stp-cor-doc-dtc-718.
       stp-cor-doc-dtc-712.
      *                      *-----------------------------------------*
      *                      * Se formato di stampa 01 : gg/mm/aa      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      spaces               to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-dat-cns-pos    to   p-pos                  .
           move      rf-ofr-dcn-ric       to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-714.
      *                      *-----------------------------------------*
      *                      * Se formato di stampa 02 : mm/aa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Data in area di ridefinizione       *
      *                          *-------------------------------------*
           move      rf-ofr-dcn-ric       to   s-dat                  .
      *                          *-------------------------------------*
      *                          * Se mese non compreso tra 1 e 12 :   *
      *                          * uscita senza alcuna azione          *
      *                          *-------------------------------------*
           if        s-mes                <    01 or
                     s-mes                >    12
                     go to stp-cor-doc-dtc-999.
      *                          *-------------------------------------*
      *                          * Editing data                        *
      *                          *-------------------------------------*
           move      spaces               to   w-stp-cor-doc-dce      .
           move      w-tbl-mes-des (s-mes)
                                          to   w-stp-cor-doc-dcm      .
           move      s-saa                to   w-stp-cor-doc-dca      .
           add       1900                 to   w-stp-cor-doc-dca      .
      *                          *-------------------------------------*
      *                          * Stampa data editata                 *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      spaces               to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-dat-cns-pos    to   p-pos                  .
           move      w-stp-cor-doc-dce    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-716.
      *                      *-----------------------------------------*
      *                      * Se formato di stampa 03 : No stampa     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-718.
      *                      *-----------------------------------------*
      *                      * Formato di stampa richiesto : st/aaaa   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Richiesta alla segreteria del nume- *
      *                          * ro della settimana nell'anno        *
      *                          *-------------------------------------*
           move      "SA"                 to   s-ope                  .
           move      rf-ofr-dcn-ric       to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                          *-------------------------------------*
      *                          * Editing settimana nell'anno         *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      s-num                to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-dat-cns-set          .
      *                          *-------------------------------------*
      *                          * Editing anno data consegna          *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      rf-ofr-dcn-ric       to   s-dat                  .
           move      s-saa                to   p-num                  .
           add       1900                 to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-dat-cns-ann          .
      *                          *-------------------------------------*
      *                          * Composizione stringa                *
      *                          *-------------------------------------*
           move      07                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-dat-cns-set        to   w-all-str-cat (1)      .
           move      "/"                  to   w-all-str-cat (2)      .
           move      w-dat-cns-ann        to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-dat-cns-edt          .
      *                          *-------------------------------------*
      *                          * Stampa data editata                 *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      spaces               to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-dat-cns-pos    to   p-pos                  .
           move      w-dat-cns-edt        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-720.
      *                  *---------------------------------------------*
      *                  * Formato di stampa data consegna richiesta : *
      *                  * Urgente                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa literal 'Urgente'                *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-dat-cns-pos    to   p-pos                  .
           move      "Urgente "           to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-730.
      *                  *---------------------------------------------*
      *                  * Formato di stampa data consegna richiesta : *
      *                  * A.S.A.P.                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa literal 'A.S.A.P.'               *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-dat-cns-pos    to   p-pos                  .
           move      "A.S.A.P."           to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-740.
      *                  *---------------------------------------------*
      *                  * Formato di stampa data consegna richiesta : *
      *                  * No stampa                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-dtc-999.
       stp-cor-doc-dtc-999.
           exit.

      *    *===========================================================*
      *    * Stampa corpo documento : Legame valutario                 *
      *    *-----------------------------------------------------------*
       stp-cor-doc-lvl-000.
      *              *-------------------------------------------------*
      *              * Se il tipo riga non indica ne' un prodotto fi-  *
      *              * nito, ne' una materia prima, ne' un materiale   *
      *              * vario : no                                      *
      *              *-------------------------------------------------*
           if        w-tip-rig-tpr        not  = "P" and
                     w-tip-rig-tpr        not  = "M" and
                     w-tip-rig-tpr        not  = "V"
                     go to stp-cor-doc-lvl-999.
      *              *-------------------------------------------------*
      *              * Se non esiste la sigla valuta per il legame va- *
      *              * lutario : nessuna azione                        *
      *              *-------------------------------------------------*
           if        rf-ofr-sgl-vpl       =    spaces
                     go to stp-cor-doc-lvl-999.
      *              *-------------------------------------------------*
      *              * Se non esiste il posizionamento per la descri-  *
      *              * zione : nessuna azione                          *
      *              *-------------------------------------------------*
           if        w-lpc-des-pro-pos    =    zero
                     go to stp-cor-doc-lvl-999.
      *              *-------------------------------------------------*
      *              * Se il tipo documento non prevede la stampa del  *
      *              * prezzo : no                                     *
      *              *-------------------------------------------------*
           if        rf-yof-snx-prz       not  = 01
                     go to stp-cor-doc-lvl-999.
      *              *-------------------------------------------------*
      *              * Se il tipo riga indica una materia prima : si'  *
      *              *-------------------------------------------------*
           if        w-tip-rig-tpr        =    "M"
                     go to stp-cor-doc-lvl-500.
      *              *-------------------------------------------------*
      *              * Se il tipo riga indica un materiale vario : si' *
      *              *-------------------------------------------------*
           if        w-tip-rig-tpr        =    "V"
                     go to stp-cor-doc-lvl-500.
      *              *-------------------------------------------------*
      *              * Se il tipo riga indica un prodotto finito       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo esposizione riga 1 : si'            *
      *                  *---------------------------------------------*
           if        rf-ofr-epz-rgo       =    1
                     go to stp-cor-doc-lvl-500.
      *                  *---------------------------------------------*
      *                  * Se tipo esposizione riga 2 : no             *
      *                  *---------------------------------------------*
           if        rf-ofr-epz-rgo       =    2
                     go to stp-cor-doc-lvl-999.
      *                  *---------------------------------------------*
      *                  * Se tipo esposizione riga 3 : no             *
      *                  *---------------------------------------------*
           if        rf-ofr-epz-rgo       =    3
