      *    *===========================================================*
      *    * Stampa documento                                          *
      *    *-----------------------------------------------------------*
       rou-stp-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Normalizzazione numero pagina                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-npr-num-pag      .
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Lettura record testata da stampare              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-inp-mst-prt        to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
           if        f-sts                =    e-not-err
                     go to rou-stp-doc-100.
      *                  *---------------------------------------------*
      *                  * Se record non trovato uscita con status al  *
      *                  * valore "N"                                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-mst              .
           move      "N"                  to   w-out-mst-stp          .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-100.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per il driver di stampa  *
      *              *-------------------------------------------------*
           move      rf-oft-num-doc       to   w-prm-pst-chm-ndo      .
           move      rf-oft-tmo-orf       to   w-prm-pst-chm-tdo      .
           move      w-prm-pst-chm        to   p-sel-spc-sel          .
      *              *-------------------------------------------------*
      *              * Incremento numero pagina                        *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-npr-num-pag      .
      *              *-------------------------------------------------*
      *              * Avanzamento pagina                              *
      *              *-------------------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Se errore grave di i-o su stampa si esce    *
      *                  * con status di errore                        *
      *                  *---------------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to  rou-stp-doc-999.
       rou-stp-doc-200.
      *              *-------------------------------------------------*
      *              * Preparazione preliminare dei literal per la     *
      *              * stampa dei box                                  *
      *              *-------------------------------------------------*
           perform   rou-stp-doc-lsb-000  thru rou-stp-doc-lsb-999    .
       rou-stp-doc-240.
      *              *-------------------------------------------------*
      *              * Apertura archivio per EDI                       *
      *              *                                                 *
      *              * ELETTRA                                         *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-seq-edi-tip-ope      .
           move      "ele/orf/prg/obj/dseqedi0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-seq-edi
                                               rf-oft
                                               rf-ofr                 .
       rou-stp-doc-260.
      *              *-------------------------------------------------*
      *              * Eventuale stampa intestazione pagina            *
      *              *-------------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *              *-------------------------------------------------*
      *              * Tentativo di lettura record [ofx] di appoggio   *
      *              * ai valori di testata                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ofx]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofx                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [ofx]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-oft-num-prt       to   rf-ofx-num-prt         .
           move      zero                 to   rf-ofx-num-prg         .
           move      01                   to   rf-ofx-tip-rec         .
           move      "pgm/orf/fls/ioc/obj/iofofx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofx                 .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori di estensione al re- *
      *                  * cord di testata                             *
      *                  *---------------------------------------------*
           move      rf-ofx-rag-ids       to   w-ext-rag-ids          .
           move      rf-ofx-via-ids       to   w-ext-via-ids          .
           move      rf-ofx-loc-ids       to   w-ext-loc-ids          .
           move      rf-ofx-des-cda       to   w-ext-des-cda          .
      *              *-------------------------------------------------*
      *              * Stampa testata documento                        *
      *              *-------------------------------------------------*
           perform   stp-tes-doc-000      thru stp-tes-doc-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to rou-stp-doc-300.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-300.
      *              *-------------------------------------------------*
      *              * Stampa corpo documento                          *
      *              *-------------------------------------------------*
           perform   stp-cor-doc-000      thru stp-cor-doc-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to rou-stp-doc-400.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-400.
      *              *-------------------------------------------------*
      *              * Stampa piede documento                          *
      *              *-------------------------------------------------*
           perform   stp-pie-doc-000      thru stp-pie-doc-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to rou-stp-doc-800.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-800.
      *              *-------------------------------------------------*
      *              * Page eject                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-inp-mst-ejc        =    "N"
                     go to rou-stp-doc-850.
      *                  *---------------------------------------------*
      *                  * Esecuzione                                  *
      *                  *---------------------------------------------*
           move      "EJ"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       rou-stp-doc-850.
      *              *-------------------------------------------------*
      *              * Chiusura del file in output                     *
      *              *                                                 *
      *              * ELETTRA                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  * ___                                         *
      *                  *---------------------------------------------*
           if        rf-oft-cod-arc       not  = 0000001
                     go to rou-stp-doc-900.
       rou-stp-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-stp-doc-999.
       rou-stp-doc-999.
           exit.

      *    *===========================================================*
      *    * Stampa documento                                          *
      *    *                                                           *
      *    * Subroutine di preparazione literal per la stampa dei box  *
      *    *-----------------------------------------------------------*
       rou-stp-doc-lsb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-cof-tbl          .
      *              *-------------------------------------------------*
      *              * Se il tipo stampato non e' libero : uscita      *
      *              *-------------------------------------------------*
           if        w-prs-sof-tst        not  = "L" and
                     w-prs-sof-tin        not  = "F"
                     go to rou-stp-doc-lsb-900.
       rou-stp-doc-lsb-100.
      *              *-------------------------------------------------*
      *              * Ciclo di caricamento                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-pmt-cof-ctr          .
       rou-stp-doc-lsb-200.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-pmt-cof-ctr          .
           if        w-pmt-cof-ctr        >    w-pmt-cof-max
                     go to rou-stp-doc-lsb-900.
      *                  *---------------------------------------------*
      *                  * Lettura file [yvf] per eventuale nome in    *
      *                  * lingua                                      *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODVDF    "         to   f-key                  .
           move      w-pmt-cof-cod
                    (w-pmt-cof-ctr)       to   rf-yvf-num-def         .
           move      spaces               to   rf-yvf-cod-def         .
           move      rf-oft-cod-lng       to   rf-yvf-cod-lng         .
           move      "pgm/dcf/fls/ioc/obj/iofyvf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yvf                 .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-stp-doc-lsb-400.
       rou-stp-doc-lsb-300.
      *                      *-----------------------------------------*
      *                      * Se record [yvf] non trovato             *
      *                      *-----------------------------------------*
           move      w-pmt-cof-des
                    (w-pmt-cof-ctr)       to   w-stp-cof-des
                                              (w-pmt-cof-ctr)         .
      *                          *-------------------------------------*
      *                          * A riciclo                           *
      *                          *-------------------------------------*
           go to     rou-stp-doc-lsb-600.
       rou-stp-doc-lsb-400.
      *                      *-----------------------------------------*
      *                      * Se record [yvf] trovato                 *
      *                      *-----------------------------------------*
           move      rf-yvf-des-stp       to   w-stp-cof-des
                                              (w-pmt-cof-ctr)         .
      *                          *-------------------------------------*
      *                          * A riciclo                           *
      *                          *-------------------------------------*
           go to     rou-stp-doc-lsb-600.
       rou-stp-doc-lsb-600.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     rou-stp-doc-lsb-200.
       rou-stp-doc-lsb-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-stp-doc-lsb-999.
       rou-stp-doc-lsb-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa testata documento                       *
      *    *-----------------------------------------------------------*
       stp-tes-doc-000.
      *              *-------------------------------------------------*
      *              * Scrittura testata archivio per EDI              *
      *              *                                                 *
      *              * ELETTRA                                         *
      *              *-------------------------------------------------*
           move      "WT"                 to   d-seq-edi-tip-ope      .
           move      "ele/orf/prg/obj/dseqedi0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-seq-edi
                                               rf-oft
                                               rf-ofr                 .
       stp-tes-doc-010.
      *              *-------------------------------------------------*
      *              * Tipo documento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [yof]                        *
      *                  *                                             *
      *                  * N.B.: La lettura deve comunque essere fatta *
      *                  *       in quanto il record [yof] contiene    *
      *                  *       alcuni indicatori di 'si/no' stampa   *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTOF    "         to   f-key                  .
           move      rf-oft-tmo-orf       to   rf-yof-cod-tof         .
           move      "pgm/orf/fls/ioc/obj/iofyof"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yof                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-yof-des-stp         .
      *                  *---------------------------------------------*
      *                  * Test su codice lingua                       *
      *                  *---------------------------------------------*
           if        rf-oft-cod-lng       =    "I  "
                     go to stp-tes-doc-040.
      *                  *---------------------------------------------*
      *                  * Eventuale dicitura in lingua straniera      *
      *                  *---------------------------------------------*
           if        w-stp-cof-des (01)   not  = spaces
                     move  w-stp-cof-des (01)
                                          to   rf-yof-des-stp         .
       stp-tes-doc-040.
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se posizionamento esistente        *
      *                      *-----------------------------------------*
           if        w-lpt-tmo-orf-lin    =   zero or
                     w-lpt-tmo-orf-pos    =   zero
                     go to stp-tes-doc-050.
      *                      *-----------------------------------------*
      *                      * Nel caso di documento in lingua, si     *
      *                      * sostituisce la descrizione timo movi-   *
      *                      * mento per la stampa con quello in lin-  *
      *                      * gua                                     *
      *                      *-----------------------------------------*
           if        rf-oft-cod-lng       not  = "I  " and
                     w-stp-cof-des (01)   not  = spaces
                     move  w-stp-cof-des (01)
                                          to   rf-yof-des-stp         .
      *                      *-----------------------------------------*
      *                      * Determinazione lunghezza stringa        *
      *                      *-----------------------------------------*
           move      zero                 to   w-stp-tes-ctr          .
           inspect   rf-yof-des-stp   tallying w-stp-tes-ctr
                                  for trailing spaces                 .
           subtract  w-stp-tes-ctr        from 25
                                        giving w-stp-tes-wsz          .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-tes-wsz        to   p-car                  .
           move      w-lpt-tmo-orf-lin    to   p-lin                  .
           divide    2                    into w-stp-tes-ctr
                                        giving p-pos                  .
           add       w-lpt-tmo-orf-pos    to   p-pos                  .
           move      rf-yof-des-stp       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tes-doc-050.
      *              *-------------------------------------------------*
      *              * Numero documento                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpt-num-doc-lin    =   zero or
                     w-lpt-num-doc-pos    =   zero
                     go to stp-tes-doc-100.
      *                  *---------------------------------------------*
      *                  * Numero documento in work ridefinito         *
      *                  *---------------------------------------------*
           move      rf-oft-num-doc       to   w-num-doc-num          .
      *                  *---------------------------------------------*
      *                  * Stampa numero progressivo                   *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      w-lpt-num-doc-lin    to   p-lin                  .
           move      w-lpt-num-doc-pos    to   p-pos                  .
           move      w-num-doc-prg        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Composizione stringa per dipendenza e sigla *
      *                  * numerazione                                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-num-doc-str          .
           move      1                    to   w-num-doc-pnt          .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da stampare                 *
      *                          *-------------------------------------*
           if        w-num-doc-dpz        =    01
                     go to stp-tes-doc-052.
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    "."
                                delimited by   size
                     w-num-doc-dpz
                                delimited by   size
                                          into w-num-doc-str
                                  with pointer w-num-doc-pnt          .
       stp-tes-doc-052.
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da stampare                 *
      *                          *-------------------------------------*
           if        rf-oft-sgl-num       =    spaces
                     go to stp-tes-doc-054.
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    "-"
                                delimited by   size
                     rf-oft-sgl-num
                                delimited by   size
                                          into w-num-doc-str
                                  with pointer w-num-doc-pnt          .
       stp-tes-doc-054.
      *                  *---------------------------------------------*
      *                  * Determinazione lunghezza stringa            *
      *                  *---------------------------------------------*
           move      zero                 to   w-num-doc-pnt          .
           inspect   w-num-doc-str
                                      tallying w-num-doc-pnt
                                  for trailing spaces                 .
      *                  *---------------------------------------------*
      *                  * Stampa stringa composta                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      07                   to   p-car                  .
           subtract  w-num-doc-pnt        from p-car                  .
           move      w-lpt-num-doc-lin    to   p-lin                  .
           move      w-lpt-num-doc-pos    to   p-pos                  .
           add       06                   to   p-pos                  .
           move      w-num-doc-str        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tes-doc-100.
      *              *-------------------------------------------------*
      *              * Data documento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpt-dat-doc-lin    =   zero or
                     w-lpt-dat-doc-pos    =   zero
                     go to stp-tes-doc-150.
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      "S"                  to   p-edm                  .
           move      w-lpt-dat-doc-lin    to   p-lin                  .
           move      w-lpt-dat-doc-pos    to   p-pos                  .
           move      rf-oft-dat-doc       to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tes-doc-150.
      *              *-------------------------------------------------*
      *              * Lettura dati anagrafici archivio                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        rf-oft-tip-arc       =    "F"
                     go to stp-tes-doc-160
           else      go to stp-tes-doc-200.
       stp-tes-doc-160.
      *                  *---------------------------------------------*
      *                  * Tipo archivio : Fornitori                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [fnt]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [fnt]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
