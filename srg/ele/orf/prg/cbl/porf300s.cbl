      *    *===========================================================*
      *    * Preparazione parametri per selezione stampante            *
      *    *-----------------------------------------------------------*
       pre-prm-stp-000.
      *              *-------------------------------------------------*
      *              * Flags di tipo selezione                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sel      .
      *              *-------------------------------------------------*
      *              * Codice stampante                                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-stp      .
      *              *-------------------------------------------------*
      *              * Tipo di stampa                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sta      .
      *              *-------------------------------------------------*
      *              * Codice modulo                                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-mod      .
      *              *-------------------------------------------------*
      *              * Tipo modulo                                     *
      *              *   - L : Libero                                  *
      *              *-------------------------------------------------*
           move      "L"                  to   w-cnt-stp-tip-mod      .
      *              *-------------------------------------------------*
      *              * Ampiezza linea di stampa in caratteri           *
      *              *                                                 *
      *              * Se personalizzazione relativa al tipo modulo    *
      *              * per stampa ordine a fornitore  :                *
      *              *   01 - ampiezza linea  96 caratteri             *
      *              *   51 - ampiezza linea 120 caratteri             *
      *              *-------------------------------------------------*
           if        w-prs-sof-tmd        =    01
                     move  096            to   w-cnt-stp-amp-lin
           else      move  120            to   w-cnt-stp-amp-lin      .
      *              *-------------------------------------------------*
      *              * Top margin in linee                             *
      *              *-------------------------------------------------*
           move      w-dsp-top-mrg        to   w-cnt-stp-top-lin      .
      *              *-------------------------------------------------*
      *              * Numero linee di stampa minimo                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-lin-min      .
      *              *-------------------------------------------------*
      *              * Bottom margin in linee                          *
      *              *-------------------------------------------------*
           move      w-dsp-bot-mrg        to   w-cnt-stp-bot-lin      .
      *              *-------------------------------------------------*
      *              * Ampiezza caratteri                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-amp-car      .
      *              *-------------------------------------------------*
      *              * Altezza interlinea                              *
      *              *-------------------------------------------------*
           move      06                   to   w-cnt-stp-alt-int      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni future            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-esp-fut      .
      *                  *---------------------------------------------*
      *                  * Flag destinato al controllo del Tipo Stampa *
      *                  * per inibire la possibilita' della stampa a  *
      *                  * Video                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-stp-esp-fut
                                              (98 : 1)                .
      *                  *---------------------------------------------*
      *                  * Flag destinato al controllo del Top Margin  *
      *                  *---------------------------------------------*
           move      "*"                  to   w-cnt-stp-esp-fut
                                              (99 : 1)                .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni speciali          *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-fnz-spc      .
       pre-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Lettura personalizzazione : Stampa ordine fornitore       *
      *    *-----------------------------------------------------------*
       prs-stp-orf-000.
      *              *-------------------------------------------------*
      *              * Lettura personalizzazione                       *
      *              *-------------------------------------------------*
           move      "P:"                 to   s-ope                  .
           move      "pgm/orf/mov/orf300s[stp-orf]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Se personalizzazione non esistente              *
      *              *-------------------------------------------------*
           if        s-ves                =    spaces
                     go to prs-stp-orf-050.
      *                  *---------------------------------------------*
      *                  * Normalizzazione al valore di default        *
      *                  *---------------------------------------------*
           move      01                   to   w-prs-sof-tmd          .
           move      "L"                  to   w-prs-sof-tst          .
           move      "P"                  to   w-prs-sof-tin          .
           move      "S"                  to   w-prs-sof-snv (1)      .
           move      "S"                  to   w-prs-sof-snv (2)      .
           move      "S"                  to   w-prs-sof-snv (3)      .
           move      "S"                  to   w-prs-sof-snv (4)      .
           move      "S"                  to   w-prs-sof-snv (5)      .
           move      "S"                  to   w-prs-sof-snv (6)      .
           move      "N"                  to   w-prs-sof-cod          .
           move      "N"                  to   w-prs-sof-rac          .
           move      "N"                  to   w-prs-sof-snf          .
           move      "N"                  to   w-prs-sof-snq          .
           move      "N"                  to   w-prs-sof-snl          .
           move      "N"                  to   w-prs-sof-snr          .
           move      "N"                  to   w-prs-sof-snp          .
           move      "S"                  to   w-prs-sof-sns (1)      .
           move      "S"                  to   w-prs-sof-sns (2)      .
           move      "S"                  to   w-prs-sof-sns (3)      .
           move      "S"                  to   w-prs-sof-sns (4)      .
           move      "S"                  to   w-prs-sof-sns (5)      .
           move      "S"                  to   w-prs-sof-sns (6)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prs-stp-orf-999.
       prs-stp-orf-050.
      *              *-------------------------------------------------*
      *              * Valore letto in work personalizzazioni          *
      *              *-------------------------------------------------*
           move      s-alf                to   w-prs-sof-str          .
      *              *-------------------------------------------------*
      *              * Controllo valori letti                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo modulo                                 *
      *                  *---------------------------------------------*
           if        w-prs-sof-tmd        not  numeric
                     move  01             to   w-prs-sof-tmd
                     go to prs-stp-orf-100.
           if        w-prs-sof-tmd        not  = 01 and
                     w-prs-sof-tmd        not  = 51
                     move  01             to   w-prs-sof-tmd          .
       prs-stp-orf-100.
      *                  *---------------------------------------------*
      *                  * Tipo stampato                               *
      *                  *---------------------------------------------*
           if        w-prs-sof-tst        not  = "T" and
                     w-prs-sof-tst        not  = "L"
                     move  "L"            to   w-prs-sof-tst          .
      *                  *---------------------------------------------*
      *                  * Tipo intestazione stampato                  *
      *                  *---------------------------------------------*
           if        w-prs-sof-tin        not  = "N" and
                     w-prs-sof-tin        not  = "R" and
                     w-prs-sof-tin        not  = "P" and
                     w-prs-sof-tin        not  = "F"
                     move  "P"            to   w-prs-sof-tin          .
           if        w-prs-sof-tin        =    "F"
                     go to prs-stp-orf-105.
           if        w-prs-sof-tst        =    "T"
                     move  "N"            to   w-prs-sof-tin          .
       prs-stp-orf-105.
      *                  *---------------------------------------------*
      *                  * Si/no stampa voci descrittive               *
      *                  *---------------------------------------------*
           move      zero                 to   w-prs-sof-ctr          .
       prs-stp-orf-110.
           add       1                    to   w-prs-sof-ctr          .
           if        w-prs-sof-ctr        >    6
                     go to prs-stp-orf-200.
           if        w-prs-sof-snv
                    (w-prs-sof-ctr)       not  = "S" and
                     w-prs-sof-snv
                    (w-prs-sof-ctr)       not  = "N"
                     move  "N"            to   w-prs-sof-snv
                                              (w-prs-sof-ctr)         .
           go to     prs-stp-orf-110.
       prs-stp-orf-200.
      *                  *---------------------------------------------*
      *                  * Cosa stampare in colonna codice             *
      *                  *---------------------------------------------*
           if        w-prs-sof-tmd        not  = 51
                     move  "N"            to   w-prs-sof-cod
                     go to prs-stp-orf-300.
           if        w-prs-sof-cod        not  = "N" and
                     w-prs-sof-cod        not  = "F" and
                     w-prs-sof-cod        not  = "P" and
                     w-prs-sof-cod        not  = "M"
                     move  "N"            to   w-prs-sof-cod          .
       prs-stp-orf-300.
      *                  *---------------------------------------------*
      *                  * Righe aggiuntive per codice prodotto        *
      *                  *---------------------------------------------*
           if        w-prs-sof-rac        not  = "N" and
                     w-prs-sof-rac        not  = "F" and
                     w-prs-sof-rac        not  = "M" and
                     w-prs-sof-rac        not  = "P" and
                     w-prs-sof-rac        not  = "E" and
                     w-prs-sof-rac        not  = "U"
                     move  "N"            to   w-prs-sof-rac          .
       prs-stp-orf-400.
      *                  *---------------------------------------------*
      *                  * Si/No stampa del numero fax                 *
      *                  *---------------------------------------------*
           if        w-prs-sof-snf        not  = "S" and
                     w-prs-sof-snf        not  = "N" and
                     w-prs-sof-snf        not  = "T"
                     move  "N"            to   w-prs-sof-snf          .
       prs-stp-orf-500.
      *                  *---------------------------------------------*
      *                  * Si/No stampa quantita' editata a destra     *
      *                  *---------------------------------------------*
           if        w-prs-sof-snq        not  = "S" and
                     w-prs-sof-snq        not  = "N"
                     move  "N"            to   w-prs-sof-snq          .
       prs-stp-orf-600.
      *                  *---------------------------------------------*
      *                  * Si/No stampa in laser o PCL5                *
      *                  *---------------------------------------------*
           if        w-prs-sof-snl        not  = "S" and
                     w-prs-sof-snl        not  = "N" and
                     w-prs-sof-snl        not  = "P"
                     move  "N"            to   w-prs-sof-snl          .
       prs-stp-orf-620.
      *                  *---------------------------------------------*
      *                  * Si/No stampa responsabile ordine            *
      *                  *---------------------------------------------*
           if        w-prs-sof-snr        not  = "S" and
                     w-prs-sof-snr        not  = "N"
                     move  "N"            to   w-prs-sof-snr          .
       prs-stp-orf-640.
      *                  *---------------------------------------------*
      *                  * Si/No stampa casa produttrice a rottura su  *
      *                  * articoli                                    *
      *                  *---------------------------------------------*
           if        w-prs-sof-snp        not  = "S" and
                     w-prs-sof-snp        not  = "N"
                     move  "N"            to   w-prs-sof-snp          .
       prs-stp-orf-700.
      *                  *---------------------------------------------*
      *                  * Si/no stampa spese in fattura               *
      *                  *---------------------------------------------*
           move      zero                 to   w-prs-sof-ctr          .
