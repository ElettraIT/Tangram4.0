      *    *===========================================================*
      *    * Descrizione in lingua per la stampa di : spese per la     *
      *    * fatturazione e sconti in chiusura e pagamento             *
      *    *-----------------------------------------------------------*
       det-des-ysf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-des-ysf-des      .
       det-des-ysf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [ysf]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofysf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ysf                 .
      *              *-------------------------------------------------*
      *              * Tentativo di lettura della descrizione con il   *
      *              * codice lingua del cliente                       *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPF    "         to   f-key                  .
           move      w-det-des-ysf-cod    to   rf-ysf-num-spf         .
           move      w-det-des-ysf-lng    to   rf-ysf-cod-lng         .
           move      "pgm/dcf/fls/ioc/obj/iofysf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ysf                 .
      *                  *---------------------------------------------*
      *                  * Se valore trovato : uscita con il valore    *
      *                  * letto                                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-ysf-200.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore letto                *
      *                  *---------------------------------------------*
           move      rf-ysf-des-stp       to   w-det-des-ysf-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-ysf-999.
       det-des-ysf-200.
      *              *-------------------------------------------------*
      *              * Tentativo di lettura della descrizione con il   *
      *              * codice lingua per l'Italia                      *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPF    "         to   f-key                  .
           move      w-det-des-ysf-cod    to   rf-ysf-num-spf         .
           move      "I  "                to   rf-ysf-cod-lng         .
           move      "pgm/dcf/fls/ioc/obj/iofysf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ysf                 .
      *                  *---------------------------------------------*
      *                  * Se valore trovato : uscita con il valore    *
      *                  * letto                                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-ysf-400.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore letto                *
      *                  *---------------------------------------------*
           move      rf-ysf-des-stp       to   w-det-des-ysf-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-ysf-999.
       det-des-ysf-400.
      *              *-------------------------------------------------*
      *              * Uscita con valore a spaces                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-ysf-999.
       det-des-ysf-999.
           exit.

      *    *===========================================================*
      *    * Controllo tipo riga                                       *
      *    *-----------------------------------------------------------*
       ctl-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Controllo se ci sono asterischi                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-tip-rig-c01      .
           inspect   w-ctl-tip-rig-tri
                                      tallying w-ctl-tip-rig-c01
                                          for  all "*"                .
      *               *------------------------------------------------*
      *               * Deviazione in funzione del numero di asterischi*
      *               * trovati                                        *
      *               *------------------------------------------------*
           if        w-ctl-tip-rig-c01    =    zero
                     go to ctl-tip-rig-200
           else if   w-ctl-tip-rig-c01    =    1
                     go to ctl-tip-rig-100.
       ctl-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se c'e' un asterisco                            *
      *              *-------------------------------------------------*
           inspect   w-ctl-tip-rig-tri
                                     replacing all "*" by   spaces    .
      *              *-------------------------------------------------*
      *              * Segnale di presenza di asterisco                *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tip-rig-ast          .
       ctl-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione tipo prodotto connesso al tipo  *
      *              * riga                                            *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (1)
                                          to   w-tip-rig-tpr          .
      *              *-------------------------------------------------*
      *              * Se tipo prodotto P                              *
      *              *-------------------------------------------------*
           if        w-ctl-tip-rig-chr (1)
                                          not  = "P"
                     go to ctl-tip-rig-999.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo funzionamento riga     *
      *                  * connesso al tipo riga                       *
      *                  *---------------------------------------------*
           move      w-ctl-tip-rig-chr (2)
                                          to   w-tip-rig-tfu          .
       ctl-tip-rig-999.
           exit.

