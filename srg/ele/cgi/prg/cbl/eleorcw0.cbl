      *    *===========================================================*
      *    * Ciclo di lettura e preparazione html                      *
      *    *-----------------------------------------------------------*
       exe-cph-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione LOG JSON                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-exe-jsn-suc          .
           move      spaces               to   w-exe-jsn-leo          .
           move      spaces               to   w-exe-jsn-err          .
           move      spaces               to   w-exe-jsn-msg          .
      *                  *---------------------------------------------*
      *                  * Normalizzazione progressivo righe           *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-num-oct-prg      .
       exe-cph-010.
      *              *-------------------------------------------------*
      *              * Test su stringa di controllo (token)            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-exe-tok-enx        =    "eleorcw0"
                     go to exe-cph-020.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "false"              to   w-exe-jsn-suc          .
           move      spaces               to   w-exe-jsn-leo          .
           move      "TOKEN ERRATO"       to   w-exe-jsn-err          .
           move      "Errore scrittura ordine"
                                          to   w-exe-jsn-msg          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     exe-cph-900.
       exe-cph-020.
      *              *-------------------------------------------------*
      *              * Test su filename                                *
      *              *-------------------------------------------------*
           if        w-exe-fil-nam        not  = spaces
                     go to exe-cph-100.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "false"              to   w-exe-jsn-suc          .
           move      spaces               to   w-exe-jsn-leo          .
           move      "FILENAME A SPACES"  to   w-exe-jsn-err          .
           move      "Errore scrittura ordine"
                                          to   w-exe-jsn-msg          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     exe-cph-900.
       exe-cph-100.
      *              *-------------------------------------------------*
      *              * Apertura file sequenziale                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di input     *
      *                  *---------------------------------------------*
           perform   opn-seq-inp-000      thru opn-seq-inp-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori in apertura                  *
      *                  *---------------------------------------------*
           if        j-sts                =    e-not-err
                     go to exe-cph-200.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "false"              to   w-exe-jsn-suc          .
           move      spaces               to   w-exe-jsn-leo          .
           move      "FILENAME ERROR"  to   w-exe-jsn-err          .
           move      "Errore lettura file di testo"
                                          to   w-exe-jsn-msg          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     exe-cph-900.
       exe-cph-200.
      *                  *---------------------------------------------*
      *                  * Lettura da sequenziale                      *
      *                  *---------------------------------------------*
           perform   get-nxt-inp-000      thru get-nxt-inp-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        j-sts                =    e-not-err
                     go to exe-cph-300.
      *                  *---------------------------------------------*
      *                  * Test se a fine file                         *
      *                  *---------------------------------------------*
           if        j-sts                =    e-end-fil
                     go to exe-cph-800.
      *                  *---------------------------------------------*
      *                  * In tutti gli altri casi                     *
      *                  *---------------------------------------------*
           move      "false"              to   w-exe-jsn-suc          .
           move      spaces               to   w-exe-jsn-leo          .
           move      "FILENAME ERROR"     to   w-exe-jsn-err          .
           move      "Errore lettura file di testo"
                                          to   w-exe-jsn-msg          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     exe-cph-900.
       exe-cph-300.
      *              *-------------------------------------------------*
      *              * Trattamento in base al tipo di record           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In campo di comodo                          *
      *                  *---------------------------------------------*
           move      j-rec                to   w-inp-gen              .
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-inp-gen-tip        =    "T"
                     go to exe-cph-400
           else if   w-inp-gen-tip        =    "S"
                     go to exe-cph-450
           else if   w-inp-gen-tip        =    "C"
                     go to exe-cph-500
           else if   w-inp-gen-tip        =    "R"
                     go to exe-cph-600
           else      go to exe-cph-200.
       exe-cph-400.
      *              *-------------------------------------------------*
