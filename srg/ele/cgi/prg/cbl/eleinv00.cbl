           move      "SK"                 to   f-ope                  .
           move      "MAGUBI    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      01                   to   rf-miu-cod-dpz         .
           move      01                   to   rf-miu-tip-mag         .
           move      w-det-qtu-pro-num    to   rf-miu-num-mag         .
           move      spaces               to   rf-miu-cod-ubi         .
