      *              * - 'C': Con giacenza presunta                    *
      *              * - 'S': Senza giacenza presunta                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione                        *
      *                  *---------------------------------------------*
           if        w-exe-snx-gia        =    "N"
                     go to  exe-cph-lv2-sel-200.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-exe-snx-gia        =    "C"
                     go to exe-cph-lv2-sel-120
           else if   w-exe-snx-gia        =    "S"
                     go to exe-cph-lv2-sel-140
           else      go to exe-cph-lv2-sel-160.
       exe-cph-lv2-sel-120.
      *                  *---------------------------------------------*
      *                  * Se con giacenza presunta                    *
      *                  *---------------------------------------------*
           if        rf-miu-qta-prs       not  = zero
                     go to  exe-cph-lv2-sel-200
           else      go to  exe-cph-lv2-sel-800.
       exe-cph-lv2-sel-140.
      *                  *---------------------------------------------*
      *                  * Se senza giacenza presunta                  *
      *                  *---------------------------------------------*
           if        rf-miu-qta-prs       =    zero
                     go to  exe-cph-lv2-sel-200
           else      go to  exe-cph-lv2-sel-800.
       exe-cph-lv2-sel-160.
      *                  *---------------------------------------------*
      *                  * Se con giacenza presunta negativa           *
      *                  *---------------------------------------------*
           if        rf-miu-qta-prs       <    zero
                     go to  exe-cph-lv2-sel-200
           else      go to  exe-cph-lv2-sel-800.
       exe-cph-lv2-sel-200.
