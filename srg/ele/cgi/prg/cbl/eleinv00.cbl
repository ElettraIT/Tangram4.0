       err-msg-htm-000.
      *              *-------------------------------------------------*
      *              * Emissione messaggio                             *
      *              *-------------------------------------------------*
           move      "ET"                 to   h-ope                  .
           move      "div"                to   h-tag                  .
           move      "I"                  to   h-sub                  .
           move      "msg"                to   h-idx                  .
           move      "msg"                to   h-nam                  .
           move      w-exe-cla-msg        to   h-cla                  .
           call      "swd/mod/prg/obj/mhtml0"
                                         using h                      .
      *
           move      "ET"                 to   h-ope                  .
           move      "h1"                 to   h-tag                  .
           move      "V"                  to   h-sub                  .
           move      w-exe-err-msg        to   h-alf                  .
           call      "swd/mod/prg/obj/mhtml0"
                                         using h                      .
      *
           move      "ET"                 to   h-ope                  .
           move      "div"                to   h-tag                  .
           move      "C"                  to   h-sub                  .
           call      "swd/mod/prg/obj/mhtml0"
                                         using h                      .
      *              *-------------------------------------------------*
