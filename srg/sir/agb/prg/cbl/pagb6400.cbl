       crz-arc-orf-000.
      *              *-------------------------------------------------*
      *              * Apertura files                                  *
      *              *-------------------------------------------------*
           perform   crz-arc-orf-opn-000  thru crz-arc-orf-opn-999    .
       crz-arc-orf-050.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatori                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-rec-num-rig          .
           move      zero                 to   w-rec-num-orf          .
      *              *-------------------------------------------------*
      *              * Start su file [oft]                             *
      *              *                                                 *
      *              * N.B.: si potrebbe migliorare la start ...       *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      01                   to   rf-oft-cod-dpz         .
           move      "F"                  to   rf-oft-tip-arc         .
           move      rr-cod-fnt           to   rf-oft-cod-arc         .
           move      rr-dem-min           to   rf-oft-dat-doc         .
           move      zero                 to   rf-oft-num-doc         .
           move      zero                 to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a uscita                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-orf-900.
       crz-arc-orf-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [oft]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : A uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-orf-900.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-oft-cod-dpz       not  = 01         or
                     rf-oft-tip-arc       not  = "F"        or
                     rf-oft-cod-arc       not  = rr-cod-fnt or
                     rf-oft-dat-doc       >    rr-dem-max
                     go to crz-arc-orf-900.
      *              *-------------------------------------------------*
