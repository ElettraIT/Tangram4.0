      *                  *---------------------------------------------*
           if        rf-oft-num-doc       <    rr-nor-min or
                     rf-oft-num-doc       >    rr-nor-max
                     go to crz-arc-orf-100.
      *              *-------------------------------------------------*
      *              * Attivazione flag di testata da scrivere         *
      *              *-------------------------------------------------*
           move      "#"                  to   w-crz-arc-orf-ftd      .
      *              *-------------------------------------------------*
      *              * Attivazione flag di file sequenziale da aprire  *
      *              *-------------------------------------------------*
           move      "#"                  to   w-crz-arc-orf-ffa      .
      *              *-------------------------------------------------*
      *              * Start su file [ofr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-oft-num-prt       to   rf-ofr-num-prt         .
           move      zero                 to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : A riciclo su [oft]        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-orf-100.
       crz-arc-orf-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [ofr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : A riciclo su [oft]           *
