           if        rr-nor-max           not  = zero
                     go to reg-ric-sel-200.
           if        rr-nor-min           =    zero
                     move 99999999999     to   rr-nor-max
           else      move rr-nor-min      to   rr-nor-max             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Tipo esecuzione                                 *
      *              *-------------------------------------------------*
           if        rr-tip-exe           =    zero
                     move  02             to   rr-tip-exe             .
           if        rr-tip-exe           =    01
                     move  "T"            to   rr-tip-exe-flg
           else      move  "P"            to   rr-tip-exe-flg         .
       reg-ric-sel-999.
           exit.

