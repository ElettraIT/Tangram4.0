      *    *-----------------------------------------------------------*
       tst-alf-num-000.
           move      spaces               to   w-tst-alf-num-flg      .
           move      18                   to   w-tst-alf-num-ctr      .
       tst-alf-num-100.
           if        w-tst-alf-num-chr
                    (w-tst-alf-num-ctr)   not  = spaces
                     go to tst-alf-num-200.
           subtract  1                    from w-tst-alf-num-ctr      .
           if        w-tst-alf-num-ctr    =    zero
                     go to tst-alf-num-999
           else      go to tst-alf-num-100.
       tst-alf-num-200.
           if        w-tst-alf-num-chr
                    (w-tst-alf-num-ctr)   <    "0" or
                     w-tst-alf-num-chr
                    (w-tst-alf-num-ctr)   >    "9"
                     move  "#"            to   w-tst-alf-num-flg
                     go to tst-alf-num-999.
           subtract  1                    from w-tst-alf-num-ctr      .
           if        w-tst-alf-num-ctr    =    zero
                     go to tst-alf-num-999
           else      go to tst-alf-num-200.
       tst-alf-num-999.
           exit.

