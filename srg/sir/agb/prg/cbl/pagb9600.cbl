      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "sir/agb/fls/ioc/obj/iofhua"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hua                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-hua-ide-dat         .
           move      s-ute                to   rf-hua-ide-ute         .
           move      s-fas                to   rf-hua-ide-fas         .
           move      w-tes-cod-ute        to   rf-hua-cod-ute         .
           move      w-scr-rec-hua-prg    to   rf-hua-num-prg         .
           move      w-rig-cod-age (1)    to   rf-hua-cod-age         .
           move      w-rig-dat-val (1)    to   rf-hua-dat-val         .
           move      w-rig-alx-exp (1)    to   rf-hua-alx-exp         .
       cmp-rec-hua-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record righe [hua]                          *
      *    *-----------------------------------------------------------*
       del-rec-hua-000.
      *              *-------------------------------------------------*
      *              * Composizione chiave primaria                    *
      *              *-------------------------------------------------*
           move      w-tes-cod-ute        to   rf-hua-cod-ute         .
           move      w-rig-num-prg (2)    to   rf-hua-num-prg         .
           move      w-rig-cod-age (2)    to   rf-hua-cod-age         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "sir/agb/fls/ioc/obj/iofhua"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hua                 .
       del-rec-hua-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento del record [age]                            *
      *    *-----------------------------------------------------------*
       agg-rec-age-000.
      *              *-------------------------------------------------*
      *              * Lettura, con lock, del record [age]             *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "CODAGE    "         to   f-key                  .
           move      w-tes-cod-ute        to   rf-age-cod-age         .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to agg-rec-age-250.
       agg-rec-age-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     agg-rec-age-900.
       agg-rec-age-250.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
       agg-rec-age-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento del record                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice agente a cui fa capo             *
      *                      *-----------------------------------------*
           move      w-agg-rec-age-sup    to   rf-age-sup-age         .
       agg-rec-age-350.
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
       agg-rec-age-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-rec-age-999.
       agg-rec-age-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
