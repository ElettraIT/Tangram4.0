           move      "NL"                 to   f-cfr                  .
           move      w-tes-cod-ute        to   rf-hua-cod-ute         .
           move      zero                 to   rf-hua-cod-age         .
           move      zero                 to   rf-hua-num-prg         .
           move      "sir/agb/fls/ioc/obj/iofhua"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hua                 .
           if        f-sts                =    e-not-err
                     go to  rou-let-reg-200.
      *                      *-----------------------------------------*
      *                      * Se errore di start : ad inserimento     *
      *                      *-----------------------------------------*
           go to     rou-let-reg-920.
       rou-let-reg-200.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [hua]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "sir/agb/fls/ioc/obj/iofhua"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hua                 .
      *                      *-----------------------------------------*
      *                      * Se at end : a test su contatore         *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-900.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : a test su contatore   *
      *                  *---------------------------------------------*
           if        rf-hua-cod-ute       not  = w-tes-cod-ute
                     go to  rou-let-reg-900.
      *                  *---------------------------------------------*
      *                  * Incremento contatore record letti           *
      *                  *---------------------------------------------*
           add       1                    to   w-rou-let-reg-ctr      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riga                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori attuali                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [hua]                        *
      *                          *-------------------------------------*
           move      rf-hua-num-prg       to   w-rig-num-prg (1)      .
           move      rf-hua-cod-age       to   w-rig-cod-age (1)      .
           move      rf-hua-dat-val       to   w-rig-dat-val (1)      .
           move      rf-hua-ide-dat       to   w-rig-ide-dat (1)      .
           move      rf-hua-ide-ute       to   w-rig-ide-ute (1)      .
           move      rf-hua-ide-fas       to   w-rig-ide-fas (1)      .
           move      rf-hua-alx-exp       to   w-rig-alx-exp (1)      .
      *                          *-------------------------------------*
      *                          * Valori contenuti indirettamente in  *
      *                          * record [hua]                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Valori dipendenti dal codice    *
      *                              * super-agente                    *
      *                              *---------------------------------*
           move      w-rig-cod-age (1)    to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
           move      w-let-arc-age-nom    to   w-rig-cod-age-nom (1)  .
       rou-let-reg-600.
      *                      *-----------------------------------------*
      *                      * Valori precedenti                       *
      *                      *-----------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                      *-----------------------------------------*
      *                      * Put su catena movimenti [rig]           *
      *                      *-----------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-hua-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura [hua] successivo          *
      *                  *---------------------------------------------*
           go to     rou-let-reg-200.
       rou-let-reg-900.
      *              *-------------------------------------------------*
      *              * Test su contatore record letti                  *
      *              *-------------------------------------------------*
           if        w-rou-let-reg-ctr    =    zero
                     go to rou-let-reg-920
           else      go to rou-let-reg-910.
       rou-let-reg-910.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : Modifica                   *
      *              *-------------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
           go to     rou-let-reg-999.
       rou-let-reg-920.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : Inserimento                *
      *              *-------------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-999.
           exit.

