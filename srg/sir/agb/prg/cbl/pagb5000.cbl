      *    *===========================================================*
      *    * Preparazione parametri per selezione stampa               *
      *    *-----------------------------------------------------------*
       pre-prm-stp-000.
      *              *-------------------------------------------------*
      *              * Flags di tipo selezione                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sel      .
      *              *-------------------------------------------------*
      *              * Codice stampante                                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-stp      .
      *              *-------------------------------------------------*
      *              * Tipo di stampa                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sta      .
      *              *-------------------------------------------------*
      *              * Codice modulo                                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-mod      .
      *              *-------------------------------------------------*
      *              * Tipo modulo                                     *
      *              *   - L : Libero                                  *
      *              *   - T : Tipografico                             *
      *              *-------------------------------------------------*
           move      "L"                  to   w-cnt-stp-tip-mod      .
      *              *-------------------------------------------------*
      *              * Ampiezza linea di stampa in caratteri           *
      *              *-------------------------------------------------*
           move      132                  to   w-cnt-stp-amp-lin      .
      *              *-------------------------------------------------*
      *              * Top margin in linee                             *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-top-lin      .
      *              *-------------------------------------------------*
      *              * Numero linee di stampa minimo                   *
      *              *-------------------------------------------------*
           move      30                   to   w-cnt-stp-lin-min      .
      *              *-------------------------------------------------*
      *              * Bottom margin in linee                          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-bot-lin      .
      *              *-------------------------------------------------*
      *              * Ampiezza caratteri                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-amp-car      .
      *              *-------------------------------------------------*
      *              * Altezza interlinea                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-alt-int      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni future            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-esp-fut      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni speciali          *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-fnz-spc      .
       pre-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione fasi del batch serale                          *
      *    *-----------------------------------------------------------*
       exe-btc-ser-000.
      *              *-------------------------------------------------*
      *              * Memorizzazione richieste per selezione stampan- *
      *              * te                                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione record richieste               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Dati di identificazione record          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Informazioni generali da segreteria *
      *                          *-------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                          *-------------------------------------*
      *                          * Codice utente                       *
      *                          *-------------------------------------*
           move      s-ute                to   w-mem-ric-sel-ute      .
      *                          *-------------------------------------*
      *                          * Fase                                *
      *                          *-------------------------------------*
           move      "mpslct"             to   w-mem-ric-sel-fas      .
      *                          *-------------------------------------*
      *                          * Data                                *
      *                          *-------------------------------------*
           move      s-dat                to   w-mem-ric-sel-dat      .
      *                      *-----------------------------------------*
      *                      * Dati record                             *
      *                      *-----------------------------------------*
           move      spaces               to   r-fix                  .
      *                          *-------------------------------------*
      *                          * Codice stampante                    *
      *                          *-------------------------------------*
           move      p-sel-stp-sel        to   r-fix-cod-stp          .
      *                          *-------------------------------------*
      *                          * Tipo di stampa                      *
      *                          *-------------------------------------*
           move      p-sel-tds-sel        to   r-fix-tip-sta          .
      *                          *-------------------------------------*
      *                          * Codice modulo                       *
      *                          *-------------------------------------*
           move      p-sel-mod-sel        to   r-fix-cod-mod          .
      *                          *-------------------------------------*
      *                          * Ampiezza caratteri                  *
      *                          *-------------------------------------*
           move      p-sel-amc-sel        to   r-fix-amp-car          .
      *                          *-------------------------------------*
      *                          * Altezza interlinea                  *
      *                          *-------------------------------------*
           move      p-sel-ali-sel        to   r-fix-alt-int          .
      *                  *---------------------------------------------*
      *                  * Scrittura record richieste                  *
      *                  *---------------------------------------------*
           move      r-fix                to   w-mem-ric-sel-rrr      .
      *                  *---------------------------------------------*
      *                  * Subroutine di scrittura                     *
      *                  *---------------------------------------------*
           perform   mem-ric-sel-wrt-000  thru mem-ric-sel-wrt-999    .
       exe-btc-ser-050.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-tbf-ctr-001          .
       exe-btc-ser-100.
           add       1                    to   w-tbf-ctr-001          .
           if        w-tbf-ctr-001        >    w-tbf-num-ele
                     go to exe-btc-ser-500.
           if        rr-exe-fas
                    (w-tbf-ctr-001)       =    spaces
                     go to exe-btc-ser-100.
      *                  *---------------------------------------------*
      *                  * Visualizzazione segnale di fase in esecu-   *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           add       04
                     w-tbf-ctr-001      giving v-lin                  .
           move      61                   to   v-pos                  .
           move      "In esecuzione  "    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Cursore per stampa                          *
      *                  *---------------------------------------------*
           move      "CS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Put della variabile di I.P.C. globale con   *
      *                  * il nome fase                                *
      *                  *---------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "nom-fas"            to   s-var                  .
           move      "G"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      06                   to   s-car                  .
           move      w-tbf-nom-fas
                    (w-tbf-ctr-001)       to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       exe-btc-ser-200.
      *                  *---------------------------------------------*
      *                  * Esecuzione fase                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Richiamo del programma di esecuzione    *
      *                      *-----------------------------------------*
           move      w-tbf-pth-fas
                    (w-tbf-ctr-001)       to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
      *                      *-----------------------------------------*
      *                      * Cancellazione del programma di esecu-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           cancel    s-pat                                            .
       exe-btc-ser-300.
      *                  *---------------------------------------------*
      *                  * Visualizzazione segnale di fase eseguita    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           add       04
                     w-tbf-ctr-001      giving v-lin                  .
           move      61                   to   v-pos                  .
           move      "Eseguito       "    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     exe-btc-ser-100.
       exe-btc-ser-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-btc-ser-999.
       exe-btc-ser-999.
           exit.

