      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore                  *
      *                  *---------------------------------------------*
           move      01                   to   w-tbf-ctr-001          .
       acc-exe-fas-100.
      *              *-------------------------------------------------*
      *              * Test se indice da accettare                     *
      *              *-------------------------------------------------*
           if        w-tbf-pth-fas
                    (w-tbf-ctr-001)       =    spaces
                     go to acc-exe-fas-600.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       04
                     w-tbf-ctr-001      giving v-lin                  .
           move      58                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      rr-exe-fas
                    (w-tbf-ctr-001)       to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-exe-fas-999.
       acc-exe-fas-200.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-exe-fas-300.
      *                  *---------------------------------------------*
      *                  * Test se programma gia' attivo               *
      *                  *---------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      w-tbf-nom-fas
                    (w-tbf-ctr-001)       to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to acc-exe-fas-300.
      *                  *---------------------------------------------*
      *                  * Richiamo del programma                      *
      *                  *---------------------------------------------*
           move      w-tbf-pth-fas
                    (w-tbf-ctr-001)       to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     acc-exe-fas-100.
       acc-exe-fas-300.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   rr-exe-fas
                                              (w-tbf-ctr-001)         .
       acc-exe-fas-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : nessun controllo       *
      *                  *---------------------------------------------*
           if        rr-exe-fas
                    (w-tbf-ctr-001)       =    spaces
                     go to acc-exe-fas-600.
      *                  *---------------------------------------------*
      *                  * Controllo che esistano le richieste per il  *
      *                  * programma                                   *
      *                  *---------------------------------------------*
           if        w-tbf-snx-ric
                    (w-tbf-ctr-001)       =    "N"
                     go to acc-exe-fas-600.
      *                  *---------------------------------------------*
      *                  * Lettura richieste di selezione              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Informazioni generali da segreteria     *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-ute                to   w-mem-ric-sel-ute      .
           move      w-tbf-nom-fas
                    (w-tbf-ctr-001)       to   w-mem-ric-sel-fas      .
      *                      *-----------------------------------------*
      *                      * Subroutine di lettura                   *
      *                      *-----------------------------------------*
           perform   mem-ric-sel-rea-000  thru mem-ric-sel-rea-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-mem-ric-sel-flg    =    spaces
                     go to acc-exe-fas-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Richieste di selezione per il programma '"
                                delimited by   size
                     w-tbf-nom-fas
                    (w-tbf-ctr-001)
                                delimited by   size
                     "' non memorizzate"
                                delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     acc-exe-fas-100.
       acc-exe-fas-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione del carattere impostato   *
      *                  * tramutato in 'X'                            *
      *                  *---------------------------------------------*
           if        rr-exe-fas
                    (w-tbf-ctr-001)       =    spaces
                     go to acc-exe-fas-700.
           move      "X"                  to   rr-exe-fas
                                              (w-tbf-ctr-001)         .
           perform   vis-exe-fas-000      thru vis-exe-fas-999        .
       acc-exe-fas-700.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione dell'impostazione    *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-exe-fas-710
           else if   v-key                =    "DOWN"
                     go to acc-exe-fas-720
           else if   v-key                =    "DO  "
                     go to acc-exe-fas-800
           else      go to acc-exe-fas-720.
       acc-exe-fas-710.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-tbf-ctr-001        >    1
                     subtract 1           from w-tbf-ctr-001          .
           go to     acc-exe-fas-100.
       acc-exe-fas-720.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           if        w-tbf-ctr-001        <    w-tbf-num-ele
                     add   1              to   w-tbf-ctr-001
                     go to acc-exe-fas-100
           else      go to acc-exe-fas-999.
       acc-exe-fas-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-exe-fas-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-exe-fas-100.
       acc-exe-fas-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Esecuzione fase         *
      *    *-----------------------------------------------------------*
       vis-exe-fas-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       04
                     w-tbf-ctr-001      giving v-lin                  .
           move      58                   to   v-pos                  .
           move      rr-exe-fas
                    (w-tbf-ctr-001)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-exe-fas-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita con successo                             *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Uscita con errori                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
       reg-ric-sel-999.
           exit.

