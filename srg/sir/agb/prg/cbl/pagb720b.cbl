           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "MB"                 to   v-edm                  .
           move      "XX:XX"              to   v-msk                  .
           move      09                   to   v-lin                  .
           move      69                   to   v-pos                  .
