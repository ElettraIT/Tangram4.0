      *    *===========================================================*
      *    * Acquisito ordini                                          *
      *    *                                                           *
      *    * Operazioni preliminari                                    *
      *    *-----------------------------------------------------------*
       exe-exp-ord-pre-000.
      *              *-------------------------------------------------*
      *              * Determinazione della data corrispondente a 6    *
      *              * mesi prima per l'anno in corso                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data                                        *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      s-dat                to   w-exe-6mm-fai          .
           move      s-saa                to   w-exe-6mm-sai          .
           move      s-mes                to   w-exe-6mm-mei          .
           move      s-mes                to   w-exe-6mm-mea          .
      *
           if        w-exe-6mm-mei        >    5
                     subtract 5           from w-exe-6mm-mei
           else      add      7           to   w-exe-6mm-mei
                     subtract 1           from w-exe-6mm-sai          .
      *
           move      01                   to   s-gio                  .
           move      w-exe-6mm-mei        to   s-mes                  .
           move      w-exe-6mm-sai        to   s-saa                  .
      *                  *---------------------------------------------*
      *                  * Inizio anno in corso                        *
      *                  *---------------------------------------------*
           move      s-dat                to   w-exe-6mm-dai          .
      *                  *---------------------------------------------*
      *                  * Inizio anno precedente                      *
      *                  *---------------------------------------------*
           move      w-exe-6mm-dai        to   w-exe-6mm-dap          .
           subtract  10000                from w-exe-6mm-dap          .
      *                  *---------------------------------------------*
      *                  * Fine anno precedente (stesso mese attuale)  *
      *                  *---------------------------------------------*
           move      w-exe-6mm-mea        to   s-mes                  .
           move      w-exe-6mm-sai        to   s-saa                  .
           subtract  1                    from s-saa                  .
           move      31                   to   s-gio                  .
       exe-exp-ord-pre-008.
           move      s-dat                to   w-exe-6mm-fap          .
      *
           move      "CD"                 to   s-ope                  .
           move      w-exe-6mm-fap        to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to  exe-exp-ord-pre-008.
      *                  *---------------------------------------------*
      *                  * Anno in corso e precedente editati          *
      *                  *---------------------------------------------*
      *                     *------------------------------------------*
      *                     * Anno in corso                            *
      *                     *------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-exe-6mm-sai        to   v-num                  .
           add       1900                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-exe-6mm-eai          .
      *                     *------------------------------------------*
      *                     * Anno precedente                          *
      *                     *------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-exe-6mm-sai        to   v-num                  .
           add       1900                 to   v-num                  .
           subtract  1                    from v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-exe-6mm-eap          .
       exe-exp-ord-pre-010.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo                                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-ctr-001          .
       exe-exp-ord-pre-020.
           add       1                    to   w-exe-ctr-001          .
           if        w-exe-ctr-001        >    6
                     go to exe-exp-ord-pre-100.
      *                  *---------------------------------------------*
      *                  * Literal mesi                                *
      *                  *---------------------------------------------*
           move      w-exe-6mm-mei        to   w-exe-ctr-002          .
           add       w-exe-ctr-001        to   w-exe-ctr-002          .
           subtract  1                    from w-exe-ctr-002          .
           if        w-exe-ctr-002        >    12
                     subtract 6           from w-exe-ctr-002          .
      *
           move      "LM"                 to   s-ope                  .
           move      "A"                  to   s-tip                  .
           move      w-exe-ctr-002        to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *
           move      s-alf                to   w-exe-6mm-mes
                                              (w-exe-ctr-001)         .
      *                  *---------------------------------------------*
      *                  * Indice numerico mese                        *
      *                  *---------------------------------------------*
           move      w-exe-ctr-002        to   w-exe-6mm-ime
                                              (w-exe-ctr-001)         .
      *                  *---------------------------------------------*
      *                  * Normalizzazioni                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-6mm-vai
                                              (w-exe-ctr-001)         .
           move      zero                 to   w-exe-6mm-vap
                                              (w-exe-ctr-001)         .
           move      zero                 to   w-exe-6mm-qai
                                              (w-exe-ctr-001)         .
           move      zero                 to   w-exe-6mm-qap
                                              (w-exe-ctr-001)         .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     exe-exp-ord-pre-020.
       exe-exp-ord-pre-100.
      *              *-------------------------------------------------*
      *              * Preparazione del castelletto 10 ultimi giorni   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo                                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-ctr-001          .
           move      11                   to   w-exe-ctr-002          .
           move      w-exe-6mm-fai        to   w-exe-10g-dwk          .
       exe-exp-ord-pre-120.
           add       1                    to   w-exe-ctr-001          .
           subtract  1                    from w-exe-ctr-002          .
           if        w-exe-ctr-001        >    10
                     go to exe-exp-ord-pre-200.
           move      w-exe-10g-dwk        to   s-dat                  .
           subtract  1                    from s-gio                  .
       exe-exp-ord-pre-140.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to exe-exp-ord-pre-140.
      *                  *---------------------------------------------*
      *                  * Test se festivo                             *
      *                  *---------------------------------------------*
           move      "GS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-num                =    6    or
                     s-num                =    7
                     subtract 1           from s-gio
                     go to exe-exp-ord-pre-140.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione                             *
      *                  *---------------------------------------------*
           move      s-dat                to   w-exe-10g-idt
                                              (w-exe-ctr-002)         .
      *                  *---------------------------------------------*
      *                  * Normalizzazioni                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-10g-qai
                                              (w-exe-ctr-001)         .
           move      zero                 to   w-exe-10g-vai
                                              (w-exe-ctr-001)         .
      *                  *---------------------------------------------*
      *                  * Comodo per riciclo                          *
      *                  *---------------------------------------------*
           move      s-dat                to   w-exe-10g-dwk          .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     exe-exp-ord-pre-120.
       exe-exp-ord-pre-200.
      *              *-------------------------------------------------*
      *              * Preparazione del castelletto agenti             *
      *              *-------------------------------------------------*
           perform   exe-exp-ord-age-000  thru exe-exp-ord-age-999    .
       exe-exp-ord-pre-400.
      *              *-------------------------------------------------*
      *              * Preparazione del castelletto 30 ultimi giorni   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo                                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-ctr-001          .
       exe-exp-ord-pre-420.
           add       1                    to   w-exe-ctr-001          .
           if        w-exe-ctr-001        >    30
                     go to exe-exp-ord-pre-600.
           move      w-exe-6mm-fai        to   s-dat                  .
           subtract  w-exe-ctr-001        from s-gio                  .
       exe-exp-ord-pre-440.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to  exe-exp-ord-pre-440.
      *                  *---------------------------------------------*
      *                  * Data                                        *
      *                  *---------------------------------------------*
