           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      032                  to   p-pos                  .
           move      w-stp-val-rie-mrg    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-val-rie-150.
