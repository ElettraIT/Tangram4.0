                     go to stp-srt-inp-set-900
           else      go to stp-srt-inp-set-200.
       stp-srt-inp-set-140.
           move      zero                 to   w-wrk-ctr-001          .
       stp-srt-inp-set-142.
           add       1                    to   w-wrk-ctr-001          .
           if        w-wrk-ctr-001        >    36
                     go to stp-srt-inp-set-900.
           if        rr-cod-age-eco
                    (w-wrk-ctr-001)       =    zero
