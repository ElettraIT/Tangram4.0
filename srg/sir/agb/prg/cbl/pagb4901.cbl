           exit.

      *    *===========================================================*
      *    * Separatore per riepilogo                                  *
      *    *-----------------------------------------------------------*
       fin-sep-rie-000.
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "+----------------------------------+-----------+--
      -              "---------+-----------+-----------+-----------+----
      -              "-------+-----------+-----------+"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fin-sep-rie-999.
           exit.

      *    *===========================================================*
      *    * Fincatura per il riepilogo                                *
      *    *-----------------------------------------------------------*
       int-fin-rie-000.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Separatore per riepilogo                        *
      *              *-------------------------------------------------*
           perform   fin-sep-rie-000      thru fin-sep-rie-999        .
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-fin-rie-100.
      *              *-------------------------------------------------*
      *              * Fincatura                                       *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "|                                  |v.ord.mese |va
      -              "l.scaduto|v.evas.30gg|v.evas.60gg|v.evas.90gg|v.ev
      -              ".120 gg|v.ev.oltre |  Totale   |"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-fin-rie-300.
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      034                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      002                  to   p-pos                  .
           move      w-int-fin-rie-pmt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-fin-rie-600.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Separatore per riepilogo                        *
      *              *-------------------------------------------------*
           perform   fin-sep-rie-000      thru fin-sep-rie-999        .
       int-fin-rie-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-fin-rie-999.
       int-fin-rie-999.
           exit.

      *    *===========================================================*
      *    * Griglia vuota per il riepilogo                            *
      *    *-----------------------------------------------------------*
       gri-vuo-rie-000.
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "|                                  |           |  
      -              "         |           |           |           |    
      -              "       |           |           |"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       gri-vuo-rie-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [ocx]                         *
      *    *-----------------------------------------------------------*
       let-arc-ocx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ocx-flg      .
      *              *-------------------------------------------------*
      *              * Test se codici nulli                            *
      *              *-------------------------------------------------*
           if        w-let-arc-ocx-prt    =    zero   or
                     w-let-arc-ocx-prg    =    zero   or
                     w-let-arc-ocx-trc    =    zero
                     go to let-arc-ocx-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-let-arc-ocx-prt    to   rf-ocx-num-prt         .
           move      w-let-arc-ocx-prg    to   rf-ocx-num-prg         .
           move      w-let-arc-ocx-trc    to   rf-ocx-tip-rec         .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-ocx-400.
       let-arc-ocx-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-ocx-des-400       to   w-let-arc-ocx-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-ocx-999.
       let-arc-ocx-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-ocx-flg      .
           move      spaces               to   w-let-arc-ocx-des      .
           move      all   "."            to   w-let-arc-ocx-drg (1)  .
           go to     let-arc-ocx-999.
       let-arc-ocx-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ocx-des      .
       let-arc-ocx-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [dcp] e [pdx]                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcp/prg/cpy/ldcppdx0.lts"                   .

      *    *===========================================================*
      *    * Determinazione descrizione riga ordine                    *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [ocr] relativo alla riga ordine cliente a  *
      *    *      disposizione in rf-ocr                               *
      *    *                                                           *
      *    *    - Record di [dcc] relativo alla riga ordine cliente    *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-det-des-rig-des : Descrizione riga ordine          *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di estensione   *
      *              *-------------------------------------------------*
           if        rf-ocr-des-ext       =    0
                     go to det-des-rig-100
           else if   rf-ocr-des-ext       =    1
                     go to det-des-rig-200
           else if   rf-ocr-des-ext       =    2
                     go to det-des-rig-300.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione : bufferizzazione descri- *
      *              * zione contenuta nel record [ocr]                *
      *              *-------------------------------------------------*
           move      rf-ocr-des-rig       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-200.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [ocx]                    *
      *              *-------------------------------------------------*
           move      rf-ocr-num-prt       to   w-let-arc-ocx-prt      .
           move      rf-ocr-num-prg       to   w-let-arc-ocx-prg      .
           move      11                   to   w-let-arc-ocx-trc      .
           perform   let-arc-ocx-000      thru let-arc-ocx-999        .
           move      w-let-arc-ocx-des    to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rf-ocr-num-pro       to   w-let-dcp-pdx-cod      .
           move      "C"                  to   w-let-dcp-pdx-tar      .
           move      rf-ocr-cod-arc       to   w-let-dcp-pdx-arc      .
           move      rf-ocr-cod-lng       to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
           move      w-let-dcp-pdx-des    to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-aav = Ammontare da convertire, espres- *
      *    *                          so nell'altra valuta             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-avb = Ammontare convertito, espresso   *
      *    *                          nella valuta base                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta base ad altra valuta     *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-avb = Ammontare da convertire, espres- *
      *    *                          so nella valuta base             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-aav = Ammontare convertito, espresso   *
      *    *                          nell'altra valuta                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Determinazione quantita' evasa                            *
      *    *-----------------------------------------------------------*
       det-qta-eva-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      rf-ocr-qta-ord       to   d-qev-roc-qta-ord      .
           move      zero                 to   d-qev-roc-qta-gsp      .
           move      zero                 to   d-qev-roc-qta-ics      .
           move      d-qev-roc-qta-ord    to   w-qta-dev-qta-dev      .
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        rr-opz-stp-pfa       not  = spaces
                     go to det-qta-eva-900.
       det-qta-eva-100.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' evasa riga ordine      *
      *              *-------------------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           move      w-tot-dat-rif        to   d-qev-roc-dat-rif      .
           move      "pgm/orc/prg/obj/dqevroc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-roc
                                               rf-ocr                 .
       det-qta-eva-200.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' evasa riga ordine      *
      *              * senza tenere conto della quantita' in ordini    *
      *              * di spedizione                                   *
      *              *-------------------------------------------------*
           move      d-qev-roc-qta-ord    to   w-qta-dev-qta-dev      .
           subtract  d-qev-roc-qta-gsp    from w-qta-dev-qta-dev      .
           if        w-qta-dev-qta-dev    <    zero
                     move  zero           to   w-qta-dev-qta-dev      .
       det-qta-eva-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qta-eva-999.
       det-qta-eva-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo residuo nella valuta di fattura-   *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       det-imp-res-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-res-ipr      .
       det-imp-res-200.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "A"
                     move  rf-ocr-imp-rig to   w-det-imp-res-ipr
                     go to det-imp-res-900.
      *                  *---------------------------------------------*
      *                  * Se altro tipo riga                          *
      *                  *---------------------------------------------*
       det-imp-res-300.
      *                      *-----------------------------------------*
      *                      * Importo residuo                         *
      *                      *-----------------------------------------*
           if        rf-ocr-flg-puq       not  = "K"
                     go to det-imp-res-320.
           divide    1000                 into w-qta-dev-qta-dev
                                        giving w-qta-dev-qta-dew      .
           multiply  w-qta-dev-qta-dew    by   w-det-imp-res-prz
                                        giving w-det-imp-res-ipr      .
           go to     det-imp-res-330.
       det-imp-res-320.
           multiply  w-qta-dev-qta-dev    by   w-det-imp-res-prz
                                        giving w-det-imp-res-ipr      .
           go to     det-imp-res-330.
       det-imp-res-330.
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ocr-dec-prz       =    1
                     divide 10            into w-det-imp-res-ipr
           else if   rf-ocr-dec-prz       =    2
                     divide 100           into w-det-imp-res-ipr      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione nella valuta di   *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-ocr-sgl-vpp       =    rf-ocr-sgl-vpf
                     go to det-imp-res-900.
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per il prezzo                    *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpp       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpp       to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpp to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta per   *
      *                          * il prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-det-imp-res-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta base  *
      *                          * a valuta per fatturazione           *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                          *-------------------------------------*
      *                          * Bufferizzazione del risultato       *
      *                          *-------------------------------------*
           move      w-cvs-vlt-aav        to   w-det-imp-res-ipr      .
       det-imp-res-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-imp-res-999.
       det-imp-res-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo sottoposto a legame valutario       *
      *    *-----------------------------------------------------------*
       det-prz-lvl-000.
      *              *-------------------------------------------------*
      *              * Controllo esistenza parametri                   *
      *              *-------------------------------------------------*
           if        w-det-prz-lvl-svl    =    spaces or
                     w-det-prz-lvl-prz    =    zero   or
                     w-det-prz-lvl-ccr    =    zero   or
                     w-det-prz-lvl-cdc    =    zero
                     go to det-prz-lvl-999.
           if        w-det-prz-lvl-plm    =    zero and
                     w-det-prz-lvl-tlm    not  = spaces
                     go to det-prz-lvl-999.
           if       (w-det-prz-lvl-plm    not  = zero  ) and
                    (w-det-prz-lvl-tlm    not  = "T" and
                     w-det-prz-lvl-tlm    not  = "F" and
                     w-det-prz-lvl-tlm    not  = "M"   )
                     go to det-prz-lvl-999.
       det-prz-lvl-050.
      *              *-------------------------------------------------*
      *              * Determinazione valore scostamento rispetto al   *
      *              * cambio di riferimento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che esista o meno la   *
      *                  * percentuale di tolleranza                   *
      *                  *---------------------------------------------*
           if        w-det-prz-lvl-plm    =    zero
                     go to det-prz-lvl-052
           else      go to det-prz-lvl-054.
       det-prz-lvl-052.
      *                  *---------------------------------------------*
      *                  * Se percentuale di tolleranza a zero         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A calcolo nuovo prezzo con tipo di li-  *
      *                      * mitazione : Tolleranza                  *
      *                      *-----------------------------------------*
           go to     det-prz-lvl-120.
       det-prz-lvl-054.
      *                  *---------------------------------------------*
      *                  * Se percentuale di tolleranza esistente      *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-plm    by   w-det-prz-lvl-ccr
                                        giving w-det-prz-lvl-wps      .
           divide    100                  into w-det-prz-lvl-wps      .
           go to     det-prz-lvl-060.
       det-prz-lvl-060.
      *              *-------------------------------------------------*
      *              * Test se esiste uno scostamento in piu'          *
      *              *-------------------------------------------------*
           add       w-det-prz-lvl-wps    to   w-det-prz-lvl-ccr
                                        giving w-det-prz-lvl-wpc      .
           if        w-det-prz-lvl-cdc    >    w-det-prz-lvl-wpc
                     go to det-prz-lvl-100.
      *              *-------------------------------------------------*
      *              * Test se esiste uno scostamento in meno          *
      *              *-------------------------------------------------*
           subtract  w-det-prz-lvl-wps    from w-det-prz-lvl-ccr
                                        giving w-det-prz-lvl-wpc      .
           if        w-det-prz-lvl-cdc    <    w-det-prz-lvl-wpc
                     go to det-prz-lvl-100.
      *              *-------------------------------------------------*
      *              * Uscita con prezzo invariato                     *
      *              *-------------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo limitazione     *
      *              *-------------------------------------------------*
           if        w-det-prz-lvl-tlm    =    "T"
                     go to det-prz-lvl-120
           else if   w-det-prz-lvl-tlm    =    "F"
                     go to det-prz-lvl-140
           else if   w-det-prz-lvl-tlm    =    "M"
                     go to det-prz-lvl-160.
       det-prz-lvl-120.
      *              *-------------------------------------------------*
      *              * Tipo limitazione : Tolleranza                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo nuovo prezzo                        *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-prz    by   w-det-prz-lvl-cdc
                                        giving w-det-prz-lvl-wpz      .
           divide    w-det-prz-lvl-ccr    into w-det-prz-lvl-wpz
                                               rounded                .
           move      w-det-prz-lvl-wpz    to   w-det-prz-lvl-prz      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-140.
      *              *-------------------------------------------------*
      *              * Tipo limitazione : Franchigia                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo nuovo prezzo                        *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-prz    by   w-det-prz-lvl-cdc
                                        giving w-det-prz-lvl-wpz      .
           divide    w-det-prz-lvl-wpc    into w-det-prz-lvl-wpz
                                               rounded                .
           move      w-det-prz-lvl-wpz    to   w-det-prz-lvl-prz      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-160.
      *              *-------------------------------------------------*
      *              * Tipo limitazione : Tetto massimo                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo nuovo prezzo                        *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-prz    by   w-det-prz-lvl-wpc
                                        giving w-det-prz-lvl-wpz      .
           divide    w-det-prz-lvl-ccr    into w-det-prz-lvl-wpz
                                               rounded                .
           move      w-det-prz-lvl-wpz    to   w-det-prz-lvl-prz      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-999.
           exit.

      *    *===========================================================*
      *    * Determinazione costo di riferimento per il prodotto       *
      *    *-----------------------------------------------------------*
       det-cos-rif-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-cos-rif-svc      .
           move      zero                 to   w-det-cos-rif-dvc      .
           move      zero                 to   w-det-cos-rif-dec      .
           move      zero                 to   w-det-cos-rif-cdr      .
           move      spaces               to   w-det-cos-rif-svl      .
           move      zero                 to   w-det-cos-rif-crl      .
           move      zero                 to   w-det-cos-rif-pll      .
      *              *-------------------------------------------------*
      *              * Tentativo di determinazione con combinazione    *
      *              * fornitore/prodotto [aaf]                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [aaq]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaq-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a determinazione    *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Se fornitore preferenziale per il prodotto  *
      *                  * a zero : a determinazione costo medio con-  *
      *                  * tinuo                                       *
      *                  *---------------------------------------------*
           if        rf-aaq-dcf-pfz       =    zero
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaf]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRFNFM"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaf-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaf-num-pro         .
           move      rf-aaq-dcf-pfz       to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : : a determinazione  *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      01                   to   w-det-cos-rif-tde      .
           move      rf-aaf-sgl-vlt       to   w-det-cos-rif-svc      .
           move      rf-aaf-dec-vlt       to   w-det-cos-rif-dvc      .
           move      rf-aaf-dec-prz       to   w-det-cos-rif-dec      .
           move      rf-aaf-prz-pes (1)   to   w-det-cos-rif-cdr      .
           if        rf-aaf-lgv-vlt       not  = spaces
                     move  rf-aaf-lgv-vlt to   w-det-cos-rif-svl
                     move  rf-aaf-lgv-tdc to   w-det-cos-rif-tcl
                     move  rf-aaf-lgv-cdc to   w-det-cos-rif-crl
                     move  rf-aaf-lgv-pdt to   w-det-cos-rif-pll      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-500.
      *              *-------------------------------------------------*
      *              * Determinazione con costo medio continuo         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo modulo di magazzino                *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0005                 to   d-vun-mag-tip-val      .
           move      w-det-cos-rif-dtb    to   d-vun-mag-dat-val      .
           move      w-det-cos-rif-tpm    to   d-vun-mag-tip-mag      .
           move      w-det-cos-rif-cnm    to   d-vun-mag-num-mag      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      02                   to   w-det-cos-rif-tde      .
           move      c-sgl                to   w-det-cos-rif-svc      .
           move      c-dec                to   w-det-cos-rif-dvc      .
           move      02                   to   w-det-cos-rif-dec      .
           move      d-vun-mag-val-uni    to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-999.
           exit.

      *    *===========================================================*
      *    * Determinazione della voce 'ordinato mese' per il cliente  *
      *    *-----------------------------------------------------------*
       det-cli-mic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cli-mic-tot      .
           move      zero                 to   w-det-cli-mic-imp      .
           move      zero                 to   w-det-imp-res-ipr      .
      *              *-------------------------------------------------*
      *              * Preparazione delle date per la scansione        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cli-mic-din      .
           move      zero                 to   w-det-cli-mic-dfi      .
      *                  *---------------------------------------------*
      *                  * Data iniziale                               *
      *                  *---------------------------------------------*
           if        rr-emi-min           >    w-tot-dat-i01 and
                     rr-emi-min           <    w-tot-dat-f01
                     move  rr-emi-min     to   w-det-cli-mic-din
           else      move  w-tot-dat-i01  to   w-det-cli-mic-din      .
      *                  *---------------------------------------------*
      *                  * Data finale                                 *
      *                  *---------------------------------------------*
           if        rr-emi-max           >    w-tot-dat-i01 and
                     rr-emi-max           <    w-tot-dat-f01
                     move  rr-emi-max     to   w-det-cli-mic-dfi
           else      move  w-tot-dat-f01  to   w-det-cli-mic-dfi      .
       det-cli-mic-100.
      *              *-------------------------------------------------*
      *              * Start su testate ordini [oct]                   *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      rr-dpz-inu           to   rf-oct-cod-dpz         .
           move      "C"                  to   rf-oct-tip-arc         .
           move      w-det-cli-mic-cli    to   rf-oct-cod-arc         .
           move      w-det-cli-mic-din    to   rf-oct-dat-doc         .
           move      zero                 to   rf-oct-num-doc         .
           move      zero                 to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Test su esito della start                   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cli-mic-900.
       det-cli-mic-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [oct]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *              *-------------------------------------------------*
      *              * Test se 'at end'                                *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cli-mic-900.
       det-cli-mic-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-oct-cod-dpz       not  = rr-dpz-inu        or
                     rf-oct-tip-arc       not  = "C"               or
                     rf-oct-cod-arc       not  = w-det-cli-mic-cli or
                     rf-oct-dat-doc       >    w-det-cli-mic-dfi
                     go to det-cli-mic-900.
       det-cli-mic-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza del cliente       *
      *                  *---------------------------------------------*
           if        rf-oct-dpz-arc       not  = w-det-cli-mic-dpz
                     go to det-cli-mic-200.
       det-cli-mic-500.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione delle righe ordine per de-   *
      *              * terminare il totale ordine in valuta base       *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-oct-num-prt       to   rf-ocr-num-prt         .
           move      zero                 to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cli-mic-850.
       det-cli-mic-520.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ocr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cli-mic-850.
       det-cli-mic-530.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ocr-num-prt       not  = rf-oct-num-prt
                     go to det-cli-mic-850.
       det-cli-mic-540.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga in comodo ridefinito              *
      *                  *---------------------------------------------*
           move      rf-ocr-tip-rig       to   w-det-imp-res-wtr      .
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : riciclo                  *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "C"
                     go to det-cli-mic-520.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "A"
                     move  rf-ocr-imp-rig to   w-det-imp-res-ipr
                     go to det-cli-mic-545.
      *                  *---------------------------------------------*
      *                  * Se altro tipo riga                          *
      *                  *---------------------------------------------*
           if        rf-ocr-flg-puq       not  = "K"
                     go to det-cli-mic-542.
           divide    1000                 into rf-ocr-qta-ord
                                        giving w-qta-dev-qta-dew      .
           multiply  w-qta-dev-qta-dew    by   rf-ocr-prz-net
                                        giving w-det-imp-res-ipr      .
           go to     det-cli-mic-543.
       det-cli-mic-542.
           multiply  rf-ocr-qta-ord       by   rf-ocr-prz-net
                                        giving w-det-imp-res-ipr      .
           go to     det-cli-mic-543.
       det-cli-mic-543.
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ocr-dec-prz       =    1
                     divide 10            into w-det-imp-res-ipr
           else if   rf-ocr-dec-prz       =    2
                     divide 100           into w-det-imp-res-ipr      .
       det-cli-mic-545.
      *                  *---------------------------------------------*
      *                  * Determinazione importo residuo in valuta    *
      *                  * base                                        *
      *                  *---------------------------------------------*
           move      w-det-imp-res-ipr    to   w-det-cli-mic-imp      .
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        rf-ocr-sgl-vpf       =    c-sgl
                     go to det-cli-mic-550.
      *                      *-----------------------------------------*
      *                      * Applicazione del cambio alla data di    *
      *                      * riferimento                             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Determinazione importo residuo riga *
      *                          * in valuta base                      *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-det-imp-res-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale ordinato mese  *
      *                          * in valuta base                      *
      *                          *-------------------------------------*
           move      w-cvs-vlt-avb        to   w-det-cli-mic-imp      .
       det-cli-mic-550.
      *                  *---------------------------------------------*
      *                  * Cumulo del valore da cumulare               *
      *                  *---------------------------------------------*
           add       w-det-cli-mic-imp    to   w-det-cli-mic-tot      .
       det-cli-mic-800.
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     det-cli-mic-520.
       det-cli-mic-850.
      *              *-------------------------------------------------*
      *              * Riciclo a testata successiva                    *
      *              *-------------------------------------------------*
           go to     det-cli-mic-200.
       det-cli-mic-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-cli-mic-999.
       det-cli-mic-999.
           exit.

