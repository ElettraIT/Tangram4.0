           move      w-stp-val-rie-sca    to   w-stp-val-rie-cli      .
           add       w-stp-val-rie-fut    to   w-stp-val-rie-cli      .
           add       w-stp-val-rie-030    to   w-stp-val-rie-cli      .
           add       w-stp-val-rie-060    to   w-stp-val-rie-cli      .
           add       w-stp-val-rie-090    to   w-stp-val-rie-cli      .
           add       w-stp-val-rie-120    to   w-stp-val-rie-cli      .
      *                  *---------------------------------------------*
