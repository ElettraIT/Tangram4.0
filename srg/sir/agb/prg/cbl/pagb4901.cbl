           exit.

      *    *===========================================================*
      *    * Stampa valori per il riepilogo                            *
      *    *                                                           *
      *    * Subroutine di stampa di un totale                         *
      *    *-----------------------------------------------------------*
       stp-val-rie-tot-000.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
      *
           if        w-stp-val-rie-tot    >    9999999 or
                     w-stp-val-rie-tot    <   -9999999
                     move  10             to   p-car
           else      move  08             to   p-car                  .
      *
           move      c-dec                to   p-dec                  .
      *
           if        w-stp-val-rie-tot    <    zero
                     move  "S"            to   p-sgn
           else      move  spaces         to   p-sgn                  .
      *
           if        w-stp-val-rie-tot    >    9999999 or
                     w-stp-val-rie-tot    <   -9999999
                     move  "<B"           to   p-edm
           else      move  "<BG"          to   p-edm                  .
      *
           move      w-stp-val-rie-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Allineamento a destra                           *
      *              *-------------------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      p-edt                to   w-all-str-alf          .
           perform   all-str-adx-000      thru all-str-adx-999        .
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-val-rie-pos    to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-val-rie-tot-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-val-rie-tot-999.
       stp-val-rie-tot-999.
           exit.

