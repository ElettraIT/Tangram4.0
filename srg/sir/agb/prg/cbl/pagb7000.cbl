           else if   rf-ocr-dcn-prv       <    w-det-qta-orc-dpo
                     move  d-qev-roc-qta-dev
                                          to   w-det-qta-orc-qpo
                     move  rf-ocr-dcn-prv to   w-det-qta-orc-dpo
           else if   rf-ocr-dcn-prv       =    w-det-qta-orc-dpo
