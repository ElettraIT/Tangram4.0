      *              *-------------------------------------------------*
           if        w-ref-con-dtb-hst    =    spaces
                     move  "localhost "   to   w-ref-con-dtb-hst      .
           if        w-ref-con-dtb-usr    =    spaces
                     move  "root      "   to   w-ref-con-dtb-usr      .
           if        w-ref-con-dtb-dtb    =    spaces
                     move  "siri      "   to   w-ref-con-dtb-dtb      .
           if        w-ref-con-dtb-pwd    =    spaces
                     move  "loppio2   "   to   w-ref-con-dtb-pwd      .
           if        w-ref-con-dtb-are    =    spaces
                     move  "siri      "   to   w-ref-con-dtb-are      .
       pre-exe-pgm-prm-880.
      *              *-------------------------------------------------*
