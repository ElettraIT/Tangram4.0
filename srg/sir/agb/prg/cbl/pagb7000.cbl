           move      spaces               to   w-ref-con-dtb-usr      .
           move      spaces               to   w-ref-con-dtb-dtb      .
           move      spaces               to   w-ref-con-dtb-pwd      .
           move      spaces               to   w-ref-con-dtb-are      .
       pre-exe-pgm-prm-100.
      *              *-------------------------------------------------*
      *              * Apertura del file in input contenente il testo  *
      *              *-------------------------------------------------*
           move      "OI"                 to   g-ope                  .
           move      "testo"              to   g-nam                  .
           move      "/abd/sql/siriel/dtb.conf"
                                          to   g-pat                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
      *              *-------------------------------------------------*
      *              * Test se errori                                  *
      *              *-------------------------------------------------*
           if        g-sts                not  = e-not-err
                     go to pre-exe-pgm-prm-800.
       pre-exe-pgm-prm-200.
      *              *-------------------------------------------------*
      *              * Ciclo di lettura file                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura linea                               *
      *                  *---------------------------------------------*
           move      "GN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Test se at-end                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-end-fil
                     go to pre-exe-pgm-prm-800.
      *                  *---------------------------------------------*
      *                  * Incremento contatore righe                  *
      *                  *---------------------------------------------*
           add       1                    to   w-ref-con-dtb-ctr      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riga di testo               *
      *                  *---------------------------------------------*
           if        w-ref-con-dtb-ctr    =    1
                     move  g-rec          to   w-ref-con-dtb-hst
           else if   w-ref-con-dtb-ctr    =    2
                     move  g-rec          to   w-ref-con-dtb-usr
           else if   w-ref-con-dtb-ctr    =    3
                     move  g-rec          to   w-ref-con-dtb-dtb
           else if   w-ref-con-dtb-ctr    =    4
                     move  g-rec          to   w-ref-con-dtb-pwd
           else if   w-ref-con-dtb-ctr    =    5
                     move  g-rec          to   w-ref-con-dtb-are
           else      go to pre-exe-pgm-prm-800.
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura                           *
      *                  *---------------------------------------------*
           go to     pre-exe-pgm-prm-200.
       pre-exe-pgm-prm-800.
      *              *-------------------------------------------------*
