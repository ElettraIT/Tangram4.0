           add       w-stp-gdm-pro-vga    to   w-det-mrg-lrd-vsc      .
           subtract  w-tot-pro-bfo-vac    from w-det-mrg-lrd-vsc      .
           subtract  w-stp-gdm-pro-vgi    from w-det-mrg-lrd-vsc      .
           multiply  100                  by   w-det-mrg-lrd-vsc      .
           divide    w-tot-pro-bol-vac    into w-det-mrg-lrd-vsc
                                        giving w-det-mrg-lrd-pmr
                                               rounded                .
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "B"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      157                  to   p-pos                  .
           move      w-det-mrg-lrd-pmr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tot-pro-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-tot-pro-999.
       stp-tot-pro-999.
           exit.

