      *                      * Valuta per la fatturazione              *
      *                      *-----------------------------------------*
           move      rf-bir-sgl-vpf       to   srt-sgl-vpf            .
           move      rf-bir-dec-vpf       to   srt-dec-vpf            .
           move      rf-bir-tdc-vpf       to   srt-tdc-vpf            .
           move      rf-bir-cdc-vpf       to   srt-cdc-vpf            .
      *                      *-----------------------------------------*
      *                      * Valuta per il prezzo                    *
      *                      *-----------------------------------------*
           move      rf-bir-sgl-vpp       to   srt-sgl-vpp            .
           move      rf-bir-dec-vpp       to   srt-dec-vpp            .
           move      rf-bir-tdc-vpp       to   srt-tdc-vpp            .
           move      rf-bir-cdc-vpp       to   srt-cdc-vpp            .
      *                      *-----------------------------------------*
      *                      * Valuta per il legame valutario          *
      *                      *-----------------------------------------*
           move      rf-bir-sgl-vpl       to   srt-sgl-vpl            .
           move      rf-bir-dec-vpl       to   srt-dec-vpl            .
           move      rf-bir-tdc-vpl       to   srt-tdc-vpl            .
           move      rf-bir-prz-vpl       to   srt-prz-vpl            .
           move      rf-bir-cdc-vpl       to   srt-cdc-vpl            .
           move      rf-bir-ccr-vpl       to   srt-ccr-vpl            .
           move      rf-bir-plm-vpl       to   srt-plm-vpl            .
