      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-cnt-tit-ctr-tit    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-cnt-tit-pos-tit    to   p-pos                  .
           move      w-cnt-tit-des-tit    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-std-900.
      *              *-------------------------------------------------*
      *              * Test sul tipo di intestazione                   *
      *              *-------------------------------------------------*
           if        w-stp-int-pag-tip    =    "N"
                     go to int-pag-std-905
           else      go to int-pag-std-950.
       int-pag-std-905.
      *              *-------------------------------------------------*
      *              * Stampa eventuale dell'intestazione per agente o *
      *              * cliente                                         *
      *              *-------------------------------------------------*
           if        rr-tor-sta           =    03
                     go to int-pag-std-950
           else if   rr-tor-sta           =    01
                     go to int-pag-std-910
           else if   rr-tor-sta           =    02
                     go to int-pag-std-920
           else      go to int-pag-std-950.
       int-pag-std-910.
      *                  *---------------------------------------------*
      *                  * Se stampa per agente                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing codice agente                   *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-stp-int-age-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Concatenamento codice agente con nomi-  *
      *                      * nativo e prompt                         *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           if        rr-cod-age           =    zero   and
                     rr-cod-age-sns       not  = zero and
                     rr-age-sns           =    2
                     move  "AGENTI :"     to   w-all-str-cat (1)
           else      move  "AGENTE :"     to   w-all-str-cat (1)      .
           move      p-edt                to   w-all-str-cat (2)      .
           move      w-stp-int-age-nom    to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
