      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/iofzfi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zfi                 .
      *                      *-----------------------------------------*
      *                      * N.B. : viene by-passato il controllo    *
      *                      *        se si tratta di movimenti di     *
      *                      *        ripresa dati precedenti          *
      *                      *-----------------------------------------*
           if        rf-bit-cod-tmb       =    "DVRS " or
                     rf-bit-cod-tmb       =    "DVRSM"
                     go to stp-srt-inp-bol-600.
      *                      *-----------------------------------------*
      *                      * Documenti normali                       *
      *                      *-----------------------------------------*
           if        rf-bit-int-ftr       =    01
                     go to stp-srt-inp-bol-200.
      *                      *-----------------------------------------*
      *                      * Lettura record [zfi]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTMO"             to   f-key                  .
           move      rf-bit-tmo-ftr       to   rf-zfi-cod-tmo         .
           move      "pgm/fat/fls/ioc/obj/iofzfi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zfi                 .
      *                          *-------------------------------------*
      *                          * Se record [zfi] non trovato :       *
      *                          * selezione non superata              *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-bol-200.
       stp-srt-inp-bol-600.
      *              *-------------------------------------------------*
      *              * Composizione del record al Sort                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione del record al Sort          *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice agente in chiave                 *
      *                      *-----------------------------------------*
           move      zero                 to   srt-age-key            .
           if        rr-tor-sta           =    01
                     move  rf-bit-cod-age to   srt-age-key            .
           if        rr-tor-sta           =    01 and
                     rr-age-sns           =    2
                     move  1              to   srt-age-key            .
      *                      *-----------------------------------------*
      *                      * Codice cliente in chiave                *
      *                      *-----------------------------------------*
           move      zero                 to   srt-cli-key            .
