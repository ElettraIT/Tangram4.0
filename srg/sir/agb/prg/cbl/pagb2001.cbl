      *                  *---------------------------------------------*
           if        rr-tip-sta           =    02
                     go to stp-srt-inp-bfo-900.
       stp-srt-inp-bfo-100.
      *              *-------------------------------------------------*
      *              * Start su file [bfr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bfr-cod-dpz         .
           move      01                   to   rf-bfr-tip-mag         .
           move      rf-dcp-num-pro       to   rf-bfr-num-mag         .
           move      w-stp-srt-inp-iar    to   rf-bfr-dat-reg         .
           move      zero                 to   rf-bfr-num-prt         .
           move      zero                 to   rf-bfr-num-prg         .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-bfo-900.
       stp-srt-inp-bfo-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bfr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-bfo-900.
       stp-srt-inp-bfo-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-bfr-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-bfo-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo magazzino                      *
      *                  *---------------------------------------------*
           if        rf-bfr-tip-mag       not  = 01
                     go to stp-srt-inp-bfo-900.
      *                  *---------------------------------------------*
      *                  * Test su codice di magazzino                 *
      *                  *---------------------------------------------*
           if        rf-bfr-num-mag       not  = rf-dcp-num-pro
                     go to stp-srt-inp-bfo-900.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione                  *
      *                  *---------------------------------------------*
           if        rf-bfr-dat-reg       >    w-stp-srt-inp-rif
                     go to stp-srt-inp-bfo-900.
       stp-srt-inp-bfo-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo riga                          *
      *                  *---------------------------------------------*
           if        rf-bfr-tip-rig       not  = "P    "
                     go to stp-srt-inp-bfo-200.
