       stp-srt-inp-orf-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-ofr-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-orf-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo magazzino                      *
      *                  *---------------------------------------------*
           if        rf-ofr-tip-mag       not  = 01
                     go to stp-srt-inp-orf-900.
      *                  *---------------------------------------------*
      *                  * Test su codice di magazzino                 *
      *                  *---------------------------------------------*
           if        rf-ofr-num-mag       not  = rf-dcp-num-pro
                     go to stp-srt-inp-orf-900.
       stp-srt-inp-orf-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo riga                          *
      *                  *---------------------------------------------*
           if        rf-ofr-tip-rig       not  = "P    "
                     go to stp-srt-inp-orf-200.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-ofr-dat-doc       >    w-stp-srt-inp-rif
                     go to stp-srt-inp-orf-200.
       stp-srt-inp-orf-500.
      *              *-------------------------------------------------*
