      *              *-------------------------------------------------*
           if        w-stp-int-pag-flg    not  = spaces
                     go to int-pag-sta-050.
      *              *-------------------------------------------------*
      *              * Flag di prima intestazione effettuata           *
      *              *-------------------------------------------------*
           move      "#"                  to   w-stp-int-pag-flg      .
      *              *-------------------------------------------------*
      *              * Oltre                                           *
      *              *-------------------------------------------------*
           go to     int-pag-sta-100.
       int-pag-sta-050.
      *              *-------------------------------------------------*
      *              * Sottolineatura di fine pagina                   *
      *              *-------------------------------------------------*
           perform   stp-sot-fin-000      thru stp-sot-fin-999        .
       int-pag-sta-100.
      *              *-------------------------------------------------*
      *              * Preparazione parametri intestazione standard    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione del literal nel formato :      *
      *                  * mese e anno per esteso                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Mese                                    *
      *                      *-----------------------------------------*
           move      w-stp-srt-inp-rif    to   s-dat                  .
           if        s-mes                =    01
                     move  "Gennaio   "   to   w-stp-int-pag-mes
           else if   s-mes                =    02
                     move  "Febbraio  "   to   w-stp-int-pag-mes
           else if   s-mes                =    03
                     move  "Marzo     "   to   w-stp-int-pag-mes
           else if   s-mes                =    04
                     move  "Aprile    "   to   w-stp-int-pag-mes
           else if   s-mes                =    05
                     move  "Maggio    "   to   w-stp-int-pag-mes
           else if   s-mes                =    06
                     move  "Giugno    "   to   w-stp-int-pag-mes
           else if   s-mes                =    07
                     move  "Luglio    "   to   w-stp-int-pag-mes
           else if   s-mes                =    08
                     move  "Agosto    "   to   w-stp-int-pag-mes
           else if   s-mes                =    09
                     move  "Settembre "   to   w-stp-int-pag-mes
           else if   s-mes                =    10
                     move  "Ottobre   "   to   w-stp-int-pag-mes
           else if   s-mes                =    11
                     move  "Novembre  "   to   w-stp-int-pag-mes
           else if   s-mes                =    12
                     move  "Dicembre  "   to   w-stp-int-pag-mes
           else      move  spaces         to   w-stp-int-pag-mes      .
      *                      *-----------------------------------------*
      *                      * Anno                                    *
      *                      *-----------------------------------------*
           move      s-saa                to   w-stp-int-pag-ann      .
           add       1900                 to   w-stp-int-pag-ann      .
      *                  *---------------------------------------------*
      *                  * Editing anno                                *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-stp-int-pag-ann    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Preparazione titolo                         *
      *                  *---------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           if        rr-tip-sta           =    01
                     move  "STATISTICA DI VENDITA E ACQUISTO -"
                                          to   w-all-str-cat (1)
           else if   rr-tip-sta           =    02
                     move  "STATISTICA DI VENDITA -"
                                          to   w-all-str-cat (1)
           else if   rr-tip-sta           =    03
                     move  "STATISTICA DI ACQUISTO -"
                                          to   w-all-str-cat (1)
           else      move  "STATISTICA DI VENDITA E ACQUISTO -"
                                          to   w-all-str-cat (1)      .
           move      w-stp-int-pag-mes    to   w-all-str-cat (2)      .
           move      w-stp-int-pag-ann    to   w-all-str-cat (3)      .
           if        rr-snx-rie           =    01
                     move "(Riepilogo)"   to   w-all-str-cat (4)
           else      move spaces          to   w-all-str-cat (4)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
