           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       prn-cls-fls-800.
      *              *-------------------------------------------------*
      *              * Close modulo per determinare stato ordine cli-  *
      *              *-------------------------------------------------*
           move      "CL"                 to   d-qev-roc-tip-ope      .
           move      "pgm/orc/prg/obj/dqevroc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-roc
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-qev-roc-tip-ope      .
           move      "pgm/orc/prg/obj/dqevroc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-roc
                                               rf-ocr                 .
           if        d-qev-roc-exi-sts    not  = spaces
                     go to prn-cls-fls-820.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/orc/prg/obj/dqevroc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       prn-cls-fls-820.
      *              *-------------------------------------------------*
      *              * Close modulo di determinazione quantita' da e-  *
      *              * vadere riga ordine                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura modulo                             *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-qev-rof-tip-ope      .
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-rof
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-qev-rof-tip-ope      .
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-rof
                                               rf-ofr                 .
           if        d-qev-rof-exi-sts    not  = spaces
                     go to prn-cls-fls-840.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       prn-cls-fls-840.
      *              *-------------------------------------------------*
      *              * Close modulo di determinazione valore di magazz.*
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura modulo                             *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-vun-mag-tip-ope      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-vun-mag-tip-ope      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
           if        d-vun-mag-exi-sts    not  = spaces
                     go to prn-cls-fls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       prn-cls-fls-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine di preparazione date             *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-dat-000  thru stp-srt-inp-dat-999    .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Memorizzazione ora di inizio del sort           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Date and time da segreteria                 *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Estrazione ora e minuti da 'time'           *
      *                  *---------------------------------------------*
           move      s-ora                to   w-stp-srt-cor-isr      .
           multiply  100                  by   w-stp-srt-cor-isr      .
           add       s-min                to   w-stp-srt-cor-isr      .
      *              *-------------------------------------------------*
      *              * Start filtro di ordinamento e selezione per il  *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      rr-fso-dcp           to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se errore su Start : ad uscita              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read Next filtro di ordinamento e selezione per *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se At End : ad uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-210.
      *                  *---------------------------------------------*
      *                  * Accettazione del tasto per l'interruzione   *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           move      "AA"                 to   v-ope                  .
           move      21                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "[2] "               to   v-pfk (15)             .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           if        v-key                not  = spaces
                     go to stp-srt-inp-215
           else      go to stp-srt-inp-300.
       stp-srt-inp-215.
      *                  *---------------------------------------------*
      *                  * Se Pf2, cioe' se interruzione richiesta     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "*** Esecuzione elaborazione interrotta ! ***"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Sub-ciclo di scansione ordini di vendita        *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-orc-000  thru stp-srt-inp-orc-999    .
       stp-srt-inp-350.
      *              *-------------------------------------------------*
      *              * Sub-ciclo di scansione bolle di vendita         *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-bol-000  thru stp-srt-inp-bol-999    .
      *              *-------------------------------------------------*
      *              * Sub-ciclo di scansione bolle di vendita per i   *
      *              * resi su acquisto                                *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-rsa-000  thru stp-srt-inp-rsa-999    .
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Sub-ciclo di scansione ordini di acquisto       *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-orf-000  thru stp-srt-inp-orf-999    .
       stp-srt-inp-450.
      *              *-------------------------------------------------*
      *              * Sub-ciclo di scansione bolle di acquisto        *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-bfo-000  thru stp-srt-inp-bfo-999    .
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Sub-ciclo di scansione giacenze                 *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-gdm-000  thru stp-srt-inp-gdm-999    .
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Riciclo a prodotto successivo                   *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Memorizzazione ora di fine del sort             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Date and time da segreteria                 *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Estrazione ora e minuti da 'time'           *
      *                  *---------------------------------------------*
           move      s-ora                to   w-stp-srt-cor-fsr      .
           multiply  100                  by   w-stp-srt-cor-fsr      .
           add       s-min                to   w-stp-srt-cor-fsr      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per la determinazione delle date in base alla  *
      *    * data di riferimento                                       *
      *    *-----------------------------------------------------------*
       stp-srt-inp-dat-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione date                        *
      *                  *---------------------------------------------*
           move      rr-dat-rif           to   w-stp-srt-inp-rif      .
           move      zero                 to   w-stp-srt-inp-imr      .
           move      zero                 to   w-stp-srt-inp-fmr      .
           move      zero                 to   w-stp-srt-inp-iar      .
           move      zero                 to   w-stp-srt-inp-far      .
       stp-srt-inp-dat-100.
      *              *-------------------------------------------------*
      *              * Calcolo della data di inizio mese di riferimen- *
      *              * to                                              *
      *              *-------------------------------------------------*
           move      w-stp-srt-inp-rif    to   w-stp-srt-inp-imr      .
           move      w-stp-srt-inp-imr    to   s-dat                  .
           move      01                   to   s-gio                  .
           move      s-dat                to   w-stp-srt-inp-imr      .
       stp-srt-inp-dat-200.
      *              *-------------------------------------------------*
      *              * Calcolo della data di fine mese di riferimento  *
      *              *-------------------------------------------------*
           move      w-stp-srt-inp-rif    to   w-stp-srt-inp-fmr      .
      *                  *---------------------------------------------*
      *                  * Fine mese                                   *
      *                  *---------------------------------------------*
           move      w-stp-srt-inp-fmr    to   s-dat                  .
           move      31                   to   s-gio                  .
       stp-srt-inp-dat-210.
           move      s-dat                to   w-stp-srt-inp-fmr      .
      *                  *---------------------------------------------*
      *                  * Controllo della data                        *
      *                  *---------------------------------------------*
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Se la data e' corretta : oltre              *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to stp-srt-inp-dat-300.
           subtract  1                    from s-gio                  .
           go to     stp-srt-inp-dat-210.
       stp-srt-inp-dat-300.
      *              *-------------------------------------------------*
      *              * Calcolo della data di inizio anno di riferimen- *
      *              * to                                              *
      *              *-------------------------------------------------*
           move      w-stp-srt-inp-rif    to   w-stp-srt-inp-iar      .
           move      w-stp-srt-inp-iar    to   s-dat                  .
           move      01                   to   s-gio                  .
           move      01                   to   s-mes                  .
           move      s-dat                to   w-stp-srt-inp-iar      .
       stp-srt-inp-dat-400.
      *              *-------------------------------------------------*
      *              * Calcolo della data di fine anno di riferimento  *
      *              *-------------------------------------------------*
           move      w-stp-srt-inp-rif    to   w-stp-srt-inp-far      .
           move      w-stp-srt-inp-far    to   s-dat                  .
           move      31                   to   s-gio                  .
           move      12                   to   s-mes                  .
           move      s-dat                to   w-stp-srt-inp-far      .
       stp-srt-inp-dat-500.
      *              *-------------------------------------------------*
      *              * Se la data di riferimento cade nello stesso me- *
      *              * se della data attuale, ed e' inferiore ad essa, *
      *              * si pone la data attuale come data di riferimen- *
      *              * to, altrimenti si pone come data di riferimento *
      *              * la data di fine mese calcolata rispetto alla    *
      *              * data di riferimento                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scomposizione data di riferimento           *
      *                  *---------------------------------------------*
           move      w-stp-srt-inp-rif    to   s-dat                  .
           move      s-saa                to   w-stp-srt-inp-srf      .
           move      s-mes                to   w-stp-srt-inp-mrf      .
      *                  *---------------------------------------------*
      *                  * Scomposizione data attuale                  *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test sul mese                               *
      *                  *---------------------------------------------*
           if        w-stp-srt-inp-mrf    not  = s-mes
                     move  w-stp-srt-inp-fmr
                                          to   w-stp-srt-inp-rif
                     go to stp-srt-inp-dat-900.
      *                  *---------------------------------------------*
      *                  * Test sul secolo / anno                      *
      *                  *---------------------------------------------*
           if        w-stp-srt-inp-srf    not  = s-saa
                     move  w-stp-srt-inp-fmr
                                          to   w-stp-srt-inp-rif
                     go to stp-srt-inp-dat-900.
      *                  *---------------------------------------------*
      *                  * Data attuale in data di riferimento         *
      *                  *---------------------------------------------*
           move      s-dat                to   w-stp-srt-inp-rif      .
       stp-srt-inp-dat-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-dat-999.
       stp-srt-inp-dat-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Sub-ciclo di scansione ordini di vendita                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-orc-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo stampa                         *
      *                  *---------------------------------------------*
           if        rr-tip-sta           =    03
                     go to stp-srt-inp-orc-900.
       stp-srt-inp-orc-100.
      *              *-------------------------------------------------*
      *              * Start su file [ocr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-ocr-cod-dpz         .
           move      01                   to   rf-ocr-tip-mag         .
           move      rf-dcp-num-pro       to   rf-ocr-num-pro         .
           move      zero                 to   rf-ocr-dat-doc         .
           move      zero                 to   rf-ocr-num-doc         .
           move      zero                 to   rf-ocr-num-prt         .
           move      zero                 to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-orc-900.
       stp-srt-inp-orc-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ocr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-orc-900.
       stp-srt-inp-orc-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-orc-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo magazzino                      *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-mag       not  = 01
                     go to stp-srt-inp-orc-900.
      *                  *---------------------------------------------*
      *                  * Test su codice di magazzino                 *
      *                  *---------------------------------------------*
           if        rf-ocr-num-pro       not  = rf-dcp-num-pro
                     go to stp-srt-inp-orc-900.
       stp-srt-inp-orc-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo ordine                        *
      *                  *---------------------------------------------*
           if        rr-snx-frc           =    01
                     go to stp-srt-inp-orc-405.
           if        rf-ocr-tip-ord       =    "F"
                     go to stp-srt-inp-orc-200.
       stp-srt-inp-orc-405.
      *                  *---------------------------------------------*
      *                  * Test sul tipo riga                          *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-rig       not  = "P    "
                     go to stp-srt-inp-orc-200.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-ocr-dat-doc       >    w-stp-srt-inp-rif
                     go to stp-srt-inp-orc-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [oct]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Lettura testata ordine per rilevare il co-  *
      *                  * dice agente                                 *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ocr-num-prt       to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Test di selezione su codice agente          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione delle richieste  *
      *                      *-----------------------------------------*
           if        rr-cod-age           =    zero and
                     rr-cod-age-sns       =    zero
                     go to stp-srt-inp-orc-410
           else if   rr-cod-age           not  = zero
                     go to stp-srt-inp-orc-412
           else if   rr-cod-age-sns       not  = zero
                     go to stp-srt-inp-orc-414.
       stp-srt-inp-orc-410.
      *                      *-----------------------------------------*
      *                      * Richieste : tutti gli agenti            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Selezione superata                  *
      *                          *-------------------------------------*
           go to     stp-srt-inp-orc-450.
       stp-srt-inp-orc-412.
      *                      *-----------------------------------------*
      *                      * Richieste : un solo agente              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se selezione non superata           *
      *                          *-------------------------------------*
           if        rf-oct-cod-age       not  = rr-cod-age
                     go to stp-srt-inp-orc-200.
      *                          *-------------------------------------*
      *                          * Selezione superata                  *
      *                          *-------------------------------------*
           go to     stp-srt-inp-orc-450.
       stp-srt-inp-orc-414.
      *                      *-----------------------------------------*
      *                      * Richieste : una selezione di agenti     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ciclo di scansione                  *
      *                          *-------------------------------------*
           move      zero                 to   w-stp-srt-inp-csa      .
       stp-srt-inp-orc-418.
           add       1                    to   w-stp-srt-inp-csa      .
           if        w-stp-srt-inp-csa    >    rr-cod-age-els
                     go to stp-srt-inp-orc-200.
           if        rf-oct-cod-age       =    rr-cod-age-eco
                                              (w-stp-srt-inp-csa)
                     go to stp-srt-inp-orc-450.
           go to     stp-srt-inp-orc-418.
       stp-srt-inp-orc-450.
      *                  *---------------------------------------------*
      *                  * Test di selezione su codice cliente da      *
      *                  * escludere                                   *
      *                  *---------------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-orc-500.
           if        rf-oct-cod-arc       =    rr-cod-cli
                     go to stp-srt-inp-orc-200.
       stp-srt-inp-orc-500.
      *                  *---------------------------------------------*
      *                  * Determinazione della quantita' spedita per  *
      *                  * la riga ordine in corso di trattamento      *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           move      w-stp-srt-inp-rif    to   d-qev-roc-dat-rif      .
           move      "pgm/orc/prg/obj/dqevroc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-roc
                                               rf-ocr                 .
       stp-srt-inp-orc-600.
      *              *-------------------------------------------------*
      *              * Composizione del record al Sort                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione del record al Sort          *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice agente in chiave                 *
      *                      *-----------------------------------------*
           move      zero                 to   srt-age-key            .
           if        rr-tor-sta           =    01
                     move  rf-oct-cod-age to   srt-age-key            .
           if        rr-tor-sta           =    01 and
                     rr-age-sns           =    2
                     move  1              to   srt-age-key            .
      *                      *-----------------------------------------*
      *                      * Codice cliente in chiave                *
      *                      *-----------------------------------------*
           move      zero                 to   srt-cli-key            .
           if        rr-tor-sta           =    02
                     move  rf-ocr-cod-arc to   srt-cli-key            .
      *                      *-----------------------------------------*
      *                      * Codice classe prodotto in chiave        *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cla-key            .
      *                      *-----------------------------------------*
      *                      * Codice gruppo prodotto in chiave        *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-gru-key            .
      *                      *-----------------------------------------*
      *                      * Codice sottogruppo prodotto in chiave   *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-sgr-key            .
      *                      *-----------------------------------------*
      *                      * Descrizione prodotto in chiave          *
      *                      *-----------------------------------------*
           move      rf-dcp-des-key       to   srt-des-key            .
      *                      *-----------------------------------------*
      *                      * Codice numerico prodotto in chiave      *
      *                      *-----------------------------------------*
           move      rf-dcp-num-pro       to   srt-num-key            .
      *                      *-----------------------------------------*
      *                      * Tipo record trattato                    *
      *                      *-----------------------------------------*
           move      4                    to   srt-tip-rec            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di Sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico del prodotto        *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   srt-alf-pro            .
      *                      *-----------------------------------------*
      *                      * Descrizione del prodotto                *
      *                      *-----------------------------------------*
           move      rf-dcp-des-pro       to   srt-des-pro            .
      *                      *-----------------------------------------*
      *                      * Codice classe del prodotto              *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cla-key            .
      *                      *-----------------------------------------*
      *                      * Codice gruppo del prodotto              *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-gru-key            .
      *                      *-----------------------------------------*
      *                      * Codice sottogruppo del prodotto         *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-sgr-key            .
      *                      *-----------------------------------------*
      *                      * Data documento relativa al tipo record  *
      *                      *-----------------------------------------*
           move      rf-ocr-dat-doc       to   srt-dat-rec            .
      *                      *-----------------------------------------*
      *                      * Quantita' relativa al tipo record       *
      *                      *-----------------------------------------*
           move      rf-ocr-qta-ord       to   srt-qta-rec            .
      *                      *-----------------------------------------*
      *                      * Quantita' da evadere                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se la riga si considera evasa  *
      *                          * comunque                            *
      *                          *-------------------------------------*
           if        rf-ocr-sdr-ccs       not  = spaces
                     move  zero           to   srt-qta-dev
                     go to stp-srt-inp-orc-620.
      *                          *-------------------------------------*
      *                          * Quantita' in ordine meno la quanti- *
      *                          * ta' gia spedita                     *
      *                          *-------------------------------------*
           move      d-qev-roc-qta-ord    to   srt-qta-dev            .
           subtract  d-qev-roc-qta-gsp    from srt-qta-dev            .
      *                          *-------------------------------------*
      *                          * In caso di super-evasione si pone a *
      *                          * zero la quantita' da evadere        *
      *                          *-------------------------------------*
           if        srt-qta-dev          <    zero
                     move  zero           to   srt-qta-dev            .
       stp-srt-inp-orc-620.
      *                      *-----------------------------------------*
      *                      * Si/no trasformazione unita' di misura   *
      *                      *-----------------------------------------*
           if        rf-ocr-flg-puq       =    "K"
                     move  "P"            to   srt-snx-tum
           else      move  spaces         to   srt-snx-tum            .
      *                      *-----------------------------------------*
      *                      * Decimali prezzo relativi al tipo record *
      *                      *-----------------------------------------*
           move      rf-ocr-dec-prz       to   srt-dpr-rec            .
      *                      *-----------------------------------------*
      *                      * Prezzo unitario relativo al tipo record *
      *                      * espresso in valuta                      *
      *                      *-----------------------------------------*
           move      rf-ocr-prz-net       to   srt-pun-rec            .
      *                      *-----------------------------------------*
      *                      * Valuta per la fatturazione              *
      *                      *-----------------------------------------*
           move      rf-ocr-sgl-vpf       to   srt-sgl-vpf            .
           move      rf-ocr-dec-vpf       to   srt-dec-vpf            .
           move      rf-ocr-tdc-vpf       to   srt-tdc-vpf            .
           move      rf-ocr-cdc-vpf       to   srt-cdc-vpf            .
      *                      *-----------------------------------------*
      *                      * Valuta per il prezzo                    *
      *                      *-----------------------------------------*
           move      rf-ocr-sgl-vpp       to   srt-sgl-vpp            .
           move      rf-ocr-dec-vpp       to   srt-dec-vpp            .
           move      rf-ocr-tdc-vpp       to   srt-tdc-vpp            .
           move      rf-ocr-cdc-vpp       to   srt-cdc-vpp            .
      *                      *-----------------------------------------*
      *                      * Valuta per il legame valutario          *
      *                      *-----------------------------------------*
           move      rf-ocr-sgl-vpl       to   srt-sgl-vpl            .
           move      rf-ocr-dec-vpl       to   srt-dec-vpl            .
           move      rf-ocr-tdc-vpl       to   srt-tdc-vpl            .
           move      rf-ocr-prz-vpl       to   srt-prz-vpl            .
           move      rf-ocr-cdc-vpl       to   srt-cdc-vpl            .
           move      rf-ocr-ccr-vpl       to   srt-ccr-vpl            .
           move      rf-ocr-plm-vpl       to   srt-plm-vpl            .
           move      rf-ocr-tlm-vpl       to   srt-tlm-vpl            .
           move      rf-ocr-map-vpl       to   srt-map-vpl            .
      *                      *-----------------------------------------*
      *                      * Dati per la giacenza                    *
      *                      *-----------------------------------------*
           move      zero                 to   srt-pro-gia            .
           move      zero                 to   srt-pro-vgi            .
           move      zero                 to   srt-pro-gat            .
           move      zero                 to   srt-pro-vga            .
      *                      *-----------------------------------------*
      *                      * Coordinate riga documento               *
      *                      *-----------------------------------------*
           move      rf-ocr-num-prt       to   srt-num-prt            .
           move      rf-ocr-num-prg       to   srt-num-prg            .
       stp-srt-inp-orc-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-orc-850.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-orc-200.
       stp-srt-inp-orc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-orc-999.
       stp-srt-inp-orc-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Sub-ciclo di scansione bolle di vendita                   *
      *    *-----------------------------------------------------------*
       stp-srt-inp-bol-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo stampa                         *
      *                  *---------------------------------------------*
           if        rr-tip-sta           =    03
                     go to stp-srt-inp-bol-900.
       stp-srt-inp-bol-100.
      *              *-------------------------------------------------*
      *              * Start su file [bir]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bir-cod-dpz         .
           move      01                   to   rf-bir-tip-mag         .
           move      rf-dcp-num-pro       to   rf-bir-num-pro         .
           move      w-stp-srt-inp-iar    to   rf-bir-dat-doc         .
           move      zero                 to   rf-bir-num-doc         .
           move      zero                 to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-bol-900.
       stp-srt-inp-bol-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bir]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-bol-900.
       stp-srt-inp-bol-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-bir-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-bol-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo magazzino                      *
      *                  *---------------------------------------------*
           if        rf-bir-tip-mag       not  = 01
                     go to stp-srt-inp-bol-900.
      *                  *---------------------------------------------*
      *                  * Test su codice di magazzino                 *
      *                  *---------------------------------------------*
           if        rf-bir-num-pro       not  = rf-dcp-num-pro
                     go to stp-srt-inp-bol-900.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-bir-dat-doc       >    w-stp-srt-inp-rif
                     go to stp-srt-inp-bol-900.
       stp-srt-inp-bol-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo riga                          *
      *                  *---------------------------------------------*
           if        rf-bir-tip-rig       not  = "P    "
                     go to stp-srt-inp-bol-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [bit]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Lettura testata ordine per rilevare il co-  *
      *                  * dice agente                                 *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bir-num-prt       to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Test di selezione su codice agente          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione delle richieste  *
      *                      *-----------------------------------------*
           if        rr-cod-age           =    zero and
                     rr-cod-age-sns       =    zero
                     go to stp-srt-inp-bol-410
           else if   rr-cod-age           not  = zero
                     go to stp-srt-inp-bol-412
           else if   rr-cod-age-sns       not  = zero
                     go to stp-srt-inp-bol-414.
       stp-srt-inp-bol-410.
      *                      *-----------------------------------------*
      *                      * Richieste : tutti gli agenti            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Selezione superata                  *
      *                          *-------------------------------------*
           go to     stp-srt-inp-bol-450.
       stp-srt-inp-bol-412.
      *                      *-----------------------------------------*
      *                      * Richieste : un solo agente              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se selezione non superata           *
      *                          *-------------------------------------*
           if        rf-bit-cod-age       not  = rr-cod-age
                     go to stp-srt-inp-bol-200.
      *                          *-------------------------------------*
      *                          * Selezione superata                  *
      *                          *-------------------------------------*
           go to     stp-srt-inp-bol-450.
       stp-srt-inp-bol-414.
      *                      *-----------------------------------------*
      *                      * Richieste : una selezione di agenti     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ciclo di scansione                  *
      *                          *-------------------------------------*
           move      zero                 to   w-stp-srt-inp-csa      .
       stp-srt-inp-bol-418.
           add       1                    to   w-stp-srt-inp-csa      .
           if        w-stp-srt-inp-csa    >    rr-cod-age-els
                     go to stp-srt-inp-bol-200.
           if        rf-bit-cod-age       =    rr-cod-age-eco
                                              (w-stp-srt-inp-csa)
                     go to stp-srt-inp-bol-450.
           go to     stp-srt-inp-bol-418.
       stp-srt-inp-bol-450.
      *                  *---------------------------------------------*
      *                  * Test di selezione su codice cliente da      *
      *                  * escludere                                   *
      *                  *---------------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-bol-500.
           if        rf-bit-cod-arc       =    rr-cod-cli
                     go to stp-srt-inp-bol-200.
       stp-srt-inp-bol-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
