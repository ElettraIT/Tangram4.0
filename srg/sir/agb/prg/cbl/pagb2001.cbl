                                          to   w-stp-srt-inp-pvb
                     go to stp-srt-inp-pvb-900.
       stp-srt-inp-pvb-200.
      *              *-------------------------------------------------*
      *              * Determinazione coefficiente di cambio alla data *
      *              * di riferimento per la valuta di fatturazione    *
      *              *-------------------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-stp-srt-inp-sgl    to   w-coe-cmb-vlt-sdv      .
           move      w-stp-srt-inp-tdc    to   w-coe-cmb-vlt-tdc      .
           move      w-stp-srt-inp-rif    to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *              *-------------------------------------------------*
      *              * Se esito determinazione negativo si considera   *
      *              * il coefficiente rilevato alla data ordine       *
      *              *-------------------------------------------------*
