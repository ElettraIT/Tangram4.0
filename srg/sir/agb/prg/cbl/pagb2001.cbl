      *    *===========================================================*
      *    * Subroutine di stampa quantita' nel formato : '-999.999'   *
      *    *-----------------------------------------------------------*
       stp-num-qta-000.
      *              *-------------------------------------------------*
      *              * Test sul valore da stampare                     *
      *              *-------------------------------------------------*
           if        w-stp-num-qta-qta    =    zero
                     go to stp-num-qta-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione del valore entrato              *
      *              *-------------------------------------------------*
           move      w-stp-num-qta-qta    to   w-stp-num-qta-buf      .
      *              *-------------------------------------------------*
      *              * Divisione                                       *
      *              *-------------------------------------------------*
           divide    w-stp-num-qta-div    into w-stp-num-qta-buf
                                        giving w-stp-num-qta-qta
                                               rounded                .
      *              *-------------------------------------------------*
      *              * Test se il valore sottoposto a divisore '1000'  *
      *              * risulta > o < di 1000                           *
      *              *-------------------------------------------------*
           if        w-stp-num-qta-div    not  = 1000
                     go to stp-num-qta-100.
           if        w-stp-num-qta-buf    not  < 1000
                     go to stp-num-qta-100.
           if        w-stp-num-qta-buf    <    -999
                     go to stp-num-qta-100.
      *                  *---------------------------------------------*
      *                  * Stampa valore non sottoposto a divisore     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      "B"                  to   p-edm                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-num-qta-pos    to   p-pos                  .
           add       4                    to   p-pos                  .
           move      w-stp-num-qta-buf    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa segnale                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-num-qta-pos    to   p-pos                  .
           move      "="                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-num-qta-900.
       stp-num-qta-100.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        w-stp-num-qta-qta    >    999999 or
                     w-stp-num-qta-qta    <   -999999
                     move  07             to   p-car
                     move  "B"            to   p-edm
           else      move  06             to   p-car
                     move  "BG"           to   p-edm                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-num-qta-pos    to   p-pos                  .
           move      w-stp-num-qta-qta    to   p-num                  .
       stp-num-qta-200.
      *              *-------------------------------------------------*
      *              * Se il valore esubera il massimo di 9999999 in   *
      *              * positivo o in negativo si divide per mille e si *
      *              * segnala                                         *
      *              *-------------------------------------------------*
           if        p-num                >    9999999 or
                     p-num                <   -9999999
                     divide  1000         into p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-num-qta-300.
      *              *-------------------------------------------------*
