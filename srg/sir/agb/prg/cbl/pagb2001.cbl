           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-num-qta-pos    to   p-pos                  .
           move      "*"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-num-qta-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-num-qta-999.
       stp-num-qta-999.
           exit.

