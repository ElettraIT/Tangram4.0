      *              *-------------------------------------------------*
           move      "DT"                 to   d-qev-rof-tip-ope      .
           move      w-stp-srt-inp-rif    to   d-qev-rof-dat-rif      .
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-rof
                                               rf-ofr                 .
       stp-srt-inp-orf-600.
      *              *-------------------------------------------------*
      *              * Composizione del record al Sort                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione del record al Sort          *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice agente in chiave                 *
      *                      *-----------------------------------------*
           move      zero                 to   srt-age-key            .
      *                      *-----------------------------------------*
      *                      * Codice cliente in chiave                *
      *                      *-----------------------------------------*
           move      zero                 to   srt-cli-key            .
      *                      *-----------------------------------------*
      *                      * Codice classe prodotto in chiave        *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cla-key            .
      *                      *-----------------------------------------*
      *                      * Codice gruppo prodotto in chiave        *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-gru-key            .
      *                      *-----------------------------------------*
      *                      * Codice sottogruppo prodotto in chiave   *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-sgr-key            .
      *                      *-----------------------------------------*
      *                      * Descrizione prodotto in chiave          *
      *                      *-----------------------------------------*
           move      rf-dcp-des-key       to   srt-des-key            .
      *                      *-----------------------------------------*
      *                      * Codice numerico prodotto in chiave      *
      *                      *-----------------------------------------*
           move      rf-dcp-num-pro       to   srt-num-key            .
      *                      *-----------------------------------------*
      *                      * Tipo record trattato                    *
      *                      *-----------------------------------------*
           move      5                    to   srt-tip-rec            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di Sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico del prodotto        *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   srt-alf-pro            .
      *                      *-----------------------------------------*
      *                      * Descrizione del prodotto                *
      *                      *-----------------------------------------*
           move      rf-dcp-des-pro       to   srt-des-pro            .
      *                      *-----------------------------------------*
      *                      * Codice classe del prodotto              *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cla-key            .
      *                      *-----------------------------------------*
      *                      * Codice gruppo del prodotto              *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-gru-key            .
      *                      *-----------------------------------------*
      *                      * Codice sottogruppo del prodotto         *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-sgr-key            .
