           move      "MAGDAT    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bir-cod-dpz         .
           move      01                   to   rf-bir-tip-mag         .
           move      rf-dcp-num-pro       to   rf-bir-num-pro         .
           move      w-stp-srt-inp-iar    to   rf-bir-dat-doc         .
           move      zero                 to   rf-bir-num-doc         .
           move      zero                 to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-rsa-900.
       stp-srt-inp-rsa-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bir]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-rsa-900.
       stp-srt-inp-rsa-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-bir-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-rsa-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo magazzino                      *
      *                  *---------------------------------------------*
           if        rf-bir-tip-mag       not  = 01
                     go to stp-srt-inp-rsa-900.
      *                  *---------------------------------------------*
      *                  * Test su codice di magazzino                 *
      *                  *---------------------------------------------*
           if        rf-bir-num-pro       not  = rf-dcp-num-pro
                     go to stp-srt-inp-rsa-900.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-bir-dat-doc       >    w-stp-srt-inp-rif
                     go to stp-srt-inp-rsa-900.
       stp-srt-inp-rsa-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo riga                          *
      *                  *---------------------------------------------*
           if        rf-bir-tip-rig       not  = "P    "
                     go to stp-srt-inp-rsa-200.
       stp-srt-inp-rsa-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
           if        rf-bir-cod-tmb       not  = "BRSA "
                     go to stp-srt-inp-rsa-200.
       stp-srt-inp-rsa-600.
      *              *-------------------------------------------------*
      *              * Composizione del record al Sort                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione del record al Sort          *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice agente in chiave                 *
      *                      *-----------------------------------------*
           move      zero                 to   srt-age-key            .
      *                      *-----------------------------------------*
      *                      * Codice cliente in chiave                *
      *                      *-----------------------------------------*
           move      zero                 to   srt-cli-key            .
      *                      *-----------------------------------------*
      *                      * Codice classe prodotto in chiave        *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cla-key            .
      *                      *-----------------------------------------*
      *                      * Codice gruppo prodotto in chiave        *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-gru-key            .
      *                      *-----------------------------------------*
      *                      * Codice sottogruppo prodotto in chiave   *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-sgr-key            .
      *                      *-----------------------------------------*
      *                      * Descrizione prodotto in chiave          *
      *                      *-----------------------------------------*
           move      rf-dcp-des-key       to   srt-des-key            .
      *                      *-----------------------------------------*
      *                      * Codice numerico prodotto in chiave      *
      *                      *-----------------------------------------*
           move      rf-dcp-num-pro       to   srt-num-key            .
      *                      *-----------------------------------------*
      *                      * Tipo record trattato                    *
      *                      *-----------------------------------------*
           move      6                    to   srt-tip-rec            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di Sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico del prodotto        *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   srt-alf-pro            .
      *                      *-----------------------------------------*
      *                      * Descrizione del prodotto                *
      *                      *-----------------------------------------*
           move      rf-dcp-des-pro       to   srt-des-pro            .
      *                      *-----------------------------------------*
      *                      * Codice classe del prodotto              *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cla-key            .
      *                      *-----------------------------------------*
      *                      * Codice gruppo del prodotto              *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-gru-key            .
      *                      *-----------------------------------------*
      *                      * Codice sottogruppo del prodotto         *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-sgr-key            .
      *                      *-----------------------------------------*
      *                      * Data documento relativa al tipo record  *
      *                      *-----------------------------------------*
           move      rf-bir-dat-doc       to   srt-dat-rec            .
      *                      *-----------------------------------------*
      *                      * Quantita' relativa al tipo record       *
      *                      *-----------------------------------------*
           move      rf-bir-qta-ven       to   srt-qta-rec            .
      *                      *-----------------------------------------*
      *                      * Aggiustamento del segno                 *
      *                      *-----------------------------------------*
           multiply  -1                   by   srt-qta-rec            .
       stp-srt-inp-rsa-620.
      *                      *-----------------------------------------*
      *                      * Seconda quantita' relativa al tipo re-  *
      *                      * cord                                    *
      *                      *-----------------------------------------*
           move      zero                 to   srt-qta-dev            .
      *                      *-----------------------------------------*
      *                      * Si/no trasformazione unita' di misura   *
      *                      *-----------------------------------------*
           if        rf-bir-flg-puq       =    "K"
                     move  "P"            to   srt-snx-tum
           else      move  spaces         to   srt-snx-tum            .
      *                      *-----------------------------------------*
      *                      * Assestamento eventuale                  *
      *                      *                                         *
      *                      * Le righe di reso non contengono l'in-   *
      *                      * dicatore del prezzo per 1000            *
      *                      *-----------------------------------------*
           if        srt-snx-tum          =    spaces
                     move  "P"            to   srt-snx-tum            .
      *                      *-----------------------------------------*
      *                      * Decimali prezzo relativi al tipo record *
      *                      *-----------------------------------------*
           move      rf-bir-dec-prz       to   srt-dpr-rec            .
      *                      *-----------------------------------------*
      *                      * Prezzo unitario relativo al tipo record *
      *                      * espresso in valuta                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione del costo medio pon- *
      *                          * derato                              *
      *                          *-------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0001                 to   d-vun-mag-tip-val      .
           move      rf-bir-dat-doc       to   d-vun-mag-dat-val      .
           move      01                   to   d-vun-mag-tip-mag      .
           move      rf-dcp-num-pro       to   d-vun-mag-num-mag      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
      *                          *-------------------------------------*
      *                          * Valore                              *
      *                          *-------------------------------------*
           divide    100                  into d-vun-mag-val-uni
                                        giving srt-pun-rec            .
      *                      *-----------------------------------------*
      *                      * Valuta per la fatturazione              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzatura a 'valuta base'           *
      *                          *-------------------------------------*
           move      c-sgl                to   srt-sgl-vpf            .
           move      c-dec                to   srt-dec-vpf            .
           move      c-tdc                to   srt-tdc-vpf            .
           move      c-cdc                to   srt-cdc-vpf            .
      *                      *-----------------------------------------*
      *                      * Valuta per il prezzo                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzatura a 'valuta base'           *
      *                          *-------------------------------------*
           move      c-sgl                to   srt-sgl-vpp            .
           move      c-dec                to   srt-dec-vpp            .
           move      c-tdc                to   srt-tdc-vpp            .
           move      c-cdc                to   srt-cdc-vpp            .
      *                      *-----------------------------------------*
      *                      * Valuta per il legame valutario          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      spaces               to   srt-sgl-vpl            .
           move      zero                 to   srt-dec-vpl            .
           move      spaces               to   srt-tdc-vpl            .
           move      zero                 to   srt-prz-vpl            .
           move      zero                 to   srt-cdc-vpl            .
           move      zero                 to   srt-ccr-vpl            .
           move      zero                 to   srt-plm-vpl            .
           move      spaces               to   srt-tlm-vpl            .
           move      spaces               to   srt-map-vpl            .
      *                      *-----------------------------------------*
      *                      * Dati per la giacenza                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   srt-pro-gia            .
           move      zero                 to   srt-pro-vgi            .
           move      zero                 to   srt-pro-gat            .
           move      zero                 to   srt-pro-vga            .
      *                      *-----------------------------------------*
      *                      * Coordinate riga documento               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   srt-num-prt            .
           move      zero                 to   srt-num-prg            .
       stp-srt-inp-rsa-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-rsa-850.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-rsa-200.
       stp-srt-inp-rsa-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-rsa-999.
       stp-srt-inp-rsa-999.
           exit.

      *    *===========================================================*
