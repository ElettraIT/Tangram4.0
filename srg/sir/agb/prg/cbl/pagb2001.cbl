           move      w-stp-srt-inp-dec    to   w-cvs-vlt-dec          .
           move      w-stp-srt-inp-tdc    to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-stp-srt-inp-prz    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
