      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiesta alla segreteria del numero della  *
      *                  * settimana nell'anno                         *
      *                  *---------------------------------------------*
           move      "SA"                 to   s-ope                  .
           move      rr-dat-min           to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Editing settimana nell'anno                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      s-num                to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (2)      .
