                     move  "S"            to   w-cnt-fun-snx-stp
           else      move  "N"            to   w-cnt-fun-snx-stp      .
      *              *-------------------------------------------------*
      *              * Si/no invio a Retarus                           *
      *              *-------------------------------------------------*
           if        rr-snx-iar           =    zero
                     move  01             to   rr-snx-iar             .
       reg-ric-sel-999.
           exit.

