                                         using v                      .
           move      v-edt                to   w-all-str-cat (4)      .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "VIS-POS-WK"         to   w-all-str-cat (1)      .
           move      "-"                  to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * In campo di destinazione                    *
      *                  *---------------------------------------------*
           move      w-all-str-alf        to   rr-fil-pos             .
       det-nom-pos-999.
           exit.

      *    *===========================================================*
      *    * Controllo che il pathname non sia gia' stato assegnato    *
      *    *-----------------------------------------------------------*
       ctl-exi-pth-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esito                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-exi-pth-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-exi-pth-ctr      .
      *              *-------------------------------------------------*
      *              * Se il pathname e' a spaces : uscita             *
      *              *-------------------------------------------------*
           if        w-ctl-exi-pth-pth    =    spaces
                     go to ctl-exi-pth-999.
       ctl-exi-pth-010.
      *              *-------------------------------------------------*
      *              * Start su file [hpo]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PTHPRG    "         to   f-key                  .
           move      w-ctl-exi-pth-pth    to   rf-hpo-pth-pos         .
           move      zero                 to   rf-hpo-prg-inp         .
           move      "sir/agb/fls/ioc/obj/iofhpo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hpo                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita con flag a spaces  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-exi-pth-999.
       ctl-exi-pth-100.
      *              *-------------------------------------------------*
      *              * Next su [hpo]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "sir/agb/fls/ioc/obj/iofhpo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hpo                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a test finale                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-exi-pth-800.
       ctl-exi-pth-200.
      *              *-------------------------------------------------*
      *              * Max su [hpo], se non superato : a test finale   *
      *              *-------------------------------------------------*
           if        rf-hpo-pth-pos       not  = w-ctl-exi-pth-pth
                     go to ctl-exi-pth-800.
       ctl-exi-pth-300.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-ctl-exi-pth-ctr      .
       ctl-exi-pth-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record [hpo] successivo               *
      *              *-------------------------------------------------*
           go to     ctl-exi-pth-100.
       ctl-exi-pth-800.
      *              *-------------------------------------------------*
      *              * Test finale                                     *
      *              *-------------------------------------------------*
           if        w-ctl-exi-pth-ctr    >    zero
                     go to ctl-exi-pth-900
           else      go to ctl-exi-pth-999.
       ctl-exi-pth-900.
      *              *-------------------------------------------------*
      *              * Uscita con errore                               *
      *              *-------------------------------------------------*
           move      "#"                  to   w-ctl-exi-pth-flg      .
       ctl-exi-pth-999.
           exit.

      *    *===========================================================*
      *    * Find su archivio [ofe]                                    *
      *    *-----------------------------------------------------------*
       fnd-arc-hpo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di selezione               *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-arc-hpo-sel      .
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pagb4510"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-arc-hpo-sel
                     go to  fnd-arc-hpo-999.
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per possibili- *
      *              * ta' di function-key "SLCT" durante l'interroga- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "sir/agb/prg/obj/pagb4510"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
      *              *-------------------------------------------------*
      *              * Estrazione di eventuale variabile di i.p.c. de- *
      *              * terminata da function-key "SLCT" durante l'in-  *
      *              * terrogazione                                    *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "pth-pos"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  spaces         to   w-fnd-arc-hpo-sel
                     move  s-alf          to   w-fnd-arc-hpo-pth
           else      move  "#"            to   w-fnd-arc-hpo-sel      .
       fnd-arc-hpo-999.
           exit.

