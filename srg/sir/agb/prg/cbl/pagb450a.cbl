           move      d-vun-mag-val-uni    to   w-edt-prz-num          .
           divide    10000000             into w-edt-prz-num          .
           perform   edt-prz-fmt-000      thru edt-prz-fmt-999        .
           move      "+"                  to   w-vsy-dtl-ucs          .
           move      w-edt-prz-edt        to   w-vsy-dtl-ucv          .
       stp-srt-inp-det-520.
      *                  *---------------------------------------------*
      *                  * Unit price                                  *
      *                  *                                             *
      *                  * E' il prezzo unitario e NON x 1.000         *
      *                  *---------------------------------------------*
           move      rf-bir-prz-net       to   w-edt-prz-num          .
           divide    10000000             into w-edt-prz-num          .
           perform   edt-prz-fmt-000      thru edt-prz-fmt-999        .
      *
           if        rf-bir-cod-tmb       =    "BVFS "
                     move  "+"            to   w-vsy-dtl-ups
           else if   rf-bir-cod-tmb       =    "BRV  "
                     move  "-"            to   w-vsy-dtl-ups          .
