      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione Cap                     *
      *                      *-----------------------------------------*
           move      w-scm-loc-ccp-w15    to   w-scm-loc-ccp-cap      .
      *                      *-----------------------------------------*
      *                      * Preparazione nuova work di lavoro       *
      *                      *-----------------------------------------*
           move      w-scm-loc-ccp-loc
                    (7 : 34)              to   w-scm-loc-ccp-wlc      .
           go to     scm-loc-ccp-200.
       scm-loc-ccp-200.
      *              *-------------------------------------------------*
      *              * Identificazione Provincia                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-scm-loc-ccp-c01      .
           inspect   w-scm-loc-ccp-wlc
                                      tallying w-scm-loc-ccp-c01
                                  for trailing spaces                 .
           move      40                   to   w-scm-loc-ccp-c02      .
           subtract  w-scm-loc-ccp-c01    from w-scm-loc-ccp-c02      .
      *                  *---------------------------------------------*
      *                  * Se provincia non identificabile : oltre     *
      *                  *---------------------------------------------*
           if        w-scm-loc-ccp-c02    <    4
                     go to scm-loc-ccp-300.
           subtract  2                    from w-scm-loc-ccp-c02      .
           if        w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 1)
                                          not  = spaces
                     go to scm-loc-ccp-300.
           add       1                    to   w-scm-loc-ccp-c02      .
           if        w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 1)
                                          =    spaces
                     go to scm-loc-ccp-300.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione Provincia                   *
      *                  *---------------------------------------------*
           move      w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 2)
                                          to   w-scm-loc-ccp-prv      .
      *                  *---------------------------------------------*
      *                  * Eliminazione Provincia                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-scm-loc-ccp-wlc
                                              (w-scm-loc-ccp-c02 : 2) .
       scm-loc-ccp-300.
      *              *-------------------------------------------------*
      *              * Identificazione Citta'                          *
      *              *-------------------------------------------------*
           move      w-scm-loc-ccp-wlc    to   w-scm-loc-ccp-cit      .
       scm-loc-ccp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     scm-loc-ccp-999.
       scm-loc-ccp-999.
           exit.

