      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-dsz-dpz       not  = rf-cdp-dsz-dpz
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-075.
      *              *-------------------------------------------------*
      *              * Selezione su : Tipo codice di magazzino         *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-tip-mag       not  = rf-cdp-tip-mag
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-100.
      *              *-------------------------------------------------*
      *              * Selezione su : Codice prodotto numerico         *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-num-mag       not  = rf-cdp-num-mag
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-125.
      *              *-------------------------------------------------*
      *              * Selezione su : Codice prodotto alfanumerico     *
      *              *                                                 *
      *              * Non viene fatta alcuna selezione su questo cam- *
      *              * po, in quanto si prevede che possa essere nel   *
      *              * frattempo variato l'identificatore alfanumerico *
      *              * del prodotto. In ogni caso l'identificatore e-  *
      *              * sposto sara' l'identificatore alfanumerico at-  *
      *              * tuale.                                          *
      *              *-------------------------------------------------*
       sel-vpt-cdp-150.
      *              *-------------------------------------------------*
      *              * Selezione su : Sigla della variante per il pro- *
      *              *                dotto                            *
      *              *                                                 *
      *              * Non viene fatta alcuna selezione su questo cam- *
      *              * po, in quanto si permette di spedire una va-    *
      *              * riante diversa da quanto stabilito in ordine    *
      *              * fornitore.                                      *
      *              *-------------------------------------------------*
       sel-vpt-cdp-175.
      *              *-------------------------------------------------*
      *              * Selezione su : Quantita' prodotta               *
      *              *                                                 *
      *              * Deve essere diversa da Zero, non si prendono in *
      *              * considerazione versamenti da produzione con     *
      *              * quantita' a Zero.                               *
      *              *-------------------------------------------------*
           if        rf-vpt-qta-pdt       =    zero
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezione : Ok                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-sel-vpt-cdp-flg      .
           go to     sel-vpt-cdp-999.
       sel-vpt-cdp-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezione : Ko                       *
      *              *-------------------------------------------------*
           move      "#"                  to   w-sel-vpt-cdp-flg      .
           go to     sel-vpt-cdp-999.
       sel-vpt-cdp-999.
           exit.

      *    *===========================================================*
      *    * Open generica file sequenziale di output                  *
      *    *-----------------------------------------------------------*
       opn-seq-out-000.
      *              *-------------------------------------------------*
      *              * Preparazione file area generica                 *
      *              *-------------------------------------------------*
           move      "dispon"             to   f-xxx-npe              .
      *              *-------------------------------------------------*
      *              * Preparazione pathname                           *
      *              *-------------------------------------------------*
           move      ".txt"               to   f-xxx-npx              .
           move      spaces               to   f-xxx-pat              .
           string    f-xxx-ppb  delimited by   spaces
                     "/exp/"    delimited by   size
                     f-xxx-npe  delimited by   spaces
                     f-xxx-npx  delimited by   spaces
                                          into f-xxx-pat              .
      *              *-------------------------------------------------*
      *              * Apertura del file in output                     *
      *              *-------------------------------------------------*
           move      "OO"                 to   g-ope                  .
           move      "seq "               to   g-nam                  .
           move      f-xxx-pat            to   g-pat                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       opn-seq-out-999.
           exit.

      *    *===========================================================*
      *    * Put next generica per output in sequenziale               *
      *    *-----------------------------------------------------------*
       put-nxt-out-000.
      *              *-------------------------------------------------*
      *              * Scrittura su sequenziale                        *
      *              *-------------------------------------------------*
           move      "PN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       put-nxt-out-999.
           exit.

      *    *===========================================================*
      *    * Preparazione pathname di base files sequenziali           *
      *    *-----------------------------------------------------------*
       pre-bas-pth-000.
      *              *-------------------------------------------------*
      *              * Pathname di base da segreteria                  *
      *              *-------------------------------------------------*
           move      "PB"                 to   s-ope                  .
           move      "asc "               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * String                                          *
      *              *-------------------------------------------------*
           move      spaces               to   f-xxx-ppb              .
           string    s-pat      delimited by   spaces
                     "/"        delimited by   size
                                          into f-xxx-ppb              .
       pre-bas-pth-999.
           exit.

