      *              *   - L : Libero                                  *
      *              *   - T : Tipografico                             *
      *              *-------------------------------------------------*
           move      "L"                  to   w-cnt-stp-tip-mod      .
      *              *-------------------------------------------------*
      *              * Ampiezza linea di stampa in caratteri           *
      *              *-------------------------------------------------*
           move      132                  to   w-cnt-stp-amp-lin      .
      *              *-------------------------------------------------*
      *              * Top margin in linee                             *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-top-lin      .
      *              *-------------------------------------------------*
      *              * Numero linee di stampa minimo                   *
      *              *-------------------------------------------------*
           move      30                   to   w-cnt-stp-lin-min      .
      *              *-------------------------------------------------*
      *              * Bottom margin in linee                          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-bot-lin      .
      *              *-------------------------------------------------*
      *              * Ampiezza caratteri                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-amp-car      .
      *              *-------------------------------------------------*
      *              * Altezza interlinea                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-alt-int      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni future            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-esp-fut      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni speciali          *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-fnz-spc      .
       pre-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Trasferimento iniziale dei files generati nel   *
      *              * server                                          *
      *              *-------------------------------------------------*
           perform   trf-fls-srv-000      thru trf-fls-srv-999        .
      *              *-------------------------------------------------*
      *              * Preparazione pathname                           *
      *              *-------------------------------------------------*
           move      spaces               to   f-xxx-pat              .
           string    f-xxx-ppb  delimited by   spaces
                     "/LISTA"   delimited by   size
                                          into f-xxx-pat              .
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-gen-buf-ctr          .
      *              *-------------------------------------------------*
      *              * Open generica file sequenziale di input         *
      *              *-------------------------------------------------*
           perform   opn-seq-inp-000      thru opn-seq-inp-999        .
       stp-srt-inp-020.
      *              *-------------------------------------------------*
      *              * Lettura da sequenziale                          *
      *              *-------------------------------------------------*
           perform   get-nxt-inp-000      thru get-nxt-inp-999        .
      *              *-------------------------------------------------*
      *              * Test se errori                                  *
      *              *-------------------------------------------------*
           if        g-sts                =    e-not-err
                     go to stp-srt-inp-030.
           if        g-sts                =    e-end-fil
                     go to stp-srt-inp-100.
       stp-srt-inp-025.
      *              *-------------------------------------------------*
      *              * Se errore di i-o                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore sull'input              *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Nessun file da trattare"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-900.
       stp-srt-inp-030.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           if        w-gen-buf-ctr        <    w-gen-buf-max
                     add  1               to   w-gen-buf-ctr          .
      *              *-------------------------------------------------*
      *              * Bufferizzazione del record letto                *
      *              *-------------------------------------------------*
           move      g-rec                to   w-gen-buf-fil
                                              (w-gen-buf-ctr)         .
       stp-srt-inp-050.
      *              *-------------------------------------------------*
      *              * Riciclo su sequenziale                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-020.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Chiusura del file                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura del file in input                  *
      *                  *---------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
       stp-srt-inp-110.
      *              *-------------------------------------------------*
      *              * Test sul numero elementi letti                  *
      *              *-------------------------------------------------*
           if        w-gen-buf-ctr        not  > zero
                     go to stp-srt-inp-025.
       stp-srt-inp-150.
      *              *-------------------------------------------------*
      *              * Inizio scansione buffer                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-gen-buf-c01          .
       stp-srt-inp-160.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-gen-buf-c01          .
           if        w-gen-buf-c01        >    w-gen-buf-ctr or
                     w-gen-buf-c01        >    w-gen-buf-max
                     go to stp-srt-inp-900.
       stp-srt-inp-180.
      *                  *---------------------------------------------*
      *                  * Apertura e trattamento file                 *
      *                  *                                             *
      *                  * La directory 'rtr' e' link a '/abd/asc/imp' *
      *                  *---------------------------------------------*
           move      spaces               to   f-xxx-pat              .
           string    "/rtr/"    delimited by   size
                     w-gen-buf-fil
                    (w-gen-buf-c01)
                                delimited by   spaces
                                          into f-xxx-pat              .
      *                  *---------------------------------------------*
      *                  * Editing contatore                           *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-gen-buf-c01        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (02)     .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "Trattamento file nr."
                                          to   w-all-str-cat (01)     .
           move      "-"                  to   w-all-str-cat (03)     .
           move      w-gen-buf-fil
                    (w-gen-buf-c01)       to   w-all-str-cat (04)     .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione contatore                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di input     *
      *                  *---------------------------------------------*
           perform   opn-seq-inp-000      thru opn-seq-inp-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione comodo progressivo rilascio *
      *                  *---------------------------------------------*
           move      zero                 to   w-gen-buf-c02          .
       stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Lettura da sequenziale                      *
      *                  *---------------------------------------------*
           perform   get-nxt-inp-000      thru get-nxt-inp-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to stp-srt-inp-300.
           if        g-sts                =    e-end-fil
                     go to stp-srt-inp-800.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Trattamento in base al tipo di record           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In campo di comodo                          *
      *                  *---------------------------------------------*
           move      g-rec                to   w-inp-gen              .
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-inp-gen-tip        =    "H"
                     go to stp-srt-inp-400
           else if   w-inp-gen-tip        =    "D"
                     go to stp-srt-inp-600
           else      go to stp-srt-inp-200.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Trattamento testate                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scomposizione record sequenziale            *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-tes-000  thru stp-srt-inp-tes-999    .
      *                  *---------------------------------------------*
      *                  * Determinazione protocollo ordine fornitore  *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-doc-000  thru stp-srt-inp-doc-999    .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [oft]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [oft]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-det-num-oft-prt    to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione record di sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Chiave                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Filename in chiave                  *
      *                          *-------------------------------------*
           move      w-gen-buf-fil
                    (w-gen-buf-c01)       to   srt-key-nam            .
      *                          *-------------------------------------*
      *                          * Protocollo ordine                   *
      *                          *-------------------------------------*
           move      w-det-num-oft-prt    to   srt-num-prt            .
      *                          *-------------------------------------*
      *                          * Data conferma fornitore in chiave   *
      *                          *-------------------------------------*
           move      w-inp-tes-scd        to   w-det-num-oft-dtw      .
           move      w-det-num-oft-anw    to   s-saa                  .
           add       100                  to   s-saa                  .
           move      w-det-num-oft-msw    to   s-mes                  .
           move      w-det-num-oft-giw    to   s-gio                  .
           move      s-dat                to   w-det-num-oft-scd      .
      *
           move      w-det-num-oft-scd    to   srt-key-scd            .
      *                          *-------------------------------------*
      *                          * Tipo record in chiave               *
      *                          *-------------------------------------*
           move      "A"                  to   srt-key-rec            .
      *                          *-------------------------------------*
      *                          * Progressivo riga EDI                *
      *                          *-------------------------------------*
           move      zero                 to   srt-edi-prg            .
      *                          *-------------------------------------*
      *                          * Progressivo rilascio riga EDI       *
      *                          *-------------------------------------*
           move      zero                 to   srt-fil-prg            .
      *                          *-------------------------------------*
      *                          * Progressivo riga ordine             *
      *                          *-------------------------------------*
           move      zero                 to   srt-num-prg            .
      *                      *-----------------------------------------*
      *                      * Dati                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Progressivo riga EDI di riferimento *
      *                          *-------------------------------------*
           move      zero                 to   srt-edi-rif            .
      *                          *-------------------------------------*
      *                          * Tipo record                         *
      *                          *-------------------------------------*
           move      w-inp-tes-tip        to   srt-tip-rec            .
      *                          *-------------------------------------*
      *                          * Filename                            *
      *                          *-------------------------------------*
           move      w-gen-buf-fil
                    (w-gen-buf-c01)       to   srt-fil-nam            .
      *                          *-------------------------------------*
      *                          * Record di input                     *
      *                          *-------------------------------------*
           move      w-inp-tes            to   srt-rec-inp            .
      *                          *-------------------------------------*
      *                          * Record [oft]                        *
      *                          *-------------------------------------*
           move      rf-oft               to   srt-rec-oft            .
      *                          *-------------------------------------*
      *                          * Record [ofr]                        *
      *                          *-------------------------------------*
           move      spaces               to   srt-rec-ofr            .
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Trattamento righe                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scomposizione record sequenziale            *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-rig-000  thru stp-srt-inp-rig-999    .
      *                  *---------------------------------------------*
      *                  * Determinazione riga di riferimento          *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-rif-000  thru stp-srt-inp-rif-999    .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ofr]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [ofr]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-det-num-oft-prt    to   rf-ofr-num-prt         .
           move      w-det-num-oft-prg    to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione record di sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Chiave                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Filename in chiave                  *
      *                          *-------------------------------------*
           move      w-gen-buf-fil
                    (w-gen-buf-c01)       to   srt-key-nam            .
      *                          *-------------------------------------*
      *                          * Protocollo ordine                   *
      *                          *-------------------------------------*
           move      w-det-num-oft-prt    to   srt-num-prt            .
      *                          *-------------------------------------*
      *                          * Data conferma fornitore in chiave   *
      *                          *-------------------------------------*
           move      w-det-num-oft-scd    to   srt-key-scd            .
      *                          *-------------------------------------*
      *                          * Tipo record in chiave               *
      *                          *-------------------------------------*
           move      "B"                  to   srt-key-rec            .
      *                          *-------------------------------------*
      *                          * Progressivo riga EDI                *
      *                          *-------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      03                   to   v-car                  .
           move      w-inp-rig-sri        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   srt-edi-prg            .
      *                          *-------------------------------------*
      *                          * Progressivo rilascio riga EDI       *
      *                          *-------------------------------------*
           add       1                    to   w-gen-buf-c02          .
           move      w-gen-buf-c02        to   srt-fil-prg            .
      *                          *-------------------------------------*
      *                          * Progressivo riga ordine reale       *
      *                          *-------------------------------------*
           move      w-det-num-oft-prg    to   srt-num-prg            .
      *                      *-----------------------------------------*
      *                      * Dati                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Progressivo riga EDI di riferimento *
      *                          *-------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      03                   to   v-car                  .
           move      w-inp-rig-brr        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   srt-edi-rif            .
      *                          *-------------------------------------*
      *                          * Tipo record                         *
      *                          *-------------------------------------*
           move      w-inp-rig-tip        to   srt-tip-rec            .
      *                          *-------------------------------------*
      *                          * Filename                            *
      *                          *-------------------------------------*
           move      w-gen-buf-fil
                    (w-gen-buf-c01)       to   srt-fil-nam            .
