      *    *===========================================================*
      *    * Determinazione scarichi di magazzino per mese             *
      *    *-----------------------------------------------------------*
       det-scm-mes-000.
      *              *-------------------------------------------------*
      *              * Data base in work di comodo                     *
      *              *-------------------------------------------------*
           move      w-det-scm-mes-dtb    to   w-det-scm-mes-wdt      .
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio di partenza    *
      *              *-------------------------------------------------*
           move      w-det-scm-mes-wdt    to   s-dat                  .
           if        w-det-scm-mes-mce    =    12             or
                     s-mes                >    w-det-scm-mes-mce
                     move     s-saa       to   w-det-scm-mes-wes
           else      move     s-saa       to   w-det-scm-mes-wes
                     subtract 1           from w-det-scm-mes-wes      .
      *              *-------------------------------------------------*
      *              * Determinazione indice mese di esercizio di par- *
      *              * tenza                                           *
      *              *-------------------------------------------------*
           move      w-det-scm-mes-wdt    to   s-dat                  .
           move      s-mes                to   w-det-scm-mes-wme      .
           if        w-det-scm-mes-mce    =    12
                     go to det-scm-mes-100.
           if        w-det-scm-mes-wme    >    w-det-scm-mes-mce
                     subtract  w-det-scm-mes-mce
                                          from w-det-scm-mes-wme
                     go to det-scm-mes-100.
           if        w-det-scm-mes-wme    <    w-det-scm-mes-mce
                     add      12          to   w-det-scm-mes-wme
                     subtract w-det-scm-mes-mce
                                          from w-det-scm-mes-wme
                     go to det-scm-mes-100.
           move      12                   to   w-det-scm-mes-wme      .
       det-scm-mes-100.
      *              *-------------------------------------------------*
      *              * Lettura scheda saldi esercizio in corso         *
      *              *-------------------------------------------------*
           perform   det-scm-mes-950      thru det-scm-mes-959        .
      *              *-------------------------------------------------*
      *              * Normalizzazione progressivi carichi e scarichi  *
      *              * ultimi 12 mesi                                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-scm-mes-pcu      .
           move      zero                 to   w-det-scm-mes-psu      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione a ritroso                    *
      *              *-------------------------------------------------*
           move      15                   to   w-det-scm-mes-c01      .
       det-scm-mes-120.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivi carichi e scari-  *
      *                  * chi ultimi 12 mesi                          *
      *                  *---------------------------------------------*
           if        w-det-scm-mes-c01    >    3
                     add  rf-mms-prg-car
                         (w-det-scm-mes-wme)
                                          to   w-det-scm-mes-pcu
                     add  rf-mms-prg-sca
                         (w-det-scm-mes-wme)
                                          to   w-det-scm-mes-psu      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione elemento in tabella         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data                                    *
      *                      *-----------------------------------------*
           move      w-det-scm-mes-wdt    to   w-det-scm-mes-tdt
                                              (w-det-scm-mes-c01)     .
      *                      *-----------------------------------------*
      *                      * Quantita'                               *
      *                      *-----------------------------------------*
           move      rf-mms-prg-sca
                    (w-det-scm-mes-wme)   to   w-det-scm-mes-tqu
                                              (w-det-scm-mes-c01)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento contatore elementi            *
      *                  *---------------------------------------------*
           subtract  1                    from w-det-scm-mes-c01      .
           if        w-det-scm-mes-c01    =    zero
                     go to det-scm-mes-900.
      *                  *---------------------------------------------*
      *                  * Aggiornamento data per anno/mese            *
      *                  *---------------------------------------------*
           subtract  1                    from w-det-scm-mes-wdm      .
           if        w-det-scm-mes-wdm    =    zero
                     move 12              to   w-det-scm-mes-wdm
                     subtract 1           from w-det-scm-mes-wda      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento anno/mese di esercizio        *
      *                  *---------------------------------------------*
           subtract  1                    from w-det-scm-mes-wme      .
           if        w-det-scm-mes-wme    >    zero
                     go to det-scm-mes-130.
      *                      *-----------------------------------------*
      *                      * Passaggio all'esercizio precedente      *
      *                      *-----------------------------------------*
           move      12                   to   w-det-scm-mes-wme      .
           subtract  1                    from w-det-scm-mes-wes      .
      *                      *-----------------------------------------*
      *                      * Lettura scheda saldi esercizio prece-   *
      *                      * dente                                   *
      *                      *-----------------------------------------*
           perform   det-scm-mes-950      thru det-scm-mes-959        .
       det-scm-mes-130.
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     det-scm-mes-120.
       det-scm-mes-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-scm-mes-999.
       det-scm-mes-950.
      *              *=================================================*
      *              * Subroutine per lettura record [mms]             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [mms]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [mms]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DPMGDS    "         to   f-key                  .
           move      w-det-scm-mes-wes    to   rf-mms-ann-ese         .
           move      w-det-scm-mes-dpz    to   rf-mms-cod-dpz         .
           move      w-det-scm-mes-tpm    to   rf-mms-tip-mag         .
           move      w-det-scm-mes-cnm    to   rf-mms-num-mag         .
           move      spaces               to   rf-mms-var-mag
           move      spaces               to   rf-mms-cod-dsl         .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
       det-scm-mes-959.
           exit.
       det-scm-mes-999.
           exit.

      *    *===========================================================*
      *    * Determinazione costo di riferimento per il prodotto       *
      *    *-----------------------------------------------------------*
       det-cos-rif-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cos-rif-tde      .
           move      spaces               to   w-det-cos-rif-svc      .
           move      zero                 to   w-det-cos-rif-dvc      .
           move      zero                 to   w-det-cos-rif-dec      .
           move      zero                 to   w-det-cos-rif-cdr      .
           move      spaces               to   w-det-cos-rif-svl      .
           move      spaces               to   w-det-cos-rif-tcl      .
           move      zero                 to   w-det-cos-rif-crl      .
           move      zero                 to   w-det-cos-rif-pll      .
      *              *-------------------------------------------------*
      *              * Tentativo di determinazione con combinazione    *
      *              * fornitore/prodotto [aaf]                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [aaq]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaq-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a determinazione    *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Se fornitore preferenziale per il prodotto  *
      *                  * a zero : a determinazione costo medio con-  *
      *                  * tinuo                                       *
      *                  *---------------------------------------------*
           if        rf-aaq-dcf-pfz       =    zero
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaf]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRFNFM"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaf-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaf-num-pro         .
           move      rf-aaq-dcf-pfz       to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : : a determinazione  *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      01                   to   w-det-cos-rif-tde      .
           move      rf-aaf-sgl-vlt       to   w-det-cos-rif-svc      .
           move      rf-aaf-dec-vlt       to   w-det-cos-rif-dvc      .
           move      rf-aaf-dec-prz       to   w-det-cos-rif-dec      .
           move      rf-aaf-prz-pes (1)   to   w-det-cos-rif-cdr      .
           if        rf-aaf-lgv-vlt       not  = spaces
                     move  rf-aaf-lgv-vlt to   w-det-cos-rif-svl
                     move  rf-aaf-lgv-tdc to   w-det-cos-rif-tcl
                     move  rf-aaf-lgv-cdc to   w-det-cos-rif-crl
                     move  rf-aaf-lgv-pdt to   w-det-cos-rif-pll      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-500.
      *              *-------------------------------------------------*
      *              * Determinazione con costo medio continuo         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo modulo di magazzino                *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0005                 to   d-vun-mag-tip-val      .
           move      w-det-cos-rif-dtb    to   d-vun-mag-dat-val      .
           move      w-det-cos-rif-tpm    to   d-vun-mag-tip-mag      .
           move      w-det-cos-rif-cnm    to   d-vun-mag-num-mag      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      02                   to   w-det-cos-rif-tde      .
           move      c-sgl                to   w-det-cos-rif-svc      .
           move      c-dec                to   w-det-cos-rif-dvc      .
           move      02                   to   w-det-cos-rif-dec      .
           move      d-vun-mag-val-uni    to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' di fabbisogno/disponibilita' da  *
      *    * visualizzare nell'interrogazione                          *
      *    *-----------------------------------------------------------*
       det-qfd-dav-000.
      *              *-------------------------------------------------*
      *              * Determinazione date per tabella disponibilita'  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione data primo elemento         *
      *                  *---------------------------------------------*
           move      w-det-qfd-dav-dtb    to   w-det-qfd-dav-dfd (1)  .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione elementi successivi      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione data base per calcolo  *
      *                      *-----------------------------------------*
           move      w-det-qfd-dav-dtb    to   w-det-qfd-dav-wdb      .
      *                      *-----------------------------------------*
      *                      * Ciclo di scansione                      *
      *                      *-----------------------------------------*
           move      1                    to   w-det-qfd-dav-c01      .
       det-qfd-dav-020.
           add       1                    to   w-det-qfd-dav-c01      .
           if        w-det-qfd-dav-c01    >    15
                     go to det-qfd-dav-100.
      *                      *-----------------------------------------*
      *                      * Determinazione data incrementata        *
      *                      *-----------------------------------------*
           move      w-det-qfd-dav-wdb    to   w-det-dat-nrg-dtb      .
           move      w-det-qfd-dav-ngi    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione in tabella data incre-  *
      *                      * mentata                                 *
      *                      *-----------------------------------------*
           move      w-det-dat-nrg-dti    to   w-det-qfd-dav-dfd
                                              (w-det-qfd-dav-c01)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento data base per prossimo    *
      *                      * calcolo                                 *
      *                      *-----------------------------------------*
           move      w-det-dat-nrg-dti    to   w-det-qfd-dav-wdb      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     det-qfd-dav-020.
       det-qfd-dav-100.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' per tabella disponibi- *
      *              * lita'                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per scansione    *
      *                  * buffer dei fabbisogni/disponibilita'        *
      *                  *---------------------------------------------*
           move      1                    to   d-buf-fod-ctr-001      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione tabella disponibilita'   *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-qfd-dav-c01      .
       det-qfd-dav-120.
           add       1                    to   w-det-qfd-dav-c01      .
           if        w-det-qfd-dav-c01    >    15
                     go to det-qfd-dav-200.
      *                  *---------------------------------------------*
      *                  * Determinazione fabbisogno/disponibilita'    *
      *                  * alla data in esame                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se data in esame superiore alla data    *
      *                      * consegna prevista dell'ultimo elemento, *
      *                      * bufferizzazione quantita' dell'ultimo   *
      *                      * elemento                                *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dfd
                    (w-det-qfd-dav-c01)   >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-qfd
                                              (w-det-qfd-dav-c01)
                     go to det-qfd-dav-160.
      *                      *-----------------------------------------*
      *                      * Continuazione scansione buffer delle    *
      *                      * quantita' di fabbisogno/disponibilita'  *
      *                      *-----------------------------------------*
       det-qfd-dav-140.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001    >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-qfd
                                              (w-det-qfd-dav-c01)
                     go to det-qfd-dav-160.
      *                      *-----------------------------------------*
      *                      * Finche' la data in esame e' superiore   *
      *                      * alla data consegna prevista dell'ele-   *
      *                      * mento : riciclo                         *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dfd
                    (w-det-qfd-dav-c01)   >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-140.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dfd
                    (w-det-qfd-dav-c01)   <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-qfd
                                              (w-det-qfd-dav-c01)     .
       det-qfd-dav-160.
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione tabella delle disponi- *
      *                  * bilita'                                     *
      *                  *---------------------------------------------*
           go to     det-qfd-dav-120.
       det-qfd-dav-200.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qfd-dav-999.
       det-qfd-dav-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di trattamento quantita'                       *
      *    *-----------------------------------------------------------*
       det-out-qta-000.
      *              *-------------------------------------------------*
      *              * Segno                                           *
      *              *-------------------------------------------------*
           if        w-det-out-qta-qta    <    zero
                     move  "-"            to   w-det-out-qta-sgn
           else      move  "+"            to   w-det-out-qta-sgn      .
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-det-out-qta-qta    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
           move      v-edt                to   w-det-out-qta-val      .
      *              *-------------------------------------------------*
      *              * Allineamento a destra                           *
      *              *-------------------------------------------------*
           move      07                   to   w-all-str-lun          .
           move      w-det-out-qta-val    to   w-all-str-alf          .
           perform   all-str-adx-000      thru all-str-adx-999        .
           move      w-all-str-alf        to   w-det-out-qta-val      .
      *              *-------------------------------------------------*
      *              * Riempimento con zeri                            *
      *              *-------------------------------------------------*
           inspect   w-det-out-qta-val
                                replacing all  " "
                                          by   "0"                    .
       det-out-qta-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di trattamento data                            *
      *    *-----------------------------------------------------------*
       det-out-dat-000.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-det-out-dat-dat    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
           move      v-edt                to   w-det-out-dat-edt      .
       det-out-dat-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [pdx] per scansione delle righe   *
      *    *-----------------------------------------------------------*
       let-arc-pdx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-pdx-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-let-arc-pdx-ctr      .
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-pdx-des      .
       let-arc-pdx-100.
      *              *-------------------------------------------------*
      *              * Start su file [pdx]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TRCLNG    "         to   f-key                  .
           move      w-let-arc-pdx-rec    to   rf-pdx-tip-rec         .
           move      w-let-arc-pdx-arc    to   rf-pdx-cod-arc         .
           move      w-let-arc-pdx-lng    to   rf-pdx-cod-lng         .
           move      w-let-arc-pdx-pro    to   rf-pdx-cod-num         .
           move      w-let-arc-pdx-fmt    to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-pdx-800.
       let-arc-pdx-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [pdx]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-pdx-800.
       let-arc-pdx-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-pdx-tip-rec       not  = w-let-arc-pdx-rec or
                     rf-pdx-cod-arc       not  = w-let-arc-pdx-arc or
                     rf-pdx-cod-lng       not  = w-let-arc-pdx-lng or
                     rf-pdx-cod-num       not  = w-let-arc-pdx-pro or
                     rf-pdx-for-mat       not  = w-let-arc-pdx-fmt
                     go to let-arc-pdx-800.
       let-arc-pdx-400.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-let-arc-pdx-ctr      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-pdx-des-pro       to   w-let-arc-pdx-rig
                                              (w-let-arc-pdx-ctr)     .
       let-arc-pdx-600.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura                              *
      *              *-------------------------------------------------*
           go to     let-arc-pdx-200.
       let-arc-pdx-800.
      *              *-------------------------------------------------*
      *              * Test su contatore elementi letti                *
      *              *-------------------------------------------------*
           if        w-let-arc-pdx-ctr    =    zero
                     go to let-arc-pdx-820
           else      go to let-arc-pdx-900.
       let-arc-pdx-820.
      *                  *---------------------------------------------*
      *                  * Se nessun elemento rilevato                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di nessun elemento rilevato        *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-pdx-flg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     let-arc-pdx-900.
       let-arc-pdx-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-pdx-999.
       let-arc-pdx-999.
           exit.

