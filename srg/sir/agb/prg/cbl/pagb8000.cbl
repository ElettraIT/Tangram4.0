      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "sir/agb/fls/ioc/obj/iofhlf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hlf                 .
       upd-rec-hlf-500.
      *                  *---------------------------------------------*
