      *                  *---------------------------------------------*
           move      w-out-dcp-des        to   rf-hlf-des-alf         .
      *
           move      w-out-dcp-des        to   w-all-str-alf          .
           move      40                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   rf-hlf-des-key         .
      *
           move      w-gen-num-pro        to   rf-hlf-num-pro         .
           move      rr-cod-fnt-vlt       to   rf-hlf-sgl-vlt         .
           move      2                    to   rf-hlf-dec-vlt         .
           move      zero                 to   rf-hlf-dec-prz         .
      *                  *---------------------------------------------*
      *                  * Prezzo di listino                           *
      *                  *---------------------------------------------*
           if        rr-snx-spc           =    01
                     move  w-gen-prz-lst  to   rf-hlf-prz-lst
           else      move  w-gen-prz-lst  to   rf-hlf-prz-spc
                     move  rr-dat-spc     to   rf-hlf-dat-spc         .
      *
           move      1000                 to   rf-hlf-qta-prz         .
           move      w-out-qta-cfz        to   rf-hlf-qta-cfz         .
           move      w-out-qta-min        to   rf-hlf-min-acq         .
      *
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-hlf-dat-agg         .
      *
           move      w-out-lib            to   rf-hlf-lib-lst         .
           move      all zero             to   rf-hlf-exp-num         .
           move      spaces               to   rf-hlf-exp-alf         .
       upd-rec-hlf-400.
      *                  *---------------------------------------------*
