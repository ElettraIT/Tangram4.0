      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Preparazione del tipo archivio in base alle     *
      *              * richieste                                       *
      *              *-------------------------------------------------*
           if        rr-tip-arc           =    "E"
                     move  "C"            to   w-stp-srt-tip
           else      move  rr-tip-arc     to   w-stp-srt-tip          .
      *              *-------------------------------------------------*
      *              * Preparazione delle date per la scansione        *
      *              *-------------------------------------------------*
           move      rr-ann-fis           to   s-saa                  .
           move      01                   to   s-gio                  .
           move      01                   to   s-mes                  .
           move      s-dat                to   w-det-dat-srt-min      .
      *
           move      rr-ann-fis           to   s-saa                  .
           add       1                    to   s-saa                  .
           move      31                   to   s-gio                  .
           move      12                   to   s-mes                  .
           move      s-dat                to   w-det-dat-srt-max      .
      *
           move      rr-ann-fis           to   s-saa                  .
           move      31                   to   s-gio                  .
           move      12                   to   s-mes                  .
           move      s-dat                to   w-det-dat-srt-sel      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di presenza Black List     *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-snx-blk-flg      .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su file [mgi]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATDOC    "         to   f-key                  .
           move      w-stp-srt-tip        to   rf-mgi-tip-rec         .
           move      w-det-dat-srt-min    to   rf-mgi-dat-reg         .
           move      zero                 to   rf-mgi-cod-num         .
           move      zero                 to   rf-mgi-prt-iva         .
           move      zero                 to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [mgi]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo record                         *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-rec       not  = w-stp-srt-tip
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Test su data massima                        *
      *                  *---------------------------------------------*
           if        rf-mgi-dat-reg       >    w-det-dat-srt-max
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su Anno in corso o precedente     *
      *                  *                                             *
      *                  * N.B.: per convenzione, in questa versione   *
      *                  *       dello spesometro, non si considerano  *
      *                  *       le Note di Variazione.                *
      *                  *                                             *
      *                  * ___ DA IMPLEMENTARE ___                     *
      *                  *---------------------------------------------*
           if        rf-mgi-flg-cop       =    "P"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezione su data documento                 *
      *                  *---------------------------------------------*
           if        rf-mgi-dat-doc       <    w-det-dat-srt-min or
                     rf-mgi-dat-doc       >    w-det-dat-srt-sel
                     go to stp-srt-inp-200.
                     
      *                  *---------------------------------------------*
      *                  * SIRI - FORNITORE 6658                       *
      *                  * ___                                         *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-rec       =    "F" and
                     rf-mgi-cod-arc       =    0006658
                     go to stp-srt-inp-450.
                     
      *                  *---------------------------------------------*
      *                  * Selezione su regime fiscale particolare     *
      *                  *                                             *
      *                  * - Spaces o N : Normale regime fiscale    SI *
      *                  * - S          : Scissione Pagamenti       NO *
      *                  * - R          : Reverse Charge            SI *
      *                  * - E          : Esclusione                NO *
      *                  *---------------------------------------------*
           if        rf-mgi-flg-rfp       =    "E" or
                     rf-mgi-flg-rfp       =    "S"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento iva                  *
      *                  *                                             *
      *                  * - 1 : Dare cliente Italia o Estero non CEE  *
      *                  * - 2 : Avere cliente Italia o Estero non CEE *
      *                  * - 3 : Corrispettivi (NON GESTITO)           *
      *                  *                                             *
      *                  * - 4 : Dare fornit. Italia o Estero non CEE  *
      *                  * - 5 : Avere fornit. Italia o Estero non CEE *
      *                  * - 6 : Bolla doganale Estero non CEE         *
      *                  *                                             *
      *                  * - A : Dare cliente Estero CEE (NON GESTITO) *
      *                  * - B : Avere cliente Estero CEE     "        *
      *                  *                                             *
      *                  * - D : Dare fornitore Estero CEE    "        *
      *                  * - E : Avere fornitore Estero CEE   "        *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-iva       =    "1" or
                     rf-mgi-tip-iva       =    "2" or
                     rf-mgi-tip-iva       =    "4" or
                     rf-mgi-tip-iva       =    "5" or
                     rf-mgi-tip-iva       =    "6"
                     go to stp-srt-inp-450
           else      go to stp-srt-inp-200.
       stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione castelletto Iva          *
      *                  *---------------------------------------------*
