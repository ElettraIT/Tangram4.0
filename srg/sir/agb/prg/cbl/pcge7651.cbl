                    (w-stp-srt-ctr)       <    100
                     move  "I"            to   rf-zci-flg-ecf
           else if   rf-mgi-cod-iva
                    (w-stp-srt-ctr)       >    700  and
                     rf-mgi-cod-iva
                    (w-stp-srt-ctr)       <    800
                     move  "I"            to   rf-zci-flg-ecf
           else if   rf-mgi-cod-iva
                    (w-stp-srt-ctr)       >    900  and
                     rf-mgi-cod-iva
                    (w-stp-srt-ctr)       <    999
                     move  "I"            to   rf-zci-flg-ecf         .
