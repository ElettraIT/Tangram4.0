           move      w-sez-rec-det-bky    to   w-ecf-mns-ccc-key
                                              (w-sez-rec-det-inx)     .
      *                      *-----------------------------------------*
      *                      * Emissione                               *
      *                      *-----------------------------------------*
           string    "+"        delimited by   size
                     w-sez-rec-det-val
                    (17 : 15)   delimited by   size
                                          into w-ecf-mns-ccc-val
                                              (w-sez-rec-det-inx)     .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     sez-rec-det-580.
       sez-rec-det-550.
      *                  *---------------------------------------------*
      *                  * III tranche                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Verifica valore                         *
      *                      *-----------------------------------------*
           if        w-sez-rec-det-val
                    (32 : 08)             =    spaces
                     go to sez-rec-det-580.
      *                      *-----------------------------------------*
      *                      * Incremento contatore progressivo        *
      *                      *-----------------------------------------*
           add       1                    to   w-sez-rec-det-inx      .
      *                      *-----------------------------------------*
      *                      * Test se oltre il massimo                *
      *                      *-----------------------------------------*
           if        w-sez-rec-det-inx    not  > w-sez-rec-det-max
                     go to sez-rec-det-552.
      *                      *-----------------------------------------*
      *                      * Gestione contatore                      *
      *                      *-----------------------------------------*
           perform   sez-rec-det-950      thru sez-rec-det-959        .
       sez-rec-det-552.
      *                      *-----------------------------------------*
      *                      * Chiave bufferizzata                     *
      *                      *-----------------------------------------*
           move      w-sez-rec-det-bky    to   w-ecf-mns-ccc-key
                                              (w-sez-rec-det-inx)     .
      *                      *-----------------------------------------*
      *                      * Emissione                               *
      *                      *-----------------------------------------*
           string    "+"        delimited by   size
                     w-sez-rec-det-val
                    (32 : 08)   delimited by   size
                                          into w-ecf-mns-ccc-val
                                              (w-sez-rec-det-inx)     .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     sez-rec-det-580.
       sez-rec-det-580.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     sez-rec-det-520.
       sez-rec-det-600.
      *              *-------------------------------------------------*
      *              * Se lunghezza valore entro il modulo             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Frammento da 16 caratteri                   *
      *                  *---------------------------------------------*
           move      w-sez-rec-det-val
                    (01 : 16)             to   w-ecf-mns-ccc-val
                                              (w-sez-rec-det-inx)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     sez-rec-det-900.
       sez-rec-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     sez-rec-det-999.
       sez-rec-det-950.
      *              *=================================================*
      *              * Gestione contatore elemento tabella             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura del modulo precedente              *
      *                  *---------------------------------------------*
           perform   mns-ccc-ecf-chi-000  thru mns-ccc-ecf-chi-999    .
      *                  *---------------------------------------------*
      *                  * Incremento modulo                           *
      *                  *---------------------------------------------*
           add       1                    to   w-tot-gen-ctr-prg      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione sezione                     *
      *                  *---------------------------------------------*
           perform   mns-ccc-ecf-ini-000  thru mns-ccc-ecf-ini-999    .
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore                  *
      *                  *---------------------------------------------*
           move      1                    to   w-sez-rec-det-inx      .
       sez-rec-det-959.
           exit.
       sez-rec-det-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [gxn]                             *
      *    *-----------------------------------------------------------*
       let-arc-gxn-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-gxn-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a spazi                          *
      *              *-------------------------------------------------*
           if        w-let-arc-gxn-cod    =    spaces
                     go to let-arc-gxn-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODNAZ    "         to   f-key                  .
           move      w-let-arc-gxn-cod    to   rf-gxn-cod-naz         .
           move      "pgm/geo/fls/ioc/obj/iofgxn"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxn                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-gxn-400.
       let-arc-gxn-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-gxn-des-naz       to   w-let-arc-gxn-des      .
           move      rf-gxn-snx-blk       to   w-let-arc-gxn-blk      .
           move      rf-gxn-cod-ste       to   w-let-arc-gxn-ste      .
      *
           if        rf-gxn-snx-blk       =    spaces
                     move  "N"            to   w-let-arc-gxn-blk      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-gxn-999.
       let-arc-gxn-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-gxn-flg      .
           move      all   "."            to   w-let-arc-gxn-des      .
           go to     let-arc-gxn-999.
       let-arc-gxn-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-gxn-des      .
           move      spaces               to   w-let-arc-gxn-blk      .
           move      spaces               to   w-let-arc-gxn-ste      .
       let-arc-gxn-999.
           exit.

