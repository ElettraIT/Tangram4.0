      *    *===========================================================*
      *    * Controllo formale su partita i.v.a.                       *
      *    *                                                           *
      *    * Input  : w-cnt-piv-piv = partita i.v.a. da controllare    *
      *    *                                                           *
      *    * Output : w-cnt-piv-flg = - spaces : p.i. corretta         *
      *    *                          - #      : p.i. errata           *
      *    *-----------------------------------------------------------*
       cnt-prt-iva-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-piv-flg          .
      *              *-------------------------------------------------*
      *              * Se p.i. a zero si esce per OK                   *
      *              *-------------------------------------------------*
           if        w-cnt-piv-piv        =    zero
                     go to cnt-prt-iva-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore caratteri e sommato- *
      *              * ria dei primi dieci caratteri                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-piv-ctr
                                               w-cnt-piv-sum          .
       cnt-prt-iva-100.
      *              *-------------------------------------------------*
      *              * Incremento contatore caratteri                  *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-piv-ctr          .
      *              *-------------------------------------------------*
      *              * Se entro i primi dieci caratteri                *
      *              *-------------------------------------------------*
           if        w-cnt-piv-ctr        >    10
                     go to cnt-prt-iva-500.
      *                  *---------------------------------------------*
      *                  * Se 1. o 3. o 5. o 7. o 9. carattere         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Somma del carattere nella sommatoria    *
      *                      *-----------------------------------------*
           add       w-cnt-piv-chr
                    (w-cnt-piv-ctr)       to   w-cnt-piv-sum          .
      *                  *---------------------------------------------*
      *                  * Se 2. o 4. o 6. o 8. o 10. carattere        *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-piv-ctr          .
      *                      *-----------------------------------------*
      *                      * Moltiplica il carattere per due         *
      *                      *-----------------------------------------*
           multiply  2                    by   w-cnt-piv-chr
                                              (w-cnt-piv-ctr)
                                        giving w-cnt-piv-w20          .
      *                      *-----------------------------------------*
      *                      * Somma nella sommatoria il carattere si- *
      *                      * nistro e il carattere destro del risul- *
      *                      * tato della moltiplicazione              *
      *                      *-----------------------------------------*
           add       w-cnt-piv-w21        to   w-cnt-piv-sum          .
           add       w-cnt-piv-w22        to   w-cnt-piv-sum          .
      *                  *---------------------------------------------*
      *                  * Ricicla su prossimo carattere               *
      *                  *---------------------------------------------*
           go to     cnt-prt-iva-100.
       cnt-prt-iva-500.
      *              *-------------------------------------------------*
      *              * Se undicesimo carattere                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo della differenza tra 100 e la som-  *
      *                  * matoria calcolata                           *
      *                  *---------------------------------------------*
           subtract  w-cnt-piv-sum        from 100
                                        giving w-cnt-piv-w20          .
      *                  *---------------------------------------------*
      *                  * Confronto tra la cifra di destra della dif- *
      *                  * ferenza e l'undicesimo carattere : se  non  *
      *                  * sono uguali c'e' un errore formale          *
      *                  *---------------------------------------------*
           if        w-cnt-piv-w22        not  = w-cnt-piv-chr
                                                (w-cnt-piv-ctr)
                     move  "#"            to   w-cnt-piv-flg          .
       cnt-prt-iva-999.
           exit.

      *    *===========================================================*
      *    * Emissione file sequenziale                                *
      *    *-----------------------------------------------------------*
       emi-fil-seq-000.
      *              *-------------------------------------------------*
      *              * Emissione file ministeriale                     *
      *              *-------------------------------------------------*
           perform   emi-fil-seq-mns-000  thru   emi-fil-seq-mns-999  .
       emi-fil-seq-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-fil-seq-999.
       emi-fil-seq-999.
           exit.

      *    *===========================================================*
      *    * Emissione file sequenziale                                *
      *    *                                                           *
      *    * Sequenziale di tipo 'ministeriale'                        *
      *    *                                                           *
      *    * 'I' : Inizializzazione                                    *
      *    * 'd' : Inizializzazione dettaglio                          *
      *    * 'D' : Preparazione dettaglio                              *
      *    * 'e' : Emissione dettaglio                                 *
      *    * 'R' : Riepilogo di chiusura                               *
      *    * 'C' : Chiusura                                            *
      *    *-----------------------------------------------------------*
       emi-fil-seq-mns-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-out-gen-tip-ope    =    "I"
                     go to emi-fil-seq-mns-100
           else if   w-out-gen-tip-ope    =    "d"
                     go to emi-fil-seq-mns-300
           else if   w-out-gen-tip-ope    =    "D"
                     go to emi-fil-seq-mns-400
           else if   w-out-gen-tip-ope    =    "e"
                     go to emi-fil-seq-mns-500
           else if   w-out-gen-tip-ope    =    "R"
                     go to emi-fil-seq-mns-600
           else if   w-out-gen-tip-ope    =    "C"
                     go to emi-fil-seq-mns-800.
       emi-fil-seq-mns-100.
      *              *=================================================*
      *              * Inizializzazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione [ada]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Lettura [ada] dati anagrafici Azienda       *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Normalizzazione [gxc]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                  *---------------------------------------------*
      *                  * Lettura Comune                              *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      rf-ada-cod-cmn       to   rf-gxc-cod-cmn         .
           move      rf-ada-cod-fzn       to   rf-gxc-cod-fzn         .
           move      rf-ada-cod-lct       to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                  *---------------------------------------------*
      *                  * Determinazione pathname completo file [ouf] *
      *                  *---------------------------------------------*
           perform   ouf-fil-det-000      thru ouf-fil-det-999        .
      *                  *---------------------------------------------*
      *                  * Open output file [ouf]                      *
      *                  *---------------------------------------------*
           perform   ouf-fil-opo-000      thru ouf-fil-opo-999        .
      *                  *---------------------------------------------*
      *                  * Generazione record di testa                 *
      *                  *---------------------------------------------*
           perform   mns-aaa-ecf-000      thru mns-aaa-ecf-999        .
      *                  *---------------------------------------------*
      *                  * Generazione record di testa - dati          *
      *                  *---------------------------------------------*
           perform   mns-bbb-ecf-000      thru mns-bbb-ecf-999        .
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice elementi quadro     *
      *                  *---------------------------------------------*
           move      zero                 to   w-sez-rec-det-inx      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-seq-mns-900.
       emi-fil-seq-mns-300.
      *              *=================================================*
      *              * Dettaglio (inizializzazione)                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione sezione                     *
      *                  *---------------------------------------------*
           perform   mns-ccc-ecf-ini-000  thru mns-ccc-ecf-ini-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-seq-mns-900.
       emi-fil-seq-mns-400.
      *              *=================================================*
      *              * Dettaglio (composizione)                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale inversione dei segni e della      *
      *                  * logica Cliente / Fornitore                  *
      *                  *---------------------------------------------*
           if        w-tot-arc-nrm-tib    >    zero
                     go to emi-fil-seq-mns-450.
      *                  *---------------------------------------------*
      *                  * Inversione dei segni                        *
      *                  *---------------------------------------------*
           if        w-tot-arc-nrm-tib    <    zero
                     multiply  -1         by   w-tot-arc-nrm-tib      .
           if        w-tot-arc-nrm-imp    <    zero
                     multiply  -1         by   w-tot-arc-nrm-imp      .
      *                  *---------------------------------------------*
      *                  * Generazione record di dettaglio con criteri *
      *                  * inversi                                     *
      *                  *---------------------------------------------*
           if        w-rot-l03-tip-arc    =    "C" and
                     w-rot-l04-key-blk    =    0
                     perform   mns-ccc-ecf-for-000
                                          thru mns-ccc-ecf-for-999
           else if   w-rot-l03-tip-arc    =    "F" and
                     w-rot-l04-key-blk    =    0
                     perform   mns-ccc-ecf-cli-000
                                          thru mns-ccc-ecf-cli-999
           else if   w-rot-l03-tip-arc    =    "C" and
                     w-rot-l04-key-blk    =    1   or
                     w-rot-l04-key-blk    =    2
                     perform   mns-ccc-ecf-fob-000
                                          thru mns-ccc-ecf-fob-999
           else if   w-rot-l03-tip-arc    =    "F" and
                     w-rot-l04-key-blk    =    1   or
                     w-rot-l04-key-blk    =    2
                     perform   mns-ccc-ecf-clb-000
                                          thru mns-ccc-ecf-clb-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-seq-mns-900.
       emi-fil-seq-mns-450.
      *                  *---------------------------------------------*
      *                  * Generazione record di dettaglio             *
      *                  *---------------------------------------------*
           if        w-rot-l03-tip-arc    =    "C" and
                     w-rot-l04-key-blk    =    0
                     perform   mns-ccc-ecf-cli-000
                                          thru mns-ccc-ecf-cli-999
           else if   w-rot-l03-tip-arc    =    "F" and
                     w-rot-l04-key-blk    =    0
                     perform   mns-ccc-ecf-for-000
                                          thru mns-ccc-ecf-for-999
           else if   w-rot-l03-tip-arc    =    "C" and
                     w-rot-l04-key-blk    =    1   or
                     w-rot-l04-key-blk    =    2
                     perform   mns-ccc-ecf-clb-000
                                          thru mns-ccc-ecf-clb-999
           else if   w-rot-l03-tip-arc    =    "F" and
                     w-rot-l04-key-blk    =    1   or
                     w-rot-l04-key-blk    =    2
                     perform   mns-ccc-ecf-fob-000
                                          thru mns-ccc-ecf-fob-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-seq-mns-900.
       emi-fil-seq-mns-500.
      *              *=================================================*
      *              * Dettaglio (emissione)                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-seq-mns-900.
       emi-fil-seq-mns-600.
      *              *=================================================*
      *              * Riepilogo (emissione)                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Generazione record di chiusura per il       *
      *                  * dettaglio                                   *
      *                  *---------------------------------------------*
           perform   mns-ccc-ecf-chi-000  thru mns-ccc-ecf-chi-999    .
      *                  *---------------------------------------------*
      *                  * Generazione record di riepilogo             *
      *                  *---------------------------------------------*
           perform   mns-eee-ecf-000      thru mns-eee-ecf-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-seq-mns-900.
       emi-fil-seq-mns-800.
      *              *=================================================*
      *              * Chiusura                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Generazione record di coda                  *
      *                  *---------------------------------------------*
           perform   mns-zzz-ecf-000      thru mns-zzz-ecf-999        .
      *                  *---------------------------------------------*
      *                  * Close file [ouf] in formato MS-DOS          *
      *                  *---------------------------------------------*
           perform   ouf-fil-cls-000      thru ouf-fil-cls-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio di dati elaborati       *
      *                  *---------------------------------------------*
           if        w-tot-gen-ctr-ele    not  > zero
                     go to emi-fil-seq-mns-900.
      *                  *---------------------------------------------*
      *                  * Separatore                                  *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      all "-"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per nome file                     *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Archivio da trasmettere         : "
                                delimited by   size
                     "[cbi/"    delimited by   size
                     w-det-pth-fso-nam
                                delimited by   spaces
                     "]"        delimited by   size
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Editing contatore clienti                   *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ctr-cli    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per contatore elementi            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Clienti nr.                     : "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Editing contatore fornitori                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ctr-for    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per contatore elementi            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Fornitori nr.                   : "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio Black List              *
      *                  *---------------------------------------------*
           if        w-tot-gen-ctr-cbl    =    zero and
                     w-tot-gen-ctr-fbl    =    zero
                     go to emi-fil-seq-mns-880.
      *                  *---------------------------------------------*
      *                  * Editing contatore clienti in Black List     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ctr-cbl    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per contatore elementi            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Clienti Black List              : "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Editing contatore fornitori in Black List   *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ctr-fbl    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per contatore elementi            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Fornitori Black List            : "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       emi-fil-seq-mns-880.
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio Non residenti           *
      *                  *---------------------------------------------*
           if        w-tot-gen-ctr-cnr    =    zero and
                     w-tot-gen-ctr-fnr    =    zero
                     go to emi-fil-seq-mns-890.
      *                  *---------------------------------------------*
      *                  * Editing contatore clienti Non residenti     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ctr-cnr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per contatore elementi            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Clienti non residenti           : "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Editing contatore fornitori Non residenti   *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ctr-fnr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Messaggio per contatore elementi            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Fornitori non residenti         : "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       emi-fil-seq-mns-890.
      *                  *---------------------------------------------*
