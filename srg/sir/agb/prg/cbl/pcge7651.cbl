       emi-fil-seq-mns-999.
           exit.

      *    *===========================================================*
      *    * Routines per il trattamento del file [ouf] per la compo-  *
      *    * sizione del file di supporto in formato MS-DOS            *
      *    *-----------------------------------------------------------*
       ouf-fil-det-000.
      *              *=================================================*
      *              * Determinazione name e pathname completo per il  *
      *              * file [ouf]                                      *
      *              *-------------------------------------------------*
       ouf-fil-det-100.
      *                  *---------------------------------------------*
      *                  * File name                                   *
      *                  *---------------------------------------------*
           move      "ouf "               to   f-ouf-nam              .
       ouf-fil-det-200.
      *                  *---------------------------------------------*
      *                  * File pathname                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Pathname di base da segreteria          *
      *                      *-----------------------------------------*
           move      "PB"                 to   s-ope                  .
           move      "asc "               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                          using s                     .
      *                      *-----------------------------------------*
      *                      * Anno di riferimento                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      rr-ann-fis           to   p-num                  .
           add       1900                 to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-ecf-mns-bbb-adr      .
      *                      *-----------------------------------------*
      *                      * Composizione di una stringa composta    *
      *                      * come segue :                            *
      *                      *                                         *
      *                      * 99999999999_AAAA.nsp                    *
      *                      *-----------------------------------------*
           move      spaces               to   w-det-pth-fso-nam      .
           string    rf-ada-prt-iva
                                delimited by   size
                     "_"   
                                delimited by   size
                     p-edt   
                                delimited by   spaces
                     ".nsp"   
                                delimited by   size
                                          into w-det-pth-fso-nam      .
      *                      *-----------------------------------------*
      *                      * Pathname completo sotto /abd/asc        *
      *                      *-----------------------------------------*
           move      spaces               to   f-ouf-pat              .
      *
           string    s-pat      delimited by   spaces
                     "/cbi/"    delimited by   size
                     w-det-pth-fso-nam
                                delimited by   spaces
                                          into f-ouf-pat              .
       ouf-fil-det-300.
      *                  *---------------------------------------------*
      *                  * File status                                 *
      *                  *---------------------------------------------*
           move      "00"                 to   f-ouf-sts              .
       ouf-fil-det-999.
           exit.
       ouf-fil-opo-000.
      *              *-------------------------------------------------*
      *              * Open output file [ouf]                          *
      *              *-------------------------------------------------*
           open      output ouf                                       .
       ouf-fil-opo-999.
           exit.
       ouf-fil-cls-000.
      *              *=================================================*
      *              * Close file [ouf]                                *
      *              *-------------------------------------------------*
           close     ouf                                              .
       ouf-fil-cls-100.
      *              *-------------------------------------------------*
      *              * Completamento del file [ouf] con il carattere   *
      *              * di fine-file x'1A'                              *
      *              *-------------------------------------------------*
       ouf-fil-cls-110.
      *                  *---------------------------------------------*
      *                  * File name per [0u2]                         *
      *                  *---------------------------------------------*
           move      "0u2 "               to   f-ou2-nam              .
      *                  *---------------------------------------------*
      *                  * File pathname per [0u2]                     *
      *                  *---------------------------------------------*
           move      f-ouf-pat            to   f-ou2-pat              .
      *                  *---------------------------------------------*
      *                  * File status per [0u2]                       *
      *                  *---------------------------------------------*
           move      "00"                 to   f-ou2-sts              .
       ouf-fil-cls-120.
      *                  *---------------------------------------------*
      *                  * Open Extend file [ou2]                      *
      *                  *---------------------------------------------*
           open      extend ou2                                       .
       ouf-fil-cls-130.
      *                  *---------------------------------------------*
      *                  * Soppressione carattere di 'EOF'             *
      *                  *---------------------------------------------*
           go to     ouf-fil-cls-140.
      *                  *---------------------------------------------*
      *                  * Scrittura file [ou2]                        *
      *                  *---------------------------------------------*
           move      x'1A'                to   ou2-chr                .
           write     ou2-rec                                          .
       ouf-fil-cls-140.
      *                  *---------------------------------------------*
      *                  * Close file [ou2]                            *
      *                  *---------------------------------------------*
           close     ou2                                              .
       ouf-fil-cls-999.
           exit.
       ouf-fil-wrt-000.
      *              *=================================================*
      *              * Write file [ouf]                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento con carattere CR              *
      *                  *---------------------------------------------*
           move      x'0D'                to   ouf-crx                .
      *                  *---------------------------------------------*
      *                  * Completamento con carattere LF              *
      *                  *---------------------------------------------*
           move      x'0A'                to   ouf-lfx                .
      *                  *---------------------------------------------*
      *                  * Scrittura effettiva                         *
      *                  *---------------------------------------------*
           write     ouf-rec                                          .
       ouf-fil-wrt-999.
           exit.

      *    *===========================================================*
      *    * Generazione archivio di supporto come definito dallo      *
      *    * Standard ministeriale                                     *
      *    *                                                           *
      *    * Record di testa 'A'                                       *
      *    *-----------------------------------------------------------*
       mns-aaa-ecf-000.
      *              *-------------------------------------------------*
