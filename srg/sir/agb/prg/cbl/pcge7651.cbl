      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      all "-"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Release                                     *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Versione 04/04/2017 - 10:00 - (SIRI)"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Separatore                                  *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      all "-"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
