      *                  * - 'N' : colonna Non imponibili              *
      *                  * - 'E' : colonna Esenti                      *
      *                  * - 'Z' : colonna iva non esposta             *
      *                  * - 'X' : non compare in elenchi              *
      *                  *---------------------------------------------*
           if        rf-zci-flg-ecf       =    "I" or
                     rf-zci-flg-ecf       =    "N" or
                     rf-zci-flg-ecf       =    "E" or
                     rf-zci-flg-ecf       =    "Z"
