      *              *-------------------------------------------------*
           if        w-stp-edt-val-val    =    zero
                     move  "               0"
                                          to   w-stp-edt-val-edt
                     go to stp-edt-val-900.
       stp-edt-val-200.
      *              *-------------------------------------------------*
      *              * Arrotondamento importo                          *
      *              *-------------------------------------------------*
           divide    100                  into w-stp-edt-val-val
                                        giving w-stp-edt-val-arr
                                       rounded                        .
      *              *-------------------------------------------------*
      *              * Editing valore arrotondato                      *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      13                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-stp-edt-val-arr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * In campo di uscita                              *
      *              *-------------------------------------------------*
           move      p-edt                to   w-stp-edt-val-edt      .
       stp-edt-val-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
