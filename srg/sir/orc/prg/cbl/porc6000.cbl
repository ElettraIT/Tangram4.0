      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da effettuare               *
      *                          *-------------------------------------*
           if        rr-snx-fgc           not  = 2
                     go to det-buf-ass-180.
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-bds-ctr-002        not  = 2
                     go to det-buf-ass-180.
      *                      *-----------------------------------------*
      *                      * Trattamento secondo elemento            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tests su elemento '1'               *
      *                          *-------------------------------------*
           if        w-bds-dat-dsp (01)   not  = zero
                     go to det-buf-ass-180.
           if        w-bds-qta-dsp (01)   =    zero
                     go to det-buf-ass-180.
           if        w-bds-qta-res (01)   =    zero
                     go to det-buf-ass-180.
           if        w-bds-prt-orf (01)   not  = zero
                     go to det-buf-ass-180.
           if        w-bds-prt-orf (01)   not  = zero
                     go to det-buf-ass-180.
      *                          *-------------------------------------*
      *                          * Se la giacenza e' utilizzabile, si  *
      *                          * assegna su di essa                  *
      *                          *-------------------------------------*
           move      01                   to   w-bds-ctr-002          .
      *                          *-------------------------------------*
      *                          * Riaggancio                          *
      *                          *-------------------------------------*
           go to     det-buf-ass-190.
      *                          *-------------------------------------*
      *                          * ___ test ___  end                   *
      *                          *-------------------------------------*
       det-buf-ass-180.
      *                      *-----------------------------------------*
      *                      * Se quantita' residua dell'elemento a    *
      *                      * zero, si passa al precedente            *
      *                      *-----------------------------------------*
           if        w-bds-qta-res
                    (w-bds-ctr-002)       =    zero
                     go to det-buf-ass-160.
       det-buf-ass-190.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' utilizzabile   *
      *                      * dell'elemento                           *
      *                      *-----------------------------------------*
           if        w-det-buf-ass-wqa    >    w-bds-qta-res
                                              (w-bds-ctr-002)
                     move  w-bds-qta-res
                          (w-bds-ctr-002) to   w-det-buf-ass-wqu
           else      move  w-det-buf-ass-wqa
                                          to   w-det-buf-ass-wqu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer delle *
      *                      * disponibilita'                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           add       w-det-buf-ass-wqu    to   w-bds-qta-ass
                                              (w-bds-ctr-002)         .
      *                          *-------------------------------------*
