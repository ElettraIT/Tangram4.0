      *    *-----------------------------------------------------------*
       pre-exe-pgm-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-exe-pgm      .
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Determinazione codice dipendenza in uso         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura della variabile eventuale di i.p.c. *
      *                  * per il codice dipendenza                    *
      *                  *---------------------------------------------*
           perform   ipc-cod-dpz-000      thru ipc-cod-dpz-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-ipc-cod-dpz-snx    not  = "S"
                     go to pre-exe-pgm-100.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valore                  *
      *                      *-----------------------------------------*
           move      w-ipc-cod-dpz-val    to   rr-dpz-inu             .
      *                      *-----------------------------------------*
      *                      * A lettura personalizzazioni             *
      *                      *-----------------------------------------*
           go to     pre-exe-pgm-200.
       pre-exe-pgm-100.
