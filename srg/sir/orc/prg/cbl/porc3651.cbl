       int-fin-rie-300.
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      034                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      002                  to   p-pos                  .
           move      w-int-fin-rie-pmt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-fin-rie-600.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Separatore per riepilogo                        *
      *              *-------------------------------------------------*
           perform   fin-sep-rie-000      thru fin-sep-rie-999        .
       int-fin-rie-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
