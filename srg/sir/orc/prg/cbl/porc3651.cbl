      *    *===========================================================*
      *    * Griglia vuota per il riepilogo                            *
      *    *-----------------------------------------------------------*
       gri-vuo-rie-000.
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "|                                  |           |  
      -              "         |           |           |           |    
      -              "       |           |           |"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       gri-vuo-rie-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [ocx]                         *
      *    *-----------------------------------------------------------*
       let-arc-ocx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ocx-flg      .
      *              *-------------------------------------------------*
      *              * Test se codici nulli                            *
      *              *-------------------------------------------------*
           if        w-let-arc-ocx-prt    =    zero   or
                     w-let-arc-ocx-prg    =    zero   or
                     w-let-arc-ocx-trc    =    zero
                     go to let-arc-ocx-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-let-arc-ocx-prt    to   rf-ocx-num-prt         .
           move      w-let-arc-ocx-prg    to   rf-ocx-num-prg         .
           move      w-let-arc-ocx-trc    to   rf-ocx-tip-rec         .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-ocx-400.
       let-arc-ocx-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-ocx-des-400       to   w-let-arc-ocx-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-ocx-999.
       let-arc-ocx-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-ocx-flg      .
           move      spaces               to   w-let-arc-ocx-des      .
           move      all   "."            to   w-let-arc-ocx-drg (1)  .
           go to     let-arc-ocx-999.
       let-arc-ocx-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ocx-des      .
       let-arc-ocx-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [dcp] e [pdx]                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcp/prg/cpy/ldcppdx0.lts"                   .

      *    *===========================================================*
      *    * Determinazione descrizione riga ordine                    *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [ocr] relativo alla riga ordine cliente a  *
      *    *      disposizione in rf-ocr                               *
      *    *                                                           *
      *    *    - Record di [dcc] relativo alla riga ordine cliente    *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-det-des-rig-des : Descrizione riga ordine          *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di estensione   *
      *              *-------------------------------------------------*
           if        rf-ocr-des-ext       =    0
                     go to det-des-rig-100
           else if   rf-ocr-des-ext       =    1
                     go to det-des-rig-200
           else if   rf-ocr-des-ext       =    2
                     go to det-des-rig-300.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione : bufferizzazione descri- *
      *              * zione contenuta nel record [ocr]                *
      *              *-------------------------------------------------*
           move      rf-ocr-des-rig       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-200.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [ocx]                    *
      *              *-------------------------------------------------*
           move      rf-ocr-num-prt       to   w-let-arc-ocx-prt      .
           move      rf-ocr-num-prg       to   w-let-arc-ocx-prg      .
           move      11                   to   w-let-arc-ocx-trc      .
           perform   let-arc-ocx-000      thru let-arc-ocx-999        .
           move      w-let-arc-ocx-des    to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rf-ocr-num-pro       to   w-let-dcp-pdx-cod      .
           move      "C"                  to   w-let-dcp-pdx-tar      .
           move      rf-ocr-cod-arc       to   w-let-dcp-pdx-arc      .
           move      rf-ocr-cod-lng       to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
           move      w-let-dcp-pdx-des    to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-aav = Ammontare da convertire, espres- *
      *    *                          so nell'altra valuta             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-avb = Ammontare convertito, espresso   *
      *    *                          nella valuta base                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta base ad altra valuta     *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-avb = Ammontare da convertire, espres- *
      *    *                          so nella valuta base             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-aav = Ammontare convertito, espresso   *
      *    *                          nell'altra valuta                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Determinazione quantita' evasa                            *
      *    *-----------------------------------------------------------*
       det-qta-eva-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      rf-ocr-qta-ord       to   d-qev-roc-qta-ord      .
           move      zero                 to   d-qev-roc-qta-gsp      .
           move      zero                 to   d-qev-roc-qta-ics      .
           move      d-qev-roc-qta-ord    to   w-qta-dev-qta-dev      .
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
       det-qta-eva-100.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' evasa riga ordine      *
      *              *-------------------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           move      w-tot-dat-rif        to   d-qev-roc-dat-rif      .
           move      "pgm/orc/prg/obj/dqevroc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-roc
                                               rf-ocr                 .
       det-qta-eva-200.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' evasa riga ordine      *
      *              * senza tenere conto della quantita' in ordini    *
      *              * di spedizione                                   *
      *              *-------------------------------------------------*
           move      d-qev-roc-qta-ord    to   w-qta-dev-qta-dev      .
           subtract  d-qev-roc-qta-gsp    from w-qta-dev-qta-dev      .
           if        w-qta-dev-qta-dev    <    zero
                     move  zero           to   w-qta-dev-qta-dev      .
       det-qta-eva-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qta-eva-999.
       det-qta-eva-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo residuo nella valuta di fattura-   *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       det-imp-res-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-res-ipr      .
       det-imp-res-200.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "A"
                     move  rf-ocr-imp-rig to   w-det-imp-res-ipr
                     go to det-imp-res-900.
      *                  *---------------------------------------------*
      *                  * Se altro tipo riga                          *
      *                  *---------------------------------------------*
       det-imp-res-300.
      *                      *-----------------------------------------*
      *                      * Importo residuo                         *
      *                      *-----------------------------------------*
           if        rf-ocr-flg-puq       not  = "K"
                     go to det-imp-res-320.
           divide    1000                 into w-qta-dev-qta-dev
                                        giving w-qta-dev-qta-dew      .
           multiply  w-qta-dev-qta-dew    by   w-det-imp-res-prz
                                        giving w-det-imp-res-ipr      .
           go to     det-imp-res-330.
       det-imp-res-320.
           multiply  w-qta-dev-qta-dev    by   w-det-imp-res-prz
                                        giving w-det-imp-res-ipr      .
           go to     det-imp-res-330.
       det-imp-res-330.
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ocr-dec-prz       =    1
                     divide 10            into w-det-imp-res-ipr
           else if   rf-ocr-dec-prz       =    2
                     divide 100           into w-det-imp-res-ipr      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione nella valuta di   *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-ocr-sgl-vpp       =    rf-ocr-sgl-vpf
                     go to det-imp-res-900.
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per il prezzo                    *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpp       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpp       to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpp to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta per   *
      *                          * il prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-det-imp-res-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta base  *
      *                          * a valuta per fatturazione           *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                          *-------------------------------------*
      *                          * Bufferizzazione del risultato       *
      *                          *-------------------------------------*
           move      w-cvs-vlt-aav        to   w-det-imp-res-ipr      .
       det-imp-res-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-imp-res-999.
       det-imp-res-999.
           exit.

      *    *===========================================================*
      *    * Determinazione costo di riferimento per il prodotto       *
      *    *-----------------------------------------------------------*
       det-cos-rif-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-cos-rif-svc      .
           move      zero                 to   w-det-cos-rif-dvc      .
           move      zero                 to   w-det-cos-rif-dec      .
           move      zero                 to   w-det-cos-rif-cdr      .
           move      spaces               to   w-det-cos-rif-svl      .
           move      zero                 to   w-det-cos-rif-crl      .
           move      zero                 to   w-det-cos-rif-pll      .
       det-cos-rif-100.
      *              *-------------------------------------------------*
      *              * Tentativo di determinazione con combinazione    *
      *              * fornitore/prodotto [aaf]                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * A determinazione tramite costo ultimo       *
      *                  *                                             *
      *                  * (Guido e Norina - marzo 2003)               *
      *                  *---------------------------------------------*
           go to     det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaq]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaq-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a determinazione    *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Se fornitore preferenziale per il prodotto  *
      *                  * a zero : a determinazione costo medio pon-  *
      *                  * derato                                      *
      *                  *---------------------------------------------*
           if        rf-aaq-dcf-pfz       =    zero
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaf]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRFNFM"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaf-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaf-num-pro         .
           move      rf-aaq-dcf-pfz       to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : : a determinazione  *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      01                   to   w-det-cos-rif-tde      .
           move      rf-aaf-sgl-vlt       to   w-det-cos-rif-svc      .
           move      rf-aaf-dec-vlt       to   w-det-cos-rif-dvc      .
           move      rf-aaf-dec-prz       to   w-det-cos-rif-dec      .
           move      rf-aaf-prz-pes (1)   to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Legame valutario                            *
      *                  *---------------------------------------------*
           if        rf-aaf-lgv-vlt       not  = spaces
                     move  rf-aaf-lgv-vlt to   w-det-cos-rif-svl
                     move  rf-aaf-lgv-tdc to   w-det-cos-rif-tcl
                     move  rf-aaf-lgv-cdc to   w-det-cos-rif-crl
                     move  rf-aaf-lgv-pdt to   w-det-cos-rif-pll      .
      *                  *---------------------------------------------*
      *                  * Test se per il prezzo di acquisto e' pre-   *
      *                  * visto la trasformazione di unita' di misura *
      *                  * per il prezzo                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se prezzo relativo a quantita'     *
      *                      *-----------------------------------------*
           if        rf-aaf-snx-tum       not  = "P"
                     go to det-cos-rif-490.
      *                      *-----------------------------------------*
      *                      * Test se la riga in corso di trattamento *
      *                      * prevede anch'essa lo stesso meccanismo  *
      *                      * dei prezzi per 1000                     *
      *                      *-----------------------------------------*
           if        w-prn-liv-det-puq    =    "K"
                     go to det-cos-rif-490.
      *                      *-----------------------------------------*
      *                      * Ritaratura del coefficiente di cambio:  *
      *                      * presumendo che il prezzo di acquisto a  *
      *                      * cui si fa riferimento, del fornitore,   *
      *                      * sia espresso in una valuta diversa      *
      *                      * ___ da sistemare ___                    *
      *                      *-----------------------------------------*
           divide    1000                 into w-det-cos-rif-cdr      .
       det-cos-rif-490.
      *                  *---------------------------------------------*
