      -              "---------+-----------+-----------+-----------+----
      -              "-------+-----------+-----------+"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fin-sep-rie-999.
           exit.

      *    *===========================================================*
      *    * Fincatura per il riepilogo                                *
      *    *-----------------------------------------------------------*
       int-fin-rie-000.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Separatore per riepilogo                        *
      *              *-------------------------------------------------*
           perform   fin-sep-rie-000      thru fin-sep-rie-999        .
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-fin-rie-100.
      *              *-------------------------------------------------*
      *              * Fincatura                                       *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "|                                  |v.ord.mese |va
      -              "l.scaduto|v.evas.30gg|v.evas.60gg|v.evas.90gg|v.ev
      -              ".120 gg|v.ev.oltre |  Totale   |"
