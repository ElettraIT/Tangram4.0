      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *                                                           *
      *    * Subroutine di aggiornamento totali                        *
      *    *-----------------------------------------------------------*
       prn-liv-det-agt-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento totali ordine                     *
      *              *-------------------------------------------------*
       prn-liv-det-agt-050.
      *                  *---------------------------------------------*
      *                  * Totale costi                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se necessario il ricalcolo         *
      *                      *-----------------------------------------*
           if        srt-cos-rif          not  = zero
                     move  srt-cos-rif    to   w-det-ric-cos-cos
                     go to prn-liv-det-agt-051.
      *                      *-----------------------------------------*
      *                      * Determinazione costo di riferimento     *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-cos-rif-dtb      .
           move      01                   to   w-det-cos-rif-tpm      .
           move      srt-num-pro          to   w-det-cos-rif-cnm      .
           perform   det-cos-rif-000      thru det-cos-rif-999        .
           move      w-det-cos-rif-cdr    to   w-det-ric-cos-cos      .
       prn-liv-det-agt-051.
      *                      *-----------------------------------------*
      *                      * Determinazione costi per la riga da     *
      *                      * cumulare                                *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-imp-res-cos      .
           multiply  srt-qta-dev          by   w-det-ric-cos-cos
                                        giving w-det-imp-res-cos      .
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        srt-dec-cos          =    1
                     divide 10            into w-det-imp-res-cos
           else if   srt-dec-cos          =    2
                     divide 100           into w-det-imp-res-cos      .
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento se prezzo per   *
      *                      * 1000                                    *
      *                      *-----------------------------------------*
           if        srt-flg-puq          =    "K"
                     divide 1000          into w-det-imp-res-cos      .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che il costo       *
      *                      * sia in valuta base o no                 *
      *                      *-----------------------------------------*
           if        srt-sgl-vpc          =    c-sgl
                     go to prn-liv-det-agt-052
           else      go to prn-liv-det-agt-054.
       prn-liv-det-agt-052.
      *                      *-----------------------------------------*
      *                      * Se costo in valuta base                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento totale costo in va-   *
      *                          * luta base                           *
      *                          *-------------------------------------*
           add       w-det-imp-res-cos    to   w-tot-ord-tcs          .
           go to     prn-liv-det-agt-100.
       prn-liv-det-agt-054.
      *                      *-----------------------------------------*
      *                      * Se costo in valuta                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per il costo                     *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      srt-sgl-vpc          to   w-coe-cmb-vlt-sdv      .
           move      srt-tdc-vpc          to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  srt-cdc-vpc    to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Determinazione importo costo riga   *
      *                          * in valuta base                      *
      *                          *-------------------------------------*
           move      srt-sgl-vpc          to   w-cvs-vlt-sgl          .
           move      srt-dec-vpc          to   w-cvs-vlt-dec          .
           move      srt-tdc-vpc          to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-det-imp-res-cos    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale costi in va-   *
      *                          * luta base                           *
      *                          *-------------------------------------*
           add       w-cvs-vlt-avb        to   w-tot-ord-tcs          .
           go to     prn-liv-det-agt-100.
       prn-liv-det-agt-100.
      *                  *---------------------------------------------*
      *                  * Totali ordine in valuta base e non          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che il documento   *
      *                      * sia in valuta base o no                 *
      *                      *-----------------------------------------*
           if        srt-sgl-vpf          =    c-sgl
                     go to prn-liv-det-agt-152
           else      go to prn-liv-det-agt-154.
       prn-liv-det-agt-152.
      *                      *-----------------------------------------*
      *                      * Se ordine in valuta base                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento totale ordine in va-  *
      *                          * luta base                           *
      *                          *-------------------------------------*
           add       srt-imp-rvb          to   w-tot-ord-tot          .
           go to     prn-liv-det-agt-300.
       prn-liv-det-agt-154.
      *                      *-----------------------------------------*
      *                      * Se documento in valuta                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento totale documento in   *
      *                          * valuta                              *
      *                          *-------------------------------------*
           add       srt-imp-res          to   w-tot-ord-tiv          .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      srt-sgl-vpf          to   w-coe-cmb-vlt-sdv      .
           move      srt-tdc-vpf          to   w-coe-cmb-vlt-tdc      .
           move      w-tot-dat-rif        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  srt-cdc-vpf    to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Determinazione importo residuo riga *
      *                          * in valuta base                      *
      *                          *-------------------------------------*
           move      srt-sgl-vpf          to   w-cvs-vlt-sgl          .
           move      srt-dec-vpf          to   w-cvs-vlt-dec          .
           move      srt-tdc-vpf          to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      srt-imp-res          to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale ordine in va-  *
      *                          * luta base                           *
      *                          *-------------------------------------*
           add       w-cvs-vlt-avb        to   w-tot-ord-tot          .
           go to     prn-liv-det-agt-300.
       prn-liv-det-agt-300.
      *              *-------------------------------------------------*
      *              * Aggiornamento dei totali di riepilogo           *
      *              *-------------------------------------------------*
       prn-liv-det-agt-320.
      *                  *---------------------------------------------*
      *                  * Ordinato mese in corso                      *
      *                  *                                             *
      *                  * N.B. : Avviene a livello di rottura per la  *
      *                  *        testata ordine cliente               *
      *                  *---------------------------------------------*
       prn-liv-det-agt-360.
      *                  *---------------------------------------------*
      *                  * Inevaso scaduto                             *
      *                  *---------------------------------------------*
           if        srt-dcn-ric          >    w-tot-dat-sca
                     go to prn-liv-det-agt-400.
           add       srt-imp-rvb          to   w-tot-cli-sca          .
       prn-liv-det-agt-400.
      *                  *---------------------------------------------*
      *                  * Inevaso a 30 gg.                            *
      *                  *---------------------------------------------*
           if        srt-dcn-ric          <    w-tot-dat-i02 or
                     srt-dcn-ric          >    w-tot-dat-f02
                     go to prn-liv-det-agt-440.
           add       srt-imp-rvb          to   w-tot-cli-030          .
       prn-liv-det-agt-440.
      *                  *---------------------------------------------*
      *                  * Inevaso a 60 gg.                            *
      *                  *---------------------------------------------*
           if        srt-dcn-ric          <    w-tot-dat-i03 or
                     srt-dcn-ric          >    w-tot-dat-f03
                     go to prn-liv-det-agt-480.
           add       srt-imp-rvb          to   w-tot-cli-060          .
       prn-liv-det-agt-480.
      *                  *---------------------------------------------*
      *                  * Inevaso a 90 gg.                            *
      *                  *---------------------------------------------*
           if        srt-dcn-ric          <    w-tot-dat-i04 or
                     srt-dcn-ric          >    w-tot-dat-f04
                     go to prn-liv-det-agt-520.
           add       srt-imp-rvb          to   w-tot-cli-090          .
       prn-liv-det-agt-520.
      *                  *---------------------------------------------*
      *                  * Inevaso a 120 gg.                           *
      *                  *---------------------------------------------*
           if        srt-dcn-ric          <    w-tot-dat-i05 or
                     srt-dcn-ric          >    w-tot-dat-f05
                     go to prn-liv-det-agt-600.
           add       srt-imp-rvb          to   w-tot-cli-120          .
       prn-liv-det-agt-600.
      *                  *---------------------------------------------*
      *                  * Inevaso futuro                              *
      *                  *---------------------------------------------*
           if        srt-dcn-ric          <    w-tot-dat-fut
                     go to prn-liv-det-agt-900.
           add       srt-imp-rvb          to   w-tot-cli-fut          .
       prn-liv-det-agt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-agt-999.
       prn-liv-det-agt-999.
           exit.

