      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su [oft] per fornitore                    *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      rr-dpz-inu           to   rf-oft-cod-dpz         .
           move      "F"                  to   rf-oft-tip-arc         .
           move      rr-cod-fnt           to   rf-oft-cod-arc         .
           move      rr-dem-min           to   rf-oft-dat-doc         .
           move      zero                 to   rf-oft-num-doc         .
           move      zero                 to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [oft]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-oft-cod-dpz       not  = rr-dpz-inu or
                     rf-oft-tip-arc       not  = "F"        or
                     rf-oft-cod-arc       not  = rr-cod-fnt
                     go to int-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Test su data emissione massima              *
      *                  *---------------------------------------------*
           if        rr-dem-max           =    zero
                     go to int-srt-inp-122
           else      go to int-srt-inp-124.
       int-srt-inp-122.
      *                      *-----------------------------------------*
      *                      * Se data emissione massima a zero        *
      *                      *-----------------------------------------*
           if        rr-dem-min           =    zero
                     go to int-srt-inp-130.
           if        rf-oft-dat-doc       >    rr-dem-min
                     go to int-srt-inp-900.
           go to     int-srt-inp-130.
       int-srt-inp-124.
      *                      *-----------------------------------------*
      *                      * Se data emissione massima non zero      *
      *                      *-----------------------------------------*
           if        rf-oft-dat-doc       >    rr-dem-max
                     go to int-srt-inp-900.
           go to     int-srt-inp-130.
       int-srt-inp-130.
      *              *-------------------------------------------------*
      *              * Fine test sul massimo                           *
      *              *-------------------------------------------------*
       int-srt-inp-140.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su flag di ordine chiuso          *
      *                  *---------------------------------------------*
           if        rr-sel-rof           =    01   and
                     rf-oft-flg-och       not  = spaces
                     go to int-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Selezione su dipendenza del fornitore       *
      *                  *---------------------------------------------*
           if        rr-dpz-fnt           =    "*   "
                     go to int-srt-inp-150.
           if        rf-oft-dpz-arc       not  = rr-dpz-fnt
                     go to int-srt-inp-100.
       int-srt-inp-150.
      *                  *---------------------------------------------*
      *                  * Selezione su numero ordine                  *
      *                  *---------------------------------------------*
           if        rr-ord-rof           not  = 01
                     go to int-srt-inp-160.
      *                      *-----------------------------------------*
      *                      * Test su numero ordine minimo            *
      *                      *-----------------------------------------*
           if        rf-oft-num-doc       <    rr-nof-min
                     go to int-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che il numero or-  *
      *                      * dine massimo sia a zero o no            *
      *                      *-----------------------------------------*
           if        rr-nof-max           =    zero
                     go to int-srt-inp-152
           else      go to int-srt-inp-154.
       int-srt-inp-152.
      *                      *-----------------------------------------*
      *                      * Se numero ordine massimo a zero         *
      *                      *-----------------------------------------*
           if        rr-nof-min           =    zero
                     go to int-srt-inp-160.
           if        rf-oft-num-doc       >    rr-nof-min
                     go to int-srt-inp-100.
           go to     int-srt-inp-160.
       int-srt-inp-154.
      *                      *-----------------------------------------*
      *                      * Se numero ordine massimo non zero       *
      *                      *-----------------------------------------*
           if        rf-oft-num-doc       >    rr-nof-max
                     go to int-srt-inp-100.
           go to     int-srt-inp-160.
       int-srt-inp-160.
      *              *-------------------------------------------------*
      *              * Fine selezioni sul record                       *
      *              *-------------------------------------------------*
       int-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Start su file [ofr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-oft-num-prt       to   rf-ofr-num-prt         .
           move      zero                 to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-500.
       int-srt-inp-220.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ofr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ofr-num-prt       not  = rf-oft-num-prt
                     go to int-srt-inp-500.
       int-srt-inp-240.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [ofr]                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga in comodo ridefinito              *
      *                  *---------------------------------------------*
           move      rf-ofr-tip-rig       to   w-int-srt-inp-wtr      .
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        w-int-srt-inp-wtp    not  = "P" or
                     w-int-srt-inp-wtf    not  = spaces
                     go to int-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Selezione su data consegna richiesta        *
      *                  *---------------------------------------------*
           if        rr-ord-rof           not  = 02
                     go to int-srt-inp-250.
      *                      *-----------------------------------------*
      *                      * Su data consegna richiesta minima       *
      *                      *-----------------------------------------*
           if        rf-ofr-dcn-ric       <    rr-dcn-min
                     go to int-srt-inp-220.
      *                      *-----------------------------------------*
      *                      * Su data consegna richiesta massima      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione a seconda che la data    *
      *                          * consegna richiesta massima sia a    *
      *                          * zero o no                           *
      *                          *-------------------------------------*
           if        rr-dcn-max           =    zero
                     go to int-srt-inp-242
           else      go to int-srt-inp-244.
       int-srt-inp-242.
      *                          *-------------------------------------*
      *                          * Se data consegna richiesta massima  *
      *                          * a zero                              *
      *                          *-------------------------------------*
           if        rr-dcn-min           =    zero
                     go to int-srt-inp-250.
           if        rf-ofr-dcn-ric       >    rr-dcn-min
                     go to int-srt-inp-220.
           go to     int-srt-inp-250.
       int-srt-inp-244.
      *                          *-------------------------------------*
      *                          * Se data consegna richiesta massima  *
      *                          * non a zero                          *
      *                          *-------------------------------------*
           if        rf-ofr-dcn-ric       >    rr-dcn-max
                     go to int-srt-inp-220.
           go to     int-srt-inp-250.
       int-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rf-ofr-num-mag       to   w-let-arc-dcp-cod      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Selezione su descrizione prodotto           *
      *                  *---------------------------------------------*
           if        rr-ord-rof           not  = 03
                     go to int-srt-inp-260.
           if        w-let-arc-dcp-flg    not  = spaces
                     go to int-srt-inp-220.
      *                      *-----------------------------------------*
      *                      * Test su descrizione minima              *
      *                      *-----------------------------------------*
           if        w-let-arc-dcp-dsk    <    rr-des-min
                     go to int-srt-inp-220.
      *                      *-----------------------------------------*
      *                      * Test su data consegna richiesta         *
      *                      *-----------------------------------------*
           if        rf-ofr-dcn-ric       <    rr-dcr-opd
                     go to int-srt-inp-220.
       int-srt-inp-260.
      *                  *---------------------------------------------*
      *                  * Selezione su status righe ordine fornitore  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' da ricevere    *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-qev-rof-tip-ope      .
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-rof
                                               rf-ofr                 .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dello status righe *
      *                      * ordine richiesto                        *
      *                      *-----------------------------------------*
           if        rr-sel-rof           =    01
                     go to int-srt-inp-262
           else if   rr-sel-rof           =    02
                     go to int-srt-inp-264
           else if   rr-sel-rof           =    03
                     go to int-srt-inp-266.
       int-srt-inp-262.
      *                      *-----------------------------------------*
      *                      * Status righe : Solo quelle inevase      *
      *                      *-----------------------------------------*
           if        d-qev-rof-qta-dri    =    zero
                     go to int-srt-inp-220.
           go to     int-srt-inp-270.
       int-srt-inp-264.
      *                      *-----------------------------------------*
      *                      * Status righe : Solo quelle evase        *
      *                      *-----------------------------------------*
           if        d-qev-rof-qta-dri    >    zero
                     go to int-srt-inp-220.
           go to     int-srt-inp-270.
       int-srt-inp-266.
      *                      *-----------------------------------------*
      *                      * Status righe : Tutte                    *
      *                      *-----------------------------------------*
           go to     int-srt-inp-270.
       int-srt-inp-270.
      *              *-------------------------------------------------*
      *              * Fine selezioni sul record [ofr]                 *
      *              *-------------------------------------------------*
       int-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo ordina- *
      *                      * mento richiesto                         *
      *                      *-----------------------------------------*
           if        rr-ord-rof           =    01
                     go to int-srt-inp-302
           else if   rr-ord-rof           =    02
                     go to int-srt-inp-304
           else if   rr-ord-rof           =    03
                     go to int-srt-inp-306.
       int-srt-inp-302.
      *                      *-----------------------------------------*
      *                      * Tipo ordinamento : Numero ordine        *
      *                      *-----------------------------------------*
           move      rf-ofr-num-doc       to   srt-nof-key            .
           move      spaces               to   srt-dep-key            .
           move      zero                 to   srt-dcr-key            .
           go to     int-srt-inp-310.
       int-srt-inp-304.
      *                      *-----------------------------------------*
      *                      * Tipo ordinamento : Data consegna ri-    *
      *                      * chiesta                                 *
      *                      *-----------------------------------------*
           move      zero                 to   srt-nof-key            .
           move      spaces               to   srt-dep-key            .
           move      rf-ofr-dcn-ric       to   srt-dcr-key            .
           go to     int-srt-inp-310.
       int-srt-inp-306.
      *                      *-----------------------------------------*
      *                      * Tipo ordinamento : Descrizione prodotto *
      *                      * e data consegna richiesta               *
      *                      *-----------------------------------------*
           move      zero                 to   srt-nof-key            .
           move      w-let-arc-dcp-dsk    to   srt-dep-key            .
           move      rf-ofr-dcn-ric       to   srt-dcr-key            .
           go to     int-srt-inp-310.
       int-srt-inp-310.
      *                      *-----------------------------------------*
      *                      * Altri elementi della chiave             *
      *                      *-----------------------------------------*
           move      rf-ofr-num-prt       to   srt-num-prt            .
           move      rf-ofr-num-prg       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-ofr-num-mag       to   srt-num-mag            .
           move      rf-ofr-alf-mag       to   srt-alf-mag            .
           move      w-let-arc-dcp-des    to   srt-des-pro            .
           move      rf-ofr-qta-ord       to   srt-qta-ord            .
           move      d-qev-rof-qta-ric    to   srt-qta-ric            .
           add       d-qev-rof-qta-icr    to   srt-qta-ric            .
           move      rf-ofr-dcn-ric       to   srt-dcn-ric            .
           move      rf-ofr-fds-dcr       to   srt-fds-dcr            .
           move      rf-ofr-dcn-prv       to   srt-dcn-prv            .
           move      rf-ofr-flg-cnf       to   srt-flg-cnf            .
       int-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [ofr]     *
      *              *-------------------------------------------------*
           go to     int-srt-inp-220.
       int-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [oft]     *
      *              *-------------------------------------------------*
           go to     int-srt-inp-100.
       int-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-999.
       int-srt-inp-999.
           exit.

