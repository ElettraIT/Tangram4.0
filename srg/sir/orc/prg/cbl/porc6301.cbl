      *    *===========================================================*
      *    * Determinazione costo di riferimento per il prodotto       *
      *    *-----------------------------------------------------------*
       det-cos-rif-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-cos-rif-svc      .
           move      zero                 to   w-det-cos-rif-dvc      .
           move      zero                 to   w-det-cos-rif-dec      .
           move      zero                 to   w-det-cos-rif-cdr      .
           move      spaces               to   w-det-cos-rif-svl      .
           move      zero                 to   w-det-cos-rif-crl      .
           move      zero                 to   w-det-cos-rif-pll      .
       det-cos-rif-100.
      *              *-------------------------------------------------*
      *              * Tentativo di determinazione con combinazione    *
      *              * fornitore/prodotto [aaf]                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * A determinazione tramite costo ultimo       *
      *                  *                                             *
      *                  * (Guido e Norina - marzo 2003)               *
      *                  *---------------------------------------------*
           go to     det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaq]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaq-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a determinazione    *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Se fornitore preferenziale per il prodotto  *
      *                  * a zero : a determinazione costo medio pon-  *
      *                  * derato                                      *
      *                  *---------------------------------------------*
           if        rf-aaq-dcf-pfz       =    zero
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaf]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRFNFM"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaf-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaf-num-pro         .
           move      rf-aaq-dcf-pfz       to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : : a determinazione  *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      01                   to   w-det-cos-rif-tde      .
           move      rf-aaf-sgl-vlt       to   w-det-cos-rif-svc      .
           move      rf-aaf-dec-vlt       to   w-det-cos-rif-dvc      .
           move      rf-aaf-dec-prz       to   w-det-cos-rif-dec      .
           move      rf-aaf-prz-pes (1)   to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Legame valutario                            *
      *                  *---------------------------------------------*
           if        rf-aaf-lgv-vlt       not  = spaces
                     move  rf-aaf-lgv-vlt to   w-det-cos-rif-svl
                     move  rf-aaf-lgv-tdc to   w-det-cos-rif-tcl
                     move  rf-aaf-lgv-cdc to   w-det-cos-rif-crl
                     move  rf-aaf-lgv-pdt to   w-det-cos-rif-pll      .
      *                  *---------------------------------------------*
      *                  * Test se per il prezzo di acquisto e' pre-   *
      *                  * visto la trasformazione di unita' di misura *
      *                  * per il prezzo                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se prezzo relativo a quantita'     *
      *                      *-----------------------------------------*
           if        rf-aaf-snx-tum       not  = "P"
                     go to det-cos-rif-490.
      *                      *-----------------------------------------*
      *                      * Test se la riga in corso di trattamento *
      *                      * prevede anch'essa lo stesso meccanismo  *
      *                      * dei prezzi per 1000                     *
      *                      *-----------------------------------------*
           if        srt-flg-puq          =    "K"
                     go to det-cos-rif-490.
      *                      *-----------------------------------------*
      *                      * Ritaratura del coefficiente di cambio:  *
      *                      * presumendo che il prezzo di acquisto a  *
      *                      * cui si fa riferimento, del fornitore,   *
      *                      * sia espresso in una valuta diversa      *
      *                      * ___ da sistemare ___                    *
      *                      *-----------------------------------------*
           divide    1000                 into w-det-cos-rif-cdr      .
       det-cos-rif-490.
      *                  *---------------------------------------------*
      *                  * Se legame valutario non esistente : a de-   *
      *                  * terminazione costo medio continuo           *
      *                  *---------------------------------------------*
           if        rf-aaf-lgv-vlt       =    spaces
                     go to det-cos-rif-500.
       det-cos-rif-492.
      *                  *---------------------------------------------*
      *                  * Valorizzazione del prezzo con legame valu-  *
      *                  * tario al cambio della data documento        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione coefficiente di cambio   *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-aaf-lgv-vlt       to   w-coe-cmb-vlt-sdv      .
           move      rf-aaf-lgv-tdc       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to det-cos-rif-494.
           move      w-det-cos-rif-crl    to   w-coe-cmb-vlt-cdc      .
       det-cos-rif-494.
      *                      *-----------------------------------------*
      *                      * Determinazione prezzo sottoposto a le-  *
      *                      * game valutario                          *
      *                      *-----------------------------------------*
           move      w-det-cos-rif-cdr    to   w-lvl-prz-prz          .
           move      rf-aaf-lgv-vlt       to   w-lvl-prz-vlt          .
           move      rf-aaf-lgv-tdc       to   w-lvl-prz-tdc          .
           move      rf-aaf-lgv-cdc       to   w-lvl-prz-ccr          .
           move      w-coe-cmb-vlt-cdc    to   w-lvl-prz-cdc          .
           move      rf-aaf-lgv-pdt       to   w-lvl-prz-plm          .
           if        rf-aaf-lgv-pdt       =    zero
                     move  spaces         to   w-lvl-prz-tlm
           else      move  "T"            to   w-lvl-prz-tlm          .
           perform   lvl-prz-det-000      thru lvl-prz-det-999        .
           move      w-lvl-prz-prz        to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-500.
      *              *-------------------------------------------------*
      *              * Determinazione con costo medio ponderato        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-det-cos-rif-cdr    not  = zero
                     go to det-cos-rif-999.
      *                  *---------------------------------------------*
      *                  * Richiamo modulo di magazzino                *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0002                 to   d-vun-mag-tip-val      .
           move      w-det-cos-rif-dtb    to   d-vun-mag-dat-val      .
           move      w-det-cos-rif-tpm    to   d-vun-mag-tip-mag      .
           move      w-det-cos-rif-cnm    to   d-vun-mag-num-mag      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      02                   to   w-det-cos-rif-tde      .
           move      c-sgl                to   w-det-cos-rif-svc      .
           move      c-dec                to   w-det-cos-rif-dvc      .
           move      02                   to   w-det-cos-rif-dec      .
           move      d-vun-mag-val-uni    to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Test se la riga in corso di trattamento     *
      *                  * prevede il meccanismo dei prezzi per 1000   *
      *                  *---------------------------------------------*
           if        srt-flg-puq          not  = "K"
                     go to det-cos-rif-590.
      *                  *---------------------------------------------*
      *                  * Ritaratura del costo di riferimento         *
      *                  *---------------------------------------------*
           multiply  1000                 by   w-det-cos-rif-cdr      .
       det-cos-rif-590.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-999.
           exit.

      *    *===========================================================*
      *    * Determinazione dati conferma ordine a fornitore           *
      *    *-----------------------------------------------------------*
       det-cnf-orf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-cnf-orf-flg      .
       det-cnf-orf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [ofr]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *              *-------------------------------------------------*
      *              * Lettura record [ofr]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ocp-prt-orf       to   rf-ofr-num-prt         .
           move      rf-ocp-prg-orf       to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cnf-orf-900.
       det-cnf-orf-300.
      *              *-------------------------------------------------*
      *              * Flag di conferma                                *
      *              *-------------------------------------------------*
           move      rf-ofr-flg-cnf       to   w-det-cnf-orf-flg      .
       det-cnf-orf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-cnf-orf-999.
       det-cnf-orf-999.
           exit.

