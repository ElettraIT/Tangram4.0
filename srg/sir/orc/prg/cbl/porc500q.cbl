      *                  * Determinazione numero giorni utilizzati     *
      *                  *---------------------------------------------*
       det-dat-nrg-120.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che sia il primo   *
      *                      * passaggio o no                          *
      *                      *-----------------------------------------*
           if        w-det-dat-nrg-fpp    =    spaces
                     go to det-dat-nrg-122
           else      go to det-dat-nrg-124.
       det-dat-nrg-122.
      *                      *-----------------------------------------*
      *                      * Primo passaggio                         *
      *                      *-----------------------------------------*
           move      "#"                  to   w-det-dat-nrg-fpp      .
           subtract  w-det-dat-nrg-dbg    from w-det-dat-nrg-dig
                                        giving w-det-dat-nrg-ngu      .
           go to     det-dat-nrg-130.
       det-dat-nrg-124.
      *                      *-----------------------------------------*
      *                      * Passaggio successivo al primo           *
      *                      *-----------------------------------------*
           move      w-det-dat-nrg-dig    to   w-det-dat-nrg-ngu      .
           go to     det-dat-nrg-130.
       det-dat-nrg-130.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivo giorni utilizzati *
      *                  *---------------------------------------------*
           add       w-det-dat-nrg-ngu    to   w-det-dat-nrg-pgu      .
      *                  *---------------------------------------------*
      *                  * Se progressivo giorni utilizzati superiore  *
      *                  * al numero giorni di incremento richiesti :  *
      *                  * a fine ciclo                                *
      *                  *---------------------------------------------*
           if        w-det-dat-nrg-pgu    not  < w-det-dat-nrg-ngi
                     go to det-dat-nrg-150.
      *                  *---------------------------------------------*
      *                  * Incremento mese/anno                        *
      *                  *---------------------------------------------*
           add       1                    to   w-det-dat-nrg-dim      .
           if        w-det-dat-nrg-dim    >    12
                     move  1              to   w-det-dat-nrg-dim
                     add   1              to   w-det-dat-nrg-dia      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-dat-nrg-100.
       det-dat-nrg-150.
      *              *-------------------------------------------------*
      *              * Fine ciclo                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero giorni in esubero ri- *
      *                  * spetto a quelli richiesti                   *
      *                  *---------------------------------------------*
           subtract  w-det-dat-nrg-ngi    from w-det-dat-nrg-pgu
                                        giving w-det-dat-nrg-ngu      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento giorno della data incrementa- *
      *                  * ta                                          *
      *                  *---------------------------------------------*
           subtract  w-det-dat-nrg-ngu    from w-det-dat-nrg-dig      .
       det-dat-nrg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' di fabbisogno/disponibilita' da  *
      *    * visualizzare nell'interrogazione                          *
      *    *-----------------------------------------------------------*
       det-qfd-dav-000.
      *              *-------------------------------------------------*
      *              * Determinazione giacenza                         *
      *              *-------------------------------------------------*
           move      d-buf-fod-qta-gia    to   w-det-qfd-dav-gia      .
       det-qfd-dav-100.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' alla   *
      *              * data nr. 1                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data nr. 1 superiore alla data consegna  *
      *                  * prevista dell'ultimo elemento : bufferizza- *
      *                  * zione quantita' dell'ultimo elemento        *
      *                  *---------------------------------------------*
           if        w-det-qfd-dav-dt1    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd1
                     go to det-qfd-dav-200.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer delle quantita'   *
      *                  * di fabbisogno/disponibilita'                *
      *                  *---------------------------------------------*
           move      1                    to   d-buf-fod-ctr-001      .
       det-qfd-dav-120.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001    >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd1
                     go to det-qfd-dav-200.
      *                      *-----------------------------------------*
      *                      * Finche' la data nr. 1 e' superiore alla *
      *                      * data consegna prevista dell'elemento :  *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt1    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-120.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt1    <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-fd1      .
       det-qfd-dav-200.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' alla   *
      *              * data nr. 2                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data nr. 2 superiore alla data consegna  *
      *                  * prevista dell'ultimo elemento : bufferizza- *
      *                  * zione quantita' dell'ultimo elemento        *
      *                  *---------------------------------------------*
           if        w-det-qfd-dav-dt2    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd2
                     go to det-qfd-dav-300.
      *                  *---------------------------------------------*
      *                  * Continuazione scansione buffer delle quan-  *
      *                  * tita' di fabbisogno/disponibilita'          *
      *                  *---------------------------------------------*
       det-qfd-dav-220.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001    >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd2
                     go to det-qfd-dav-300.
      *                      *-----------------------------------------*
      *                      * Finche' la data nr. 2 e' superiore alla *
      *                      * data consegna prevista dell'elemento :  *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt2    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-220.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt2    <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-fd2      .
       det-qfd-dav-300.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' alla   *
      *              * data nr. 3                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data nr. 3 superiore alla data consegna  *
      *                  * prevista dell'ultimo elemento : bufferizza- *
      *                  * zione quantita' dell'ultimo elemento        *
      *                  *---------------------------------------------*
           if        w-det-qfd-dav-dt3    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd3
                     go to det-qfd-dav-400.
      *                  *---------------------------------------------*
      *                  * Continuazione scansione buffer delle quan-  *
      *                  * tita' di fabbisogno/disponibilita'          *
      *                  *---------------------------------------------*
       det-qfd-dav-320.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001        >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd3
                     go to det-qfd-dav-400.
      *                      *-----------------------------------------*
      *                      * Finche' la data nr. 3 e' superiore alla *
      *                      * data consegna prevista dell'elemento :  *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt3    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-320.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt3    <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-fd3      .
       det-qfd-dav-400.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' oltre  *
      *              * la data nr. 3                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione quantita' di fabbisogno/di- *
      *                  * sponibilita' dell'ultimo elemento           *
      *                  *---------------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-num-ele)   to   w-det-qfd-dav-fd4      .
       det-qfd-dav-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qfd-dav-999.
       det-qfd-dav-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

