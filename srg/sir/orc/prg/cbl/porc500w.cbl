      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        w-prn-fat-pre        >    999999999 or
                     w-prn-fat-pre        <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-prn-fat-pre        >    999999999 or
                     w-prn-fat-pre        <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
