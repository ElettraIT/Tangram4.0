           move      08                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      61                   to   p-pos                  .
           move      spaces               to   p-alf                  .
           string    "Ft.'"
                                delimited by   size
                     w-prn-saa-pan
                                delimited by   size
                     " :"
                                delimited by   size
                                          into p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
