      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [mms]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DPMGDS    "         to   f-key                  .
           move      w-det-scm-mes-wes    to   rf-mms-ann-ese         .
           move      w-det-scm-mes-dpz    to   rf-mms-cod-dpz         .
           move      w-det-scm-mes-tpm    to   rf-mms-tip-mag         .
           move      w-det-scm-mes-cnm    to   rf-mms-num-mag         .
           move      spaces               to   rf-mms-var-mag
           move      spaces               to   rf-mms-cod-dsl         .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
