      *    *===========================================================*
      *    * Determinazione costo di riferimento per il prodotto       *
      *    *-----------------------------------------------------------*
       det-cos-rif-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cos-rif-tde      .
           move      spaces               to   w-det-cos-rif-svc      .
           move      zero                 to   w-det-cos-rif-dvc      .
           move      zero                 to   w-det-cos-rif-dec      .
           move      zero                 to   w-det-cos-rif-cdr      .
           move      spaces               to   w-det-cos-rif-svl      .
           move      spaces               to   w-det-cos-rif-tcl      .
           move      zero                 to   w-det-cos-rif-crl      .
           move      zero                 to   w-det-cos-rif-pll      .
           move      spaces               to   w-det-cos-rif-pnp      .
      *              *-------------------------------------------------*
      *              * Tentativo di determinazione con combinazione    *
      *              * fornitore/prodotto [aaf]                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [aaq]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaq-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a determinazione    *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Memorizzazione part-number                  *
      *                  *---------------------------------------------*
           move      rf-aaq-cdp-pdt       to   w-det-cos-rif-pnp      .
      *                  *---------------------------------------------*
      *                  * Se fornitore preferenziale per il prodotto  *
      *                  * a zero : a determinazione costo medio con-  *
      *                  * tinuo                                       *
      *                  *---------------------------------------------*
           if        rf-aaq-dcf-pfz       =    zero
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Lettura record [aaf]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRFNFM"             to   f-key                  .
           move      w-det-cos-rif-tpm    to   rf-aaf-tip-mag         .
           move      w-det-cos-rif-cnm    to   rf-aaf-num-pro         .
           move      rf-aaq-dcf-pfz       to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : : a determinazione  *
      *                  * costo medio continuo                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cos-rif-500.
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      01                   to   w-det-cos-rif-tde      .
           move      rf-aaf-sgl-vlt       to   w-det-cos-rif-svc      .
           move      rf-aaf-dec-vlt       to   w-det-cos-rif-dvc      .
           move      rf-aaf-dec-prz       to   w-det-cos-rif-dec      .
           move      rf-aaf-prz-pes (1)   to   w-det-cos-rif-cdr      .
           if        rf-aaf-lgv-vlt       not  = spaces
                     move  rf-aaf-lgv-vlt to   w-det-cos-rif-svl
                     move  rf-aaf-lgv-tdc to   w-det-cos-rif-tcl
                     move  rf-aaf-lgv-cdc to   w-det-cos-rif-crl
                     move  rf-aaf-lgv-pdt to   w-det-cos-rif-pll      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-500.
      *              *-------------------------------------------------*
      *              * Determinazione con costo medio continuo         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo modulo di magazzino                *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0005                 to   d-vun-mag-tip-val      .
           move      w-det-cos-rif-dtb    to   d-vun-mag-dat-val      .
           move      w-det-cos-rif-tpm    to   d-vun-mag-tip-mag      .
           move      w-det-cos-rif-cnm    to   d-vun-mag-num-mag      .
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
      *                  *---------------------------------------------*
      *                  * Preparazione valori in uscita               *
      *                  *---------------------------------------------*
           move      02                   to   w-det-cos-rif-tde      .
           move      c-sgl                to   w-det-cos-rif-svc      .
           move      c-dec                to   w-det-cos-rif-dvc      .
           move      02                   to   w-det-cos-rif-dec      .
           move      d-vun-mag-val-uni    to   w-det-cos-rif-cdr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cos-rif-999.
       det-cos-rif-999.
           exit.

