           move      "DT"                 to   d-prm-ubi-tip-ope      .
           move      rf-ocr-cod-dpz       to   d-prm-ubi-cod-dpz      .
           move      01                   to   d-prm-ubi-tip-mag      .
           move      rf-ocr-num-pro       to   d-prm-ubi-num-mag      .
           move      rf-ocr-sgl-vrn       to   d-prm-ubi-var-mag      .
           perform   det-prm-ubi-cll-000  thru det-prm-ubi-cll-999    .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione ubicazione              *
      *                      *-----------------------------------------*
           move      d-prm-ubi-ubi-lit    to   w-rig-key-ubi-11
                                              (w-rig-num-ele)         .
       stp-cor-doc-obk-140.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-cor-doc-obk-900.
       stp-cor-doc-obk-900.
      *              *-------------------------------------------------*
      *              * Preparazione dati di ordinamento                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione progressivo riga            *
      *                  *---------------------------------------------*
           move      rf-ocr-num-prg       to   w-rig-dti-prg
                                              (w-rig-num-ele)         .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-cor-doc-obk-999.
       stp-cor-doc-obk-999.
           exit.

      *    *===========================================================*
      *    * Stampa corpo documento                                    *
      *    *                                                           *
      *    * Subroutine per la stampa del codice prodotto              *
      *    *-----------------------------------------------------------*
       stp-cor-doc-cpr-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se tipo prodotto P,M,S e V             *
      *                  *---------------------------------------------*
           if        w-tip-rig-tpr        not  = "P" and
                     w-tip-rig-tpr        not  = "M" and
                     w-tip-rig-tpr        not  = "S" and
                     w-tip-rig-tpr        not  = "V"
                     go to stp-cor-doc-cpr-900.
      *                  *---------------------------------------------*
      *                  * Se tipo prodotto P : solo se tipo funziona- *
      *                  * mento a spazi                               *
      *                  *---------------------------------------------*
           if        w-tip-rig-tpr        =    "P"  and
                     w-tip-rig-tfu        not  = spaces
                     go to stp-cor-doc-cpr-900.
      *                  *---------------------------------------------*
      *                  * Solo se tipo modulo lo prevede              *
      *                  *---------------------------------------------*
           if        w-prs-soc-tmd        =    01
                     go to stp-cor-doc-cpr-900.
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpc-cod-pro-pos    =    zero
                     go to stp-cor-doc-cpr-900.
       stp-cor-doc-cpr-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore da stampare              *
      *              *-------------------------------------------------*
           move      rf-ocr-alf-pro       to   w-stp-cor-alf-pro      .
       stp-cor-doc-cpr-200.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della personalizzazione  *
      *              * relativa al codice da stampare nella colonna    *
      *              * apposita                                        *
      *              *-------------------------------------------------*
           if        w-prs-soc-cds        =    "C"
                     go to stp-cor-doc-cpr-400.
       stp-cor-doc-cpr-300.
      *              *-------------------------------------------------*
      *              * Se codice nostro : nessuna ulteriore azione     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * A stampa del codice preparato               *
      *                  *---------------------------------------------*
           go to     stp-cor-doc-cpr-600.
       stp-cor-doc-cpr-400.
      *              *-------------------------------------------------*
      *              * Se codice del cliente : preparazione            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo archivio non e' 'C' : a stampa   *
      *                  * del nostro codice                           *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-arc       not  = "C"
                     go to stp-cor-doc-cpr-600.
      *                  *---------------------------------------------*
      *                  * Se il codice per il cliente e' a spaces : a *
      *                  * stampa del nostro codice                    *
      *                  *---------------------------------------------*
           if        rf-ocr-cop-scl       =    spaces
                     go to stp-cor-doc-cpr-600.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione del codice per il cliente   *
      *                  *---------------------------------------------*
           move      rf-ocr-cop-scl       to   w-stp-cor-alf-pro      .
      *                  *---------------------------------------------*
      *                  * A stampa del codice preparato               *
      *                  *---------------------------------------------*
           go to     stp-cor-doc-cpr-600.
       stp-cor-doc-cpr-600.
      *              *-------------------------------------------------*
      *              * Stampa del codice preparato                     *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-cod-pro-pos    to   p-pos                  .
           move      w-stp-cor-alf-pro    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-cor-doc-cpr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-cor-doc-cpr-999.
       stp-cor-doc-cpr-999.
           exit.

      *    *===========================================================*
      *    * Stampa corpo documento                                    *
      *    *                                                           *
      *    * Subroutine per la stampa quantita'                        *
      *    *-----------------------------------------------------------*
       stp-cor-doc-qta-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se tipo prodotto P,M,S,V               *
      *                  *---------------------------------------------*
           if        w-tip-rig-tpr        not  = "P" and
                     w-tip-rig-tpr        not  = "M" and
                     w-tip-rig-tpr        not  = "S" and
                     w-tip-rig-tpr        not  = "V"
                     go to stp-cor-doc-qta-900.
      *                  *---------------------------------------------*
      *                  * Solo se tipo esposizione riga lo consente   *
      *                  *---------------------------------------------*
           if        rf-ocr-epz-rgf       =    1 or
                     rf-ocr-epz-rgf       =    2
                     go to stp-cor-doc-qta-100
           else if   rf-ocr-epz-rgf       =    3
                     go to stp-cor-doc-qta-900
           else      if     rf-ocr-qta-ord
                                          =    1,000
                            go to stp-cor-doc-qta-900.
       stp-cor-doc-qta-100.
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpc-qta-ord-pos    =    zero
                     go to stp-cor-doc-qta-900.
       stp-cor-doc-qta-200.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sulla personalizzazione che indica la  *
      *                  * richiesta di allineamento a destra della    *
      *                  * quantita'                                   *
      *                  *---------------------------------------------*
           if        w-prs-soc-snq        not  = "S"
                     go to stp-cor-doc-qta-400.
       stp-cor-doc-qta-300.
      *                  *---------------------------------------------*
      *                  * Se quantita' allineata a destra             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing preliminare della quantita'     *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      rf-ocr-dec-qta       to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "<GBD"               to   p-edm                  .
           move      rf-ocr-qta-ord       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Allineamento a destra quantita'         *
      *                      *-----------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      p-edt                to   w-all-str-alf          .
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                      *-----------------------------------------*
      *                      * Stampa quantita' allineata a destra     *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-qta-ord-pos    to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-qta-900.
       stp-cor-doc-qta-400.
      *                  *---------------------------------------------*
      *                  * Se quantita' normale                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *                                         *
      *                      * SIRI                                    *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      spaces               to   p-msk                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-qta-ord-pos    to   p-pos                  .
           move      rf-ocr-qta-ord       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-qta-900.
       stp-cor-doc-qta-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-cor-doc-qta-999.
       stp-cor-doc-qta-999.
           exit.

      *    *===========================================================*
      *    * Stampa corpo documento                                    *
      *    *                                                           *
      *    * Subroutine per la stampa della data consegna              *
      *    *-----------------------------------------------------------*
       stp-cor-doc-dcn-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se previsto dalle personalizzazioni    *
      *                  *---------------------------------------------*
           if        w-prs-soc-tor        not  = "01"
                     go to stp-cor-doc-dcn-900.
      *                  *---------------------------------------------*
      *                  * Solo se tipo prodotto P,M,S,A               *
      *                  *---------------------------------------------*
           if        w-tip-rig-tpr        not  = "P" and
                     w-tip-rig-tpr        not  = "M" and
                     w-tip-rig-tpr        not  = "S" and
                     w-tip-rig-tpr        not  = "V" and
                     w-tip-rig-tpr        not  = "A"
                     go to stp-cor-doc-dcn-900.
      *                  *---------------------------------------------*
      *                  * Solo se tipo movimento lo prevede           *
      *                  *---------------------------------------------*
           if        rf-zoc-snx-dtc       not  = 01
                     go to stp-cor-doc-dcn-900.
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpc-dat-cns-pos    =    zero
                     go to stp-cor-doc-dcn-900.
      *                  *---------------------------------------------*
      *                  * Preparazione della data da stampare in fun- *
      *                  * zione delle personalizzazioni               *
      *                  *---------------------------------------------*
           if        w-prs-soc-dds        =    "R"
                     move  rf-ocr-dcn-ric to   w-dat-cns-dat
           else      move  rf-ocr-dcn-prv to   w-dat-cns-dat          .
      *                  *---------------------------------------------*
      *                  * Test se valore esistente                    *
      *                  *---------------------------------------------*
           if        w-dat-cns-dat        =   zero
                     go to stp-cor-doc-dcn-900.
       stp-cor-doc-dcn-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del formato di stampa    *
      *              * richiesto o se urgente                          *
      *              *-------------------------------------------------*
           if        w-dat-cns-dat        =   rf-oct-dat-doc
                     go to stp-cor-doc-dcn-080
           else if   rf-oct-fds-dtc       =   01
                     go to stp-cor-doc-dcn-100
           else if   rf-oct-fds-dtc       =   02
                     go to stp-cor-doc-dcn-200
           else if   rf-oct-fds-dtc       =   03
                     go to stp-cor-doc-dcn-300
           else if   rf-oct-fds-dtc       =   04
                     go to stp-cor-doc-dcn-400
           else      go to stp-cor-doc-dcn-100.
       stp-cor-doc-dcn-080.
      *                  *---------------------------------------------*
      *                  * Se data consegna prevista uguale alla data  *
      *                  * documento                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Literal in funzione delle personalizza- *
      *                      * zioni                                   *
      *                      *-----------------------------------------*
           if        w-prs-soc-dcp        =    "U"
                     move  " Urgente"     to   w-dat-cns-edt
           else if   w-prs-soc-dcp        =    "A"
                     move  "A.S.A.P."     to   w-dat-cns-edt
           else      go to stp-cor-doc-dcn-100.
      *                      *-----------------------------------------*
      *                      * A stampa data consegna in riga          *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-dcn-800.
       stp-cor-doc-dcn-100.
      *                  *---------------------------------------------*
      *                  * Formato di stampa richiesto : gg/mm/aa      *
      *                  *---------------------------------------------*
