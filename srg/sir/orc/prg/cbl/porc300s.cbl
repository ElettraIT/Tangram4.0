      *              * Deviazione in funzione delle personalizzazioni  *
      *              *-------------------------------------------------*
           if        w-prs-soc-tor        =    "01"
                     go to stp-cor-doc-obk-010
           else if   w-prs-soc-tor        =    "11"
                     go to stp-cor-doc-obk-110
           else      go to stp-cor-doc-obk-010.
       stp-cor-doc-obk-010.
      *              *-------------------------------------------------*
      *              * Se ordinamento per progressivo riga             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione chiave di ordinamento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione progressivo riga        *
      *                      *-----------------------------------------*
           move      rf-ocr-num-prg       to   w-rig-key-prg-01
                                              (w-rig-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-cor-doc-obk-900.
       stp-cor-doc-obk-110.
      *              *-------------------------------------------------*
      *              * Se ordinamento per ubicazione per precorso      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione chiave di ordinamento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo riga non "P"                    *
      *                      *-----------------------------------------*
           if        w-ctl-tip-rig-chr (1)
                                          =    "P"
                     go to stp-cor-doc-obk-120.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione ubicazione              *
      *                      *-----------------------------------------*
           move      all "z"              to   w-rig-key-ubi-11
                                              (w-rig-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-cor-doc-obk-140.
       stp-cor-doc-obk-120.
      *                      *-----------------------------------------*
