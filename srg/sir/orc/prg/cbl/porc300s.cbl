      *    *-----------------------------------------------------------*
       stp-tes-doc-000.
      *              *-------------------------------------------------*
      *              * Tipo documento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpt-tmo-orc-lin    =   zero or
                     w-lpt-tmo-orc-pos    =   zero
                     go to stp-tes-doc-050.
      *                  *---------------------------------------------*
      *                  * Lettura record [zoc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTOC    "         to   f-key                  .
           move      rf-oct-tmo-orc       to   rf-zoc-cod-toc         .
           move      "pgm/orc/fls/ioc/obj/iofzoc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zoc                 .
           if        f-sts                not  = e-not-err
                     go to stp-tes-doc-050.
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nel caso di documento in lingua, si     *
      *                      * sostituisce la descrizione tipo movi-   *
      *                      * mento per la stampa con quello in lin-  *
      *                      * gua                                     *
      *                      *-----------------------------------------*
           if        rf-oct-cod-lng       not  = "I  " and
                     w-stp-coc-des (01)   not  = spaces
                     move  w-stp-coc-des (01)
                                          to   rf-zoc-des-stp         .
      *                      *-----------------------------------------*
      *                      * Determinazione lunghezza stringa        *
      *                      *-----------------------------------------*
           move      zero                 to   w-stp-tes-ctr          .
           inspect   rf-zoc-des-stp   tallying w-stp-tes-ctr
                                  for trailing spaces                 .
           subtract  w-stp-tes-ctr        from 25
                                        giving w-stp-tes-wsz          .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-tes-wsz        to   p-car                  .
           move      w-lpt-tmo-orc-lin    to   p-lin                  .
           divide    2                    into w-stp-tes-ctr
                                        giving p-pos                  .
           add       w-lpt-tmo-orc-pos    to   p-pos                  .
           move      rf-zoc-des-stp       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tes-doc-050.
