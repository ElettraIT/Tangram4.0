      *              *-------------------------------------------------*
           if        rf-ocr-per-scr (1)   =    zero and
                     rf-ocr-per-scr (2)   =    zero and
                     rf-ocr-per-scr (3)   =    zero and
                     rf-ocr-per-scr (4)   =    zero and
                     rf-ocr-per-scr (5)   =    zero
                     go to stp-cor-doc-ras-900.
       stp-cor-doc-ras-100.
      *              *-------------------------------------------------*
      *              * Test su righe corpo residue                     *
      *              *-------------------------------------------------*
           if        p-lnr                <    w-lpc-ult-rig-lin
                     go to stp-cor-doc-ras-200.
      *                  *---------------------------------------------*
      *                  * Reintestazione documento                    *
      *                  *---------------------------------------------*
           perform   rei-mod-tes-000      thru rei-mod-tes-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to stp-cor-doc-ras-200.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     stp-cor-doc-ras-900.
       stp-cor-doc-ras-200.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo per 5 %                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-azi-lux-ctr      .
       stp-cor-doc-ras-220.
           add       1                    to   w-det-azi-lux-ctr      .
           if        w-det-azi-lux-ctr    >    5
                     go to stp-cor-doc-ras-400.
           if        rf-ocr-per-scr
                    (w-det-azi-lux-ctr)   =    zero
                     go to stp-cor-doc-ras-400.
      *                  *---------------------------------------------*
      *                  * Se primo passaggio                          *
      *                  *---------------------------------------------*
           if        w-det-azi-lux-ctr    =    1
                     move  "Sconto :"     to   w-all-str-cat (1)
                     move  spaces         to   w-all-str-cat (2)
           else      move  w-all-str-alf  to   w-all-str-cat (1)
                     move  "+"            to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
      *                  * Editing %                                   *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      01                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BD"                to   p-edm                  .
           move      rf-ocr-per-scr
                    (w-det-azi-lux-ctr)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      p-edt                to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     stp-cor-doc-ras-220.
       stp-cor-doc-ras-400.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-des-pro-pos    to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-cor-doc-ras-900.
      *              *-------------------------------------------------*
