                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-cor-doc-pcr-900.
       stp-cor-doc-pcr-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ocr-num-prt       not  = w-rig-num-prt
                     go to stp-cor-doc-pcr-900.
       stp-cor-doc-pcr-400.
       stp-cor-doc-pcr-500.
      *              *-------------------------------------------------*
