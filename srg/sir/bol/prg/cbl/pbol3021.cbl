      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di stampa       *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-010
           else      go to stp-srt-inp-020.
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Start su archivio [bit] per data registrazione  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-ini           to   rf-bit-dat-doc         .
           move      zero                 to   rf-bit-cod-dpz         .
           move      zero                 to   rf-bit-num-doc         .
           move      spaces               to   rf-bit-cod-tmb         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-020.
      *              *-------------------------------------------------*
      *              * Start su archivio [bit] per data ultima modifi- *
      *              * ca                                              *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATSYS    "         to   f-key                  .
           move      rr-dat-ini           to   rf-bit-ide-dat         .
           move      zero                 to   rf-bit-dat-doc         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Read-next su archivio [bit]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di stampa   *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-210
           else      go to stp-srt-inp-220.
       stp-srt-inp-210.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-bit-dat-doc       >    rr-dat-fin
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Test su data ultima modifica                *
      *                  *---------------------------------------------*
           if        rf-bit-ide-dat       >    rr-dat-fin
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record [bit]                  *
      *                  *---------------------------------------------*
       stp-srt-inp-310.
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza : se diverso, *
      *                      * a riciclo                               *
      *                      *-----------------------------------------*
           if        rf-bit-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-100.
       stp-srt-inp-320.
      *                      *-----------------------------------------*
      *                      * Test su codice utente                   *
      *                      *-----------------------------------------*
           if        rr-cod-ute           =    spaces
                     go to stp-srt-inp-330.
           if        rf-bit-ide-ute       not  = rr-cod-ute
                     go to stp-srt-inp-100.
       stp-srt-inp-330.
      *                      *-----------------------------------------*
      *                      * Test su codice fase                     *
      *                      *-----------------------------------------*
           if        rr-cod-fas           =    spaces
                     go to stp-srt-inp-340.
           if        rf-bit-ide-fas       not  = rr-cod-fas
                     go to stp-srt-inp-100.
       stp-srt-inp-340.
      *                      *-----------------------------------------*
      *                      * Test su codice tipo movimento           *
      *                      *-----------------------------------------*
           if        rr-cod-tmb           =    spaces
                     go to stp-srt-inp-500.
           if        rf-bit-cod-tmb       not  = rr-cod-tmb
                     go to stp-srt-inp-100.
       stp-srt-inp-500.
