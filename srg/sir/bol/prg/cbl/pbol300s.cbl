           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-lpt-dat-doc-lin    to   p-lin                  .
           move      w-lpt-dat-doc-pos    to   p-pos                  .
           move      rf-bit-dat-doc       to   p-dat                  .
