      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing numero bolla                        *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-bit-num-doc       to   w-wrk-num-011          .
           move      w-wrk-num-011-prg    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Informazioni generali da segreteria         *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Preparazione path                           *
      *                  *---------------------------------------------*
           move      spaces               to   w-det-pth-fso-pat      .
           string    "/abd/asc/"
                                delimited by   size
                     s-ute      delimited by   spaces
                     "/pdf/out/BV"
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-det-pth-fso-pat      .
