                                        giving w-det-pos-stp-coe      .
           go to     det-pos-stp-330.
       det-pos-stp-330.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Campi testata                           *
      *                      *-----------------------------------------*
           multiply  w-det-pos-stp-coe    by   w-lpt-cod-tmb-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-num-doc-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-dat-doc-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-cod-fis-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-prt-iva-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-int-rag-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-int-via-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-int-loc-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-inl-rag-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-inl-ra2-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-inl-via-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-inl-loc-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-des-age-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpt-des-dpz-pos      .
      *                      *-----------------------------------------*
      *                      * Campi corpo                             *
      *                      *-----------------------------------------*
           multiply  w-det-pos-stp-coe    by   w-lpc-rif-ocl-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-cod-pro-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-des-pro-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-qta-ven-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-umi-ven-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-prz-ven-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-per-scr-pos (1)  .
           multiply  w-det-pos-stp-coe    by   w-lpc-per-scr-pos (2)  .
           multiply  w-det-pos-stp-coe    by   w-lpc-per-scr-pos (3)  .
           multiply  w-det-pos-stp-coe    by   w-lpc-per-scr-pos (4)  .
           multiply  w-det-pos-stp-coe    by   w-lpc-per-scr-pos (5)  .
           multiply  w-det-pos-stp-coe    by   w-lpc-imp-rig-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-cod-iva-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpc-des-dct-pos      .
      *                      *-----------------------------------------*
      *                      * Campi piede                             *
      *                      *-----------------------------------------*
           multiply  w-det-pos-stp-coe    by   w-lpp-des-fop-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-cod-abi-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-des-abi-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-cod-cab-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-des-cab-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-ccc-app-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-str-acc-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-lit-seg-pos      .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-ibl-pos (1)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-ibl-pos (2)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-ibl-pos (3)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-ibl-pos (4)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-ibl-pos (5)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-ibl-pos (6)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-cod-pos (1)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-cod-pos (2)  .
           multiply  w-det-pos-stp-coe    by   w-lpp-iva-cod-pos (3)  .
