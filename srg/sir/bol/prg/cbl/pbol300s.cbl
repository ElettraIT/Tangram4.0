      *                      *-----------------------------------------*
           move      10                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      w-wrk-dat-gio        to   w-all-str-cat (1)      .
           move      "/"                  to   w-all-str-cat (2)      .
           move      w-wrk-dat-mes        to   w-all-str-cat (3)      .
           move      "/"                  to   w-all-str-cat (4)      .
           move      w-wrk-dat-ann        to   w-all-str-cat (5)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-out-bol-dat-doc      .
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Il giorno dopo alla consegna            *
      *                      *-----------------------------------------*
           move      rf-bir-dat-doc       to   w-det-dat-nrg-dtb      .
           move      1                    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
