           move      "N"                  to   w-prs-gep-snx          .
       prs-gep-snx-999.
           exit.

      *    *===========================================================*
      *    * Lettura personalizzazione : Stampa bolla                  *
      *    *-----------------------------------------------------------*
       prs-stp-bol-000.
      *              *-------------------------------------------------*
      *              * Lettura personalizzazione                       *
      *              *-------------------------------------------------*
           move      "P:"                 to   s-ope                  .
           move      "pgm/bol/mov/bol300s[stp-bol]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Se personalizzazione non esistente              *
      *              *-------------------------------------------------*
           if        s-ves                =    spaces
                     go to prs-stp-bol-050.
      *                  *---------------------------------------------*
      *                  * Normalizzazione al valore di default        *
      *                  *---------------------------------------------*
           move      01                   to   w-prs-stb-tmd          .
           move      "N"                  to   w-prs-stb-snv (1)      .
           move      "N"                  to   w-prs-stb-snv (2)      .
           move      "N"                  to   w-prs-stb-snv (3)      .
           move      "N"                  to   w-prs-stb-snv (4)      .
           move      "N"                  to   w-prs-stb-snv (5)      .
           move      "N"                  to   w-prs-stb-snv (6)      .
           move      "N"                  to   w-prs-stb-snq          .
           move      "N"                  to   w-prs-stb-sng          .
           move      zero                 to   w-prs-stb-gn1          .
           move      zero                 to   w-prs-stb-gn2          .
           move      "N"                  to   w-prs-stb-sno          .
           move      "N"                  to   w-prs-stb-snl          .
           move      "N"                  to   w-prs-cds-pro          .
           move      "N"                  to   w-prs-snx-rac          .
           move      "N"                  to   w-prs-snx-tel          .
           move      00                   to   w-prs-stb-diz          .
           move      "S"                  to   w-prs-snx-tdc          .
           move      "N"                  to   w-prs-snx-rnc          .
           move      "N"                  to   w-prs-stb-lsr          .
           move      "N"                  to   w-prs-stb-ipf          .
           move      spaces               to   w-prs-stb-exp          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prs-stp-bol-999.
       prs-stp-bol-050.
      *              *-------------------------------------------------*
      *              * Valore letto in work personalizzazioni          *
      *              *-------------------------------------------------*
           move      s-alf                to   w-prs-stb-str          .
      *              *-------------------------------------------------*
      *              * Controllo valori letti                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo movimento per stampa bolla             *
      *                  *---------------------------------------------*
           if        w-prs-stb-tmd        not  numeric
                     move  01             to   w-prs-stb-tmd
                     go to prs-stp-bol-100.
           if        w-prs-stb-tmd        not  = 01 and
                     w-prs-stb-tmd        not  = 51
                     move  01             to   w-prs-stb-tmd          .
       prs-stp-bol-100.
      *                  *---------------------------------------------*
      *                  * Si/no stampa voci descrittive               *
      *                  *---------------------------------------------*
           move      zero                 to   w-prs-stb-ctr          .
       prs-stp-bol-110.
           add       1                    to   w-prs-stb-ctr          .
           if        w-prs-stb-ctr        >    6
                     go to prs-stp-bol-200.
           if        w-prs-stb-snv
                    (w-prs-stb-ctr)       not  = "S" and
                     w-prs-stb-snv
                    (w-prs-stb-ctr)       not  = "P" and
                     w-prs-stb-snv
                    (w-prs-stb-ctr)       not  = "N"
                     move  "N"            to   w-prs-stb-snv
                                              (w-prs-stb-ctr)         .
           go to     prs-stp-bol-110.
       prs-stp-bol-200.
      *                  *---------------------------------------------*
      *                  * Si/no stampa delle quantita' editate a de-  *
      *                  * stra                                        *
      *                  *---------------------------------------------*
           if        w-prs-stb-snq        not  = "S" and
                     w-prs-stb-snq        not  = "N"
                     move  "N"            to   w-prs-stb-snq          .
       prs-stp-bol-300.
      *                  *---------------------------------------------*
      *                  * Si/no stampa del giorno di chiusura del     *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           if        w-prs-stb-sng        not  = "S" and
                     w-prs-stb-sng        not  = "N" and
                     w-prs-stb-sng        not  = "T" and
                     w-prs-stb-sng        not  = "#"
                     move  "N"            to   w-prs-stb-sng          .
       prs-stp-bol-400.
      *                  *---------------------------------------------*
      *                  * Giorni di chiusura comunque da non stampare *
      *                  *---------------------------------------------*
           if        w-prs-stb-gn1        not  numeric
                     move  zero           to   w-prs-stb-gn1          .
           if        w-prs-stb-gn1        <    1 or
                     w-prs-stb-gn1        >    7
                     move  zero           to   w-prs-stb-gn1          .
           if        w-prs-stb-sng        =    "N"
                     move  zero           to   w-prs-stb-gn1          .
      *
           if        w-prs-stb-gn2        not  numeric
                     move  zero           to   w-prs-stb-gn2          .
           if        w-prs-stb-gn2        <    1 or
                     w-prs-stb-gn2        >    7
                     move  zero           to   w-prs-stb-gn2          .
           if        w-prs-stb-sng        =    "N"
                     move  zero           to   w-prs-stb-gn2          .
       prs-stp-bol-500.
      *                  *---------------------------------------------*
      *                  * Si/no stampa degli orari di apertura del    *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           if        w-prs-stb-sno        not  = "S" and
                     w-prs-stb-sno        not  = "N"
                     move  "N"            to   w-prs-stb-sno          .
       prs-stp-bol-550.
      *                  *---------------------------------------------*
      *                  * Si/no stampa del corpo di tipo 'lungo'      *
      *                  *---------------------------------------------*
           if        w-prs-stb-snl        not  = "S" and
                     w-prs-stb-snl        not  = "N"
                     move  "N"            to   w-prs-stb-snl          .
       prs-stp-bol-600.
      *                  *---------------------------------------------*
      *                  * Codice da stampare                          *
      *                  *---------------------------------------------*
