           move      s-saa                to   w-wrk-dat-ann          .
           if        w-det-dat-nrg-dti    >    zero
                     add  1900            to   w-wrk-dat-ann          .
           move      s-mes                to   w-wrk-dat-mes          .
           move      s-gio                to   w-wrk-dat-gio          .
      *                      *-----------------------------------------*
      *                      * Assemblaggio                            *
      *                      *-----------------------------------------*
           move      10                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      w-wrk-dat-gio        to   w-all-str-cat (1)      .
           move      "/"                  to   w-all-str-cat (2)      .
           move      w-wrk-dat-mes        to   w-all-str-cat (3)      .
