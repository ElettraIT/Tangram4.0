      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofzbi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zbi                 .
      *              *-------------------------------------------------*
      *              * Lettura record [zbi]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTMB    "         to   f-key                  .
           move      rf-bit-cod-tmb       to   rf-zbi-cod-tmb         .
           move      zero                 to   rf-zbi-cod-dpz         .
           move      "pgm/bol/fls/ioc/obj/iofzbi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zbi                 .
       stp-tes-doc-010.
      *              *-------------------------------------------------*
      *              * Tipo documento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore esistente                    *
      *                  *---------------------------------------------*
           if        rf-zbi-des-stp       =   spaces
                     go to stp-tes-doc-050.
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpt-cod-tmb-lin    =   zero or
                     w-lpt-cod-tmb-pos    =   zero
                     go to stp-tes-doc-050.
      *                  *---------------------------------------------*
      *                  * Allineamento al centro                      *
      *                  *---------------------------------------------*
           move      25                   to   w-all-str-lun          .
           move      rf-zbi-des-stp       to   w-all-str-alf          .
           perform   all-str-cen-000      thru all-str-cen-999        .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      25                   to   p-car                  .
           move      w-lpt-cod-tmb-lin    to   p-lin                  .
           move      w-lpt-cod-tmb-pos    to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tes-doc-050.
      *              *-------------------------------------------------*
      *              * Numero documento                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se posizionamento esistente            *
      *                  *---------------------------------------------*
           if        w-lpt-num-doc-lin    =   zero or
                     w-lpt-num-doc-pos    =   zero
                     go to stp-tes-doc-100.
      *                  *---------------------------------------------*
      *                  * Numero documento in work ridefinito         *
      *                  *---------------------------------------------*
           move      rf-bit-num-doc       to   w-num-doc-num          .
      *                  *---------------------------------------------*
      *                  * Stampa numero progressivo                   *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      w-lpt-num-doc-lin    to   p-lin                  .
           move      w-lpt-num-doc-pos    to   p-pos                  .
           move      w-num-doc-prg        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Composizione stringa per dipendenza o gior- *
      *                  * nale iva e sigla numerazione                *
      *                  *---------------------------------------------*
           move      spaces               to   w-num-doc-str          .
           move      1                    to   w-num-doc-pnt          .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza o numero giornale iva *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da stampare                 *
      *                          *-------------------------------------*
           if        rf-bit-int-ftr       =    03 and
                     w-num-doc-doi        =    00
                     go to stp-tes-doc-052.
           if        rf-bit-int-ftr       not  = 03 and
                     w-num-doc-doi        =    01
                     go to stp-tes-doc-052.
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    "."
                                delimited by   size
                     w-num-doc-doi
                                delimited by   size
                                          into w-num-doc-str
                                  with pointer w-num-doc-pnt          .
       stp-tes-doc-052.
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da stampare                 *
      *                          *-------------------------------------*
           if        rf-bit-sgl-num       =    spaces
                     go to stp-tes-doc-054.
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    "-"
                                delimited by   size
                     rf-bit-sgl-num
                                delimited by   size
                                          into w-num-doc-str
                                  with pointer w-num-doc-pnt          .
       stp-tes-doc-054.
      *                  *---------------------------------------------*
      *                  * Determinazione lunghezza stringa            *
      *                  *---------------------------------------------*
           move      zero                 to   w-num-doc-pnt          .
           inspect   w-num-doc-str
                                      tallying w-num-doc-pnt
                                  for trailing spaces                 .
      *                  *---------------------------------------------*
      *                  * Stampa stringa composta                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      07                   to   p-car                  .
           subtract  w-num-doc-pnt        from p-car                  .
           move      w-lpt-num-doc-lin    to   p-lin                  .
           move      w-lpt-num-doc-pos    to   p-pos                  .
           add       06                   to   p-pos                  .
           move      w-num-doc-str        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tes-doc-100.
      *              *-------------------------------------------------*
      *              * Data documento                                  *
      *              *-------------------------------------------------*
