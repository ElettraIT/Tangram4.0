                                               rf-bix                 .
           if        f-sts                =    e-not-err
                     move  rf-bix-des-400 to   w-stp-cor-doc-der
           else      move  spaces         to   w-stp-cor-doc-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-600.
      *              *-------------------------------------------------*
      *              * Se estensione in file [pdx]                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rf-bir-num-pro       to   w-let-dcp-pdx-cod      .
           move      rf-bit-tip-arc       to   w-let-dcp-pdx-tar      .
           if        rf-bit-tip-frn       =    11
                     move  rf-bit-cod-arc to   w-let-dcp-pdx-arc
           else      move  rf-bit-arc-plf to   w-let-dcp-pdx-arc      .
           move      rf-bir-cod-lng       to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
           move      w-let-dcp-pdx-des    to   w-stp-cor-doc-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-900.
      *              *-------------------------------------------------*
      *              * Eventuale integrazione con righe aggiuntive per *
      *              * il codice prodotto                              *
      *              *-------------------------------------------------*
           perform   det-des-rig-rac-000  thru det-des-rig-rac-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione per la riga                    *
      *    *                                                           *
      *    * Subroutine per l'eventuale integrazione con righe ag-     *
      *    * giuntive per il codice prodotto                           *
      *    *-----------------------------------------------------------*
       det-des-rig-rac-000.
      *              *-------------------------------------------------*
      *              * Scansione delle righe di descrizione per otte-  *
      *              * nere il posizionamento della prima riga libera  *
      *              * da utilizzare per la stampa dei codici          *
      *              *-------------------------------------------------*
           move      11                   to   w-stp-cor-doc-c01      .
       det-des-rig-rac-010.
           subtract  1                    from w-stp-cor-doc-c01      .
           if        w-stp-cor-doc-c01    =    zero
                     go to det-des-rig-rac-011.
           if        w-stp-cor-doc-rgd
                    (w-stp-cor-doc-c01)   =    spaces
                     go to det-des-rig-rac-010.
       det-des-rig-rac-011.
           move      w-stp-cor-doc-c01    to   w-stp-cor-doc-c02      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della relativa persona-  *
      *              * lizzazione                                      *
      *              *-------------------------------------------------*
           if        w-prs-snx-rac        =    "N"
                     go to det-des-rig-rac-100
           else if   w-prs-snx-rac        =    "C" or
                     w-prs-snx-rac        =    "E"
                     go to det-des-rig-rac-200
           else if   w-prs-snx-rac        =    "M"
                     go to det-des-rig-rac-300
           else      go to det-des-rig-rac-100.
       det-des-rig-rac-100.
      *              *-------------------------------------------------*
      *              * Nessuna riga aggiuntiva                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-200.
      *              *-------------------------------------------------*
      *              * Una riga aggiuntiva con il codice del cliente   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice del cliente a spaces : a test *
      *                      * se altra riga contenente in ns. codice  *
      *                      *-----------------------------------------*
           if        rf-bir-cop-scl       =    spaces
                     go to det-des-rig-rac-290.
      *                      *-----------------------------------------*
      *                      * Incremento del contatore                *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-cor-doc-c02      .
      *                      *-----------------------------------------*
      *                      * Composizione riga aggiuntiva            *
      *                      *-----------------------------------------*
           move      spaces               to   w-stp-cor-doc-rgd
                                              (w-stp-cor-doc-c02)     .
           string    "  - Vs. codice : "
                                delimited by   size
                     rf-bir-cop-scl
                                delimited by   size
                                          into w-stp-cor-doc-rgd
                                              (w-stp-cor-doc-c02)     .
       det-des-rig-rac-290.
      *                  *---------------------------------------------*
      *                  * Test se altra riga aggiuntiva con il nostro *
      *                  * codice                                      *
      *                  *---------------------------------------------*
           if        w-prs-snx-rac        =    "E"
                     go to det-des-rig-rac-300.
      *                  *---------------------------------------------*
      *                  * Test se altra riga aggiuntiva con il codice *
      *                  * nomenclatura combinata                      *
      *                  *---------------------------------------------*
           if        w-prs-snx-rac        =    "W"
                     go to det-des-rig-rac-400.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-300.
      *              *-------------------------------------------------*
      *              * Una riga aggiuntiva con il codice nostro        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se nostro codice a spaces : ad uscita   *
      *                      *-----------------------------------------*
           if        rf-bir-alf-pro       =    spaces
                     go to det-des-rig-rac-900.
      *                      *-----------------------------------------*
      *                      * Incremento del contatore                *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-cor-doc-c02      .
      *                      *-----------------------------------------*
      *                      * Composizione riga aggiuntiva            *
      *                      *-----------------------------------------*
           move      spaces               to   w-stp-cor-doc-rgd
                                              (w-stp-cor-doc-c02)     .
           string    "  - Ns. codice : "
                                delimited by   size
                     rf-bir-alf-pro
                                delimited by   size
                                          into w-stp-cor-doc-rgd
                                              (w-stp-cor-doc-c02)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-400.
      *              *-------------------------------------------------*
      *              * Una riga aggiuntiva con la nomenclatura combi-  *
      *              * nata (fatture CEE)                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se fattura accompagnatoria         *
      *                      *-----------------------------------------*
           if        rf-bit-int-ftr       not  = 03
                     go to det-des-rig-rac-900.
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [zfi]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/iofzfi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zfi                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [zfi]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTMO    "         to   f-key                  .
           move      rf-bit-tmo-ftr       to   rf-zfi-cod-tmo         .
           move      "pgm/fat/fls/ioc/obj/iofzfi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zfi                 .
      *                          *-------------------------------------*
      *                          * Test su esito lettura               *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-rac-900.
       det-des-rig-rac-420.
      *                      *-----------------------------------------*
      *                      * Se documento CEE                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su codice causale contabile    *
      *                          *-------------------------------------*
           if        rf-zfi-cau-cge       =    zero
                     go to det-des-rig-rac-900.
      *                          *-------------------------------------*
      *                          * Normalizzazione record [zcc]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zcc]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      rf-zfi-cau-cge       to   rf-zcc-cod-cau         .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
      *                          *-------------------------------------*
      *                          * Test su tipo movimenti Iva          *
      *                          *-------------------------------------*
           if        rf-zcc-tip-moi       not  = "A" and
                     rf-zcc-tip-moi       not  = "B"
                     go to det-des-rig-rac-900.
      *                      *-----------------------------------------*
      *                      * Se riga prodotto                        *
      *                      *-----------------------------------------*
           if        rf-bir-num-pro       =    zero
                     go to det-des-rig-rac-900.
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [dcp]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                      *-----------------------------------------*
      *                      * Lettura per codice                      *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rf-bir-num-pro       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                      *-----------------------------------------*
      *                      * Se nomenclatura esistente               *
      *                      *-----------------------------------------*
           if        rf-dcp-cdn-cdm       =    zero
                     go to det-des-rig-rac-900.
      *                      *-----------------------------------------*
      *                      * Incremento del contatore                *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-cor-doc-c02      .
      *                      *-----------------------------------------*
      *                      * Composizione riga aggiuntiva            *
      *                      *-----------------------------------------*
           move      spaces               to   w-stp-cor-doc-rgd
                                              (w-stp-cor-doc-c02)     .
           string    "  - Codice doganale : "
                                delimited by   size
                     rf-dcp-cdn-cdm
                                delimited by   size
                                          into w-stp-cor-doc-rgd
                                              (w-stp-cor-doc-c02)     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione per stampa finale del   *
      *                      * riepilogo                               *
      *                      *-----------------------------------------*
           move      rf-dcp-cdn-cdm       to   w-nom-cmb-nom-cmb      .
           perform   nom-cmb-buf-000      thru nom-cmb-buf-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-rig-rac-999.
       det-des-rig-rac-999.
           exit.

      *    *===========================================================*
      *    * Nomenclatura combinata                                    *
      *    *                                                           *
      *    * Normalizzazione preliminare                               *
      *    *-----------------------------------------------------------*
       nom-cmb-nor-000.
      *              *-------------------------------------------------*
      *              * Determinazione se necessario trattamento nomen- *
      *              * clatura combinata                               *
      *              *-------------------------------------------------*
           perform   nom-cmb-snx-000      thru nom-cmb-snx-999        .
       nom-cmb-nor-050.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        w-nom-cmb-flg-snx    not  = "S"
                     go to nom-cmb-nor-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore elementi              *
      *              *-------------------------------------------------*
           move      zero                 to   w-nom-cmb-num-ele      .
       nom-cmb-nor-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione castelletto elementi            *
      *              *-------------------------------------------------*
           move      zero                 to   w-nom-cmb-ctr-001      .
       nom-cmb-nor-200.
           add       1                    to   w-nom-cmb-ctr-001      .
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-max-ele
                     go to nom-cmb-nor-900.
           move      zero                 to   w-nom-cmb-cst-cod
                                              (w-nom-cmb-ctr-001)     .
           move      zero                 to   w-nom-cmb-cst-val
                                              (w-nom-cmb-ctr-001)     .
           move      zero                 to   w-nom-cmb-cst-pes
                                              (w-nom-cmb-ctr-001)     .
           move      zero                 to   w-nom-cmb-cst-qta
                                              (w-nom-cmb-ctr-001)     .
           go to     nom-cmb-nor-200.
       nom-cmb-nor-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     nom-cmb-nor-999.
       nom-cmb-nor-999.
           exit.

      *    *===========================================================*
      *    * Nomenclatura combinata                                    *
      *    *                                                           *
      *    * Test se da trattare                                       *
      *    *-----------------------------------------------------------*
       nom-cmb-snx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore elementi              *
      *              *-------------------------------------------------*
           if        w-prs-snx-rnc        =    "S"
                     move  "S"            to   w-nom-cmb-flg-snx
           else      move  "N"            to   w-nom-cmb-flg-snx      .
       nom-cmb-snx-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     nom-cmb-snx-999.
       nom-cmb-snx-999.
           exit.

      *    *===========================================================*
      *    * Nomenclatura combinata                                    *
      *    *                                                           *
      *    * Bufferizzazione per stampa finale del riepilogo           *
      *    *-----------------------------------------------------------*
       nom-cmb-buf-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        w-nom-cmb-flg-snx    not  = "S"
                     go to nom-cmb-buf-900.
       nom-cmb-buf-100.
      *              *-------------------------------------------------*
      *              * Ricerca elemento                                *
      *              *-------------------------------------------------*
           set       w-nom-cmb-inx-ele    to   1                      .
           search    w-nom-cmb-cst-ele
                     when    w-nom-cmb-cst-cod
                            (w-nom-cmb-inx-ele)
                                          =    w-nom-cmb-nom-cmb
                     go to nom-cmb-buf-400.
       nom-cmb-buf-200.
      *              *-------------------------------------------------*
      *              * Elemento non trovato                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi               *
      *                  *---------------------------------------------*
           add       1                    to   w-nom-cmb-num-ele      .
           move      w-nom-cmb-num-ele    to   w-nom-cmb-inx-ele      .
      *                  *---------------------------------------------*
      *                  * Test se superato il massimo elementi        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-nom-cmb-num-ele    >    w-nom-cmb-max-ele
                     move  w-nom-cmb-max-ele
                                          to   w-nom-cmb-num-ele
                     go to nom-cmb-buf-900.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione nomenclatura            *
      *                      *-----------------------------------------*
           move      w-nom-cmb-nom-cmb    to   w-nom-cmb-cst-cod
                                              (w-nom-cmb-inx-ele)     .
       nom-cmb-buf-400.
      *              *-------------------------------------------------*
      *              * Elemento trovato                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento valori cumulativi                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore                                  *
      *                      *-----------------------------------------*
           add       rf-bir-imp-rig       to   w-nom-cmb-cst-val
                                              (w-nom-cmb-inx-ele)     .
      *                      *-----------------------------------------*
      *                      * Peso                                    *
      *                      *                                         *
      *                      * N.B.: Attualmente non gestito           *
      *                      *-----------------------------------------*
      *                      *-----------------------------------------*
      *                      * Quantita'                               *
      *                      *-----------------------------------------*
           add       rf-bir-qta-ven       to   w-nom-cmb-cst-qta
                                              (w-nom-cmb-inx-ele)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     nom-cmb-buf-900.
       nom-cmb-buf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     nom-cmb-buf-999.
       nom-cmb-buf-999.
           exit.

      *    *===========================================================*
      *    * Nomenclatura combinata                                    *
      *    *                                                           *
      *    * Stampa castelletto di riepilogo                           *
      *    *-----------------------------------------------------------*
       nom-cmb-stp-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su flag                                *
      *                  *---------------------------------------------*
           if        w-nom-cmb-flg-snx    not  = "S"
                     go to nom-cmb-stp-900.
      *                  *---------------------------------------------*
      *                  * Test su numero elementi                     *
      *                  *---------------------------------------------*
           if        w-nom-cmb-num-ele    not  > zero
                     go to nom-cmb-stp-900.
       nom-cmb-stp-100.
      *              *-------------------------------------------------*
      *              * Determinazioni preliminari                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale ritaratura dei valori di ogni     *
      *                  * elemento in base alla ripartizione omogenea *
      *                  * di eventuali sconti o spese accessorie      *
      *                  *---------------------------------------------*
           perform   nom-cmb-stp-rit-000  thru nom-cmb-stp-rit-999    .
       nom-cmb-stp-150.
      *                  *---------------------------------------------*
      *                  * Test che ci siano almeno 5 linee residue    *
      *                  *---------------------------------------------*
           move      p-lnr                to   w-nom-cmb-lin-res      .
           add       4                    to   w-nom-cmb-lin-res      .
           if        w-nom-cmb-lin-res    <    w-lpc-ult-rig-lin
                     go to nom-cmb-stp-200.
      *                  *---------------------------------------------*
      *                  * Reintestazione documento                    *
      *                  *---------------------------------------------*
           perform   rei-mod-tes-000      thru rei-mod-tes-999        .
      *                      *-----------------------------------------*
      *                      * Test su status di uscita                *
      *                      *-----------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to nom-cmb-stp-200.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     nom-cmb-stp-900.
       nom-cmb-stp-200.
      *              *-------------------------------------------------*
      *              * Fincatura - linea 1                             *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      70                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-nom-box-pos    to   p-pos                  .
           move      "+----------+-----------------+-----------------+--
      -              "----------------+"  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       nom-cmb-stp-220.
      *              *-------------------------------------------------*
      *              * Fincatura - linea 2                             *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      70                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-nom-box-pos    to   p-pos                  .
           move      "|  Codice  |     Valore      |      Peso       |  
      -              "  Quantita'     |"  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       nom-cmb-stp-230.
      *              *-------------------------------------------------*
      *              * Fincatura - linea 3                             *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      70                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-nom-box-pos    to   p-pos                  .
           move      "+----------+-----------------+-----------------+--
      -              "----------------+"  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       nom-cmb-stp-300.
      *              *-------------------------------------------------*
      *              * Prima linea del castelletto                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea vuota                                 *
      *                  *---------------------------------------------*
           perform   nom-cmb-stp-vuo-000  thru nom-cmb-stp-vuo-999    .
      *                  *---------------------------------------------*
      *                  * Valori                                      *
      *                  *---------------------------------------------*
           move      001                  to   w-nom-cmb-ctr-001      .
           perform   nom-cmb-stp-ele-000  thru nom-cmb-stp-ele-999    .
       nom-cmb-stp-400.
      *              *-------------------------------------------------*
      *              * Elementi successivi                             *
      *              *-------------------------------------------------*
           move      001                  to   w-nom-cmb-ctr-001      .
       nom-cmb-stp-420.
           add       001                  to   w-nom-cmb-ctr-001      .
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-num-ele
                     go to nom-cmb-stp-800.
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-max-ele
                     go to nom-cmb-stp-800.
      *                  *---------------------------------------------*
      *                  * Test che ci siano almeno 2 linee residue    *
      *                  *---------------------------------------------*
           move      p-lnr                to   w-nom-cmb-lin-res      .
           add       1                    to   w-nom-cmb-lin-res      .
           if        w-nom-cmb-lin-res    <    w-lpc-ult-rig-lin
                     go to nom-cmb-stp-440.
      *                  *---------------------------------------------*
      *                  * Reintestazione documento                    *
      *                  *---------------------------------------------*
           perform   rei-mod-tes-000      thru rei-mod-tes-999        .
      *                      *-----------------------------------------*
