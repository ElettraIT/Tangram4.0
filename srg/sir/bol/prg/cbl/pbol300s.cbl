      *    *-----------------------------------------------------------*
       rou-stp-doc-000.
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Determinazione se Lux                           *
      *              *                                                 *
      *              * SIRI                                            *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-azi                =    "lux "
                     move  "#"            to   w-det-azi-lux-snx
           else      move  spaces         to   w-det-azi-lux-snx      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Normalizzazione numero pagina                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-npr-num-pag      .
      *              *-------------------------------------------------*
      *              * Normalizzazione work per bufferizzazione dati   *
      *              * da [dcc] per la stampa dei giorni di chiusura   *
      *              * e dell'orario di apertura                       *
      *              *  - Giorni di apertura                           *
      *              *  - Orario di apertura, mattino inizio           *
      *              *  - Orario di apertura, mattino fine             *
      *              *  - Orario di apertura, pomeriggio inizio        *
      *              *  - Orario di apertura, pomeriggio fine          *
      *              *-------------------------------------------------*
           move      all   "."            to   w-stp-tes-dcc-gdl      .
           move      zero                 to   w-stp-tes-dcc-ami      .
           move      zero                 to   w-stp-tes-dcc-amf      .
           move      zero                 to   w-stp-tes-dcc-api      .
           move      zero                 to   w-stp-tes-dcc-apf      .
           move      spaces               to   w-stp-tes-dcc-abn      .
      *              *-------------------------------------------------*
      *              * Normalizzazione work per bufferizzazione dati   *
      *              * da [dcc] per la stampa del telefono             *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-tes-dcc-tel      .
      *              *-------------------------------------------------*
      *              * Lettura record testata da stampare              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-inp-mst-prt        to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
           if        f-sts                =    e-not-err
                     go to rou-stp-doc-100.
      *                  *---------------------------------------------*
      *                  * Se record non trovato uscita con status al  *
      *                  * valore "N"                                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-mst              .
           move      "N"                  to   w-out-mst-stp          .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-100.
      *              *-------------------------------------------------*
      *              * Incremento numero pagina                        *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-npr-num-pag      .
      *              *-------------------------------------------------*
      *              * Avanzamento pagina                              *
      *              *-------------------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Se errore grave di i-o su stampa si esce    *
      *                  * con status di errore                        *
      *                  *---------------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to  rou-stp-doc-999.
       rou-stp-doc-200.
      *              *-------------------------------------------------*
      *              * Determinazione castelletto iva per la stampa    *
      *              *-------------------------------------------------*
           perform   det-cst-iva-000      thru det-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Tentativo di lettura record [bix] di appoggio   *
      *              * ai valori di testata                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [bix]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbix"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bix                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [bix]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bit-num-prt       to   rf-bix-num-prt         .
           move      zero                 to   rf-bix-num-prg         .
           move      01                   to   rf-bix-tip-rec         .
           move      "pgm/bol/fls/ioc/obj/iofbix"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bix                 .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori di estensione al re- *
      *                  * cord di testata                             *
      *                  *---------------------------------------------*
           move      rf-bix-rag-ids       to   w-ext-rag-ids          .
           move      rf-bix-rs2-ids       to   w-ext-rs2-ids          .
           move      rf-bix-via-ids       to   w-ext-via-ids          .
           move      rf-bix-loc-ids       to   w-ext-loc-ids          .
           move      rf-bix-rag-vet       to   w-ext-rag-vet          .
           move      rf-bix-via-vet       to   w-ext-via-vet          .
           move      rf-bix-loc-vet       to   w-ext-loc-vet          .
           move      rf-bix-des-ant       to   w-ext-des-ant          .
      *              *-------------------------------------------------*
      *              * Stampa testata documento                        *
      *              *-------------------------------------------------*
           perform   stp-tes-doc-000      thru stp-tes-doc-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to rou-stp-doc-300.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-300.
      *              *-------------------------------------------------*
      *              * Stampa corpo documento                          *
      *              *-------------------------------------------------*
           perform   stp-cor-doc-000      thru stp-cor-doc-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to rou-stp-doc-400.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
       rou-stp-doc-400.
      *              *-------------------------------------------------*
      *              * Stampa piede documento                          *
      *              *-------------------------------------------------*
           perform   stp-pie-doc-000      thru stp-pie-doc-999        .
      *                  *---------------------------------------------*
      *                  * Test su status di uscita                    *
      *                  *---------------------------------------------*
           if        w-out-mst-stp        =    spaces
                     go to rou-stp-doc-900.
           move      spaces               to   w-out-mst              .
           perform   wrt-out-mst-000      thru wrt-out-mst-999        .
           go to     rou-stp-doc-999.
