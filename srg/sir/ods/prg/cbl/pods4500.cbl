      *              *-------------------------------------------------*
           move      zero                 to   w-det-esp-cli-esp      .
           move      zero                 to   w-det-esp-cli-wfd      .
           move      zero                 to   w-det-esp-cli-wac      .
           move      spaces               to   w-det-esp-cli-olf      .
       rou-det-cec-100.
      *              *-------------------------------------------------*
      *              * Preparazione parametri                          *
      *              *-------------------------------------------------*
           move      "EC"                 to   d-esp-cec-tip-ope      .
           move      w-tes-cod-cli        to   d-esp-cec-cod-cli      .
      *              *-------------------------------------------------*
      *              * Chiamata modulo                                 *
      *              *-------------------------------------------------*
           move      "pgm/gep/prg/obj/despcec0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-esp-cec              .
       rou-det-cec-200.
      *              *-------------------------------------------------*
      *              * Determinazione se cliente oltre Fido            *
      *              *-------------------------------------------------*
           move      d-esp-cec-esp-orc    to   w-det-esp-cli-esp      .
           add       d-esp-cec-esp-ods    to   w-det-esp-cli-esp      .
           add       d-esp-cec-esp-bol    to   w-det-esp-cli-esp      .
           add       d-esp-cec-esp-gep    to   w-det-esp-cli-esp      .
      *
           move      d-esp-cec-max-fid    to   w-det-esp-cli-wfd      .
           move      d-esp-cec-imp-acr    to   w-det-esp-cli-wac      .
      *
           if        w-det-esp-cli-wfd    =    zero
                     go to rou-det-cec-250.
      *
           if        c-dec                =    2
                     multiply  100        by   w-det-esp-cli-wfd
           else if   c-dec                =    1
                     multiply  10         by   w-det-esp-cli-wfd      .
       rou-det-cec-250.
           if        w-det-esp-cli-wac    =    zero
                     go to rou-det-cec-300.
      *
           if        c-dec                =    2
                     multiply  100        by   w-det-esp-cli-wac
           else if   c-dec                =    1
                     multiply  10         by   w-det-esp-cli-wac      .
       rou-det-cec-300.
      *              *-------------------------------------------------*
      *              * Test su Fido                                    *
      *              *-------------------------------------------------*
           if        w-det-esp-cli-esp    =    zero or
                     w-det-esp-cli-wfd    =    zero
                     go to rou-det-cec-400.
      *
           if        w-det-esp-cli-esp    >    w-det-esp-cli-wfd
                     move  "#"            to   w-det-esp-cli-olf      .
       rou-det-cec-400.
      *              *-------------------------------------------------*
