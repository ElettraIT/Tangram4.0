      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *-----------------------------------------------------------*
       ext-prm-000.
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Data di sistema                                 *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-exe-dat-exe          .
      *              *-------------------------------------------------*
      *              * CORRETTIVO PROVVISORIO                          *
      *              *-------------------------------------------------*
           if        w-exe-dat-exe        <    999999
                     add  1000000         to   w-exe-dat-exe          .
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-exe-prt-ods          .
           move      spaces               to   w-exe-prg-ods          .
           move      zero                 to   w-exe-prg-cnv          .
           move      spaces               to   w-exe-pri-ods          .
           move      spaces               to   w-exe-alf-pro          .
           move      zero                 to   w-exe-num-pro          .
           move      zero                 to   w-slc-num-ost-prt      .
      *              *-------------------------------------------------*
      *              * Normalizzazione parametri                       *
      *              *-------------------------------------------------*
           move      "NO"                 to   w-cgi-tip-ope          .
           move      04                   to   w-cgi-str-num          .
           perform   ope-prm-inp-000      thru ope-prm-inp-999        .
      *              *-------------------------------------------------*
      *              * Lettura della variabile di environment          *
      *              *-------------------------------------------------*
           move      "I2"                 to   o-ope                  .
           move      "POST"               to   o-com                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
      *              *-------------------------------------------------*
      *              * Estrazione parametri                            *
      *              *-------------------------------------------------*
           move      o-pst                to   w-cgi-str-var          .
           perform   cgi-str-ext-000      thru cgi-str-ext-999        .
       ext-prm-300.
      *              *-------------------------------------------------*
      *              * Assegnazione componenti                         *
      *              *-------------------------------------------------*
           move      "EX"                 to   w-cgi-tip-ope          .
           move      w-cgi-str-num        to   w-cgi-str-num          .
           perform   ope-prm-inp-000      thru ope-prm-inp-999        .
       ext-prm-500.
      *              *-------------------------------------------------*
      *              * Regolarizzazioni                                *
      *              *-------------------------------------------------*
      
           go to     ext-prm-501.
      *              *-------------------------------------------------*
      *              * DEBUG                                           *
      *              *-------------------------------------------------*
           display   "Content-type: text/html"
                                          with no advancing           .
           display   ""                                               .
           display   o-pst                                            .
           display   "<br>"                                           .
       ext-prm-501.
      
      
      
      *                  *---------------------------------------------*
      *                  * Protocollo documento                        *
      *                  *---------------------------------------------*
           perform   ext-prm-prt-000      thru ext-prm-prt-999        .
      *                  *---------------------------------------------*
      *                  * Progressivo riga                            *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      11                   to   p-car                  .
           move      w-exe-prg-ods        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-exe-prg-cnv          .
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico prodotto                *
      *                  *---------------------------------------------*
           perform   ext-prm-pro-000      thru ext-prm-pro-999        .
       ext-prm-700.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
       ext-prm-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-999.
       ext-prm-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di assegnazione del valore in base al nome del *
      *    * campo in input                                            *
      *    *-----------------------------------------------------------*
       ext-prm-ass-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del nome campo           *
      *              *-------------------------------------------------*
           if        w-all-str-cat (1)    =    "prt_ods"
                     move  w-all-str-cat (2)
                                          to   w-exe-prt-ods
           else if   w-all-str-cat (1)    =    "prg_ods"
                     move  w-all-str-cat (2)
                                          to   w-exe-prg-ods
           else if   w-all-str-cat (1)    =    "pri_ods"
                     move  w-all-str-cat (2)
                                          to   w-exe-pri-ods
           else if   w-all-str-cat (1)    =    "alf_pro"
                     move  w-all-str-cat (2)
                                          to   w-exe-alf-pro          .
       ext-prm-ass-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-ass-999.
       ext-prm-ass-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di eventuale estrazione protocollo             *
      *    *-----------------------------------------------------------*
       ext-prm-prt-000.
      *              *-------------------------------------------------*
      *              * Test su valore del campo in input               *
      *              *-------------------------------------------------*
           if        w-exe-prt-ods        =    spaces
                     go to ext-prm-prt-900.
           if        w-slc-num-ost-prt    not  = zero
                     go to ext-prm-prt-900.
       ext-prm-prt-300.
      *              *-------------------------------------------------*
      *              * Test su lunghezza del campo in input            *
      *              *-------------------------------------------------*
           move      w-exe-prt-ods        to   w-all-str-alf          .
           perform   all-str-lun-000      thru all-str-lun-999        .
           if        w-all-str-lun        >    6
                     go to ext-prm-prt-600.
       ext-prm-prt-400.
      *              *-------------------------------------------------*
      *              * Se lunghezza di 6 caratteri o inferiore         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Anno da campo in input                      *
      *                  *---------------------------------------------*
           move      w-exe-prt-ods
                    (01 : 02)             to   w-exe-aaa-prt          .
      *                  *---------------------------------------------*
      *                  * Numero da campo in input                    *
      *                  *---------------------------------------------*
           move      w-exe-prt-ods
                    (03 : 04)             to   w-exe-num-prt          .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza                           *
      *                  *---------------------------------------------*
           move      "01"                 to   w-exe-dpz-prt          .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      "1"                  to   w-all-str-cat (1)      .
           move      w-exe-aaa-prt        to   w-all-str-cat (2)      .
           move      w-exe-dpz-prt        to   w-all-str-cat (3)      .
           move      "00"                 to   w-all-str-cat (4)      .
           move      w-exe-num-prt        to   w-all-str-cat (5)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Conversione in numerico                     *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      11                   to   p-car                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-slc-num-ost-prt      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     ext-prm-prt-900.
       ext-prm-prt-600.
      *              *-------------------------------------------------*
      *              * Se lunghezza maggiore di 6 caratteri            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Conversione in numerico                     *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      11                   to   p-car                  .
           move      w-exe-prt-ods        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-slc-num-ost-prt      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     ext-prm-prt-900.
       ext-prm-prt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-prt-999.
       ext-prm-prt-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di eventuale regolarizzazione codice prodotto  *
      *    *-----------------------------------------------------------*
       ext-prm-pro-000.
      *              *-------------------------------------------------*
      *              * Test su valore del campo in input               *
      *              *-------------------------------------------------*
           if        w-exe-alf-pro        =    spaces
                     go to ext-prm-pro-900.
      *              *-------------------------------------------------*
      *              * Uppercase                                       *
      *              *-------------------------------------------------*
           move      w-exe-alf-pro        to   w-all-str-alf          .
           move      20                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   w-exe-alf-pro          .
       ext-prm-pro-200.
      *              *-------------------------------------------------*
      *              * Test se presente il carattere '%'               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           move      w-exe-alf-pro        to   w-all-str-alf          .
           move      "%"                  to   w-all-str-del          .
           perform   all-str-chr-000      thru all-str-chr-999        .
      *                  *---------------------------------------------*
      *                  * Se non trovato: ad uscita                   *
      *                  *---------------------------------------------*
           if        w-all-str-num        =    zero
                     go to ext-prm-pro-900.
      *                  *---------------------------------------------*
      *                  * Scomposizione                               *
      *                  *---------------------------------------------*
           move      w-exe-alf-pro        to   w-all-str-alf          .
           move      "%"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
      *                  *---------------------------------------------*
      *                  * Test sui componenti                         *
      *                  *---------------------------------------------*
           if        w-all-str-cat (2)
                    (01 : 02)             not  = "2F"
                     go to ext-prm-pro-900.
           move      w-all-str-cat (1)    to   w-exe-prm-vx1          .
           move      w-all-str-cat (2)
                    (03 : 12)             to   w-exe-prm-vx2          .
      *                  *---------------------------------------------*
      *                  * Riassemblaggio                              *
      *                  *---------------------------------------------*
           move      14                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-exe-prm-vx1        to   w-all-str-cat (1)      .
           move      "/"                  to   w-all-str-cat (2)      .
           move      w-exe-prm-vx2        to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-exe-alf-pro          .
       ext-prm-pro-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-pro-999.
       ext-prm-pro-999.
           exit.

