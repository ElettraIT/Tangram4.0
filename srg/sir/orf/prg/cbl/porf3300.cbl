           if        w-all-str-lun        <    001
                     move  001            to   w-all-str-lun          .
           if        w-all-str-lun        >    240
                     move  240            to   w-all-str-lun          .
      *              *-------------------------------------------------*
      *              * Determinazione dell'indice relativo al primo    *
