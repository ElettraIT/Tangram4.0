           copy      "swd/std/prg/cpy/wedtqta0.wks"                   .

      *    *===========================================================*
      *    * Routine per calcoli ed operazioni su date                 *
      *    *-----------------------------------------------------------*
       clc-ope-dat-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-clc-dat-nrg          .
           move      w-clc-dat-min        to   w-clc-dat-ng0          .
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-clc-dat-max        =    w-clc-dat-min
                     go to clc-ope-dat-999.
           if        w-clc-dat-max        <    w-clc-dat-min
                     go to clc-ope-dat-300.
       clc-ope-dat-100.
      *              *-------------------------------------------------*
      *              * Se data massima maggiore                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento                                  *
      *                  *---------------------------------------------*
           add       1                    to   w-clc-dat-nrg          .
           move      w-clc-dat-ng0        to   w-det-dat-nrg-dtb      .
           move      1                    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-clc-dat-ng0          .
      *                  *---------------------------------------------*
      *                  * Test se fine ciclo                          *
      *                  *---------------------------------------------*
           if        w-clc-dat-ng0        =    w-clc-dat-max
                     go to clc-ope-dat-999.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     clc-ope-dat-100.
       clc-ope-dat-300.
      *              *-------------------------------------------------*
      *              * Se data massima minore                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Decremento                                  *
      *                  *---------------------------------------------*
           add       1                    to   w-clc-dat-nrg          .
           move      w-clc-dat-ng0        to   w-det-nrg-dat-dtb      .
           move      1                    to   w-det-nrg-dat-ngd      .
           perform   det-nrg-dat-000      thru det-nrg-dat-999        .
           move      w-det-nrg-dat-dtd    to   w-clc-dat-ng0          .
      *                  *---------------------------------------------*
      *                  * Test se fine ciclo                          *
      *                  *---------------------------------------------*
           if        w-clc-dat-ng0        =    w-clc-dat-max
                     multiply -1          by   w-clc-dat-nrg
                     go to clc-ope-dat-999.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     clc-ope-dat-300.
       clc-ope-dat-999.
           exit.

      *    *===========================================================*
      *    * Determinazione dei totali del documento                   *
      *    *-----------------------------------------------------------*
       agg-tes-doc-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione totali ordine                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-tot-tot-rig (1)      .
           move      zero                 to   w-tot-tot-rig (2)      .
           move      zero                 to   w-tot-tot-rig (3)      .
           move      zero                 to   w-tot-tot-rig (4)      .
           move      zero                 to   w-tot-tot-rig (5)      .
           move      zero                 to   w-tot-tot-rig (6)      .
           move      zero                 to   w-tot-tot-rig (7)      .
           move      zero                 to   w-tot-tot-rig (8)      .
           move      zero                 to   w-tot-tot-rig (9)      .
           move      zero                 to   w-tot-tot-rta          .
       agg-tes-doc-100.
      *              *-------------------------------------------------*
      *              * Start su file [ofr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-ofr-num-prt         .
           move      zero                 to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-tes-doc-800.
       agg-tes-doc-200.
      *              *-------------------------------------------------*
      *              * Read next su [ofr]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-tes-doc-800.
       agg-tes-doc-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ofr-num-prt       not  = w-tes-num-prt
                     go to agg-tes-doc-800.
       agg-tes-doc-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga 'C' : a riciclo                     *
      *                  *---------------------------------------------*
           if        rf-ofr-tip-rig (1:1) =    "C"
                     go to agg-tes-doc-200.
       agg-tes-doc-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento totale righe                      *
      *              *-------------------------------------------------*
           if        rf-ofr-tip-rig (1:1) =    "P"
                     add   rf-ofr-imp-rig to   w-tot-tot-rig
                                              (rf-ofr-tip-pro)
           else if   rf-ofr-tip-rig (1:1) =    "A"
                     add   rf-ofr-imp-rig to   w-tot-tot-rta          .
       agg-tes-doc-700.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     agg-tes-doc-200.
       agg-tes-doc-800.
      *              *-------------------------------------------------*
      *              * Scrittura record [oft] subentrante              *
      *              *-------------------------------------------------*
           perform   agg-tot-doc-000      thru agg-tot-doc-999        .
       agg-tes-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-tes-doc-999.
       agg-tes-doc-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento dei totali del documento                    *
      *    *-----------------------------------------------------------*
       agg-tot-doc-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento record [oft]                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ottenimento record [oft]                    *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : uscita                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-tot-doc-900.
      *                  *---------------------------------------------*
      *                  * Informazioni generali                       *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-oft-ide-dat         .
           move      s-ute                to   rf-oft-ide-ute         .
           move      s-fas                to   rf-oft-ide-fas         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento dati record [oft]             *
      *                  *---------------------------------------------*
           move      w-tes-cof-dat (1)    to   rf-oft-cof-dat         .
           move      w-tes-cof-num (1)    to   rf-oft-cof-num         .
           move      w-tes-cof-rif (1)    to   rf-oft-cof-rif         .
      *                  *---------------------------------------------*
      *                  * Totali di suddivisione per le righe         *
      *                  *---------------------------------------------*
           move      w-tot-tot-rig (1)    to   rf-oft-tot-rig (1)     .
           move      w-tot-tot-rig (2)    to   rf-oft-tot-rig (2)     .
           move      w-tot-tot-rig (3)    to   rf-oft-tot-rig (3)     .
           move      w-tot-tot-rig (4)    to   rf-oft-tot-rig (4)     .
           move      w-tot-tot-rig (5)    to   rf-oft-tot-rig (5)     .
           move      w-tot-tot-rig (6)    to   rf-oft-tot-rig (6)     .
           move      w-tot-tot-rig (7)    to   rf-oft-tot-rig (7)     .
           move      w-tot-tot-rig (8)    to   rf-oft-tot-rig (8)     .
           move      w-tot-tot-rig (9)    to   rf-oft-tot-rig (9)     .
      *                  *---------------------------------------------*
      *                  * Totale documento                            *
      *                  *                                             *
      *                  * N.B.: non tiene conto di spese accessorie e *
      *                  *       sconti in chiusura                    *
      *                  *---------------------------------------------*
           add       w-tot-tot-rig (1)
                     w-tot-tot-rig (2)
                     w-tot-tot-rig (3)
                     w-tot-tot-rig (4)
                     w-tot-tot-rig (5)
                     w-tot-tot-rig (6)
                     w-tot-tot-rig (7)
                     w-tot-tot-rig (8)
                     w-tot-tot-rig (9)
                     w-tot-tot-rta      giving rf-oft-tot-doc         .
      *                  *---------------------------------------------*
      *                  * Update record [oft]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Release record [oft]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
       agg-tot-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-tot-doc-999.
       agg-tot-doc-999.
           exit.

