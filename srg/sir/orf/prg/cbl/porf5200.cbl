      *              *-------------------------------------------------*
           move      spaces               to   w-det-edi-rig-flg      .
           move      spaces               to   w-det-edi-rig-pth      .
           move      zero                 to   w-det-edi-rig-ctr      .
           move      spaces               to   w-det-edi-rig-num      .
           move      spaces               to   w-det-edi-rig-rif      .
           move      zero                 to   w-det-edi-rig-dat      .
       det-edi-rig-100.
      *              *-------------------------------------------------*
      *              * Start su [her]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PRTPRG    "         to   f-key                  .
           move      rf-oft-num-prt       to   rf-her-orc-prt         .
           move      zero                 to   rf-her-edi-prg         .
           move      spaces               to   rf-her-pth-edi         .
           move      zero                 to   rf-her-prg-inp         .
           move      "sir/agb/fls/ioc/obj/iofher"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-her                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a test su contatore       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-edi-rig-800.
       det-edi-rig-200.
      *              *-------------------------------------------------*
      *              * Next su [her]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "sir/agb/fls/ioc/obj/iofher"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-her                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a test su contatore           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-edi-rig-800.
       det-edi-rig-300.
      *              *-------------------------------------------------*
      *              * Max su [her], se non superato : a test su con-  *
      *              * tatore                                          *
      *              *-------------------------------------------------*
           if        rf-her-orc-prt       not  = rf-oft-num-prt
                     go to det-edi-rig-800.
       det-edi-rig-400.
      *              *-------------------------------------------------*
      *              * Selezione su [her]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su flag di riga caricata               *
      *                  *---------------------------------------------*
           if        rf-her-flg-car       not  = spaces
                     go to det-edi-rig-200.
      *                  *---------------------------------------------*
      *                  * Test pathname memorizzato                   *
      *                  *---------------------------------------------*
           if        w-det-edi-rig-pth    =    spaces
                     go to det-edi-rig-500.
      *                  *---------------------------------------------*
      *                  * Test su pathname                            *
      *                  *---------------------------------------------*
           if        rf-her-pth-edi       not  = w-det-edi-rig-pth
                     go to det-edi-rig-200.
       det-edi-rig-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-edi-rig-ctr      .
      *              *-------------------------------------------------*
      *              * Bufferizzazioni                                 *
      *              *-------------------------------------------------*
           if        w-det-edi-rig-pth    =    spaces
                     move  rf-her-pth-edi to   w-det-edi-rig-pth      .
      *
           move      rf-her-cof-dat       to   w-det-edi-rig-dat      .
           move      rf-her-cof-num       to   w-det-edi-rig-num      .
           move      rf-her-cof-rif       to   w-det-edi-rig-rif      .
       det-edi-rig-700.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-edi-rig-200.
       det-edi-rig-800.
      *              *-------------------------------------------------*
      *              * Test sul contatore righe                        *
      *              *-------------------------------------------------*
           if        w-det-edi-rig-ctr    =    zero
                     move  "#"            to   w-det-edi-rig-flg      .
       det-edi-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-edi-rig-999.
       det-edi-rig-999.
           exit.

