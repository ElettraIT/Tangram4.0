      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-acc-flg        =    spaces or
                     w-rig-acc-flg        =    "?"
                     go to acc-flg-cnf-600.
           if        w-rig-acc-flg        not  <  "0" and
                     w-rig-acc-flg        not  >  "9"
                     go to acc-flg-cnf-600.
           if        w-rig-acc-flg        not  <  "A" and
                     w-rig-acc-flg        not  >  "Z"
                     go to acc-flg-cnf-600
           else      go to acc-flg-cnf-100.
       acc-flg-cnf-600.
