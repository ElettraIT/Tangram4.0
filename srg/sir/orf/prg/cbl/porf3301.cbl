      *    *    - w-det-cdp-pdt-tpm : Tipo codice di magazzino         *
      *    *                                                           *
      *    *    - w-det-cdp-pdt-nmm : Codice numerico di magazzino     *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-det-cdp-pdt-cod : Codice secondo il produttore     *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-cdp-pdt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore determinato              *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-cdp-pdt-cod      .
      *              *-------------------------------------------------*
      *              * Se valore non da determinare : uscita           *
      *              *-------------------------------------------------*
           if        w-det-cdp-pdt-tpr    not  = "P    "
                     go to det-cdp-pdt-999.
           if        w-det-cdp-pdt-tpm    not  = 01
                     go to det-cdp-pdt-999.
           if        w-det-cdp-pdt-nmm    =    zero
                     go to det-cdp-pdt-999.
      *              *-------------------------------------------------*
      *              * Lettura [aaq] e determinazione valore           *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO    "         to   f-key                  .
           move      01                   to   rf-aaq-tip-mag         .
           move      w-det-cdp-pdt-nmm    to   rf-aaq-num-pro         .
           move      "pgm/dcf/fls/ioc/obj/iofaaq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaq                 .
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-aaq-cdp-pdt         .
           move      rf-aaq-cdp-pdt       to   w-det-cdp-pdt-cod      .
       det-cdp-pdt-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione riga ordine                    *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [ofr] relativo alla riga ordine fornitore  *
      *    *      a disposizione in rf-ofr                             *
      *    *                                                           *
      *    *    - Record di [dcf] relativo alla riga ordine fornitore  *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-det-des-rig-des : Descrizione riga ordine          *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-des-rig-des      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del flag di estensione   *
      *              * alla descrizione                                *
      *              *-------------------------------------------------*
           if        rf-ofr-des-ext       =    0
                     go to det-des-rig-100
           else if   rf-ofr-des-ext       =    1
                     go to det-des-rig-200
           else if   rf-ofr-des-ext       =    2
                     go to det-des-rig-300
           else if   rf-ofr-des-ext       =    3
                     go to det-des-rig-400.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione : bufferizzazione descri- *
      *              * zione contenuta nel record [ofr]                *
      *              *-------------------------------------------------*
           move      rf-ofr-des-rig       to   w-det-des-rig-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-200.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [ofx]                    *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ofr-num-prt       to   rf-ofx-num-prt         .
           move      rf-ofr-num-prg       to   rf-ofx-num-prg         .
           move      11                   to   rf-ofx-tip-rec         .
           move      "pgm/orf/fls/ioc/obj/iofofx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofx                 .
           if        f-sts                not  = e-not-err
                     move  all '.'        to   rf-ofx-des-400         .
           move      rf-ofx-des-400       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice lingua 'I  '                      *
      *                  *---------------------------------------------*
           if        rf-ofr-cod-lng       not  = "I  "
                     go to det-des-rig-350.
       det-des-rig-310.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdx]                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      01                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      "I  "                to   rf-pdx-cod-lng         .
           move      rf-ofr-num-mag       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-pdx-des-pro         .
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-350.
      *                  *---------------------------------------------*
      *                  * Se codice lingua diverso da 'I  '           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tentativo di lettura file [pdx] per de- *
      *                      * scrizione in lingua estera              *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      02                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      rf-ofr-cod-lng       to   rf-pdx-cod-lng         .
           move      rf-ofr-num-mag       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     go to det-des-rig-310.
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-400.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx] come estensione al *
      *              * file [aaf]                                      *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           if        rf-ofr-tip-mag       =    01
                     move  13             to   rf-pdx-tip-rec
           else if   rf-ofr-tip-mag       =    03
                     move  33             to   rf-pdx-tip-rec
           else if   rf-ofr-tip-mag       =    04
                     move  43             to   rf-pdx-tip-rec         .
           move      rf-ofr-cod-arc       to   rf-pdx-cod-arc         .
           move      spaces               to   rf-pdx-cod-lng         .
           move      rf-ofr-num-mag       to   rf-pdx-cod-num         .
           move      rf-ofr-fda-pif       to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     go to det-des-rig-310.
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-aav = Ammontare da convertire, espres- *
      *    *                          so nell'altra valuta             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-avb = Ammontare convertito, espresso   *
      *    *                          nella valuta base                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta base ad altra valuta     *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-avb = Ammontare da convertire, espres- *
      *    *                          so nella valuta base             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-aav = Ammontare convertito, espresso   *
      *    *                          nell'altra valuta                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Determinazione quantita' evasa                            *
      *    *-----------------------------------------------------------*
       det-qta-eva-000.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' evasa riga ordine      *
      *              *-------------------------------------------------*
           move      "DT"                 to   d-qev-rof-tip-ope      .
           move      rr-dat-rif           to   d-qev-rof-dat-rif      .
           move      "pgm/orf/prg/obj/dqevrof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qev-rof
                                               rf-ofr                 .
       det-qta-eva-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qta-eva-999.
       det-qta-eva-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo residuo nella valuta di fattura-   *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       det-imp-res-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-res-ipr      .
       det-imp-res-100.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
       det-imp-res-200.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "A"
                     move  rf-ofr-imp-rig to   w-det-imp-res-ipr
                     go to det-imp-res-900.
       det-imp-res-300.
      *                  *---------------------------------------------*
      *                  * Se altro tipo riga                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione prezzo unitario per il   *
      *                      * calcolo dell'importo in caso di tra-    *
      *                      * sformazione unita' di misura di tipo    *
      *                      * 'S' o 'N'                               *
      *                      *-----------------------------------------*
           if        rf-ofr-snx-tum       =    "P"
                     go to det-imp-res-322.
      *                          *-------------------------------------*
      *                          * Prezzo unitario pari a quello appe- *
      *                          * na calcolato                        *
      *                          *-------------------------------------*
           go to     det-imp-res-328.
       det-imp-res-322.
      *                      *-----------------------------------------*
      *                      * Determinazione prezzo unitario per il   *
      *                      * calcolo dell'importo in caso di tra-    *
      *                      * sformazione unita' di misura di tipo    *
      *                      * 'P'                                     *
      *                      *-----------------------------------------*
           divide    rf-ofr-qta-ord       into rf-ofr-imp-rig
                                        giving w-det-imp-res-wpr
                                               rounded                .
           multiply  d-qev-rof-qta-dri    by   w-det-imp-res-wpr
                                        giving w-det-imp-res-ipr      .
           go to     det-imp-res-350.
       det-imp-res-328.
      *                      *-----------------------------------------*
      *                      * Importo residuo                         *
      *                      *-----------------------------------------*
           multiply  d-qev-rof-qta-dri    by   w-det-imp-res-prz
                                        giving w-det-imp-res-ipr      .
       det-imp-res-330.
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ofr-dec-prz       =    1
                     divide 10            into w-det-imp-res-ipr
           else if   rf-ofr-dec-prz       =    2
                     divide 100           into w-det-imp-res-ipr      .
       det-imp-res-350.
      *                      *-----------------------------------------*
      *                      * Eventuale conversione nella valuta di   *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-ofr-sgl-vpp       =    rf-ofr-sgl-vpf
                     go to det-imp-res-900.
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per il prezzo                    *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ofr-sgl-vpp       to   w-coe-cmb-vlt-sdv      .
           move      rf-ofr-tdc-vpp       to   w-coe-cmb-vlt-tdc      .
           move      rr-dat-rif           to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ofr-cdc-vpp to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta per   *
      *                          * il prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-ofr-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-ofr-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-ofr-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-det-imp-res-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ofr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ofr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      rr-dat-rif           to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ofr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta base  *
      *                          * a valuta per fatturazione           *
      *                          *-------------------------------------*
           move      rf-ofr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ofr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ofr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                          *-------------------------------------*
      *                          * Bufferizzazione del risultato       *
      *                          *-------------------------------------*
           move      w-cvs-vlt-aav        to   w-det-imp-res-ipr      .
       det-imp-res-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-imp-res-999.
       det-imp-res-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo sottoposto a legame valutario       *
      *    *-----------------------------------------------------------*
       det-prz-lvl-000.
      *              *-------------------------------------------------*
      *              * Controllo esistenza parametri                   *
      *              *-------------------------------------------------*
           if        w-det-prz-lvl-svl    =    spaces or
                     w-det-prz-lvl-prz    =    zero   or
                     w-det-prz-lvl-ccr    =    zero   or
                     w-det-prz-lvl-cdc    =    zero
                     go to det-prz-lvl-999.
           if        w-det-prz-lvl-plm    =    zero and
                     w-det-prz-lvl-tlm    not  = spaces
                     go to det-prz-lvl-999.
           if       (w-det-prz-lvl-plm    not  = zero  ) and
                    (w-det-prz-lvl-tlm    not  = "T" and
                     w-det-prz-lvl-tlm    not  = "F" and
                     w-det-prz-lvl-tlm    not  = "M"   )
                     go to det-prz-lvl-999.
       det-prz-lvl-050.
      *              *-------------------------------------------------*
      *              * Determinazione valore scostamento rispetto al   *
      *              * cambio di riferimento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che esista o meno la   *
      *                  * percentuale di tolleranza                   *
      *                  *---------------------------------------------*
           if        w-det-prz-lvl-plm    =    zero
                     go to det-prz-lvl-052
           else      go to det-prz-lvl-054.
       det-prz-lvl-052.
      *                  *---------------------------------------------*
      *                  * Se percentuale di tolleranza a zero         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A calcolo nuovo prezzo con tipo di li-  *
      *                      * mitazione : Tolleranza                  *
      *                      *-----------------------------------------*
           go to     det-prz-lvl-120.
       det-prz-lvl-054.
      *                  *---------------------------------------------*
      *                  * Se percentuale di tolleranza esistente      *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-plm    by   w-det-prz-lvl-ccr
                                        giving w-det-prz-lvl-wps      .
           divide    100                  into w-det-prz-lvl-wps      .
           go to     det-prz-lvl-060.
       det-prz-lvl-060.
      *              *-------------------------------------------------*
      *              * Test se esiste uno scostamento in piu'          *
      *              *-------------------------------------------------*
           add       w-det-prz-lvl-wps    to   w-det-prz-lvl-ccr
                                        giving w-det-prz-lvl-wpc      .
           if        w-det-prz-lvl-cdc    >    w-det-prz-lvl-wpc
                     go to det-prz-lvl-100.
      *              *-------------------------------------------------*
      *              * Test se esiste uno scostamento in meno          *
      *              *-------------------------------------------------*
           subtract  w-det-prz-lvl-wps    from w-det-prz-lvl-ccr
                                        giving w-det-prz-lvl-wpc      .
           if        w-det-prz-lvl-cdc    <    w-det-prz-lvl-wpc
                     go to det-prz-lvl-100.
      *              *-------------------------------------------------*
      *              * Uscita con prezzo invariato                     *
      *              *-------------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo limitazione     *
      *              *-------------------------------------------------*
           if        w-det-prz-lvl-tlm    =    "T"
                     go to det-prz-lvl-120
           else if   w-det-prz-lvl-tlm    =    "F"
                     go to det-prz-lvl-140
           else if   w-det-prz-lvl-tlm    =    "M"
                     go to det-prz-lvl-160.
       det-prz-lvl-120.
      *              *-------------------------------------------------*
      *              * Tipo limitazione : Tolleranza                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo nuovo prezzo                        *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-prz    by   w-det-prz-lvl-cdc
                                        giving w-det-prz-lvl-wpz      .
           divide    w-det-prz-lvl-ccr    into w-det-prz-lvl-wpz
                                               rounded                .
           move      w-det-prz-lvl-wpz    to   w-det-prz-lvl-prz      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-140.
      *              *-------------------------------------------------*
      *              * Tipo limitazione : Franchigia                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo nuovo prezzo                        *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-prz    by   w-det-prz-lvl-cdc
                                        giving w-det-prz-lvl-wpz      .
           divide    w-det-prz-lvl-wpc    into w-det-prz-lvl-wpz
                                               rounded                .
           move      w-det-prz-lvl-wpz    to   w-det-prz-lvl-prz      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-160.
      *              *-------------------------------------------------*
      *              * Tipo limitazione : Tetto massimo                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo nuovo prezzo                        *
      *                  *---------------------------------------------*
           multiply  w-det-prz-lvl-prz    by   w-det-prz-lvl-wpc
                                        giving w-det-prz-lvl-wpz      .
           divide    w-det-prz-lvl-ccr    into w-det-prz-lvl-wpz
                                               rounded                .
           move      w-det-prz-lvl-wpz    to   w-det-prz-lvl-prz      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-lvl-999.
       det-prz-lvl-999.
           exit.

      *    *===========================================================*
      *    * Determinazione della voce 'ordinato mese' per fornitore   *
      *    *-----------------------------------------------------------*
       det-fnt-mic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-fnt-mic-tot      .
           move      zero                 to   w-det-fnt-mic-imp      .
           move      zero                 to   w-det-imp-res-ipr      .
       det-fnt-mic-100.
      *              *-------------------------------------------------*
      *              * Start su testate ordini [oft]                   *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      rr-dpz-inu           to   rf-oft-cod-dpz         .
           move      "F"                  to   rf-oft-tip-arc         .
           move      w-det-fnt-mic-fnt    to   rf-oft-cod-arc         .
           move      w-tot-dat-i01        to   rf-oft-dat-doc         .
           move      zero                 to   rf-oft-num-doc         .
           move      zero                 to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito della start                   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fnt-mic-900.
       det-fnt-mic-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [oft]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *              *-------------------------------------------------*
      *              * Test se 'at end'                                *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fnt-mic-900.
       det-fnt-mic-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-oft-cod-dpz       not  = rr-dpz-inu        or
                     rf-oft-tip-arc       not  = "F"               or
                     rf-oft-cod-arc       not  = w-det-fnt-mic-fnt or
                     rf-oft-dat-doc       >    w-tot-dat-f01
                     go to det-fnt-mic-900.
       det-fnt-mic-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
       det-fnt-mic-500.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione delle righe ordine per de-   *
      *              * terminare il totale ordine in valuta base       *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-oft-num-prt       to   rf-ofr-num-prt         .
           move      zero                 to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fnt-mic-850.
       det-fnt-mic-520.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ofr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fnt-mic-850.
       det-fnt-mic-530.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ofr-num-prt       not  = rf-oft-num-prt
                     go to det-fnt-mic-850.
       det-fnt-mic-540.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga in comodo ridefinito              *
      *                  *---------------------------------------------*
           move      rf-ofr-tip-rig       to   w-det-imp-res-wtr      .
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : riciclo                  *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "C"
                     go to det-fnt-mic-520.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           if        w-det-imp-res-wtp    =    "A"
                     move  rf-ofr-imp-rig to   w-det-imp-res-ipr
                     go to det-fnt-mic-545.
      *                  *---------------------------------------------*
      *                  * Se altro tipo riga                          *
      *                  *---------------------------------------------*
           move      rf-ofr-imp-rig       to   w-det-imp-res-ipr      .
       det-fnt-mic-545.
      *                  *---------------------------------------------*
      *                  * Determinazione importo residuo in valuta    *
      *                  * base                                        *
      *                  *---------------------------------------------*
           move      w-det-imp-res-ipr    to   w-det-fnt-mic-imp      .
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        rf-ofr-sgl-vpf       =    c-sgl
                     go to det-fnt-mic-550.
      *                      *-----------------------------------------*
      *                      * Applicazione del cambio alla data di    *
      *                      * riferimento                             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data di rif. per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ofr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ofr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      rr-dat-rif           to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ofr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Determinazione importo residuo riga *
      *                          * in valuta base                      *
      *                          *-------------------------------------*
           move      rf-ofr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ofr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ofr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-det-imp-res-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale ordinato mese  *
      *                          * in valuta base                      *
      *                          *-------------------------------------*
           move      w-cvs-vlt-avb        to   w-det-fnt-mic-imp      .
       det-fnt-mic-550.
      *                  *---------------------------------------------*
      *                  * Cumulo del valore da cumulare               *
      *                  *---------------------------------------------*
           add       w-det-fnt-mic-imp    to   w-det-fnt-mic-tot      .
       det-fnt-mic-800.
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     det-fnt-mic-520.
       det-fnt-mic-850.
      *              *-------------------------------------------------*
      *              * Riciclo a testata successiva                    *
      *              *-------------------------------------------------*
           go to     det-fnt-mic-200.
       det-fnt-mic-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-fnt-mic-999.
       det-fnt-mic-999.
           exit.

      *    *===========================================================*
      *    * Put next generica per output in sequenziale               *
      *    *-----------------------------------------------------------*
       put-nxt-out-000.
      *              *-------------------------------------------------*
      *              * Scrittura su sequenziale                        *
      *              *-------------------------------------------------*
           move      "PN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       put-nxt-out-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per l'accettazione del coefficiente di cambio *
      *    * valuta                                                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcc/prg/cpy/acoecmb0.acs"                   .

