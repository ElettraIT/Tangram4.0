           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-rig-cod-cli-rag    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cli-rag-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no sospensione documento          *
      *    *-----------------------------------------------------------*
       acc-snx-ebf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-snx-ebf        to   w-sav-snx-ebf          .
       acc-snx-ebf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-ebf-lun    to   v-car                  .
           move      w-exp-snx-ebf-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-exp-snx-ebf-tbl    to   v-txt                  .
      *
           if        w-rig-snx-ebf        =    spaces
                     move  1              to   v-num
           else if   w-rig-snx-ebf        =    "N"
                     move  1              to   v-num
           else if   w-rig-snx-ebf        =    "S"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-snx-ebf-999.
       acc-snx-ebf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "N"            to   w-rig-snx-ebf
           else if   v-num                =    2
                     move  "S"            to   w-rig-snx-ebf
           else      move  spaces         to   w-rig-snx-ebf          .
       acc-snx-ebf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-ebf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-ebf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-snx-ebf-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-snx-ebf-100.
       acc-snx-ebf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Si/no sospensione documento       *
      *    *-----------------------------------------------------------*
       vis-snx-ebf-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-ebf-lun    to   v-car                  .
           move      w-exp-snx-ebf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-exp-snx-ebf-tbl    to   v-txt                  .
      *
           if        w-rig-snx-ebf        =    spaces
                     move  1              to   v-num
           else if   w-rig-snx-ebf        =    "N"
                     move  1              to   v-num
           else if   w-rig-snx-ebf        =    "S"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-ebf-999.
           exit.

      *    *===========================================================*
