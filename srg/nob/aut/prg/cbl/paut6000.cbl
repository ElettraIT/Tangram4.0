      *                  *---------------------------------------------*
           move      w-att-orc-prt-num    to   w-att-orc-prt-wnu      .
           subtract  1                    from w-att-orc-prt-wpr      .
           if        w-att-orc-prt-wpr    =    zero
                     move  zero           to   w-att-orc-prt-wnu      .
           move      w-att-orc-prt-wnu    to   rn-orc-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
       rip-orc-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
