      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-tot      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-ctr      .
       det-tot-doc-100.
           add       1                    to   w-det-tot-doc-ctr      .
           if        w-det-tot-doc-ctr    >    6
                     go to det-tot-doc-800.
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   =    zero
                     go to det-tot-doc-100.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
           add       rf-bit-iva-ibl
                    (w-det-tot-doc-ctr)   to   w-det-tot-doc-tot      .
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   >    900
                     move  rf-bit-iva-imp
                          (w-det-tot-doc-ctr)
                                          to   w-det-tot-doc-wpa
                     go to det-tot-doc-600.
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   >    100 
                     go to det-tot-doc-700.
           multiply  rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   by   rf-bit-iva-ibl
                                              (w-det-tot-doc-ctr)
                                        giving w-det-tot-doc-wpa      .
           divide    100                  into w-det-tot-doc-wpa
                                        giving w-det-tot-doc-s11
                                     remainder w-det-tot-doc-wpr      .
           move      w-det-tot-doc-s11    to   w-det-tot-doc-wpa      .
           if        w-det-tot-doc-wpr    >    zero
                     add      1           to   w-det-tot-doc-wpa
           else if   w-det-tot-doc-wpr    <    zero
                     subtract 1           from w-det-tot-doc-wpa      .
       det-tot-doc-600.
           add       w-det-tot-doc-wpa    to   w-det-tot-doc-tot      .
       det-tot-doc-700.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-doc-100.
       det-tot-doc-800.
      *              *-------------------------------------------------*
      *              * Eventuale eliminazione spese incasso            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se totale maggiore                     *
      *                  *---------------------------------------------*
           if        w-det-tot-doc-tot    <    rf-bit-tot-sic
                     go to det-tot-doc-850.
      *                  *---------------------------------------------*
      *                  * Test se esistenti                           *
      *                  *---------------------------------------------*
           if        rf-bit-tot-sic       =    zero
                     go to det-tot-doc-850.
      *                  *---------------------------------------------*
      *                  * Applicazione aliquota Iva 20%               *
      *                  *---------------------------------------------*
           move      rf-bit-tot-sic       to   d-imp-iva-ibl-iva      .
           move      00020                to   d-imp-iva-cod-iva      .
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      "DI"                 to   d-imp-iva-tip-ope      .
           move      "pgm/cge/prg/obj/dimpiva0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-imp-iva              .
      *                  *---------------------------------------------*
      *                  * Aggiornamento del totale documento          *
      *                  *---------------------------------------------*
           subtract  rf-bit-tot-sic       from w-det-tot-doc-tot      .
           subtract  d-imp-iva-ims-iva    from w-det-tot-doc-tot      .
       det-tot-doc-850.
      *              *-------------------------------------------------*
      *              * Eventuale conversione in valuta base            *
      *              *-------------------------------------------------*
           if        rf-bit-sgl-vpf       =    c-sgl
                     go to det-tot-doc-900.
           move      rf-bit-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-bit-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-bit-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-bit-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      w-det-tot-doc-tot    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-det-tot-doc-tot      .
       det-tot-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-tot-doc-999.
       det-tot-doc-999.
           exit.

