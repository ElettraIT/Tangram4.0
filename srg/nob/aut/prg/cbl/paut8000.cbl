      *    *===========================================================*
      *    * Determinazione prezzo netto                               *
      *    *-----------------------------------------------------------*
       det-prz-net-000.
      *              *-------------------------------------------------*
      *              * Se valore in input a zero : uscita              *
      *              *-------------------------------------------------*
           if        w-det-prz-net-prz    =    zero
                     go to det-prz-net-999.
      *              *-------------------------------------------------*
      *              * Se percentuali di sconto tutte a zero, prezzo   *
      *              * netto pari al valore in input : uscita          *
      *              *-------------------------------------------------*
           if        w-det-prz-net-psc (1)
                                          =    zero and
                     w-det-prz-net-psc (2)
                                          =    zero and
                     w-det-prz-net-psc (3)
                                          =    zero and
                     w-det-prz-net-psc (4)
                                          =    zero and
                     w-det-prz-net-psc (5)
                                          =    zero
                     go to det-prz-net-999.
      *              *-------------------------------------------------*
      *              * Ciclo per abbattimento con sconti               *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-prz-net-ctr      .
       det-prz-net-100.
           add       1                    to   w-det-prz-net-ctr      .
           if        w-det-prz-net-ctr    >    5
                     go to det-prz-net-999.
      *                  *---------------------------------------------*
      *                  * Richiamo routine di calcolo                 *
      *                  *---------------------------------------------*
           move      w-det-prz-net-prz    to   w-cal-imp-sco-iml      .
           move      w-det-prz-net-psc
                    (w-det-prz-net-ctr)   to   w-cal-imp-sco-psc      .
           perform   cal-imp-sco-000      thru cal-imp-sco-999        .
           move      w-cal-imp-sco-imn    to   w-det-prz-net-prz      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-prz-net-100.
       det-prz-net-999.
           exit.

      *    *===========================================================*
      *    * Routine di calcolo importo scontato                       *
      *    *                                                           *
      *    * Input  : w-cal-imp-sco-iml = importo lordo da scontare    *
      *    *        : w-cal-imp-sco-psc = percentuale di sconto        *
      *    *                                                           *
      *    * Output : w-cal-imp-sco-imn = importo netto scontato       *
      *    *          w-cal-imp-sco-ams = ammontare dello sconto       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       cal-imp-sco-000.
      *              *-------------------------------------------------*
      *              * Se percentuale di sconto a zero : uscita        *
      *              *-------------------------------------------------*
           if        w-cal-imp-sco-psc    =    zero
                     move  w-cal-imp-sco-iml
                                          to   w-cal-imp-sco-imn
                     move  zero           to   w-cal-imp-sco-ams
                     go to cal-imp-sco-999.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           subtract  w-cal-imp-sco-psc    from 100,0
                                        giving w-cal-imp-sco-w01      .
           multiply  w-cal-imp-sco-iml    by   w-cal-imp-sco-w01
                                        giving w-cal-imp-sco-w02      .
           divide    100                  into w-cal-imp-sco-w02
                                        giving w-cal-imp-sco-imn
                                               rounded                .
           subtract  w-cal-imp-sco-imn    from w-cal-imp-sco-iml
                                        giving w-cal-imp-sco-ams      .
       cal-imp-sco-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo ordini clienti  *
      *    *-----------------------------------------------------------*
       att-orc-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [orcprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-orc-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-orc-prt-saa      .
           move      w-att-orc-prt-saa    to   rn-orc-prt-scl-ann     .
           move      w-att-orc-prt-dpz    to   rn-orc-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [orcprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-orc-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-orc-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-orc-prt-000.
       att-orc-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-orc-prt-num-prt   to   w-att-orc-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-orc-prt-wpr      .
           if        w-att-orc-prt-wpr    =    zero
                     move  1              to   w-att-orc-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-orc-prt-saa    to   w-att-orc-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-orc-prt-dpz    to   w-att-orc-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-orc-prt-wnu    to   rn-orc-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-orc-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-orc-prt-num-prt   to   w-att-orc-prt-num      .
       att-orc-prt-999.
           exit.

