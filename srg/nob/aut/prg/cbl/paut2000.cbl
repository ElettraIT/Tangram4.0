           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      s-mes                to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Risultato in campo di output        *
      *                          *-------------------------------------*
           move      p-edt                to   w-out-001-mes-bol      .
      *                      *-----------------------------------------*
      *                      * Giorno                                  *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      s-gio                to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Risultato in campo di output        *
      *                          *-------------------------------------*
           move      p-edt                to   w-out-001-gio-bol      .
      *                  *---------------------------------------------*
      *                  * Partita Iva                                 *
      *                  *---------------------------------------------*
           move      w-ref-sqz-pds-fnt    to   w-out-001-prt-iva      .
      *                  *---------------------------------------------*
      *                  * Codice divisione                            *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-001-cod-div      .
      *                  *---------------------------------------------*
      *                  * Codice cliente - Padis                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-ref-sqz-pds-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Risultato in campo di output        *
      *                          *-------------------------------------*
           move      p-edt                to   w-out-001-cod-cli      .
      *                          *-------------------------------------*
      *                          * Allineamento a sx.                  *
      *                          *-------------------------------------*
           move      10                   to   w-all-str-lun          .
           move      w-out-001-cod-cli    to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
           move      w-all-str-alf        to   w-out-001-cod-cli      .
      *                  *---------------------------------------------*
      *                  * Codice destinatario                         *
      *                  *                                             *
      *                  * Codice dipendenza letto da bolla            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione protocollo bolla         *
      *                      *-----------------------------------------*
           move      rf-fir-cod-dpz       to   w-det-prt-bit-dpz      .
           move      rf-fir-bcc-num       to   w-det-prt-bit-num      .
           move      rf-fir-bcc-dat       to   w-det-prt-bit-dat      .
           move      rf-fir-bcc-tip       to   w-det-prt-bit-tmo      .
           perform   det-prt-bit-000      thru det-prt-bit-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [bit]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [bit]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-det-prt-bit-prt    to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [dcc]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] per il codice      *
      *                      * dipendenza                              *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-bit-cod-arc       to   rf-dcc-cod-cli         .
           move      rf-bit-dpz-arc       to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Il numero di telex ospita il codice per *
      *                      * la Padis                                *
      *                      *-----------------------------------------*
           move      rf-dcc-num-tlx       to   w-out-001-cod-dst      .
      *                  *---------------------------------------------*
      *                  * Descrizione destinatario                    *
      *                  *                                             *
      *                  * Dal campo 'e-mail'                          *
      *                  *---------------------------------------------*
           move      rf-dcc-idn-ema       to   w-out-001-des-dst      .
           move      rf-dcc-idn-em2       to   w-out-001-des-dst
                                              (21 : 10)               .
      *                  *---------------------------------------------*
      *                  * Filler di 13 caratteri                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-001-fil-ler      .
      *                  *---------------------------------------------*
      *                  * Fine riga : CR + LF                         *
      *                  *---------------------------------------------*
           move      w-flg-crx-lfx        to   w-out-001-crx-lfx      .
      *              *-------------------------------------------------*
      *              * Scrittura record in output                      *
      *              *-------------------------------------------------*
           move      w-out-001            to   g-rec                  .
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       prn-liv-det-tes-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-tes-999.
       prn-liv-det-tes-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Intestazione standard                           *
      *              *-------------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                  *---------------------------------------------*
      *                  * Se uscita per interruzione forzata          *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Put next generica per output in sequenziale               *
      *    *-----------------------------------------------------------*
       put-nxt-out-000.
      *              *-------------------------------------------------*
      *              * Scrittura su sequenziale                        *
      *              *-------------------------------------------------*
           move      "PN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       put-nxt-out-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per allineamenti a destra o a sinistra oppure *
      *    * al centro di campi alfanumerici di varia lunghezza, fi-   *
      *    * no ad un massimo di 240 caratteri, oppure per il conca-   *
      *    * tenamento, con o senza separazione, di max 10 substrin-   *
      *    * ghe in una unica substringa                               *
      *    *-----------------------------------------------------------*
      *    *                                                           *
      *    * 'all-str-asx-000/999'                                     *
      *    * 'all-str-adx-000/999'                                     *
      *    * 'all-str-cen-000/999'                                     *
      *    *                                                           *
      *    * Routines per l'allineamento di una stringa a sx o dx o al *
      *    * centro                                                    *
      *    *                                                           *
      *    * Input  : w-all-str-lun = Lunghezza massima della stringa  *
      *    *                                                           *
      *    *          w-all-str-alf = Valore della stringa da allinea- *
      *    *                          re                               *
      *    *                                                           *
      *    * Output : w-all-str-alf = Valore della stringa allineata   *
      *    *                          a sinistra                       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    *                                                           *
      *    * 'all-str-cat-000/999' - (senza uno spazio di separazione) *
      *    * 'all-str-csb-000/999' - (con uno spazio di separazione)   *
      *    *                                                           *
      *    * Routines per il concatenamento di max 10 stringhe di max  *
      *    * 80 caratteri ciascuna con o senza uno spazio di separa-   *
      *    * zione tra una stringa e l'altra                           *
      *    *                                                           *
      *    *                                                           *
      *    * Input  : w-all-str-lun     = Lunghezza massima della      *
      *    *                              stringa concatenata          *
      *    *                                                           *
      *    *          w-all-str-num     = Numero delle stringhe da     *
      *    *                              concatenare                  *
      *    *                                                           *
      *    *          w-all-str-cat (i) = Valore delle stringhe da     *
      *    *                              concatenare                  *
      *    *                                                           *
      *    * Output : w-all-str-alf     = Valore della stringa con-    *
      *    *                              catenata, allineata a si-    *
      *    *                              nistra                       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wallstr0.cps"                   .

      *    *===========================================================*
      *    * Determinazione protocollo bolla cliente                   *
      *    *-----------------------------------------------------------*
       det-prt-bit-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-prt-bit-prt      .
      *              *-------------------------------------------------*
      *              * Start su [bit]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "IDEDOC    "         to   f-key                  .
           move      w-det-prt-bit-dat    to   rf-bit-dat-doc         .
           move      w-det-prt-bit-dpz    to   rf-bit-cod-dpz         .
           move      w-det-prt-bit-num    to   rf-bit-num-doc         .
           move      w-det-prt-bit-tmo    to   rf-bit-cod-tmb         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-bit-900.
       det-prt-bit-100.
      *              *-------------------------------------------------*
      *              * Read next su [bit]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-bit-900.
       det-prt-bit-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-bit-dat-doc       not  = w-det-prt-bit-dat or
                     rf-bit-cod-dpz       not  = w-det-prt-bit-dpz or
                     rf-bit-num-doc       not  = w-det-prt-bit-num or
                     rf-bit-cod-tmb       not  = w-det-prt-bit-tmo
                     go to det-prt-bit-900.
       det-prt-bit-400.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero protocollo               *
      *              *-------------------------------------------------*
           move      rf-bit-num-prt       to   w-det-prt-bit-prt      .
       det-prt-bit-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     det-prt-bit-100.
       det-prt-bit-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prt-bit-999.
       det-prt-bit-999.
           exit.

