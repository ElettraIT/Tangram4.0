      *    * aggiornamenti contabili per movimenti di portafoglio      *
      *    *-----------------------------------------------------------*
       prs-prm-fat-000.
      *              *-------------------------------------------------*
      *              * Open file [fat]                                 *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffat"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fat                 .
       prs-prm-fat-100.
      *              *-------------------------------------------------*
      *              * Lettura record personalizzazioni                *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFAT    "         to   f-key                  .
           move      01                   to   rf-fat-tip-rec         .
           move      "fat420    "         to   rf-fat-cod-rec         .
           move      "pgm/fat/fls/ioc/obj/ioffat"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fat                 .
      *              *-------------------------------------------------*
      *              * Deviazione secondo l'esito della lettura        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to prs-prm-fat-200
           else      go to prs-prm-fat-400.
       prs-prm-fat-200.
      *              *-------------------------------------------------*
      *              * Se record personalizzazioni esistente           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Dati record in area per ridefinizione delle *
      *                  * personalizzazioni                           *
      *                  *---------------------------------------------*
           move      rf-fat-dat-rec       to   w-fil-fat-rec          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     prs-prm-fat-900.
       prs-prm-fat-400.
      *              *-------------------------------------------------*
      *              * Se record personalizzazioni non esistente       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     prs-prm-fat-900.
       prs-prm-fat-900.
      *              *-------------------------------------------------*
      *              * Close file [fat]                                *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffat"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fat                 .
       prs-prm-fat-999.
           exit.

