      *                  *---------------------------------------------*
           move      zero                 to   rf-mgr-num-prg         .
      *              *-------------------------------------------------*
      *              * Start file [mgr] per chiave "ARCDAT"            *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCDAT"             to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-900.
       det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mgr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  det-sdo-dat-900.
      *              *-------------------------------------------------*
      *              * Test se superamento limiti massimi              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo e codice archivio                      *
      *                  *---------------------------------------------*
           if        rf-mgr-tip-arc        not  = "C"           or
                     rf-mgr-cod-arc        not  = w-sad-cod-cli
                     go to  det-sdo-dat-900.
      *                  *---------------------------------------------*
      *                  * Data registrazione                          *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-reg       >    w-sad-dat-sad
                     go to  det-sdo-dat-900.
      *                  *---------------------------------------------*
      *                  * Se movimento di bilancio si ricicla         *
      *                  *---------------------------------------------*
           if        rf-mgr-snx-mob        not  = "N"
                     go to  det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo alla data                   *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     add      rf-mgr-imp-mov
                                          to   w-sad-prg-ave
           else      add      rf-mgr-imp-mov
                                          to   w-sad-prg-dar          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura [mgr]                        *
      *              *-------------------------------------------------*
           go to     det-sdo-dat-500.
       det-sdo-dat-900.
      *              *-------------------------------------------------*
      *              * Determinazione saldo alla data richiesta        *
      *              *-------------------------------------------------*
           move      w-sad-sdo-ini        to   w-sad-sdo-dat          .
           add       w-sad-prg-dar        to   w-sad-sdo-dat          .
           subtract  w-sad-prg-ave        from w-sad-sdo-dat          .
       det-sdo-dat-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-ese-cge-dtr        to   s-dat                  .
           if        w-ese-cge-mce        =    12         or
                     s-mes                >    w-ese-cge-mce
                     move  s-saa          to   w-ese-cge-esa
                     go to det-ese-cge-500.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-ese-cge-esa          .
       det-ese-cge-500.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-ese-cge-esm          .
           if        w-ese-cge-mce        =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-ese-cge-mce
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-ese-cge-mce
                     add   12             to   w-ese-cge-esm
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-ese-cge-esm          .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
      *    * Determinazione contropartita registrazione                *
      *    *-----------------------------------------------------------*
       det-cpt-mgr-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cpt-mgr-cod      .
           move      spaces               to   w-det-cpt-mgr-com      .
           move      zero                 to   w-det-cpt-mgr-ctr      .
       det-cpt-mgr-050.
      *              *-------------------------------------------------*
      *              * Se causale senza descrizione                    *
      *              *-------------------------------------------------*
           if        rf-mgt-des-cau       =    spaces
                     move  rf-mgr-com-rig to   w-det-cpt-mgr-com
                     go to det-cpt-mgr-900.
       det-cpt-mgr-100.
      *              *-------------------------------------------------*
      *              * Start su file [mgr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATREG    "         to   f-key                  .
           move      w-det-cpt-mgr-drg    to   rf-mgr-dat-reg         .
           move      w-det-cpt-mgr-prt    to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita con flag a 'no'    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cpt-mgr-999.
       det-cpt-mgr-200.
      *              *-------------------------------------------------*
      *              * Next su [mgr]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a test finale                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cpt-mgr-800.
       det-cpt-mgr-300.
      *              *-------------------------------------------------*
      *              * Max su [mgr], se non superato : a test finale   *
      *              *-------------------------------------------------*
           if        rf-mgr-dat-reg       not  = w-det-cpt-mgr-drg or
                     rf-mgr-num-prt       not  = w-det-cpt-mgr-prt
                     go to det-cpt-mgr-800.
       det-cpt-mgr-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
       det-cpt-mgr-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-cpt-mgr-ctr      .
       det-cpt-mgr-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione del codice sottoconto           *
      *              *-------------------------------------------------*
           move      rf-mgr-cod-pdc       to   w-det-cpt-mgr-cod      .
       det-cpt-mgr-620.
      *              *-------------------------------------------------*
      *              * Eventuale bufferizzazione commento              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo conto       *
      *                  *---------------------------------------------*
           if        w-det-cpt-mgr-tco    =    "G"
                     go to det-cpt-mgr-640
           else if   w-det-cpt-mgr-tco    =    "C"
                     go to det-cpt-mgr-650
           else      go to det-cpt-mgr-660.
       det-cpt-mgr-640.
      *                  *---------------------------------------------*
      *                  * Se di 'Generale'                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       =    w-det-cpt-mgr-tco and
                     rf-mgr-cod-pdc       =    w-det-cpt-mgr-cco
                     move  rf-mgr-com-rig to   w-det-cpt-mgr-com      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     det-cpt-mgr-700.
       det-cpt-mgr-650.
      *                  *---------------------------------------------*
      *                  * Se di 'Clienti'                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       =    w-det-cpt-mgr-tco and
                     rf-mgr-cod-arc       =    w-det-cpt-mgr-cco
                     move  rf-mgr-com-rig to   w-det-cpt-mgr-com      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     det-cpt-mgr-700.
       det-cpt-mgr-660.
      *                  *---------------------------------------------*
      *                  * Se di 'Fornitori'                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       =    w-det-cpt-mgr-tco and
                     rf-mgr-cod-arc       =    w-det-cpt-mgr-cco
                     move  rf-mgr-com-rig to   w-det-cpt-mgr-com      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     det-cpt-mgr-700.
       det-cpt-mgr-700.
      *              *-------------------------------------------------*
      *              * Riciclo a record [mgr] successivo               *
      *              *-------------------------------------------------*
           go to     det-cpt-mgr-200.
       det-cpt-mgr-800.
      *              *-------------------------------------------------*
      *              * Determinazione finale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se durante la ricerca e' stato trovato un   *
      *                  * numero di righe superiore a 2 si esce con   *
      *                  * il codice contropartita a zero              *
      *                  *---------------------------------------------*
           if        w-det-cpt-mgr-ctr    >    2
                     move  zero           to   w-det-cpt-mgr-cod      .
       det-cpt-mgr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-cpt-mgr-999.
       det-cpt-mgr-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

