      *    *===========================================================*
      *    * Aggiornamento record [hox]                                *
      *    *-----------------------------------------------------------*
       upd-rec-hox-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione del record                      *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "nob/aut/fls/ioc/obj/iofhox"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hox                 .
       upd-rec-hox-100.
      *              *-------------------------------------------------*
      *              * Lettura, con lock, del record                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT "            to   f-key                  .
           move      srt-num-prt          to   rf-hox-num-prt         .
           move      "nob/aut/fls/ioc/obj/iofhox"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hox                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito lettura     *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to upd-rec-hox-300.
       upd-rec-hox-200.
      *              *-------------------------------------------------*
      *              * Se record [hox] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Write record [hox] normalizzato             *
      *                  *---------------------------------------------*
           perform   wrt-rec-hox-000      thru wrt-rec-hox-999        .
      *                  *---------------------------------------------*
      *                  * Ripetizione lettura                         *
      *                  *---------------------------------------------*
           go to     upd-rec-hox-100.
       upd-rec-hox-300.
      *              *-------------------------------------------------*
      *              * Se record [hox] esistente                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice vettore                              *
      *                  *---------------------------------------------*
           move      srt-cod-vet          to   rf-hox-cod-vet         .
      *                  *---------------------------------------------*
      *                  * Data consegna                               *
      *                  *---------------------------------------------*
           if        srt-dat-cns          =    zero
                     move  srt-dat-reg    to   rf-hox-dat-cns
           else      move  srt-dat-cns    to   rf-hox-dat-cns         .
       upd-rec-hox-700.
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "nob/aut/fls/ioc/obj/iofhox"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hox                 .
      *                  *---------------------------------------------*
      *                  * Release                                     *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "nob/aut/fls/ioc/obj/iofhox"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hox                 .
       upd-rec-hox-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     upd-rec-hox-999.
       upd-rec-hox-999.
           exit.

