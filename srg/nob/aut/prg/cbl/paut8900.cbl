      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero d'ordine progressivo di *
      *              * rilascio al sort                                *
      *              *-------------------------------------------------*
           move      zero                 to   w-gen-num-prg          .
      *              *-------------------------------------------------*
      *              * Ciclo per [oct] su ordini clienti               *
      *              *                                                 *
      *              * NOBILI                                          *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-oct-000  thru stp-srt-inp-oct-999    .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Ciclo per [oct]                                           *
      *    *-----------------------------------------------------------*
       stp-srt-inp-oct-000.
      *              *-------------------------------------------------*
      *              * Start su file [oct]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-rif           to   rf-oct-dat-doc         .
           move      zero                 to   rf-oct-cod-dpz         .
           move      zero                 to   rf-oct-num-doc         .
           move      spaces               to   rf-oct-tmo-orc         .
           move      zero                 to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-oct-900.
       stp-srt-inp-oct-200.
      *              *-------------------------------------------------*
      *              * Read-next su archivio [oct]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-oct-900.
       stp-srt-inp-oct-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
       stp-srt-inp-oct-350.
      *              *-------------------------------------------------*
      *              * Lettura record [dcc]                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [dcc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-oct-cod-arc       to   rf-dcc-cod-cli         .
           move      rf-oct-dpz-arc       to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
       stp-srt-inp-oct-400.
      *              *-------------------------------------------------*
      *              * Selezione su codice vettore                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In campo di comodo                          *
      *                  *---------------------------------------------*
           move      rf-dcc-cod-vet       to   w-wrk-cod-vet          .
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione codice vettore in *
      *                  * testata ordine                              *
      *                  *---------------------------------------------*
           if        rf-oct-cod-vet       not  numeric
                     move  zero           to   rf-oct-cod-vet         .
      *                  *---------------------------------------------*
      *                  * Eventuale codice vettore in ordine cliente  *
      *                  *---------------------------------------------*
           if        rf-oct-cod-vet       not  = zero
                     move  rf-oct-cod-vet to   w-wrk-cod-vet          .
      *                  *---------------------------------------------*
      *                  * Selezione su codice vettore                 *
      *                  *                                             *
      *                  * NOBILI - Solo STEF                          *
      *                  *---------------------------------------------*
           if        w-wrk-cod-vet        not  = 0000079
                     go to stp-srt-inp-oct-200.
       stp-srt-inp-oct-600.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave per il sort                          *
      *                  *---------------------------------------------*
           move      "1"                  to   srt-key-rec            .
           move      "oct"                to   srt-tip-rec            .
           add       1                    to   w-gen-num-prg          .
           move      w-gen-num-prg        to   srt-prg-rec            .
      *                  *---------------------------------------------*
      *                  * Dati per il sort                            *
      *                  *---------------------------------------------*
           move      rf-oct-num-prt       to   srt-num-prt            .
           move      rf-oct-dat-doc       to   srt-dat-reg            .
           move      rf-oct-dat-cns       to   srt-dat-cns            .
           move      rf-oct-cod-vet       to   srt-cod-vet            .
       stp-srt-inp-oct-700.
      *                  *---------------------------------------------*
      *                  * Rilascio record al sort                     *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-oct-800.
      *                  *---------------------------------------------*
      *                  * Riciclo a record [oct] successivo           *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-oct-200.
       stp-srt-inp-oct-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-oct-999.
       stp-srt-inp-oct-999.
           exit.
      
