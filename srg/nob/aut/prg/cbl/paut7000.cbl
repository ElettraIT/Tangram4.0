           if        rr-tip-exe           =    zero
                     go to acc-tip-exe-100.
       acc-tip-exe-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-exe-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-tip-exe-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-tip-exe-100.
       acc-tip-exe-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo codice cliente                        *
      *              *-------------------------------------------------*
           if        rr-cod-cli           not  = zero
                     go to tdo-ric-sel-200.
           move      "Manca il codice cliente !                         
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su data emissione min - max           *
      *              *-------------------------------------------------*
           if        rr-dem-min           =    zero or
                     rr-dem-max           =    zero
                     go to tdo-ric-sel-300.
           if        rr-dem-max           not  < rr-dem-min
                     go to tdo-ric-sel-300.
           move      "Data emissione massima inferiore alla data emissio
      -              "ne minima      "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo su numero documento min - max         *
      *              *-------------------------------------------------*
           if        rr-ndo-min           =    zero or
                     rr-ndo-max           =    zero
                     go to tdo-ric-sel-320.
           if        rr-ndo-max           not  < rr-ndo-min
                     go to tdo-ric-sel-320.
           move      "Numero documento massimo inferiore a quello minimo
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-320.
           if        rr-ndo-min           not  = zero
                     go to tdo-ric-sel-340.
           move      "Manca il numero documento iniziale !              
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-340.
           if        rr-ndo-min           =    rr-ndo-max
                     go to tdo-ric-sel-800.
           move      "Il numero documento finale dev'essere uguale all'i
      -              "niziale !      "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita con successo                             *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Uscita con errori                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Data emissione min - max                        *
      *              *-------------------------------------------------*
           if        rr-dem-max           not  = zero
                     go to reg-ric-sel-100.
           if        rr-dem-min           =    zero
                     move 9999999         to   rr-dem-max
           else      move rr-dem-min      to   rr-dem-max             .
       reg-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Numero documento min - max                      *
      *              *-------------------------------------------------*
           if        rr-ndo-max           not  = zero
                     go to reg-ric-sel-200.
           if        rr-ndo-min           =    zero
                     move 99999999999     to   rr-ndo-max
           else      move rr-ndo-min      to   rr-ndo-max             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Tipo esecuzione                                 *
      *              *-------------------------------------------------*
           if        rr-tip-exe           =    zero
                     move  01             to   rr-tip-exe             .
           if        rr-tip-exe           =    01
                     move  "T"            to   rr-tip-exe-flg
           else      move  "P"            to   rr-tip-exe-flg         .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      zero                 to   rr-cod-cli             .
           move      spaces               to   rr-cod-cli-rag         .
           move      spaces               to   rr-cod-cli-via         .
           move      spaces               to   rr-cod-cli-loc         .
           move      spaces               to   rr-cod-cli-edi         .
           move      zero                 to   rr-dem-min             .
           move      zero                 to   rr-dem-max             .
           move      zero                 to   rr-ndo-min             .
           move      zero                 to   rr-ndo-max             .
           move      zero                 to   rr-tip-exe             .
           move      spaces               to   rr-tip-exe-flg         .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe          *
      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio fatture clienti per EDI                *
      *    *-----------------------------------------------------------*
       crz-arc-pre-000.
      *              *-------------------------------------------------*
      *              * Apertura files                                  *
      *              *-------------------------------------------------*
           perform   crz-arc-fat-opn-000  thru crz-arc-fat-opn-999    .
      *              *-------------------------------------------------*
      *              * Sort                                            *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   crz-arc-srt-000
                                          thru crz-arc-srt-999
                     output procedure     is   crz-arc-fat-000
                                          thru crz-arc-fat-999        .
      *              *-------------------------------------------------*
      *              * Chiusura files                                  *
      *              *-------------------------------------------------*
           perform   crz-arc-fat-cls-000  thru crz-arc-fat-cls-999    .
       crz-arc-pre-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio fatture clienti per EDI                *
      *    *                                                           *
      *    * Procedura di input                                        *
      *    *-----------------------------------------------------------*
       crz-arc-srt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatori                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-rec-num-rig          .
           move      zero                 to   w-rec-num-fat          .
       crz-arc-srt-100.
      *              *-------------------------------------------------*
      *              * Start su file [fit]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CLIDAT    "         to   f-key                  .
           move      rr-cod-cli           to   rf-fit-cod-cli         .
           move      rr-dem-min           to   rf-fit-dat-doc         .
           move      zero                 to   rf-fit-num-doc         .
           move      spaces               to   rf-fit-cod-tmo         .
           move      zero                 to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a uscita                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-srt-900.
       crz-arc-srt-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [fit]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : A uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-srt-900.
       crz-arc-srt-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-fit-cod-cli       not  = rr-cod-cli or
                     rf-fit-dat-doc       >    rr-dem-max
                     go to crz-arc-srt-900.
       crz-arc-srt-400.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero documento                    *
      *                  *---------------------------------------------*
           if        rf-fit-num-doc       <    rr-ndo-min or
                     rf-fit-num-doc       >    rr-ndo-max
                     go to crz-arc-srt-200.
       crz-arc-srt-600.
      *              *-------------------------------------------------*
      *              * Composizione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record per Sort             *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           move      rf-fit-num-doc       to   srt-num-key            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-fit               to   srt-rec-fit            .
       crz-arc-srt-700.
      *              *-------------------------------------------------*
      *              * Rilascio record al Sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       crz-arc-srt-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale file [fit]       *
      *              *-------------------------------------------------*
           go to     crz-arc-srt-200.
       crz-arc-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     crz-arc-srt-999.
       crz-arc-srt-999.
           exit.

      *    *===========================================================*
      *    * Creazione archivio fatture clienti per EDI                *
      *    *                                                           *
      *    * Procedura di output                                       *
      *    *-----------------------------------------------------------*
       crz-arc-fat-000.
       crz-arc-fat-100.
      *              *-------------------------------------------------*
      *              * Lettura record da sort                          *
      *              *-------------------------------------------------*
           return    srt   at end
                     go to crz-arc-fat-900.
      *              *-------------------------------------------------*
      *              * Recupero record [fit]                           *
      *              *-------------------------------------------------*
           move      srt-rec-fit          to   rf-fit                 .
      *              *-------------------------------------------------*
      *              * Attivazione flag di testata da scrivere         *
      *              *-------------------------------------------------*
           move      "#"                  to   w-crz-arc-fat-ftd      .
      *              *-------------------------------------------------*
      *              * Attivazione flag di file sequenziale da aprire  *
      *              *-------------------------------------------------*
           move      "#"                  to   w-crz-arc-fat-ffa      .
       crz-arc-fat-150.
      *              *-------------------------------------------------*
      *              * Start su file [fir]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-fit-num-prt       to   rf-fir-num-prt         .
           move      zero                 to   rf-fir-num-prg         .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : A riciclo su [fit]        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-fat-100.
       crz-arc-fat-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [fir]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : A riciclo su [fit]           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to crz-arc-fat-600.
       crz-arc-fat-230.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-fir-num-prt       not  = rf-fit-num-prt
                     go to crz-arc-fat-600.
       crz-arc-fat-240.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        rf-fir-tip-rig (1:1) not  = "P" or
                     rf-fir-tip-rig (2:1) not  = spaces
                     go to crz-arc-fat-200.
       crz-arc-fat-300.
      *              *-------------------------------------------------*
      *              * Test se file sequenziale da aprire              *
      *              *-------------------------------------------------*
           if        w-crz-arc-fat-ffa    =    spaces
                     go to crz-arc-fat-350.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag file da aprire         *
      *                  *---------------------------------------------*
           move      spaces               to   w-crz-arc-fat-ffa      .
      *                  *---------------------------------------------*
      *                  * Apertura file sequenziale in output         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione pathname                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing codice cliente              *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      rr-cod-cli           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-gen-cod-cli          .
      *                          *-------------------------------------*
      *                          * Editing anno documento              *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rr-ndo-min (02 : 02) to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-gen-ann-doc          .
      *                          *-------------------------------------*
      *                          * Editing numero documento minimo     *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      rr-ndo-min (06 : 06) to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-gen-num-doc          .
      *                          *-------------------------------------*
      *                          * Composizione stringa                *
      *                          *-------------------------------------*
           move      spaces               to   w-det-pth-fso-nam      .
           string    "INVOIC_"  delimited by   size
                     w-gen-ann-doc
                                delimited by   spaces 
                     "_"        delimited by   size
                     w-gen-num-doc
                                delimited by   spaces 
                                          into w-det-pth-fso-nam      .
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           perform   det-pth-fso-000      thru det-pth-fso-999        .
      *                      *-----------------------------------------*
      *                      * Apertura del file in output             *
      *                      *-----------------------------------------*
           move      "OO"                 to   g-ope                  .
           move      "seq "               to   g-nam                  .
           move      w-det-pth-fso-pt1    to   g-pat                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       crz-arc-fat-350.
      *              *-------------------------------------------------*
      *              * Test se testata da scrivere                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-crz-arc-fat-ftd    =    spaces
                     go to crz-arc-fat-400.
      *                  *---------------------------------------------*
      *                  * Record di intestazione                      *
      *                  *---------------------------------------------*
           perform   scr-int-fat-000      thru scr-int-fat-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag testata da scrivere    *
      *                  *---------------------------------------------*
           move      spaces               to   w-crz-arc-fat-ftd      .
      *                  *---------------------------------------------*
      *                  * Scrittura testata fattura cliente           *
      *                  *---------------------------------------------*
           perform   scr-tes-fat-000      thru scr-tes-fat-999        .
       crz-arc-fat-400.
      *              *-------------------------------------------------*
      *              * Scrittura riga fattura cliente                  *
      *              *-------------------------------------------------*
           perform   scr-rig-fat-000      thru scr-rig-fat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale [fir]            *
      *              *-------------------------------------------------*
           go to     crz-arc-fat-200.
       crz-arc-fat-600.
      *              *-------------------------------------------------*
      *              * Scrittura piede fattura cliente                 *
      *              *-------------------------------------------------*
           perform   scr-pie-fat-000      thru scr-pie-fat-999        .
