                     go to clc-tbl-scd-494.
           move      w-clc-tbl-scd-wt2
                    (w-clc-tbl-scd-wdm)   to   w-clc-tbl-scd-wdg      .
       clc-tbl-scd-494.
      *                                      *-------------------------*
      *                                      * Aggiornamento decorrenza*
      *                                      * per scdenza successiva  *
      *                                      *-------------------------*
           if        w-clc-tbl-scd-gdi
                    (w-clc-tbl-scd-wip)   =    01
                     add  30              to   w-clc-tbl-scd-wpd
           else if   w-clc-tbl-scd-gdi
                    (w-clc-tbl-scd-wip)   =    02
                     add  15              to   w-clc-tbl-scd-wpd      .
       clc-tbl-scd-500.
      *                              *---------------------------------*
      *                              * Data scadenza calcolata         *
      *                              *---------------------------------*
           move      w-clc-tbl-scd-wdt    to   w-clc-tbl-scd-dds
                                              (w-clc-tbl-scd-nts)     .
       clc-tbl-scd-505.
      *                              *---------------------------------*
      *                              * Codice della causale contabile  *
      *                              * per l'aggiornamento             *
      *                              *---------------------------------*
           move      w-clc-tbl-scd-ccp
                    (w-clc-tbl-scd-wip)   to   w-clc-tbl-scd-ccs
                                              (w-clc-tbl-scd-nts)     .
       clc-tbl-scd-510.
      *                              *---------------------------------*
      *                              * Importo della scadenza          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Deviazione a seconda se si  *
      *                                  * e' sull'ultima scadenza da  *
      *                                  * calcolare per il codice pa- *
      *                                  * gamento in esame oppure no  *
      *                                  *-----------------------------*
           if        w-clc-tbl-scd-wnc    =    w-clc-tbl-scd-wnd
                     go to clc-tbl-scd-512
           else      go to clc-tbl-scd-514.
       clc-tbl-scd-512.
      *                                  *-----------------------------*
      *                                  * Se si e' sull'ultima        *
      *                                  *-----------------------------*
           move      w-clc-tbl-scd-wap    to   w-clc-tbl-scd-ids
                                              (w-clc-tbl-scd-nts)     .
           subtract  w-clc-tbl-scd-wad    from w-clc-tbl-scd-ids
                                              (w-clc-tbl-scd-nts)     .
           go to     clc-tbl-scd-520.
       clc-tbl-scd-514.
      *                                  *-----------------------------*
      *                                  * Se non si e' sull'ultima    *
      *                                  *-----------------------------*
           move      w-clc-tbl-scd-wis    to   w-clc-tbl-scd-ids
                                              (w-clc-tbl-scd-nts)     .
       clc-tbl-scd-520.
      *                          *-------------------------------------*
      *                          * Incremento ammontare gia' distri-   *
      *                          * buito                               *
      *                          *-------------------------------------*
           add       w-clc-tbl-scd-ids
                    (w-clc-tbl-scd-nts)    to   w-clc-tbl-scd-wad     .
       clc-tbl-scd-530.
      *                          *-------------------------------------*
      *                          * Riciclo su prossima scadenza        *
      *                          *-------------------------------------*
           go to     clc-tbl-scd-290.
       clc-tbl-scd-590.
      *                  *---------------------------------------------*
      *                  * Riciclo su codice di pagamento successivo   *
      *                  *---------------------------------------------*
           go to     clc-tbl-scd-110.
       clc-tbl-scd-600.
      *              *-------------------------------------------------*
      *              * Compattamento della tabella calcolata           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se numero scadenze calcolate non superiore a*
      *                  * uno : nessun compattamento                  *
      *                  *---------------------------------------------*
           if        w-clc-tbl-scd-nts    not  > 1
                     go to clc-tbl-scd-999.
      *                  *---------------------------------------------*
      *                  * Ordinamento scadenze                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-clc-tbl-scd-wo1      .
       clc-tbl-scd-610.
           add       1                    to   w-clc-tbl-scd-wo1      .
           if        w-clc-tbl-scd-wo1    =    w-clc-tbl-scd-nts
                     go to  clc-tbl-scd-700.
           move      w-clc-tbl-scd-wo1    to   w-clc-tbl-scd-wo2
                                               w-clc-tbl-scd-wo3      .
           move      w-clc-tbl-scd-ets
                    (w-clc-tbl-scd-wo1)   to   w-clc-tbl-scd-wet      .
       clc-tbl-scd-620.
           add       1                    to   w-clc-tbl-scd-wo2      .
           if        w-clc-tbl-scd-wo2    >    w-clc-tbl-scd-nts
                     go to  clc-tbl-scd-630.
           if        w-clc-tbl-scd-ets
                    (w-clc-tbl-scd-wo2)   >    w-clc-tbl-scd-wet
                     go to  clc-tbl-scd-620.
           move      w-clc-tbl-scd-wo2    to   w-clc-tbl-scd-wo3      .
           move      w-clc-tbl-scd-ets
                    (w-clc-tbl-scd-wo2)   to   w-clc-tbl-scd-wet      .
           go to     clc-tbl-scd-620.
       clc-tbl-scd-630.
           move      w-clc-tbl-scd-wo2    to   w-clc-tbl-scd-wo4      .
           if        w-clc-tbl-scd-wet    >    w-clc-tbl-scd-ets
                                              (w-clc-tbl-scd-wo4)
                     go to  clc-tbl-scd-610.
           move      w-clc-tbl-scd-ets
                    (w-clc-tbl-scd-wo3)   to   w-clc-tbl-scd-wet      .
           move      w-clc-tbl-scd-ets
                    (w-clc-tbl-scd-wo4)   to   w-clc-tbl-scd-ets
                                              (w-clc-tbl-scd-wo3)     .
           move      w-clc-tbl-scd-wet    to   w-clc-tbl-scd-ets
                                              (w-clc-tbl-scd-wo4)     .
           go to     clc-tbl-scd-610.
       clc-tbl-scd-700.
      *                  *---------------------------------------------*
      *                  * Compattamento vero e proprio                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Azzeramento work per rottura            *
      *                      *-----------------------------------------*
           move      zero                 to   w-clc-tbl-scd-wct      .
           move      zero                 to   w-clc-tbl-scd-wcd      .
           move      zero                 to   w-clc-tbl-scd-wcc      .
      *                      *-----------------------------------------*
      *                      * Azzeramento contatori                   *
      *                      *-----------------------------------------*
           move      zero                 to   w-clc-tbl-scd-wo1      .
           move      zero                 to   w-clc-tbl-scd-wo2      .
       clc-tbl-scd-710.
           add       1                    to   w-clc-tbl-scd-wo1      .
           if        w-clc-tbl-scd-wo1    >    w-clc-tbl-scd-nts
                     go to clc-tbl-scd-750.
      *                      *-----------------------------------------*
      *                      * Test se rottura                         *
      *                      *-----------------------------------------*
           if        w-clc-tbl-scd-tds
                    (w-clc-tbl-scd-wo1)   =    w-clc-tbl-scd-wct and
                     w-clc-tbl-scd-dds
                    (w-clc-tbl-scd-wo1)   =    w-clc-tbl-scd-wcd and
                     w-clc-tbl-scd-ccs
                    (w-clc-tbl-scd-wo1)   =    w-clc-tbl-scd-wcc
                     go to clc-tbl-scd-730.
      *                      *-----------------------------------------*
      *                      * Se rottura                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Fine rottura precedente             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se prima rottura : oltre        *
      *                              *---------------------------------*
           if        w-clc-tbl-scd-wct    =    zero and
                     w-clc-tbl-scd-wcd    =    zero and
                     w-clc-tbl-scd-wcc    =    zero
                     go to clc-tbl-scd-720.
      *                              *---------------------------------*
      *                              * Incremento contatore elementi   *
      *                              *---------------------------------*
           add       1                    to   w-clc-tbl-scd-wo2      .
      *                              *---------------------------------*
      *                              * Bufferizzazione in tabella      *
      *                              *---------------------------------*
           move      w-clc-tbl-scd-wct    to   w-clc-tbl-scd-tds
                                              (w-clc-tbl-scd-wo2)     .
           move      w-clc-tbl-scd-wcd    to   w-clc-tbl-scd-dds
                                              (w-clc-tbl-scd-wo2)     .
           move      w-clc-tbl-scd-wcc    to   w-clc-tbl-scd-ccs
                                              (w-clc-tbl-scd-wo2)     .
           move      w-clc-tbl-scd-wci    to   w-clc-tbl-scd-ids
                                              (w-clc-tbl-scd-wo2)     .
       clc-tbl-scd-720.
      *                          *-------------------------------------*
      *                          * Inizio nuova rottura                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento area rottura      *
      *                              *---------------------------------*
           move      w-clc-tbl-scd-tds
                    (w-clc-tbl-scd-wo1)   to   w-clc-tbl-scd-wct      .
           move      w-clc-tbl-scd-dds
                    (w-clc-tbl-scd-wo1)   to   w-clc-tbl-scd-wcd      .
           move      w-clc-tbl-scd-ccs
                    (w-clc-tbl-scd-wo1)   to   w-clc-tbl-scd-wcc      .
      *                              *---------------------------------*
      *                              * Normalizzazione importo scadenza*
      *                              *---------------------------------*
           move      zero                 to   w-clc-tbl-scd-wci      .
       clc-tbl-scd-730.
      *                      *-----------------------------------------*
      *                      * Se non rottura                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento importo scadenza      *
      *                          *-------------------------------------*
           add       w-clc-tbl-scd-ids
                    (w-clc-tbl-scd-wo1)   to   w-clc-tbl-scd-wci      .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione tabella            *
      *                      *-----------------------------------------*
           go to     clc-tbl-scd-710.
       clc-tbl-scd-750.
      *                      *-----------------------------------------*
      *                      * Fine ultima rottura                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Incremento contatore elementi       *
      *                          *-------------------------------------*
           add       1                    to   w-clc-tbl-scd-wo2      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione in tabella          *
      *                          *-------------------------------------*
           move      w-clc-tbl-scd-wct    to   w-clc-tbl-scd-tds
                                              (w-clc-tbl-scd-wo2)     .
           move      w-clc-tbl-scd-wcd    to   w-clc-tbl-scd-dds
                                              (w-clc-tbl-scd-wo2)     .
           move      w-clc-tbl-scd-wcc    to   w-clc-tbl-scd-ccs
                                              (w-clc-tbl-scd-wo2)     .
           move      w-clc-tbl-scd-wci    to   w-clc-tbl-scd-ids
                                              (w-clc-tbl-scd-wo2)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero elementi in tabella*
      *                      *-----------------------------------------*
           move      w-clc-tbl-scd-wo2    to   w-clc-tbl-scd-nts      .
       clc-tbl-scd-999.
           exit.

