      *                  *---------------------------------------------*
           if        w-tst-cla-tst        not  = "PS  " and
                     w-tst-cla-tst        not  = "PCL5" and
                     w-tst-cla-tst        not  = "SPPX" and
                     w-tst-cla-tst        not  = "FAX "
                     move  w-det-tcb-efl-eft
                                          to   p-sel-eft-sel
                     go to pre-ass-sgr-620.
           if        r-fix-esp-fut (99 : 1)
                                          =    "*"
                     move  r-fix-top-lin  to   p-sel-eft-sel
           else      move  zero           to   p-sel-eft-sel          .
       pre-ass-sgr-620.
      *                  *---------------------------------------------*
      *                  * Corpo effettivo in linee selezionato        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se la classe stampante non e' ne' tipo  *
      *                      * PostScript ne' PCL5 ne' Special Printer *
      *                      * SPPX ne' Fax : nessuna forzatura        *
      *                      *-----------------------------------------*
           if        w-tst-cla-tst        not  = "PS  " and
                     w-tst-cla-tst        not  = "PCL5" and
                     w-tst-cla-tst        not  = "SPPX" and
                     w-tst-cla-tst        not  = "FAX "
                     move  w-det-tcb-efl-efc
                                          to   p-sel-efc-sel
                     go to pre-ass-sgr-640.
      *                      *-----------------------------------------*
      *                      * Se la classe stampante e' di tipo Post- *
      *                      * Script, ed inoltre il formato non e' lo *
      *                      * standard A4, bensi' si tratta di un A3, *
      *                      * oppure A2, o A1, o A0 : forzatura a 96  *
      *                      * linee di corpo                          *
      *                      *-----------------------------------------*
           if       (w-tst-cla-tst        =    "PS  "    ) and
                    (w-tst-scl-tst        =    "A3  " or
                     w-tst-scl-tst        =    "A2  " or
                     w-tst-scl-tst        =    "A1  " or
                     w-tst-scl-tst        =    "A0  "    )
                     move  96             to   p-sel-efc-sel
                     go to pre-ass-sgr-640.
      *                      *-----------------------------------------*
      *                      * Se Special Printer SPPX : si forza a 66 *
      *                      *-----------------------------------------*
           if        w-tst-cla-tst        =    "SPPX"
                     move  66             to   p-sel-efc-sel
                     go to pre-ass-sgr-640.
      *                      *-----------------------------------------*
      *                      * Se invece:                              *
      *                      *  - PostScript A4                        *
      *                      *  - PCL5                                 *
      *                      * si forza a 72, con eventuale correzione *
      *                      * per Top e Bottom                        *
      *                      *-----------------------------------------*
           move      72                   to   p-sel-efc-sel          .
           if        r-fix-esp-fut (99 : 1)
                                          =    "*"
                     subtract  r-fix-top-lin
                                          from p-sel-efc-sel
                     subtract  r-fix-bot-lin
                                          from p-sel-efc-sel          .
      *                      *-----------------------------------------*
      *                      * Se Fax : si forza a 66                  *
      *                      *-----------------------------------------*
           if        w-tst-cla-tst        =    "FAX "
                     move  66             to   p-sel-efc-sel
                     go to pre-ass-sgr-640.
       pre-ass-sgr-640.
      *                  *---------------------------------------------*
      *                  * Bottom margin effettivo in linee seleziona- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           if        w-tst-cla-tst        not  = "PS  " and
                     w-tst-cla-tst        not  = "PCL5" and
                     w-tst-cla-tst        not  = "SPPX" and
                     w-tst-cla-tst        not  = "FAX "
                     move  w-det-tcb-efl-efb
                                          to   p-sel-efb-sel
                     go to pre-ass-sgr-660.
           if        r-fix-esp-fut (99 : 1)
                                          =    "*"
                     move  r-fix-bot-lin  to   p-sel-efb-sel
           else      move  zero           to   p-sel-efb-sel          .
       pre-ass-sgr-660.
