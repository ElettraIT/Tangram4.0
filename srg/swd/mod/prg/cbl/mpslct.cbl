      *                          * Preparazione canale di uscita       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Normalizzazioni preliminari     *
      *                              *---------------------------------*
           move      spaces               to   p-sel-can-stp          .
      *                              *---------------------------------*
      *                              * Assemblaggio pathname (1.parte) *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-stp-can-stp (1 : 3)
                                          to   w-all-str-cat (1)      .
           move      w-pre-ass-sgr-pat    to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                              *---------------------------------*
      *                              * Assemblaggio pathname (2.parte) *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
      *                                  *-----------------------------*
      *                                  * Ora e minuti : file name    *
      *                                  *-----------------------------*
           if        w-pre-ass-sgr-tim    =    spaces
                     move  spaces         to   w-all-str-cat (2)
                     move  spaces         to   w-all-str-cat (3)
           else      move  w-pre-ass-sgr-tim
                                          to   w-all-str-cat (2)
                     move  "_"            to   w-all-str-cat (3)      .
      *                                  *-----------------------------*
      *                                  * Assemblaggio                *
      *                                  *-----------------------------*
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                          *-------------------------------------*
      *                          * In campo di destinazione            *
      *                          *-------------------------------------*
           move      w-all-str-alf        to   p-sel-can-stp          .
       pre-ass-sgr-ucp-400.
      *                          *-------------------------------------*
      *                          * Preparazione nome file              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test se stampante di tipo 'fax' *
      *                              *---------------------------------*
           if        w-stp-can-stp
                    (1 : 5)               =    "fax *"
                     go to pre-ass-sgr-ucp-500.
      *                              *---------------------------------*
      *                              * Test se il nome file e' gia'    *
      *                              * stato preparato                 *
      *                              *---------------------------------*
           if        p-sel-fut-nam        not  = spaces
                     go to pre-ass-sgr-ucp-500.
      *                              *---------------------------------*
      *                              * Assemblaggio                    *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-acc-nom-fil        to   w-all-str-cat (1)      .
      *
           if        w-pre-ass-sgr-pfp    =    spaces
                     move  spaces         to   w-all-str-cat (2)
                     move  spaces         to   w-all-str-cat (3)
           else      move  "."            to   w-all-str-cat (2)
                     move  w-pre-ass-sgr-pfp
                                          to   w-all-str-cat (3)      .
      *
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                          *-------------------------------------*
      *                          * In campo di destinazione            *
      *                          *-------------------------------------*
           move      w-all-str-alf        to   p-sel-fut-nam          .
       pre-ass-sgr-ucp-500.
      *                          *-------------------------------------*
      *                          * Preparazione parametri per il fax   *
      *                          *-------------------------------------*
           if        w-stp-can-stp
                    (1 : 5)               not  = "fax *"
                     go to pre-ass-sgr-ucp-600.
      *                          *-------------------------------------*
      *                          * In campo di destinazione            *
      *                          *-------------------------------------*
           move      w-acc-num-fax        to   p-sel-fut-nam          .
           move      w-acc-snd-tim        to   p-sel-fut-nam
                                              (16 : 04)               .
           move      w-acc-dst-fax        to   p-sel-fut-exp          .
       pre-ass-sgr-ucp-600.
      *                          *-------------------------------------*
      *                          * Preparazione parametri per e-mail   *
      *                          *-------------------------------------*
           if        w-stp-can-stp
                    (1 : 5)               not  = "eml *"
                     go to pre-ass-sgr-ucp-900.
      *                          *-------------------------------------*
      *                          * In campo di destinazione            *
      *                          *-------------------------------------*
           move      w-acc-ind-ema        to   p-sel-fut-nam          .
           move      w-acc-ogg-ema        to   p-sel-fut-exp          .
       pre-ass-sgr-ucp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pre-ass-sgr-ucp-999.
       pre-ass-sgr-ucp-999.
           exit.

      *    *===========================================================*
      *    * Consegna dell'area di selezione stampa p-sel al modulo di *
      *    * segreteria 'msegrt'                                       *
      *    *-----------------------------------------------------------*
       cns-ass-sgr-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cns-ass-sgr-sts      .
       cns-ass-sgr-100.
      *              *-------------------------------------------------*
      *              * Contatore su numero segmento da consegnare al   *
      *              * modulo di segreteria : zero                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-cns-ass-sgr-ctr      .
       cns-ass-sgr-200.
      *              *-------------------------------------------------*
      *              * Incremento contatore su numero segmento da con- *
      *              * segnare al modulo di segreteria                 *
      *              *-------------------------------------------------*
           add       1                    to   w-cns-ass-sgr-ctr      .
      *              *-------------------------------------------------*
      *              * Determinazione valore iniziale puntatore per    *
      *              * operazione di 'unstring' per estrazione         *
      *              *-------------------------------------------------*
           move      w-cns-ass-sgr-ctr    to   w-cns-ass-sgr-pnt      .
           multiply  80                   by   w-cns-ass-sgr-pnt      .
           subtract  79                   from w-cns-ass-sgr-pnt      .
      *              *-------------------------------------------------*
      *              * Salvataggio del valore iniziale puntatore per   *
      *              * operazione di 'unstring' per estrazione         *
      *              *-------------------------------------------------*
           move      w-cns-ass-sgr-pnt    to   w-cns-ass-sgr-svp      .
      *              *-------------------------------------------------*
      *              * Estrazione di un segmento dall'area p-sel       *
      *              *-------------------------------------------------*
           unstring  p-sel                into w-cns-ass-sgr-sgm
                                  with pointer w-cns-ass-sgr-pnt      .
      *              *-------------------------------------------------*
      *              * Se il segmento e' di lunghezza nulla : uscita   *
      *              *-------------------------------------------------*
           if        w-cns-ass-sgr-pnt    =    w-cns-ass-sgr-svp
                     go to cns-ass-sgr-999.
      *              *-------------------------------------------------*
      *              * Consegna del segmento alla segreteria           *
      *              *                                                 *
      *              * Se si tratta del segmento nr. 1 si passa anche  *
      *              * il tipo di stampa selezionato                   *
      *              *-------------------------------------------------*
           move      "S>"                 to   s-ope                  .
           move      w-cns-ass-sgr-ctr    to   s-num                  .
           move      w-cns-ass-sgr-sgm    to   s-alf                  .
           if        w-cns-ass-sgr-ctr    =    1
                     move  p-sel-tds-sel  to   s-sts
           else      move  spaces         to   s-sts                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Se il segmento era solo parzialmente pieno : u- *
      *              * scita                                           *
      *              *-------------------------------------------------*
           add       80                   to   w-cns-ass-sgr-svp      .
           if        w-cns-ass-sgr-svp    not  = w-cns-ass-sgr-svp
                     go to cns-ass-sgr-999.
      *              *-------------------------------------------------*
      *              * Altrimenti si ricicla per il segmento successi- *
      *              * vo                                              *
      *              *-------------------------------------------------*
           go to     cns-ass-sgr-200.
       cns-ass-sgr-999.
           exit.

      *    *===========================================================*
      *    * Controlli sulla definizione interna del codice stampante  *
      *    *-----------------------------------------------------------*
       cnt-dfz-stp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cnt-dfz-stp-sts      .
       cnt-dfz-stp-100.
      *              *-------------------------------------------------*
      *              * Se manca il tipo stampante si pone lo status ad *
      *              * errore e si esce                                *
      *              *-------------------------------------------------*
           if        w-stp-tip-stp        =    spaces
                     move  "99"           to   w-cnt-dfz-stp-sts
                     go to cnt-dfz-stp-999.
       cnt-dfz-stp-200.
      *              *-------------------------------------------------*
      *              * Se manca il canale di stampa si pone lo status  *
      *              * ad errore e si esce                             *
      *              *-------------------------------------------------*
           move      w-stp-cod-stp        to   w-cod-stp-cod          .
           if        w-cod-stp-chr (1)    =    "#"
                     go to cnt-dfz-stp-999.
           if        w-stp-can-stp        =    spaces
                     move  "99"           to   w-cnt-dfz-stp-sts
                     go to cnt-dfz-stp-999.
       cnt-dfz-stp-999.
           exit.

      *    *===========================================================*
      *    * Controlli sulla definizione interna del codice tipo stam- *
      *    * pante                                                     *
      *    *-----------------------------------------------------------*
       cnt-dfz-tst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cnt-dfz-tst-sts      .
       cnt-dfz-tst-100.
      *              *-------------------------------------------------*
      *              * Controllo su driver di stampa                   *
      *              *-------------------------------------------------*
           if        w-tst-drv-tst        not  = spaces
                     go to cnt-dfz-tst-200.
           move      "99"                 to   w-cnt-dfz-tst-sts      .
           go to     cnt-dfz-tst-999.
       cnt-dfz-tst-200.
      *              *-------------------------------------------------*
      *              * Controllo su classe stampante                   *
      *              *-------------------------------------------------*
           if        w-tst-cla-tst        =    spaces or
                     w-tst-cla-tst        =    "PS  " or
                     w-tst-cla-tst        =    "PCL5" or
                     w-tst-cla-tst        =    "SPPX" or
                     w-tst-cla-tst        =    "FAX "
                     go to cnt-dfz-tst-300.
           move      "99"                 to   w-cnt-dfz-tst-sts      .
           go to     cnt-dfz-tst-999.
       cnt-dfz-tst-300.
      *              *-------------------------------------------------*
      *              * Controllo su sottoclasse stampante              *
      *              *-------------------------------------------------*
           if        w-tst-cla-tst        =    spaces
                     go to cnt-dfz-tst-310
           else if   w-tst-cla-tst        =    "PS  "
                     go to cnt-dfz-tst-320
           else if   w-tst-cla-tst        =    "PCL5"
                     go to cnt-dfz-tst-330
           else if   w-tst-cla-tst        =    "SPPX" or
                     w-tst-cla-tst        =    "FAX "
                     go to cnt-dfz-tst-340
           else      go to cnt-dfz-tst-310.
       cnt-dfz-tst-310.
      *                  *---------------------------------------------*
      *                  * Se di classe normale                        *
      *                  *---------------------------------------------*
           go to     cnt-dfz-tst-999.
       cnt-dfz-tst-320.
      *                  *---------------------------------------------*
      *                  * Se di classe PostScript                     *
      *                  *---------------------------------------------*
           if        w-tst-scl-tst        =    "A4  " or
                     w-tst-scl-tst        =    "A3  " or
                     w-tst-scl-tst        =    "A2  " or
                     w-tst-scl-tst        =    "A1  " or
                     w-tst-scl-tst        =    "A0  "
                     go to cnt-dfz-tst-999.
           move      "99"                 to   w-cnt-dfz-tst-sts      .
           go to     cnt-dfz-tst-999.
       cnt-dfz-tst-330.
      *                  *---------------------------------------------*
      *                  * Se di classe PCL5                           *
      *                  *---------------------------------------------*
           if        w-tst-scl-tst        =    "A4  " or
                     w-tst-scl-tst        =    "A3  " or
                     w-tst-scl-tst        =    "A2  " or
                     w-tst-scl-tst        =    "A1  " or
                     w-tst-scl-tst        =    "A0  "
                     go to cnt-dfz-tst-999.
           move      "99"                 to   w-cnt-dfz-tst-sts      .
           go to     cnt-dfz-tst-999.
       cnt-dfz-tst-340.
      *                  *---------------------------------------------*
      *                  * Se di classe Special Printer SPPX o Fax     *
      *                  *---------------------------------------------*
           go to     cnt-dfz-tst-999.
       cnt-dfz-tst-999.
           exit.

      *    *===========================================================*
      *    * Controlli sulla definizione interna del codice modulo     *
      *    *-----------------------------------------------------------*
       cnt-dfz-mod-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cnt-dfz-mod-sts      .
      *              *-------------------------------------------------*
      *              * Se manca il tipo modulo si pone lo status ad    *
      *              * errore e si esce                                *
      *              *-------------------------------------------------*
           if        w-mod-tip-mod        =    spaces
                     move  "99"           to   w-cnt-dfz-mod-sts
                     go to cnt-dfz-mod-999.
       cnt-dfz-mod-200.
      *              *-------------------------------------------------*
      *              * Se manca la larghezza modulo si pone lo status  *
      *              * ad errore e si esce                             *
      *              *-------------------------------------------------*
           if        w-mod-l72-mod        =    zero
                     move  "99"           to   w-cnt-dfz-mod-sts
                     go to cnt-dfz-mod-999.
      *              *-------------------------------------------------*
      *              * Se manca l'altezza modulo si pone lo status     *
      *              * ad errore e si esce                             *
      *              *-------------------------------------------------*
           if        w-mod-a72-mod        =    zero
                     move  "99"           to   w-cnt-dfz-mod-sts
                     go to cnt-dfz-mod-999.
       cnt-dfz-mod-999.
           exit.

      *    *===========================================================*
      *    * Controlli se la stampante e' in grado di supportare l'am- *
      *    * piezza caratteri                                          *
      *    *-----------------------------------------------------------*
       cnt-amc-tst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cnt-amc-tst-sts      .
       cnt-amc-tst-100.
      *              *-------------------------------------------------*
      *              * Se la stampante e' di classe PostScript o PCL5  *
      *              * o Special Printer SPPX o Fax : il controllo e'  *
      *              * comunque superato                               *
      *              *-------------------------------------------------*
           if        w-cnt-amc-tst-clt    =    "PS  " or
                     w-cnt-amc-tst-clt    =    "PCL5" or
                     w-cnt-amc-tst-clt    =    "SPPX" or
                     w-cnt-amc-tst-clt    =    "FAX "
                     go to cnt-amc-tst-999.
      *              *-------------------------------------------------*
      *              * Se non esiste una lista ampiezze supportate si  *
      *              * presume che la stampante possa supportare tut-  *
      *              * te le ampiezze, altrimenti l'ampiezza richiesta *
      *              * deve trovare riscontro tra le ampiezze suppor-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero ampiezze supportate a zero           *
      *                  *---------------------------------------------*
           move      zero                 to   w-cnt-amc-tst-c01      .
      *                  *---------------------------------------------*
      *                  * Indice per scansione su ampiezze supportate *
      *                  * a zero                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-cnt-amc-tst-i01      .
       cnt-amc-tst-200.
      *                  *---------------------------------------------*
      *                  * Incremento indice per scansione su ampiezze *
      *                  * supportate                                  *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-amc-tst-i01      .
      *                  *---------------------------------------------*
      *                  * Test se fine ampiezze supportate            *
      *                  *---------------------------------------------*
           if        w-cnt-amc-tst-i01    >    20
                     go to cnt-amc-tst-300.
      *                  *---------------------------------------------*
      *                  * Se trovata ampiezza cercata : uscita        *
      *                  *---------------------------------------------*
           if        w-cnt-amc-tst-lst
                    (w-cnt-amc-tst-i01)   =    w-cnt-amc-tst-amp
                     go to cnt-amc-tst-999.
      *                  *---------------------------------------------*
      *                  * Se l' ampiezza non e' a zero : incremento   *
      *                  * numero ampiezze supportate                  *
      *                  *---------------------------------------------*
           if        w-cnt-amc-tst-lst
                    (w-cnt-amc-tst-i01)   not  = zero
                     add   1              to   w-cnt-amc-tst-c01      .
      *                  *---------------------------------------------*
      *                  * Riciclo su ampiezza supportata successiva   *
      *                  *---------------------------------------------*
           go to     cnt-amc-tst-200.
       cnt-amc-tst-300.
      *                  *---------------------------------------------*
      *                  * Se fine ampiezze supportate                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il numero ampiezze supportate e' a   *
      *                      * zero : uscita                           *
      *                      *-----------------------------------------*
           if        w-cnt-amc-tst-c01    =    zero
                     go to cnt-amc-tst-999.
      *                      *-----------------------------------------*
      *                      * ALtrimenti : segnale di errore          *
      *                      *-----------------------------------------*
           move      "99"                 to   w-cnt-amc-tst-sts      .
       cnt-amc-tst-999.
           exit.

