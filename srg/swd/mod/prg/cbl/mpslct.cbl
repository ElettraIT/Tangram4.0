      *                  *---------------------------------------------*
      *                  * Sigla fase gestionale                       *
      *                  *---------------------------------------------*
           move      r-ide-fas-ges        to   p-sel-fas-ges          .
       pre-ass-sgr-380.
      *                  *---------------------------------------------*
      *                  * Codice stampante selezionata                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se parametri modificabili          *
      *                      *-----------------------------------------*
           if        w-pms-snx-mod        =    "S"
                     move  w-acc-cod-stp  to   p-sel-stp-sel
                     go to pre-ass-sgr-400.
      *                      *-----------------------------------------*
      *                      * In condizioni normali                   *
      *                      *-----------------------------------------*
           if        r-fix-cod-stp        not  = spaces
                     move  r-fix-cod-stp  to   p-sel-stp-sel
           else if   w-pms-cod-stp        not  = spaces
                     move  w-pms-cod-stp  to   p-sel-stp-sel
           else      move  w-acc-cod-stp  to   p-sel-stp-sel          .
       pre-ass-sgr-400.
      *                  *---------------------------------------------*
      *                  * Tipo di stampa selezionato                  *
      *                  *---------------------------------------------*
           if        r-fix-tip-sta        not  = spaces
                     move  r-fix-tip-sta  to   p-sel-tds-sel
           else if   w-pms-out-stp        not  = spaces
                     move  w-pms-out-stp  to   p-sel-tds-sel
           else      move  w-acc-cod-tds  to   p-sel-tds-sel          .
       pre-ass-sgr-420.
      *                  *---------------------------------------------*
      *                  * Codice modulo selezionato                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se parametri modificabili          *
      *                      *-----------------------------------------*
           if        w-pms-snx-mod        =    "S"
                     move  w-acc-cod-mod  to   p-sel-mod-sel
                     go to pre-ass-sgr-440.
      *                      *-----------------------------------------*
      *                      * In condizioni normali                   *
      *                      *-----------------------------------------*
           if        r-fix-cod-mod        not  = spaces
                     move  r-fix-cod-mod  to   p-sel-mod-sel
           else if   w-pms-cod-mod        not  = spaces
                     move  w-pms-cod-mod  to   p-sel-mod-sel
           else      move  w-acc-cod-mod  to   p-sel-mod-sel          .
       pre-ass-sgr-440.
      *                  *---------------------------------------------*
      *                  * Ampiezza caratteri selezionata              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        r-fix-amp-car        not  = zero
                     move  r-fix-amp-car  to   p-sel-amc-sel
           else if   w-pms-amp-car        not  = zero
                     move  w-pms-amp-car  to   p-sel-amc-sel
           else      move  w-acc-amp-car  to   p-sel-amc-sel          .
      *                      *-----------------------------------------*
      *                      * Test se modulo tipografico              *
      *                      *-----------------------------------------*
           if        r-fix-tip-mod        =    "T"
                     go to pre-ass-sgr-460.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione ampiezza ca-  *
      *                      * ratteri                                 *
      *                      *-----------------------------------------*
           if        w-tst-cla-tst        =    "PS  " or
                     w-tst-cla-tst        =    "PCL5" or
                     w-tst-cla-tst        =    "SPPX" or
                     w-tst-cla-tst        =    "FAX "
                     move  zero           to   p-sel-amc-sel          .
       pre-ass-sgr-460.
      *                  *---------------------------------------------*
      *                  * Altezza interlinea selezionata              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        r-fix-alt-int        not  = zero
                     move  r-fix-alt-int  to   p-sel-ali-sel
           else if   w-pms-alt-int        not  = zero
                     move  w-pms-alt-int  to   p-sel-ali-sel
           else      move  w-acc-alt-int  to   p-sel-ali-sel          .
      *                      *-----------------------------------------*
      *                      * Test se modulo tipografico              *
      *                      *-----------------------------------------*
           if        r-fix-tip-mod        =    "T"
                     go to pre-ass-sgr-500.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione ampiezza      *
      *                      * interlinea                              *
      *                      *-----------------------------------------*
           if        w-tst-cla-tst        =    "PS  " or
                     w-tst-cla-tst        =    "PCL5" or
                     w-tst-cla-tst        =    "SPPX" or
                     w-tst-cla-tst        =    "FAX "
                     move  zero           to   p-sel-ali-sel          .
       pre-ass-sgr-500.
      *                  *---------------------------------------------*
      *                  * Ampiezza linea di stampa selezionata        *
      *                  *---------------------------------------------*
           move      r-fix-amp-lin        to   p-sel-als-sel          .
       pre-ass-sgr-520.
      *                  *---------------------------------------------*
      *                  * Top margin in linee selezionato             *
      *                  *---------------------------------------------*
           move      r-fix-top-lin        to   p-sel-top-sel          .
