           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-mmo-100-100.
      *              *-------------------------------------------------*
      *              * Preparazione accettazione scelta operazione     *
      *              *-------------------------------------------------*
           move      2                    to   w-box-mmo-100-num      .
           move      "Montaggio del modulo richiesto               "
                                          to   w-box-mmo-100-tbx (01) .
           move      "Rinuncia all'esecuzione della stampa         "
                                          to   w-box-mmo-100-tbx (02) .
       box-mmo-100-200.
      *              *-------------------------------------------------*
      *              * Accettazione scelta operazione                  *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-box-mmo-100-lun    to   v-car                  .
           move      w-box-mmo-100-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      27                   to   v-pos                  .
           add       w-dsp-box-mmo-100    to   v-pos                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-box-mmo-100-tbl    to   v-txt                  .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-mmo-100-225.
      *              *-------------------------------------------------*
      *              * Salvataggio valore impostato                    *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  zero           to   w-box-mmo-100-sce
           else      move  v-num          to   w-box-mmo-100-sce      .
       box-mmo-100-250.
      *              *-------------------------------------------------*
      *              * Test su ammissibilita' valore impostato         *
      *              *-------------------------------------------------*
           if        w-box-mmo-100-sce    >    w-box-mmo-100-num
                     go to box-mmo-100-200.
       box-mmo-100-300.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda della scelta effettuata    *
      *              *-------------------------------------------------*
           if        w-box-mmo-100-sce    =    01
                     go to box-mmo-100-400
           else      go to box-mmo-100-800.
       box-mmo-100-400.
      *              *-------------------------------------------------*
      *              * Se scelta di montaggio modulo                   *
      *              *-------------------------------------------------*
       box-mmo-100-425.
      *                  *---------------------------------------------*
      *                  * Note operative per il montaggio modulo      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      67                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      06                   to   v-pos                  .
           add       w-dsp-box-mmo-100    to   v-pos                  .
           move      "Montare il modulo sulla stampante e poi premere il
      -              " tasto Return :  "  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-mmo-100-450.
      *                  *---------------------------------------------*
      *                  * Accettazione di Return o Exit               *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "RTRN"               to   v-pfk (14)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      72                   to   v-pos                  .
           add       w-dsp-box-mmo-100    to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-mmo-100-475.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tasto premuto      *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  " or
                     v-key                =    "EXIT"
                     go to box-mmo-100-500
           else      go to box-mmo-100-600.
       box-mmo-100-500.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Cancellazione note operative per il     *
      *                      * montaggio modulo                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      67                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      06                   to   v-pos                  .
           add       w-dsp-box-mmo-100    to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Rientro ad accettazione scelta          *
      *                      *-----------------------------------------*
           go to     box-mmo-100-200.
       box-mmo-100-600.
      *                  *---------------------------------------------*
      *                  * Se Return o Up                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     box-mmo-100-900.
       box-mmo-100-800.
      *              *-------------------------------------------------*
      *              * Se scelta di rinuncia all'esecuzione stampa     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     box-mmo-100-900.
       box-mmo-100-900.
      *              *-------------------------------------------------*
      *              * Restore video                                   *
      *              *-------------------------------------------------*
           perform   rip-imm-vid-000      thru rip-imm-vid-999        .
       box-mmo-100-999.
           exit.

      *    *===========================================================*
      *    * Find su codici stampante di [pss]                         *
      *    *-----------------------------------------------------------*
       fnd-pss-stp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di selezione               *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-pss-stp-sel      .
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pxpg4210"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-pss-stp-sel
                     go to  fnd-pss-stp-999.
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per possibili- *
      *              * ta' di function-key "SLCT" durante l'interroga- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           call      "swd/xpg/prg/obj/pxpg4210"                       .
           cancel    "swd/xpg/prg/obj/pxpg4210"                       .
      *              *-------------------------------------------------*
      *              * Estrazione di eventuale variabile di i.p.c. de- *
      *              * terminata da function-key "SLCT" durante l'in-  *
      *              * terrogazione                                    *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "pss-stp"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  spaces         to   w-fnd-pss-stp-sel
                     move  s-alf          to   w-fnd-pss-stp-cod
           else      move  "#"            to   w-fnd-pss-stp-sel      .
       fnd-pss-stp-999.
           exit.

      *    *===========================================================*
      *    * Find su codici modulo di [pss]                            *
      *    *-----------------------------------------------------------*
       fnd-pss-mod-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di selezione               *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-pss-mod-sel      .
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pxpg4310"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-pss-mod-sel
                     go to  fnd-pss-mod-999.
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per possibili- *
      *              * ta' di function-key "SLCT" durante l'interroga- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. 'cod-mod'      *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-mod"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      08                   to   s-car                  .
           move      w-fnd-pss-mod-cod    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. 'non-tgr', per *
      *              * escludere dalla visualizzazione i moduli tipo-  *
      *              * grafici                                         *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "non-tgr"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "N"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           call      "swd/xpg/prg/obj/pxpg4310"                       .
           cancel    "swd/xpg/prg/obj/pxpg4310"                       .
      *              *-------------------------------------------------*
      *              * Estrazione di eventuale variabile di i.p.c. de- *
      *              * terminata da function-key "SLCT" durante l'in-  *
      *              * terrogazione                                    *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "pss-mod"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  spaces         to   w-fnd-pss-mod-sel
                     move  s-alf          to   w-fnd-pss-mod-cod
           else      move  "#"            to   w-fnd-pss-mod-sel      .
       fnd-pss-mod-999.
           exit.

