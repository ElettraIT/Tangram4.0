                     w-cnt-acc-prm-amc    =    "S"
                     move  "UP  "         to   v-pfk (01)             .
      *
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-acc-nom-fil        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
