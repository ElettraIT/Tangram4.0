           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      36                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      27                   to   v-pos                  .
           add       w-dsp-cnt-acc-prm    to   v-pos                  .
      *
           if        w-cnt-acc-prm-cst    =    "S" or
                     w-cnt-acc-prm-cmo    =    "S" or
