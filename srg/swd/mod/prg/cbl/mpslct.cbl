           if        w-cnt-ali-mod-lst
                    (w-cnt-ali-mod-i01)   not  = zero
                     add   1              to   w-cnt-ali-mod-c01      .
      *                  *---------------------------------------------*
      *                  * Riciclo su altezza supportata successiva    *
      *                  *---------------------------------------------*
           go to     cnt-ali-mod-200.
       cnt-ali-mod-300.
      *                  *---------------------------------------------*
      *                  * Se fine altezze supportate                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il numero altezze supportate e' a    *
      *                      * zero : uscita                           *
      *                      *-----------------------------------------*
           if        w-cnt-ali-mod-c01    =    zero
                     go to cnt-ali-mod-999.
      *                      *-----------------------------------------*
      *                      * Altrimenti : segnale di errore          *
      *                      *-----------------------------------------*
           move      "99"                 to   w-cnt-ali-mod-sts      .
       cnt-ali-mod-999.
           exit.

      *    *===========================================================*
      *    * Controllo se se il tipo di modulo puo' essere montato     *
      *    * sulla stampante, sotto il profilo delle dimensioni di     *
      *    * entrambi                                                  *
      *    *-----------------------------------------------------------*
       cnt-dim-mss-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cnt-dim-mss-sts      .
      *              *-------------------------------------------------*
      *              * Se la stampante e' di classe PostScript o PCL5  *
      *              * o Special Printer SPPX o Fax : il controllo e'  *
      *              * comunque superato                               *
      *              *-------------------------------------------------*
           if        w-cnt-dim-mss-clt    =    "PS  " or
                     w-cnt-dim-mss-clt    =    "PCL5" or
                     w-cnt-dim-mss-clt    =    "SPPX" or
                     w-cnt-dim-mss-clt    =    "FAX "
                     go to cnt-dim-mss-999.
       cnt-dim-mss-100.
      *              *-------------------------------------------------*
      *              * Controllo orizzontale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se la larghezza carrello e' zero, cioe' in- *
      *                  * finita il controllo orizzontale non viene   *
      *                  * eseguito                                    *
      *                  *---------------------------------------------*
           if        w-cnt-dim-mss-sla    =    zero
                     go to cnt-dim-mss-500.
      *                  *---------------------------------------------*
      *                  * Controllo effettivo                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se l'ampiezza carrello e' inferiore al- *
      *                      * la larghezza del modulo si pone lo sta- *
      *                      * tus ad errore e si esce                 *
      *                      *-----------------------------------------*
           if        w-cnt-dim-mss-sla    <    w-cnt-dim-mss-mla
                     move  "99"           to   w-cnt-dim-mss-sts
                     go to cnt-dim-mss-999.
       cnt-dim-mss-500.
      *              *-------------------------------------------------*
      *              * Controllo verticale                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se l'altezza carrello e' zero, cioe' infi-  *
      *                  * nita il controllo verticale non viene ese-  *
      *                  * guito                                       *
      *                  *---------------------------------------------*
           if        w-cnt-dim-mss-sal    =    zero
                     go to cnt-dim-mss-999.
      *                  *---------------------------------------------*
      *                  * Controllo effettivo                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se l'altezza carrello e' inferiore al-  *
      *                      * l'altezza del modulo si pone lo status  *
      *                      * ad errore e si esce                     *
      *                      *-----------------------------------------*
           if        w-cnt-dim-mss-sal    <    w-cnt-dim-mss-mal
                     move  "99"           to   w-cnt-dim-mss-sts
                     go to cnt-dim-mss-999.
       cnt-dim-mss-999.
           exit.

      *    *===========================================================*
      *    * Controllo su ampiezza caratteri in rapporto al codice mo- *
      *    * dulo, al codice stampante, e all'ampiezza della linea di  *
      *    * stampa, ovvero se la linea puo' essere contenuta nel mo-  *
      *    * dulo tenendo conto del margine perso per la stampante sia *
      *    * a sinistra che a destra                                   *
      *    *-----------------------------------------------------------*
       cnt-amc-sml-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-cnt-amc-sml-sts      .
      *              *-------------------------------------------------*
      *              * Se la stampante e' di classe PostScript o PCL5  *
      *              * o Special Printer SPPX : il controllo e' comun- *
      *              * que superato                                    *
      *              *-------------------------------------------------*
           if        w-cnt-amc-sml-clt    =    "PS  " or
                     w-cnt-amc-sml-clt    =    "PCL5" or
                     w-cnt-amc-sml-clt    =    "SPPX" or
                     w-cnt-amc-sml-clt    =    "FAX "
                     go to cnt-amc-sml-999.
       cnt-amc-sml-500.
      *              *-------------------------------------------------*
      *              * Determinazione dell'ampiezza modulo utile, come *
      *              * differenza tra l'ampiezza modulo reale e i mar- *
      *              * gini persi per il tipo di stampante sinistro e  *
      *              * destro, il tutto in 72mi di pollice             *
      *              *-------------------------------------------------*
           move      w-cnt-amc-sml-mla    to   w-cnt-amc-sml-w01      .
           subtract  w-cnt-amc-sml-ssi    from w-cnt-amc-sml-w01      .
           subtract  w-cnt-amc-sml-sde    from w-cnt-amc-sml-w01      .
      *              *-------------------------------------------------*
      *              * Determinazione dell'ampiezza della linea stampa *
      *              * in 72mi di pollice tenendo conto dell'ampiezza  *
      *              * della linea stampa in caratteri e dell'ampiezza *
      *              * del carattere                                   *
      *              *-------------------------------------------------*
           move      w-cnt-amc-sml-als    to   w-cnt-amc-sml-w02      .
           multiply  72                   by   w-cnt-amc-sml-w02      .
           divide    w-cnt-amc-sml-amc    into w-cnt-amc-sml-w02      .
      *              *-------------------------------------------------*
      *              * Se l'ampiezza del modulo utile in 72mi e' infe- *
      *              * riore all'ampiezza della linea stampa in 72mi   *
      *              * si pone lo status ad errore e si esce           *
      *              *-------------------------------------------------*
           if        w-cnt-amc-sml-w01    <    w-cnt-amc-sml-w02
                     move  "99"           to   w-cnt-amc-sml-sts
                     go to cnt-amc-sml-999.
       cnt-amc-sml-999.
           exit.

      *    *===========================================================*
      *    * Determinazione del top margin in linee effettivo, del     *
      *    * corpo in linee effettivo, e del bottom margin in linee    *
      *    * effettivo in funzione del tipo modulo usato, dell'altezza *
      *    * modulo in 72mi di pollice, dei margini persi inferiore e  *
      *    * superiore per il tipo stampante in 72mi di pollice, e del *
      *    * numero di linee minimo richiesto per la stampa            *
      *    *-----------------------------------------------------------*
       det-tcb-efl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-det-tcb-efl-sts      .
       det-tcb-efl-100.
      *              *-------------------------------------------------*
      *              * Se la stampante e' di classe PostScript o PCL5  *
      *              * o Special Printer SPPX o Fax : il controllo e'  *
      *              * comunque superato                               *
      *              *-------------------------------------------------*
           if        w-det-tcb-efl-clt    not  = "PS  " and
                     w-det-tcb-efl-clt    not  = "PCL5" and
                     w-det-tcb-efl-clt    not  = "SPPX" and
                     w-det-tcb-efl-clt    not  = "FAX "
                     go to det-tcb-efl-150.
      *                  *---------------------------------------------*
      *                  * Top e bottom a zero                         *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tcb-efl-eft
                                               w-det-tcb-efl-w91      .
           move      zero                 to   w-det-tcb-efl-efb
                                               w-det-tcb-efl-w93      .
      *                  *---------------------------------------------*
      *                  * Corpo : a seconda della sottoclasse per il  *
      *                  *         tipo di stampante, per ora posto al *
      *                  *         valore fisso 72 o 96 per le Post-   *
      *                  *         script e le PCL5, a 66 per le Spe-  *
      *                  *         cial Printers SPPX                  *
      *                  *---------------------------------------------*
           if        w-det-tcb-efl-clt    =    "SPPX"
                     move  66             to   w-det-tcb-efl-efc
                                               w-det-tcb-efl-w92
           else if  (w-det-tcb-efl-clt    =    "PS  "    ) and
                    (w-det-tcb-efl-sct    =    "A3  " or
                     w-det-tcb-efl-sct    =    "A2  " or
                     w-det-tcb-efl-sct    =    "A1  " or
                     w-det-tcb-efl-sct    =    "A0  "    )
                     move  96             to   w-det-tcb-efl-efc
                                               w-det-tcb-efl-w92
           else      move  72             to   w-det-tcb-efl-efc
                                               w-det-tcb-efl-w92      .
      *                  *---------------------------------------------*
      *                  * A pre-uscita                                *
      *                  *---------------------------------------------*
           go to     det-tcb-efl-900.
       det-tcb-efl-150.
      *              *-------------------------------------------------*
      *              * Determinazione del numero di linee stampa cui   *
      *              * corrisponde l'altezza modulo, arrotondando in   *
      *              * difetto                                         *
      *              *-------------------------------------------------*
           move      w-det-tcb-efl-ali    to   w-det-tcb-efl-w10      .
           multiply  w-det-tcb-efl-alm    by   w-det-tcb-efl-w10      .
           divide    72                   into w-det-tcb-efl-w10      .
           move      w-det-tcb-efl-w10    to   w-det-tcb-efl-wqm      .
      *              *-------------------------------------------------*
      *              * Determinazione del numero di linee stampa cui   *
      *              * corrisponde il margine superiore perso, arro-   *
      *              * tondando in eccesso                             *
      *              *-------------------------------------------------*
           move      w-det-tcb-efl-ali    to   w-det-tcb-efl-w10      .
           multiply  w-det-tcb-efl-msu    by   w-det-tcb-efl-w10      .
           add       71,99                to   w-det-tcb-efl-w10      .
           divide    72                   into w-det-tcb-efl-w10      .
           move      w-det-tcb-efl-w10    to   w-det-tcb-efl-wps      .
      *              *-------------------------------------------------*
      *              * Determinazione del numero di linee stampa cui   *
      *              * corrisponde il margine inferiore perso, arro-   *
      *              * tondando in eccesso                             *
      *              *-------------------------------------------------*
           move      w-det-tcb-efl-ali    to   w-det-tcb-efl-w10      .
           multiply  w-det-tcb-efl-min    by   w-det-tcb-efl-w10      .
           add       71,99                to   w-det-tcb-efl-w10      .
           divide    72                   into w-det-tcb-efl-w10      .
           move      w-det-tcb-efl-w10    to   w-det-tcb-efl-wpi      .
      *              *-------------------------------------------------*
      *              * Determinazione del numero di linee stampa utili *
      *              * per differenza tra il numero di linee stampa    *
      *              * cui corrisponde l'altezza modulo ed il numero   *
      *              * linee stampa cui corrispondono i margini persi  *
      *              * superiore ed inferiore                          *
      *              *-------------------------------------------------*
           move      w-det-tcb-efl-wqm    to   w-det-tcb-efl-wum      .
           subtract  w-det-tcb-efl-wps    from w-det-tcb-efl-wum      .
           subtract  w-det-tcb-efl-wpi    from w-det-tcb-efl-wum      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo modulo usato    *
      *              *-------------------------------------------------*
           if        w-det-tcb-efl-tmo    =    "T"
                     go to det-tcb-efl-500
           else      go to det-tcb-efl-200.
       det-tcb-efl-200.
      *              *-------------------------------------------------*
      *              * Se modulo libero o specifico non tipografico    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero linee di stampa utili in     *
      *                  * rapporto al numero di linee stampa minimo   *
      *                  *---------------------------------------------*
           if        w-det-tcb-efl-wum    <    w-det-tcb-efl-lsm
                     go to det-tcb-efl-225
           else      go to det-tcb-efl-325.
       det-tcb-efl-225.
      *                  *---------------------------------------------*
      *                  * Se il numero linee di stampa utili e' infe- *
      *                  * riore al numero di linee stampa minimo      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione numero linee da recupe-  *
      *                      * rare dal top o dal bottom per raggiun-  *
      *                      * gere il numero linee di stampa minimo   *
      *                      *-----------------------------------------*
           move      w-det-tcb-efl-lsm    to   w-det-tcb-efl-wdc      .
           subtract  w-det-tcb-efl-wum    from w-det-tcb-efl-wdc      .
      *                      *-----------------------------------------*
      *                      * Determinazione della somma del numero   *
      *                      * linee di top e di bottom                *
      *                      *-----------------------------------------*
           move      w-det-tcb-efl-top    to   w-det-tcb-efl-wtb      .
           add       w-det-tcb-efl-bot    to   w-det-tcb-efl-wtb      .
      *                      *-----------------------------------------*
      *                      * Test se e' possibile il recupero linee  *
      *                      * dal top e dal bottom                    *
      *                      *-----------------------------------------*
           if        w-det-tcb-efl-wdc    >    w-det-tcb-efl-wtb
                     go to det-tcb-efl-250
           else      go to det-tcb-efl-275.
       det-tcb-efl-250.
      *                      *-----------------------------------------*
      *                      * Se non e' possibile il recupero linee   *
      *                      * dal top e dal bottom                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Status di uscita a '99'             *
      *                          *-------------------------------------*
           move      "99"                 to   w-det-tcb-efl-sts      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     det-tcb-efl-999.
       det-tcb-efl-275.
      *                      *-----------------------------------------*
      *                      * Se il recupero linee dal top e dal bot- *
      *                      * tom e' possibile                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Numero di linee prelevate dal top e *
      *                          * dal bottom : zero                   *
      *                          *-------------------------------------*
           move      zero                 to   w-det-tcb-efl-wrt      .
           move      zero                 to   w-det-tcb-efl-wrb      .
      *                          *-------------------------------------*
      *                          * Prelevamento linee alternativamente *
      *                          * dal top e dal bottom                *
      *                          *-------------------------------------*
           move      w-det-tcb-efl-wdc    to   w-det-tcb-efl-w91      .
           move      w-det-tcb-efl-top    to   w-det-tcb-efl-w92      .
           move      w-det-tcb-efl-bot    to   w-det-tcb-efl-w93      .
       det-tcb-efl-280.
           if        w-det-tcb-efl-w92    =    zero
                     go to det-tcb-efl-287.
       det-tcb-efl-282.
           add       1                    to   w-det-tcb-efl-wrt      .
           subtract  1                    from w-det-tcb-efl-w92      .
           subtract  1                    from w-det-tcb-efl-w91      .
           if        w-det-tcb-efl-w91    =    zero
                     go to det-tcb-efl-300.
       det-tcb-efl-285.
           if        w-det-tcb-efl-w93    =    zero
                     go to det-tcb-efl-282.
       det-tcb-efl-287.
           add       1                    to   w-det-tcb-efl-wrb      .
           subtract  1                    from w-det-tcb-efl-w93      .
           subtract  1                    from w-det-tcb-efl-w91      .
           if        w-det-tcb-efl-w91    >    zero
                     go to det-tcb-efl-280.
       det-tcb-efl-300.
      *                          *-------------------------------------*
      *                          * Preparazione dei parametri in usci- *
      *                          * ta                                  *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Top effettivo in linee determi- *
      *                              * nato                            *
      *                              *---------------------------------*
           move      w-det-tcb-efl-top    to   w-det-tcb-efl-w91      .
           subtract  w-det-tcb-efl-wrt    from w-det-tcb-efl-w91      .
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-eft      .
      *                              *---------------------------------*
      *                              * Corpo effettivo in linee deter- *
      *                              * minato                          *
      *                              *---------------------------------*
           move      w-det-tcb-efl-lsm    to   w-det-tcb-efl-w92      .
           move      w-det-tcb-efl-w92    to   w-det-tcb-efl-efc      .
      *                              *---------------------------------*
      *                              * Bottom effettivo in linee de-   *
      *                              * terminato                       *
      *                              *---------------------------------*
           move      w-det-tcb-efl-bot    to   w-det-tcb-efl-w93      .
           subtract  w-det-tcb-efl-wrb    from w-det-tcb-efl-w93      .
           move      w-det-tcb-efl-w93    to   w-det-tcb-efl-efb      .
      *                          *-------------------------------------*
      *                          * A pre-uscita                        *
      *                          *-------------------------------------*
           go to     det-tcb-efl-900.
       det-tcb-efl-325.
      *                  *---------------------------------------------*
      *                  * Se il numero linee di stampa utili non e'   *
      *                  * inferiore al numero di linee stampa minimo  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione del top effettivo in li- *
      *                      * nee determinato con eventuale assorbi-  *
      *                      * mento del numero linee perse per il     *
      *                      * margine superiore                       *
      *                      *-----------------------------------------*
           if        w-det-tcb-efl-wps    >    w-det-tcb-efl-top
                     move     zero        to   w-det-tcb-efl-w91
           else if   w-det-tcb-efl-wps    =    w-det-tcb-efl-top
                     move     zero        to   w-det-tcb-efl-w91
           else      move     w-det-tcb-efl-top
                                          to   w-det-tcb-efl-w91
                     subtract w-det-tcb-efl-wps
                                          from w-det-tcb-efl-w91      .
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-eft      .
      *                      *-----------------------------------------*
      *                      * Determinazione del bottom effettivo in  *
      *                      * linee determinato con eventuale assor-  *
      *                      * bimento del numero linee perse per il   *
      *                      * margine inferiore                       *
      *                      *-----------------------------------------*
           if        w-det-tcb-efl-wpi    >    w-det-tcb-efl-bot
                     move     zero        to   w-det-tcb-efl-w93
           else if   w-det-tcb-efl-wpi    =    w-det-tcb-efl-bot
                     move     zero        to   w-det-tcb-efl-w93
           else      move     w-det-tcb-efl-bot
                                          to   w-det-tcb-efl-w93
                     subtract w-det-tcb-efl-wpi
                                          from w-det-tcb-efl-w93      .
           move      w-det-tcb-efl-w93    to   w-det-tcb-efl-efb      .
      *                      *-----------------------------------------*
      *                      * Determinazione del corpo effettivo in   *
      *                      * linee determinato per differenza tra il *
      *                      * numero di linee utili per il modulo ed  *
      *                      * il top ed il bottom effettivi determi-  *
      *                      * nati                                    *
      *                      *-----------------------------------------*
           move      w-det-tcb-efl-wum    to   w-det-tcb-efl-w92      .
           subtract  w-det-tcb-efl-w91    from w-det-tcb-efl-w92      .
           subtract  w-det-tcb-efl-w93    from w-det-tcb-efl-w92      .
           move      w-det-tcb-efl-w92    to   w-det-tcb-efl-efc      .
      *                      *-----------------------------------------*
      *                      * Test se il numero linee di corpo effet- *
      *                      * tive determinate rispetta il numero di  *
      *                      * linee di stampa minimo                  *
      *                      *-----------------------------------------*
           if        w-det-tcb-efl-w92    <    w-det-tcb-efl-lsm
                     go to det-tcb-efl-375.
       det-tcb-efl-350.
      *                      *-----------------------------------------*
      *                      * Se il numero linee di corpo effettive   *
      *                      * determinate risulta  superiore o uguale *
      *                      * al numero di linee di stampa minimo     *
      *                      *-----------------------------------------*
      *                           *------------------------------------*
      *                           * A pre-uscita                       *
      *                           *------------------------------------*
           go to     det-tcb-efl-900.
       det-tcb-efl-375.
      *                      *-----------------------------------------*
      *                      * Se il numero linee di corpo effettive   *
      *                      * determinate risulta inferiore al numero *
      *                      * di linee di stampa minimo               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione numero linee da re-  *
      *                          * cuperare dal top o dal bottom per   *
      *                          * raggiungere il numero linee di      *
      *                          * stampa minimo                       *
      *                          *-------------------------------------*
           move      w-det-tcb-efl-lsm    to   w-det-tcb-efl-wdc      .
           subtract  w-det-tcb-efl-w92    from w-det-tcb-efl-wdc      .
      *                          *-------------------------------------*
      *                          * Determinazione della somma del nu-  *
      *                          * mero linee di top e di bottom ef-   *
      *                          * fettivi                             *
      *                          *-------------------------------------*
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-wtb      .
           add       w-det-tcb-efl-w93    to   w-det-tcb-efl-wtb      .
      *                          *-------------------------------------*
      *                          * Test se e' possibile il recupero    *
      *                          * linee dal top e dal bottom          *
      *                          *-------------------------------------*
           if        w-det-tcb-efl-wdc    >    w-det-tcb-efl-wtb
                     go to det-tcb-efl-400
           else      go to det-tcb-efl-425.
       det-tcb-efl-400.
      *                          *-------------------------------------*
      *                          * Se non e' possibile il recupero li- *
      *                          * nee dal top e dal bottom            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Status di uscita a '99'         *
      *                              *---------------------------------*
           move      "99"                 to   w-det-tcb-efl-sts      .
      *                              *---------------------------------*
      *                              * Uscita                          *
      *                              *---------------------------------*
           go to     det-tcb-efl-999.
       det-tcb-efl-425.
      *                          *-------------------------------------*
      *                          * Se il recupero linee dal top e dal  *
      *                          * bottom e' possibile                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Numero di linee prelevate dal   *
      *                              * top e dal bottom : zero         *
      *                              *---------------------------------*
           move      zero                 to   w-det-tcb-efl-wrt      .
           move      zero                 to   w-det-tcb-efl-wrb      .
      *                              *---------------------------------*
      *                              * Prelevamento linee alternativa- *
      *                              * mente dal top e dal bottom      *
      *                              *---------------------------------*
           move      w-det-tcb-efl-wdc    to   w-det-tcb-efl-w81      .
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-w82      .
           move      w-det-tcb-efl-w93    to   w-det-tcb-efl-w83      .
       det-tcb-efl-430.
           if        w-det-tcb-efl-w82    =    zero
                     go to det-tcb-efl-437.
       det-tcb-efl-432.
           add       1                    to   w-det-tcb-efl-wrt      .
           subtract  1                    from w-det-tcb-efl-w82      .
           subtract  1                    from w-det-tcb-efl-w81      .
           if        w-det-tcb-efl-w81    =    zero
                     go to det-tcb-efl-450.
       det-tcb-efl-435.
           if        w-det-tcb-efl-w83    =    zero
                     go to det-tcb-efl-432.
       det-tcb-efl-437.
           add       1                    to   w-det-tcb-efl-wrb      .
           subtract  1                    from w-det-tcb-efl-w83      .
           subtract  1                    from w-det-tcb-efl-w81      .
           if        w-det-tcb-efl-w81    >    zero
                     go to det-tcb-efl-430.
       det-tcb-efl-450.
      *                              *---------------------------------*
      *                              * Preparazione dei parametri in   *
      *                              * uscita                          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Top effettivo in linee de-  *
      *                                  * terminato                   *
      *                                  *-----------------------------*
           subtract  w-det-tcb-efl-wrt    from w-det-tcb-efl-w91      .
           subtract  w-det-tcb-efl-w91    from w-det-tcb-efl-eft      .
      *                                  *-----------------------------*
      *                                  * Corpo effettivo in linee    *
      *                                  * determinato                 *
      *                                  *-----------------------------*
           move      w-det-tcb-efl-lsm    to   w-det-tcb-efl-w92      .
           move      w-det-tcb-efl-w92    to   w-det-tcb-efl-efc      .
      *                                  *-----------------------------*
      *                                  * Bottom effettivo in linee   *
      *                                  * determinato                 *
      *                                  *-----------------------------*
           subtract  w-det-tcb-efl-wrb    from w-det-tcb-efl-w93      .
           subtract  w-det-tcb-efl-w93    from w-det-tcb-efl-efb      .
      *                                  *-----------------------------*
      *                                  * A pre-uscita                *
      *                                  *-----------------------------*
           go to     det-tcb-efl-900.
       det-tcb-efl-500.
      *              *-------------------------------------------------*
      *              * Se modulo tipografico                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del top effettivo in linee   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Confronto tra il margine superiore per- *
      *                      * so in linee ed il top margin richiesto  *
      *                      *-----------------------------------------*
           if        w-det-tcb-efl-wps    <    w-det-tcb-efl-top
                     go to det-tcb-efl-550
           else if   w-det-tcb-efl-wps    =    w-det-tcb-efl-top
                     go to det-tcb-efl-575.
       det-tcb-efl-525.
      *                      *-----------------------------------------*
      *                      * Se il margine superiore perso in linee  *
      *                      * e' superiore al top margin richiesto    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Status di uscita a '99'             *
      *                          *-------------------------------------*
           move      "99"                 to   w-det-tcb-efl-sts      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     det-tcb-efl-999.
       det-tcb-efl-550.
      *                      *-----------------------------------------*
      *                      * Se il margine superiore perso in linee  *
      *                      * e' inferiore al top margin richiesto    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Top effettivo in linee pari alla    *
      *                          * differenza tra il top margin ri-    *
      *                          * chiesto ed il margine superiore     *
      *                          * perso in linee                      *
      *                          *-------------------------------------*
           move      w-det-tcb-efl-top    to   w-det-tcb-efl-w91      .
           subtract  w-det-tcb-efl-wps    from w-det-tcb-efl-w91      .
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-eft      .
           go to     det-tcb-efl-600.
       det-tcb-efl-575.
      *                      *-----------------------------------------*
      *                      * Se il margine superiore perso in linee  *
      *                      * e' uguale al top margin richiesto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Top effettivo in linee : zero       *
      *                          *-------------------------------------*
           move      zero                 to   w-det-tcb-efl-w91      .
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-eft      .
           go to     det-tcb-efl-600.
       det-tcb-efl-600.
      *                  *---------------------------------------------*
      *                  * Determinazione del corpo effettivo in linee *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo della somma tra il top effetti- *
      *                      * vo in linee ed il numero di linee di    *
      *                      * stampa minimo (che per il modulo tipo-  *
      *                      * grafico equivale al numero fisso di     *
      *                      * linee per il corpo)                     *
      *                      *-----------------------------------------*
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-wtc      .
           add       w-det-tcb-efl-lsm    to   w-det-tcb-efl-wtc      .
      *                      *-----------------------------------------*
      *                      * Controllo che questa somma non sia su-  *
      *                      * periore al numero di linee utili per    *
      *                      * il modulo                               *
      *                      *-----------------------------------------*
           if        w-det-tcb-efl-wtc    >    w-det-tcb-efl-wum
                     go to det-tcb-efl-625
           else      go to det-tcb-efl-650.
       det-tcb-efl-625.
      *                      *-----------------------------------------*
      *                      * Se il numero linee utili per il modulo  *
      *                      * non e' sufficiente a coprire il numero  *
      *                      * linee di top effettivo ed il numero li- *
      *                      * nee di stampa minimo richiesto          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Status di uscita a '99'             *
      *                          *-------------------------------------*
           move      "99"                 to   w-det-tcb-efl-sts      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     det-tcb-efl-999.
       det-tcb-efl-650.
      *                      *-----------------------------------------*
      *                      * Se il numero linee utili per il modulo  *
      *                      * e' sufficiente a coprire il numero li-  *
      *                      * nee di top effettivo ed il numero linee *
      *                      * di stampa minimo richiesto              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Corpo effettivo in linee pari al    *
      *                          * numero linee di stampa minimo ri-   *
      *                          * chiesto                             *
      *                          *-------------------------------------*
           move      w-det-tcb-efl-lsm    to   w-det-tcb-efl-w92      .
           move      w-det-tcb-efl-w92    to   w-det-tcb-efl-efc      .
       det-tcb-efl-675.
      *                  *---------------------------------------------*
      *                  * Determinazione del bottom effettivo in li-  *
      *                  * nee                                         *
      *                  *---------------------------------------------*
      *                          *-------------------------------------*
      *                          * Bottom effettivo in linee pari alla *
      *                          * differenza tra il numero linee uti- *
      *                          * li per il modulo ed il top effetti- *
      *                          * vo ed il corpo effettivo in linee   *
      *                          * determinati                         *
      *                          *-------------------------------------*
           move      w-det-tcb-efl-wum    to   w-det-tcb-efl-w93      .
           subtract  w-det-tcb-efl-wtc    from w-det-tcb-efl-w93      .
           move      w-det-tcb-efl-w93    to   w-det-tcb-efl-efb      .
      *                          *-------------------------------------*
      *                          * A pre-uscita                        *
      *                          *-------------------------------------*
           go to     det-tcb-efl-900.
       det-tcb-efl-900.
      *              *-------------------------------------------------*
      *              * Controllo che top, corpo e bottom non superino  *
      *              * individualmente il valore 96, e che cumulativa- *
      *              * mente non superino il valore 240                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        w-det-tcb-efl-w91    >    96 or
                     w-det-tcb-efl-w92    >    96 or
                     w-det-tcb-efl-w93    >    96
                     go to det-tcb-efl-950.
           move      w-det-tcb-efl-w91    to   w-det-tcb-efl-w94      .
           add       w-det-tcb-efl-w92    to   w-det-tcb-efl-w94      .
           add       w-det-tcb-efl-w93    to   w-det-tcb-efl-w94      .
           if        w-det-tcb-efl-w94    >    240
                     go to det-tcb-efl-950.
       det-tcb-efl-925.
      *                  *---------------------------------------------*
      *                  * Se controllo superato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-tcb-efl-999.
       det-tcb-efl-950.
      *                  *---------------------------------------------*
      *                  * Se controllo non superato                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Status di uscita a '99'                 *
      *                      *-----------------------------------------*
           move      "99"                 to   w-det-tcb-efl-sts      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-tcb-efl-999.
       det-tcb-efl-999.
           exit.

      *    *===========================================================*
