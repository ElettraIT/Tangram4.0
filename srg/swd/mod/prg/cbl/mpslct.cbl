      *                      *-----------------------------------------*
           if        w-tst-cla-tst        not  = "PS  " and
                     w-tst-cla-tst        not  = "PCL5" and
                     w-tst-cla-tst        not  = "SPPX" and
                     w-tst-cla-tst        not  = "FAX "
                     go to acc-cod-stp-650.
       acc-cod-stp-627.
      *                      *-----------------------------------------*
      *                      * Ampiezza caratteri                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su provenienza                 *
      *                          *-------------------------------------*
           if        r-fix-amp-car        not  = zero or
                     w-pms-amp-car        not  = zero
                     go to acc-cod-stp-628.
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-acc-amp-car          .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           add       w-dsp-cnt-acc-prm    to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-stp-628.
      *                      *-----------------------------------------*
      *                      * Altezza interlinea - Inibita (07/09/04) *
      *                      *-----------------------------------------*
       acc-cod-stp-650.
      *              *-------------------------------------------------*
      *              * Eventuale password per la stampante             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se la stampante non ha password non si ese- *
      *                  * gue alcun controllo                         *
      *                  *---------------------------------------------*
           if        w-stp-pwd-stp        =    spaces
                     go to acc-cod-stp-675.
      *                  *---------------------------------------------*
      *                  * Se le personalizzazioni generali non indi-  *
      *                  * cano che c'e' controllo password per le     *
      *                  * stampanti non si esegue nessun controllo    *
      *                  *---------------------------------------------*
           if        w-psg-pwd-stp        not  = "S"
                     go to acc-cod-stp-675.
      *                  *---------------------------------------------*
      *                  * Se l'utente e' di tipo supervisore non si   *
      *                  * esegue nessun controllo                     *
      *                  *---------------------------------------------*
           if        w-ute-tip-ute        =    02
                     go to acc-cod-stp-675.
      *                  *---------------------------------------------*
      *                  * Box di impostazione password codice 100 per *
      *                  * password su stampante                       *
      *                  *---------------------------------------------*
           move      w-stp-pwd-stp        to   w-box-pwd-100-pwr      .
           perform   box-pwd-100-000      thru box-pwd-100-999        .
      *                  *---------------------------------------------*
      *                  * Se password impostata diversa da password   *
      *                  * richiesta : a reimpostazione codice stam-   *
      *                  * pante                                       *
      *                  *---------------------------------------------*
           if        w-box-pwd-100-pwi    not  = w-box-pwd-100-pwr
                     go to acc-cod-stp-100.
       acc-cod-stp-675.
      *              *-------------------------------------------------*
      *              * Eventuale normalizzazione codice modulo         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il codice stampante precedente era a     *
      *                  * spaces : no normalizzazione                 *
      *                  *---------------------------------------------*
           if        w-acc-sav-cst        =    spaces
                     go to acc-cod-stp-680.
      *                  *---------------------------------------------*
      *                  * Se il codice stampante non e' variato : no  *
      *                  * normalizzazione                             *
      *                  *---------------------------------------------*
           if        w-acc-cod-stp        =    w-acc-sav-cst
                     go to acc-cod-stp-680.
      *                  *---------------------------------------------*
      *                  * Se il codice modulo e' gia' attualmente a   *
      *                  * spaces : no normalizzazione                 *
      *                  *---------------------------------------------*
           if        w-acc-cod-mod        =    spaces
                     go to acc-cod-stp-680.
      *                  *---------------------------------------------*
      *                  * Se il codice modulo indica un tipo modulo   *
      *                  * tipografico oppure specifico non tipogra-   *
      *                  * fico : no normalizzazione                   *
      *                  *---------------------------------------------*
           if        w-mod-cod-mod        =    spaces
                     go to acc-cod-stp-680.
           if        w-mod-tip-mod        not  = "L"
                     go to acc-cod-stp-680.
      *                  *---------------------------------------------*
      *                  * Se il codice modulo non e' un campo da ac-  *
      *                  * cettare : no normalizzazione                *
      *                  *---------------------------------------------*
           if        w-cnt-acc-prm-cmo    not  = "S"
                     go to acc-cod-stp-680.
      *                  *---------------------------------------------*
      *                  * Normalizzazione codice modulo               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice modulo                           *
      *                      *-----------------------------------------*
           move      spaces               to   w-acc-cod-mod          .
      *                      *-----------------------------------------*
      *                      * Descrizione modulo                      *
      *                      *-----------------------------------------*
           move      spaces               to   w-acc-des-mod          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valori normalizzati         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice modulo                           *
      *                      *-----------------------------------------*
           perform   vis-cod-mod-000      thru vis-cod-mod-999        .
      *                      *-----------------------------------------*
      *                      * Descrizione modulo                      *
      *                      *-----------------------------------------*
           perform   vis-cod-mod-des-000  thru vis-cod-mod-des-999    .
       acc-cod-stp-680.
      *              *-------------------------------------------------*
      *              * Eventuale normalizzazione nome file             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il codice stampante precedente era a     *
      *                  * spaces : no normalizzazione                 *
      *                  *---------------------------------------------*
           if        w-acc-sav-cst        =    spaces
                     go to acc-cod-stp-700.
      *                  *---------------------------------------------*
      *                  * Se il codice stampante non e' variato : no  *
      *                  * normalizzazione                             *
      *                  *---------------------------------------------*
______*    if        w-acc-cod-stp        =    w-acc-sav-cst
______*              go to acc-cod-stp-700.
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           perform   pmt-fnz-stp-000      thru pmt-fnz-stp-999        .
      *                  *---------------------------------------------*
      *                  * Se il nome file e' gia' attualmente a       *
      *                  * spaces : no normalizzazione                 *
      *                  *---------------------------------------------*
           if        w-acc-nom-fil        =    spaces
                     go to acc-cod-stp-700.
      *                  *---------------------------------------------*
      *                  * Se la stampante prevede il nome file : no   *
      *                  * normalizzazione                             *
      *                  *---------------------------------------------*
           if        w-stp-can-stp
                    (1 : 5)               =    "rcp *" or
                     w-stp-can-stp
                    (1 : 5)               =    "ucp *" or
                     w-stp-can-stp
                    (1 : 5)               =    "ghs *"
                     go to acc-cod-stp-700.
      *                  *---------------------------------------------*
      *                  * Normalizzazione nome file                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-acc-nom-fil          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valori normalizzati         *
      *                  *---------------------------------------------*
           perform   vis-nom-fil-000      thru vis-nom-fil-999        .
       acc-cod-stp-700.
      *              *-------------------------------------------------*
      *              * Eventuale normalizzazione numero fax            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il codice stampante precedente era a     *
      *                  * spaces : no normalizzazione                 *
      *                  *---------------------------------------------*
           if        w-acc-sav-cst        =    spaces
                     go to acc-cod-stp-720.
      *                  *---------------------------------------------*
      *                  * Se il codice stampante non e' variato : no  *
      *                  * normalizzazione                             *
      *                  *---------------------------------------------*
______*    if        w-acc-cod-stp        =    w-acc-sav-cst
______*              go to acc-cod-stp-720.
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           perform   pmt-fnz-stp-000      thru pmt-fnz-stp-999        .
      *                  *---------------------------------------------*
      *                  * Se il numero fax e' gia' attualmente a      *
      *                  * spaces : no normalizzazione                 *
      *                  *---------------------------------------------*
           if        w-acc-num-fax        =    spaces
                     go to acc-cod-stp-720.
      *                  *---------------------------------------------*
      *                  * Se la stampante prevede il numero fax : no  *
      *                  * normalizzazione                             *
      *                  *---------------------------------------------*
           if        w-stp-can-stp
                    (1 : 5)               =    "fax *"
                     go to acc-cod-stp-420.
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-acc-num-fax          .
           move      zero                 to   w-acc-snd-tim          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valori normalizzati         *
      *                  *---------------------------------------------*
           perform   vis-num-fax-000      thru vis-num-fax-999        .
           perform   vis-snd-tim-000      thru vis-snd-tim-999        .
       acc-cod-stp-720.
      *              *-------------------------------------------------*
      *              * Eventuale normalizzazione ___                   *
      *              *-------------------------------------------------*
       acc-cod-stp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cod-stp-999.
      *                  *---------------------------------------------*
      *                  * Controllo globale per tasto Do              *
      *                  *---------------------------------------------*
           perform   cnt-glo-tdo-000      thru cnt-glo-tdo-999        .
      *                  *---------------------------------------------*
      *                  * Se errori : reimpostazione                  *
      *                  *---------------------------------------------*
           if        w-cnt-glo-tdo-sts    not  = e-not-err
                     go to acc-cod-stp-100.
      *                  *---------------------------------------------*
      *                  * Altrimenti uscita con Do                    *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-cod-stp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice stampante                  *
      *    *-----------------------------------------------------------*
       vis-cod-stp-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      27                   to   v-pos                  .
           add       w-dsp-cnt-acc-prm    to   v-pos                  .
           if        w-cod-stp-chr (1)    =    "#"
                     move  "#"            to   v-alf
           else      move  w-acc-cod-stp  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-stp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice stampante, descrizione     *
      *    *-----------------------------------------------------------*
       vis-cod-stp-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      36                   to   v-pos                  .
           add       w-dsp-cnt-acc-prm    to   v-pos                  .
           if        w-cod-stp-chr (1)    =    "#"
                     move  "Stampante Locale"
                                          to   v-alf
           else      move  w-acc-des-stp  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-stp-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice modulo                        *
      *    *-----------------------------------------------------------*
       acc-cod-mod-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-cnt-acc-prm-cmo    not  = "S"
                     go to acc-cod-mod-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-acc-cod-mod        to   w-acc-sav-cmo          .
       acc-cod-mod-050.
      *                  *---------------------------------------------*
      *                  * Preparazione del default : se codice modulo *
      *                  * attualmente a spaces si propone il codice   *
      *                  * modulo attualmente montato sulla stampante, *
      *                  * sempreche' ce ne sia uno montato            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice modulo diverso da spaces : no *
      *                      * default                                 *
      *                      *-----------------------------------------*
           if        w-acc-cod-mod        not  = spaces
                     go to acc-cod-mod-100.
      *                      *-----------------------------------------*
      *                      * Lettura modulo montato sulla stampante  *
      *                      *-----------------------------------------*
           move      w-acc-cod-stp        to   w-let-mmo-pss-cst      .
           perform   let-mmo-pss-000      thru let-mmo-pss-999        .
      *                      *-----------------------------------------*
      *                      * Test se errori                          *
      *                      *-----------------------------------------*
           if        w-let-mmo-pss-sts    =    e-not-err
                     go to acc-cod-mod-055.
      *                      *-----------------------------------------*
      *                      * Se errori nella lettura del record per  *
      *                      * il modulo montato sulla stampante       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun default                      *
      *                          *-------------------------------------*
           go to     acc-cod-mod-100.
       acc-cod-mod-055.
      *                      *-----------------------------------------*
      *                      * Se nessun errore nella lettura record   *
      *                      * modulo montato su stampante             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test che esista un modulo montato   *
      *                          * sulla stampante                     *
      *                          *-------------------------------------*
           if        w-mmo-cod-mod        not  = spaces
                     go to acc-cod-mod-060.
      *                          *-------------------------------------*
      *                          * Se non c'e' alcun modulo montato    *
      *                          * sulla stampante                     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Nessun default                  *
      *                              *---------------------------------*
           go to     acc-cod-mod-100.
       acc-cod-mod-060.
      *                          *-------------------------------------*
      *                          * Se c'e' un modulo attualmente mon-  *
      *                          * tato sulla stampante                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Lettura record codice modulo    *
      *                              *---------------------------------*
           move      w-mmo-cod-mod        to   w-let-mod-pss-cod      .
           perform   let-mod-pss-000      thru let-mod-pss-999        .
      *                              *---------------------------------*
      *                              * Test se errori                  *
      *                              *---------------------------------*
           if        w-let-mod-pss-sts    =    e-not-err
                     go to acc-cod-mod-065.
      *                              *---------------------------------*
      *                              * Se errori nella lettura record  *
      *                              * codice modulo                   *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Nessun default              *
      *                                  *-----------------------------*
           go to     acc-cod-mod-100.
       acc-cod-mod-065.
      *                              *---------------------------------*
      *                              * Se nessun errore nella lettura  *
      *                              * record codice modulo            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Controllo sulla definizione *
      *                                  * interna del codice modulo   *
      *                                  *-----------------------------*
           perform   cnt-dfz-mod-000      thru cnt-dfz-mod-999        .
      *                                  *-----------------------------*
      *                                  * Se definizione interna del  *
      *                                  * codice modulo errata : no   *
      *                                  * default                     *
      *                                  *-----------------------------*
           if        w-cnt-dfz-mod-sts    not  = e-not-err
                     go to acc-cod-mod-100.
      *                                  *-----------------------------*
      *                                  * Deviazione a seconda del    *
      *                                  * tipo modulo attualmente     *
      *                                  * montato                     *
      *                                  *-----------------------------*
           if        w-mod-tip-mod        =    "L"
                     go to acc-cod-mod-070.
      *                                  *-----------------------------*
      *                                  * Se e' un modulo tipografico *
      *                                  * oppure specifico non tipo-  *
      *                                  * grafico : nessun default    *
      *                                  *-----------------------------*
           go to     acc-cod-mod-100.
       acc-cod-mod-070.
      *                                  *-----------------------------*
      *                                  * Se e' un modulo libero      *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Defaults                *
      *                                      *-------------------------*
      *                                          *---------------------*
      *                                          * Codice modulo       *
      *                                          *---------------------*
           move      w-mod-cod-mod        to   w-acc-cod-mod          .
      *                                          *---------------------*
      *                                          * Descrizione modulo  *
      *                                          *---------------------*
           move      w-mod-des-mod        to   w-acc-des-mod          .
      *                                      *-------------------------*
      *                                      * Visualizzazioni         *
      *                                      *-------------------------*
      *                                          *---------------------*
      *                                          * Codice modulo       *
      *                                          *---------------------*
           perform   vis-cod-mod-000      thru vis-cod-mod-999        .
      *                                          *---------------------*
      *                                          * Descrizione modulo  *
      *                                          *---------------------*
           perform   vis-cod-mod-des-000  thru vis-cod-mod-des-999    .
       acc-cod-mod-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      27                   to   v-pos                  .
           add       w-dsp-cnt-acc-prm    to   v-pos                  .
           if        w-cnt-acc-prm-cst    =    "S"
                     move  "UP  "         to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-acc-cod-mod        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "90"           to   w-cnt-acc-prm-sts
                     go to acc-cod-mod-999.
       acc-cod-mod-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-acc-cod-mod          .
       acc-cod-mod-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-cod-mod-400.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del codice           *
      *                  *---------------------------------------------*
           if        w-acc-cod-mod
                    (01 : 01)             =    "-"
                     move  w-acc-cod-mod
                          (02 : 07)       to   w-fnd-pss-mod-cod
           else      move  spaces         to   w-fnd-pss-mod-cod      .
       acc-cod-mod-320.
      *                  *---------------------------------------------*
      *                  * Find su codici modulo in [pss]              *
      *                  *---------------------------------------------*
           move      w-acc-cod-mod        to   w-fnd-pss-mod-cod      .
           perform   fnd-pss-mod-000      thru fnd-pss-mod-999        .
      *                  *---------------------------------------------*
      *                  * Se non selezionato : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-fnd-pss-mod-sel    not  = spaces
                     go to acc-cod-mod-100.
      *                  *---------------------------------------------*
      *                  * Codice selezionato in campo di destinazione *
      *                  *---------------------------------------------*
           move      w-fnd-pss-mod-cod    to   w-acc-cod-mod          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice selezionato          *
      *                  *---------------------------------------------*
           perform   vis-cod-mod-000      thru vis-cod-mod-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key impostazione   *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
       acc-cod-mod-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del codice per Find  *
      *                  *---------------------------------------------*
           if        w-acc-cod-mod
                    (01 : 01)             =    "-"
                     move  w-acc-cod-mod
                          (02 : 07)       to   w-fnd-pss-mod-cod
                     move  spaces         to   w-acc-cod-mod
                     go to acc-cod-mod-320.
      *                  *---------------------------------------------*
      *                  * Test se valore mancante                     *
      *                  *---------------------------------------------*
           if        w-acc-cod-mod        not  = spaces
                     go to acc-cod-mod-410.
      *                  *---------------------------------------------*
      *                  * Se valore mancante                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione descrizione             *
      *                      *-----------------------------------------*
           move      spaces               to   w-acc-des-mod          .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-cod-mod-des-000  thru vis-cod-mod-des-999    .
      *                      *-----------------------------------------*
      *                      * Se Up si esce                           *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-cod-mod-999.
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-mod-100.
       acc-cod-mod-410.
      *                  *---------------------------------------------*
      *                  * Se valore presente                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura da [pss] codice modulo          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura                             *
      *                          *-------------------------------------*
           move      w-acc-cod-mod        to   w-let-mod-pss-cod      .
           perform   let-mod-pss-000      thru let-mod-pss-999        .
      *                          *-------------------------------------*
      *                          * Test se errori                      *
      *                          *-------------------------------------*
           if        w-let-mod-pss-sts    =    e-not-err
                     go to acc-cod-mod-420
           else if   w-let-mod-pss-sts    =    e-not-fnd
                     go to acc-cod-mod-415.
      *                          *-------------------------------------*
      *                          * Se errore grave di i-o              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Exit                            *
      *                              *---------------------------------*
           move      "EXIT"               to   v-key                  .
      *                              *---------------------------------*
      *                              * Flag uscita ad errore di i-o    *
      *                              *---------------------------------*
           move      "99"                 to   w-cnt-acc-prm-sts      .
      *                              *---------------------------------*
      *                              * Uscita                          *
      *                              *---------------------------------*
           go to     acc-cod-mod-999.
       acc-cod-mod-415.
      *                          *-------------------------------------*
      *                          * Se record non esistente             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Descrizione per non esistente   *
      *                              *---------------------------------*
           move      all   "."            to   w-acc-des-mod          .
      *                              *---------------------------------*
      *                              * Visualizzazione descrizione     *
      *                              *---------------------------------*
           perform   vis-cod-mod-des-000  thru vis-cod-mod-des-999    .
      *                              *---------------------------------*
      *                              * Reimpostazione                  *
      *                              *---------------------------------*
           go to     acc-cod-mod-100.
       acc-cod-mod-420.
      *                          *-------------------------------------*
      *                          * Se record esistente                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Descrizione in area di accetta- *
      *                              * zione                           *
      *                              *---------------------------------*
           move      w-mod-des-mod        to   w-acc-des-mod          .
      *                              *---------------------------------*
      *                              * Visualizzazione descrizione     *
      *                              *---------------------------------*
           perform   vis-cod-mod-des-000  thru vis-cod-mod-des-999    .
      *                              *---------------------------------*
      *                              * Controllo sulla definizione in- *
      *                              * terna del codice modulo         *
      *                              *---------------------------------*
           perform   cnt-dfz-mod-000      thru cnt-dfz-mod-999        .
      *                              *---------------------------------*
      *                              * Test su esito controllo         *
      *                              *---------------------------------*
           if        w-cnt-dfz-mod-sts    =    e-not-err
                     go to acc-cod-mod-600.
      *                              *---------------------------------*
