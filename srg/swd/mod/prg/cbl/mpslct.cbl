           move      v-alf                to   w-acc-nom-fil          .
       acc-nom-fil-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore mancante                     *
      *                  *---------------------------------------------*
           if        w-acc-nom-fil        not  = spaces
                     go to acc-nom-fil-410.
           if        v-key                =    "UP  "
                     go to acc-nom-fil-999.
           go to     acc-nom-fil-100.
       acc-nom-fil-410.
      *                  *---------------------------------------------*
      *                  * Se valore presente                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test che non ci siano blanks embedded   *
      *                      *-----------------------------------------*
           move      w-acc-nom-fil        to   w-all-str-alf          .
           move      40                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-nom-fil-100.
      *                      *-----------------------------------------*
