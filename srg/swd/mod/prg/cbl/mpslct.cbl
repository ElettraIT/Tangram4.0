      *    *===========================================================*
      *    * Accettazione campo : Tipo di stampa                       *
      *    *-----------------------------------------------------------*
       acc-tip-sta-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-sta-010.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-cnt-acc-prm-tds    not  = "S"
                     go to acc-tip-sta-999.
       acc-tip-sta-020.
      *                  *---------------------------------------------*
      *                  * Se si e' in esecuzione di un desk-accessory *
      *                  * di tipo Screen-Hard-Copy si limita l'accet- *
      *                  * tazione in modo tale da non consentire il   *
      *                  * tipo di stampa 'A video'                    *
      *                  *---------------------------------------------*
           if        w-exe-dac-snx-dac    =    "S"    and
                     w-exe-dac-tip-dac    =    "SHCP"
                     move  2              to   w-acc-exp-tds-num
           else      move  3              to   w-acc-exp-tds-num      .
      *                  *---------------------------------------------*
      *                  * Se l'area per espansioni future contiene il *
      *                  * valore '#' al carattere con posizione nella *
      *                  * stringa, significa che per il tipo di stam- *
      *                  * pa richiesta non e' prevista l'opzione 'A   *
      *                  * video'                                      *
      *                  *---------------------------------------------*
           if        r-fix-esp-fut (98 : 1)
                                          =    "#"
                     move  2              to   w-acc-exp-tds-num      .
      *                  *---------------------------------------------*
      *                  * Eventuale ritaratura di un default          *
      *                  *---------------------------------------------*
           if        w-acc-exp-tds-num    =    2 and
                     w-acc-cod-tds        =    "V"
                     move  "D"            to   w-acc-cod-tds          .
       acc-tip-sta-030.
      *                  *---------------------------------------------*
      *                  * Determinazione del displacement di accetta- *
      *                  * zione e visualizzazione a seconda del modo  *
      *                  * di utilizzo attuale del video               *
      *                  *---------------------------------------------*
           move      "M?"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-ope                =    "M1"
                     move  26             to   w-dsp-acc-tip-sta
           else      move  zero           to   w-dsp-acc-tip-sta      .
       acc-tip-sta-040.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-acc-cod-tds        to   w-acc-sav-tds          .
       acc-tip-sta-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore, con pre-espansione solo se *
      *              * si e' alla prima impostazione                   *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-acc-exp-tds-lun    to   v-car                  .
           move      w-acc-exp-tds-num    to   v-ldt                  .
           if        w-acc-cod-tds-uno    =    spaces
                     move  "#"            to   w-acc-cod-tds-uno
                     move  "X"            to   v-edm
           else      move  spaces         to   v-edm                  .
           move      13                   to   v-lin                  .
           move      "IDV#"               to   v-msk                  .
           move      27                   to   v-pos                  .
           add       w-dsp-acc-tip-sta    to   v-pos                  .
           if        w-cnt-acc-prm-cst    =    "S" or
                     w-cnt-acc-prm-cmo    =    "S"
                     move  "UP  "         to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-acc-exp-tds-tbl    to   v-txt                  .
      *
           if        w-acc-cod-tds        =    "I"
                     move  01             to   v-num
           else if   w-acc-cod-tds        =    "D"
                     move  02             to   v-num
           else if   w-acc-cod-tds        =    "V"
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *
           if        v-num                >    w-acc-exp-tds-num
                     move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "90"           to   w-cnt-acc-prm-sts
                     go to acc-tip-sta-999.
       acc-tip-sta-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "I"            to   w-acc-cod-tds
                     move  v-alf          to   w-acc-des-tds
           else if   v-num                =    02
                     move  "D"            to   w-acc-cod-tds
                     move  v-alf          to   w-acc-des-tds
           else if   v-num                =    03
                     move  "V"            to   w-acc-cod-tds
                     move  v-alf          to   w-acc-des-tds
           else      move  spaces         to   w-acc-cod-tds
                     move  spaces         to   w-acc-des-tds          .
       acc-tip-sta-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore mancante                     *
      *                  *---------------------------------------------*
           if        w-acc-cod-tds        not  = spaces
                     go to acc-tip-sta-410.
      *                  *---------------------------------------------*
      *                  * Se valore mancante                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Up si esce                           *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-tip-sta-999.
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-tip-sta-100.
       acc-tip-sta-410.
      *                  *---------------------------------------------*
      *                  * Se valore presente                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se valore previsto                 *
      *                      *-----------------------------------------*
           if        w-acc-cod-tds        not  = "I" and
                     w-acc-cod-tds        not  = "D" and
                     w-acc-cod-tds        not  = "V"
                     go to acc-tip-sta-100.
       acc-tip-sta-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-sta-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-tip-sta-999.
      *                  *---------------------------------------------*
      *                  * Controllo globale per tasto Do              *
      *                  *---------------------------------------------*
           perform   cnt-glo-tdo-000      thru cnt-glo-tdo-999        .
      *                  *---------------------------------------------*
      *                  * Se errori : reimpostazione                  *
      *                  *---------------------------------------------*
           if        w-cnt-glo-tdo-sts    not  = e-not-err
                     go to acc-tip-sta-100.
       acc-tip-sta-999.
           exit.

