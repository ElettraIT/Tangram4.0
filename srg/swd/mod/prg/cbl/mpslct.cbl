           move      w-tst-spa-ori (08)   to   p-sel-spo-tst (08)     .
           move      w-tst-spa-ori (09)   to   p-sel-spo-tst (09)     .
           move      w-tst-spa-ori (10)   to   p-sel-spo-tst (10)     .
           move      w-tst-spa-ori (11)   to   p-sel-spo-tst (11)     .
           move      w-tst-spa-ori (12)   to   p-sel-spo-tst (12)     .
           move      w-tst-spa-ori (13)   to   p-sel-spo-tst (13)     .
           move      w-tst-spa-ori (14)   to   p-sel-spo-tst (14)     .
           move      w-tst-spa-ori (15)   to   p-sel-spo-tst (15)     .
           move      w-tst-spa-ori (16)   to   p-sel-spo-tst (16)     .
