           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-mtv-qta-cfz       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
