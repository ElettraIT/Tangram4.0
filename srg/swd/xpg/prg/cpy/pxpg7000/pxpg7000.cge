           move      "S"                  to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-mgi-ibl-iva
                    (w-exe-ctr-001)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
