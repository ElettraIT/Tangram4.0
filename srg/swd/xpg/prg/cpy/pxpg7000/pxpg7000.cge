      *              *-------------------------------------------------*
           perform   wrt-rum-msg-000      thru wrt-rum-msg-999        .
       exe-exp-mgi-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [mpu]                                        *
      *    *-----------------------------------------------------------*
       exe-exp-mpu-000.
      *              *-------------------------------------------------*
      *              * Sezione di testata : presentazione              *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-pre-000  thru exe-exp-mpu-pre-999    .
      *              *-------------------------------------------------*
      *              * Sezione 1          : Erario                     *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-001-000  thru exe-exp-mpu-001-999    .
      *              *-------------------------------------------------*
      *              * Sezione 2          : INPS                       *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-002-000  thru exe-exp-mpu-002-999    .
      *              *-------------------------------------------------*
      *              * Sezione 3          : Regioni                    *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-003-000  thru exe-exp-mpu-003-999    .
      *              *-------------------------------------------------*
      *              * Sezione 4          : ICI e tributi locali       *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-004-000  thru exe-exp-mpu-004-999    .
      *              *-------------------------------------------------*
      *              * Sezione 5          : INAIL                      *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-005-000  thru exe-exp-mpu-005-999    .
      *              *-------------------------------------------------*
      *              * Sezione 6          : Enti previdenziali         *
      *              *-------------------------------------------------*
           perform   exe-exp-mpu-006-000  thru exe-exp-mpu-006-999    .
       exe-exp-mpu-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [mpu]                                        *
      *    *                                                           *
      *    * Sezione di testata : presentazione                        *
      *    *-----------------------------------------------------------*
       exe-exp-mpu-pre-000.
      *              *-------------------------------------------------*
      *              * Preparazione file area generica                 *
      *              *-------------------------------------------------*
           move      "cge "               to   f-xxx-are              .
           move      "mpu "               to   f-xxx-nam              .
           move      "std_cge_mpu"        to   f-xxx-npe              .
      *              *-------------------------------------------------*
      *              * Richiesta di conferma, se manuale               *
      *              *-------------------------------------------------*
           perform   ric-cnf-man-000      thru ric-cnf-man-999        .
      *              *-------------------------------------------------*
      *              * Se non confermato : ad uscita                   *
      *              *-------------------------------------------------*
           if        f-xxx-sts            not  = "S"
                     go to exe-exp-mpu-pre-999.
      *              *-------------------------------------------------*
      *              * Eventuali forzature se esecuzione batch         *
      *              *-------------------------------------------------*
           if        w-exe-flg-btc        =    "S"
                     go to exe-exp-mpu-pre-010.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-mpu-pre-010.
      *              *-------------------------------------------------*
      *              * Numero records letti e scritti a zero           *
      *              *-------------------------------------------------*
           move      zero                 to   f-xxx-nrl              .
           move      zero                 to   f-xxx-nrs              .
       exe-exp-mpu-pre-020.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * [mpu]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di output    *
      *                  *---------------------------------------------*
           perform   opn-seq-out-000      thru opn-seq-out-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to exe-exp-mpu-pre-100.
      *                  *---------------------------------------------*
      *                  * Se errori                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore sull'input          *
      *                      *-----------------------------------------*
           perform   msg-inp-err-000      thru msg-inp-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-mpu-pre-999.
       exe-exp-mpu-pre-100.
      *              *-------------------------------------------------*
      *              * Start su file [mpu]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      zero                 to   rf-mpu-num-prt         .
           move      zero                 to   rf-mpu-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a close file              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-mpu-pre-800.
       exe-exp-mpu-pre-200.
      *              *-------------------------------------------------*
      *              * Next su [mpu]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
      *                  *---------------------------------------------*
