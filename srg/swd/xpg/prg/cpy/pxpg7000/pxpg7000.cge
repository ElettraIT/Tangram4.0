           move      "pgm/cge/fls/ioc/obj/iofzca"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zca                 .
       exe-exp-zca-850.
