           if        w-exe-ctr-001        >    10
                     go to exe-exp-cer-630.
      *                  *---------------------------------------------*
      *                  * Flags di trattamento                        *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      rf-cer-flg-snx
                    (w-exe-ctr-001)       to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           if        w-exe-ctr-001        =    10
                     move  "Af"           to   w-scr-str-tip
           else      move  "AA"           to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     exe-exp-cer-620.
       exe-exp-cer-630.
       exe-exp-cer-690.
