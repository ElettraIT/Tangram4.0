                                         using s                      .
           call      s-pat               using f
                                               rf-zfi                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a close file                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-zfi-800.
       exe-exp-zfi-300.
      *              *-------------------------------------------------*
