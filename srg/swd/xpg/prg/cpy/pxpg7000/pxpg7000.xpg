           move      zero                 to   f-xxx-nrl              .
           move      zero                 to   f-xxx-nrs              .
       exe-exp-ref-020.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Apertura file personalizzazioni             *
      *                  *---------------------------------------------*
           perform   opn-ref-000          thru opn-ref-999            .
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di output    *
      *                  *---------------------------------------------*
           perform   opn-seq-out-000      thru opn-seq-out-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to exe-exp-ref-100.
      *                  *---------------------------------------------*
      *                  * Se errori                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore sull'input          *
      *                      *-----------------------------------------*
           perform   msg-inp-err-000      thru msg-inp-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-ref-999.
       exe-exp-ref-100.
      *              *-------------------------------------------------*
      *              * Start su [ref]                                  *
      *              *-------------------------------------------------*
           move      "ref "               to   ref-tre                .
           move      spaces               to   ref-cod                .
           move      zero                 to   ref-prg                .
           start     ref   key not less
                           ref-rck
                           invalid key
                           go to exe-exp-ref-800.
       exe-exp-ref-200.
      *              *-------------------------------------------------*
      *              * Read next su [auc]                              *
      *              *-------------------------------------------------*
           read      ref    next
                            with no lock
                            at end
                            go to exe-exp-ref-800.
       exe-exp-ref-300.
      *              *-------------------------------------------------*
      *              * Text max                                        *
      *              *-------------------------------------------------*
           if        ref-tre              not  = "ref "
                     go to exe-exp-ref-800.
       exe-exp-ref-400.
      *              *-------------------------------------------------*
      *              * Sel su [ref]                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura referenza                           *
      *                  *---------------------------------------------*
           move      "R:"                 to   s-ope                  .
           move      ref-cod              to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su valori letti                        *
      *                  *---------------------------------------------*
           if        s-ves                not  = spaces
                     go to exe-exp-ref-200.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo personalizzazione      *
      *                  *---------------------------------------------*
           move      s-tip                to   w-exe-per-tip          .
           move      spaces               to   w-exe-per-val          .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo referenza   *
      *                  *---------------------------------------------*
           move      spaces               to   w-exe-per-val          .
           if        s-tip                =    "A"
                     perform  exe-exp-ref-alf-000
                                          thru exe-exp-ref-alf-999
           else if   s-tip                =    "D"
                     perform  exe-exp-ref-dat-000
                                          thru exe-exp-ref-dat-999
           else if   s-tip                =    "N"
                     perform  exe-exp-ref-num-000
                                          thru exe-exp-ref-num-999    .
       exe-exp-ref-500.
      *              *-------------------------------------------------*
      *              * Incremento numero records letti                 *
      *              *-------------------------------------------------*
           perform   inc-rec-let-000      thru inc-rec-let-999        .
           if        w-exe-flg-brk        not  = spaces
                     go to exe-exp-ref-800.
       exe-exp-ref-550.
      *              *-------------------------------------------------*
      *              * Pulizia preliminare record sequenziale          *
      *              *-------------------------------------------------*
           move      spaces               to   g-rec                  .
       exe-exp-ref-600.
      *              *-------------------------------------------------*
      *              * Composizione record in output                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizio                                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-str-out          .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "iA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Codice                                      *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      ref-cod              to   w-scr-str-ele          .
           move      40                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "AN"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Progressivo                                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      ref-prg              to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "N "                 to   w-scr-str-tip          .
           move      v-edt                to   w-scr-str-ele          .
           move      03                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "NA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Tipo                                        *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      w-exe-per-tip        to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "AA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Valore alfanumerico                         *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      w-exe-per-val        to   w-scr-str-ele          .
           move      80                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "Af"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-ref-690.
      *              *-------------------------------------------------*
      *              * Composizione carattere di fine record           *
      *              *-------------------------------------------------*
           move      "fr"                 to   w-scr-str-tip          .
           move      w-scr-fso-cfr        to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-ref-700.
      *              *-------------------------------------------------*
      *              * Scrittura record in output                      *
      *              *-------------------------------------------------*
           move      w-out-str-out        to   g-rec                  .
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       exe-exp-ref-720.
      *              *-------------------------------------------------*
      *              * Incremento numero records scritti               *
      *              *-------------------------------------------------*
           perform   inc-rec-scr-000      thru inc-rec-scr-999        .
       exe-exp-ref-750.
      *              *-------------------------------------------------*
      *              * Riciclo a Next su [ref]                         *
      *              *-------------------------------------------------*
           go to     exe-exp-ref-200.
       exe-exp-ref-800.
      *              *-------------------------------------------------*
      *              * Close files                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura del file in output                 *
      *                  *---------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo utilizzato             *
      *                  *---------------------------------------------*
           cancel    "swd/mod/prg/obj/mcvout"                         .
      *                  *---------------------------------------------*
      *                  * Chiusura file personalizzazioni             *
      *                  *---------------------------------------------*
           perform   cls-ref-000          thru cls-ref-999            .
       exe-exp-ref-850.
      *              *-------------------------------------------------*
      *              * Visualizzazione nr records letti e scritti      *
      *              *-------------------------------------------------*
           perform   vis-rec-let-000      thru vis-rec-let-999        .
           perform   vis-rec-scr-000      thru vis-rec-scr-999        .
      *              *-------------------------------------------------*
      *              * Accettazione presa visione                      *
      *              *-------------------------------------------------*
           perform   acc-pre-vis-000      thru acc-pre-vis-999        .
       exe-exp-ref-900.
      *              *-------------------------------------------------*
      *              * Scrittura rullino messaggi                      *
      *              *-------------------------------------------------*
           perform   wrt-rum-msg-000      thru wrt-rum-msg-999        .
       exe-exp-ref-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [ref]                                        *
      *    *                                                           *
      *    * Personalizzazione alfanumerica                            *
      *    *-----------------------------------------------------------*
       exe-exp-ref-alf-000.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      s-alf                to   w-exe-per-val          .
       exe-exp-ref-alf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-ref-alf-999.
       exe-exp-ref-alf-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [ref]                                        *
      *    *                                                           *
      *    * Personalizzazione numerica                                *
      *    *-----------------------------------------------------------*
       exe-exp-ref-num-000.
      *              *-------------------------------------------------*
      *              * Editing valore numerico                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      s-num                to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      v-edt                to   w-exe-per-val          .
       exe-exp-ref-num-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-ref-num-999.
       exe-exp-ref-num-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [ref]                                        *
      *    *                                                           *
      *    * Personalizzazione data                                    *
      *    *-----------------------------------------------------------*
       exe-exp-ref-dat-000.
      *              *-------------------------------------------------*
      *              * Editing data                                    *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      s-dat                to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      v-edt                to   w-exe-per-val          .
       exe-exp-ref-dat-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-ref-dat-999.
       exe-exp-ref-dat-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [num]                                        *
      *    *-----------------------------------------------------------*
       exe-exp-num-000.
      *              *-------------------------------------------------*
      *              * Preparazione file area generica                 *
      *              *-------------------------------------------------*
           move      "xpg "               to   f-xxx-are              .
           move      "num "               to   f-xxx-nam              .
           move      "std_xpg_num"        to   f-xxx-npe              .
      *              *-------------------------------------------------*
      *              * Richiesta di conferma, se manuale               *
      *              *-------------------------------------------------*
           perform   ric-cnf-man-000      thru ric-cnf-man-999        .
      *              *-------------------------------------------------*
      *              * Se non confermato : ad uscita                   *
      *              *-------------------------------------------------*
           if        f-xxx-sts            not  = "S"
                     go to exe-exp-num-999.
      *              *-------------------------------------------------*
      *              * Eventuali forzature se esecuzione batch         *
      *              *-------------------------------------------------*
           if        w-exe-flg-btc        =    "S"
                     go to exe-exp-num-010.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-num-010.
      *              *-------------------------------------------------*
      *              * Numero records letti e scritti a zero           *
      *              *-------------------------------------------------*
           move      zero                 to   f-xxx-nrl              .
           move      zero                 to   f-xxx-nrs              .
       exe-exp-num-020.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * [num]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           call      "swd/xpg/fls/ioc/obj/iofnum"
                                         using f
                                               rf-num                 .
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di output    *
      *                  *---------------------------------------------*
           perform   opn-seq-out-000      thru opn-seq-out-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to exe-exp-num-100.
      *                  *---------------------------------------------*
      *                  * Se errori                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore sull'input          *
      *                      *-----------------------------------------*
           perform   msg-inp-err-000      thru msg-inp-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-num-999.
       exe-exp-num-100.
      *              *-------------------------------------------------*
      *              * Start su file [num]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMKEY    "         to   f-key                  .
           move      spaces               to   rf-num-key-fix         .
           move      spaces               to   rf-num-key-var         .
           move      zero                 to   rf-num-key-cnf         .
           call      "swd/xpg/fls/ioc/obj/iofnum"
                                         using f
                                               rf-num                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a close file              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-num-800.
       exe-exp-num-200.
      *              *-------------------------------------------------*
      *              * Next su [num]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           call      "swd/xpg/fls/ioc/obj/iofnum"
                                         using f
                                               rf-num                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a close file                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-num-800.
       exe-exp-num-300.
      *              *-------------------------------------------------*
      *              * Max su [num]                                    *
      *              *-------------------------------------------------*
       exe-exp-num-400.
      *              *-------------------------------------------------*
      *              * Sel su [num]                                    *
      *              *-------------------------------------------------*
       exe-exp-num-500.
      *              *-------------------------------------------------*
      *              * Incremento numero records letti                 *
      *              *-------------------------------------------------*
           perform   inc-rec-let-000      thru inc-rec-let-999        .
           if        w-exe-flg-brk        not  = spaces
                     go to exe-exp-num-800.
       exe-exp-num-550.
      *              *-------------------------------------------------*
      *              * Pulizia preliminare record sequenziale          *
      *              *-------------------------------------------------*
           move      spaces               to   g-rec                  .
       exe-exp-num-600.
      *              *-------------------------------------------------*
      *              * Composizione record in output                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione della numerazione    *
      *                  *---------------------------------------------*
           if        rf-num-key-fix       =    "bfoprt  "
                     perform exe-exp-bfo-prt-000
                                          thru exe-exp-bfo-prt-999
           else if   rf-num-key-fix       =    "ffoprt  "
                     perform exe-exp-ffo-prt-000
                                          thru exe-exp-ffo-prt-999
           else if   rf-num-key-fix       =    "bciprt  "
                     perform exe-exp-bol-prt-000
                                          thru exe-exp-bol-prt-999
           else if   rf-num-key-fix       =    "bcindo  "
                     perform exe-exp-bol-ndo-000
                                          thru exe-exp-bol-ndo-999
           else if   rf-num-key-fix       =    "cdpprt  "
                     perform exe-exp-cdp-prt-000
                                          thru exe-exp-cdp-prt-999
           else if   rf-num-key-fix       =    "cdpndo  "
                     perform exe-exp-cdp-ndo-000
                                          thru exe-exp-cdp-ndo-999
           else if   rf-num-key-fix       =    "datbil  "
                     perform exe-exp-dat-bil-000
                                          thru exe-exp-dat-bil-999
           else if   rf-num-key-fix       =    "dtrcge  "
                     perform exe-exp-dtr-cge-000
                                          thru exe-exp-dtr-cge-999
           else if   rf-num-key-fix       =    "giocon  "
                     perform exe-exp-gio-con-000
                                          thru exe-exp-gio-con-999
           else if   rf-num-key-fix       =    "givacq  "
                     perform exe-exp-giv-acq-000
                                          thru exe-exp-giv-acq-999
           else if   rf-num-key-fix       =    "givcor  "
                     perform exe-exp-giv-cor-000
                                          thru exe-exp-giv-cor-999
           else if   rf-num-key-fix       =    "givven  "
                     perform exe-exp-giv-ven-000
                                          thru exe-exp-giv-ven-999
           else if   rf-num-key-fix       =    "mpuprt  "
                     perform exe-exp-mpu-prt-000
                                          thru exe-exp-mpu-prt-999
           else if   rf-num-key-fix       =    "parcli  "
                     perform exe-exp-par-cli-000
                                          thru exe-exp-par-cli-999
           else if   rf-num-key-fix       =    "parfnt  "
                     perform exe-exp-par-fnt-000
                                          thru exe-exp-par-fnt-999
           else if   rf-num-key-fix       =    "pargen  "
                     perform exe-exp-par-gen-000
                                          thru exe-exp-par-gen-999
           else if   rf-num-key-fix       =    "prtcge  "
                     perform exe-exp-prt-cge-000
                                          thru exe-exp-prt-cge-999
           else if   rf-num-key-fix       =    "prtivf  "
                     perform exe-exp-prt-ivf-000
                                          thru exe-exp-prt-ivf-999
           else if   rf-num-key-fix       =    "datife  "
                     perform exe-exp-dat-ife-000
                                          thru exe-exp-dat-ife-999
           else if   rf-num-key-fix       =    "datinv  "
                     perform exe-exp-dat-inv-000
                                          thru exe-exp-dat-inv-999
           else if   rf-num-key-fix       =    "duccmc  "
                     perform exe-exp-duc-cmc-000
                                          thru exe-exp-duc-cmc-999
           else if   rf-num-key-fix       =    "prtmag  "
                     perform exe-exp-prt-mag-000
                                          thru exe-exp-prt-mag-999
           else if   rf-num-key-fix       =    "ftilfd  "
                     perform exe-exp-fat-lfd-000
                                          thru exe-exp-fat-lfd-999
           else if   rf-num-key-fix       =    "ftiprt  "
                     perform exe-exp-fat-prt-000
                                          thru exe-exp-fat-prt-999
           else if   rf-num-key-fix       =    "ftindo  "
                     perform exe-exp-fat-ndo-000
                                          thru exe-exp-fat-ndo-999
           else if   rf-num-key-fix       =    "givaic  "
                     perform exe-exp-giv-aic-000
                                          thru exe-exp-giv-aic-999
           else if   rf-num-key-fix       =    "numiic  "
                     perform exe-exp-num-iic-000
                                          thru exe-exp-num-iic-999
           else if   rf-num-key-fix       =    "numgpc  "
                     perform exe-exp-num-gpc-000
                                          thru exe-exp-num-gpc-999
           else if   rf-num-key-fix       =    "numgpm  "
                     perform exe-exp-num-gpm-000
                                          thru exe-exp-num-gpm-999
           else if   rf-num-key-fix       =    "orcprt  "
                     perform exe-exp-orc-prt-000
                                          thru exe-exp-orc-prt-999
           else if   rf-num-key-fix       =    "orcndo  "
                     perform exe-exp-orc-ndo-000
                                          thru exe-exp-orc-ndo-999
           else if   rf-num-key-fix       =    "orfprt  "
                     perform exe-exp-orf-prt-000
                                          thru exe-exp-orf-prt-999
           else if   rf-num-key-fix       =    "orcndo  "
                     perform exe-exp-orf-ndo-000
                                          thru exe-exp-orf-ndo-999
           else if   rf-num-key-fix       =    "odsprt  "
                     perform exe-exp-ods-prt-000
                                          thru exe-exp-ods-prt-999
           else if   rf-num-key-fix       =    "lotslc  "
                     perform exe-exp-lot-slc-000
                                          thru exe-exp-lot-slc-999
           else if   rf-num-key-fix       =    "numddp  "
                     perform exe-exp-num-ddp-000
                                          thru exe-exp-num-ddp-999
           else if   rf-num-key-fix       =    "numddx  "
                     perform exe-exp-num-ddx-000
                                          thru exe-exp-num-ddx-999
           else if   rf-num-key-fix       =    "numrsd  "
                     perform exe-exp-num-rsd-000
                                          thru exe-exp-num-rsd-999
           else if   rf-num-key-fix       =    "numsdb  "
                     perform exe-exp-num-sdb-000
                                          thru exe-exp-num-sdb-999
           else if   rf-num-key-fix       =    "sfanum  "
                     perform exe-exp-num-sfa-000
                                          thru exe-exp-num-sfa-999
           else if   rf-num-key-fix       =    "sffnum  "
                     perform exe-exp-num-sff-000
                                          thru exe-exp-num-sff-999
           else if   rf-num-key-fix       =    "sfonum  "
                     perform exe-exp-num-sfo-000
                                          thru exe-exp-num-sfo-999
           else if   rf-num-key-fix       =    "sfsnum  "
                     perform exe-exp-num-sfs-000
                                          thru exe-exp-num-sfs-999
           else if   rf-num-key-fix       =    "rdaprt  "
                     perform exe-exp-prt-rda-000
                                          thru exe-exp-prt-rda-999
           else if   rf-num-key-fix       =    "vdpprt  "
                     perform exe-exp-vdp-prt-000
                                          thru exe-exp-vdp-prt-999
           else if   rf-num-key-fix       =    "vdpndo  "
                     perform exe-exp-vdp-ndo-000
                                          thru exe-exp-vdp-ndo-999
______*    else if   rf-num-key-fix       =    "numdst  "
______*              perform exe-exp-num-dst-000
______*                                   thru exe-exp-num-dst-999
           else      go to exe-exp-num-200.
       exe-exp-num-690.
      *              *-------------------------------------------------*
      *              * Composizione carattere di fine record           *
      *              *-------------------------------------------------*
           move      "fr"                 to   w-scr-str-tip          .
           move      w-scr-fso-cfr        to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-num-700.
      *              *-------------------------------------------------*
      *              * Scrittura record in output                      *
      *              *-------------------------------------------------*
           move      w-out-str-out        to   g-rec                  .
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       exe-exp-num-720.
      *              *-------------------------------------------------*
      *              * Incremento numero records scritti               *
      *              *-------------------------------------------------*
           perform   inc-rec-scr-000      thru inc-rec-scr-999        .
       exe-exp-num-750.
      *              *-------------------------------------------------*
      *              * Riciclo a Next su [num]                         *
      *              *-------------------------------------------------*
           go to     exe-exp-num-200.
