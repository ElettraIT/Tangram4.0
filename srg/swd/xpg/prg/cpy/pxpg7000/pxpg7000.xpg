      *    *===========================================================*
      *    * Area [xpg] Ultimo aggiornamento: 20/02/26                 *
      *    *===========================================================*

      *    *===========================================================*
      *    * Esportazione [cat]                                        *
      *    *-----------------------------------------------------------*
       exe-exp-cat-000.
      *              *-------------------------------------------------*
      *              * Preparazione file area generica                 *
      *              *-------------------------------------------------*
           move      "xpg "               to   f-xxx-are              .
           move      "cat "               to   f-xxx-nam              .
           move      "std_xpg_cat"        to   f-xxx-npe              .
      *              *-------------------------------------------------*
      *              * Richiesta di conferma, se manuale               *
      *              *-------------------------------------------------*
           perform   ric-cnf-man-000      thru ric-cnf-man-999        .
      *              *-------------------------------------------------*
      *              * Se non confermato : ad uscita                   *
      *              *-------------------------------------------------*
           if        f-xxx-sts            not  = "S"
                     go to exe-exp-cat-999.
      *              *-------------------------------------------------*
      *              * Eventuali forzature se esecuzione batch         *
      *              *-------------------------------------------------*
           if        w-exe-flg-btc        =    "S"
                     go to exe-exp-cat-010.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-cat-010.
      *              *-------------------------------------------------*
      *              * Numero records letti e scritti a zero           *
      *              *-------------------------------------------------*
           move      zero                 to   f-xxx-nrl              .
           move      zero                 to   f-xxx-nrs              .
       exe-exp-cat-020.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Apertura file personalizzazioni             *
      *                  *---------------------------------------------*
           perform   opn-enc-000          thru opn-enc-999            .
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di output    *
      *                  *---------------------------------------------*
           perform   opn-seq-out-000      thru opn-seq-out-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to exe-exp-cat-100.
      *                  *---------------------------------------------*
      *                  * Se errori                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore sull'input          *
      *                      *-----------------------------------------*
           perform   msg-inp-err-000      thru msg-inp-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-cat-999.
       exe-exp-cat-100.
      *              *-------------------------------------------------*
      *              * Start su [enc]                                  *
      *              *-------------------------------------------------*
           move      "enc "               to   enc-tre                .
           move      spaces               to   enc-cod                .
           move      zero                 to   enc-prg                .
           start     enc   key not less
                           enc-rck
                           invalid key
                           go to exe-exp-cat-800.
       exe-exp-cat-200.
      *              *-------------------------------------------------*
      *              * Read next su [enc]                              *
      *              *-------------------------------------------------*
           read      enc   next
                           with no lock
                           at end
                           go to exe-exp-cat-800.
       exe-exp-cat-300.
      *              *-------------------------------------------------*
      *              * Text max                                        *
      *              *-------------------------------------------------*
           if        enc-tre              not  = "enc "
                     go to exe-exp-cat-800.
       exe-exp-cat-400.
      *              *-------------------------------------------------*
      *              * Sel su [enc]                                    *
      *              *-------------------------------------------------*
       exe-exp-cat-500.
      *              *-------------------------------------------------*
      *              * Incremento numero records letti                 *
      *              *-------------------------------------------------*
           perform   inc-rec-let-000      thru inc-rec-let-999        .
           if        w-exe-flg-brk        not  = spaces
                     go to exe-exp-cat-800.
       exe-exp-cat-550.
      *              *-------------------------------------------------*
      *              * Pulizia preliminare record sequenziale          *
      *              *-------------------------------------------------*
           move      spaces               to   g-rec                  .
       exe-exp-cat-600.
      *              *-------------------------------------------------*
      *              * Composizione record in output                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizio                                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-str-out          .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "iA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Codice                                      *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      enc-cod              to   w-scr-str-ele          .
           move      04                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "AN"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Ultimo codice utilizzato                    *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      enc-num              to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "N "                 to   w-scr-str-tip          .
           move      v-edt                to   w-scr-str-ele          .
           move      13                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "Nf"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-cat-690.
      *              *-------------------------------------------------*
      *              * Composizione carattere di fine record           *
      *              *-------------------------------------------------*
           move      "fr"                 to   w-scr-str-tip          .
           move      w-scr-fso-cfr        to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-cat-700.
      *              *-------------------------------------------------*
      *              * Scrittura record in output                      *
      *              *-------------------------------------------------*
           move      w-out-str-out        to   g-rec                  .
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       exe-exp-cat-720.
      *              *-------------------------------------------------*
      *              * Incremento numero records scritti               *
      *              *-------------------------------------------------*
           perform   inc-rec-scr-000      thru inc-rec-scr-999        .
       exe-exp-cat-750.
      *              *-------------------------------------------------*
      *              * Riciclo a Next su [cat]                         *
      *              *-------------------------------------------------*
           go to     exe-exp-cat-200.
       exe-exp-cat-800.
      *              *-------------------------------------------------*
      *              * Close files                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura del file in output                 *
      *                  *---------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo utilizzato             *
      *                  *---------------------------------------------*
           cancel    "swd/mod/prg/obj/mcvout"                         .
      *                  *---------------------------------------------*
      *                  * Chiusura file personalizzazioni             *
      *                  *---------------------------------------------*
           perform   cls-enc-000          thru cls-enc-999            .
       exe-exp-cat-850.
      *              *-------------------------------------------------*
      *              * Visualizzazione nr records letti e scritti      *
      *              *-------------------------------------------------*
           perform   vis-rec-let-000      thru vis-rec-let-999        .
           perform   vis-rec-scr-000      thru vis-rec-scr-999        .
      *              *-------------------------------------------------*
      *              * Accettazione presa visione                      *
      *              *-------------------------------------------------*
           perform   acc-pre-vis-000      thru acc-pre-vis-999        .
       exe-exp-cat-900.
      *              *-------------------------------------------------*
      *              * Scrittura rullino messaggi                      *
      *              *-------------------------------------------------*
           perform   wrt-rum-msg-000      thru wrt-rum-msg-999        .
       exe-exp-cat-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [prs]                                        *
      *    *-----------------------------------------------------------*
       exe-exp-prs-000.
      *              *-------------------------------------------------*
      *              * Preparazione file area generica                 *
      *              *-------------------------------------------------*
           move      "xpg "               to   f-xxx-are              .
           move      "prs "               to   f-xxx-nam              .
           move      "std_xpg_prs"        to   f-xxx-npe              .
      *              *-------------------------------------------------*
      *              * Richiesta di conferma, se manuale               *
      *              *-------------------------------------------------*
           perform   ric-cnf-man-000      thru ric-cnf-man-999        .
      *              *-------------------------------------------------*
      *              * Se non confermato : ad uscita                   *
      *              *-------------------------------------------------*
           if        f-xxx-sts            not  = "S"
                     go to exe-exp-prs-999.
      *              *-------------------------------------------------*
      *              * Eventuali forzature se esecuzione batch         *
      *              *-------------------------------------------------*
           if        w-exe-flg-btc        =    "S"
                     go to exe-exp-prs-010.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-prs-010.
      *              *-------------------------------------------------*
      *              * Numero records letti e scritti a zero           *
      *              *-------------------------------------------------*
           move      zero                 to   f-xxx-nrl              .
           move      zero                 to   f-xxx-nrs              .
       exe-exp-prs-020.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Apertura file personalizzazioni             *
      *                  *---------------------------------------------*
           perform   opn-prs-000          thru opn-prs-999            .
      *                  *---------------------------------------------*
      *                  * Open generica file sequenziale di output    *
      *                  *---------------------------------------------*
           perform   opn-seq-out-000      thru opn-seq-out-999        .
      *                  *---------------------------------------------*
      *                  * Test se errori                              *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to exe-exp-prs-100.
      *                  *---------------------------------------------*
      *                  * Se errori                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore sull'input          *
      *                      *-----------------------------------------*
           perform   msg-inp-err-000      thru msg-inp-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-prs-999.
       exe-exp-prs-100.
      *              *-------------------------------------------------*
      *              * Start su [prs]                                  *
      *              *-------------------------------------------------*
           move      "prs "               to   prs-tre                .
           move      spaces               to   prs-cod                .
           move      zero                 to   prs-prg                .
           start     prs   key not less
                           prs-rck
                           invalid key
                           go to exe-exp-prs-800.
       exe-exp-prs-200.
      *              *-------------------------------------------------*
      *              * Read next su [auc]                              *
      *              *-------------------------------------------------*
           read      prs    next
                            with no lock
                            at end
                            go to exe-exp-prs-800.
       exe-exp-prs-300.
      *              *-------------------------------------------------*
      *              * Text max                                        *
      *              *-------------------------------------------------*
           if        prs-tre              not  = "prs "
                     go to exe-exp-prs-800.
       exe-exp-prs-400.
      *              *-------------------------------------------------*
      *              * Sel su [prs]                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eliminazione personalizzazioni obsolete     *
      *                  * ___ DA AGGIORNARE ___                       *
      *                  *---------------------------------------------*
           if        prs-cod              =     "pgm/abi[snx]" or
                                                "pgm/bol[snx]" or
                                                "pgm/cdp[snx]" or
                                                "pgm/dcc[snx]" or
                                                "pgm/dcp[snx]" or
                                                "pgm/dtp[snx]" or
                                                "pgm/vdp[snx]" or
                                                "pgm/cdp[snx]"
                     go to exe-exp-prs-200.
           
      *                  *---------------------------------------------*
      *                  * Lettura personalizzazione                   *
      *                  *---------------------------------------------*
           move      "P:"                 to   s-ope                  .
           move      prs-cod              to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su valori letti                        *
      *                  *---------------------------------------------*
           if        s-ves                not  = spaces
                     go to exe-exp-prs-200.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo personalizzazione      *
      *                  *---------------------------------------------*
           move      s-tip                to   w-exe-per-tip          .
           move      spaces               to   w-exe-per-val          .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo personaliz- *
      *                  * zazione                                     *
      *                  *---------------------------------------------*
           move      spaces               to   w-exe-per-val          .
           if        s-tip                =    "A"
                     perform  exe-exp-prs-alf-000
                                          thru exe-exp-prs-alf-999
           else if   s-tip                =    "D"
                     perform  exe-exp-prs-dat-000
                                          thru exe-exp-prs-dat-999
           else if   s-tip                =    "N"
                     perform  exe-exp-prs-num-000
                                          thru exe-exp-prs-num-999    .
       exe-exp-prs-500.
      *              *-------------------------------------------------*
      *              * Incremento numero records letti                 *
      *              *-------------------------------------------------*
           perform   inc-rec-let-000      thru inc-rec-let-999        .
           if        w-exe-flg-brk        not  = spaces
                     go to exe-exp-prs-800.
       exe-exp-prs-550.
      *              *-------------------------------------------------*
      *              * Pulizia preliminare record sequenziale          *
      *              *-------------------------------------------------*
           move      spaces               to   g-rec                  .
       exe-exp-prs-600.
      *              *-------------------------------------------------*
      *              * Composizione record in output                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizio                                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-str-out          .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "iA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Codice                                      *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      prs-cod              to   w-scr-str-ele          .
           move      40                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "AA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Tipo                                        *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      w-exe-per-tip        to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "AA"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Valore alfanumerico                         *
      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
           move      w-exe-per-val        to   w-scr-str-ele          .
           move      80                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "Af"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-prs-690.
      *              *-------------------------------------------------*
      *              * Composizione carattere di fine record           *
      *              *-------------------------------------------------*
           move      "fr"                 to   w-scr-str-tip          .
           move      w-scr-fso-cfr        to   w-scr-str-ele          .
           move      01                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
       exe-exp-prs-700.
      *              *-------------------------------------------------*
      *              * Scrittura record in output                      *
      *              *-------------------------------------------------*
           move      w-out-str-out        to   g-rec                  .
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       exe-exp-prs-720.
      *              *-------------------------------------------------*
      *              * Incremento numero records scritti               *
      *              *-------------------------------------------------*
           perform   inc-rec-scr-000      thru inc-rec-scr-999        .
       exe-exp-prs-750.
      *              *-------------------------------------------------*
      *              * Riciclo a Next su [prs]                         *
      *              *-------------------------------------------------*
           go to     exe-exp-prs-200.
       exe-exp-prs-800.
      *              *-------------------------------------------------*
      *              * Close files                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura del file in output                 *
      *                  *---------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo utilizzato             *
      *                  *---------------------------------------------*
           cancel    "swd/mod/prg/obj/mcvout"                         .
      *                  *---------------------------------------------*
      *                  * Chiusura file personalizzazioni             *
      *                  *---------------------------------------------*
           perform   cls-prs-000          thru cls-prs-999            .
       exe-exp-prs-850.
      *              *-------------------------------------------------*
      *              * Visualizzazione nr records letti e scritti      *
      *              *-------------------------------------------------*
           perform   vis-rec-let-000      thru vis-rec-let-999        .
           perform   vis-rec-scr-000      thru vis-rec-scr-999        .
      *              *-------------------------------------------------*
      *              * Accettazione presa visione                      *
      *              *-------------------------------------------------*
           perform   acc-pre-vis-000      thru acc-pre-vis-999        .
       exe-exp-prs-900.
      *              *-------------------------------------------------*
      *              * Scrittura rullino messaggi                      *
      *              *-------------------------------------------------*
           perform   wrt-rum-msg-000      thru wrt-rum-msg-999        .
       exe-exp-prs-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [prs]                                        *
      *    *                                                           *
      *    * Personalizzazione alfanumerica                            *
      *    *-----------------------------------------------------------*
       exe-exp-prs-alf-000.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      s-alf                to   w-exe-per-val          .
       exe-exp-prs-alf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-prs-alf-999.
       exe-exp-prs-alf-999.
           exit.

      *    *===========================================================*
      *    * Esportazione [prs]                                        *
      *    *                                                           *
      *    * Personalizzazione numerica                                *
      *    *-----------------------------------------------------------*
       exe-exp-prs-num-000.
      *              *-------------------------------------------------*
      *              * Editing valore numerico                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      s-num                to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      v-edt                to   w-exe-per-val          .
       exe-exp-prs-num-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-prs-num-999.
       exe-exp-prs-num-999.
           exit.

