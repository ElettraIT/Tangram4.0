      *              *-------------------------------------------------*
           move      spaces               to   g-rec                  .
       exe-exp-zpx-600.
      *              *-------------------------------------------------*
      *              * Composizione record in output                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-ctr-001          .
       exe-exp-zpx-620.
           add       1                    to   w-exe-ctr-001          .
           if        w-exe-ctr-001        >    06
                     go to exe-exp-zpx-750.
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
           if        w-exe-scg-zpv        =    01
                if   rf-zpx-spd-sco
                    (w-exe-ctr-001, 01)   =    zero and
                     rf-zpx-spd-scu
                    (w-exe-ctr-001)       =    zero and
                     rf-zpx-spd-pvg
                    (w-exe-ctr-001, 01)   =    zero
                     go to exe-exp-zpx-620.
           if        w-exe-scg-zpv        =    02
                if   rf-zpx-spi-sco
                    (w-exe-ctr-001, 01)   =    zero and
                     rf-zpx-spi-scu
                    (w-exe-ctr-001)       =    zero and
                     rf-zpx-spi-pvg
                    (w-exe-ctr-001, 01)   =    zero
                     go to exe-exp-zpx-620.
      *                  *---------------------------------------------*
      *                  * Inizio                                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-out-str-out          .
      *                  *---------------------------------------------*
      *                  * Tipo incrocio                              *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-zpx-tip-inc       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "N "                 to   w-scr-str-tip          .
           move      v-edt                to   w-scr-str-ele          .
           move      02                   to   w-scr-lun-ele          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * S-e-p-a-r-a-t-o-r-i                         *
      *                  *---------------------------------------------*
           move      "NN"                 to   w-scr-str-tip          .
           perform   cmp-sng-fld-000      thru cmp-sng-fld-999        .
      *                  *---------------------------------------------*
      *                  * Codice uno                                  *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-zpx-cod-uno       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "N "                 to   w-scr-str-tip          .
           move      v-edt                to   w-scr-str-ele          .
           move      05                   to   w-scr-lun-ele          .
