      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-zpx-800.
       exe-exp-zpx-200.
      *              *-------------------------------------------------*
      *              * Next su [zpx]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofzpx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpx                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a close file                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-zpx-800.
       exe-exp-zpx-300.
      *              *-------------------------------------------------*
