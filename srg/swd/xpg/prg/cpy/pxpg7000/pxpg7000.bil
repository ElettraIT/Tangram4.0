      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-vbv-999.
       exe-exp-vbv-100.
      *              *-------------------------------------------------*
      *              * Start su file [vbv]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATVDB    "         to   f-key                  .
           move      spaces               to   rf-vbv-tip-bil         .
           move      zero                 to   rf-vbv-dat-bil         .
           move      zero                 to   rf-vbv-vdb-lv1         .
           move      zero                 to   rf-vbv-vdb-lv2         .
           move      zero                 to   rf-vbv-vdb-lv3         .
