           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-bit-prt-fti       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
