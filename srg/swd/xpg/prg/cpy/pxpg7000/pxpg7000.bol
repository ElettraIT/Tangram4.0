           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-bie-cod-dpz       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
