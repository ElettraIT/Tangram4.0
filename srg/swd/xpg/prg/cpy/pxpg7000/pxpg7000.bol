                    (1 : 8)               to   w-det-tot-inc-alf      .
      *                      *-----------------------------------------*
      *                      * Eliminazione eventuali virgole          *
      *                      *-----------------------------------------*
           inspect   w-det-tot-inc-alf
                                     replacing all "," 
                                               by  " "                .
      *                      *-----------------------------------------*
      *                      * Conversione incassato                   *
      *                      *-----------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      08                   to   v-car                  .
           move      w-det-tot-inc-alf    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-tot-inc-tot      .
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "9"                  to   v-edm                  .
______*    move      rf-bit-tot-rsc       to   v-num                  .
