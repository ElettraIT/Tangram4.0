           move      "N"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-lst-prz-lst       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
