      *                  *---------------------------------------------*
           move      "A "                 to   w-scr-str-tip          .
      *
           if        rf-zpg-tip-pag       =    01
                     move  "MP01"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    02
                     move  "MP12"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    03
                     move  "MP12"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    04
                     move  "MP19"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    05
                     move  "MP13"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    06
                     move  "MP09"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    07
                     move  "MP05"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    08
                     move  "MP18"         to   w-scr-str-ele
           else if   rf-zpg-tip-pag       =    09
                     move  "MP12"         to   w-scr-str-ele
