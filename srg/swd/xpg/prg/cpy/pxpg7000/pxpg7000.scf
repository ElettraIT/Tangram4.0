           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rf-sfs-num-scf       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
