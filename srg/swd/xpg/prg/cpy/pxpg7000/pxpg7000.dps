                                         using s                      .
           call      s-pat               using f
                                               rf-zs3                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a close file                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-exp-zs3-800.
       exe-exp-zs3-300.
