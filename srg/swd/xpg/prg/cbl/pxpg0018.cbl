      *    *===========================================================*
      *    * Accettazione campo : Indirizzo mail destinatario          *
      *    *-----------------------------------------------------------*
       acc-ind-eml-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-ind-eml-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-ind-eml-ope      .
           move      rr-pth-inp           to   w-cod-ind-eml-ind      .
           move      05                   to   w-cod-ind-eml-lin      .
           move      30                   to   w-cod-ind-eml-pos      .
           move      06                   to   w-cod-ind-eml-dln      .
           move      30                   to   w-cod-ind-eml-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-ind-eml-cll-000  thru cod-ind-eml-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-ind-eml-foi-000  thru cod-ind-eml-foi-999    .
       acc-ind-eml-110.
           perform   cod-ind-eml-cll-000  thru cod-ind-eml-cll-999    .
           if        w-cod-ind-eml-ope    =    "F+"
                     go to acc-ind-eml-115.
           if        w-cod-ind-eml-ope    =    "AC"
                     go to acc-ind-eml-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ind-eml-115.
           perform   cod-ind-eml-foi-000  thru cod-ind-eml-foi-999    .
           go to     acc-ind-eml-110.
       acc-ind-eml-120.
           move      w-cod-ind-eml-ind    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-ind-eml-999.
       acc-ind-eml-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   rr-pth-inp             .
       acc-ind-eml-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore mancante                     *
      *                  *---------------------------------------------*
           if        rr-pth-inp           not  = spaces
                     go to acc-ind-eml-410.
           if        v-key                =    "UP  "
                     go to acc-ind-eml-999.
           go to     acc-ind-eml-100.
       acc-ind-eml-410.
      *                  *---------------------------------------------*
      *                  * Se valore presente                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test che non ci siano blanks embedded   *
      *                      *-----------------------------------------*
           move      rr-pth-inp           to   w-all-str-alf          .
           move      40                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-ind-eml-100.
      *                      *-----------------------------------------*
      *                      * Test che ci sia un carattere '@'        *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-i01          .
           inspect   rr-pth-inp       tallying w-all-str-i01
                                     for all   "@"                    .
           if        w-all-str-i01        not  = 01
                     go to acc-ind-eml-100.
      *                      *-----------------------------------------*
      *                      * Test che ci siano caratteri '.'         *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-i01          .
           inspect   rr-pth-inp       tallying w-all-str-i01
                                     for all   "."                    .
           if        w-all-str-i01        not  > zero
                     go to acc-ind-eml-100.
      *                      *-----------------------------------------*
      *                      * Test che non ci siano caratteri '"'     *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-i01          .
           inspect   rr-pth-inp       tallying w-all-str-i01
                                     for all   """"                   .
           if        w-all-str-i01        >    zero
                     go to acc-ind-eml-100.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-ind-eml-600.
       acc-ind-eml-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ind-eml-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
