           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe          *
      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Find su lista PDF dell-utente                             *
      *    *-----------------------------------------------------------*
       fnd-lst-pdf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-pdf-fnd-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-pdf-fnd-crb      .
       fnd-lst-pdf-100.
      *              *-------------------------------------------------*
      *              * Apertura del file temporaneo                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Open                                        *
      *                  *---------------------------------------------*
           move      "OI"                 to   g-ope                  .
           move      "pdf "               to   g-nam                  .
           move      f-xxx-ppb            to   g-pat                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Se errore : uscita con flag di errore       *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to fnd-lst-pdf-200.
      *                  *---------------------------------------------*
      *                  * Chiusura del file in input                  *
      *                  *---------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo utilizzato             *
      *                  *---------------------------------------------*
           cancel    "swd/mod/prg/obj/mcvinp"                         .
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "N"                  to   w-buf-pdf-fnd-flg      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     fnd-lst-pdf-999.
       fnd-lst-pdf-200.
      *              *-------------------------------------------------*
      *              * Read file sequenziale                           *
      *              *-------------------------------------------------*
           move      "GN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Se fine file : uscita con flag              *
      *                  *---------------------------------------------*
           if        g-sts                not  = e-not-err
                     go to fnd-lst-pdf-500.
       fnd-lst-pdf-300.
      *              *-------------------------------------------------*
      *              * Incremento numero records nel buffer            *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-pdf-fnd-crb      .
      *              *-------------------------------------------------*
      *              * Test se buffer oltre il numero previsto         *
      *              *-------------------------------------------------*
           if        w-buf-pdf-fnd-crb    >    w-buf-pdf-fnd-max
                     move  w-buf-pdf-fnd-max
                                          to   w-buf-pdf-fnd-crb
                     go to fnd-lst-pdf-500.
       fnd-lst-pdf-400.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
           move      g-rec                to   w-buf-pdf-fnd-pdf
                                              (w-buf-pdf-fnd-crb)     .
       fnd-lst-pdf-420.
      *              *-------------------------------------------------*
      *              * A riciclo                                       *
      *              *-------------------------------------------------*
           go to     fnd-lst-pdf-200.
       fnd-lst-pdf-500.
      *              *-------------------------------------------------*
      *              * Operazioni di controllo                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo numero records letti con lo stes- *
      *                  * so valore                                   *
      *                  *---------------------------------------------*
           if        w-buf-pdf-fnd-crb    =    zero
                     go to fnd-lst-pdf-999.
      *                      *-----------------------------------------*
      *                      * Determinazione numero pagine nel buffer *
      *                      *-----------------------------------------*
           move      w-buf-pdf-fnd-crb    to   w-buf-pdf-fnd-cpb      .
           subtract  1                    from w-buf-pdf-fnd-cpb      .
           divide    6                    into w-buf-pdf-fnd-cpb      .
           add       1                    to   w-buf-pdf-fnd-cpb      .
      *                      *-----------------------------------------*
      *                      * Inizializzazione numero record nel buf- *
      *                      * fer attualmente trattato                *
      *                      *-----------------------------------------*
           move      1                    to   w-buf-pdf-fnd-c01      .
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione box vuoto               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      "                  STAMPE 'PDF' DISPONIBILI        
      -              "          "         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura fincatura                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura di chiusura              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione pagina video contenente *
      *                      * il record attualmente trattato          *
      *                      *-----------------------------------------*
           perform   fnd-lst-pdf-950      thru fnd-lst-pdf-959        .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       fnd-lst-pdf-550.
      *                      *-----------------------------------------*
      *                      * Determinazione numero linea a video     *
      *                      *-----------------------------------------*
           move      w-buf-pdf-fnd-c01    to   w-buf-pdf-fnd-nli      .
       fnd-lst-pdf-555.
           if        w-buf-pdf-fnd-nli    >    6
                     subtract  6          from w-buf-pdf-fnd-nli
                     go to fnd-lst-pdf-555.
      *                          *-------------------------------------*
      *                          * Incremento numero linea a video     *
      *                          * per posizionamento verticale        *
      *                          *-------------------------------------*
           add       06                   to   w-buf-pdf-fnd-nli      .
       fnd-lst-pdf-560.
      *                      *-----------------------------------------*
      *                      * Espansione record attualmente trattato  *
      *                      *-----------------------------------------*
       fnd-lst-pdf-575.
      *                      *-----------------------------------------*
      *                      * Accettazione del mark-point             *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      spaces               to   v-ufk                  .
           if        w-buf-pdf-fnd-c01    >    1
                     move  "UP  "         to   v-pfk (01)             .
           if        w-buf-pdf-fnd-c01    <    w-buf-pdf-fnd-crb
                     move  "DOWN"         to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-buf-pdf-fnd-cpa    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           if        w-buf-pdf-fnd-cpa    <    w-buf-pdf-fnd-cpb
                     move  "NXSC"         to   v-pfk (08)             .
           move      "SLCT"               to   v-pfk (10)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-buf-pdf-fnd-nli    to   v-lin                  .
           move      11                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       fnd-lst-pdf-580.
           if        v-key                =    spaces or
                     v-key                =    "DO  " or
                     v-key                =    "SLCT"
                     go to fnd-lst-pdf-582
           else if   v-key                =    "UP  "
                     go to fnd-lst-pdf-584
           else if   v-key                =    "DOWN"
                     go to fnd-lst-pdf-586
           else if   v-key                =    "EXIT"
                     go to fnd-lst-pdf-598
           else if   v-key                =    "NXSC"
                     go to fnd-lst-pdf-592
           else if   v-key                =    "PRSC"
                     go to fnd-lst-pdf-594
           else      go to fnd-lst-pdf-575.
       fnd-lst-pdf-582.
      *              *-------------------------------------------------*
      *              * Se spaces, Do o select                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori selezionati           *
      *                  *---------------------------------------------*
           move      w-buf-pdf-fnd-pdf
                    (w-buf-pdf-fnd-c01)
                    (01 : 40)             to   rr-pth-all             .
      *                  *---------------------------------------------*
      *                  * Preparazione flag di uscita                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-buf-pdf-fnd-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     fnd-lst-pdf-999.
       fnd-lst-pdf-584.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           subtract  1                    from w-buf-pdf-fnd-c01      .
           if        w-buf-pdf-fnd-nli    =    07
                     go to fnd-lst-pdf-590
           else      go to fnd-lst-pdf-550.
       fnd-lst-pdf-586.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        w-buf-pdf-fnd-c01    <    w-buf-pdf-fnd-crb
                     add   1              to   w-buf-pdf-fnd-c01
                     go to fnd-lst-pdf-588
           else      go to fnd-lst-pdf-575.
       fnd-lst-pdf-588.
           if        w-buf-pdf-fnd-nli    =    12
                     go to fnd-lst-pdf-590
           else      go to fnd-lst-pdf-550.
       fnd-lst-pdf-590.
           perform   fnd-lst-pdf-950      thru fnd-lst-pdf-959        .
           go to     fnd-lst-pdf-550.
       fnd-lst-pdf-592.
      *              *-------------------------------------------------*
      *              * Se Next screen                                  *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-pdf-fnd-cpa      .
           go to     fnd-lst-pdf-596.
       fnd-lst-pdf-594.
      *              *-------------------------------------------------*
      *              * Se Previous screen                              *
      *              *-------------------------------------------------*
           subtract  1                    from w-buf-pdf-fnd-cpa      .
       fnd-lst-pdf-596.
           move      w-buf-pdf-fnd-cpa    to   w-buf-pdf-fnd-c01      .
           multiply  6                    by   w-buf-pdf-fnd-c01      .
           subtract  5                    from w-buf-pdf-fnd-c01      .
           go to     fnd-lst-pdf-590.
       fnd-lst-pdf-598.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di selezione                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-buf-pdf-fnd-fds      .
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       fnd-lst-pdf-800.
      *              *-------------------------------------------------*
      *              * Chiusura del file in input                      *
      *              *-------------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvinp"
                                         using g                      .
      *              *-------------------------------------------------*
      *              * Cancellazione modulo utilizzato                 *
      *              *-------------------------------------------------*
           cancel    "swd/mod/prg/obj/mcvinp"                         .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fnd-lst-pdf-999.
       fnd-lst-pdf-950.
      *              *=================================================*
      *              * Visualizzazione pagina video contenente il re-  *
      *              * cord attualmente trattato                       *
      *              *-------------------------------------------------*
           move      w-buf-pdf-fnd-c01    to   w-buf-pdf-fnd-c02      .
           add       5                    to   w-buf-pdf-fnd-c02      .
           divide    6                    into w-buf-pdf-fnd-c02      .
           move      w-buf-pdf-fnd-c02    to   w-buf-pdf-fnd-cpa      .
           subtract  1                    from w-buf-pdf-fnd-c02      .
           multiply  6                    by   w-buf-pdf-fnd-c02      .
           add       1                    to   w-buf-pdf-fnd-c02      .
           add       5
                     w-buf-pdf-fnd-c02  giving w-buf-pdf-fnd-c03      .
           move      w-buf-pdf-fnd-c03    to   w-buf-pdf-fnd-c04      .
           if        w-buf-pdf-fnd-c03    >    w-buf-pdf-fnd-crb
                     move  w-buf-pdf-fnd-crb
                                          to   w-buf-pdf-fnd-c03      .
           move      07                   to   w-buf-pdf-fnd-c05      .
       fnd-lst-pdf-951.
      *                  *---------------------------------------------*
      *                  * File PDF                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      w-buf-pdf-fnd-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      w-buf-pdf-fnd-pdf
                    (w-buf-pdf-fnd-c02)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Incremento contatori                        *
      *                  *---------------------------------------------*
           add       1                    to   w-buf-pdf-fnd-c02      .
           add       1                    to   w-buf-pdf-fnd-c05      .
           if        w-buf-pdf-fnd-c02    not  > w-buf-pdf-fnd-c03
                     go to fnd-lst-pdf-951.
       fnd-lst-pdf-952.
           if        w-buf-pdf-fnd-c02    >    w-buf-pdf-fnd-c04
                     go to fnd-lst-pdf-955.
           if        w-buf-pdf-fnd-crb    not  > 6
                     go to fnd-lst-pdf-955.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      w-buf-pdf-fnd-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           add       1                    to   w-buf-pdf-fnd-c02      .
           add       1                    to   w-buf-pdf-fnd-c05      .
           go to     fnd-lst-pdf-952.
       fnd-lst-pdf-955.
      *                  *---------------------------------------------*
      *                  * Literal 'pagina'                            *
      *                  *---------------------------------------------*
           move      w-buf-pdf-fnd-cpa    to   w-buf-pdf-fnd-lt1      .
           move      w-buf-pdf-fnd-cpb    to   w-buf-pdf-fnd-lt2      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      33                   to   v-pos                  .
           move      w-buf-pdf-fnd-ltp    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       fnd-lst-pdf-959.
           exit.
       fnd-lst-pdf-999.
           exit.

