      *                  *---------------------------------------------*
           if        w-acc-chr-int        not  = zero or
                     w-acc-chr-dec        not  = zero
                     go to acc-chr-dac-855.
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione ultimo carattere valido   *
      *                  *---------------------------------------------*
           perform   vis-chr-uci-000      thru vis-chr-uci-999        .
      *                  *---------------------------------------------*
      *                  * Ad accettazione                             *
      *                  *---------------------------------------------*
           go to     acc-chr-dac-100.
       acc-chr-dac-855.
      *                  *---------------------------------------------*
      *                  * Operazioni comuni                           *
      *                  *---------------------------------------------*
           perform   acc-chr-ocm-000      thru acc-chr-ocm-999        .
      *                  *---------------------------------------------*
      *                  * Come per Totale                             *
      *                  *---------------------------------------------*
           go to     acc-chr-dac-820.
       acc-chr-dac-860.
      *                  *=============================================*
      *                  * 'M' o 'm' : Memorizzazione totale           *
      *                  *---------------------------------------------*
       acc-chr-dac-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-chr-dac-999.
       acc-chr-dac-999.
           exit.

      *    *===========================================================*
      *    * Reset generale                                            *
      *    *-----------------------------------------------------------*
       acc-chr-rsg-000.
           move      19                   to   w-acc-chr-mca          .
           move      zero                 to   w-acc-chr-cch          .
           move      zero                 to   w-acc-chr-nsa          .
           move      zero                 to   w-acc-chr-dec          .
           move      zero                 to   w-acc-chr-int          .
           move      zero                 to   w-acc-chr-num          .
           move      zero                 to   w-acc-chr-tot          .
           move      spaces               to   w-acc-chr-alf          .
           move      spaces               to   w-acc-chr-nal          .
           move      spaces               to   w-acc-chr-ali          .
           move      spaces               to   w-acc-chr-uci          .
           move      spaces               to   w-acc-chr-ope          .
           move      spaces               to   w-acc-chr-fio          .
      *              *-------------------------------------------------*
      *              * Normalizzazione buffer                          *
      *              *-------------------------------------------------*
           move      zero                 to   w-acc-chr-ctr          .
           move      zero                 to   w-acc-chr-inx          .
       acc-chr-rsg-200.
           add       1                    to   w-acc-chr-inx          .
           if        w-acc-chr-inx        >    w-acc-chr-max
                     go to acc-chr-rsg-999.
           move      zero                 to   w-acc-chr-bnu
                                              (w-acc-chr-inx)         .
           move      spaces               to   w-acc-chr-bop
                                              (w-acc-chr-inx)         .
           go to     acc-chr-rsg-200.
       acc-chr-rsg-999.
           exit.

      *    *===========================================================*
      *    * Reset valori                                              *
      *    *-----------------------------------------------------------*
       acc-chr-rst-000.
           move      spaces               to   w-acc-chr-fio          .
           move      spaces               to   w-acc-chr-ope          .
           move      spaces               to   w-acc-chr-alf          .
           move      spaces               to   w-acc-chr-nal          .
           move      zero                 to   w-acc-chr-num          .
           move      zero                 to   w-acc-chr-int          .
           move      zero                 to   w-acc-chr-dec          .
           move      zero                 to   w-acc-chr-nsa          .
           move      zero                 to   w-acc-chr-cch          .
       acc-chr-rst-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione valori                                    *
      *    *-----------------------------------------------------------*
       acc-chr-bva-000.
           if        w-acc-chr-ctr        <    w-acc-chr-max
                     add   1              to   w-acc-chr-ctr
                     move  w-acc-chr-num  to   w-acc-chr-bnu
                                              (w-acc-chr-ctr)
                     move  w-acc-chr-ope  to   w-acc-chr-bop
                                              (w-acc-chr-ctr)         .
       acc-chr-bva-999.
           exit.

      *    *===========================================================*
      *    * Scansione del buffer per determinazione totali            *
      *    *-----------------------------------------------------------*
       acc-chr-sbt-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-acc-chr-ctr        =    1
                     move  w-acc-chr-num  to   w-acc-chr-tot
                     go to acc-chr-sbt-900.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      w-acc-chr-num        to   w-acc-chr-n01          .
           move      w-acc-chr-tot        to   w-acc-chr-n02          .
           move      zero                 to   w-acc-chr-n03          .
           move      "+"                  to   w-acc-chr-opp          .
      *              *-------------------------------------------------*
      *              * Inizio scansione                                *
      *              *-------------------------------------------------*
           move      zero                 to   w-acc-chr-inx          .
       acc-chr-sbt-200.
           add       1                    to   w-acc-chr-inx          .
           if        w-acc-chr-inx        >    w-acc-chr-ctr
                     go to acc-chr-sbt-900.
           if        w-acc-chr-inx        >    w-acc-chr-max
                     go to acc-chr-sbt-900.
           if        w-acc-chr-bop
                    (w-acc-chr-inx)       =    spaces
                     go to acc-chr-sbt-200.
       acc-chr-sbt-300.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore numerico                 *
      *              *-------------------------------------------------*
           move      w-acc-chr-bnu
                    (w-acc-chr-inx)       to   w-acc-chr-n01          .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione dell'operatore           *
      *              *-------------------------------------------------*
           if        w-acc-chr-opp        =    "+"
                     go to acc-chr-sbt-400
           else if   w-acc-chr-opp        =    "-"
                     go to acc-chr-sbt-450
           else if   w-acc-chr-opp        =    "*"
                     go to acc-chr-sbt-500
           else if   w-acc-chr-opp        =    "/"
                     go to acc-chr-sbt-550
           else      go to acc-chr-sbt-200.
       acc-chr-sbt-400.
      *              *-------------------------------------------------*
      *              * Somma (+)                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           add       w-acc-chr-n01        to   w-acc-chr-n02
                                        giving w-acc-chr-n03          .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-chr-sbt-800.
       acc-chr-sbt-450.
      *              *-------------------------------------------------*
      *              * Sottrazione (-)                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           subtract  w-acc-chr-n01        from w-acc-chr-n02
                                        giving w-acc-chr-n03          .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-chr-sbt-800.
       acc-chr-sbt-500.
      *              *-------------------------------------------------*
      *              * Moltiplicazione (*)                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  w-acc-chr-n02        by   w-acc-chr-n01
                                        giving w-acc-chr-n03          .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-chr-sbt-800.
       acc-chr-sbt-550.
      *              *-------------------------------------------------*
      *              * Divisione (/)                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           divide    w-acc-chr-n02        by   w-acc-chr-n01
                                        giving w-acc-chr-n03          .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-chr-sbt-800.
       acc-chr-sbt-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento operatore precedente              *
      *              *-------------------------------------------------*
           move      w-acc-chr-bop
                    (w-acc-chr-inx)       to   w-acc-chr-opp          .
      *              *-------------------------------------------------*
      *              * Comodo calcolato in totale                      *
      *              *-------------------------------------------------*
           move      w-acc-chr-n03        to   w-acc-chr-tot          .
       acc-chr-sbt-850.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     acc-chr-sbt-200.
       acc-chr-sbt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-chr-sbt-999.
       acc-chr-sbt-999.
           exit.

      *    *===========================================================*
      *    * Serie di operazioni comuni per terminatori speciali       *
      *    *-----------------------------------------------------------*
       acc-chr-ocm-000.
      *              *-------------------------------------------------*
      *              * Operazioni comuni                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione operatore                   *
      *                  *---------------------------------------------*
           move      w-acc-chr-opw        to   w-acc-chr-ope          .
      *                  *---------------------------------------------*
      *                  * Conversione della stringa fin qui accettata *
      *                  *---------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      w-acc-chr-mca        to   v-car                  .
           move      w-acc-chr-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-acc-chr-num          .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore e operatore          *
      *                  *---------------------------------------------*
           perform   acc-chr-bva-000      thru acc-chr-bva-999        .
      *                  *---------------------------------------------*
      *                  * Contatore elementi impostati                *
      *                  *---------------------------------------------*
           perform   vis-chr-nvi-000      thru vis-chr-nvi-999        .
      *                  *---------------------------------------------*
      *                  * Scansione del buffer per determinare totale *
      *                  *---------------------------------------------*
           perform   acc-chr-sbt-000      thru acc-chr-sbt-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione operatore impostato         *
      *                  *---------------------------------------------*
           perform   vis-chr-ope-000      thru vis-chr-ope-999        .
      *                  *---------------------------------------------*
      *                  * Nuovo elemento                              *
      *                  *---------------------------------------------*
           move      w-acc-chr-alw        to   w-acc-chr-alf          .
      *                  *---------------------------------------------*
      *                  * Operatore come per Totale                   *
      *                  *---------------------------------------------*
           move      "="                  to   w-acc-chr-ali          .
       acc-chr-ocm-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-chr-ocm-999.
       acc-chr-ocm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione stringa bufferizzata                      *
      *    *-----------------------------------------------------------*
       vis-chr-alf-000.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-acc-chr-mca        to   v-car                  .
           move      08                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-acc-chr-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-chr-alf-200.
      *              *-------------------------------------------------*
      *              * L'ultimo carattere viene bufferizzato           *
      *              *-------------------------------------------------*
           move      w-acc-chr-alf
                    (w-acc-chr-mca : 1)   to   w-acc-chr-uci          .
       vis-chr-alf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione ultimo valore impostato                   *
      *    *-----------------------------------------------------------*
       vis-chr-num-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-acc-chr-mca        to   v-car                  .
           move      10                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-acc-chr-nal        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-chr-num-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione ultimo carattere impostato                *
      *    *-----------------------------------------------------------*
       vis-chr-uci-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      w-acc-chr-uci        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-chr-uci-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione operatore impostato                       *
      *    *-----------------------------------------------------------*
       vis-chr-ope-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      48                   to   v-pos                  .
           move      w-acc-chr-ope        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-chr-ope-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione numero valori impostati                   *
      *    *-----------------------------------------------------------*
       vis-chr-nvi-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      10                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-acc-chr-ctr        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-chr-nvi-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-999.
           exit.
           
      *    *===========================================================*
      *    * Normalizzazione dati chiave e non chiave                  *
      *    *-----------------------------------------------------------*
       nor-key-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati chiave                     *
      *              *-------------------------------------------------*
           perform   nor-key-reg-000      thru nor-key-reg-999        .
       nor-key-nok-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave                               *
      *    *-----------------------------------------------------------*
       nor-key-reg-000.
      *              *-------------------------------------------------*
      *              * Reset generale                                  *
      *              *-------------------------------------------------*
           perform   acc-chr-rsg-000      thru acc-chr-rsg-999        .
       nor-key-reg-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione di una stampa, in foreground, inclusa in un    *
      *    * programma non dedicato alla sola stampa                   *
      *    *                                                           *
      *    * Prerequisiti :                                            *
      *    *                                                           *
      *    * - Se la stampa prevede un sort, devono esistere :         *
      *    *                                                           *
      *    *   - L'Input-Output Section per il file [srt]              *
      *    *   - La File Section per il file [srt] con il suo record   *
      *    *                                                           *
      *    * - In ogni caso devono esistere in Working-Storage :       *
      *    *                                                           *
      *    *   - L'area di comunicazione per modulo 'mpslct'           *
      *    *   - L'area di comunicazione per modulo 'mbckgx'           *
      *    *   - L'area di comunicazione per modulo 'mmessg'           *
      *    *   - L'area di comunicazione per modulo 'mprint'           *
      *    *                                                           *
      *    *   - La work-area di controllo sub-funzione di stampa      *
      *    *   - La work-area per controllo rotture di livello         *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       stp-frg-inc-000.
      *              *-------------------------------------------------*
      *              * Flag di stampa effettivamente eseguita a : No   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-stp-frg-inc-flg      .
      *              *-------------------------------------------------*
      *              * Open files per sub-funzione di stampa, con u-   *
      *              * scita in caso di errore                         *
      *              *-------------------------------------------------*
           perform   opn-fls-stp-000      thru opn-fls-stp-999        .
           if        w-stp-opn-fls-stp    not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Preparazione defaults per parametri di selezio- *
      *              * ne stampa                                       *
      *              *-------------------------------------------------*
           perform   pre-prm-stp-000      thru pre-prm-stp-999        .
      *              *-------------------------------------------------*
      *              * Selezione parametri stampa, con uscita in caso  *
      *              * di mancata selezione                            *
      *              *-------------------------------------------------*
           perform   sel-prm-stp-000      thru sel-prm-stp-999        .
           if        w-stp-sel-prm-stp    not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Inizializzazione rullino messaggi di foreground *
      *              * con uscita in caso di errore                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
            if       m-rsc                not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Lettura parametri di selezione stampa, con u-   *
      *              * scita in caso di errore                         *
      *              *-------------------------------------------------*
           perform   let-sel-stp-000      thru let-sel-stp-999        .
           if        w-stp-let-sel-stp    not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Esecuzione eventuale sort preliminare           *
      *              *-------------------------------------------------*
           perform   exe-srt-stp-000      thru exe-srt-stp-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se sort eseguito           *
      *              *-------------------------------------------------*
           if        w-stp-exe-srt-stp    =    spaces
                     go to stp-frg-inc-400
           else      go to stp-frg-inc-500.
       stp-frg-inc-400.
      *              *-------------------------------------------------*
      *              * Se sort non eseguito                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di report-program                     *
      *                  *---------------------------------------------*
           perform   prn-rou-pri-000      thru prn-rou-pri-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     stp-frg-inc-600.
       stp-frg-inc-500.
      *              *-------------------------------------------------*
      *              * Se sort eseguito                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     stp-frg-inc-600.
       stp-frg-inc-600.
      *              *-------------------------------------------------*
      *              * Cancellazione modulo stampa                     *
      *              *-------------------------------------------------*
           cancel    "swd/mod/prg/obj/mprint"                         .
       stp-frg-inc-900.
      *              *-------------------------------------------------*
      *              * Visualizzazione eventuali errori di esecuzione  *
      *              *-------------------------------------------------*
           move      "VE"                 to   b-ope                  .
           move      "F"                  to   b-tfe                  .
           move      i-ide-des            to   b-chr                  .
           call      "swd/mod/prg/obj/mbckgv"
                                         using b                      .
           cancel    "swd/mod/prg/obj/mbckgv"                         .
       stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Close files per sub-funzione di stampa          *
      *              *-------------------------------------------------*
           perform   cls-fls-stp-000      thru cls-fls-stp-999        .
       stp-frg-inc-999.
           exit.

      *    *===========================================================*
      *    *  Selezione parametri stampa, per sub-funzione di stampa   *
      *    *-----------------------------------------------------------*
       sel-prm-stp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-sel-prm-stp      .
      *              *-------------------------------------------------*
      *              * Preparazione parametri per richiamo selezione   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Informazioni generali da segreteria         *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Codice azienda                          *
      *                      *-----------------------------------------*
           move      s-azi                to   r-env-cod-azi          .
      *                      *-----------------------------------------*
      *                      * Codice terminale                        *
      *                      *-----------------------------------------*
           move      s-ter                to   r-env-cod-ter          .
      *                      *-----------------------------------------*
      *                      * Codice utente                           *
      *                      *-----------------------------------------*
           move      s-ute                to   r-env-cod-ute          .
      *                      *-----------------------------------------*
      *                      * Date and time da segreteria             *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Date and time                           *
      *                      *-----------------------------------------*
           move      s-sdt                to   r-env-dat-tim          .
      *                  *---------------------------------------------*
      *                  * Informazioni da identificazione programma   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Sistema applicativo                     *
      *                      *-----------------------------------------*
           move      i-ide-sap            to   r-ide-sis-app          .
      *                      *-----------------------------------------*
      *                      * Area gestionale                         *
      *                      *-----------------------------------------*
           move      i-ide-arg            to   r-ide-are-ges          .
      *                      *-----------------------------------------*
      *                      * Settore gestionale                      *
      *                      *-----------------------------------------*
           move      i-ide-set            to   r-ide-set-ges          .
      *                      *-----------------------------------------*
      *                      * Fase gestionale                         *
      *                      *-----------------------------------------*
           move      i-ide-fas            to   r-ide-fas-ges          .
      *                  *---------------------------------------------*
      *                  * Informazioni da preparazione param. stampa  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flags di tipo selezione                 *
      *                      *-----------------------------------------*
           move      w-stp-stp-tip-sel    to   r-fix-tip-sel          .
      *                      *-----------------------------------------*
      *                      * Codice stampante                        *
      *                      *-----------------------------------------*
           move      w-stp-stp-cod-stp    to   r-fix-cod-stp          .
      *                      *-----------------------------------------*
      *                      * Tipo di stampa                          *
      *                      *-----------------------------------------*
           move      w-stp-stp-tip-sta    to   r-fix-tip-sta          .
      *                      *-----------------------------------------*
      *                      * Codice modulo                           *
      *                      *-----------------------------------------*
           move      w-stp-stp-cod-mod    to   r-fix-cod-mod          .
      *                      *-----------------------------------------*
      *                      * Tipo modulo                             *
      *                      *-----------------------------------------*
           move      w-stp-stp-tip-mod    to   r-fix-tip-mod          .
      *                      *-----------------------------------------*
      *                      * Ampiezza linea di stampa in caratteri   *
      *                      *-----------------------------------------*
           move      w-stp-stp-amp-lin    to   r-fix-amp-lin          .
      *                      *-----------------------------------------*
      *                      * Top margin in linee                     *
      *                      *-----------------------------------------*
           move      w-stp-stp-top-lin    to   r-fix-top-lin          .
      *                      *-----------------------------------------*
      *                      * Numero linee di stampa minimo           *
      *                      *-----------------------------------------*
           move      w-stp-stp-lin-min    to   r-fix-lin-min          .
      *                      *-----------------------------------------*
      *                      * Bottom margin in linee                  *
      *                      *-----------------------------------------*
           move      w-stp-stp-bot-lin    to   r-fix-bot-lin          .
      *                      *-----------------------------------------*
      *                      * Ampiezza caratteri                      *
      *                      *-----------------------------------------*
           move      w-stp-stp-amp-car    to   r-fix-amp-car          .
      *                      *-----------------------------------------*
      *                      * Altezza interlinea                      *
      *                      *-----------------------------------------*
           move      w-stp-stp-alt-int    to   r-fix-alt-int          .
      *                      *-----------------------------------------*
      *                      * Area riservata per espansioni future    *
      *                      *-----------------------------------------*
           move      w-stp-stp-esp-fut    to   r-fix-esp-fut          .
      *                      *-----------------------------------------*
      *                      * Area riservata per funzioni speciali    *
      *                      *-----------------------------------------*
           move      w-stp-stp-fnz-spc    to   r-fix-fnz-spc          .
      *              *-------------------------------------------------*
      *              * Richiamo modulo di selezione stampa             *
      *              *-------------------------------------------------*
           call      "swd/mod/prg/obj/mpslct"
                                         using r                      .
           cancel    "swd/mod/prg/obj/mpslct"                         .
      *              *-------------------------------------------------*
      *              * Status di uscita                                *
      *              *-------------------------------------------------*
           if        r-rsc                not  = spaces
                     move  "#"            to   w-stp-sel-prm-stp      .
       sel-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Lettura parametri di selezione stampa da segreteria, per  *
      *    *sub-funzione di stampa                                     *
      *    *-----------------------------------------------------------*
       let-sel-stp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-let-sel-stp      .
      *              *-------------------------------------------------*
      *              * Inizializzazione area parametri stampa          *
      *              *-------------------------------------------------*
           move      spaces               to   p-sel                  .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero progressivo segmento    *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-stu-num-seg      .
       let-sel-stp-100.
      *              *-------------------------------------------------*
      *              * Incremento numero progressivo segmento          *
      *              *-------------------------------------------------*
           add       1                    to   w-stp-stu-num-seg      .
      *              *-------------------------------------------------*
      *              * Richiamo del modulo di segreteria per l'estra-  *
      *              * zione del segmento di parametri stampa          *
      *              *-------------------------------------------------*
           move      "S<"                 to   s-ope                  .
           move      w-stp-stu-num-seg    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Concatenazione del segmento in area parametri   *
      *              * di stampa selezionati                           *
      *              *-------------------------------------------------*
           move      w-stp-stu-num-seg    to   w-stp-stu-pnt-stu      .
           multiply  80                   by   w-stp-stu-pnt-stu      .
           subtract  79                   from w-stp-stu-pnt-stu      .
           move      w-stp-stu-pnt-stu    to   w-stp-stu-sav-pnt      .
           string    s-alf
                     delimited by size    into p-sel
                                  with pointer w-stp-stu-pnt-stu      .
      *              *-------------------------------------------------*
      *              * Se non si e' alla fine del record si ricicla    *
      *              *-------------------------------------------------*
           if        w-stp-stu-pnt-stu    not  = w-stp-stu-sav-pnt
                     go to let-sel-stp-100.
       let-sel-stp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo di report-program, per sub-funzione di stampa       *
      *    *-----------------------------------------------------------*
       prn-rou-pri-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione markers                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-prn-mrk-uno      .
           move      spaces               to   w-stp-prn-mrk-beg      .
      *              *-------------------------------------------------*
      *              * Inizializzazione area per rotture di livello    *
      *              *-------------------------------------------------*
           move      spaces               to   w-rot                  .
      *              *-------------------------------------------------*
      *              * Inizializzazione flag di interruzione forzata   *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Start iniziale                                  *
      *              *-------------------------------------------------*
           perform   prn-str-ini-000      thru prn-str-ini-999        .
           if        w-stp-prn-flg-sub    not  = spaces
                     move   spaces        to   w-stp-prn-flg-sub
                     go to  prn-rou-pri-600.
       prn-rou-pri-100.
      *              *-------------------------------------------------*
      *              * Salvataggio area rottura in area precedente     *
      *              *-------------------------------------------------*
           move      w-rot-l05            to   w-stp-prn-sav-l05      .
           move      w-rot-l04            to   w-stp-prn-sav-l04      .
           move      w-rot-l03            to   w-stp-prn-sav-l03      .
           move      w-rot-l02            to   w-stp-prn-sav-l02      .
           move      w-rot-l01            to   w-stp-prn-sav-l01      .
       prn-rou-pri-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale                             *
      *              *-------------------------------------------------*
           perform   prn-let-seq-000      thru prn-let-seq-999        .
           if        w-stp-prn-flg-sub    not  = spaces
                     move   spaces        to   w-stp-prn-flg-sub
                     go to  prn-rou-pri-500.
      *              *-------------------------------------------------*
      *              * Test se superamento limiti massimi              *
      *              *-------------------------------------------------*
           perform   prn-tst-max-000      thru prn-tst-max-999        .
           if        w-stp-prn-flg-sub    not  = spaces
                     move   spaces        to   w-stp-prn-flg-sub
                     go to  prn-rou-pri-500.
      *              *-------------------------------------------------*
      *              * Selezione su record letto                       *
      *              *-------------------------------------------------*
           perform   prn-sel-rec-000      thru prn-sel-rec-999        .
           if        w-stp-prn-flg-sub    not  = spaces
                     move   spaces        to   w-stp-prn-flg-sub
                     go to  prn-rou-pri-200.
      *              *-------------------------------------------------*
      *              * Composizione area per tests di rottura          *
      *              *-------------------------------------------------*
           perform   prn-cmp-rot-000      thru prn-cmp-rot-999        .
      *              *-------------------------------------------------*
