      *                  * su misura                                   *
      *                  *---------------------------------------------*
           perform   acc-snx-sum-000      thru acc-snx-sum-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
           if        v-key                =    "UP  "
                     go to acc-ric-sel-100.
       acc-ric-sel-300.
      *                  *---------------------------------------------*
      *                  * Sigla sistema applicativo su misura 1       *
      *                  *---------------------------------------------*
           perform   acc-sum-001-000      thru acc-sum-001-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
           if        v-key                =    "UP  "
                     go to acc-ric-sel-200.
       acc-ric-sel-400.
      *                  *---------------------------------------------*
      *                  * Sigla sistema applicativo su misura 2       *
      *                  *---------------------------------------------*
           perform   acc-sum-002-000      thru acc-sum-002-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
           if        v-key                =    "UP  "
                     go to acc-ric-sel-300.
       acc-ric-sel-500.
      *                  *---------------------------------------------*
      *                  * Sigla sistema applicativo su misura 3       *
      *                  *---------------------------------------------*
           perform   acc-sum-003-000      thru acc-sum-003-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
           if        v-key                =    "UP  "
                     go to acc-ric-sel-400.
       acc-ric-sel-600.
      *                  *---------------------------------------------*
      *                  * Codice procedura di salvataggio             *
      *                  *---------------------------------------------*
           perform   acc-cod-bak-000      thru acc-cod-bak-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
           if        v-key                =    "UP  "
                     go to acc-ric-sel-500.
       acc-ric-sel-700.
      *                  *---------------------------------------------*
