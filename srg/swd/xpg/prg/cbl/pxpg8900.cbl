      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Test su : Si/No preparazione sistemi applicati- *
      *              *           vi standard                           *
      *              *-------------------------------------------------*
       tdo-ric-sel-102.
           if        rr-snx-std           not  = spaces
                     go to tdo-ric-sel-104.
           move      "Manca la selezione sui sistemi applicativi standar
      -              "d !            "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-104.
           if        rr-snx-std           =    "S" or
                     rr-snx-std           =    "N"
                     go to tdo-ric-sel-106.
           move      "Selezione sui sistemi applicativi standard errata 
      -              "!              "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-106.
           go to     tdo-ric-sel-200.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Test su : Si/No preparazione sistemi applicati- *
      *              *           vi su misura                          *
      *              *-------------------------------------------------*
       tdo-ric-sel-202.
           if        rr-snx-sum           not  = spaces
                     go to tdo-ric-sel-204.
           move      "Manca la selezione sui sistemi applicativi su misu
      -              "ra !           "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-204.
           if        rr-snx-std           =    "S" or
                     rr-snx-std           =    "N"
                     go to tdo-ric-sel-206.
           move      "Selezione sui sistemi applicativi su misura errata
      -              " !             "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-206.
           go to     tdo-ric-sel-300.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Test su : Sigle sistemi applicativi su misura   *
      *              *-------------------------------------------------*
       tdo-ric-sel-302.
           if        rr-snx-sum           not  = "S"
                     go to tdo-ric-sel-304.
           if        rr-sum-001           not  = spaces or
                     rr-sum-002           not  = spaces or
                     rr-sum-003           not  = spaces
                     go to tdo-ric-sel-304.
           move      "Manca la sigla di almeno un sistema applicativo su
      -              " misura !      "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-304.
           go to     tdo-ric-sel-400.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Controllo sull'abilitazione alla procedura      *
      *              *-------------------------------------------------*
           if        rr-cod-bak           =    spaces
                     go to tdo-ric-sel-500.
           if        w-ute-tip-ute        =    02
                     go to tdo-ric-sel-500.
           if        w-bak-tut-abl        not  = 02
                     go to tdo-ric-sel-500.
           move      "Manca l'abilitazione per l'esecuzione della proced
      -              "ura !          "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-500.
      *              *-------------------------------------------------*
      *              * Controllo sullo status della procedura          *
      *              *-------------------------------------------------*
           if        rr-cod-bak           =    spaces
                     go to tdo-ric-sel-600.
           if        w-ute-tip-ute        =    02
                     go to tdo-ric-sel-600.
           if        w-bak-sts-bak        not  = 02
                     go to tdo-ric-sel-600.
           move      "L'esecuzione della procedura e' bloccata a tutti g
      -              "li utenti !    "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-600.
      *              *-------------------------------------------------*
      *              * Controllo sulla password per l'esecuzione       *
      *              *-------------------------------------------------*
           if        rr-cod-bak           =    spaces
                     go to tdo-ric-sel-700.
           if        w-ute-tip-ute        =    02
                     go to tdo-ric-sel-700.
           if        w-bak-pwd-bak        =    spaces
                     go to tdo-ric-sel-700.
           if        rr-pwd-bak           not  = spaces
                     go to tdo-ric-sel-700.
           move      "Manca la password per l'esecuzione della procedura
      -              " !             "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-700.
      *              *-------------------------------------------------*
      *              * Uscita per tests tutti superati                 *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
