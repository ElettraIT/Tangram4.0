       acc-pre-vre-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-pre-vre-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-pre-vre-100.
       acc-pre-vre-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-999.
           exit.

      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do riga corpo             *
      *    *-----------------------------------------------------------*
       cnt-tdo-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-100.
      *              *-------------------------------------------------*
      *              * Controllo su Testo promemoria                   *
      *              *-------------------------------------------------*
           if        w-rig-txt-upr (1)    not  = spaces
                     go to cnt-tdo-rig-200.
           move      "Manca il testo del promemoria !                   
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-200.
      *              *-------------------------------------------------*
      *              * Controllo su Giorno di riferimento              *
      *              *-------------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 03 and
                     w-rig-mdr-upr (1)    not  = 04
                     go to cnt-tdo-rig-300.
           if        w-rig-gio-rif (1)    not  = zero
                     go to cnt-tdo-rig-300.
           move      "Manca il giorno di riferimento del mese !         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-300.
      *              *-------------------------------------------------*
      *              * Controllo su Mese di riferimento                *
      *              *-------------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 04
                     go to cnt-tdo-rig-400.
           if        w-rig-mes-rif (1)    not  = zero
                     go to cnt-tdo-rig-400.
           move      "Manca il mese di riferimento !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo su Giorno e mese di riferimento       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su modalita' di ripetizione            *
      *                  *---------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 04
                     go to cnt-tdo-rig-500.
      *                  *---------------------------------------------*
      *                  * Test se inferiore a 29                      *
      *                  *---------------------------------------------*
           if        w-rig-gio-rif (1)    <    29
                     go to cnt-tdo-rig-500.
      *                  *---------------------------------------------*
      *                  * Assemblaggio di giorno e mese adottando per *
      *                  * convenzione un anno non bisestile           *
      *                  *---------------------------------------------*
           move      w-rig-gio-rif (1)    to   s-gio                  .
           move      w-rig-mes-rif (1)    to   s-mes                  .
           move      101                  to   s-saa                  .
      *                  *---------------------------------------------*
      *                  * Controllo della data ottenuta               *
      *                  *---------------------------------------------*
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su esito controllo                     *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to cnt-tdo-rig-500.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      "Il giorno ed il mese di riferimento presentano una
      -              " incongruenza !"    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-500.
      *              *-------------------------------------------------*
      *              * Controllo su Data di riferimento                *
      *              *-------------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 01
                     go to cnt-tdo-rig-600.
           if        w-rig-dat-upr (1)    not  = zero
                     go to cnt-tdo-rig-600.
           move      "Manca la data promemoria !                        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-600.
      *              *-------------------------------------------------*
      *              * Controllo su Data di scadenza                   *
      *              *-------------------------------------------------*
           if        w-rig-drt-upr (1)    not  = 02
                     go to cnt-tdo-rig-700.
           if        w-rig-dfi-upr (1)    not  = zero
                     go to cnt-tdo-rig-700.
           move      "Manca la data di scadenza !                       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-700.
      *              *-------------------------------------------------*
      *              * Normalizzazione Giorni di preavviso             *
      *              *-------------------------------------------------*
           if        w-rig-mdp-upr (1)    not  = 01
                     go to cnt-tdo-rig-720.
           if        w-rig-ngp-upr (1)    =    zero
                     go to cnt-tdo-rig-720.
           move      zero                 to   w-rig-ngp-upr (1)      .
       cnt-tdo-rig-720.
      *              *-------------------------------------------------*
      *              * Data di scadenza                                *
      *              *-------------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 01
                     go to cnt-tdo-rig-800.
           move      w-rig-dat-upr (1)    to   w-rig-dfi-upr (1)      .
       cnt-tdo-rig-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli tutti superati             *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo                  *
      *    *-----------------------------------------------------------*
       pre-rig-cor-000.
       pre-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Attribuzione del numero progressivo per la riga New       *
      *    *-----------------------------------------------------------*
       prg-rig-cor-000.
           move      w-cat-rig-prg        to   w-rig-cod-upr (1)      .
       prg-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo                       *
      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
       pos-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave e non chiave                  *
      *    *-----------------------------------------------------------*
       nor-key-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati chiave                     *
      *              *-------------------------------------------------*
           perform   nor-key-reg-000      thru nor-key-reg-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave testata         *
      *              *-------------------------------------------------*
           perform   nor-nok-tes-000      thru nor-nok-tes-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave riga corpo      *
      *              *-------------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave piede           *
      *              *-------------------------------------------------*
           perform   nor-nok-pie-000      thru nor-nok-pie-999        .
       nor-key-nok-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave                               *
      *    *-----------------------------------------------------------*
       nor-key-reg-000.
           move      spaces               to   w-tes-cod-ute          .
       nor-key-reg-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave testata                   *
      *    *-----------------------------------------------------------*
       nor-nok-tes-000.
       nor-nok-tes-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave riga corpo                *
      *    *-----------------------------------------------------------*
       nor-nok-rig-000.
           move      zero                 to   w-rig-cod-upr (1)      .
           move      spaces               to   w-rig-des-upr (1)      .
           move      spaces               to   w-rig-txt-upr (1)      .
           move      zero                 to   w-rig-mdr-upr (1)      .
           move      zero                 to   w-rig-mda-upr (1)      .
           move      zero                 to   w-rig-dat-upr (1)      .
           move      zero                 to   w-rig-gio-set (1)      .
           move      zero                 to   w-rig-gio-rif (1)      .
           move      zero                 to   w-rig-mes-rif (1)      .
           move      zero                 to   w-rig-ngp-upr (1)      .
           move      zero                 to   w-rig-mdp-upr (1)      .
           move      zero                 to   w-rig-drt-upr (1)      .
           move      zero                 to   w-rig-dfi-upr (1)      .
           move      zero                 to   w-rig-dpv-upr (1)      .
           move      spaces               to   w-rig-snx-acp (1)      .
           move      spaces               to   w-rig-snx-pvs (1)      .
           move      spaces               to   w-rig-snx-scf (1)      .
           move      spaces               to   w-rig-alx-exp (1)      .
       nor-nok-rig-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave piede                     *
      *    *-----------------------------------------------------------*
       nor-nok-pie-000.
       nor-nok-pie-999.
           exit.

      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione progressivo righe               *
      *              *-------------------------------------------------*
           move      zero                 to   w-cix-ctr-prg          .
      *              *-------------------------------------------------*
      *              * Esecuzione sort per ordinamento richiesto       *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   car-fil-rap-000
                                          thru car-fil-rap-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di records ca-  *
      *              * ricati nel file relative di appoggio            *
      *              *-------------------------------------------------*
           if        w-cix-ctr-prg        =    zero
                     go to rou-let-reg-200
           else      go to rou-let-reg-300.
       rou-let-reg-200.
      *              *-------------------------------------------------*
      *              * Se numero di records caricati : zero            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se numero di records caricati maggiore di zero  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Modifica                                    *
      *                  *---------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di duplicazione     *
      *                  *---------------------------------------------*
           move      spaces               to   w-dup-rec-upr-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [upr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "UTECOD    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-cod-ute        to   rf-upr-cod-ute         .
           move      zero                 to   rf-upr-cod-upr         .
           move      "swd/xpg/fls/ioc/obj/iofupr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-upr                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [upr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "swd/xpg/fls/ioc/obj/iofupr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-upr                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo : uscita                       *
      *              *-------------------------------------------------*
           if        rf-upr-cod-ute       not  = w-tes-cod-ute
                     go to stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [upr]                      *
      *              *-------------------------------------------------*
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento progressivo righe                 *
      *              *-------------------------------------------------*
           add       00100                to   w-cix-ctr-prg          .
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record di sort              *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Progressivo righe                       *
      *                      *-----------------------------------------*
           move      rf-upr-cod-upr       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Record [upr]                            *
      *                      *-----------------------------------------*
           move      rf-upr               to   srt-rec-upr            .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione caricamento file relative di appoggio          *
      *    *-----------------------------------------------------------*
       car-fil-rap-000.
      *              *-------------------------------------------------*
      *              * La preparazione della catena avviene dai record *
      *              * rilasciati dalla routine in input di sort       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su records letti                       *
      *                  *---------------------------------------------*
           if        w-cix-ctr-prg        =    zero
                     go to car-fil-rap-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione catena [rig]               *
      *                  *---------------------------------------------*
           move      "BE"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-fil-rap-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se At End : uscita                          *
      *                  *---------------------------------------------*
           return    srt    at end
                            go to car-fil-rap-999                     .
       car-fil-rap-200.
      *                  *---------------------------------------------*
      *                  * Composizione area 'w-rig'                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione [upr]                   *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "swd/xpg/fls/ioc/obj/iofupr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-upr                 .
      *                      *-----------------------------------------*
      *                      * Recupero [upr]                          *
      *                      *-----------------------------------------*
           move      srt-rec-upr          to   rf-upr                 .
      *                      *-----------------------------------------*
      *                      * Composizione                            *
      *                      *-----------------------------------------*
           move      rf-upr-cod-upr       to   w-rig-cod-upr (1)      .
           move      rf-upr-des-upr       to   w-rig-des-upr (1)      .
           move      rf-upr-txt-upr       to   w-rig-txt-upr (1)      .
           move      rf-upr-mdr-upr       to   w-rig-mdr-upr (1)      .
           move      rf-upr-mda-upr       to   w-rig-mda-upr (1)      .
           move      rf-upr-dat-upr       to   w-rig-dat-upr (1)      .
           move      rf-upr-gio-set       to   w-rig-gio-set (1)      .
           move      rf-upr-gio-rif       to   w-rig-gio-rif (1)      .
           move      rf-upr-mes-rif       to   w-rig-mes-rif (1)      .
           move      rf-upr-ngp-upr       to   w-rig-ngp-upr (1)      .
           move      rf-upr-mdp-upr       to   w-rig-mdp-upr (1)      .
           move      rf-upr-drt-upr       to   w-rig-drt-upr (1)      .
           move      rf-upr-dfi-upr       to   w-rig-dfi-upr (1)      .
           move      rf-upr-dpv-upr       to   w-rig-dpv-upr (1)      .
           move      rf-upr-snx-acp       to   w-rig-snx-acp (1)      .
           move      rf-upr-snx-pvs       to   w-rig-snx-pvs (1)      .
           move      rf-upr-snx-scf       to   w-rig-snx-scf (1)      .
           move      rf-upr-alx-exp       to   w-rig-alx-exp (1)      .
      *                  *---------------------------------------------*
      *                  * Valori contenuti indirettamente in record   *
      *                  * [upr]                                       *
      *                  *---------------------------------------------*
       car-fil-rap-600.
      *                  *---------------------------------------------*
      *                  * Lettura eventuale record note               *
      *                  *---------------------------------------------*
       car-fil-rap-900.
      *                  *---------------------------------------------*
      *                  * Valori precedenti                           *
      *                  *---------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Put su catena movimenti [rig]               *
      *                  *---------------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      w-rig-cod-upr (1)    to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura record di sort            *
      *                  *---------------------------------------------*
           go to     car-fil-rap-100.
       car-fil-rap-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-accettazioni per inserimento                  *
      *    *-----------------------------------------------------------*
       pre-acc-ins-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
