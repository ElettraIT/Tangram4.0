      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-des-upr (1)    to   v-alf                  .
       acc-des-upr-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-des-upr-400.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-des-upr-300
           else      go to acc-des-upr-350.
       acc-des-upr-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-des-upr-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-des-upr-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-des-upr-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-des-upr-310.
       acc-des-upr-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-des-upr-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-des-upr-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-des-upr-999.
       acc-des-upr-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-des-upr-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-des-upr-999
                     else    go to acc-des-upr-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-des-upr-999.
       acc-des-upr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-des-upr (1)      .
      *                  *---------------------------------------------*
      *                  * Se valore invariato : nessun controllo      *
      *                  *---------------------------------------------*
           if        w-rig-des-upr (1)    =    w-sav-des-upr
                     go to acc-des-upr-450.
      *                  *---------------------------------------------*
      *                  * Se a spaces : a controlli su spaces         *
      *                  *---------------------------------------------*
           if        w-rig-des-upr (1)    =    spaces
                     go to acc-des-upr-450.
      *                  *---------------------------------------------*
      *                  * Controlli su valore impostato               *
      *                  *---------------------------------------------*
           go to     acc-des-upr-600.
       acc-des-upr-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-des-upr (1)    =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-des-upr-999
                     else  go to acc-des-upr-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-des-upr-100.
       acc-des-upr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-des-upr-800.
       acc-des-upr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione                       *
      *    *-----------------------------------------------------------*
       vis-des-upr-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-rig-des-upr (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-upr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Testo                                *
      *    *-----------------------------------------------------------*
       acc-txt-upr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale default                           *
      *                  *---------------------------------------------*
           if        w-rig-txt-upr (1)    =    spaces
                     move  w-rig-des-upr (1)
                                          to   w-rig-txt-upr (1)      .
       acc-txt-upr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-txt-upr (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-txt-upr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-txt-upr-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-rig-txt-upr (1)      .
       acc-txt-upr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-txt-upr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-txt-upr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-txt-upr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-txt-upr-100.
       acc-txt-upr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Testo                             *
      *    *-----------------------------------------------------------*
       vis-txt-upr-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-rig-txt-upr (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-txt-upr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Modalita' di ripetizione             *
      *    *-----------------------------------------------------------*
       acc-mdr-upr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-mdr-upr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-mdr-upr-lun    to   v-car                  .
           move      w-exp-mdr-upr-num    to   v-ldt                  .
           move      "DSMAO#"             to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-mdr-upr-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-mdr-upr (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-mdr-upr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-mdr-upr-999.
       acc-mdr-upr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-mdr-upr (1)      .
       acc-mdr-upr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-mdr-upr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Solo alla data indicata                  *
      *                  *---------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 01
                     go to acc-mdr-upr-620.
      *                  *---------------------------------------------*
      *                  * Normalizzazione Durata promemoria           *
      *                  *---------------------------------------------*
           move      02                   to   w-rig-drt-upr (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione Durata promemoria           *
      *                  *---------------------------------------------*
           perform   vis-drt-upr-000      thru vis-drt-upr-999        .
       acc-mdr-upr-620.
      *                  *---------------------------------------------*
      *                  * Se Ogni giorno                              *
      *                  *---------------------------------------------*
           if        w-rig-mdr-upr (1)    not  = 05
                     go to acc-mdr-upr-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione Giorni di preavviso         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-ngp-upr (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione Durata promemoria           *
      *                  *---------------------------------------------*
           perform   vis-ngp-upr-000      thru vis-ngp-upr-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione Modalita' di preavviso      *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-mdp-upr (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione Modalita' promemoria        *
      *                  *---------------------------------------------*
           perform   vis-mdp-upr-000      thru vis-mdp-upr-999        .
       acc-mdr-upr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-mdr-upr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-mdr-upr-100.
       acc-mdr-upr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Modalita' di ripetizione          *
      *    *-----------------------------------------------------------*
       vis-mdr-upr-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-mdr-upr-lun    to   v-car                  .
           move      w-exp-mdr-upr-num    to   v-ldt                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-mdr-upr-tbl    to   v-txt                  .
           move      w-rig-mdr-upr (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-mdr-upr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Riferimento 1 ripetizione            *
      *    *-----------------------------------------------------------*
       acc-rf1-upr-000.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           perform   pmt-rf1-upr-000      thru pmt-rf1-upr-999        .
      *              *-------------------------------------------------*
      *              * Riferimento 1 ripetizione                       *
      *              *-------------------------------------------------*
           perform   vis-rf1-upr-000      thru vis-rf1-upr-999        .
      *              *-------------------------------------------------*
      *              * Riferimento 2 ripetizione                       *
      *              *-------------------------------------------------*
           perform   vis-rf2-upr-000      thru vis-rf2-upr-999        .
       acc-rf1-upr-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della modalita' di ri-   *
      *              * petizione                                       *
      *              *-------------------------------------------------*
           if        w-rig-mdr-upr (1)    =    01
                     go to acc-rf1-upr-100
           else if   w-rig-mdr-upr (1)    =    02
                     go to acc-rf1-upr-200
           else if   w-rig-mdr-upr (1)    =    03 or
                     w-rig-mdr-upr (1)    =    04
                     go to acc-rf1-upr-300
           else if   w-rig-mdr-upr (1)    =    05
                     go to acc-rf1-upr-800
           else      go to acc-rf1-upr-800.
       acc-rf1-upr-100.
      *              *-------------------------------------------------*
      *              * Se non si ripete                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione data                           *
      *                  *---------------------------------------------*
           perform   acc-rf1-upr-dat-000  thru acc-rf1-upr-dat-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-rf1-upr-900.
       acc-rf1-upr-200.
      *              *-------------------------------------------------*
      *              * Se ogni giorno della settimana                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione giorno della settimana         *
      *                  *---------------------------------------------*
           perform   acc-rf1-upr-gds-000  thru acc-rf1-upr-gds-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-rf1-upr-900.
       acc-rf1-upr-300.
      *              *-------------------------------------------------*
      *              * Se ogni giorno del mese o ogni mese             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione giorno del mese                *
      *                  *---------------------------------------------*
           perform   acc-rf1-upr-gdm-000  thru acc-rf1-upr-gdm-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-rf1-upr-900.
       acc-rf1-upr-800.
      *              *-------------------------------------------------*
      *              * In tutti gli altri casi                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-rf1-upr-900.
       acc-rf1-upr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-rf1-upr-999.
       acc-rf1-upr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Riferimento 1 ripetizione         *
      *    *-----------------------------------------------------------*
       vis-rf1-upr-000.
      *              *-------------------------------------------------*
      *              * Pulizia preliminare                             *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-rf1-upr-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della modalita' di ri-   *
      *              * petizione                                       *
      *              *-------------------------------------------------*
           if        w-rig-mdr-upr (1)    =    01
                     go to vis-rf1-upr-100
           else if   w-rig-mdr-upr (1)    =    02
                     go to vis-rf1-upr-200
           else if   w-rig-mdr-upr (1)    =    03 or
                     w-rig-mdr-upr (1)    =    04
                     go to vis-rf1-upr-300
           else if   w-rig-mdr-upr (1)    =    05
