           if        rr-snx-num           not  = "S"
                     go to stp-rig-det-400.
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-stp-num-rig        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rig-det-400.
      *              *-------------------------------------------------*
      *              * Dati veri e propri                              *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      rr-amp-lin           to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           if        rr-snx-num           =    "S"
                     add   7              to   p-pos                  .
           move      seq-rec
                    (1 : rr-amp-lin)      to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rig-det-999.
           exit.

      *    *===========================================================*
      *    * Open file [seq]                                           *
      *    *-----------------------------------------------------------*
       opn-fil-seq-000.
      *              *-------------------------------------------------*
      *              * Preparazione del name                           *
      *              *-------------------------------------------------*
           move      "seq "               to   f-seq-nam              .
      *              *-------------------------------------------------*
      *              * Preparazione del pathname                       *
      *              *-------------------------------------------------*
           move      rr-pat-fil           to   f-seq-pat              .
      *              *-------------------------------------------------*
      *              * Normalizzazione del file status                 *
      *              *-------------------------------------------------*
           move      e-not-err            to   f-seq-sts              .
      *              *-------------------------------------------------*
      *              * Open effettiva                                  *
      *              *-------------------------------------------------*
           open      input  seq                                       .
       opn-fil-seq-999.
           exit.

      *    *===========================================================*
      *    * Close file [seq]                                          *
      *    *-----------------------------------------------------------*
       cls-fil-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione del file status                 *
      *              *-------------------------------------------------*
           move      e-not-err            to   f-seq-sts              .
      *              *-------------------------------------------------*
      *              * Close effettiva                                 *
      *              *-------------------------------------------------*
           close     seq                                              .
       cls-fil-seq-999.
           exit.

      *    *===========================================================*
      *    * Read file [seq]                                           *
      *    *-----------------------------------------------------------*
       rea-fil-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione area record                     *
      *              *-------------------------------------------------*
           move      spaces               to   seq-rec                .
      *              *-------------------------------------------------*
      *              * Normalizzazione del file status                 *
      *              *-------------------------------------------------*
           move      e-not-err            to   f-seq-sts              .
      *              *-------------------------------------------------*
      *              * Read effettiva                                  *
      *              *-------------------------------------------------*
           read      seq    at end
                            move e-end-fil
                                          to   f-seq-sts              .
       rea-fil-seq-999.
           exit.

      *    *===========================================================*
      *    * Separazione linea in input, contenuta in 'seq-rec', in    *
      *    * max 20 elementi, separati da una sequenza di spazi, o da  *
      *    * anche un solo punto                                       *
      *    *                                                           *
      *    * La linea in input viene preventivamente convertita in up- *
      *    * percase                                                   *
      *    *-----------------------------------------------------------*
       sep-seq-rec-000.
      *              *-------------------------------------------------*
      *              * Linea in input in uppercase                     *
      *              *-------------------------------------------------*
           move      seq-rec              to   w-upp-low-str          .
           perform   cvs-low-upp-000      thru cvs-low-upp-999        .
           move      w-upp-low-str        to   w-sep-lin-str          .
       sep-seq-rec-100.
      *              *-------------------------------------------------*
      *              * Separazione in elementi                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-sep-lin-tbl          .
           unstring  w-sep-lin-str
                                delimited by   all spaces
                                          or   all "."
                                          into w-sep-lin-ele (01)
                                               w-sep-lin-ele (02)
                                               w-sep-lin-ele (03)
                                               w-sep-lin-ele (04)
                                               w-sep-lin-ele (05)
                                               w-sep-lin-ele (06)
                                               w-sep-lin-ele (07)
                                               w-sep-lin-ele (08)
                                               w-sep-lin-ele (09)
                                               w-sep-lin-ele (10)
                                               w-sep-lin-ele (11)
                                               w-sep-lin-ele (12)
                                               w-sep-lin-ele (13)
                                               w-sep-lin-ele (14)
                                               w-sep-lin-ele (15)
                                               w-sep-lin-ele (16)
                                               w-sep-lin-ele (17)
                                               w-sep-lin-ele (18)
                                               w-sep-lin-ele (19)
                                               w-sep-lin-ele (20)     .
       sep-seq-rec-200.
      *              *-------------------------------------------------*
      *              * Calcolo numero elementi presenti                *
      *              *-------------------------------------------------*
       sep-seq-rec-202.
           move      20                   to   w-sep-lin-num          .
       sep-seq-rec-204.
           if        w-sep-lin-ele
                    (w-sep-lin-num)       not  = spaces
                     go to sep-seq-rec-300.
           subtract  1                    from w-sep-lin-num          .
           if        w-sep-lin-num        >    zero
                     go to sep-seq-rec-204.
       sep-seq-rec-300.
      *              *-------------------------------------------------*
      *              * Memorizzazione indice dell'ultimo elemento      *
      *              *-------------------------------------------------*
           move      w-sep-lin-num        to   w-sep-lin-iue          .
       sep-seq-rec-400.
      *              *-------------------------------------------------*
      *              * Calcolo indice e posizione del primo elemento   *
      *              *-------------------------------------------------*
       sep-seq-rec-402.
           move      zero                 to   w-sep-lin-i1e          .
           move      zero                 to   w-sep-lin-p1e          .
       sep-seq-rec-404.
           if        w-sep-lin-num        =    zero
                     go to sep-seq-rec-500.
       sep-seq-rec-406.
           add       1                    to   w-sep-lin-i1e          .
           if        w-sep-lin-ele
                    (w-sep-lin-i1e)       =    spaces
                     go to sep-seq-rec-406.
       sep-seq-rec-408.
           inspect   w-sep-lin-str    tallying w-sep-lin-p1e
                                   for leading spaces                 .
           add       1                    to   w-sep-lin-p1e          .
       sep-seq-rec-500.
      *              *-------------------------------------------------*
      *              * Correzione numero elementi presenti             *
      *              *-------------------------------------------------*
           if        w-sep-lin-num        not  = zero
                     add      1           to   w-sep-lin-num
                     subtract w-sep-lin-i1e
                                          from w-sep-lin-num          .
       sep-seq-rec-600.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     sep-seq-rec-999.
       sep-seq-rec-999.
           exit.

      *    *===========================================================*
      *    * Routine per la conversione da lowercase a uppercase       *
      *    *                                                           *
      *    * Input  : w-upp-low-str = Valore della stringa da conver-  *
      *    *                          tire, max 80 caratteri           *
      *    *                                                           *
      *    * Output : w-upp-low-str = Valore della stringa in upperca- *
      *    *                          se                               *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       cvs-low-upp-000.
      *              *-------------------------------------------------*
      *              * Conteggio dei trailing spaces                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-upp-low-cts          .
           inspect   w-upp-low-str    tallying w-upp-low-cts
                                  for trailing spaces                 .
      *              *-------------------------------------------------*
      *              * Calcolo numero caratteri da convertire          *
      *              *-------------------------------------------------*
           move      80                   to   w-upp-low-lun          .
           subtract  w-upp-low-cts        from w-upp-low-lun          .
      *              *-------------------------------------------------*
      *              * Inizializzazione indice su carattere da conver- *
      *              * tire                                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-upp-low-inx          .
       cvs-low-upp-100.
      *              *-------------------------------------------------*
      *              * Incremento indice su carattere da convertire    *
      *              *-------------------------------------------------*
           add       1                    to   w-upp-low-inx          .
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : ad uscita                 *
      *              *-------------------------------------------------*
           if        w-upp-low-inx        >    w-upp-low-lun
                     go to cvs-low-upp-999.
      *              *-------------------------------------------------*
      *              * Conversione da lowercase a uppercase            *
      *              *-------------------------------------------------*
           move      zero                 to   w-upp-low-itc          .
           inspect   w-upp-low-low    tallying w-upp-low-itc
                     for characters     before
                                       initial w-upp-low-chr
                                              (w-upp-low-inx)         .
           if        w-upp-low-itc        <    26
                     add   1              to   w-upp-low-itc
                     move  w-upp-low-upc
                          (w-upp-low-itc) to   w-upp-low-chr
                                              (w-upp-low-inx)         .
      *              *-------------------------------------------------*
      *              * Riciclo su carattere successivo                 *
      *              *-------------------------------------------------*
           go to     cvs-low-upp-100.
       cvs-low-upp-999.
           exit.

      *    *===========================================================*
      *    * Routine per la conversione da uppercase a lowercase       *
      *    *                                                           *
      *    * Input  : w-upp-low-str = Valore della stringa da conver-  *
      *    *                          tire, max 80 caratteri           *
      *    *                                                           *
      *    * Output : w-upp-low-str = Valore della stringa in lowerca- *
      *    *                          se                               *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       cvs-upp-low-000.
      *              *-------------------------------------------------*
      *              * Conteggio dei trailing spaces                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-upp-low-cts          .
           inspect   w-upp-low-str    tallying w-upp-low-cts
                                  for trailing spaces                 .
      *              *-------------------------------------------------*
      *              * Calcolo numero caratteri da convertire          *
      *              *-------------------------------------------------*
           move      80                   to   w-upp-low-lun          .
           subtract  w-upp-low-cts        from w-upp-low-lun          .
      *              *-------------------------------------------------*
      *              * Inizializzazione indice su carattere da conver- *
      *              * tire                                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-upp-low-inx          .
       cvs-upp-low-100.
      *              *-------------------------------------------------*
      *              * Incremento indice su carattere da convertire    *
      *              *-------------------------------------------------*
           add       1                    to   w-upp-low-inx          .
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : ad uscita                 *
      *              *-------------------------------------------------*
           if        w-upp-low-inx        >    w-upp-low-lun
                     go to cvs-upp-low-999.
      *              *-------------------------------------------------*
      *              * Conversione da uppercase a lowercase            *
      *              *-------------------------------------------------*
           move      zero                 to   w-upp-low-itc          .
           inspect   w-upp-low-upp    tallying w-upp-low-itc
                     for characters     before
                                       initial w-upp-low-chr
                                              (w-upp-low-inx)         .
           if        w-upp-low-itc        <    26
                     add   1              to   w-upp-low-itc
                     move  w-upp-low-loc
                          (w-upp-low-itc) to   w-upp-low-chr
                                              (w-upp-low-inx)         .
      *              *-------------------------------------------------*
      *              * Riciclo su carattere successivo                 *
      *              *-------------------------------------------------*
           go to     cvs-upp-low-100.
       cvs-upp-low-999.
           exit.

