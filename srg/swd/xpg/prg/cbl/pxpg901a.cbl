           if        w-sep-lin-ele
                    (w-sep-lin-inx)       not  = "DIVISION"
                     go to acc-pat-fil-481.
           perform   cls-fil-seq-000      thru cls-fil-seq-999        .
           go to     acc-pat-fil-500.
       acc-pat-fil-481.
           perform   cls-fil-seq-000      thru cls-fil-seq-999        .
       acc-pat-fil-483.
