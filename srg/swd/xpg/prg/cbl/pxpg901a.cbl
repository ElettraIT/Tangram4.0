       stp-fnc-dat-210.
           if        rr-snx-sep           =    "S"
                     go to stp-rig-det-220
           else      go to stp-rig-det-230.
       stp-rig-det-220.
           move      "L+"                 to   p-ope                  .
           move      2                    to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     stp-rig-det-300.
       stp-rig-det-230.
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     stp-rig-det-300.
       stp-rig-det-300.
      *              *-------------------------------------------------*
