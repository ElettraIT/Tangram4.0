      *    *===========================================================*
      *    * Selezione riga di dettaglio                               *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Incremento numero progressivo riga letto        *
      *              *-------------------------------------------------*
           add       1                    to   w-stp-num-rig          .
       prn-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Separazione record letto in max 20 componenti,  *
      *              * in uppercase                                    *
      *              *-------------------------------------------------*
           perform   sep-seq-rec-000      thru sep-seq-rec-999        .
       prn-sel-rec-200.
      *              *-------------------------------------------------*
      *              * Se la linea letta e' a spaces : nessun errore   *
      *              *-------------------------------------------------*
           if        w-sep-lin-str        =    spaces
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Se la linea letta e' di commento : nessun erro- *
      *              * re                                              *
      *              *-------------------------------------------------*
           if        w-sep-lin-str (07 : 01)
                                          =    "*"
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Se la linea letta e' composta di zero elemen-   *
      *              * ti : nessun errore                              *
      *              *-------------------------------------------------*
           if        w-sep-lin-num        =    zero
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Se la linea letta non e' composta di un solo    *
      *              * elemento : non si tratta sicuramente di una li- *
      *              * nea di label, per cui si va' a controllare che  *
      *              * non ci sia un richiamo effettivo                *
      *              *-------------------------------------------------*
           if        w-sep-lin-num        not  = 1
                     go to prn-sel-rec-600.
      *              *-------------------------------------------------*
      *              * Se la posizione iniziale dell'elemento non e'   *
      *              * compresa tra 08 e 12 : nessun errore            *
      *              *-------------------------------------------------*
           if        w-sep-lin-p1e        <    08 or
                     w-sep-lin-p1e        >    12
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Label in esame in campo di comodo               *
      *              *-------------------------------------------------*
           move      w-sep-lin-ele
                    (w-sep-lin-i1e)       to   w-got-lat-str          .
      *              *-------------------------------------------------*
      *              * Separazione tra:                                *
      *              *  - Prefisso, senza gli ultimi quattro caratteri *
      *              *  - Ultimi quattro caratteri                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-got-ctr-c01          .
           inspect   w-got-lat-str    tallying w-got-ctr-c01
                                  for trailing spaces                 .
           move      84                   to   w-got-ctr-c02          .
           subtract  w-got-ctr-c01        from w-got-ctr-c02          .
           move      1                    to   w-got-inx-i01          .
           move      w-got-ctr-c02        to   w-got-inx-i02          .
           subtract  4                    from w-got-inx-i02          .
           move      w-got-inx-i02        to   w-got-inx-i03          .
           subtract  w-got-inx-i01        from w-got-inx-i03          .
           add       1                    to   w-got-inx-i03          .
           if        w-got-ctr-c02        not  > 4
                     move  zero           to   w-got-inx-i01
                     move  zero           to   w-got-inx-i02
                     move  zero           to   w-got-inx-i03          .
           if        w-got-inx-i03        =    zero
                     move  spaces         to   w-got-lat-pre
           else      move  w-got-lat-str
                          (w-got-inx-i01 :
                           w-got-inx-i03 )
                                          to   w-got-lat-pre          .
           if        w-got-ctr-c02        >    3
                     move      w-got-ctr-c02
                                          to   w-got-inx-i01
                     subtract  3          from w-got-inx-i01
           else      move      1          to   w-got-inx-i01          .
           move      w-got-ctr-c02        to   w-got-inx-i02          .
           move      w-got-inx-i02        to   w-got-inx-i03          .
           subtract  w-got-inx-i01        from w-got-inx-i03          .
           add       1                    to   w-got-inx-i03          .
           move      w-got-lat-str
                    (w-got-inx-i01 :
                     w-got-inx-i03 )      to   w-got-lat-pos          .
      *              *-------------------------------------------------*
      *              * Se il prefisso e' a spaces : nessun errore      *
      *              *-------------------------------------------------*
           if        w-got-lat-pre        =    spaces
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Se il postfisso e' diverso da '-000' : nessun   *
      *              * errore                                          *
      *              *-------------------------------------------------*
           if        w-got-lat-pos        not  = "-000"
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Memorizzazione ultima label incontrata termi-   *
      *              * nante in '-000' :                               *
      *              *  - Valore completo                              *
      *              *  - Prefisso                                     *
      *              *-------------------------------------------------*
           move      w-got-lat-str        to   w-got-ull-str          .
           move      w-got-lat-pre        to   w-got-ull-pre          .
      *              *-------------------------------------------------*
      *              * Uscita senza nessun errore                      *
      *              *-------------------------------------------------*
           go to     prn-sel-rec-900.
       prn-sel-rec-600.
      *              *-------------------------------------------------*
      *              * Allineamento indice sull'elemento corrisponden- *
      *              * te al primo elemento                            *
      *              *-------------------------------------------------*
           move      w-sep-lin-i1e        to   w-sep-lin-inx          .
       prn-sel-rec-610.
      *              *-------------------------------------------------*
      *              * Se non ci sono almeno altri due elementi : nes- *
      *              * sun errore                                      *
      *              *-------------------------------------------------*
           move      w-sep-lin-inx        to   w-sep-lin-i02          .
           add       2                    to   w-sep-lin-i02          .
           if        w-sep-lin-i02        >    w-sep-lin-iue
                     go to prn-sel-rec-900.
       prn-sel-rec-620.
      *              *-------------------------------------------------*
      *              * Se non corrisponde a 'GO'                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-sep-lin-ele
                    (w-sep-lin-inx)       =    "GO"
                     go to prn-sel-rec-630.
      *                  *---------------------------------------------*
      *                  * Incremento indice su elemento               *
      *                  *---------------------------------------------*
           add       1                    to   w-sep-lin-inx          .
      *                  *---------------------------------------------*
      *                  * Se oltre il max : nessun errore             *
      *                  *---------------------------------------------*
           if        w-sep-lin-inx        >    w-sep-lin-iue
                     go to prn-sel-rec-900.
      *                  *---------------------------------------------*
      *                  * Altrimenti riciclo                          *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-610.
       prn-sel-rec-630.
      *              *-------------------------------------------------*
      *              * Incremento indice su elemento                   *
      *              *-------------------------------------------------*
           add       1                    to   w-sep-lin-inx          .
      *              *-------------------------------------------------*
      *              * Se oltre il max : nessun errore                 *
      *              *-------------------------------------------------*
           if        w-sep-lin-inx        >    w-sep-lin-iue
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Se non c'e' almeno un altro elemento : nessun   *
      *              * errore                                          *
      *              *-------------------------------------------------*
           move      w-sep-lin-inx        to   w-sep-lin-i02          .
           add       1                    to   w-sep-lin-i02          .
           if        w-sep-lin-i02        >    w-sep-lin-iue
                     go to prn-sel-rec-900.
       prn-sel-rec-640.
      *              *-------------------------------------------------*
      *              * Se non corrisponde a 'TO'                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-sep-lin-ele
                    (w-sep-lin-inx)       =    "TO"
                     go to prn-sel-rec-650.
      *                  *---------------------------------------------*
      *                  * Incremento indice su elemento               *
      *                  *---------------------------------------------*
           add       1                    to   w-sep-lin-inx          .
      *                  *---------------------------------------------*
      *                  * Se oltre il max : nessun errore             *
      *                  *---------------------------------------------*
           if        w-sep-lin-inx        >    w-sep-lin-iue
                     go to prn-sel-rec-900.
      *                  *---------------------------------------------*
      *                  * Altrimenti riciclo                          *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-610.
       prn-sel-rec-650.
      *              *-------------------------------------------------*
      *              * Incremento indice su elemento                   *
      *              *-------------------------------------------------*
           add       1                    to   w-sep-lin-inx          .
      *              *-------------------------------------------------*
      *              * Se oltre il max : ad uscita per errore          *
      *              *-------------------------------------------------*
           if        w-sep-lin-inx        >    w-sep-lin-iue
                     go to prn-sel-rec-700.
      *              *-------------------------------------------------*
      *              * Label in esame in campo di comodo               *
      *              *-------------------------------------------------*
           move      w-sep-lin-ele
                    (w-sep-lin-inx)       to   w-got-lat-str          .
      *              *-------------------------------------------------*
      *              * Separazione tra:                                *
      *              *  - Prefisso, senza gli ultimi quattro caratteri *
      *              *  - Ultimi quattro caratteri                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-got-ctr-c01          .
           inspect   w-got-lat-str    tallying w-got-ctr-c01
                                  for trailing spaces                 .
           move      84                   to   w-got-ctr-c02          .
           subtract  w-got-ctr-c01        from w-got-ctr-c02          .
           move      1                    to   w-got-inx-i01          .
           move      w-got-ctr-c02        to   w-got-inx-i02          .
           subtract  4                    from w-got-inx-i02          .
           move      w-got-inx-i02        to   w-got-inx-i03          .
           subtract  w-got-inx-i01        from w-got-inx-i03          .
           add       1                    to   w-got-inx-i03          .
           if        w-got-ctr-c02        not  > 4
                     move  zero           to   w-got-inx-i01
                     move  zero           to   w-got-inx-i02
                     move  zero           to   w-got-inx-i03          .
           if        w-got-inx-i03        =    zero
                     move  spaces         to   w-got-lat-pre
           else      move  w-got-lat-str
                          (w-got-inx-i01 :
                           w-got-inx-i03 )
                                          to   w-got-lat-pre          .
           if        w-got-ctr-c02        >    3
                     move      w-got-ctr-c02
                                          to   w-got-inx-i01
                     subtract  3          from w-got-inx-i01
           else      move      1          to   w-got-inx-i01          .
           move      w-got-ctr-c02        to   w-got-inx-i02          .
           move      w-got-inx-i02        to   w-got-inx-i03          .
           subtract  w-got-inx-i01        from w-got-inx-i03          .
           add       1                    to   w-got-inx-i03          .
           move      w-got-lat-str
                    (w-got-inx-i01 :
                     w-got-inx-i03 )      to   w-got-lat-pos          .
      *              *-------------------------------------------------*
      *              * Se il prefisso e' a spaces : ad errore          *
      *              *-------------------------------------------------*
           if        w-got-lat-pre        =    spaces
                     go to prn-sel-rec-700.
      *              *-------------------------------------------------*
      *              * Se il prefisso e' diverso dall'ultimo prefisso  *
      *              * corrispondente ad una label '-000' : ad uscita  *
      *              * per errore                                      *
      *              *-------------------------------------------------*
           if        w-got-lat-pre        not  = w-got-ull-pre
                     go to prn-sel-rec-700.
      *              *-------------------------------------------------*
      *              * Altrimenti : uscita per nessun errore           *
      *              *-------------------------------------------------*
           go to     prn-sel-rec-900.
       prn-sel-rec-700.
      *              *-------------------------------------------------*
      *              * Uscita per errore : selezione superata          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero di errori                 *
      *                  *---------------------------------------------*
           add       1                    to   w-got-num-err          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Uscita per nessun errore : selezione non supe-  *
      *              * rata                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-prn-flg-sub      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-999.
