           move      "EL"                 to   v-ope                  .
           move      06                   to   v-lin                  .
           move      15                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura linea 06                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R       Operazione                         Campo
      -              "              Valore campo    "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura linea 07                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---  ------------------------------  -------------
      -              "--------  --------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura linea 15                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Tipo operazione   *
      *              *-------------------------------------------------*
           perform   vis-tip-ope-000      thru vis-tip-ope-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Descrizione tipo  *
      *              *                               operazione        *
      *              *-------------------------------------------------*
           perform   vis-des-ope-000      thru vis-des-ope-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Tipo campo        *
      *              *-------------------------------------------------*
           perform   vis-tip-cmp-000      thru vis-tip-cmp-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Nr caratteri      *
      *              *-------------------------------------------------*
           perform   vis-car-cmp-000      thru vis-car-cmp-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Nr decimali       *
      *              *-------------------------------------------------*
           perform   vis-dec-cmp-000      thru vis-dec-cmp-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Presenza segno    *
      *              *-------------------------------------------------*
           perform   vis-sgn-cmp-000      thru vis-sgn-cmp-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Tipo rappresenza- *
      *              *                               zione segno       *
      *              *-------------------------------------------------*
           perform   vis-trs-cmp-000      thru vis-trs-cmp-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Displacement      *
      *              *-------------------------------------------------*
           perform   vis-dsp-cmp-000      thru vis-dsp-cmp-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Valore campo      *
      *              *-------------------------------------------------*
           perform   vis-val-cmp-000      thru vis-val-cmp-999        .
       vis-rig-cor-999.
           exit.

