      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Tipo o- *
      *    *                                                 perazione *
      *    *-----------------------------------------------------------*
       acc-tip-ope-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio sigla tipo operazione preceden- *
      *                  * te                                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-ope (1)    =    01
                     move  "NO"           to   w-sav-sop-pre
           else if   w-rig-tip-ope (1)    =    02
                     move  "IN"           to   w-sav-sop-pre
           else if   w-rig-tip-ope (1)    =    03
                     move  "SO"           to   w-sav-sop-pre
           else if   w-rig-tip-ope (1)    =    04
                     move  "UC"           to   w-sav-sop-pre
           else if   w-rig-tip-ope (1)    =    05
                     move  "LC"           to   w-sav-sop-pre
           else      move  spaces         to   w-sav-sop-pre          .
       acc-tip-ope-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino sigla precedente su attuale      *
      *                  *---------------------------------------------*
           move      w-sav-sop-pre        to   w-sav-sop-att          .
       acc-tip-ope-150.
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      26                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : ammesso solo se record new e se  *
      *                      * il primo campo ammette il Find          *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     move  "FIND"         to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-sav-sop-att        to   v-alf                  .
       acc-tip-ope-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-ope-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-ope-250.
      *                  *---------------------------------------------*
      *                  * Find su tipo operazione                     *
      *                  *---------------------------------------------*
           perform   fnd-tip-ope-000      thru fnd-tip-ope-999        .
           if        w-fnd-tip-ope-sel    not  = spaces
                     go to acc-tip-ope-100.
           move      w-fnd-tip-ope-sgl    to   w-sav-sop-att          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione sigla tipo operazione       *
      *                  *---------------------------------------------*
           perform   vis-sgl-ope-000      thru vis-sgl-ope-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-ope-425.
       acc-tip-ope-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-ope-300
           else      go to acc-tip-ope-350.
       acc-tip-ope-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-ope-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-ope-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-ope-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-ope-310.
       acc-tip-ope-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-ope-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-ope-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-ope-999.
       acc-tip-ope-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-ope-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-ope-999
                     else    go to acc-tip-ope-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-ope-999.
       acc-tip-ope-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-sav-sop-att          .
           if        w-sav-sop-att        =    spaces
                     move  00             to   w-rig-tip-ope (1)
           else if   w-sav-sop-att        =    "NO"
                     move  01             to   w-rig-tip-ope (1)
           else if   w-sav-sop-att        =    "IN"
                     move  02             to   w-rig-tip-ope (1)
           else if   w-sav-sop-att        =    "SO"
                     move  03             to   w-rig-tip-ope (1)
           else if   w-sav-sop-att        =    "UC"
                     move  04             to   w-rig-tip-ope (1)
           else if   w-sav-sop-att        =    "LC"
                     move  05             to   w-rig-tip-ope (1)
           else      go to acc-tip-ope-150.
       acc-tip-ope-425.
      *                  *---------------------------------------------*
      *                  * Visualizzazione Descrizione tipo operazione *
      *                  *---------------------------------------------*
           perform   vis-tip-ope-000      thru vis-tip-ope-999        .
       acc-tip-ope-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tip-ope (1)    =    zero
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-ope-999
                     else  go to acc-tip-ope-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-ope-100.
       acc-tip-ope-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-ope-800.
       acc-tip-ope-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo operazione                   *
      *    *-----------------------------------------------------------*
       vis-tip-ope-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      26                   to   v-pos                  .
           if        w-rig-tip-ope (1)    =    01
                     move  "NO"           to   v-alf
           else if   w-rig-tip-ope (1)    =    02
                     move  "IN"           to   v-alf
           else if   w-rig-tip-ope (1)    =    03
                     move  "SO"           to   v-alf
           else if   w-rig-tip-ope (1)    =    04
                     move  "UC"           to   v-alf
           else if   w-rig-tip-ope (1)    =    05
                     move  "LC"           to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-ope-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla tipo operazione             *
      *    *-----------------------------------------------------------*
       vis-sgl-ope-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      26                   to   v-pos                  .
           move      w-sav-sop-att        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-ope-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione tipo operazione       *
      *    *-----------------------------------------------------------*
       vis-des-ope-000.
           move      w-rig-tip-ope (1)    to   w-exp-tip-ope-inx      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      31                   to   v-pos                  .
           if        w-exp-tip-ope-inx    =    zero           or
                     w-exp-tip-ope-inx    >    w-exp-tip-ope-num
                     move  spaces         to   v-alf
           else      move  w-exp-tip-ope-ele
                          (w-exp-tip-ope-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-ope-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo corpo : Tipo campo                     *
      *    *-----------------------------------------------------------*
       acc-tip-cmp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-cmp (1)    to   w-sav-tip-cmp          .
      *                  *---------------------------------------------*
      *                  * Test se valore da accettare                 *
      *                  *---------------------------------------------*
           if        w-rig-tip-ope (1)    not  = 04 and
                     w-rig-tip-ope (1)    not  = 05
                     go to acc-tip-cmp-100.
           move      "A"                  to   w-rig-tip-cmp (1)      .
           perform   vis-tip-cmp-000      thru vis-tip-cmp-999        .
           go to     acc-tip-cmp-600.
       acc-tip-cmp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-cmp-lun    to   v-car                  .
           move      w-exp-tip-cmp-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      17                   to   v-lin                  .
           move      26                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-exp-tip-cmp-tbl    to   v-txt                  .
           if        w-rig-tip-cmp (1)    =    "A"
                     move  01             to   v-num
           else if   w-rig-tip-cmp (1)    =    "N"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-cmp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-cmp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "A"            to   w-rig-tip-cmp (1)
           else if   v-num                =    02
                     move  "N"            to   w-rig-tip-cmp (1)
           else      move  spaces         to   w-rig-tip-cmp (1)      .
       acc-tip-cmp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        w-rig-tip-cmp (1)    not  = "A" and
                     w-rig-tip-cmp (1)    not  = "N"
                     go to acc-tip-cmp-100.
       acc-tip-cmp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo campo       *
      *                  *---------------------------------------------*
           if        w-rig-tip-cmp (1)    =    "A"
                     go to acc-tip-cmp-650
           else      go to acc-tip-cmp-700.
       acc-tip-cmp-650.
      *                  *---------------------------------------------*
      *                  * Se tipo campo Alfanumerico                  *
      *                  *---------------------------------------------*
       acc-tip-cmp-655.
      *                      *-----------------------------------------*
      *                      * Normalizzazione numero decimali         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-dec-cmp (1)      .
           perform   vis-dec-cmp-000      thru vis-dec-cmp-999        .
       acc-tip-cmp-660.
      *                      *-----------------------------------------*
      *                      * Normalizzazione presenza segno          *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-sgn-cmp (1)      .
           perform   vis-sgn-cmp-000      thru vis-sgn-cmp-999        .
       acc-tip-cmp-665.
      *                      *-----------------------------------------*
      *                      * Normalizzazione tipo rappres. segno     *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-trs-cmp (1)      .
           perform   vis-trs-cmp-000      thru vis-trs-cmp-999        .
       acc-tip-cmp-670.
      *                      *-----------------------------------------*
      *                      * Normalizzazione valore campo            *
      *                      *-----------------------------------------*
           if        w-rig-tip-cmp (1)    =    w-sav-tip-cmp
                     go to acc-tip-cmp-675.
           move      spaces               to   w-rig-val-cmp (1)      .
           perform   vis-val-cmp-000      thru vis-val-cmp-999        .
       acc-tip-cmp-675.
      *                      *-----------------------------------------*
      *                      * Fine normalizzazione per Alfanumerico   *
      *                      *-----------------------------------------*
           go to     acc-tip-cmp-800.
       acc-tip-cmp-700.
      *                  *---------------------------------------------*
      *                  * Se tipo campo Numerico                      *
      *                  *---------------------------------------------*
       acc-tip-cmp-705.
      *                      *-----------------------------------------*
      *                      * Normalizzazione numero caratteri        *
      *                      *-----------------------------------------*
           if        w-rig-car-cmp (1)    not  > 13
                     go to acc-tip-cmp-710.
           move      zero                 to   w-rig-car-cmp (1)      .
           perform   vis-car-cmp-000      thru vis-car-cmp-999        .
       acc-tip-cmp-710.
      *                      *-----------------------------------------*
      *                      * Normalizzazione valore campo            *
      *                      *-----------------------------------------*
           if        w-rig-tip-cmp (1)    =    w-sav-tip-cmp
                     go to acc-tip-cmp-715.
           move      spaces               to   w-rig-val-cmp (1)      .
           perform   vis-val-cmp-000      thru vis-val-cmp-999        .
       acc-tip-cmp-715.
      *                      *-----------------------------------------*
      *                      * Fine normalizzazione per Alfanumerico   *
      *                      *-----------------------------------------*
           go to     acc-tip-cmp-800.
       acc-tip-cmp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-cmp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-tip-cmp-100.
       acc-tip-cmp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo campo                        *
      *    *-----------------------------------------------------------*
       vis-tip-cmp-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      26                   to   v-pos                  .
           if        w-rig-tip-cmp (1)    =    "A"
                     move  01             to   w-exp-tip-cmp-inx
           else if   w-rig-tip-cmp (1)    =    "N"
                     move  02             to   w-exp-tip-cmp-inx
           else      move  zero           to   w-exp-tip-cmp-inx      .
           if        w-exp-tip-cmp-inx    =    zero           or
                     w-exp-tip-cmp-inx    >    w-exp-tip-cmp-num
                     move  spaces         to   v-alf
           else      move  w-exp-tip-cmp-ele
                          (w-exp-tip-cmp-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-cmp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo corpo : Numero caratteri               *
      *    *-----------------------------------------------------------*
       acc-car-cmp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-car-cmp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      26                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-car-cmp (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-car-cmp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-car-cmp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-car-cmp (1)      .
       acc-car-cmp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Che il valore non sia a zero                *
      *                  *---------------------------------------------*
           if        w-rig-car-cmp (1)    not  = zero
                     go to acc-car-cmp-450.
           if        v-key                =    "UP  "
                     go to acc-car-cmp-600
           else      go to acc-car-cmp-100.
       acc-car-cmp-450.
      *                  *---------------------------------------------*
      *                  * Che il valore non sia maggiore di 13 se il  *
      *                  * campo e' di tipo Numerico                   *
      *                  *---------------------------------------------*
           if        w-rig-tip-cmp (1)    not  = "N"
                     go to acc-car-cmp-600.
           if        w-rig-car-cmp (1)    >    13
                     go to acc-car-cmp-100.
       acc-car-cmp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-car-cmp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-car-cmp-999
