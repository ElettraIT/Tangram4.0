                     go to cnt-tdo-rig-110.
           move      "Manca il tipo campo                               
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-110.
           if        w-rig-tip-cmp (1)    =    "A" or
                     w-rig-tip-cmp (1)    =    "N"
                     go to cnt-tdo-rig-150.
           move      "Tipo campo errato                                 
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-150.
      *              *-------------------------------------------------*
      *              * Test su numero caratteri                        *
      *              *-------------------------------------------------*
           if        w-rig-car-cmp (1)    not  = zero
                     go to cnt-tdo-rig-160.
           move      "Manca il numero caratteri                         
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-160.
           if        w-rig-tip-cmp (1)    not  = "N"
                     go to cnt-tdo-rig-200.
           if        w-rig-car-cmp (1)    not  > 13
                     go to cnt-tdo-rig-200.
           move      "Numero caratteri errato                           
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-200.
      *              *-------------------------------------------------*
      *              * Test su numero decimali                         *
      *              *-------------------------------------------------*
           if        w-rig-tip-cmp (1)    not  = "N"
                     go to cnt-tdo-rig-250.
           if        w-rig-dec-cmp (1)    not  > 05
                     go to cnt-tdo-rig-250.
           move      "Numero decimali errato                            
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-250.
      *              *-------------------------------------------------*
      *              * Test su presenza segno algebrico                *
      *              *-------------------------------------------------*
           if        w-rig-tip-cmp (1)    not  = "N"
                     go to cnt-tdo-rig-300.
           if        w-rig-sgn-cmp (1)    =    spaces or
                     w-rig-sgn-cmp (1)    =    "S"
                     go to cnt-tdo-rig-300.
           move      "Presenza segno algebrico errata                   
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-300.
      *              *-------------------------------------------------*
      *              * Test su rappresentazione segno algebrico        *
      *              *-------------------------------------------------*
           if        w-rig-tip-cmp (1)    not  = "N"
                     go to cnt-tdo-rig-350.
           if        w-rig-sgn-cmp (1)    not  = "S"
                     go to cnt-tdo-rig-350.
           if        w-rig-trs-cmp (1)    =    "T" or
                     w-rig-trs-cmp (1)    =    "E"
                     go to cnt-tdo-rig-350.
           move      "Tipo rappresentazione segno algebrico errata      
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-350.
      *              *-------------------------------------------------*
      *              * Test su displacement campo                      *
      *              *-------------------------------------------------*
           if        w-rig-dsp-cmp (1)    not  = zero
                     go to cnt-tdo-rig-360.
           move      "Manca il displacement per il campo                
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-360.
           if        w-rig-dsp-cmp (1)    not  > 5120
                     go to cnt-tdo-rig-400.
           move      "Displacement per il campo errato                  
      -              "      "             to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-400.
      *              *-------------------------------------------------*
      *              * Test su valore campo                            *
      *              *-------------------------------------------------*
       cnt-tdo-rig-500.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo campo         *
      *                  *---------------------------------------------*
           if        w-rig-tip-cmp (1)    =    "N"
                     go to cnt-tdo-rig-700.
       cnt-tdo-rig-600.
      *                  *---------------------------------------------*
      *                  * Se tipo campo Alfanumerico                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-dec-cmp (1)      .
           move      spaces               to   w-rig-sgn-cmp (1)      .
           move      spaces               to   w-rig-trs-cmp (1)      .
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-700.
      *                  *---------------------------------------------*
      *                  * Se tipo campo Numerico                      *
      *                  *---------------------------------------------*
           if        w-rig-sgn-cmp (1)    not  = "S"
                     move  spaces         to   w-rig-trs-cmp (1)      .
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-999.
           exit.

