      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Distribuzione dati da [fcs] a testata e righe             *
      *    *-----------------------------------------------------------*
       dda-fcs-wtr-000.
      *              *-------------------------------------------------*
      *              * Descrizione filtro                              *
      *              *-------------------------------------------------*
           move      w-fcs-des-fcs        to   w-tes-des-fcs (1)      .
      *              *-------------------------------------------------*
      *              * Password filtro                                 *
      *              *-------------------------------------------------*
           move      w-fcs-pwd-fcs        to   w-tes-pwd-fcs (1)      .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero parametri per filtro    *
      *              * di conversione                                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-nup-fcs (1)      .
       dda-fcs-wtr-100.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore su array nel record  *
      *              * da 1 a 36                                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-agg-rig-ctr          .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero progressivo riga vir-   *
      *              * tuale                                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-agg-rig-prg          .
       dda-fcs-wtr-200.
      *              *-------------------------------------------------*
      *              * Incremento contatore su array nel record da 1 a *
      *              * 36                                              *
      *              *-------------------------------------------------*
           add       1                    to   w-agg-rig-ctr          .
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : a conclusione             *
      *              *-------------------------------------------------*
           if        w-agg-rig-ctr        >    36
                     go to dda-fcs-wtr-700.
      *              *-------------------------------------------------*
      *              * Se tipo operazione non riconosciuta : si ignora *
      *              * l'elemento                                      *
      *              *-------------------------------------------------*
           if        w-fcs-tip-ope
                    (w-agg-rig-ctr)       <    01 or
                     w-fcs-tip-ope
                    (w-agg-rig-ctr)       >    05
                     go to dda-fcs-wtr-200.
      *              *-------------------------------------------------*
      *              * Incremento numero parametri per filtro di con-  *
      *              * versione                                        *
      *              *-------------------------------------------------*
           add       1                    to   w-tes-nup-fcs (1)      .
      *              *-------------------------------------------------*
      *              * Incremento numero progressivo riga virtuale     *
      *              *-------------------------------------------------*
           add       100                  to   w-agg-rig-prg          .
       dda-fcs-wtr-300.
      *              *-------------------------------------------------*
      *              * Composizione riga                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero progressivo virtuale                 *
      *                  *---------------------------------------------*
           move      w-agg-rig-prg        to   w-rig-num-prg (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo operazione                             *
      *                  *---------------------------------------------*
           move      w-fcs-tip-ope
                    (w-agg-rig-ctr)       to   w-rig-tip-ope (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo campo                                  *
      *                  *---------------------------------------------*
           move      w-fcs-tip-cmp
                    (w-agg-rig-ctr)       to   w-rig-tip-cmp (1)      .
      *                  *---------------------------------------------*
      *                  * Numero caratteri                            *
      *                  *---------------------------------------------*
           move      w-fcs-car-cmp
                    (w-agg-rig-ctr)       to   w-rig-car-cmp (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali                             *
      *                  *---------------------------------------------*
           move      w-fcs-dec-cmp
                    (w-agg-rig-ctr)       to   w-rig-dec-cmp (1)      .
      *                  *---------------------------------------------*
      *                  * Presenza segno algebrico                    *
      *                  *---------------------------------------------*
           move      w-fcs-sgn-cmp
                    (w-agg-rig-ctr)       to   w-rig-sgn-cmp (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo rappresentazione per il segno algebri- *
      *                  * co                                          *
      *                  *---------------------------------------------*
           move      w-fcs-trs-cmp
                    (w-agg-rig-ctr)       to   w-rig-trs-cmp (1)      .
      *                  *---------------------------------------------*
      *                  * Displacement per il campo                   *
      *                  *---------------------------------------------*
           move      w-fcs-dsp-cmp
                    (w-agg-rig-ctr)       to   w-rig-dsp-cmp (1)      .
      *                  *---------------------------------------------*
      *                  * Valore per il campo                         *
      *                  *---------------------------------------------*
           move      w-fcs-val-cmp
                    (w-agg-rig-ctr)       to   w-rig-val-cmp (1)      .
       dda-fcs-wtr-400.
      *                  *---------------------------------------------*
      *                  * Valori attuali riga su valori precedenti,   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se in Inserimento : no duplicazione     *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to dda-fcs-wtr-500.
      *                      *-----------------------------------------*
      *                      * Duplicazione                            *
      *                      *-----------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
       dda-fcs-wtr-500.
      *                  *---------------------------------------------*
      *                  * Put su catena movimenti [rig]               *
      *                  *---------------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      w-rig-num-prg (1)    to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       dda-fcs-wtr-600.
      *                  *---------------------------------------------*
      *                  * Riciclo ad elemento successivo              *
      *                  *---------------------------------------------*
           go to     dda-fcs-wtr-200.
       dda-fcs-wtr-700.
      *                  *---------------------------------------------*
      *                  * Valori attuali testata su valori precedenti *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se in Inserimento : no duplicazione     *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to dda-fcs-wtr-800.
      *                      *-----------------------------------------*
      *                      * Duplicazione                            *
      *                      *-----------------------------------------*
           move      w-tes-val-aep (1)    to   w-tes-val-aep (2)      .
       dda-fcs-wtr-800.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     dda-fcs-wtr-999.
       dda-fcs-wtr-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-accettazioni per inserimento                  *
      *    *-----------------------------------------------------------*
       pre-acc-ins-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-acc-ins      .
       pre-acc-ins-100.
      *              *-------------------------------------------------*
      *              * Duplicazione record precedente se richiesto     *
      *              *-------------------------------------------------*
       pre-acc-ins-110.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-cnt-dup-rec-flg    =    spaces
                     go to pre-acc-ins-900.
       pre-acc-ins-120.
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di duplicazione     *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-dup-rec-flg      .
       pre-acc-ins-130.
      *                  *---------------------------------------------*
      *                  * Clonazione                                  *
      *                  *---------------------------------------------*
       pre-acc-ins-140.
      *                      *-----------------------------------------*
      *                      * Lettura filtro da clonare e sua collo-  *
      *                      * cazione in area di ridefinizione        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura                             *
      *                          *-------------------------------------*
           move      "RD"                 to   j-ope                  .
           move      "FCS"                to   j-tre                  .
           move      w-tes-cod-fcs        to   j-kre                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
      *                          *-------------------------------------*
      *                          * Se record non trovato : uscita      *
      *                          *-------------------------------------*
           if        j-rsc                not  = spaces
                     go to rou-let-reg-900.
      *                          *-------------------------------------*
      *                          * Record in area di ridefinizione     *
      *                          *-------------------------------------*
           move      j-dat                to   w-fcs                  .
       pre-acc-ins-150.
      *                      *-----------------------------------------*
      *                      * Distribuzione dati per testata e righe  *
      *                      *-----------------------------------------*
           perform   dda-fcs-wtr-000      thru dda-fcs-wtr-999        .
       pre-acc-ins-160.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flags di controllo          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di impostazione pagine di testata  *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-tes      .
           move      all   "#"            to   w-cnt-sts-imp-pte      .
      *                      *-----------------------------------------*
      *                      * Flag di ingresso in pagine di testata   *
      *                      *-----------------------------------------*
           move      all   "#"            to   w-cnt-sts-ing-pte      .
      *                      *-----------------------------------------*
      *                      * Flag di impostazione corpo              *
      *                      *-----------------------------------------*
           move      all   "#"            to   w-cnt-sts-imp-cor      .
      *                      *-----------------------------------------*
      *                      * Flag di impostazione piede              *
      *                      *-----------------------------------------*
           move      all   "#"            to   w-cnt-sts-imp-pie      .
       pre-acc-ins-170.
      *                  *---------------------------------------------*
      *                  * Visualizzazione pagina di testata           *
      *                  *---------------------------------------------*
           perform   vis-tes-reg-000      thru vis-tes-reg-999        .
       pre-acc-ins-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
       pre-acc-ins-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-accettazioni per modifica                     *
      *    *-----------------------------------------------------------*
       pre-acc-mod-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-acc-mod      .
      *              *-------------------------------------------------*
      *              * Normalizzazione segnale di duplicazione         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-dup-rec-flg      .
       pre-acc-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-accettazioni per visualizzazione              *
      *    *-----------------------------------------------------------*
       pre-acc-vis-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-acc-vis      .
      *              *-------------------------------------------------*
      *              * Normalizzazione segnale di duplicazione         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-dup-rec-flg      .
       pre-acc-vis-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-richiesta di ratifica tasto Delete            *
      *    *-----------------------------------------------------------*
       pre-snx-del-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-snx-del      .
       pre-snx-del-999.
           exit.

      *    *===========================================================*
      *    * Routine post-richiesta di ratifica tasto Delete           *
      *    *-----------------------------------------------------------*
       pos-snx-del-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pos-snx-del      .
       pos-snx-del-999.
           exit.

      *    *===========================================================*
      *    * Routine post-exit su inserimento                          *
      *    *-----------------------------------------------------------*
       pos-exi-ins-000.
       pos-exi-ins-999.
           exit.

      *    *===========================================================*
      *    * Routine post-exit su modifica                             *
      *    *-----------------------------------------------------------*
       pos-exi-mod-000.
       pos-exi-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine post-exit su visualizzazione                      *
      *    *-----------------------------------------------------------*
       pos-exi-vis-000.
       pos-exi-vis-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Scrittura movimento su files                    *
      *              *-------------------------------------------------*
           perform   scr-mov-fil-000      thru scr-mov-fil-999        .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Scrittura movimento su files                    *
      *              *-------------------------------------------------*
           perform   scr-mov-fil-000      thru scr-mov-fil-999        .
       pos-cnf-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Delete movimento da files                       *
      *              *-------------------------------------------------*
           perform   del-mov-fil-000      thru del-mov-fil-999        .
       pos-cnf-ann-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se inserimento                                  *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Write record [fcs]                          *
      *                  *---------------------------------------------*
           perform   wrt-rec-fcs-000      thru wrt-rec-fcs-999        .
           go to     scr-mov-fil-999.
       scr-mov-fil-500.
      *              *-------------------------------------------------*
      *              * Se modifica                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Rewrite record [fcs]                        *
      *                  *---------------------------------------------*
           perform   rew-rec-fcs-000      thru rew-rec-fcs-999        .
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Delete record [fcs]                             *
      *              *-------------------------------------------------*
           perform   del-rec-fcs-000      thru del-rec-fcs-999        .
       del-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record                                       *
      *    *-----------------------------------------------------------*
       cmp-rec-fcs-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   j-ope                  .
           move      "FCS"                to   j-tre                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
           move      j-dat                to   w-fcs                  .
       cmp-rec-fcs-200.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
       cmp-rec-fcs-210.
      *                  *---------------------------------------------*
      *                  * Codice filtro                               *
      *                  *---------------------------------------------*
           move      w-tes-cod-fcs        to   w-fcs-cod-fcs          .
       cmp-rec-fcs-220.
      *                  *---------------------------------------------*
      *                  * Descrizione filtro                          *
      *                  *---------------------------------------------*
           move      w-tes-des-fcs (1)    to   w-fcs-des-fcs          .
       cmp-rec-fcs-230.
      *                  *---------------------------------------------*
      *                  * Password filtro                             *
      *                  *---------------------------------------------*
           move      w-tes-pwd-fcs (1)    to   w-fcs-pwd-fcs          .
       cmp-rec-fcs-240.
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero elementi            *
      *                  *---------------------------------------------*
           move      zero                 to   w-fcs-num-pcv          .
       cmp-rec-fcs-300.
      *                  *---------------------------------------------*
      *                  * Elementi                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start su righe corpo                    *
      *                      *-----------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Se start non valida : fine righe        *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to cmp-rec-fcs-900.
       cmp-rec-fcs-400.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale righe corpo         *
      *                      *-----------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Se at end : fine righe                  *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to cmp-rec-fcs-900.
      *                      *-----------------------------------------*
      *                      * Movimento da buffer catena movimenti a  *
      *                      * work                                    *
      *                      *-----------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                      *-----------------------------------------*
      *                      * Se tipo operazione non valido : si i-   *
      *                      * gnora la riga                           *
      *                      *-----------------------------------------*
           if        w-rig-tip-ope (1)    <    01 or
                     w-rig-tip-ope (1)    >    05
                     go to cmp-rec-fcs-400.
      *                      *-----------------------------------------*
      *                      * Incremento numero elementi              *
      *                      *-----------------------------------------*
           add       1                    to   w-fcs-num-pcv          .
      *                      *-----------------------------------------*
      *                      * Test su numero elementi                 *
      *                      *-----------------------------------------*
           if        w-fcs-num-pcv        not  >    36
                     go to cmp-rec-fcs-500.
           subtract  1                    from w-fcs-num-pcv          .
           move      "Attenzione : non sono ammesse piu' di 36 operazion
      -              "i     "             to   w-err-tdo-nok-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     cmp-rec-fcs-999.
       cmp-rec-fcs-500.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione elemento                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      w-rig-tip-ope (1)    to   w-fcs-tip-ope
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Tipo campo                          *
      *                          *-------------------------------------*
           move      w-rig-tip-cmp (1)    to   w-fcs-tip-cmp
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Numero caratteri                    *
      *                          *-------------------------------------*
           move      w-rig-car-cmp (1)    to   w-fcs-car-cmp
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Numero decimali                     *
      *                          *-------------------------------------*
           move      w-rig-dec-cmp (1)    to   w-fcs-dec-cmp
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Presenza segno algebrico            *
      *                          *-------------------------------------*
           move      w-rig-sgn-cmp (1)    to   w-fcs-sgn-cmp
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Tipo di rappresentazione per il se- *
      *                          * gno algebrico                       *
      *                          *-------------------------------------*
           move      w-rig-trs-cmp (1)    to   w-fcs-trs-cmp
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Displacement per il campo           *
      *                          * gno algebrico                       *
      *                          *-------------------------------------*
           move      w-rig-dsp-cmp (1)    to   w-fcs-dsp-cmp
                                              (w-fcs-num-pcv)         .
      *                          *-------------------------------------*
      *                          * Valore per il campo                 *
      *                          *-------------------------------------*
           move      w-rig-val-cmp (1)    to   w-fcs-val-cmp
                                              (w-fcs-num-pcv)         .
       cmp-rec-fcs-600.
      *                      *-----------------------------------------*
      *                      * A riga successiva                       *
      *                      *-----------------------------------------*
           go to     cmp-rec-fcs-400.
       cmp-rec-fcs-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cmp-rec-fcs-999.
       cmp-rec-fcs-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [fcs]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-fcs-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-fcs-000      thru cmp-rec-fcs-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   j-ope                  .
           move      "FCS"                to   j-tre                  .
           move      w-fcs-cod-fcs        to   j-kre                  .
           move      w-fcs                to   j-dat                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
       wrt-rec-fcs-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record [fcs]                                  *
      *    *-----------------------------------------------------------*
       rew-rec-fcs-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-fcs-000      thru cmp-rec-fcs-999        .
      *              *-------------------------------------------------*
      *              * Update record                                   *
      *              *-------------------------------------------------*
           move      "UP"                 to   j-ope                  .
           move      "FCS"                to   j-tre                  .
           move      w-fcs-cod-fcs        to   j-kre                  .
           move      w-fcs                to   j-dat                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
       rew-rec-fcs-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record [fcs]                                *
      *    *-----------------------------------------------------------*
       del-rec-fcs-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-fcs-000      thru cmp-rec-fcs-999        .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   j-ope                  .
           move      "FCS"                to   j-tre                  .
           move      w-fcs-cod-fcs        to   j-kre                  .
           move      w-fcs                to   j-dat                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
       del-rec-fcs-999.
           exit.
