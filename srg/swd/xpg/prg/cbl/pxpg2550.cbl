      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rr-dat-exe             .
           move      s-tim (1 : 4)        to   rr-ora-exe             .
      *                  *---------------------------------------------*
      *                  * Determinazione literal giorno della setti-  *
      *                  * mana                                        *
      *                  *---------------------------------------------*
           move      "GS"                 to   s-ope                  .
           move      rr-dat-exe           to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-alf                to   rr-dat-exe-lit         .
       nor-ric-sel-999.
           exit.

