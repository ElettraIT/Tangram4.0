      *    *===========================================================*
      *    * Accettazione : Codice della procedura di salvataggio      *
      *    *-----------------------------------------------------------*
       acc-cod-bak-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-bak-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      rr-cod-bak           to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cod-bak-999.
       acc-cod-bak-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   rr-cod-bak             .
       acc-cod-bak-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-cod-bak-350.
      *                  *---------------------------------------------*
      *                  * Find su codici procedura di salvataggio     *
      *                  *---------------------------------------------*
           move      rr-cod-bak           to   w-fnd-auc-bak-cod      .
           perform   fnd-auc-bak-000      thru fnd-auc-bak-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-auc-bak-sel    not  = spaces
                     go to acc-cod-bak-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione codice selezionato           *
      *                  *---------------------------------------------*
           move      w-fnd-auc-bak-cod    to   rr-cod-bak             .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice selezionato          *
      *                  *---------------------------------------------*
           perform   vis-cod-bak-000      thru vis-cod-bak-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A controlli su impostazione                 *
      *                  *---------------------------------------------*
           go to     acc-cod-bak-400.
       acc-cod-bak-350.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-cod-bak-400.
      *                  *---------------------------------------------*
      *                  * Insr su codici procedura di salvataggio     *
      *                  *---------------------------------------------*
           perform   ins-auc-bak-000      thru ins-auc-bak-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-cod-bak-100.
       acc-cod-bak-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-bak-410.
      *                  *---------------------------------------------*
      *                  * Se codice a Spaces : si normalizzano e si   *
      *                  * visualizzano i campi derivati               *
      *                  *---------------------------------------------*
           if        rr-cod-bak           not  = spaces
                     go to acc-cod-bak-425.
      *                      *-----------------------------------------*
      *                      * Descrizione procedura                   *
      *                      *-----------------------------------------*
           move      spaces               to   rr-des-bak             .
           perform   vis-des-bak-000      thru vis-des-bak-999        .
      *                      *-----------------------------------------*
      *                      * Tipo unita' da utilizzare               *
      *                      *-----------------------------------------*
           move      zero                 to   rr-tip-dev             .
           perform   vis-tip-dev-000      thru vis-tip-dev-999        .
      *                      *-----------------------------------------*
      *                      * Password per l'esecuzione               *
      *                      *-----------------------------------------*
           move      spaces               to   rr-pwd-bak             .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-bak-100.
       acc-cod-bak-425.
      *                  *---------------------------------------------*
      *                  * Lettura codice procedura di salvataggio e   *
      *                  * deviazione secondo l'esito della lettura    *
      *                  *---------------------------------------------*
           move      "RD"                 to   j-ope                  .
           move      "BAK"                to   j-tre                  .
           move      rr-cod-bak           to   j-kre                  .
           call      "swd/mod/prg/obj/maucmf"
