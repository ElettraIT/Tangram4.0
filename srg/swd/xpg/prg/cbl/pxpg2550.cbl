      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     exe-prc-svt-std-900.
       exe-prc-svt-std-190.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           cancel    "swd/mod/prg/obj/mlsfil"                         .
       exe-prc-svt-std-200.
      *                  *---------------------------------------------*
      *                  * Ad esecuzione salvataggio effettivo         *
      *                  *---------------------------------------------*
           go to     exe-prc-svt-std-400.
       exe-prc-svt-std-400.
      *              *-------------------------------------------------*
      *              * Erase video                                     *
      *              *-------------------------------------------------*
           move      "ER"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-prc-svt-std-500.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per il richiamo del mo-  *
      *              * dulo per l'esecuzione di comandi di sistema     *
      *              *-------------------------------------------------*
       exe-prc-svt-std-510.
      *                  *---------------------------------------------*
      *                  * 1. parametro     : Tipo di unita' o pathna- *
      *                  *                    me del device driver     *
      *                  *---------------------------------------------*
           if        w-bak-tip-dev        =    01
                     move "b"             to   w-exe-cmd-p01
           else if   w-bak-tip-dev        =    02
                     move "a"             to   w-exe-cmd-p01
           else if   w-bak-tip-dev        =    03
                     move "f"             to   w-exe-cmd-p01
           else if   w-bak-tip-dev        =    99
                     move w-bak-pdd-uns   to   w-exe-cmd-p01
           else      move "b"             to   w-exe-cmd-p01          .
       exe-prc-svt-std-520.
      *                  *---------------------------------------------*
      *                  * 2. parametro     : Pathname directory di    *
      *                  *                    base                     *
      *                  *---------------------------------------------*
           move      w-bak-pth-dir        to   w-exe-cmd-p02          .
       exe-prc-svt-std-530.
      *                  *---------------------------------------------*
      *                  * 3. parametro     : Pathname control-file    *
      *                  *---------------------------------------------*
           move      w-exe-pth-uni        to   w-exe-cmd-p03          .
       exe-prc-svt-std-600.
      *              *-------------------------------------------------*
      *              * Richiamo del modulo per l'esecuzione di comandi *
      *              * di sistema contenuti in /abd                    *
      *              *-------------------------------------------------*
           move      "A0"                 to   o-ope                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
      *
           move      "A5"                 to   o-ope                  .
           move      "etc"                to   o-com                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
      *
           move      "X9"                 to   o-ope                  .
           move      "tarcntf"            to   o-com                  .
           move      spaces               to   o-shs                  .
           string    w-exe-cmd-p01
                                delimited by   spaces
                     " "
                                delimited by   size
                     w-exe-cmd-p02
                                delimited by   spaces
                     " "
                                delimited by   size
                     w-exe-cmd-p03
                                delimited by   spaces
                                          into o-shs                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
       exe-prc-svt-std-700.
      *              *-------------------------------------------------*
      *              * Erase video                                     *
      *              *-------------------------------------------------*
           move      "ER"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-prc-svt-std-800.
      *              *-------------------------------------------------*
      *              * Rimozione del control-file temporaneo           *
      *              *-------------------------------------------------*
           move      "PD"                 to   s-ope                  .
           move      w-exe-pth-uni        to   s-pat                  .
           move      "S"                  to   s-sts                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       exe-prc-svt-std-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-prc-svt-std-999.
       exe-prc-svt-std-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione procedura di salvataggio tipo standard         *
      *    *-----------------------------------------------------------*
       exe-prc-svt-bat-000.
      *              *-------------------------------------------------*
      *              * Richiesta alla segreteria di esecuzione di una  *
      *              * procedura batch standard, definita in /abd/bat, *
      *              * con richiesta di salvataggio e ripristino video *
      *              *-------------------------------------------------*
           move      "XB"                 to   s-ope                  .
           move      w-bak-pdd-uns        to   s-alf                  .
           move      "S"                  to   s-svv                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       exe-prc-svt-bat-999.
           exit.

      *    *===========================================================*
      *    * Routine ciclo di attesa                                   *
      *    *-----------------------------------------------------------*
       rou-ccl-att-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esecuzione interrotta   *
      *              *-------------------------------------------------*
           move      spaces               to   w-exe-flg-ein          .
      *              *-------------------------------------------------*
      *              * Test su data ed ora di esecuzione               *
      *              *-------------------------------------------------*
           if        rr-dat-exe           =    zero or
                     rr-ora-exe           =    zero
                     go to rou-ccl-att-900.
       rou-ccl-att-100.
      *              *-------------------------------------------------*
      *              * Tentativo di esecuzione iniziale                *
      *              *-------------------------------------------------*
           go to     rou-ccl-att-220.
       rou-ccl-att-200.
      *              *-------------------------------------------------*
      *              * Messaggi di attesa                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      23                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "[F1] Per sbloccare attesa esecuzione              
      -              " [F2] Per annullare esecuzione"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      24                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "           ***   I N   A T T E S A   D I   E S E C
      -              " U Z I O N E   ***            "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rou-ccl-att-205.
      *              *-------------------------------------------------*
      *              * Attesa di 5 minuti (300 secondi)                *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-ctr-att          .
       rou-ccl-att-210.
           add       1                    to   w-exe-ctr-att          .
           if        w-exe-ctr-att        >    300
                     go to rou-ccl-att-220.
      *                  *---------------------------------------------*
      *                  * Frazione di attesa da un secondo            *
      *                  *---------------------------------------------*
           call      "swd/mod/prg/obj/mwait0"                         .
       rou-ccl-att-212.
      *                  *---------------------------------------------*
      *                  * Accettazione del tasto per l'interruzione   *
      *                  * dell'attesa                                 *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           move      "AA"                 to   v-ope                  .
           move      21                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "[1] "               to   v-pfk (14)             .
           move      "[2] "               to   v-pfk (15)             .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Se attesa disattivata : ad uscita       *
      *                      *-----------------------------------------*
           if        v-key                =    spaces
                     go to rou-ccl-att-210.
       rou-ccl-att-214.
      *                      *-----------------------------------------*
      *                      * Se 'Pf1'                                *
      *                      *-----------------------------------------*
           if        v-key                not  = "[1] "
                     go to rou-ccl-att-216.
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     rou-ccl-att-300.
       rou-ccl-att-216.
      *                      *-----------------------------------------*
      *                      * Se 'Pf2'                                *
      *                      *-----------------------------------------*
           if        v-key                not  = "[2] "
                     go to rou-ccl-att-210.
      *                          *-------------------------------------*
      *                          * Flag di uscita                      *
      *                          *-------------------------------------*
           move      "#"                  to   w-exe-flg-ein          .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     rou-ccl-att-300.
       rou-ccl-att-220.
      *                  *---------------------------------------------*
      *                  * Ora di sistema                              *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Confronto con la data                       *
      *                  *---------------------------------------------*
           if        s-dat                <    rr-dat-exe
                     go to rou-ccl-att-200.
      *                  *---------------------------------------------*
      *                  * Confronto con l'ora                         *
      *                  *---------------------------------------------*
           if        s-tim (1 : 4)        not  < rr-ora-exe
                     go to rou-ccl-att-300.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     rou-ccl-att-200.
       rou-ccl-att-300.
      *              *-------------------------------------------------*
      *              * Pulizia linea 23 e 24                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      23                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all spaces           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      24                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all spaces           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rou-ccl-att-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-ccl-att-999.
       rou-ccl-att-999.
           exit.

