      *    *===========================================================*
      *    * Visualizzazione :  Tipo di unita' da utilizzare           *
      *    *-----------------------------------------------------------*
       vis-tip-dev-000.
      *              *-------------------------------------------------*
      *              * Prompt per tipo unita' da utilizzare            *
      *              *-------------------------------------------------*
           perform   pmt-tip-dev-000      thru pmt-tip-dev-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      21                   to   v-pos                  .
           if        rr-tip-dev           =    zero or
                     rr-tip-dev           =    55
                     move  spaces         to   v-alf
           else if   rr-tip-dev           =    01
                     move  "Unita' per backup             "
                                          to   v-alf
           else if   rr-tip-dev           =    02
                     move  "Unita' per aggiorn. software  "
                                          to   v-alf
           else if   rr-tip-dev           =    03
                     move  "Unita' per floppy disk        "
                                          to   v-alf
           else if   rr-tip-dev           =    99
                     move  "Unita' speciale               "
                                          to   v-alf
           else      move  all "."        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-dev-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Password per l'esecuzione                  *
      *    *-----------------------------------------------------------*
       acc-pwd-bak-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-pwd-bak-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ute-tip-ute        =    02
                     go to acc-pwd-bak-999.
           if        w-bak-pwd-bak        =    spaces
                     go to acc-pwd-bak-999.
       acc-pwd-bak-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione                                *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      rr-pwd-bak           to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                  *---------------------------------------------*
      *                  * Valore impostato in campo di destinazione   *
      *                  *---------------------------------------------*
           move      v-alf                to   rr-pwd-bak             .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione a spaces                  *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-pwd-bak-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-pwd-bak-999.
       acc-pwd-bak-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pwd-bak-425.
      *                  *---------------------------------------------*
      *                  * Test che il valore non manchi, e che cor-   *
      *                  * risponda alla password. A meno che non si   *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pwd-bak-600.
           if        rr-pwd-bak           =    spaces
                     go to acc-pwd-bak-100.
           if        rr-pwd-bak           not  = w-bak-pwd-bak
                     go to acc-pwd-bak-100.
       acc-pwd-bak-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pwd-bak-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-pwd-bak-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-pwd-bak-100.
       acc-pwd-bak-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Data di esecuzione                         *
      *    *-----------------------------------------------------------*
       acc-dat-exe-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dat-exe-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      rr-dat-exe           to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-dat-exe-999.
       acc-dat-exe-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   rr-dat-exe             .
       acc-dat-exe-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data a zero non accettabile                 *
      *                  *---------------------------------------------*
           if        rr-dat-exe           =    zero
                     go to acc-dat-exe-100.
      *                  *---------------------------------------------*
      *                  * Data inferiore a quella attuale non accet-  *
      *                  * tabile                                      *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-dat-exe           not  < s-dat
                     go to acc-dat-exe-500.
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           move      "Data antecedente inaccettabile !                  
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-dat-exe-100.
       acc-dat-exe-500.
      *                  *---------------------------------------------*
      *                  * Data superiore a quella attuale non accet-  *
      *                  * tabile se oltre 3 giorni                    *
      *                  *---------------------------------------------*
           move      s-dat                to   w-det-dat-nrg-dtb      .
           move      3                    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-dat-exe           not  > w-det-dat-nrg-dti
                     go to acc-dat-exe-600.
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           move      "Data futura inaccettabile !                       
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-dat-exe-100.
       acc-dat-exe-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione literal giorno della setti-  *
      *                  * mana                                        *
      *                  *---------------------------------------------*
           move      "GS"                 to   s-ope                  .
           move      rr-dat-exe           to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-alf                to   rr-dat-exe-lit         .
           perform   vis-dat-exe-lit-000  thru vis-dat-exe-lit-999    .
       acc-dat-exe-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-exe-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-exe-100.
       acc-dat-exe-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Data di esecuzione                      *
      *    *-----------------------------------------------------------*
       vis-dat-exe-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      rr-dat-exe           to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-exe-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Data di esecuzione, literal             *
      *    *-----------------------------------------------------------*
       vis-dat-exe-lit-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      rr-dat-exe-lit       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-exe-lit-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Ora di esecuzione                    *
      *    *-----------------------------------------------------------*
       acc-ora-exe-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        rr-dat-exe           =    zero
                     go to acc-ora-exe-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio in campo di comodo              *
      *                  *---------------------------------------------*
           move      rr-ora-exe           to   w-exe-ora-exe          .
       acc-ora-exe-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "MB"                 to   v-edm                  .
           move      "XX:XX"              to   v-msk                  .
           move      13                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      rr-ora-exe           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-ora-exe-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   rr-ora-exe             .
       acc-ora-exe-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-ora-exe-400.
      *                  *---------------------------------------------*
      *                  * Ora attuale                                 *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-tim (1 : 4)        to   rr-ora-exe             .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-ora-exe-100.
       acc-ora-exe-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ora a zero non accettabile                  *
      *                  *---------------------------------------------*
           if        rr-ora-exe           =    zero
                     go to acc-ora-exe-100.
      *                  *---------------------------------------------*
      *                  * Controllo che :                             *
      *                  *  - l'ora sia compresa tra      00 e 23      *
      *                  *  - i minuti siano compresi tra 00 e 59      *
      *                  *---------------------------------------------*
           if        rr-ora-exe           >    2359
                     go to acc-ora-exe-100.
           multiply  100                  by   rr-ora-exe             .
           if        rr-ora-exe           >    5900
                     move  v-num          to   rr-ora-exe
                     go to acc-ora-exe-100
           else      move  v-num          to   rr-ora-exe             .
      *                  *---------------------------------------------*
      *                  * Ora inferiore a quella attuale non accet-   *
      *                  * tabile                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se valore accettato diverso da     *
      *                      * quello di default                       *
      *                      *-----------------------------------------*
           if        rr-ora-exe           =    w-exe-ora-exe
                     go to acc-ora-exe-600.
      *                      *-----------------------------------------*
      *                      * Determinazione ora attuale              *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Test se la data e' la stessa di quella  *
      *                      * di esecuzione                           *
      *                      *-----------------------------------------*
           if        rr-dat-exe           not  = s-dat
                     go to acc-ora-exe-600.
      *                      *-----------------------------------------*
      *                      * Test se ora richiesta inferiore a quel- *
      *                      * la attuale                              *
      *                      *-----------------------------------------*
           if        rr-ora-exe (1 : 2)   <    s-tim (1 : 2)
                     go to acc-ora-exe-100.
       acc-ora-exe-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ora-exe-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-ora-exe-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-ora-exe-100.
       acc-ora-exe-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Ora di esecuzione                 *
      *    *-----------------------------------------------------------*
       vis-ora-exe-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "MB"                 to   v-edm                  .
           move      "XX:XX"              to   v-msk                  .
           move      13                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      rr-ora-exe           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ora-exe-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su codice procedura di salvataggio    *
      *              *-------------------------------------------------*
           if        rr-cod-bak           not  = spaces
                     go to tdo-ric-sel-200.
           move      "Manca il codice della procedura di salvataggio !  
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo sull'abilitazione alla procedura      *
      *              *-------------------------------------------------*
           if        w-ute-tip-ute        =    02
                     go to tdo-ric-sel-300.
           if        w-bak-tut-abl        not  = 02
                     go to tdo-ric-sel-300.
           move      "Manca l'abilitazione per l'esecuzione della proced
      -              "ura !          "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo sullo status della procedura          *
      *              *-------------------------------------------------*
           if        w-ute-tip-ute        =    02
                     go to tdo-ric-sel-400.
           if        w-bak-sts-bak        not  = 02
                     go to tdo-ric-sel-400.
           move      "L'esecuzione della procedura e' bloccata a tutti g
      -              "li utenti !    "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Controllo sulla password per l'esecuzione       *
      *              *-------------------------------------------------*
           if        w-ute-tip-ute        =    02
                     go to tdo-ric-sel-500.
           if        w-bak-pwd-bak        =    spaces
                     go to tdo-ric-sel-500.
           if        rr-pwd-bak           not  = spaces
                     go to tdo-ric-sel-500.
           move      "Manca la password per l'esecuzione della procedura
      -              " !             "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-500.
      *              *-------------------------------------------------*
      *              * Data di esecuzione                              *
      *              *-------------------------------------------------*
           if        rr-dat-exe           not  = zero
                     go to tdo-ric-sel-600.
           move      "Manca la data di esecuzione !                     
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-600.
      *              *-------------------------------------------------*
      *              * Ora di esecuzione                               *
      *              *-------------------------------------------------*
           if        rr-ora-exe           not  = zero
                     go to tdo-ric-sel-800.
           move      "Manca l'ora di esecuzione !                       
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
           move      spaces               to   rr-cod-bak             .
           move      spaces               to   rr-des-bak             .
           move      zero                 to   rr-tip-dev             .
           move      spaces               to   rr-pwd-bak             .
       nor-ric-sel-200.
      *              *-------------------------------------------------*
