           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      rr-cod-bak           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bak-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione :  Descrizione della procedura di salva-  *
      *    *                    taggio                                 *
      *    *-----------------------------------------------------------*
       vis-des-bak-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      21                   to   v-pos                  .
