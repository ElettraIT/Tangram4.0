      *                  * Accettazione carattere di risposta          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Default per la risposta                 *
      *                      *-----------------------------------------*
           move      "N"                  to   w-rmv-prf-acc          .
       can-prf-sel-350.
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "DELT"               to   v-pfk (19)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-rmv-prf-acc        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Normalizzazione carattere di risposta   *
      *                      * se premuto un tasto funzione            *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  " or
                     v-key                =    "REMV" or
                     v-key                =    "DELT"
                     move  "S"            to   v-alf                  .
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Memorizzazione carattere di risposta    *
      *                      *-----------------------------------------*
           move      v-alf                to   w-rmv-prf-acc          .
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del carattere di *
      *                      * risposta                                *
      *                      *-----------------------------------------*
