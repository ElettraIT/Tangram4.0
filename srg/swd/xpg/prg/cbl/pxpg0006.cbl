                     move  "Conferma cancellazione dell'archivio-stampa 
      -                    "selezionato (S/N) ?   "
                                          to   v-alf
                     go to can-prf-sel-220.
      *                      *-----------------------------------------*
      *                      * Se piu' elementi                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing numero elementi             *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-rap-c02-prf        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
