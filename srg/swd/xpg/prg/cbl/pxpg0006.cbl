      *    *===========================================================*
      *    * Rilascio impegno della stampante                          *
      *    *-----------------------------------------------------------*
       ril-imp-stp-000.
      *              *-------------------------------------------------*
      *              * Se stampante locale : uscita immediata senza    *
      *              * alcuna azione                                   *
      *              *-------------------------------------------------*
           if        w-rim-stp-cod-stp
                    (01 : 01)             =    "#"
                     go to ril-imp-stp-999.
      *              *-------------------------------------------------*
      *              * Se stampante in spool : uscita immediata        *
      *              *-------------------------------------------------*
           if        w-rim-stp-can-stp
                    (01 : 05)             =    "spool"
                     go to ril-imp-stp-999.
      *              *-------------------------------------------------*
      *              * Se stampante in remote copy : uscita immediata  *
      *              *-------------------------------------------------*
           if        w-rim-stp-can-stp
                    (01 : 03)             =    "rcp"
                     go to ril-imp-stp-999.
      *              *-------------------------------------------------*
      *              * Se stampante tipo 'ucp' : uscita immediata      *
      *              *-------------------------------------------------*
           if        w-rim-stp-can-stp
                    (01 : 03)             =    "ucp"
                     go to ril-imp-stp-999.
      *              *-------------------------------------------------*
      *              * Se stampante tipo 'ucp' : uscita immediata      *
      *              *-------------------------------------------------*
           if        w-rim-stp-can-stp
                    (01 : 03)             =    "ghs"
                     go to ril-imp-stp-999.
       ril-imp-stp-050.
      *              *-------------------------------------------------*
      *              * Lettura record impegno con lock                 *
      *              *-------------------------------------------------*
           move      "imp "               to   pss-tre                .
           move      w-rim-stp-can-stp    to   pss-kre                .
           move      e-not-err            to   e-sts                  .
           read      pss    invalid key
                            go to   ril-imp-stp-100.
           go to     ril-imp-stp-150.
       ril-imp-stp-100.
      *              *-------------------------------------------------*
      *              * Se record impegno non esistente                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Unlock                                      *
      *                  *---------------------------------------------*
           unlock    pss    records                                   .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     ril-imp-stp-999.
       ril-imp-stp-150.
      *              *-------------------------------------------------*
      *              * Test su status di errore di i-o da lettura      *
      *              *-------------------------------------------------*
           if        e-sts                not  = e-use-err
                     go to ril-imp-stp-200.
      *              *-------------------------------------------------*
      *              * Se record locked                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Si ritenta la lettura fino a che non si ri- *
      *                  * esce ad ottenere il record                  *
      *                  *---------------------------------------------*
           go to     ril-imp-stp-050.
       ril-imp-stp-200.
      *              *-------------------------------------------------*
      *              * Se errore grave                                 *
      *              *-------------------------------------------------*
           if        e-sts                =    e-not-err
                     go to ril-imp-stp-300.
       ril-imp-stp-250.
