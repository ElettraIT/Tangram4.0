      *                          * nale per stampa in spool : no ini-  *
      *                          * bizione                             *
      *                          *-------------------------------------*
           move      spaces               to   w-stp-ibz-fff          .
      *                          *-------------------------------------*
      *                          * Ubicazione abituale                 *
      *                          *-------------------------------------*
           move      spaces               to   w-stp-des-ubi          .
      *                          *-------------------------------------*
      *                          * Status stampante                    *
      *                          *-------------------------------------*
           move      spaces               to   w-stp-sts-stp          .
      *                          *-------------------------------------*
      *                          * Status di uscita ad errore          *
      *                          *-------------------------------------*
           move      "#"                  to   w-ope-pss-sts          .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     let-stp-pss-999.
       let-stp-pss-200.
      *                  *---------------------------------------------*
      *                  * Se codice stampante esistente               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione parametri letti         *
      *                      *-----------------------------------------*
           move      pss-dat              to   w-stp                  .
       let-stp-pss-999.
           exit.

      *    *===========================================================*
      *    * Lettura parametri correlati al modulo stampa il cui codi- *
      *    * ce e' in w-mod-cod-mod                                    *
      *    *-----------------------------------------------------------*
       let-mod-pss-000.
      *              *-------------------------------------------------*
      *              * Status di uscita a spaces                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-ope-pss-sts          .
      *              *-------------------------------------------------*
      *              * Lettura record codice modulo                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio codice modulo                   *
      *                  *---------------------------------------------*
           move      w-mod-cod-mod        to   w-sav-cod-mod          .
       let-mod-pss-050.
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "mod "               to   pss-tre                .
           move      w-sav-cod-mod        to   pss-kre                .
           move      e-not-err            to   e-sts                  .
           read      pss    with no lock
                            invalid key
                            go to   let-mod-pss-100.
      *                  *---------------------------------------------*
      *                  * Se errori                                   *
      *                  *---------------------------------------------*
           if        e-sts                =    e-not-err
                     go to let-mod-pss-200.
      *                      *-----------------------------------------*
      *                      * Se record locked si ricicla in lettura  *
      *                      *-----------------------------------------*
           if        e-sts                =    e-use-err
                     go to let-mod-pss-050.
      *                          *-------------------------------------*
      *                          * Emissione messaggio di errore       *
      *                          *-------------------------------------*
           move      f-pss-nam            to   w-box-err-nam          .
           move      f-pss-pat            to   w-box-err-pat          .
           move      03                   to   w-box-err-fun          .
           move      e-sts                to   w-box-err-cod          .
           perform   box-err-gio-000      thru box-err-gio-999        .
      *                          *-------------------------------------*
      *                          * Status di uscita ad errore          *
      *                          *-------------------------------------*
           move      "#"                  to   w-ope-pss-sts          .
      *                          *-------------------------------------*
      *                          * A normalizzazione area              *
      *                          *-------------------------------------*
           go to     let-mod-pss-100.
       let-mod-pss-100.
      *                  *---------------------------------------------*
      *                  * Se codice modulo non esistente              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione area codice modulo      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice modulo                       *
      *                          *-------------------------------------*
           move      w-sav-cod-mod        to   w-mod-cod-mod          .
      *                          *-------------------------------------*
      *                          * Descrizione modulo                  *
      *                          *-------------------------------------*
           move      spaces               to   w-mod-des-mod          .
           string    "Modulo "  delimited by   size
                     w-mod-cod-mod
                                delimited by   size
                                          into w-mod-des-mod          .
      *                          *-------------------------------------*
      *                          * Tipo modulo : nessuno               *
      *                          *-------------------------------------*
           move      spaces               to   w-mod-tip-mod          .
      *                          *-------------------------------------*
      *                          * Larghezza modulo in 72mi di polli-  *
      *                          * ce : zero                           *
      *                          *-------------------------------------*
           move      zero                 to   w-mod-l72-mod          .
      *                          *-------------------------------------*
      *                          * Altezza modulo in 72mi di pollice : *
      *                          * zero                                *
      *                          *-------------------------------------*
           move      zero                 to   w-mod-a72-mod          .
      *                          *-------------------------------------*
      *                          * Interlinee possibili per il modulo  *
      *                          * : tutte a zero                      *
      *                          *-------------------------------------*
           move      zero                 to   w-mod-int-mod (01)
                                               w-mod-int-mod (02)
                                               w-mod-int-mod (03)
                                               w-mod-int-mod (04)
                                               w-mod-int-mod (05)
                                               w-mod-int-mod (06)
                                               w-mod-int-mod (07)
                                               w-mod-int-mod (08)
                                               w-mod-int-mod (09)
                                               w-mod-int-mod (10)
                                               w-mod-int-mod (11)
                                               w-mod-int-mod (12)
                                               w-mod-int-mod (13)
                                               w-mod-int-mod (14)
                                               w-mod-int-mod (15)
                                               w-mod-int-mod (16)
                                               w-mod-int-mod (17)
                                               w-mod-int-mod (18)
                                               w-mod-int-mod (19)
                                               w-mod-int-mod (20)     .
      *                          *-------------------------------------*
      *                          * Classe di appartenenza : nessuna    *
      *                          *-------------------------------------*
           move      spaces               to   w-mod-cla-mod          .
      *                          *-------------------------------------*
      *                          * Sistema applicativo di appartenen-  *
      *                          * za : nessuno                        *
      *                          *-------------------------------------*
           move      spaces               to   w-mod-sap-mod          .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     let-mod-pss-999.
       let-mod-pss-200.
      *                  *---------------------------------------------*
      *                  * Se codice modulo esistente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione parametri letti         *
      *                      *-----------------------------------------*
           move      pss-dat              to   w-mod                  .
       let-mod-pss-999.
           exit.

      *    *===========================================================*
      *    * Raccolta print-files relativi all'azienda in uso per l'u- *
      *    * tente in uso                                              *
      *    *-----------------------------------------------------------*
       rac-prf-uso-000.
      *              *-------------------------------------------------*
      *              * Numero print-files raccolti : zero              *
      *              *-------------------------------------------------*
           move      zero                 to   w-rap-num-prf          .
       rac-prf-uso-100.
      *              *-------------------------------------------------*
      *              * Start su [pfc]                                  *
      *              *-------------------------------------------------*
           move      w-sgt-cod-ute        to   pfc-cod-ute-005        .
           move      w-sgt-cod-azi        to   pfc-cod-azi-005        .
           move      zero                 to   pfc-num-prg-005        .
           start     pfc    key not less
                            pfc-k05
                            invalid key
                            go to   rac-prf-uso-999.
       rac-prf-uso-200.
      *              *-------------------------------------------------*
      *              * Next su [pfc]                                   *
      *              *-------------------------------------------------*
           read      pfc    next
                            with no lock
                            at end
                            go to   rac-prf-uso-999.
       rac-prf-uso-300.
      *              *-------------------------------------------------*
      *              * Max su [pfc]                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se rottura utente : uscita                  *
      *                  *---------------------------------------------*
           if        pfc-cod-ute          not  = w-sgt-cod-ute
                     go to rac-prf-uso-999.
      *                  *---------------------------------------------*
      *                  * Se rottura azienda : uscita                 *
      *                  *---------------------------------------------*
           if        pfc-cod-azi          not  = w-sgt-cod-azi
                     go to rac-prf-uso-999.
       rac-prf-uso-400.
      *              *-------------------------------------------------*
      *              * Sel su [pfc]                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non e' un Print File : no selezione      *
      *                  *---------------------------------------------*
           if        pfc-tip-fil          not  = 01
                     go to rac-prf-uso-200.
       rac-prf-uso-500.
      *              *-------------------------------------------------*
      *              * Bufferizzazione print-file in tabella           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se oltre il numero massimo di elementi *
      *                  * previsti per la tabella                     *
      *                  *---------------------------------------------*
           if        w-rap-num-prf        not  < w-rap-max-prf
                     go to rac-prf-uso-800.
      *                  *---------------------------------------------*
      *                  * Numero print-files raccolti : +1            *
      *                  *---------------------------------------------*
           add       1                    to   w-rap-num-prf          .
      *                  *---------------------------------------------*
      *                  * Flag di elemento rimosso                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-rap-flg-rim
                                              (w-rap-num-prf)         .
      *                  *---------------------------------------------*
      *                  * Numero progressivo di print-file            *
      *                  *---------------------------------------------*
           move      pfc-num-prg          to   w-rap-num-prg
                                              (w-rap-num-prf)         .
      *                  *---------------------------------------------*
      *                  * Data inizio creazione                       *
      *                  *---------------------------------------------*
           move      pfc-dat-icr          to   w-rap-dat-icr
                                              (w-rap-num-prf)         .
      *                  *---------------------------------------------*
      *                  * Ora inizio creazione                        *
      *                  *---------------------------------------------*
           move      pfc-ora-icr          to   w-rap-ora-icr
                                              (w-rap-num-prf)         .
      *                  *---------------------------------------------*
      *                  * Numero pagine totali                        *
      *                  *---------------------------------------------*
           move      pfc-nmr-pgn          to   w-rap-nmr-pgn
                                              (w-rap-num-prf)         .
      *                  *---------------------------------------------*
      *                  * Fase gestionale del programma che ha creato *
      *                  * il print-file                               *
      *                  *---------------------------------------------*
           move      pfc-ide-fas          to   w-rap-ide-fas
                                              (w-rap-num-prf)         .
      *                  *---------------------------------------------*
      *                  * Status del print-file                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su data di fine creazione          *
      *                      *-----------------------------------------*
           if        pfc-dat-fcr          =    zero
                     move  01             to   w-rap-sts-prf
                                              (w-rap-num-prf)
                     go to rac-prf-uso-550.
      *                      *-----------------------------------------*
      *                      * Test se numero stampe effettive zero    *
      *                      *-----------------------------------------*
           if        pfc-num-sef          =    zero
                     move  02             to   w-rap-sts-prf
                                              (w-rap-num-prf)
                     go to rac-prf-uso-550.
      *                      *-----------------------------------------*
      *                      * Test se numero stampe effettive : una   *
      *                      *-----------------------------------------*
           if        pfc-num-sef          =    0001
                     move  04             to   w-rap-sts-prf
                                              (w-rap-num-prf)
                     go to rac-prf-uso-550.
      *                      *-----------------------------------------*
      *                      * Test se numero stampe effettive : piu'  *
      *                      * di una                                  *
      *                      *-----------------------------------------*
           if        pfc-num-sef          >    0001
                     move  06             to   w-rap-sts-prf
                                              (w-rap-num-prf)
                     go to rac-prf-uso-550.
      *                      *-----------------------------------------*
      *                      * Altrimenti : normalizzazione status     *
      *                      *-----------------------------------------*
           move      zero                 to   w-rap-sts-prf
                                              (w-rap-num-prf)         .
       rac-prf-uso-550.
      *                  *---------------------------------------------*
      *                  * Numero di stampe effettive gia' eseguite e  *
      *                  * completate per il print-file                *
      *                  *---------------------------------------------*
           move      pfc-num-sef          to   w-rap-num-sef
                                              (w-rap-num-prf)         .
       rac-prf-uso-600.
      *                  *---------------------------------------------*
      *                  * Segnale di visualizzazione effettuata       *
      *                  *---------------------------------------------*
           move      pfc-snx-vis          to   w-rap-snx-vis
                                              (w-rap-num-prf)         .
       rac-prf-uso-700.
      *              *-------------------------------------------------*
      *              * Riciclo a next                                  *
      *              *-------------------------------------------------*
           go to     rac-prf-uso-200.
       rac-prf-uso-800.
      *              *-------------------------------------------------*
      *              * Se oltre il numero massimo di elementi previsti *
      *              * per la tabella                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita senza alcuna segnalazione per tron-  *
      *                  * camento della tabella ai primi elementi     *
      *                  *---------------------------------------------*
           go to     rac-prf-uso-999.
       rac-prf-uso-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione print-files relativi all'azienda in uso   *
      *    * per l'utente in uso                                       *
      *    *-----------------------------------------------------------*
       vis-prf-uso-000.
      *              *-------------------------------------------------*
      *              * Test se numero print files raccolti pari a zero *
      *              *-------------------------------------------------*
           if        w-rap-num-prf        >    zero
                     go to vis-prf-uso-100.
       vis-prf-uso-010.
      *              *-------------------------------------------------*
      *              * Se numero print files raccolti pari a zero      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se l'utente in uso e'  *
      *                  * di tipo supervisore oppure no               *
      *                  *---------------------------------------------*
           if        w-ute-tip-ute        =    02
                     go to vis-prf-uso-030.
       vis-prf-uso-020.
      *                  *---------------------------------------------*
      *                  * Se l'utente in uso non e' supervisore       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box vuoto                               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      10                   to   v-lin                  .
           move      02                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      79                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Messaggio interno al box                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Non esiste nessun archivio-stampa memorizzato per 
      -              "l'utente ["
                                delimited by   size
                     w-sgt-cod-ute
                                delimited by   spaces
                     "] "       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Due punti                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Accettazione presa visione              *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      12                   to   v-lin                  .
           move      77                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Status di uscita ad indicare l'uscita   *
      *                      * dal programma senza alcuna azione       *
      *                      *-----------------------------------------*
           move      00                   to   w-vis-uso-exs          .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-prf-uso-999.
       vis-prf-uso-030.
      *                  *---------------------------------------------*
      *                  * Se l'utente in uso e' di tipo supervisore   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box vuoto                               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      10                   to   v-lin                  .
           move      02                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      79                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Messaggio interno al box                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Non esiste nessun archivio-stampa memorizzato per 
      -              "l'utente ["
                                delimited by   size
                     w-sgt-cod-ute
                                delimited by   spaces
                     "] "       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Due punti                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Accettazione presa visione              *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      12                   to   v-lin                  .
           move      77                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda della function-key *
      *                      * digitata dall'utente                    *
      *                      *-----------------------------------------*
           if        v-key                =    "INSR"
                     go to vis-prf-uso-040
           else      go to vis-prf-uso-050.
       vis-prf-uso-040.
      *                      *-----------------------------------------*
      *                      * Se Insr                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Status di uscita ad indicare l'ese- *
      *                          * cuzione della subroutine di gestio- *
      *                          * ne vera e propria                   *
      *                          *-------------------------------------*
           move      01                   to   w-vis-uso-exs          .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     vis-prf-uso-999.
       vis-prf-uso-050.
      *                      *-----------------------------------------*
      *                      * Se non Insr                             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Status di uscita ad indicare l'u-   *
      *                          * scita dal programma senza alcuna    *
      *                          * ulteriore azione                    *
      *                          *-------------------------------------*
           move      00                   to   w-vis-uso-exs          .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     vis-prf-uso-999.
       vis-prf-uso-100.
      *              *-------------------------------------------------*
      *              * Se numero print files raccolti maggiore di zero *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interrogazione su print-files raccolti      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione numero pagine da visua-  *
      *                      * lizzare                                 *
      *                      *-----------------------------------------*
           move      w-rap-num-prf        to   w-vis-uso-w01          .
           move      zero                 to   w-vis-uso-lup          .
           divide    w-vis-uso-epp        into w-vis-uso-w01
                                        giving w-vis-uso-npd
                                     remainder w-vis-uso-lup          .
           if        w-vis-uso-lup        >    zero
                     add   1              to   w-vis-uso-npd          .
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente visualizzata  *
      *                      * a 1                                     *
      *                      *-----------------------------------------*
           move      1                    to   w-vis-uso-npa          .
       vis-prf-uso-200.
      *                      *-----------------------------------------*
      *                      * Subroutine di visualizzazione pagina    *
      *                      *-----------------------------------------*
           perform   vis-prf-usp-000      thru vis-prf-usp-999        .
       vis-prf-uso-400.
      *                      *-----------------------------------------*
      *                      * Accettazioni su pagina                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Inizializzazione indice su tabella  *
      *                          * print-files relativo all'elemento   *
      *                          * attualmente in fase di trattamento  *
      *                          *-------------------------------------*
           move      w-vis-uso-ipe        to   w-vis-uso-iea          .
      *                          *-------------------------------------*
      *                          * Inizializzazione indice su linea a  *
      *                          * video relativa all'elemento attual- *
      *                          * lmente in fase di trattamento       *
      *                          *-------------------------------------*
           move      w-vis-uso-plv        to   w-vis-uso-ilv          .
       vis-prf-uso-450.
      *                          *-------------------------------------*
      *                          * Accettazione su mark-point          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Parametri generali              *
      *                              *---------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      w-vis-uso-ilv        to   v-lin                  .
           move      29                   to   v-pos                  .
       vis-prf-uso-455.
      *                              *---------------------------------*
      *                              * Function keys abilitate         *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Up                          *
      *                                  *-----------------------------*
           if        w-vis-uso-iea        >    w-vis-uso-ipe
                     move  "UP  "         to   v-pfk (01)             .
      *                                  *-----------------------------*
      *                                  * Down                        *
      *                                  *-----------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *                                  *-----------------------------*
      *                                  * Remv e Delt                 *
      *                                  *-----------------------------*
           if        w-rap-flg-rim
                    (w-vis-uso-iea)       not  = spaces
                     go to vis-prf-uso-457.
           if        w-rap-sts-prf
                    (w-vis-uso-iea)       not  = 01 and
                     w-rap-sts-prf
                    (w-vis-uso-iea)       not  = 02 and
                     w-rap-sts-prf
                    (w-vis-uso-iea)       not  = 04 and
                     w-rap-sts-prf
                    (w-vis-uso-iea)       not  = 06
                     go to vis-prf-uso-457.
           move      "REMV"               to   v-pfk (06)             .
           move      "DELT"               to   v-pfk (19)             .
       vis-prf-uso-457.
      *                                  *-----------------------------*
      *                                  * Prsc                        *
      *                                  *-----------------------------*
           if        w-vis-uso-npa        >    1
                     move  "PRSC"         to   v-pfk (07)             .
      *                                  *-----------------------------*
      *                                  * Nxsc                        *
      *                                  *-----------------------------*
