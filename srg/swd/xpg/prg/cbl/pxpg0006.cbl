                     move  "NXSC"         to   v-pfk (08)
                     move  "DOWN"         to   v-pfk (02)
           else if   w-int-pth-flf        =    spaces
                     move  "NXSC"         to   v-pfk (08)
                     move  "DOWN"         to   v-pfk (02)             .
      *                          *-------------------------------------*
      *                          * Tab                                 *
      *                          *-------------------------------------*
           if        w-int-pth-flf        =    spaces
                     move  "TAB "         to   v-pfk (09)             .
      *                          *-------------------------------------*
      *                          * Back                                *
      *                          *-------------------------------------*
           if        w-int-pth-npb        >    1
                     move  "BACK"         to   v-pfk (10)             .
      *                          *-------------------------------------*
      *                          * Prnt                                *
      *                          *-------------------------------------*
           move      "PRNT"               to   v-pfk (11)             .
      *                          *-------------------------------------*
      *                          * Left                                *
      *                          *-------------------------------------*
           if        w-int-pth-dsp        >    001
                     move  "LEFT"         to   v-pfk (12)             .
      *                          *-------------------------------------*
      *                          * Rght                                *
      *                          *-------------------------------------*
           move      w-int-pth-dsp        to   w-int-pth-w00          .
           add       080                  to   w-int-pth-w00          .
           subtract  1                    from w-int-pth-w00          .
           if        w-int-pth-w00        <    w-int-pth-amp
                     move  "RGHT"         to   v-pfk (13)             .
      *                          *-------------------------------------*
      *                          * Do                                  *
      *                          *-------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *                          *-------------------------------------*
      *                          * Exit                                *
      *                          *-------------------------------------*
           move      "EXIT"               to   v-pfk (20)             .
      *                      *-----------------------------------------*
      *                      * Linea e posizione                       *
      *                      *-----------------------------------------*
           move      24                   to   v-lin                  .
           move      w-int-pth-ack-pos    to   v-pos                  .
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione tasto funzione              *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     move  "PRSC"         to   v-key                  .
           if        v-key                =    "DOWN"
                     move  "NXSC"         to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tasto funzione     *
      *                  *---------------------------------------------*
           if        v-key                =    "FIND"
                     go to int-prf-080-895
           else if   v-key                =    "PRSC"
                     go to int-prf-080-845
           else if   v-key                =    "NXSC"
                     go to int-prf-080-850
           else if   v-key                =    "TAB "
                     go to int-prf-080-855
           else if   v-key                =    "BACK"
                     go to int-prf-080-860
           else if   v-key                =    "PRNT"
                     go to int-prf-080-865
           else if   v-key                =    "LEFT"
                     go to int-prf-080-870
           else if   v-key                =    "RGHT"
                     go to int-prf-080-875
           else if   v-key                =    "EXIT"
                     go to int-prf-080-885
           else if   v-key                =    "INSR"
                     go to int-prf-080-890
           else if   v-key                =    "DO  "
                     go to int-prf-080-844
           else      go to int-prf-080-842.
       int-prf-080-844.
      *                  *---------------------------------------------*
      *                  * Se funzione Do                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di memorizzazione, solo per il ca- *
      *                      * so di visualizzazione di un print-file  *
      *                      * passato come variabile di i.p.c. : Si   *
      *                      *-----------------------------------------*
           move      "M"                  to   w-int-pth-mem          .
      *                      *-----------------------------------------*
      *                      * Riciclo ad accettazione                 *
      *                      *-----------------------------------------*
           go to     int-prf-080-842.
       int-prf-080-845.
      *                  *---------------------------------------------*
      *                  * Se funzione Prsc                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Se si e' in un riquadro oltre il primo  *
      *                      * si visualizza il riquadro precedente,   *
      *                      * altrimenti si esce con status di usci-  *
      *                      * ta a '-'                                *
      *                      *-----------------------------------------*
           if        w-int-pth-nrb        >    1
                     subtract  1          from w-int-pth-nrb
                     go to     int-prf-080-805
           else      move      "-"        to   w-int-pth-flv
                     go to     int-prf-080-899.
       int-prf-080-850.
      *                  *---------------------------------------------*
      *                  * Se funzione Nxsc                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Se si e' prima dell'ultimo riquadro si  *
      *                      * visualizza il riquadro successivo, sl-  *
      *                      * trimenti si esce con status di uscita a *
      *                      * '+'                                     *
      *                      *-----------------------------------------*
           if        w-int-pth-nrb        <    w-int-pth-riq
                     add   1              to   w-int-pth-nrb
                     go to int-prf-080-805
           else      move      "+"        to   w-int-pth-flv
                     go to int-prf-080-899.
       int-prf-080-855.
      *                  *---------------------------------------------*
      *                  * Se funzione Tab                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Si esce con status di uscita a '1'      *
      *                      *-----------------------------------------*
           move      "9"                  to   w-int-pth-flv          .
           go to     int-prf-080-899.
       int-prf-080-860.
      *                  *---------------------------------------------*
      *                  * Se funzione Back                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Si esce con status di uscita a '1'      *
      *                      *-----------------------------------------*
           move      "1"                  to   w-int-pth-flv          .
           go to     int-prf-080-899.
       int-prf-080-865.
      *                  *---------------------------------------------*
      *                  * Se funzione Prnt                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Si esce con status di uscita a 'P'      *
      *                      *-----------------------------------------*
           move      "P"                  to   w-int-pth-flv          .
           go to     int-prf-080-899.
       int-prf-080-870.
      *                  *---------------------------------------------*
      *                  * Se funzione Left                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Decremento displacement del carattere   *
      *                      * relativo alla posizione 1               *
      *                      *-----------------------------------------*
           if        w-int-pth-dsp        >    w-int-pth-idd
                     subtract  w-int-pth-idd
                                          from w-int-pth-dsp
           else      move      001        to   w-int-pth-dsp          .
      *                      *-----------------------------------------*
      *                      * A rivisualizzazione riquadro            *
      *                      *-----------------------------------------*
           go to     int-prf-080-805.
       int-prf-080-875.
      *                  *---------------------------------------------*
      *                  * Se funzione Rght                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Incremento displacement del carattere   *
      *                      * relativo alla posizione 1               *
      *                      *-----------------------------------------*
           move      w-int-pth-dsp        to   w-int-pth-w00          .
           add       w-int-pth-idd        to   w-int-pth-w00          .
           add       080                  to   w-int-pth-w00          .
           subtract  1                    from w-int-pth-w00          .
           if        w-int-pth-w00        >    w-int-pth-amp
                     move  w-int-pth-amp  to   w-int-pth-w00          .
           move      w-int-pth-w00        to   w-int-pth-dsp          .
           subtract  080                  from w-int-pth-dsp          .
           add       1                    to   w-int-pth-dsp          .
      *                      *-----------------------------------------*
      *                      * A rivisualizzazione riquadro            *
      *                      *-----------------------------------------*
           go to     int-prf-080-805.
       int-prf-080-885.
      *                  *---------------------------------------------*
      *                  * Se funzione Exit                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Si esce con status di uscita a 'E'      *
      *                      *-----------------------------------------*
           move      "E"                  to   w-int-pth-flv          .
           go to     int-prf-080-899.
       int-prf-080-890.
      *                  *---------------------------------------------*
      *                  * Se funzione Insr                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 24 a spaces                       *
      *                      *-----------------------------------------*
           perform   int-prf-080-900      thru int-prf-080-909        .
      *                      *-----------------------------------------*
      *                      * Esecuzione subroutine di Insr           *
      *                      *-----------------------------------------*
           perform   int-prf-080-940      thru int-prf-080-949        .
      *                      *-----------------------------------------*
      *                      * A rivisualizzazione riquadro            *
      *                      *-----------------------------------------*
           go to     int-prf-080-805.
       int-prf-080-895.
      *                  *---------------------------------------------*
      *                  * Se funzione Find                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box vuoto                               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      10                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      60                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Messaggio interno al box                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-int-pth-e11        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Prompt di accettazione                  *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Accettazione presa visione              *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      12                   to   v-lin                  .
           move      57                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Ripristino immagine video               *
      *                      *-----------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Ad accettazione funzione                *
      *                      *-----------------------------------------*
           go to     int-prf-080-842.
       int-prf-080-899.
           exit.
       int-prf-080-900.
      *              *-------------------------------------------------*
      *              * Subroutine di cancellazione linea 24            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione comodo per linea 24 a spaces   *
      *                  *---------------------------------------------*
           move      24                   to   w-int-pth-wlx          .
           move      spaces               to   w-int-pth-wcx          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione linea se diversa da quanto  *
      *                  * gia' visualizzato                           *
      *                  *---------------------------------------------*
           perform   int-prf-080-910      thru int-prf-080-919        .
       int-prf-080-909.
           exit.
       int-prf-080-910.
      *              *-------------------------------------------------*
      *              * Subroutine di visualizzazione linea a video     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      w-int-pth-wlx        to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-int-pth-wcx        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       int-prf-080-919.
           exit.
       int-prf-080-920.
      *              *-------------------------------------------------*
      *              * Subroutine di lettura personalizzazione per la  *
      *              * determinazione dell'incremento/decremento per   *
      *              * i tasti funzione Left/Rght durante la visualiz- *
      *              * zazione della pagina                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se gia' determinato : uscita                *
      *                  *---------------------------------------------*
           if        w-int-pth-idd        not  = zero
                     go to int-prf-080-929.
      *                  *---------------------------------------------*
      *                  * Preparazione del valore determinato dalla   *
      *                  * segreteria a inizio programma               *
      *                  *---------------------------------------------*
           move      w-sgt-iod-lor        to   w-int-pth-idd          .
       int-prf-080-929.
           exit.
       int-prf-080-940.
      *              *-------------------------------------------------*
      *              * Subroutine di Insr sui tasti funzione           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Save video                                  *
      *                  *---------------------------------------------*
           perform   sav-imm-vid-000      thru sav-imm-vid-999        .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box vuoto                                   *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      08                   to   v-pos                  .
           move      16                   to   v-lto                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggio all'interno del box               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      61                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Nuovo incremento/decremento per spostamenti orizzo
      -              "ntali :    "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       int-prf-080-942.
      *                  *---------------------------------------------*
      *                  * Salvataggio vecchio incremento/decremento   *
      *                  *---------------------------------------------*
           move      w-int-pth-idd        to   w-int-pth-w00          .
       int-prf-080-944.
      *                  *---------------------------------------------*
      *                  * Accettazione nuovo incremento/decremento    *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      14                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      w-int-pth-w00        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-int-pth-w00          .
      *                  *---------------------------------------------*
      *                  * Se Exit : uscita senza modificazioni        *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     go to int-prf-080-948.
      *                  *---------------------------------------------*
      *                  * Se valore non accettabile : reimpostazione  *
      *                  *---------------------------------------------*
           if        w-int-pth-w00        <    001 or
                     w-int-pth-w00        >    080
                     go to int-prf-080-944.
      *                  *---------------------------------------------*
      *                  * Se valore accettabile : modificazione       *
      *                  *---------------------------------------------*
           move      w-int-pth-w00        to   w-int-pth-idd          .
       int-prf-080-948.
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           perform   rip-imm-vid-000      thru rip-imm-vid-999        .
       int-prf-080-949.
           exit.
       int-prf-080-990.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se interrogazione su 24 colonne si ripone   *
      *                  * in On il segnale di manipolazione codice    *
      *                  * azienda in alto a destra                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-int-pth-nlv        not  = 24
                     go to int-prf-080-999.
      *                      *-----------------------------------------*
      *                      * Manipolazione codice azienda in On      *
      *                      *-----------------------------------------*
           move      "A+"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       int-prf-080-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione su print-file fisico secondo pathname      *
      *    *                                                           *
      *    * Modo a 132 colonne                                        *
      *    *-----------------------------------------------------------*
       int-prf-132-000.
      *              *-------------------------------------------------*
      *              * Modo di utilizzo : a 132 colonne                *
      *              *-------------------------------------------------*
           move      "M1"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se interrogazione su 24 colonne si pone in Off  *
      *              * il segnale di manipolazione codice azienda in   *
      *              * alto a destra                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-int-pth-nlv        not  = 24
                     go to int-prf-132-005.
      *                  *---------------------------------------------*
      *                  * Manipolazione codice azienda in Off         *
      *                  *---------------------------------------------*
           move      "A-"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       int-prf-132-005.
      *              *-------------------------------------------------*
      *              * Normalizzazione pagina in buffer                *
      *              *-------------------------------------------------*
       int-prf-132-025.
      *                  *---------------------------------------------*
      *                  * Determinazione del numero di riquadri che   *
      *                  * compongono una pagina, a seconda se visua-  *
      *                  * lizzazione su 18 o 24 linee                 *
      *                  *---------------------------------------------*
           if        w-int-pth-nlv        =    24
                     go to int-prf-132-035.
       int-prf-132-030.
           if        w-hdr-efc-sel        >    80
                     move  6              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    64
                     move  5              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    48
                     move  4              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    32
                     move  3              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    16
                     move  2              to   w-int-pth-riq
           else      move  1              to   w-int-pth-riq          .
           go to     int-prf-132-050.
       int-prf-132-035.
           if        w-hdr-efc-sel        >    96
                     move  5              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    72
                     move  4              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    48
                     move  3              to   w-int-pth-riq
           else if   w-hdr-efc-sel        >    24
                     move  2              to   w-int-pth-riq
           else      move  1              to   w-int-pth-riq          .
       int-prf-132-050.
      *                  *---------------------------------------------*
      *                  * Determinazione ampiezza linea effettiva in  *
      *                  * caratteri : 001..240                        *
      *                  *---------------------------------------------*
           move      w-hdr-als-sel        to   w-int-pth-amp          .
      *                  *---------------------------------------------*
      *                  * Inizializzazione displacement del carattere *
      *                  * relativo alla posizione 1                   *
      *                  *---------------------------------------------*
           move      001                  to   w-int-pth-dsp          .
      *                  *---------------------------------------------*
      *                  * Numero pagina attualmente nel buffer : zero *
      *                  *---------------------------------------------*
           move      zero                 to   w-int-pth-npb          .
      *                  *---------------------------------------------*
      *                  * Ultima pagina precedentemente visualizzata  *
      *                  * a video : zero                              *
      *                  *---------------------------------------------*
           move      zero                 to   w-int-pth-upv          .
      *                  *---------------------------------------------*
      *                  * Numero riquadro forzato da visualizzare ad  *
      *                  * inizio visualizzazione pagina : zero        *
      *                  *---------------------------------------------*
           move      zero                 to   w-int-pth-rfv          .
      *                  *---------------------------------------------*
      *                  * Flag di fine file : off                     *
      *                  *---------------------------------------------*
           move      spaces               to   w-int-pth-flf          .
       int-prf-132-075.
      *              *-------------------------------------------------*
      *              * Caricamento nel buffer della prima pagina       *
      *              *-------------------------------------------------*
       int-prf-132-077.
      *                  *---------------------------------------------*
      *                  * Lettura del record di pagina [prf]          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Read [prf]                              *
      *                      *-----------------------------------------*
           move      "GN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mlsfil"
                                         using g                      .
           if        g-sts                =    e-not-err
                     go to int-prf-132-081.
           if        g-sts                =    e-end-fil
                     go to int-prf-132-079.
      *                      *-----------------------------------------*
