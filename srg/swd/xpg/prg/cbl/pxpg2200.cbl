      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Trattamento data aggiornamento password         *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-ute-dat-agg          .
      *              *-------------------------------------------------*
      *              * Scrittura movimento su files                    *
      *              *-------------------------------------------------*
           perform   scr-mov-fil-000      thru scr-mov-fil-999        .
      *              *-------------------------------------------------*
      *              * Scrittura utente tramite chiamata ad apposito   *
      *              * programma di interfaccia MySQL per ricostruire  *
      *              * l'intera tabella utenti                         *
      *              *-------------------------------------------------*
           perform   fas-xpg-740-000      thru fas-xpg-740-999        .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione programma                                      *
      *    *-----------------------------------------------------------*
       fas-xpg-740-000.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'xpg740-sub-pgm'  *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "xpg740-sub-pgm"     to   s-var                  .
           move      "G"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      80                   to   s-car                  .
           move      spaces               to   w-ipc-sub-pgm-val      .
           move      "S"                  to   w-ipc-sub-pgm-snb      .
           move      "IU"                 to   w-ipc-sub-pgm-ind      .
           move      w-ipc-sub-pgm-val    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo del programma                          *
      *              *-------------------------------------------------*
           move      "swd/xpg/prg/obj/pxpg7400"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
      *              *-------------------------------------------------*
      *              * Cancellazione del programma                     *
      *              *-------------------------------------------------*
           move      "swd/xpg/prg/obj/pxpg7400"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel   s-pat                                             .
       fas-xpg-740-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Trattamento data aggiornamento password         *
      *              *-------------------------------------------------*
           perform   pos-cnf-mod-pwd-000  thru pos-cnf-mod-pwd-999    .
       pos-cnf-mod-200.
      *              *-------------------------------------------------*
      *              * Scrittura movimento su files                    *
      *              *-------------------------------------------------*
           perform   scr-mov-fil-000      thru scr-mov-fil-999        .
       pos-cnf-mod-300.
      *              *-------------------------------------------------*
      *              * Update tabella database                         *
      *              *-------------------------------------------------*
           perform   pos-cnf-mod-upd-000  thru pos-cnf-mod-upd-999    .
       pos-cnf-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *                                                           *
      *    * Subroutine relativa al cambiamento eventuale della pass-  *
      *    * word                                                      *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-pwd-000.
      *              *-------------------------------------------------*
      *              * Trattamento data aggiornamento password         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se data esistente                      *
      *                  *---------------------------------------------*
           if        w-ute-dat-agg        =    zero
                     go to pos-cnf-mod-pwd-100.
      *                  *---------------------------------------------*
      *                  * Test se variata                             *
      *                  *---------------------------------------------*
           if        w-sav-pwd-ute        =    w-ute-pwd-ute
                     go to pos-cnf-mod-pwd-900.
       pos-cnf-mod-pwd-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento data                          *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-ute-dat-agg          .
       pos-cnf-mod-pwd-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento tabella password precedenti       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatori                   *
      *                  *---------------------------------------------*
           move      w-det-pwd-pre-max    to   w-det-pwd-pre-c01      .
           add       1                    to   w-det-pwd-pre-c01      .
           move      w-det-pwd-pre-max    to   w-det-pwd-pre-c02      .
       pos-cnf-mod-pwd-220.
      *                  *---------------------------------------------*
      *                  * Decremento contatori                        *
      *                  *---------------------------------------------*
           subtract  1                    from w-det-pwd-pre-c01      .
           subtract  1                    from w-det-pwd-pre-c02      .
      *                  *---------------------------------------------*
      *                  * Test su contatori                           *
      *                  *---------------------------------------------*
           if        w-det-pwd-pre-c02    =    zero
                     go to pos-cnf-mod-pwd-300.
           if        w-det-pwd-pre-c01    =    zero
                     go to pos-cnf-mod-pwd-300.
      *                  *---------------------------------------------*
      *                  * Shift elemento                              *
      *                  *---------------------------------------------*
           move      w-ute-pwd-utp
                    (w-det-pwd-pre-c02)   to   w-ute-pwd-utp
                                              (w-det-pwd-pre-c01)     .
           move      w-ute-pwd-udp
                    (w-det-pwd-pre-c02)   to   w-ute-pwd-udp
                                              (w-det-pwd-pre-c01)     .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     pos-cnf-mod-pwd-220.
       pos-cnf-mod-pwd-300.
      *              *-------------------------------------------------*
      *              * Password salvata                                *
      *              *-------------------------------------------------*
           move      w-sav-pwd-ute        to   w-ute-pwd-utp (1)      .
           move      w-ute-dat-agg        to   w-ute-pwd-udp (1)      .
       pos-cnf-mod-pwd-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
            go to    pos-cnf-mod-pwd-999.
       pos-cnf-mod-pwd-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *                                                           *
      *    * Subroutine di update tabella database                     *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-upd-000.
      *              *-------------------------------------------------*
      *              * Referenze per collegamento al database          *
      *              *-------------------------------------------------*
           perform   ref-dtb-sql-000      thru ref-dtb-sql-999        .
      *              *-------------------------------------------------*
      *              * Test se eseguibile                              *
      *              *-------------------------------------------------*
           if        w-ref-dtb-sql-pwd    =    spaces
                     go to pos-cnf-mod-upd-900.
           if        w-ute-pwd-ute        =    spaces
                     go to pos-cnf-mod-upd-900.
       pos-cnf-mod-upd-100.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Preparazione parametri                          *
      *              *-------------------------------------------------*
           move      "root"               to   w-det-upd-msq-usr      .
           move      w-ref-dtb-sql-pwd    to   w-det-upd-msq-pwd      .
           move      "xpg"                to   w-det-upd-msq-dtb      .
           move      "ute"                to   w-det-upd-msq-tab      .
           move      "pwd_ute"            to   w-det-upd-msq-fld      .
           move      "dat_agg"            to   w-det-upd-msq-dag      .
           move      "cod_ute"            to   w-det-upd-msq-flk      .
           move      w-ute-cod-ute        to   w-det-upd-msq-ute      .
           move      w-ute-pwd-ute        to   w-det-upd-msq-upw      .
      *              *-------------------------------------------------*
      *              * Assemblaggio comando                            *
      *              *-------------------------------------------------*
           move      spaces               to   o-shs                  .
           string    "mysql -u "
                                delimited by   size
                     w-det-upd-msq-usr
                                delimited by   spaces
                     " -p"      delimited by   size
                     w-det-upd-msq-pwd
                                delimited by   spaces
                     " -N "     delimited by   size
                     w-det-upd-msq-dtb
                                delimited by   spaces
                     " -e ""UPDATE "
                                delimited by   size
                     w-det-upd-msq-tab
                                delimited by   spaces
                     " SET "    delimited by   size
                     w-det-upd-msq-fld
                                delimited by   spaces
                     " = MD5('" delimited by   size
                     w-det-upd-msq-upw
                                delimited by   spaces
                     "') , "    delimited by   size
                     w-det-upd-msq-dag
                                delimited by   spaces
                     " = NOW() WHERE "
                                delimited by   size
                     w-det-upd-msq-flk
                                delimited by   spaces
                     " = '"     delimited by   size
                     w-det-upd-msq-ute
                                delimited by   spaces
                     "' LIMIT 1"""
                                delimited by   size
                                          into o-shs                  .
      *              *-------------------------------------------------*
      *              * Richiamo del modulo 'mopsys'                    *
      *              *-------------------------------------------------*
           move      "SH"                 to   o-ope                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
       pos-cnf-mod-upd-800.
      *              *-------------------------------------------------*
      *              * Erase video                                     *
      *              *-------------------------------------------------*
           move      "ER"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pos-cnf-mod-upd-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
            go to    pos-cnf-mod-upd-999.
       pos-cnf-mod-upd-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Delete movimento da files                       *
      *              *-------------------------------------------------*
           perform   del-mov-fil-000      thru del-mov-fil-999        .
      *              *-------------------------------------------------*
      *              * Programma di interfaccia MySQL per ricostruire  *
      *              * l'intera tabella utenti                         *
      *              *-------------------------------------------------*
           perform   fas-xpg-740-000      thru fas-xpg-740-999        .
       pos-cnf-ann-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
