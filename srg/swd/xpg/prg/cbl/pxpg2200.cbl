      *                          *-------------------------------------*
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    =    spaces
                     go to acc-cmd-abl-280
           else      move  spaces         to   w-cnt-tus-acc-tes
                     go to acc-cmd-abl-200.
       acc-cmd-abl-280.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-920  thru acc-cmd-abl-929    .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-tus-acc-tes      .
           go to     acc-cmd-abl-800.
       acc-cmd-abl-300.
      *                      *-----------------------------------------*
      *                      * Se Remv                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "REMV"
                     go to acc-cmd-abl-325.
      *                          *-------------------------------------*
      *                          * Compattamento in ogni caso          *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-930  thru acc-cmd-abl-939    .
      *                          *-------------------------------------*
      *                          * A reimpostare                       *
      *                          *-------------------------------------*
           go to     acc-cmd-abl-080.
       acc-cmd-abl-325.
      *                      *-----------------------------------------*
      *                      * Se Prsc                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-cmd-abl-350.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-920  thru acc-cmd-abl-929    .
      *                          *-------------------------------------*
      *                          * Se su prima facciata : uscita       *
      *                          *-------------------------------------*
           if        w-acc-abl-cmd-nel    not  > 12
                     move  "UP  "         to   v-key
                     go to acc-cmd-abl-800.
      *                          *-------------------------------------*
      *                          * Al primo elemento della facciata    *
      *                          * precedente                          *
      *                          *-------------------------------------*
           subtract  1                    from w-acc-abl-cmd-nel      .
           divide    12                   into w-acc-abl-cmd-nel      .
           subtract  1                    from w-acc-abl-cmd-nel      .
           multiply  12                   by   w-acc-abl-cmd-nel      .
           add       1                    to   w-acc-abl-cmd-nel      .
           go to     acc-cmd-abl-080.
       acc-cmd-abl-350.
      *                      *-----------------------------------------*
      *                      * Se Nxsc                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "NXSC"
                     go to acc-cmd-abl-375.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-920  thru acc-cmd-abl-929    .
      *                          *-------------------------------------*
      *                          * Se su ultima facciata : uscita      *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-c0a      .
           subtract  1                    from w-acc-abl-cmd-c0a      .
           divide    12                   into w-acc-abl-cmd-c0a      .
           add       1                    to   w-acc-abl-cmd-c0a      .
           multiply  12                   by   w-acc-abl-cmd-c0a      .
           add       1                    to   w-acc-abl-cmd-c0a      .
           if        w-acc-abl-cmd-c0a    >    w-acc-abl-cmd-max
                     move  "DOWN"         to   v-key
                     go to acc-cmd-abl-800.
           if        w-ute-tip-abl
                    (w-acc-abl-cmd-c0a)   =    spaces
                     move  "DOWN"         to   v-key
