      *              *-------------------------------------------------*
           if        w-acc-pwd-ute-chk    =    "0" or
                     w-acc-pwd-ute-chk    =    "1" or
                     w-acc-pwd-ute-chk    =    "2" or
                     w-acc-pwd-ute-chk    =    "3" or
                     w-acc-pwd-ute-chk    =    "4" or
                     w-acc-pwd-ute-chk    =    "5" or
                     w-acc-pwd-ute-chk    =    "6" or
                     w-acc-pwd-ute-chk    =    "7" or
                     w-acc-pwd-ute-chk    =    "8" or
                     w-acc-pwd-ute-chk    =    "9"
                     add   1              to   w-acc-pwd-ute-cnu      .
       acc-pwd-ute-chk-600.
      *              *-------------------------------------------------*
      *              * Test su caratteri speciali                      *
      *              *-------------------------------------------------*
           if        w-acc-pwd-ute-chk    =    "!" or
                     w-acc-pwd-ute-chk    =    "$" or
                     w-acc-pwd-ute-chk    =    "%" or
                     w-acc-pwd-ute-chk    =    "&" or
                     w-acc-pwd-ute-chk    =    "?" or
                     w-acc-pwd-ute-chk    =    "+" or
                     w-acc-pwd-ute-chk    =    "-" or
                     w-acc-pwd-ute-chk    =    "_" or
                     w-acc-pwd-ute-chk    =    "*"
                     add   1              to   w-acc-pwd-ute-ccs      .
       acc-pwd-ute-chk-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-pwd-ute-chk-999.
       acc-pwd-ute-chk-999.
           exit.

