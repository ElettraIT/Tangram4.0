           if        j-rsc                not  = spaces
                     go to rou-let-reg-900.
      *                  *---------------------------------------------*
      *                  * Record in area di lavoro                    *
      *                  *---------------------------------------------*
           move      j-dat                to   w-psg                  .
       rou-let-reg-030.
      *              *-------------------------------------------------*
      *              * Salvataggio eventuale segnale di utente         *
      *              * supervisore                                     *
      *              *-------------------------------------------------*
           move      w-ute-cod-ute        to   w-sav-ute-sav          .
           move      spaces               to   w-sav-ute-spv          .
      *              *-------------------------------------------------*
      *              * Determinazione codice utente                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Informazioni generali da segreteria         *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "RD"                 to   j-ope                  .
           move      "UTE"                to   j-tre                  .
           move      s-ute                to   j-kre                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
      *                  *---------------------------------------------*
      *                  * Record in area di lavoro                    *
      *                  *---------------------------------------------*
           move      j-dat                to   w-ute                  .
      *                  *---------------------------------------------*
      *                  * Segnale di supervisore                      *
      *                  *---------------------------------------------*
           if        w-ute-tip-ute        =    02
                     move  "#"            to   w-sav-ute-spv          .
       rou-let-reg-050.
      *              *-------------------------------------------------*
      *              * Ripristino utente in corso di trattamento       *
      *              *-------------------------------------------------*
           move      w-sav-ute-sav        to   w-ute-cod-ute          .
      *              *-------------------------------------------------*
      *              * Lettura                                         *
      *              *-------------------------------------------------*
           move      "RD"                 to   j-ope                  .
           move      "UTE"                to   j-tre                  .
           move      w-ute-cod-ute        to   j-kre                  .
           call      "swd/mod/prg/obj/maucmf"
                                        using  j                      .
      *              *-------------------------------------------------*
      *              * Test su esito lettura                           *
      *              *-------------------------------------------------*
           if        j-rsc                =    e-not-fnd
                     go to rou-let-reg-100
           else if   j-rsc                =    spaces
                     go to rou-let-reg-300
           else      go to rou-let-reg-900.
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Se record non trovato                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il programma e' stato richiamato per la  *
      *                  * modifica della propria password : non si    *
      *                  * accetta l'inserimento, e si esce con status *
      *                  * ad errore                                   *
      *                  *---------------------------------------------*
           if        w-ipc-xpg-220-pwd    =    "S"
                     move  "#"            to   w-cnt-rou-let-reg
                     go to rou-let-reg-999.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Modifica               *
      *                  *---------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Record in area di lavoro                    *
      *                  *---------------------------------------------*
           move      j-dat                to   w-ute                  .
      *                  *---------------------------------------------*
      *                  * Lettura codice stampante per descrizione    *
      *                  *---------------------------------------------*
           move      w-ute-cst-ass        to   w-let-arc-stp-cod      .
           perform   let-arc-stp-000      thru let-arc-stp-999        .
           move      w-let-arc-stp-des    to   w-exe-des-cst          .
      *                  *---------------------------------------------*
      *                  * Lettura codice stampante locale per descri- *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           move      w-ute-csl-aau        to   w-let-arc-stp-cod      .
           perform   let-arc-stp-000      thru let-arc-stp-999        .
           move      w-let-arc-stp-des    to   w-exe-des-csl          .
      *                  *---------------------------------------------*
      *                  * Eventuali normalizzazioni                   *
      *                  *---------------------------------------------*
           if        w-ute-snx-usl        not  = "S"
                     move  "N"            to   w-ute-snx-usl          .
           if        w-ute-dat-agg        not  numeric
                     move  zero           to   w-ute-dat-agg          .
           if        w-ute-dat-uti        not  numeric
                     move  zero           to   w-ute-dat-uti          .
           if        w-ute-dat-scd        not  numeric
                     move  zero           to   w-ute-dat-scd          .
      *                  *---------------------------------------------*
      *                  * Salvataggio password utente attuale         *
      *                  *---------------------------------------------*
           move      w-ute-pwd-ute        to   w-sav-pwd-ute          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-900.
      *              *-------------------------------------------------*
      *              * Se errore grave di i-o                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di errore                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
