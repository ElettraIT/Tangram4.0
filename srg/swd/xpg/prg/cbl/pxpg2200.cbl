       acc-cmd-abl-200.
      *                  *---------------------------------------------*
      *                  * Accettazione tipo abilitazione              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione parametri                  *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-c0r      .
           subtract  w-acc-abl-cmd-pev    from w-acc-abl-cmd-c0r      .
           add       9                    to   w-acc-abl-cmd-c0r      .
           move      w-acc-abl-cmd-c0r    to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-ute-tip-abl
                    (w-acc-abl-cmd-nel)   not  = spaces and
                     w-ute-tip-abl
                    (w-acc-abl-cmd-max)   =    spaces
                     move  "INSR"         to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-ute-tip-abl
                    (w-acc-abl-cmd-nel)   not  = spaces
                     go to acc-cmd-abl-202.
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-c0a      .
           add       1                    to   w-acc-abl-cmd-c0a      .
           if        w-acc-abl-cmd-c0a    >    w-acc-abl-cmd-max
                     go to acc-cmd-abl-204.
           if        w-ute-tip-abl
                    (w-acc-abl-cmd-c0a)   =    spaces
                     go to acc-cmd-abl-204.
       acc-cmd-abl-202.
           move      "REMV"               to   v-pfk (06)             .
       acc-cmd-abl-204.
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           if        w-acc-abl-cmd-nel    >    1
                     move  "BACK"         to   v-pfk (09)             .
           if        w-acc-abl-cmd-nel    =    w-acc-abl-cmd-max
                     go to acc-cmd-abl-208.
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-c0a      .
           add       1                    to   w-acc-abl-cmd-c0a      .
           if        w-ute-tip-abl
                    (w-acc-abl-cmd-nel)   =    spaces and
                     w-ute-tip-abl
                    (w-acc-abl-cmd-c0a)   =    spaces
                     go to acc-cmd-abl-208.
           move      "TAB "               to   v-pfk (10)             .
       acc-cmd-abl-208.
           move      w-acc-abl-cmd-sta    to   v-alf                  .
