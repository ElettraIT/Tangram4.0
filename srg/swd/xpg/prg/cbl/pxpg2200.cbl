      *    *===========================================================*
      *    * Accettazione : Codice utente                              *
      *    *-----------------------------------------------------------*
       acc-cod-ute-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-ute-025.
      *                  *---------------------------------------------*
      *                  * Se il programma e' stato richiamato per la  *
      *                  * modifica della propria password : si simula *
      *                  * una impostazione automatica del codice u-   *
      *                  * tente pari al codice utente in uso          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-ipc-xpg-220-pwd    not  = "S"
                     go to acc-cod-ute-100.
      *                      *-----------------------------------------*
      *                      * Informazioni generali da segreteria     *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Codice utente in campo di destinazione  *
      *                      *-----------------------------------------*
           move      s-ute                to   w-ute-cod-ute          .
      *                      *-----------------------------------------*
      *                      * Eventuale codice utente da chiamante    *
      *                      *-----------------------------------------*
           if        w-ipc-xpg-220-ute    not  = spaces
                     move  w-ipc-xpg-220-ute
                                          to   w-ute-cod-ute          .
      *                      *-----------------------------------------*
      *                      * Visualizzazione codice utente           *
      *                      *-----------------------------------------*
           perform   vis-cod-ute-000      thru vis-cod-ute-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione function key            *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Riaggancio a dipendenze da impostazione *
      *                      *-----------------------------------------*
           go to     acc-cod-ute-600.
       acc-cod-ute-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-ute-cod-ute        to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-ute-999.
       acc-cod-ute-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-ute-cod-ute          .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-cod-ute-400.
      *                  *---------------------------------------------*
      *                  * Find su codici utente                       *
      *                  *---------------------------------------------*
           move      w-ute-cod-ute        to   w-fnd-auc-ute-cod      .
           perform   fnd-auc-ute-000      thru fnd-auc-ute-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-auc-ute-sel    not  = spaces
                     go to acc-cod-ute-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione codice selezionato           *
      *                  *---------------------------------------------*
           move      w-fnd-auc-ute-cod    to   w-ute-cod-ute          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice selezionato          *
      *                  *---------------------------------------------*
           perform   vis-cod-ute-000      thru vis-cod-ute-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
       acc-cod-ute-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-ute-cod-ute        to   w-all-str-alf          .
           move      08                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-cod-ute-100.
       acc-cod-ute-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-ute-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cod-ute-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-ute-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cod-ute-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cod-ute-999.
       acc-cod-ute-999.
           exit.

