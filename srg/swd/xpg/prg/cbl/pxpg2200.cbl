      *                      *-----------------------------------------*
           move      v-alf                to   w-ute-tip-abl
                                              (w-acc-abl-cmd-nel)     .
      *                      *-----------------------------------------*
      *                      * Se Exit                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cmd-abl-800.
      *                      *-----------------------------------------*
      *                      * Se Delt                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cmd-abl-800.
      *                      *-----------------------------------------*
      *                      * Se Return                               *
      *                      *-----------------------------------------*
           if        v-key                =    spaces
                     go to acc-cmd-abl-425.
      *                      *-----------------------------------------*
      *                      * In ogni altro caso il valore deve esse- *
      *                      * re inalterato                           *
      *                      *-----------------------------------------*
           if        v-alf                not  = w-acc-abl-cmd-sta
                     go to acc-cmd-abl-200.
       acc-cmd-abl-210.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-cmd-abl-225.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-920  thru acc-cmd-abl-929    .
      *                          *-------------------------------------*
      *                          * Se sul primo : uscita               *
      *                          *-------------------------------------*
           subtract  1                    from w-acc-abl-cmd-nel      .
           if        w-acc-abl-cmd-nel    =    zero
                     move  "UP  "         to   v-key
                     go to acc-cmd-abl-800
           else      go to acc-cmd-abl-080.
       acc-cmd-abl-225.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "DOWN"
                     go to acc-cmd-abl-250.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-920  thru acc-cmd-abl-929    .
      *                          *-------------------------------------*
      *                          * Se sull'ultimo : uscita             *
      *                          *-------------------------------------*
           if        w-acc-abl-cmd-fce    =    spaces
                     add   1              to   w-acc-abl-cmd-nel      .
           if        w-acc-abl-cmd-nel    >    w-acc-abl-cmd-max
                     move  "DOWN"         to   v-key
                     go to acc-cmd-abl-800.
           if        w-acc-abl-cmd-nel    =    1
                     go to acc-cmd-abl-230
           else      go to acc-cmd-abl-235.
       acc-cmd-abl-230.
           if        w-ute-tip-abl (1)    =    spaces and
                     w-ute-tip-abl (2)    =    spaces
                     move  "DOWN"         to   v-key
                     go to acc-cmd-abl-800
           else      go to acc-cmd-abl-080.
       acc-cmd-abl-235.
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-c0a      .
           move      w-acc-abl-cmd-c0a    to   w-acc-abl-cmd-c0b      .
           subtract  1                    from w-acc-abl-cmd-c0b      .
           if        w-ute-tip-abl
                    (w-acc-abl-cmd-c0a)   =    spaces and
                     w-ute-tip-abl
                    (w-acc-abl-cmd-c0b)   =    spaces
                     move  "DOWN"         to   v-key
                     go to acc-cmd-abl-800
           else      go to acc-cmd-abl-080.
       acc-cmd-abl-250.
      *                      *-----------------------------------------*
      *                      * Se Insr                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-cmd-abl-275.
           move      w-acc-abl-cmd-nel    to   w-acc-abl-cmd-nec      .
           perform   acc-cmd-abl-940  thru acc-cmd-abl-949    .
           go to     acc-cmd-abl-080.
       acc-cmd-abl-275.
      *                      *-----------------------------------------*
      *                      * Se Do                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cmd-abl-300.
