      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      68                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      "Richiesta di esecuzione operazione alla prossima a
      -              "pertura di un file"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
