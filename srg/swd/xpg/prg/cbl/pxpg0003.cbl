       blo-spo-sta-575.
      *                  *---------------------------------------------*
      *                  * Se codice stampante esistente               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Record letto in area di lavoro          *
      *                      *-----------------------------------------*
           move      pss-dat              to   w-stp                  .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione stampante    *
      *                      *-----------------------------------------*
           move      w-stp-des-stp        to   w-blo-spl-des          .
      *                      *-----------------------------------------*
      *                      * Memorizzazione canale per la stampante  *
      *                      *-----------------------------------------*
           move      w-stp-can-stp        to   w-blo-spl-can          .
      *                      *-----------------------------------------*
      *                      * Separazione del parametro 'canale di    *
      *                      * stampa' in uno o due componenti         *
      *                      *                                         *
      *                      * - Se una sola componente                *
      *                      *                                         *
      *                      *   - w-blo-spl-cn1 = canale di stampa    *
      *                      *   - w-blo-spl-cn2 = spaces              *
      *                      *                                         *
      *                      * - Se due componenti                     *
      *                      *                                         *
      *                      *   - w-blo-spl-cn1 = spooler da utiliz-  *
      *                      *                     zare                *
      *                      *                     - "spool"           *
      *                      *                     - "rcp"             *
      *                      *                     - "ucp"             *
      *                      *   - w-blo-spl-cn2 = nome logico della   *
      *                      *                     stampante per lo    *
      *                      *                     spooler o per il    *
      *                      *                     remote copy         *
      *                      *-----------------------------------------*
           move      spaces               to   w-blo-spl-cn1          .
           move      spaces               to   w-blo-spl-cn2          .
           unstring  w-blo-spl-can
                                delimited by   all spaces
                                          into w-blo-spl-cn1
                                               w-blo-spl-cn2          .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione stampante   *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      w-blo-spl-des        to   v-alf                  .
           if        v-alc (40)           =    "*"
                     move  spaces         to   v-alc (40)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       blo-spo-sta-600.
