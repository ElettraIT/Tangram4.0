           move      zero                 to   w-imp-sdt-imp          .
      *                          *-------------------------------------*
      *                          * Record impegno in area file         *
      *                          *-------------------------------------*
           move      w-imp                to   pss-dat                .
      *                          *-------------------------------------*
      *                          * Riscrittura record impegno          *
      *                          *-------------------------------------*
           rewrite   pss-rec invalid key
                             go to   dis-imp-stp-990.
       dis-imp-stp-990.
      *                          *-------------------------------------*
      *                          * Unlock [pss]                        *
      *                          *-------------------------------------*
           unlock    pss   records                                    .
       dis-imp-stp-999.
           exit.

      *    *===========================================================*
      *    * Blocco spooler di stampa                                  *
      *    *-----------------------------------------------------------*
       blo-spo-sta-000.
      *              *-------------------------------------------------*
      *              * Lettura della personalizzazione relativa al     *
      *              * template per il blocco dello spooler di stampa  *
      *              *-------------------------------------------------*
           move      "PS"                 to   s-ope                  .
           move      "tem-bss"            to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-alf                to   w-blo-spl-tem          .
      *              *-------------------------------------------------*
      *              * Se template a spaces : uscita immediata, in     *
      *              * quanto operazione non possibile                 *
      *              *-------------------------------------------------*
           if        w-blo-spl-tem        =    spaces
                     go to blo-spo-sta-999.
      *              *-------------------------------------------------*
      *              * Se template a '.' : uscita immediata, in quanto *
      *              * operazione non possibile                        *
      *              *-------------------------------------------------*
           if        w-blo-spl-tem        =    "."
                     go to blo-spo-sta-999.
      *              *-------------------------------------------------*
      *              * Controllo che esista uno e solo uno carattere   *
      *              * '@' nel template; in caso contrario uscita im-  *
      *              * mediata in quanto operazione non possibile      *
      *              *-------------------------------------------------*
           move      zero                 to   w-blo-spl-i01          .
           inspect   w-blo-spl-tem    tallying w-blo-spl-i01
                                          for  all   "@"              .
           if        w-blo-spl-i01        not  = 1
                     go to blo-spo-sta-999.
      *              *-------------------------------------------------*
      *              * Determinazione numero di caratteri che prece-   *
      *              * dono il carattere '@' nel template              *
      *              *-------------------------------------------------*
           move      zero                 to   w-blo-spl-i01          .
           inspect   w-blo-spl-tem    tallying w-blo-spl-i01
                                          for  characters
                                        before initial "@"            .
      *              *-------------------------------------------------*
      *              * Controllo che il carattere successivo a '@' sia *
      *              * il carattere 'p';in caso contrario uscita im-   *
      *              * mediata in quanto operazione non possibile      *
      *              *-------------------------------------------------*
           move      w-blo-spl-i01        to   w-blo-spl-i02          .
           add       2                    to   w-blo-spl-i02          .
           if        w-blo-spl-tex
                    (w-blo-spl-i02)       not  = "p" and
                     w-blo-spl-tex
                    (w-blo-spl-i02)       not  = "P"
                     go to blo-spo-sta-999.
       blo-spo-sta-025.
