      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-blo-spl-cn1        =    "spool"
                     go to blo-spo-sta-800.
      *                          *-------------------------------------*
      *                          * Emissione messaggio di errore       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Literal                         *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      "Messaggio        :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggio                       *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      "Stampante non bloccabile! (Non in spool)"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * A reimpostazione codice stampante   *
      *                          *-------------------------------------*
           go to     blo-spo-sta-400.
       blo-spo-sta-800.
      *              *-------------------------------------------------*
      *              * Accettazione conferma finale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Note operative                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      52                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      "Conferma esecuzione del blocco stampante (S/N/E) ?
      -              "  "                 to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione risposta                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-blo-spl-snx          .
       blo-spo-sta-825.
      *                  *---------------------------------------------*
      *                  * Accettazione conferma                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      74                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-blo-spl-snx        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-alf                to   w-blo-spl-snx          .
      *                  *---------------------------------------------*
      *                  * Se premuta function-key                     *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to blo-spo-sta-850
           else if   v-key                =    "DO  "
                     go to blo-spo-sta-875
           else if   v-key                =    "EXIT"
                     go to blo-spo-sta-999.
      *                  *---------------------------------------------*
      *                  * Se Return                                   *
      *                  *---------------------------------------------*
           if        w-blo-spl-snx        =    "N"
                     go to blo-spo-sta-850
           else if   w-blo-spl-snx        =    "S"
                     go to blo-spo-sta-875
           else if   w-blo-spl-snx        =    "E"
                     go to blo-spo-sta-999
           else      go to blo-spo-sta-825.
       blo-spo-sta-850.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Cancellazione note operative            *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      52                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * A reimpostazione codice stampante       *
      *                      *-----------------------------------------*
           go to     blo-spo-sta-400.
       blo-spo-sta-875.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Cancellazione note operative            *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      52                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       blo-spo-sta-900.
      *                      *-----------------------------------------*
      *                      * Costruzione del comando per il blocco   *
      *                      * dello spooler di stampa, in base ai     *
      *                      * seguenti parametri:                     *
      *                      *                                         *
      *                      * - w-blo-spl-tem : Template per il bloc- *
      *                      *                   co dello spooler      *
      *                      * - w-blo-spl-stp : Codice della stampan- *
      *                      *                   te                    *
      *                      * - w-blo-spl-cn1 : Canale di stampa, 1.a *
      *                      *                   parte                 *
      *                      * - w-blo-spl-cn2 : Canale di stampa, 2.a *
      *                      *                   parte                 *
      *                      *-----------------------------------------*
       blo-spo-sta-905.
      *                          *-------------------------------------*
      *                          * Normalizzazioni preliminari         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Area o-shs                      *
      *                              *---------------------------------*
           move      spaces               to   o-shs                  .
      *                              *---------------------------------*
      *                              * Indice su template              *
      *                              *---------------------------------*
           move      001                  to   w-blo-spl-i01          .
      *                              *---------------------------------*
      *                              * Indice area o-shs               *
      *                              *---------------------------------*
           move      001                  to   w-blo-spl-i02          .
       blo-spo-sta-910.
      *                          *-------------------------------------*
      *                          * Copiatura porzione precedente il    *
      *                          * carattere '@'                       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Determinazione numero di carat- *
      *                              * teri che precedono '@'          *
      *                              *---------------------------------*
           move      zero                 to   w-blo-spl-c01          .
           inspect   w-blo-spl-tem    tallying w-blo-spl-c01
                                          for  characters
                                        before initial "@"            .
      *                              *---------------------------------*
      *                              * Copiatura                       *
      *                              *---------------------------------*
           move      w-blo-spl-tem
                    (w-blo-spl-i01:
                     w-blo-spl-c01)       to   o-shs
                                              (w-blo-spl-i02:
                                               w-blo-spl-c01)         .
      *                              *---------------------------------*
      *                              * Aggiornamento indice su tem-    *
      *                              * plate                           *
      *                              *---------------------------------*
           add       w-blo-spl-c01        to   w-blo-spl-i01          .
           add       2                    to   w-blo-spl-i01          .
      *                              *---------------------------------*
      *                              * Aggiornamento indice su o-shs   *
      *                              *---------------------------------*
           add       w-blo-spl-c01        to   w-blo-spl-i02          .
       blo-spo-sta-915.
      *                          *-------------------------------------*
      *                          * Copiatura codice stampante          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se la seconda parte del canale  *
      *                              * di stampa e' a spaces, la si    *
      *                              * sostituisce con il codice del-  *
      *                              * la stampante                    *
      *                              *---------------------------------*
           if        w-blo-spl-cn2        =    spaces
                     move  w-blo-spl-stp  to   w-blo-spl-cn2          .
      *                              *---------------------------------*
      *                              * Determinazione lunghezza effet- *
      *                              * tiva per il codice stampante    *
      *                              *---------------------------------*
           move      zero                 to   w-blo-spl-c02          .
           inspect   w-blo-spl-cn2    tallying w-blo-spl-c02
                                          for  trailing spaces        .
           move      40                   to   w-blo-spl-c01          .
           subtract  w-blo-spl-c02        from w-blo-spl-c01          .
      *                              *---------------------------------*
      *                              * Copiatura                       *
      *                              *---------------------------------*
           move      w-blo-spl-cn2        to   o-shs
                                              (w-blo-spl-i02:
                                               w-blo-spl-c01)         .
      *                              *---------------------------------*
      *                              * Aggiornamento indice su o-shs   *
      *                              *---------------------------------*
