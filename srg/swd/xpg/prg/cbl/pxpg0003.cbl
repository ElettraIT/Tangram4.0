                     go to vis-hlp-scr-640
           else if   v-key                =    "TAB "
                     go to vis-hlp-scr-660
           else if   v-key                =    "ESC "
                     go to vis-hlp-scr-670
           else if   v-key                =    spaces or
                     v-key                =    "RTRN"
                     go to vis-hlp-scr-680
