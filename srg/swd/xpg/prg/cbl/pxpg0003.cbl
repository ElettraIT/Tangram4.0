      *                  * ri non si eseguono i controlli seguenti     *
      *                  *---------------------------------------------*
           if        w-exe-dac-snx-dac    =    "S"
                     go to acc-cmd-mnu-027.
      *                  *---------------------------------------------*
      *                  * Controllo terminazione background           *
      *                  *---------------------------------------------*
           perform   cnt-ter-bkg-000      thru cnt-ter-bkg-999        .
      *                  *---------------------------------------------*
      *                  * Controllo fra max numero utenti abilitati e *
      *                  * numero progressivo utente in uso            *
      *                  *---------------------------------------------*
           perform   cnt-nut-npu-000      thru cnt-nut-npu-999        .
      *                  *---------------------------------------------*
      *                  * Controllo su data di scadenza licenza d'uso *
      *                  *---------------------------------------------*
           perform   cnt-scd-lcu-000      thru cnt-scd-lcu-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione esistenza print-files per    *
      *                  * l'utente in uso, per l'azienda in uso, di   *
      *                  * tipo 'e-mail'                               *
      *                  *---------------------------------------------*
           perform   acc-cmd-mnu-mbx-000  thru acc-cmd-mnu-mbx-999    .
       acc-cmd-mnu-027.
      *                  *---------------------------------------------*
      *                  * Accettazione                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Parametri generali                      *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-acc-com-lac        to   v-lin                  .
           move      w-acc-com-pac        to   v-pos                  .
           move      spaces               to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Function keys                           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Up                                  *
      *                          *-------------------------------------*
           if        w-let-mnu-nmk        >    zero
                     move  "UP  "         to   v-pfk (01)             .
      *                          *-------------------------------------*
      *                          * Find                                *
      *                          *-------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                          *-------------------------------------*
      *                          * Do                                  *
      *                          *-------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *                          *-------------------------------------*
      *                          * Prsc                                *
      *                          *-------------------------------------*
           if        w-let-mnu-epp        =    "S"
                     move  "PRSC"         to   v-pfk (07)             .
      *                          *-------------------------------------*
      *                          * Nxsc                                *
      *                          *-------------------------------------*
           if        w-let-mnu-eps        =    "S"
                     move  "NXSC"         to   v-pfk (08)             .
      *                          *-------------------------------------*
      *                          * Prnt                                *
      *                          *-------------------------------------*
           move      "PRNT"               to   v-pfk (11)             .
      *                          *-------------------------------------*
      *                          * Pf1                                 *
      *                          *-------------------------------------*
           move      "[1] "               to   v-pfk (14)             .
      *                          *-------------------------------------*
      *                          * Pf2                                 *
      *                          *-------------------------------------*
           move      "[2] "               to   v-pfk (15)             .
      *                          *-------------------------------------*
      *                          * Pf3                                 *
      *                          *-------------------------------------*
           move      "[3] "               to   v-pfk (16)             .
      *                          *-------------------------------------*
      *                          * Pf4                                 *
      *                          *-------------------------------------*
           move      "[4] "               to   v-pfk (17)             .
      *                          *-------------------------------------*
      *                          * Select                              *
      *                          *-------------------------------------*
           move      "SLCT"               to   v-pfk (18)             .
      *                          *-------------------------------------*
      *                          * Exit                                *
      *                          *-------------------------------------*
           move      "EXIT"               to   v-pfk (20)             .
       acc-cmd-mnu-030.
      *                      *-----------------------------------------*
