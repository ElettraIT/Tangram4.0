           if        v-key                =    "SLCT"
                     go to acc-cmd-mnu-145
           else if   v-key                =    "UP  "
                     go to acc-cmd-mnu-060
           else if   v-key                =    spaces or
                     v-key                =    "DOWN"
                     go to acc-cmd-mnu-065
           else if   v-key                =    "EXIT"
                     go to acc-cmd-mnu-080
           else if   v-key                =    "PRSC"
                     go to acc-cmd-mnu-070
           else if   v-key                =    "NXSC"
                     go to acc-cmd-mnu-075
           else      go to acc-cmd-mnu-050.
       acc-cmd-mnu-060.
      *                  *---------------------------------------------*
      *                  * Se tasto Up da mark point                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Cursore supplementare a spazi           *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-let-mnu-lmk
                    (w-acc-com-i01)       to   v-lin                  .
           move      04                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Codice comando in lowercase             *
      *                      *-----------------------------------------*
           move      06                   to   w-all-str-lun          .
           move      w-let-mnu-vmk
                    (w-acc-com-i01)       to   w-all-str-alf          .
           perform   all-str-low-000      thru all-str-low-999        .

           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-let-mnu-lmk
                    (w-acc-com-i01)       to   v-lin                  .
           move      11                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
