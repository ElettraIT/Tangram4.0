                     move  ".p"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    11
                     move  ".r"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    12
                     move  ".s"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    13
                     move  ".t"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    14
                     move  ".u"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    15
                     move  ".w"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    w-fnd-auc-cmd-li2
