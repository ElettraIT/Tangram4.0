      *    *===========================================================*
      *    * Determinazione si/no background attualmente in esecuzione *
      *    *-----------------------------------------------------------*
       det-snx-bkg-000.
      *              *-------------------------------------------------*
      *              * Richiesta informazioni generali da segreteria   *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Trasferimento informazioni riguardanti il back- *
      *              * ground in area di comodo                        *
      *              *-------------------------------------------------*
           if        s-snb                =    "S"
                     move  "S"            to   w-snx-bkg-snx
                     move  s-npb          to   w-snx-bkg-pro
                     move  s-alf          to   w-snx-bkg-des
                     move  s-psb          to   w-snx-bkg-pst
           else      move  "N"            to   w-snx-bkg-snx
                     move  spaces         to   w-snx-bkg-pro
                     move  spaces         to   w-snx-bkg-des
                     move  zero           to   w-snx-bkg-pst          .
       det-snx-bkg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione status del background in esecuzione        *
      *    *-----------------------------------------------------------*
       det-sts-bkg-000.
      *              *-------------------------------------------------*
      *              * Se non ci sono background in esecuzione : usci- *
      *              * ta con status a 'N'                             *
      *              *-------------------------------------------------*
           if        w-snx-bkg-snx        =    "N"
                     move  "N"            to   w-snx-bkg-sts
                     go to det-sts-bkg-999.
       det-sts-bkg-100.
      *              *-------------------------------------------------*
      *              * Se ci sono background in esecuzione             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se terminazione avvenuta               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura variabile di i.p.c. gloable di  *
      *                      * nome 'Status Background'                *
      *                      *-----------------------------------------*
           move      "GV"                 to   s-ope                  .
           move      "Status Background   "
                                          to   s-var                  .
           move      "G"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda se variabile tro-  *
      *                      * vata oppure no                          *
      *                      *-----------------------------------------*
           if        s-ves                =    spaces
                     go to det-sts-bkg-300.
       det-sts-bkg-200.
      *                      *-----------------------------------------*
      *                      * Se variabile non trovata                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Uscita con segnale di nessun back-  *
      *                          * ground in esecuzione                *
      *                          *-------------------------------------*
           move      "N"                  to   w-snx-bkg-sts          .
           go to     det-sts-bkg-999.
       det-sts-bkg-300.
      *                      *-----------------------------------------*
      *                      * Se variabile trovata                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del valore   *
      *                          * della variabile                     *
      *                          *-------------------------------------*
           if        s-alf                =    "T"
                     go to det-sts-bkg-400
           else      go to det-sts-bkg-500.
       det-sts-bkg-400.
      *                          *-------------------------------------*
      *                          * Se variabile a valore 'T'           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Uscita con il segnale di back-  *
      *                              * ground in esecuzione terminato  *
      *                              *---------------------------------*
           move      "T"                  to   w-snx-bkg-sts          .
           go to     det-sts-bkg-999.
       det-sts-bkg-500.
      *                          *-------------------------------------*
      *                          * Se variabile a valore non 'T'       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Uscita con il segnale di back-  *
      *                              * ground in esecuzione ma non an- *
      *                              * cora terminato                  *
      *                              *---------------------------------*
           move      "S"                  to   w-snx-bkg-sts          .
           go to     det-sts-bkg-999.
       det-sts-bkg-999.
           exit.

