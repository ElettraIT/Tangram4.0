      *              *-------------------------------------------------*
      *              * Determinazione codice utente attuale            *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-ute                to   w-dim-stp-ute          .
      *              *-------------------------------------------------*
      *              * Determinazione tipo utente attuale              *
      *              *-------------------------------------------------*
           move      "ute "               to   auc-tre                .
           move      w-dim-stp-ute        to   auc-kre                .
           read      auc    with no lock
                            invalid key
                            move    00    to   w-dim-stp-tut
                            go to   dis-imp-stp-050.
           move      auc-dat              to   w-ute                  .
           if        w-ute-tse-cst        not  numeric
                     move  zero           to   w-ute-tse-cst
                     move  spaces         to   w-ute-cst-ass
                     move  zero           to   w-ute-amc-def
                     move  zero           to   w-ute-ali-def
                     move  spaces         to   w-ute-csl-aau
                     move  spaces         to   w-ute-aps-aau          .
           move      w-ute-tip-ute        to   w-dim-stp-tut          .
       dis-imp-stp-050.
