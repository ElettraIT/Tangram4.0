      *                      *-----------------------------------------*
           if        w-fnd-auc-cmd-lin    =    w-fnd-auc-cmd-li1
                     move  ".a"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    10
                     move  ".b"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    11
                     move  ".c"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    12
                     move  ".d"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    13
                     move  ".e"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    14
                     move  ".i"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    15
                     move  ".l"           to   w-fnd-auc-cmd-cod
           else if   w-fnd-auc-cmd-lin    =    w-fnd-auc-cmd-li2
                     move  ".m"           to   w-fnd-auc-cmd-cod      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     vis-hlp-scr-900.
       vis-hlp-scr-700.
      *                      *-----------------------------------------*
      *                      * Lato destro                             *
      *                      *-----------------------------------------*
           if        w-fnd-auc-cmd-lin    =    w-fnd-auc-cmd-li1
                     move  ".n"           to   w-fnd-auc-cmd-cod
