      *                  * Nome del file                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-nxt-opn-nam        to   v-alf                  .
