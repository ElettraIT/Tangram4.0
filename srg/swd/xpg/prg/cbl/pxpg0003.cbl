      *                      * Test se raggiunto limite inferiore      *
      *                      *-----------------------------------------*
           if        w-fnd-auc-cmd-lin    =    w-fnd-auc-cmd-li2
                     go to vis-hlp-scr-622.
      *                      *-----------------------------------------*
      *                      * Incremento linea                        *
      *                      *-----------------------------------------*
           add       1                    to   w-fnd-auc-cmd-lin      .
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     vis-hlp-scr-520.
       vis-hlp-scr-622.
      *                      *-----------------------------------------*
      *                      * Se raggiunto limite inferiore           *
      *                      *-----------------------------------------*
           if        w-fnd-auc-cmd-pos    =    w-fnd-auc-cmd-po1
                     move  w-fnd-auc-cmd-li1
                                          to   w-fnd-auc-cmd-lin
                     move  w-fnd-auc-cmd-po2
                                          to   w-fnd-auc-cmd-pos      .
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     vis-hlp-scr-520.
       vis-hlp-scr-630.
      *                  *---------------------------------------------*
      *                  * Se 'Left'                                   *
      *                  *---------------------------------------------*
