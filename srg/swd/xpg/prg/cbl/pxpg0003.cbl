           move      zero                 to   w-nxt-opn-tpf          .
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-nxt-opn-etf-lun    to   v-car                  .
           move      w-nxt-opn-etf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
