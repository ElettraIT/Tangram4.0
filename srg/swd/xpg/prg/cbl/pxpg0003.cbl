      *                      * Visualizzazione in Bold                 *
      *                      *-----------------------------------------*
           display   w-let-mnu-vmk
                    (w-acc-com-i01)       bold
                                          line w-let-mnu-lmk
                                              (w-acc-com-i01)
                                          position 11                 .
      *                      *-----------------------------------------*
      *                      * Ad accettazione function key            *
      *                      *-----------------------------------------*
           go to     acc-cmd-mnu-057.
       acc-cmd-mnu-056.
      *                  *---------------------------------------------*
      *                  * Codice comando in uppercase                 *
      *                  *---------------------------------------------*
           move      06                   to   w-all-str-lun          .
           move      w-let-mnu-vmk
                    (w-acc-com-i01)       to   w-all-str-alf          .
           perform   all-str-upp-000      thru all-str-upp-999        .

           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-let-mnu-lmk
                    (w-acc-com-i01)       to   v-lin                  .
           move      11                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cmd-mnu-057.
      *                  *---------------------------------------------*
      *                  * Accettazione function key in mark point     *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      w-let-mnu-lmk
                    (w-acc-com-i01)       to   v-lin                  .
           move      w-let-mnu-pmk
                    (w-acc-com-i01)       to   v-pos                  .
           if        w-acc-com-i01        >    1
                     move  "UP  "         to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-let-mnu-epp        =    "S"
                     move  "PRSC"         to   v-pfk (07)             .
           if        w-let-mnu-eps        =    "S"
                     move  "NXSC"         to   v-pfk (08)             .
           move      "SLCT"               to   v-pfk (10)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           if        v-key                =    spaces
