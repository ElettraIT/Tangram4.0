      *              * postazione nome comando o menu'                 *
      *              *-------------------------------------------------*
           if        v-key                =    spaces or
                     v-key                =    "DO  "
                     go to acc-cmd-mnu-150
           else if   v-key                =    "UP  "
                     go to acc-cmd-mnu-050
           else if   v-key                =    "EXIT"
                     go to acc-cmd-mnu-080
           else if   v-key                =    "PRSC"
                     go to acc-cmd-mnu-070
           else if   v-key                =    "NXSC"
                     go to acc-cmd-mnu-075
           else if   v-key                =    "PRNT"
                     go to acc-cmd-mnu-035
           else if   v-key                =    "FIND"
                     go to acc-cmd-mnu-033
           else if   v-key                =    "[1] "
                     go to acc-cmd-mnu-040
           else if   v-key                =    "[2] "
                     go to acc-cmd-mnu-042
           else if   v-key                =    "[3] "
                     go to acc-cmd-mnu-043
           else if   v-key                =    "[4] "
                     go to acc-cmd-mnu-044
           else if   v-key                =    "SLCT"
                     go to acc-cmd-mnu-045
           else      go to acc-cmd-mnu-025.
       acc-cmd-mnu-033.
      *              *-------------------------------------------------*
      *              * Se tasto Find                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se si e' in esecuzione *
      *                  * di desk-accessory                           *
