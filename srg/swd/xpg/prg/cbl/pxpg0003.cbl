      *                  * Sel su record di impegno stampanti          *
      *                  *---------------------------------------------*
           if        w-imp-ute-imp        not  = w-dim-stp-ute
                     go to dis-imp-stp-055.
           if        w-imp-can-stp
                    (01 : 01)             =    "#"
                     go to dis-imp-stp-055.
           if        w-imp-can-stp
                    (01 : 05)             =    "spool"
                     go to dis-imp-stp-055.
           if        w-imp-can-stp
                    (01 : 03)             =    "rcp"
                     go to dis-imp-stp-055.
           if        w-imp-can-stp
