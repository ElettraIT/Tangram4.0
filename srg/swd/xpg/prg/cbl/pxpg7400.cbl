      *              *-------------------------------------------------*
           move      spaces               to   w-scr-str-ele          .
       exe-exp-cmd-pth-100.
      *              *-------------------------------------------------*
      *              * Test se "menu"                                  *
      *              *-------------------------------------------------*
           if        w-cmd-tip-cmd        not  = 1
                     go to exe-exp-cmd-pth-200.
      *              *-------------------------------------------------*
      *              * Assemblaggio stringhe                           *
      *              *-------------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
      *
           move      "/menu/"             to   w-all-str-cat (1)      .
           move      w-cmd-cod-cmd        to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-scr-str-ele          .
           go to     exe-exp-cmd-pth-900.
       exe-exp-cmd-pth-200.
      *              *-------------------------------------------------*
      *              * Estrazione stringhe                             *
      *              *-------------------------------------------------*
           move      w-cmd-pth-cmd        to   w-scr-str-ele          .
           move      w-cmd-pth-cmd        to   w-all-str-alf          .
           move      "/"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           if        w-all-str-num        not  = 5
                     move  w-cmd-pth-cmd  to   w-scr-str-ele   
                     go to exe-exp-cmd-pth-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione stringhe                        *
      *              *-------------------------------------------------*
           move      w-all-str-cat (1)    to   w-exe-pth-el1          .
           move      w-all-str-cat (2)    to   w-exe-pth-el2          .
           move      w-all-str-cat (3)    to   w-exe-pth-el3          .
           move      w-all-str-cat (4)    to   w-exe-pth-el4          .
           move      w-all-str-cat (5)    to   w-exe-pth-el5          .
      *              *-------------------------------------------------*
      *              * Assemblaggio stringhe                           *
      *              *-------------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
      *
           move      w-exe-pth-el2        to   w-all-str-cat (1)      .
           move      "."                  to   w-all-str-cat (2)      .
           move      w-exe-pth-el5
                    (02 : 06)             to   w-all-str-cat (3)      .
           move      ".index"             to   w-all-str-cat (4)      .
      *
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-scr-str-ele          .
       exe-exp-cmd-pth-900.
