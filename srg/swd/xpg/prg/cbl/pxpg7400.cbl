      *    * - w-exe-pth-el1 = 'pgm'                                   *
      *    * - w-exe-pth-el2 = 'dcc'                                   *
      *    * - w-exe-pth-el3 = 'prg'                                   *
      *    * - w-exe-pth-el4 = 'obj'                                   *
      *    * - w-exe-pth-el5 = 'pdcc0200'                              *
      *    *                                                           *
      *    * Ad esempio 'pgm/dcc/prg/obj/pdcc0200' diventa             *
      *    *                                                           *
      *    *            'dcc.dcc020.index'                             *
