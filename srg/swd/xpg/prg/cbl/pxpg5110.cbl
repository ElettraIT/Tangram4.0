           move      "PF"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      66                   to   v-car                  .
           move      v-lnr                to   v-lin                  .
           move      15                   to   v-pos                  .
           move      srt-dat-prs-alf      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     liv-det-vlr-600.
       liv-det-vlr-600.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     liv-det-vlr-999.
       liv-det-vlr-999.
           exit.

