       pmt-cod-tst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice tipo stampante      :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
