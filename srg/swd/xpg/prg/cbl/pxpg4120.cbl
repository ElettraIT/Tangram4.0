           go to     prn-liv-det-425.
       prn-liv-det-425.
      *              *-------------------------------------------------*
      *              * Spaziature verticali                            *
      *              *-------------------------------------------------*
       prn-liv-det-426.
      *                  *---------------------------------------------*
      *                  * Se stampante di tipo Postscript o PCL5 o    *
      *                  * Special Printer SPPX : no stampa            *
      *                  *---------------------------------------------*
           if        w-tst-cla-tst        =    "PS  " or
                     w-tst-cla-tst        =    "PCL5" or
                     w-tst-cla-tst        =    "SPPX" or
                     w-tst-cla-tst        =    "FAX "
                     go to prn-liv-det-450.
       prn-liv-det-427.
      *                  *---------------------------------------------*
      *                  * Test se numero righe residue sufficienti    *
      *                  *---------------------------------------------*
           if        p-res                >    2
                     go to prn-liv-det-428.
      *                  *---------------------------------------------*
      *                  * Intestazione foglio                         *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                  *---------------------------------------------*
      *                  * Test se interruzione forzata                *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-428.
      *                  *---------------------------------------------*
      *                  * Due interlinee                              *
      *                  *---------------------------------------------*
           move      "L+"                 to   p-ope                  .
           move      2                    to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-429.
      *                  *---------------------------------------------*
      *                  * Literal                                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      32                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      010                  to   p-pos                  .
           move      "Spaziature verticali ......... :"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-430.
      *                  *---------------------------------------------*
      *                  * Spaziature verticali                        *
      *                  *---------------------------------------------*
       prn-liv-det-431.
           move      zero                 to   w-det-ctr-001          .
           move      zero                 to   w-det-inx-001          .
       prn-liv-det-432.
           add       1                    to   w-det-inx-001          .
           if        w-det-inx-001        >    20
                     go to prn-liv-det-438.
           if        w-tst-spa-ver
                    (w-det-inx-001)       =    zero
                     go to prn-liv-det-432.
       prn-liv-det-433.
           if        w-det-ctr-001        =    zero
                     go to prn-liv-det-435.
           if        p-res                >    1
                     go to prn-liv-det-434.
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-434.
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-435.
           add       1                    to   w-det-ctr-001          .
       prn-liv-det-436.
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      02                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<DB"                to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      043                  to   p-pos                  .
           move      w-tst-spa-ver
                    (w-det-inx-001)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-437.
           go to     prn-liv-det-432.
       prn-liv-det-438.
           go to     prn-liv-det-450.
       prn-liv-det-450.
      *                  *---------------------------------------------*
      *                  * Fine stampa                                 *
      *                  *---------------------------------------------*
           go to     prn-liv-det-500.
       prn-liv-det-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri intestazione standard,   *
      *              * che pero' espone non la ragione sociale del-    *
      *              * l'azienda in uso, bensi' la ragione sociale     *
      *              * del licenziatario software                      *
      *              *-------------------------------------------------*
           move      "TIPI STAMPANTE"     to   w-cnt-tit-des-tit      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
       int-pag-sta-100.
      *              *-------------------------------------------------*
      *              * Richiamo subroutine di intestazione pagina      *
      *              * standard                                        *
      *              *-------------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
       int-pag-sta-200.
      *              *-------------------------------------------------*
      *              * Se uscita per interruzione forzata              *
      *              *-------------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
       int-pag-sta-300.
      *              *-------------------------------------------------*
      *              * Separazione                                     *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       1
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-pag-sta-999.
       int-pag-sta-999.
           exit.

