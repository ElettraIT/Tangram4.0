      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-exe-pgm      .
       pre-exe-pgm-100.
      *              *-------------------------------------------------*
      *              * Lettura variabile di i.p.c. 'xpg-001'           *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "xpg-001"            to   s-var                  .
           move      "G"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces and
                     s-tip                =    "A"
                     move  s-alf          to   w-ipc-xpg-001
           else      move  spaces         to   w-ipc-xpg-001          .
           if        w-ipc-xpg-001        not  = "S"
                     move  spaces         to   w-ipc-xpg-001          .
       pre-exe-pgm-999.
