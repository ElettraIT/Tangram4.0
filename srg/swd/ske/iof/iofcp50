                                         using s                      .
           move      z-svx                to   z-inx                  .
           add       80                   to   z-inx                  .
           go to     ktk-250.
       ktk-275.
      *                  *---------------------------------------------*
      *                  * Fine blocchi da 80 caratteri ed esecuzione  *
      *                  * funzione di filtro                          *
      *                  *---------------------------------------------*
           move      "P9"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzkk"
                                         using s                      .
           if        s-sts                not  = spaces
                     move  e-fat-err      to   f-sts
                     go to ktk-999.
       ktk-300.
      *              *-------------------------------------------------*
      *              * Get da modulo per richiamo filtri               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record logico               *
      *                  *---------------------------------------------*
           perform   nor-rec-log-000      thru nor-rec-log-999        .
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice per composizione a  *
      *                  * blocchi da 80 caratteri                     *
      *                  *---------------------------------------------*
           move      1                    to   z-sqc                  .
       ktk-325.
      *                  *---------------------------------------------*
      *                  * Lettura blocco da 80 caratteri              *
      *                  *---------------------------------------------*
           move      "G5"                 to   s-ope                  .
           move      z-sqc                to   s-num                  .
           call      "swd/mod/prg/obj/msqzkk"
                                         using s                      .
           if        s-sts                not  = spaces
                     go to ktk-400.
      *                  *---------------------------------------------*
      *                  * Composizione blocco da 80 caratteri in area *
      *                  * del record logico                           *
      *                  *---------------------------------------------*
           move      z-sqc                to   z-inx                  .
           perform   stg-rec-log-000      thru stg-rec-log-999        .
      *                  *---------------------------------------------*
      *                  * Incremento indice per composizione          *
      *                  *---------------------------------------------*
           add       80                   to   z-sqc                  .
      *                  *---------------------------------------------*
      *                  * A prossimo blocco da 80 caratteri           *
