       sqz-425.
      *                  *---------------------------------------------*
      *                  * Scrittura n records da 80 caratteri         *
      *                  *---------------------------------------------*
           move      1                    to   z-inx                  .
       sqz-450.
           move      spaces               to   s-alf                  .
           move      z-inx                to   z-svx                  .
           perform   uns-rec-log-000      thru uns-rec-log-999        .
           if        z-inx                =    z-svx
                     go to sqz-475.
           move      "P5"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzou"
                                         using s                      .
           move      z-svx                to   z-inx                  .
           add       80                   to   z-inx                  .
           go to     sqz-450.
       sqz-475.
      *                  *---------------------------------------------*
      *                  * Fine blocchi da 80 caratteri                *
      *                  *---------------------------------------------*
           move      "P9"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzou"
                                         using s                      .
           if        s-sts                not  = spaces
                     move  e-fat-err      to   f-sts
                     go to sqz-999.
       sqz-600.
      *              *-------------------------------------------------*
      *              * Riciclo a Read Next su file                     *
      *              *-------------------------------------------------*
           go to     sqz-200.
       sqz-800.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione - canc.   *
      *              *-------------------------------------------------*
           move      "IC"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Close file sequenziale                          *
      *              *-------------------------------------------------*
           move      "CL"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzou"
                                         using s                      .
           cancel    "swd/mod/prg/obj/msqzou"                         .
           if        s-sts                not  = spaces
                     move  e-fat-err      to   f-sts
                     go to sqz-999.
       sqz-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di indicizzazione del file da '.sqz'           *
      *    *-----------------------------------------------------------*
       idx-000.
      *              *-------------------------------------------------*
      *              * Open file sequenziale                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   s-ope                  .
           move      f-fil-nam            to   s-nam                  .
           move      f-fil-pat            to   s-pat                  .
           call      "swd/mod/prg/obj/msqzin"
                                         using s                      .
           if        s-sts                not  = spaces
                     move  e-fat-err      to   f-sts
                     go to idx-999.
      *              *-------------------------------------------------*
      *              * Comunicazione attributi sul filtro              *
      *              *-------------------------------------------------*
           move      "FT"                 to   s-ope                  .
           move      z-tpf                to   s-num                  .
           move      z-nmf                to   s-pat                  .
           call      "swd/mod/prg/obj/msqzou"
                                         using s                      .
       idx-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read Next da file sequenziale                   *
      *              *-------------------------------------------------*
           move      "G0"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzin"
                                         using s                      .
           if        s-sts                not  = spaces
                     go to idx-800.
      *              *-------------------------------------------------*
      *              * Preparazione lettura a blocchi da 80 caratteri  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record logico               *
      *                  *---------------------------------------------*
           perform   nor-rec-log-000      thru nor-rec-log-999        .
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice per composizione a  *
      *                  * blocchi da 80 caratteri                     *
      *                  *---------------------------------------------*
           move      1                    to   z-sqc                  .
       idx-250.
      *              *-------------------------------------------------*
      *              * Lettura blocco da 80 caratteri                  *
      *              *-------------------------------------------------*
           move      "G5"                 to   s-ope                  .
           move      z-sqc                to   s-num                  .
           call      "swd/mod/prg/obj/msqzin"
                                         using s                      .
           if        s-sts                not  = spaces
                     go to idx-400.
      *              *-------------------------------------------------*
      *              * Composizione blocco da 80 caratteri in area del *
      *              * record logico                                   *
      *              *-------------------------------------------------*
           move      z-sqc                to   z-inx                  .
           perform   stg-rec-log-000      thru stg-rec-log-999        .
      *              *-------------------------------------------------*
      *              * Incremento indice per composizione              *
      *              *-------------------------------------------------*
           add       80                   to   z-sqc                  .
      *              *-------------------------------------------------*
      *              * A prossimo blocco da 80 caratteri               *
      *              *-------------------------------------------------*
           go to     idx-250.
       idx-400.
      *              *-------------------------------------------------*
      *              * Put su file, oppure Force Put su file           *
      *              *-------------------------------------------------*
           if        z-sqz                =    "SJ"
                     perform fpt-000      thru fpt-999
           else      perform put-000      thru put-999                .
      *              *-------------------------------------------------*
      *              * Se chiave gia' esistente : si ignora            *
      *              *-------------------------------------------------*
           if        f-sts                =    e-dup-key
                     go to idx-200.
      *              *-------------------------------------------------*
      *              * Se altro errore : uscita con fatal error        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  e-fat-err      to   f-sts
                     go to idx-999.
      *              *-------------------------------------------------*
      *              * Riciclo a Read Next da sequenziale              *
      *              *-------------------------------------------------*
           go to     idx-200.
       idx-800.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione - canc.   *
      *              *-------------------------------------------------*
           move      "IC"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Close file sequenziale                          *
      *              *-------------------------------------------------*
           move      "CL"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzin"
                                         using s                      .
           cancel    "swd/mod/prg/obj/msqzin"                         .
           if        s-sts                not  = spaces
                     move  e-fat-err      to   f-sts
                     go to idx-999.
       idx-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di trattamento del file su se' stesso          *
      *    *-----------------------------------------------------------*
       ktk-000.
      *              *-------------------------------------------------*
      *              * Open modulo per richiamo filtri, con comunica-  *
      *              * zione attributi sul filtro                      *
      *              *-------------------------------------------------*
           move      "OP"                 to   s-ope                  .
           move      z-tpf                to   s-num                  .
           move      z-nmf                to   s-pat                  .
           call      "swd/mod/prg/obj/msqzkk"
                                         using s                      .
           if        s-sts                not  = spaces
                     move  e-fat-err      to   f-sts
                     go to ktk-999.
      *              *-------------------------------------------------*
