      *              *-------------------------------------------------*
           move      "NL"                 to   f-cfr                  .
           move      low-values           to   fil-rec                .
           move      1                    to   z-key                  .
           perform   str-000              thru str-999                .
           if        f-sts                not  = e-not-err
                     go to ktk-800.
       ktk-100.
      *              *-------------------------------------------------*
      *              * Get Next su file                                *
      *              *-------------------------------------------------*
           move      1                    to   z-lok                  .
           perform   nxt-000              thru nxt-999                .
           if        f-sts                not  = e-not-err
                     go to ktk-800.
       ktk-200.
      *              *-------------------------------------------------*
      *              * Put su modulo per richiamo filtri               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizio blocchi da 80 caratteri              *
      *                  *---------------------------------------------*
           move      "P0"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msqzkk"
                                         using s                      .
       ktk-225.
      *                  *---------------------------------------------*
      *                  * Scrittura n records da 80 caratteri         *
      *                  *---------------------------------------------*
           move      1                    to   z-inx                  .
       ktk-250.
           move      spaces               to   s-alf                  .
           move      z-inx                to   z-svx                  .
           perform   uns-rec-log-000      thru uns-rec-log-999        .
           if        z-inx                =    z-svx
