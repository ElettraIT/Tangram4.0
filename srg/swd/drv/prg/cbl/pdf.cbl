       emi-seq-lin-fnt-600.
      *              *-------------------------------------------------*
      *              * Transformation matrix font                      *
      *              *                                                 *
      *              * Specifiche :                                    *
      *              *                                                 *
      *              *  - AAA.AAA = Larghezza Font (dpi)               *
      *              *  - B       = Inclinazione Y                     *
      *              *  - C       = Inclinazione X                     *
      *              *  - DDD.DDD = Altezza interlinea                 *
      *              *  - EEE.EEE = Margine sinistro                   *
      *              *  - FFF.FFF = Margine superiore                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo larghezza font                      *
      *                  *                                             *
      *                  * (Dpi / Ampiezza linea in caratteri)* Coeff. *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Eventuale rotazione                     *
      *                      *-----------------------------------------*
           if        p-sel-als-sel        >    w-lim-rot
                     move  17,20          to   w-fnt-coe
           else      move  11,40          to   w-fnt-coe              .
      *                      *-----------------------------------------*
      *                      * Calcolo                                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-fnt-wdt              .
           divide    p-sel-als-sel        into 72
                                        giving w-fnt-wdt              .
           multiply  w-fnt-coe            by   w-fnt-wdt              .
      *                  *---------------------------------------------*
      *                  * Editing larghezza font                      *
      *                  *---------------------------------------------*
           move      w-fnt-wdt            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-edt-wdt              .
      *                  *---------------------------------------------*
      *                  * Calcolo altezza interlinea                  *
      *                  *                                             *
      *                  * [(Altezza stampante - margini)/linee ]/0.9  *
      *                  *---------------------------------------------*
           move      73                   to   w-set-nrl              .
           move      p-sel-msu-tst        to   w-set-mrg              .
           add       p-sel-min-tst        to   w-set-mrg              .
           move      w-alt-stp            to   w-alt-int              .
           subtract  w-set-mrg            from w-alt-int              .
           divide    w-set-nrl            into w-alt-int              .
           multiply  0,9                  by   w-alt-int              .
      *                  *---------------------------------------------*
      *                  * Editing altezza interlinea                  *
      *                  *---------------------------------------------*
           move      w-alt-int            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-edt-int              .
      *                  *---------------------------------------------*
      *                  * Editing margine sinistro                    *
      *                  *---------------------------------------------*
           move      p-sel-msi-tst        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-edt-msi              .
      *                  *---------------------------------------------*
      *                  * Calcolo margine superiore testo             *
      *                  *---------------------------------------------*
           move      w-alt-stp            to   w-mrg-sup              .
           subtract  p-sel-min-tst        from w-mrg-sup              .
           subtract  w-alt-int            from w-mrg-sup              .
      *                  *---------------------------------------------*
      *                  * Editing margine superiore testo             *
      *                  *---------------------------------------------*
           move      w-mrg-sup            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-edt-psu              .
       emi-seq-lin-fnt-610.
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
