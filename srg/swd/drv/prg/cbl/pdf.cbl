      *    *===========================================================*
      *    * Emissione sequenze di controllo per una linea             *
      *    *                                                           *
      *    * Input  : w-lin-stp-amp = Ampiezza linea da stampare       *
      *    *                                                           *
      *    *          w-lin-stp-inx = Indice linea da stampare         *
      *    *                                                           *
      *    *          w-lin-stp-cnt = Contenuto linea da stampare      *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       emi-seq-lin-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se riquadro da stampare                *
      *                  *---------------------------------------------*
           if        w-lin-stp-cnt
                    (01 : 01)             =    "=" and
                     w-lin                =    01
                     move  "#"            to   w-pdf-box-pag          .
       emi-seq-lin-050.
      *              *-------------------------------------------------*
      *              * Inizio testo e dichiarazione font               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-pdf-dcr-fnt        =    spaces
                     go to emi-seq-lin-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di utilizzo grassetto  *
      *                  *---------------------------------------------*
           move      spaces               to   w-pdf-dcr-fnt          .
      *                  *---------------------------------------------*
      *                  * Dichiarazione font                          *
      *                  *---------------------------------------------*
           perform   emi-seq-lin-fnt-000  thru emi-seq-lin-fnt-999    .
       emi-seq-lin-100.
      *              *-------------------------------------------------*
      *              * Test se linea da abblencare                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test solo se prime 5 linee                  *
      *                  *---------------------------------------------*
           if        w-lin                >    05
                     go to emi-seq-lin-200.
      *                  *---------------------------------------------*
      *                  * Test se linea titolo inferiore a 3 o 4 o 5  *
      *                  *---------------------------------------------*
           if        w-pdf-lin-fin        >    zero
                     go to emi-seq-lin-120.
           if        w-lin-stp-cnt
                    (01 : 01)             =    "-"
                     move  w-lin          to   w-pdf-lin-fin          .
       emi-seq-lin-120.
      *                  *---------------------------------------------*
      *                  * Se individuata una fincatura, ci si compor- *
      *                  * ta come per le linee vuote                  *
      *                  *---------------------------------------------*
           if        w-lin-stp-cnt
                    (01 : 01)             =    "=" or
                     w-lin-stp-cnt
                    (01 : 01)             =    "-"
                     go to emi-seq-lin-220.
       emi-seq-lin-200.
      *              *-------------------------------------------------*
      *              * Linea di stampa normale                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se contenuto a spaces                  *
      *                  *---------------------------------------------*
           if        w-lin-stp-cnt        not  = spaces
                     go to emi-seq-lin-250.
       emi-seq-lin-220.
      *              *-------------------------------------------------*
      *              * Eventuale ritaratura font                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-lin                not  > 1
                     go to emi-seq-lin-240.
           if        w-pdf-bld-utl        =    spaces
                     go to emi-seq-lin-240.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di utilizzo grassetto  *
      *                  *---------------------------------------------*
           move      spaces               to   w-pdf-bld-utl          .
      *                  *---------------------------------------------*
      *                  * Font base                                   *
      *                  *---------------------------------------------*
           move      "/F1 1 Tf"           to   w-pdf-str-001          .
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      09                   to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Incremento contatore byte                   *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-byt          .
      *                  *---------------------------------------------*
      *                  * Incremento contatore stream                 *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-str          .
      *                  *---------------------------------------------*
      *                  * Composizione e scrittura                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    w-pdf-str-001
                                delimited by   size
                     w-c0c-CR   delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-seq-lin-240.
      *              *-------------------------------------------------*
      *              * Emissione linea                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      06                   to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Incremento contatore byte                   *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-byt          .
      *                  *---------------------------------------------*
      *                  * Incremento contatore stream                 *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-str          .
      *                  *---------------------------------------------*
      *                  * Composizione e scrittura                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    "( )Tj"    delimited by   size
                     w-c0c-CR   delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     emi-seq-lin-600.
       emi-seq-lin-250.
      *                  *---------------------------------------------*
      *                  * Scorrimento a destra di un carattere per    *
      *                  * fare spazio alla parentesi                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-lin-cnt-wrk          .
           move      w-lin-stp-cnt        to   w-lin-cnt-wrk
                                              (02 : p-sel-als-sel)    .
           move      "("                  to   w-lin-cnt-wrk
                                              (01 : 01)               .
      *                  *---------------------------------------------*
      *                  * Determinazione della lunghezza effettiva se *
      *                  * si eliminano gli spazi in coda              *
      *                  *---------------------------------------------*
           move      zero                 to   w-pdf-ctr-001          .
           inspect   w-lin-cnt-wrk    tallying w-pdf-ctr-001
                                  for trailing spaces                 .
           move      250                  to   w-pdf-ctr-002          .
           subtract  w-pdf-ctr-001        from w-pdf-ctr-002          .
           add       1                    to   w-pdf-ctr-002          .
      *                  *---------------------------------------------*
      *                  * Aggiunta del terminatore 'Tj' e dei carat-  *
      *                  * teri '%｣' per tagliare la stringa           *
      *                  *---------------------------------------------*
           move      ")Tj%｣#"             to   w-lin-cnt-wrk
                                              (w-pdf-ctr-002 : 06)    .
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Composizione e scrittura                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    w-lin-cnt-wrk
                                delimited by   "%｣#"
                     w-c0c-CR   delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Incremento contatore byte                   *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-byt          .
      *                  *---------------------------------------------*
      *                  * Incremento contatore stream                 *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-str          .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     emi-seq-lin-600.
       emi-seq-lin-600.
      *              *-------------------------------------------------*
      *              * Posizionamento prima linea                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-lin                not  = 01
                     go to emi-seq-lin-700.
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      13                   to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Incremento contatore byte                   *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-byt          .
      *                  *---------------------------------------------*
      *                  * Incremento contatore stream                 *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-str          .
      *                  *---------------------------------------------*
      *                  * Composizione e scrittura                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    "0 -1.1111 TD"
                                delimited by   size
                     w-c0c-CR   delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     emi-seq-lin-900.
       emi-seq-lin-700.
      *              *-------------------------------------------------*
      *              * 'T*'                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da emettere                         *
      *                  *---------------------------------------------*
           if        w-lin                =    p-sel-efc-sel
                     go to emi-seq-lin-900.
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      03                   to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Incremento contatore byte                   *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-byt          .
      *                  *---------------------------------------------*
      *                  * Incremento contatore stream                 *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-str          .
      *                  *---------------------------------------------*
      *                  * Composizione e scrittura                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    "T*"       delimited by   size
                     w-c0c-CR   delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-seq-lin-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-seq-lin-999.
       emi-seq-lin-999.
           exit.

      *    *===========================================================*
      *    * Emissione sequenze di controllo per una linea             *
      *    *                                                           *
      *    * Lettura facilitata                                        *
      *    *-----------------------------------------------------------*
       emi-seq-lin-fcl-000.
      *              *-------------------------------------------------*
      *              * Test sul flag di riquadratura                   *
      *              *-------------------------------------------------*
           if        w-pdf-let-fcl        =    spaces
                     go to emi-seq-lin-fcl-900.
       emi-seq-lin-fcl-100.
      *              *-------------------------------------------------*
      *              * Ciclo per 66/2 linee + 1                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione top line                    *
      *                  *---------------------------------------------*
           if        p-sel-als-sel        >    w-lim-rot
                     move  0520,6582      to   w-fcl-tix
           else      move  0755,3286      to   w-fcl-tix              .
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-pdf-ctr-001          .
       emi-seq-lin-fcl-200.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-pdf-ctr-001          .
      *                  *---------------------------------------------*
      *                  * Test su contatore                           *
      *                  *---------------------------------------------*
           if        w-pdf-ctr-001        >    34
                     go to emi-seq-lin-fcl-900.
       emi-seq-lin-fcl-300.
      *                  *---------------------------------------------*
      *                  * Calcolo margine lettura facilitata - left   *
      *                  *---------------------------------------------*
           move      p-sel-mde-tst        to   w-fcl-lrq              .
      *                  *---------------------------------------------*
      *                  * Editing margine lettura facilitata - left   *
      *                  *---------------------------------------------*
           move      w-fcl-lrq            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-fce-lrq              .
      *                  *---------------------------------------------*
      *                  * Calcolo coefficiente di incremento          *
      *                  *---------------------------------------------*
           move      73                   to   w-set-nrl              .
           move      p-sel-msu-tst        to   w-set-mrg              .
           add       p-sel-min-tst        to   w-set-mrg              .
           move      w-alt-stp            to   w-fcl-inx              .
           subtract  w-set-mrg            from w-fcl-inx              .
           divide    w-set-nrl            into w-fcl-inx              .
           move      w-fcl-inx            to   w-fcl-wdt              .
           add       0,2                  to   w-fcl-wdt              .
           multiply  2                    by   w-fcl-inx              .
      *                  *---------------------------------------------*
      *                  * Calcolo margine lettura facilitata - top    *
      *                  *---------------------------------------------*
           subtract  w-fcl-inx            from w-fcl-tix              .
      *                  *---------------------------------------------*
      *                  * Editing margine lettura facilitata - top    *
      *                  *---------------------------------------------*
           move      w-fcl-tix            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-fce-tix              .
      *                  *---------------------------------------------*
      *                  * Editing spessore linea                      *
      *                  *---------------------------------------------*
           move      w-fcl-wdt            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-fce-wdt              .
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza linea                     *
      *                  *---------------------------------------------*
           move      w-lar-stp            to   w-fcl-rrq              .
           subtract  p-sel-mde-tst        from w-fcl-rrq              .
           subtract  2                    from w-fcl-rrq              .
      *                  *---------------------------------------------*
      *                  * Editing lunghezza linea                     *
      *                  *---------------------------------------------*
           move      w-fcl-rrq            to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-fce-rrq              .
       emi-seq-lin-fcl-320.
      *                  *---------------------------------------------*
      *                  * Set gray %                                  *
      *                  *---------------------------------------------*
           move      07                   to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Incremento contatore byte                   *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-byt          .
      *                  *---------------------------------------------*
      *                  * Incremento contatore stream                 *
      *                  *---------------------------------------------*
           add       w-fil-bin-wrt-lun    to   w-pdf-ctr-str          .
      *                  *---------------------------------------------*
      *                  * Composizione e scrittura                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    "0.90 G"   delimited by   size
                     w-c0c-CR   delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-seq-lin-fcl-400.
      *                  *---------------------------------------------*
