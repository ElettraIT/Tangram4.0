      *    *===========================================================*
      *    * Lettura delle referenze generali                          *
      *    *-----------------------------------------------------------*
       ref-stp-gen-000.
      *              *-------------------------------------------------*
      *              * Ciclo per 'max' referenze                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ref-stp-gen-ctr      .
       ref-stp-gen-200.
           add       1                    to   w-ref-stp-gen-ctr      .
           if        w-ref-stp-gen-ctr    >    w-ref-stp-gen-max
                     go to ref-stp-gen-999.
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-ref-stp-gen-spr
                                              (w-ref-stp-gen-ctr)     .
      *                  *---------------------------------------------*
      *                  * Lettura referenza multipla                  *
      *                  *---------------------------------------------*
           move      "R:"                 to   s-ope                  .
           move      w-ref-stp-gen-ctr    to   s-num                  .
           move      "swd/drv/datamax[prm-gen]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        s-ves                not  = spaces
                     go to ref-stp-gen-800.
           if        s-alf                =    spaces
                     go to ref-stp-gen-800.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione referenza                   *
      *                  *---------------------------------------------*
           move      s-alf                to   w-ref-stp-gen-spr
                                              (w-ref-stp-gen-ctr)     .
       ref-stp-gen-800.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     ref-stp-gen-200.
       ref-stp-gen-999.
           exit.

