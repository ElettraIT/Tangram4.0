       emi-seq-inp-000.
      *              *-------------------------------------------------*
      *              * Determinazione dell'ultima linea non vuota      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-lin-stp-yff          .
           move      zero                 to   w-lin-stp-yfs          .
           move      zero                 to   w-lin                  .
       emi-seq-inp-020.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-lin                  .
      *                  *---------------------------------------------*
      *                  * Test se fine Corpo                          *
      *                  *---------------------------------------------*
           if        w-lin                >    73
                     go to emi-seq-inp-050.
           if        p-buf-lin (w-lin)    not  = spaces
                     move  zero           to   w-lin-stp-yfs
                     move  spaces         to   w-lin-stp-yff
                     go to emi-seq-inp-020.
           if        w-lin-stp-yff        not  = spaces
                     go to emi-seq-inp-020.
           move      w-lin                to   w-lin-stp-yfs          .
           if        w-lin-stp-yff        =    spaces
                     move  "#"            to   w-lin-stp-yff          .
           go to     emi-seq-inp-020.
       emi-seq-inp-050.
      *                  *---------------------------------------------*
      *                  * Determinazione altezza dei box              *
      *                  *---------------------------------------------*
           move      zero                 to   w-lin-stp-lbi          .
           if        w-lin-stp-yfs        =    zero or
                     w-lin-stp-yfs        >    66
                     move  3020           to   w-lin-stp-lbi
                     go to emi-seq-inp-060.
           multiply  w-lin-stp-yfs        by   45
                                        giving w-lin-stp-lbi          .
       emi-seq-inp-060.
