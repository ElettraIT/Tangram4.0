       emi-lay-pag-ret-000.
      *              *-------------------------------------------------*
      *              * Eventuale retinatura                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da preparare                        *
      *                  *---------------------------------------------*
           if        w-lay-pag-shd        =    "0"
                     go to emi-lay-pag-ret-200.
      *                  *---------------------------------------------*
      *                  * Raster resolution                           *
      *                  *---------------------------------------------*
           move      07                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*t300R"  
                                delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Shading                                     *
      *                  *---------------------------------------------*
           move      06                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*c"       delimited by   size
                     w-lay-pag-shp
                                delimited by   size
                     "G"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-ret-200.
      *              *-------------------------------------------------*
      *              * Rettangolo                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Orizzontale                                 *
      *                  *---------------------------------------------*
           move      w-lay-pag-xnu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-xal          .
           move      w-edt-num-str-lun    to   w-lay-pag-xlu          .
      *                  *---------------------------------------------*
      *                  * Verticale                                   *
      *                  *---------------------------------------------*
           move      w-lay-pag-ynu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-yal          .
           move      w-edt-num-str-lun    to   w-lay-pag-ylu          .
      *                  *---------------------------------------------*
      *                  * Lunghezza della sequenza                    *
      *                  *---------------------------------------------*
           move      07                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-xlu        to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-ylu        to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Sequenza                                    *
      *                  *---------------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "*c"       delimited by   size
                     w-lay-pag-xal
                                delimited by   spaces
                     "a"        delimited by   size
                     w-lay-pag-yal
                                delimited by   spaces
                     "b"        delimited by   size
                     w-lay-pag-shd
                                delimited by   spaces
                     "P"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-ret-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-lay-pag-ret-999.
       emi-lay-pag-ret-999.
           exit.

