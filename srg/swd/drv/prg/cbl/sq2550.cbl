      *    *===========================================================*
      *    * Definizione di 96 Line Feed consecutivi, a seconda del    *
      *    * tipo di interlinea                                        *
      *    *-----------------------------------------------------------*
       def-096-lfc-000.
           if        w-par-pds-int        =    01
                     go to def-096-lfc-100
           else if   w-par-pds-int        =    02
                     go to def-096-lfc-200
           else if   w-par-pds-int        =    03
                     go to def-096-lfc-300.
       def-096-lfc-100.
           move      spaces               to   w-96l                  .
           inspect   w-96l      replacing all  spaces
                                          by   w-c0c-LF               .
           go to     def-096-lfc-999.
       def-096-lfc-200.
           move      spaces               to   w-96l                  .
           inspect   w-96l      replacing all  spaces
                                          by   w-c0c-CR               .
           go to     def-096-lfc-999.
       def-096-lfc-300.
           move      zero                 to   w-par-pds-ctr          .
           move      zero                 to   w-par-pds-pnt          .
       def-096-lfc-302.
           add       1                    to   w-par-pds-ctr          .
           if        w-par-pds-ctr        >    96
                     go to def-096-lfc-999.
           add       1                    to   w-par-pds-pnt          .
           move      w-c0c-CR             to   w-96l
                                              (w-par-pds-pnt : 1)     .
           add       1                    to   w-par-pds-pnt          .
           move      w-c0c-LF             to   w-96l
                                              (w-par-pds-pnt : 1)     .
           go to     def-096-lfc-302.
       def-096-lfc-999.
           exit.

