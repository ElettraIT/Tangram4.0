           move      w-non-sta-des        to   w-for-nde-72p          .
      *                  *---------------------------------------------*
      *                  * Determinazione altezza utile relativa al    *
      *                  * tipo stampante, calcolata come differenza   *
      *                  * tra l'altezza effettiva e i margini effet-  *
      *                  * tivi, in 72mi di pollice:                   *
      *                  *  - Se orientamento verticale                *
      *                  *       - Margine superiore                   *
      *                  *       - Margine inferiore                   *
      *                  *  - Se orientamento orizzontale              *
      *                  *       - Margine sinistro                    *
      *                  *       - Margine destro                      *
      *                  *---------------------------------------------*
           if        w-for-toc-voo        =    "O"
                     move     w-for-alt-tst
                                          to   w-for-alt-utl
                     subtract w-for-msi-72p
                                          from w-for-alt-utl
                     subtract w-for-mde-72p
                                          from w-for-alt-utl
           else      move     w-for-alt-tst
                                          to   w-for-alt-utl
                     subtract w-for-msu-72p
                                          from w-for-alt-utl
                     subtract w-for-min-72p
                                          from w-for-alt-utl          .
      *                  *---------------------------------------------*
      *                  * Determinazione larghezza utile relativa al  *
      *                  * tipo stampante, calcolata come differenza   *
      *                  * tra la larghezza effettiva e i margini ef-  *
      *                  * fettivi, in 72mi di pollice:                *
      *                  *  - Se orientamento verticale                *
      *                  *       - Margine sinistro                    *
      *                  *       - Margine destro                      *
      *                  *  - Se orientamento orizzontale              *
      *                  *       - Margine superiore                   *
      *                  *       - Margine inferiore                   *
      *                  *---------------------------------------------*
           if        w-for-toc-voo        =    "O"
                     move     w-for-lar-tst
                                          to   w-for-lar-utl
                     subtract w-for-msu-72p
                                          from w-for-lar-utl
                     subtract w-for-min-72p
                                          from w-for-lar-utl
           else      move     w-for-lar-tst
                                          to   w-for-lar-utl
                     subtract w-for-msi-72p
                                          from w-for-lar-utl
                     subtract w-for-mde-72p
                                          from w-for-lar-utl          .
