           move      zero                 to   w-lay-pag-box-pmb      .
      *
           subtract  w-lay-pag-box-alt    from w-lay-pag-box-yyy      .
           add       w-lin-stp-ibl        to   w-lay-pag-box-yyy      .
           perform   emi-lay-pag-box-000  thru emi-lay-pag-box-999    .
       emi-seq-lin-360.
      *                  *---------------------------------------------*
      *                  * Box per codice                              *
      *                  *---------------------------------------------*
           move      1181                 to   w-lay-pag-box-xxx      .
           move      w-lin-stp-lin        to   w-lay-pag-box-yyy      .
           move      0160                 to   w-lay-pag-box-lun      .
           move      w-lin-stp-abx        to   w-lay-pag-box-alt      .
           move      0003                 to   w-lay-pag-box-sps      .
           move      "0"                  to   w-lay-pag-box-ptr      .
      *
           if        w-lin                =    06
                     move  "2"            to   w-lay-pag-box-rtn
                     move  "20"           to   w-lay-pag-box-rtp
           else      move  "0"            to   w-lay-pag-box-rtn
                     move  spaces         to   w-lay-pag-box-rtp      .
      *
           move      spaces               to   w-lay-pag-box-pmt      .
           move      zero                 to   w-lay-pag-box-pmp      .
           move      zero                 to   w-lay-pag-box-pmd      .
           move      zero                 to   w-lay-pag-box-pmb      .
      *
           subtract  w-lay-pag-box-alt    from w-lay-pag-box-yyy      .
           add       w-lin-stp-ibl        to   w-lay-pag-box-yyy      .
           perform   emi-lay-pag-box-000  thru emi-lay-pag-box-999    .

       emi-seq-lin-400.
      *                  *---------------------------------------------*
      *                  * Test su numero linea                        *
      *                  *---------------------------------------------*
           if        w-lin                <    07
                     go to emi-seq-lin-900.
      *                  *---------------------------------------------*
      *                  * Estrazione codice da stampare - Code 128    *
      *                  *---------------------------------------------*
           move      w-lin-stp-cnt
                    (w-lay-lcb-pbl : 05)  to   w-lay-lcb-128          .
      *                  *---------------------------------------------*
      *                  * Test se codice numerico                     *
      *                  *---------------------------------------------*
           if        w-lay-num-128        not  numeric
                     go to emi-seq-lin-900.
      *                  *---------------------------------------------*
      *                  * Determinazione check digit per un codice    *
      *                  * numerico di 5 cifre (F.I.)                  *
      *                  *                                             *
      *                  * Componenti :                                *
      *                  *                                             *
      *                  *  Start digit              = 105   (set.'C') *
      *                  *  1. coppia    "99"        = nn  x 1         *
      *                  *  2. coppia    "99"        = nn  x 2         *
      *                  *  Code 'C'                 = 100 x 3         *
      *                  *  5. cifra     "9"         = nn  x 4         *
      *                  *                                             *
      *                  *  Si sommano tutti i risultati delle molti-  *
      *                  *  plicazioni ed il totale si divide per 103. *
      *                  *  Il resto della divisione (cioe' si molti-  *
      *                  *  plica 103 per l'intero risultante dalla    *
      *                  *  divisione e si sottrae il risultato da     *
      *                  *  quello precedente. Es.: 518 : 103 = 5,02912*
      *                  *  103 * 5 = 515; 518 - 515 = 3 check digit)  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preliminare                             *
      *                      *-----------------------------------------*
           move      zero                 to   w-lay-lcb-chk          .
           move      105                  to   w-lay-lcb-c01          .
      *                      *-----------------------------------------*
      *                      * Scansione dei 05 caratteri              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Estrazione prima coppia             *
      *                          *-------------------------------------*
           move      w-lay-lcb-128
                    (01 : 02)             to   w-lay-lcb-cp1          .
           multiply  1                    by   w-lay-lcb-cp1
                                        giving w-lay-lcb-w01          .
           add       w-lay-lcb-w01        to   w-lay-lcb-c01          .
      *                          *-------------------------------------*
      *                          * Estrazione seconda coppia           *
      *                          *-------------------------------------*
           move      w-lay-lcb-128
                    (03 : 02)             to   w-lay-lcb-cp2          .
           multiply  2                    by   w-lay-lcb-cp2
                                        giving w-lay-lcb-w01          .
           add       w-lay-lcb-w01        to   w-lay-lcb-c01          .
      *                          *-------------------------------------*
      *                          * Estrazione code 'B' (value 100 * 3) *
      *                          *-------------------------------------*
           add       300                  to   w-lay-lcb-c01          .
      *                          *-------------------------------------*
      *                          * Estrazione cifra singola (0..9)     *
      *                          *-------------------------------------*
           move      w-lay-lcb-128
                    (05 : 01)             to   w-lay-lcb-sn1          .
           move      16                   to   w-lay-lcb-w02          .
           add       w-lay-lcb-sn1        to   w-lay-lcb-w02          .
           multiply  4                    by   w-lay-lcb-w02
                                        giving w-lay-lcb-w01          .
           add       w-lay-lcb-w01        to   w-lay-lcb-c01          .
      *                      *-----------------------------------------*
      *                      * Calcolo vero e proprio                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           divide    103                  into w-lay-lcb-c01
                                        giving w-lay-lcb-c02
                                     remainder w-lay-lcb-chk          .
      *                          *-------------------------------------*
      *                          * Compensazione sfasamento tabella    *
      *                          *-------------------------------------*
           add       1                    to   w-lay-lcb-chk          .
       emi-seq-lin-610.
      *                  *---------------------------------------------*
      *                  * Ciclo di preparazione 'code 128'            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ciclo 1..5                             *
      *                      *-----------------------------------------*
           move      spaces               to   w-128-cod-128          .
           move      zero                 to   w-lay-lcb-ctr          .
           move      1                    to   w-lay-lcb-006          .
       emi-seq-lin-620.
           add       1                    to   w-lay-lcb-ctr          .
           if        w-lay-lcb-ctr        >    5
                     go to emi-seq-lin-700.
      *                      *-----------------------------------------*
      *                      * Elementi variabili                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Delle 2 coppie                      *
      *                          *-------------------------------------*
           if        w-lay-lcb-ctr        not  = 01 and
                     w-lay-lcb-ctr        not  = 03
                     go to emi-seq-lin-640.
           move      w-lay-lcb-128
                    (w-lay-lcb-ctr : 02)  to   w-lay-lcb-inx          .
           add       1                    to   w-lay-lcb-inx          .
      *                          *-------------------------------------*
      *                          * A trattamento blocco                *
      *                          *-------------------------------------*
           go to     emi-seq-lin-660.
       emi-seq-lin-640.
      *                          *-------------------------------------*
      *                          * Estrazione carattere singolo        *
      *                          *-------------------------------------*
           if        w-lay-lcb-ctr        not  = 05
                     go to emi-seq-lin-620.
           move      w-lay-lcb-128
                    (w-lay-lcb-ctr : 01)  to   w-lay-lcb-inx          .
           add       16                   to   w-lay-lcb-inx          .
           add       1                    to   w-lay-lcb-inx          .
      *                          *-------------------------------------*
      *                          * A trattamento blocco                *
      *                          *-------------------------------------*
           go to     emi-seq-lin-660.
       emi-seq-lin-660.
      *                      *-----------------------------------------*
      *                      * Trattamento blocco da 6 componenti      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se 'start' character           *
      *                          *-------------------------------------*
           if        w-lay-lcb-ctr        not  = 01
                     go to emi-seq-lin-662.
           move      w-128-tbl-105        to   w-128-cod-128
                                              (w-lay-lcb-006 : 6)     .
           add       6                    to   w-lay-lcb-006          .
      *                              *---------------------------------*
      *                              * A bufferizzazione blocco        *
      *                              *---------------------------------*
           go to     emi-seq-lin-670.
       emi-seq-lin-662.
      *                          *-------------------------------------*
      *                          * Test se 'shift' character [set B]   *
      *                          *-------------------------------------*
           if        w-lay-lcb-ctr        not  = 05
                     go to emi-seq-lin-670.
           move      w-128-tbl-sbx (101)  to   w-128-cod-128
                                              (w-lay-lcb-006 : 6)     .
           add       6                    to   w-lay-lcb-006          .
      *                              *---------------------------------*
      *                              * A bufferizzazione blocco        *
      *                              *---------------------------------*
           go to     emi-seq-lin-670.
       emi-seq-lin-670.
      *                          *-------------------------------------*
      *                          * Bufferizzazione blocco              *
      *                          *-------------------------------------*
           move      w-128-tbl-sng
                    (w-lay-lcb-inx)       to   w-128-cod-128
                                              (w-lay-lcb-006 : 6)     .
           add       6                    to   w-lay-lcb-006          .
       emi-seq-lin-672.
      *                          *-------------------------------------*
      *                          * Test se fine                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        w-lay-lcb-ctr        not  = 05
                     go to emi-seq-lin-680.
      *                              *---------------------------------*
      *                              * 'check digit'                   *
      *                              *---------------------------------*
           move      w-128-tbl-sbx
                    (w-lay-lcb-chk)       to   w-128-cod-128
                                              (w-lay-lcb-006 : 6)     .
           add       6                    to   w-lay-lcb-006          .
      *                              *---------------------------------*
      *                              * 'stop' character                *
      *                              *---------------------------------*
           move      w-128-tbl-106        to   w-128-cod-128
                                              (w-lay-lcb-006 : 7)     .
      *                              *---------------------------------*
      *                              * A stampa                        *
      *                              *---------------------------------*
           go to     emi-seq-lin-700.
       emi-seq-lin-680.
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     emi-seq-lin-620.
       emi-seq-lin-700.
      *                  *---------------------------------------------*
      *                  * Stampa code 128                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Dimensioni                              *
      *                      *-----------------------------------------*
           move      00600                to   w-sbc-xyz-dim          .
      *                      *-----------------------------------------*
      *                      * Coordinate 'x,y'                        *
      *                      *-----------------------------------------*
           if        w-sbc-xyz-xfl        =    spaces
                     move  6300           to   w-sbc-xyz-xIP (1)
                     move  "#"            to   w-sbc-xyz-xfl
           else      move  5100           to   w-sbc-xyz-xIP (1)
                     move  spaces         to   w-sbc-xyz-xfl          .
           move      w-sbc-xyz-xln        to   w-sbc-xyz-yIP (1)      .
           perform   emi-seq-lin-128-000  thru emi-seq-lin-128-999    .
       emi-seq-lin-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-seq-lin-999.
       emi-seq-lin-999.
           exit.

      *    *===========================================================*
      *    * Emissione sequenze di controllo per una linea             *
      *    *                                                           *
      *    * Subroutine di stampa code-128 in base alla stringa in     *
      *    * input                                                     *
      *    *-----------------------------------------------------------*
       emi-seq-lin-128-000.
      *              *-------------------------------------------------*
      *              * Preparazioni preliminari                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Altezza bar-code                            *
      *                  *---------------------------------------------*
           move      "50"                 to   w-sbc-xyz-hbc          .
      *                  *---------------------------------------------*
      *                  * Completamento coordinate 'x,y'              *
      *                  *---------------------------------------------*
           move      w-sbc-xyz-xIP (1)    to   w-sbc-xyz-xIP (2)      .
           add       w-sbc-xyz-dim        to   w-sbc-xyz-xIP (2)      .
      *
           move      w-sbc-xyz-yIP (1)    to   w-sbc-xyz-yIP (2)      .
           add       w-sbc-xyz-dim        to   w-sbc-xyz-yIP (2)      .
      *                  *---------------------------------------------*
      *                  * Editing coordinate 'x,y'                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing 'x 1'                           *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-sbc-xyz-xIP (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-sbc-xyz-xIP-alf (1)  .
      *                      *-----------------------------------------*
      *                      * Editing 'x 2'                           *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-sbc-xyz-xIP (2)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-sbc-xyz-xIP-alf (2)  .
      *                      *-----------------------------------------*
      *                      * Editing 'y 1'                           *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-sbc-xyz-yIP (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-sbc-xyz-yIP-alf (1)  .
      *                      *-----------------------------------------*
      *                      * Editing 'y 2'                           *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-sbc-xyz-yIP (2)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-sbc-xyz-yIP-alf (2)  .
      *                      *-----------------------------------------*
      *                      * Assemblaggio sequenza                   *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      09                   to   w-all-str-num          .
           move      "IP"                 to   w-all-str-cat (01)     .
           move      w-sbc-xyz-xIP (1)    to   w-all-str-cat (02)     .
           move      ","                  to   w-all-str-cat (03)     .
           move      w-sbc-xyz-yIP (1)    to   w-all-str-cat (04)     .
           move      ","                  to   w-all-str-cat (05)     .
           move      w-sbc-xyz-xIP (2)    to   w-all-str-cat (06)     .
           move      ","                  to   w-all-str-cat (07)     .
           move      w-sbc-xyz-yIP (2)    to   w-all-str-cat (08)     .
           move      ";"                  to   w-all-str-cat (09)     .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-sbc-xyz-cIP          .
       emi-seq-lin-128-080.
      *              *-------------------------------------------------*
      *              * Preparazione poligoni                           *
      *              *-------------------------------------------------*
       emi-seq-lin-128-100.
      *              *-------------------------------------------------*
      *              * HP-GL : Attiva modo HP-GL/2                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lunghezza della sequenza                    *
      *                  *---------------------------------------------*
           move      04                   to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Sequenza                                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-fil-bin-wrt-rec      .
           string    w-c0c-ESC  delimited by   size
                     "%0B"      delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-110.
      *              *-------------------------------------------------*
      *              * HP-GL : Inizializza HP-GL/2                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione sequenza                       *
      *                  *---------------------------------------------*
           move      03                   to   w-fil-bin-wrt-lun      .
           move      spaces               to   w-fil-bin-wrt-rec      .
      *
           string    "IN;"      delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-120.
      *              *-------------------------------------------------*
      *              * HP-GL : Input Points - IP                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione sequenza                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
           move      spaces               to   w-fil-bin-wrt-rec      .
      *
           string    w-sbc-xyz-cIP
                                delimited by   spaces
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-140.
      *              *-------------------------------------------------*
      *              * HP-GL : Scale - SC                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione                                *
      *                  *                                             *
      *                  * N.B.: il secondo valore modifica la lun-    *
      *                  *       ghezza del bar-code, mentre il quarto *
      *                  *       modifica l'altezza. I valori agiscono *
      *                  *       a rovescio                            *
      *                  *---------------------------------------------*
           move      "SC0,45,0,170;       "
                                          to   w-sbc-xyz-cSC          .
      *                  *---------------------------------------------*
      *                  * Preparazione sequenza                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
           move      w-sbc-xyz-cSC        to   w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-160.
      *              *-------------------------------------------------*
      *              * HP-GL : Penna - Trasparenza                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione sequenza                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
           move      spaces               to   w-fil-bin-wrt-rec      .
      *
           string    "SP1;TR0;"  
                                delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-180.
      *              *-------------------------------------------------*
      *              * HP-GL : Fill Pattern                            *
      *              *-------------------------------------------------*
       emi-seq-lin-128-200.
      *              *-------------------------------------------------*
      *              * HP-GL : Poligoni                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scansione dei 'w-128-lng-128' componenti    *
      *                  *---------------------------------------------*
           move      spaces               to   w-sbc-xyz-swc          .
           move      zero                 to   w-sbc-xyz-c01          .
           move      zero                 to   w-sbc-xyz-cpa          .
       emi-seq-lin-128-220.
           add       1                    to   w-sbc-xyz-c01          .
           if        w-sbc-xyz-c01        >    w-128-lng-128
                     go to emi-seq-lin-128-700.
      *                  *---------------------------------------------*
      *                  * Estrazione elemento                         *
      *                  *---------------------------------------------*
           move      w-128-cod-128
                    (w-sbc-xyz-c01 : 1)   to   w-sbc-xyz-num          .
           move      w-128-cod-128
                    (w-sbc-xyz-c01 : 1)   to   w-sbc-xyz-alf          .
      *                  *---------------------------------------------*
      *                  * In base allo switch (s/b), si produce o me- *
      *                  * no il poligono                              *
      *                  *---------------------------------------------*
           if        w-sbc-xyz-swc        =    spaces
                     move  "#"            to   w-sbc-xyz-swc
           else      move  spaces         to   w-sbc-xyz-swc
                     go to emi-seq-lin-128-500.
      *                  *---------------------------------------------*
      *                  * Editing 'PA'                                *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-sbc-xyz-cpa        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Assemblaggio sequenza                       *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      07                   to   w-all-str-num          .
           move      "PA"                 to   w-all-str-cat (01)     .
           move      v-edt                to   w-all-str-cat (02)     .
           move      ",0;RR"              to   w-all-str-cat (03)     .
           move      w-sbc-xyz-alf        to   w-all-str-cat (04)     .
           move      ","                  to   w-all-str-cat (05)     .
           move      w-sbc-xyz-hbc        to   w-all-str-cat (06)     .
           move      ";"                  to   w-all-str-cat (07)     .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-sbc-xyz-pa1          .
      *                  *---------------------------------------------*
      *                  * Preparazione sequenza                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
           move      w-sbc-xyz-pa1        to   w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-seq-lin-128-500.
      *                  *---------------------------------------------*
      *                  * Aggiornamento comodo per il posizionamento  *
      *                  *---------------------------------------------*
           add       w-sbc-xyz-num        to   w-sbc-xyz-cpa          .
       emi-seq-lin-128-600.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     emi-seq-lin-128-220.
       emi-seq-lin-128-700.
      *              *-------------------------------------------------*
      *              * HP-GL : Fill Poligoni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lunghezza della sequenza                    *
      *                  *---------------------------------------------*
           move      zero                 to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Sequenza                                    *
      *                  *---------------------------------------------*
           move      "FP;"                to   w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-800.
      *              *-------------------------------------------------*
      *              * HP-GL : Fine - riattivazione PCL-5              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione sequenza                       *
      *                  *---------------------------------------------*
           move      04                   to   w-fil-bin-wrt-lun      .
           move      spaces               to   w-fil-bin-wrt-rec      .
      *
           string    w-c0c-ESC  delimited by   size
                     "%0A"      delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Se status stampa ad errore : uscita         *
      *                  *---------------------------------------------*
           if        w-err                not  =  spaces
                     go to emi-seq-lin-128-999.
       emi-seq-lin-128-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-seq-lin-128-999.
       emi-seq-lin-128-999.
           exit.

      *    *===========================================================*
      *    * Emissione Layout di pagina                                *
      *    *                                                           *
      *    * Subroutine di posizionamento                              *
      *    *-----------------------------------------------------------*
       emi-lay-pag-pos-000.
      *              *-------------------------------------------------*
      *              * Emissione coordinate di posizionamento          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Orizzontale                                 *
      *                  *---------------------------------------------*
           move      w-lay-pag-xnu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-xal          .
           move      w-edt-num-str-lun    to   w-lay-pag-xlu          .
      *                  *---------------------------------------------*
      *                  * Verticale                                   *
      *                  *---------------------------------------------*
           move      w-lay-pag-ynu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-yal          .
           move      w-edt-num-str-lun    to   w-lay-pag-ylu          .
       emi-lay-pag-pos-200.
      *                  *---------------------------------------------*
      *                  * Sequenza                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo di me-  *
      *                      * todo                                    *
      *                      *-----------------------------------------*
           if        w-lay-pag-mdp        =    "S"
                     go to emi-lay-pag-pos-300
           else if   w-lay-pag-mdp        =    "D"
                     go to emi-lay-pag-pos-400
           else if   w-lay-pag-mdp        =    "C"
                     go to emi-lay-pag-pos-500.
       emi-lay-pag-pos-300.
      *                      *-----------------------------------------*
      *                      * 72" di pollice                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lunghezza della sequenza            *
      *                          *-------------------------------------*
           move      04                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-ylu        to   w-fil-bin-wrt-lun      .
      *                          *-------------------------------------*
      *                          * Posizionamento verticale            *
      *                          *-------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "&a"       delimited by   size
                     w-lay-pag-yal
                                delimited by   spaces
                     "V"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                          *-------------------------------------*
      *                          * Emissione sequenza                  *
      *                          *-------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                          *-------------------------------------*
      *                          * Lunghezza della sequenza            *
      *                          *-------------------------------------*
           move      04                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-xlu        to   w-fil-bin-wrt-lun      .
      *                          *-------------------------------------*
      *                          * Posizionamento orizzontale          *
      *                          *-------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "&a"       delimited by   size
                     w-lay-pag-xal
                                delimited by   spaces
                     "H"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                          *-------------------------------------*
      *                          * Emissione sequenza                  *
      *                          *-------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-900.
       emi-lay-pag-pos-400.
      *                      *-----------------------------------------*
      *                      * Dots                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lunghezza della sequenza            *
      *                          *-------------------------------------*
           move      05                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-xlu        to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-ylu        to   w-fil-bin-wrt-lun      .
      *                          *-------------------------------------*
      *                          * Posizionamento                      *
      *                          *-------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "*p"       delimited by   size
                     w-lay-pag-xal
                                delimited by   spaces
                     "x"        delimited by   size
                     w-lay-pag-yal
                                delimited by   spaces
                     "Y"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                      *-----------------------------------------*
      *                      * Ad emissione sequenza                   *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-800.
       emi-lay-pag-pos-500.
      *                      *-----------------------------------------*
      *                      * Colonne                                 *
      *                      * ___ da implementare ___                 *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-900.


      *                      *-----------------------------------------*
      *                      * Ad emissione sequenza                   *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-800.
       emi-lay-pag-pos-800.
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-pos-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-lay-pag-pos-999.
       emi-lay-pag-pos-999.
           exit.

      *    *===========================================================*
      *    * Emissione Layout di pagina                                *
      *    *                                                           *
      *    * Subroutine per generazione rettangolo                     *
      *    *-----------------------------------------------------------*
       emi-lay-pag-ret-000.
      *              *-------------------------------------------------*
      *              * Eventuale retinatura                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da preparare                        *
      *                  *---------------------------------------------*
           if        w-lay-pag-shd        =    "0"
                     go to emi-lay-pag-ret-200.
      *                  *---------------------------------------------*
      *                  * Raster resolution                           *
      *                  *---------------------------------------------*
           move      07                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*t600R"  
                                delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Shading                                     *
      *                  *---------------------------------------------*
           move      06                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*c"       delimited by   size
                     w-lay-pag-shp
                                delimited by   size
                     "G"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-ret-200.
      *              *-------------------------------------------------*
      *              * Rettangolo                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Orizzontale                                 *
