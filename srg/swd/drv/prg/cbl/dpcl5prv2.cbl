           go to     emi-seq-lin-999.
       emi-seq-lin-999.
           exit.

      *    *===========================================================*
      *    * Emissione Layout di pagina                                *
      *    *                                                           *
      *    * Subroutine di posizionamento                              *
      *    *-----------------------------------------------------------*
       emi-lay-pag-pos-000.
      *              *-------------------------------------------------*
      *              * Emissione coordinate di posizionamento          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Orizzontale                                 *
      *                  *---------------------------------------------*
           move      w-lay-pag-xnu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-xal          .
           move      w-edt-num-str-lun    to   w-lay-pag-xlu          .
      *                  *---------------------------------------------*
      *                  * Verticale                                   *
      *                  *---------------------------------------------*
           move      w-lay-pag-ynu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-yal          .
           move      w-edt-num-str-lun    to   w-lay-pag-ylu          .
       emi-lay-pag-pos-200.
      *                  *---------------------------------------------*
      *                  * Sequenza                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo di me-  *
      *                      * todo                                    *
      *                      *-----------------------------------------*
           if        w-lay-pag-mdp        =    "S"
                     go to emi-lay-pag-pos-300
           else if   w-lay-pag-mdp        =    "D"
                     go to emi-lay-pag-pos-400
           else if   w-lay-pag-mdp        =    "C"
                     go to emi-lay-pag-pos-500.
       emi-lay-pag-pos-300.
      *                      *-----------------------------------------*
      *                      * 72" di pollice (decimi di punto)        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lunghezza della sequenza            *
      *                          *-------------------------------------*
           move      04                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-ylu        to   w-fil-bin-wrt-lun      .
      *                          *-------------------------------------*
      *                          * Posizionamento verticale            *
      *                          *-------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "&a"       delimited by   size
                     w-lay-pag-yal
                                delimited by   spaces
                     "V"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                          *-------------------------------------*
      *                          * Emissione sequenza                  *
      *                          *-------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                          *-------------------------------------*
      *                          * Lunghezza della sequenza            *
      *                          *-------------------------------------*
           move      04                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-xlu        to   w-fil-bin-wrt-lun      .
      *                          *-------------------------------------*
      *                          * Posizionamento orizzontale          *
      *                          *-------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "&a"       delimited by   size
                     w-lay-pag-xal
                                delimited by   spaces
                     "H"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                          *-------------------------------------*
      *                          * Emissione sequenza                  *
      *                          *-------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-900.
       emi-lay-pag-pos-400.
      *                      *-----------------------------------------*
      *                      * Dots                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lunghezza della sequenza            *
      *                          *-------------------------------------*
           move      05                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-xlu        to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-ylu        to   w-fil-bin-wrt-lun      .
      *                          *-------------------------------------*
      *                          * Posizionamento                      *
      *                          *-------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "*p"       delimited by   size
                     w-lay-pag-xal
                                delimited by   spaces
                     "x"        delimited by   size
                     w-lay-pag-yal
                                delimited by   spaces
                     "Y"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                      *-----------------------------------------*
      *                      * Ad emissione sequenza                   *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-800.
       emi-lay-pag-pos-500.
      *                      *-----------------------------------------*
      *                      * Colonne                                 *
      *                      * ___ da implementare ___                 *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-900.
      *                      *-----------------------------------------*
      *                      * Ad emissione sequenza                   *
      *                      *-----------------------------------------*
           go to     emi-lay-pag-pos-800.
       emi-lay-pag-pos-800.
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-pos-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-lay-pag-pos-999.
       emi-lay-pag-pos-999.
           exit.

      *    *===========================================================*
      *    * Emissione Layout di pagina                                *
      *    *                                                           *
      *    * Subroutine per generazione rettangolo                     *
      *    *-----------------------------------------------------------*
       emi-lay-pag-ret-000.
      *              *-------------------------------------------------*
      *              * Eventuale retinatura                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da preparare                        *
      *                  *---------------------------------------------*
           if        w-lay-pag-shd        =    "0"
                     go to emi-lay-pag-ret-200.
      *                  *---------------------------------------------*
      *                  * Raster resolution                           *
      *                  *---------------------------------------------*
           move      07                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*t600R"  
                                delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Campitura opaca                             *
      *                  *---------------------------------------------*
           move      05                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*v1O"     delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
      *                  *---------------------------------------------*
      *                  * Test se bianco pieno                        *
      *                  *---------------------------------------------*
           if        w-lay-pag-shd        =    "1"
                     go to emi-lay-pag-ret-200.
      *                  *---------------------------------------------*
      *                  * Shading                                     *
      *                  *---------------------------------------------*
           move      06                   to   w-fil-bin-wrt-lun      .
           string    w-c0c-ESC  delimited by   size
                     "*c"       delimited by   size
                     w-lay-pag-shp
                                delimited by   size
                     "G"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-ret-200.
      *              *-------------------------------------------------*
      *              * Rettangolo                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Orizzontale                                 *
      *                  *---------------------------------------------*
           move      w-lay-pag-xnu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-xal          .
           move      w-edt-num-str-lun    to   w-lay-pag-xlu          .
      *                  *---------------------------------------------*
      *                  * Verticale                                   *
      *                  *---------------------------------------------*
           move      w-lay-pag-ynu        to   w-edt-num-str-num      .
           perform   edt-num-str-000      thru edt-num-str-999        .
           move      w-edt-num-str-edt    to   w-lay-pag-yal          .
           move      w-edt-num-str-lun    to   w-lay-pag-ylu          .
      *                  *---------------------------------------------*
      *                  * Lunghezza della sequenza                    *
      *                  *---------------------------------------------*
           move      07                   to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-xlu        to   w-fil-bin-wrt-lun      .
           add       w-lay-pag-ylu        to   w-fil-bin-wrt-lun      .
      *                  *---------------------------------------------*
      *                  * Sequenza                                    *
      *                  *---------------------------------------------*
           string    w-c0c-ESC  delimited by   size
                     "*c"       delimited by   size
                     w-lay-pag-xal
                                delimited by   spaces
                     "a"        delimited by   size
                     w-lay-pag-yal
                                delimited by   spaces
                     "b"        delimited by   size
                     w-lay-pag-shd
                                delimited by   spaces
                     "P"        delimited by   size
                                          into w-fil-bin-wrt-rec      .
      *                  *---------------------------------------------*
      *                  * Emissione sequenza                          *
      *                  *---------------------------------------------*
           perform   fil-bin-wrt-000      thru fil-bin-wrt-999        .
       emi-lay-pag-ret-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-lay-pag-ret-999.
       emi-lay-pag-ret-999.
           exit.

