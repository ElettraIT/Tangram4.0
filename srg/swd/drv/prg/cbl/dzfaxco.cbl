           move      028                  to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-c0c-FS               .
           move      029                  to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-c0c-GS               .
           move      030                  to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-c0c-RS               .
           move      031                  to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-c0c-US               .
      *              *-------------------------------------------------*
