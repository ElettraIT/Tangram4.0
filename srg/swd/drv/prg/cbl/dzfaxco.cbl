           move      023                  to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-c0c-ETB              .
           move      024                  to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-c0c-CAN              .
