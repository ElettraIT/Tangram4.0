           move      "U"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-MW               .
           move      "V"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-SPA              .
           move      "W"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-EPA              .
           move      "X"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-E-X              .
           move      "Y"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-E-Y              .
           move      "Z"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-E-Z              .
           move      "["                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-CSI              .
           move      "\"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-ST               .
           move      "]"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-OSC              .
           move      "^"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-PM               .
           move      "_"                  to   w-asc-w02              .
           move      w-asc-w2c            to   w-c1e-APC              .
       det-asc-c1e-999.
           exit.

      *    *===========================================================*
      *    * Definizione di 96 Line Feed consecutivi, a seconda del    *
      *    * tipo di interlinea                                        *
      *    *-----------------------------------------------------------*
       def-096-lfc-000.
           if        w-par-pds-int        =    01
                     go to def-096-lfc-100
           else if   w-par-pds-int        =    02
                     go to def-096-lfc-200
           else if   w-par-pds-int        =    03
                     go to def-096-lfc-300.
       def-096-lfc-100.
           move      spaces               to   w-96l                  .
           inspect   w-96l      replacing all  spaces
                                          by   w-c0c-LF               .
           go to     def-096-lfc-999.
       def-096-lfc-200.
           move      spaces               to   w-96l                  .
           inspect   w-96l      replacing all  spaces
                                          by   w-c0c-CR               .
           go to     def-096-lfc-999.
       def-096-lfc-300.
           move      zero                 to   w-par-pds-ctr          .
           move      zero                 to   w-par-pds-pnt          .
       def-096-lfc-302.
           add       1                    to   w-par-pds-ctr          .
           if        w-par-pds-ctr        >    96
                     go to def-096-lfc-999.
           add       1                    to   w-par-pds-pnt          .
           move      w-c0c-CR             to   w-96l
                                              (w-par-pds-pnt : 1)     .
           add       1                    to   w-par-pds-pnt          .
           move      w-c0c-LF             to   w-96l
                                              (w-par-pds-pnt : 1)     .
           go to     def-096-lfc-302.
       def-096-lfc-999.
           exit.

