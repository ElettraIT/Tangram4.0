      *                  *---------------------------------------------*
           move      "DU"                 to   h-ope                  .
           move      w-exe-pwd-ute        to   h-alf                  .
           move      "nnn"                to   h-tip                  .
           call      "swd/mod/prg/obj/mhtml0"
