               w-det-dow-aes.
               10  w-det-dow-sec          pic  9(02)                  .
               10  w-det-dow-ann          pic  9(02)                  .
      *        *-------------------------------------------------------*
      *        * Tabella giorni della settimana                        *
      *        *-------------------------------------------------------*
           05  w-det-dow-tdw.
               10  filler                 pic  x(10)   value
                                                        "Lunedi'   "  .
               10  filler                 pic  x(10)   value
                                                        "Martedi'  "  .
               10  filler                 pic  x(10)   value
                                                        "Mercoledi'"  .
               10  filler                 pic  x(10)   value
                                                        "Giovedi'  "  .
               10  filler                 pic  x(10)   value
                                                        "Venerdi'  "  .
               10  filler                 pic  x(10)   value
                                                        "Sabato    "  .
               10  filler                 pic  x(10)   value
                                                        "Domenica  "  .
               10  filler                 pic  x(10)   value
                                                        ".........."  .
           05  w-det-dow-tdw-r redefines
               w-det-dow-tdw.
               10  w-det-dow-tde occurs 8 pic  x(10)                  .
