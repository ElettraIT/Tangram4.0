      *    *===========================================================*
      *    * Subroutines per determinazione quantita' da spedire riga  *
      *    * ordine di spedizione                                      *
      *    *-----------------------------------------------------------*
       det-qds-ros-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-qds-ros-tip-ope      .
           perform   det-qds-ros-cll-000  thru det-qds-ros-cll-999    .
       det-qds-ros-opn-999.
           exit.

       det-qds-ros-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-qds-ros-tip-ope      .
           perform   det-qds-ros-cll-000  thru det-qds-ros-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-qds-ros-tip-ope      .
           perform   det-qds-ros-cll-000  thru det-qds-ros-cll-999    .
           if        d-qds-ros-exi-sts    not  = spaces
                     go to det-qds-ros-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/ods/prg/obj/dqdsros0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       det-qds-ros-cls-999.
           exit.

       det-qds-ros-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/ods/prg/obj/dqdsros0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-qds-ros
                                               rf-osr                 .
       det-qds-ros-cll-999.
           exit.

