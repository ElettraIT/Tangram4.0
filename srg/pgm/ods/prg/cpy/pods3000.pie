      *    *===========================================================*
      *    * Routine pre-trattamento piede registrazione               *
      *    *-----------------------------------------------------------*
       pre-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-pie-reg      .
      *              *-------------------------------------------------*
      *              * Routines da eseguire solo il documento interes- *
      *              * sa l'archivio Clienti                           *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to pre-pie-reg-999.
      *                  *---------------------------------------------*
      *                  * Determinazione totali riga                  *
      *                  *---------------------------------------------*
           perform   det-tot-rig-000      thru det-tot-rig-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totali riepilogo documento   *
      *                  *---------------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione valori per vettore           *
      *                  *---------------------------------------------*
           perform   det-vlp-vet-000      thru det-vlp-vet-999        .
       pre-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione numero pagine che compongono il piede      *
      *    *-----------------------------------------------------------*
       dmp-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Il piede e' composto di nr. 2 pagine            *
      *              *-------------------------------------------------*
           move      2                    to   w-cnt-sts-imp-mpp      .
       dmp-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no pagina w-cnt-sts-imp-npp da trattare *
      *    *-----------------------------------------------------------*
       snp-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snx      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina piede  *
      *              *-------------------------------------------------*
           go to     snp-pie-reg-100
                     snp-pie-reg-200
                     depending            on   w-cnt-sts-imp-npp      .
           go to     snp-pie-reg-999.
       snp-pie-reg-100.
      *              *-------------------------------------------------*
      *              * Pagina 1 : da accettare comunque                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snx      .
           go to     snp-pie-reg-999.
       snp-pie-reg-200.
      *              *-------------------------------------------------*
      *              * Pagina 2 : da accettare solo se il documento    *
      *              *            interessa l'archivio Clienti         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     move  "#"            to   w-cnt-sts-imp-snx      .
           go to     snp-pie-reg-999.
       snp-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione piede registrazione                          *
      *    *-----------------------------------------------------------*
       acc-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-pie      .
      *              *-------------------------------------------------*
      *              * Normalizzazione func-key di impostazione        *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : piede                       *
      *              *-------------------------------------------------*
           move      "P"                  to   w-cnt-mfu-tip-imp      .
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     acc-pie-reg-100
                     acc-pie-reg-200
                     depending            on   w-cnt-sts-imp-npp      .
           go to     acc-pie-reg-999.
       acc-pie-reg-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Trasporto a cura                            *
      *                  *---------------------------------------------*
           perform   acc-tra-cur-000      thru acc-tra-cur-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-pie
                     go to acc-pie-reg-999.
       acc-pie-reg-105.
      *                  *---------------------------------------------*
      *                  * Causale del trasporto                       *
      *                  *---------------------------------------------*
           perform   acc-cau-tra-000      thru acc-cau-tra-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-100.
       acc-pie-reg-110.
      *                  *---------------------------------------------*
      *                  * Aspetto esteriore dei beni                  *
      *                  *---------------------------------------------*
           perform   acc-cod-aeb-000      thru acc-cod-aeb-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-105.
       acc-pie-reg-115.
      *                  *---------------------------------------------*
      *                  * Numero colli                                *
      *                  *---------------------------------------------*
           perform   acc-num-col-000      thru acc-num-col-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-110.
       acc-pie-reg-120.
      *                  *---------------------------------------------*
      *                  * Peso totale                                 *
      *                  *---------------------------------------------*
           perform   acc-pes-tot-000      thru acc-pes-tot-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-115.
       acc-pie-reg-125.
      *                  *---------------------------------------------*
      *                  * Data inizio trasporto                       *
      *                  *---------------------------------------------*
           perform   acc-dat-itr-000      thru acc-dat-itr-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-120.
       acc-pie-reg-130.
      *                  *---------------------------------------------*
      *                  * Ora inizio trasporto                        *
      *                  *---------------------------------------------*
           perform   acc-ora-itr-000      thru acc-ora-itr-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-125.
       acc-pie-reg-135.
      *                  *---------------------------------------------*
      *                  * Codice primo vettore                        *
      *                  *---------------------------------------------*
           perform   acc-cod-vet-000      thru acc-cod-vet-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-130.
       acc-pie-reg-140.
      *                  *---------------------------------------------*
      *                  * Codice secondo vettore                      *
      *                  *---------------------------------------------*
           perform   acc-cod-vt2-000      thru acc-cod-vt2-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-135.
       acc-pie-reg-145.
      *                  *---------------------------------------------*
      *                  * Codice terzo vettore                        *
      *                  *---------------------------------------------*
           perform   acc-cod-vt3-000      thru acc-cod-vt3-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-140.
       acc-pie-reg-150.
      *                  *---------------------------------------------*
      *                  * Codice annotazioni per le spedizioni        *
      *                  *---------------------------------------------*
           perform   acc-cod-aps-000      thru acc-cod-aps-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-145.
       acc-pie-reg-155.
      *                  *---------------------------------------------*
      *                  * Descrizione annotazioni per spedizione      *
      *                  *---------------------------------------------*
           perform   acc-des-aps-000      thru acc-des-aps-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-150.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina piede 1            *
      *                  *---------------------------------------------*
           perform   acc-pre-vpp-000      thru acc-pre-vpp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-155.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-pie      .
           go to     acc-pie-reg-999.
       acc-pie-reg-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Abilitazione tasto Do                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-pie      .
      *                  *---------------------------------------------*
      *                  * Totale sconto in chiusura                   *
      *                  *---------------------------------------------*
           perform   acc-tot-scc-000      thru acc-tot-scc-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-pie
                     go to acc-pie-reg-999.
       acc-pie-reg-210.
      *                  *---------------------------------------------*
      *                  * Percentuale sconto in chiusura              *
      *                  *---------------------------------------------*
           perform   acc-per-scc-000      thru acc-per-scc-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-200.
       acc-pie-reg-220.
      *                  *---------------------------------------------*
      *                  * Totale sconto pagamento                     *
      *                  *---------------------------------------------*
           perform   acc-tot-scp-000      thru acc-tot-scp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-210.
           if        v-key                =    "DOWN"
                     go to acc-pie-reg-235.
       acc-pie-reg-230.
      *                  *---------------------------------------------*
      *                  * Percentuale sconto pagamento                *
      *                  *---------------------------------------------*
           perform   acc-per-scp-000      thru acc-per-scp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-220.
       acc-pie-reg-235.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella spese*
      *                  *---------------------------------------------*
           move      1                    to   w-acc-iep-spe-ctr      .
       acc-pie-reg-240.
      *                  *---------------------------------------------*
      *                  * Si/No addebito, importo e percentuale spesa *
      *                  *---------------------------------------------*
       acc-pie-reg-242.
      *                      *-----------------------------------------*
      *                      * Accettazione Si/No addebito             *
      *                      *-----------------------------------------*
           perform   acc-spe-snx-000      thru acc-spe-snx-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-pie-reg-244.
           subtract  1                    from w-acc-iep-spe-ctr      .
           if        w-acc-iep-spe-ctr    =    zero
                     go to acc-pie-reg-230
           else      go to acc-pie-reg-242.
       acc-pie-reg-244.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DOWN"
                     go to acc-pie-reg-248.
      *                      *-----------------------------------------*
      *                      * Accettazione importo spesa              *
      *                      *-----------------------------------------*
           perform   acc-spe-imp-000      thru acc-spe-imp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-242.
       acc-pie-reg-246.
      *                      *-----------------------------------------*
      *                      * Accettazione percentuale spesa          *
      *                      *-----------------------------------------*
           perform   acc-spe-per-000      thru acc-spe-per-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-244.
       acc-pie-reg-248.
      *                      *-----------------------------------------*
      *                      * Se Down o Return                        *
      *                      *-----------------------------------------*
           add       1                    to   w-acc-iep-spe-ctr      .
           if        w-acc-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to acc-pie-reg-249
           else      go to acc-pie-reg-242.
       acc-pie-reg-249.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella spese*
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-nst    to   w-acc-iep-spe-ctr      .
       acc-pie-reg-250.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-pie      .
           go to     acc-pie-reg-999.
       acc-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione piede registrazione                       *
      *    *-----------------------------------------------------------*
       vis-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     vis-pie-reg-100
                     vis-pie-reg-200
                     depending            on   w-cnt-sts-imp-npp      .
           go to     vis-pie-reg-999.
       vis-pie-reg-100.
      *                  *---------------------------------------------*
      *                  * Trasporto a cura                            *
      *                  *---------------------------------------------*
           perform   vis-tra-cur-000      thru vis-tra-cur-999        .
      *                  *---------------------------------------------*
      *                  * Causale del trasporto                       *
      *                  *---------------------------------------------*
           perform   vis-cau-tra-000      thru vis-cau-tra-999        .
           perform   vis-des-ctr-000      thru vis-des-ctr-999        .
      *                  *---------------------------------------------*
      *                  * Aspetto esteriore dei beni                  *
      *                  *---------------------------------------------*
           perform   vis-cod-aeb-000      thru vis-cod-aeb-999        .
           perform   vis-des-aeb-000      thru vis-des-aeb-999        .
      *                  *---------------------------------------------*
      *                  * Numero colli                                *
      *                  *---------------------------------------------*
           perform   vis-num-col-000      thru vis-num-col-999        .
      *                  *---------------------------------------------*
      *                  * Peso totale                                 *
      *                  *---------------------------------------------*
           perform   vis-pes-tot-000      thru vis-pes-tot-999        .
      *                  *---------------------------------------------*
      *                  * Data inizio trasporto                       *
      *                  *---------------------------------------------*
           perform   vis-dat-itr-000      thru vis-dat-itr-999        .
      *                  *---------------------------------------------*
      *                  * Ora inizio trasporto                        *
      *                  *---------------------------------------------*
           perform   vis-ora-itr-000      thru vis-ora-itr-999        .
      *                  *---------------------------------------------*
      *                  * Codice primo vettore                        *
      *                  *---------------------------------------------*
           perform   vis-cod-vet-000      thru vis-cod-vet-999        .
           perform   vis-cod-vet-des-000  thru vis-cod-vet-des-999    .
      *                  *---------------------------------------------*
      *                  * Codice secondo vettore                      *
      *                  *---------------------------------------------*
           perform   vis-cod-vt2-000      thru vis-cod-vt2-999        .
           perform   vis-cod-vt2-des-000  thru vis-cod-vt2-des-999    .
      *                  *---------------------------------------------*
      *                  * Codice terzo vettore                        *
      *                  *---------------------------------------------*
           perform   vis-cod-vt3-000      thru vis-cod-vt3-999        .
           perform   vis-cod-vt3-des-000  thru vis-cod-vt3-des-999    .
      *                  *---------------------------------------------*
      *                  * Codice annotazioni per spedizione           *
      *                  *---------------------------------------------*
           perform   vis-cod-aps-000      thru vis-cod-aps-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione annotazioni per spedizione      *
      *                  *---------------------------------------------*
           perform   vis-des-aps-000      thru vis-des-aps-999        .
           go to     vis-pie-reg-999.
       vis-pie-reg-200.
      *                  *---------------------------------------------*
      *                  * Totale sconto in chiusura                   *
      *                  *---------------------------------------------*
           perform   vis-tot-scc-000      thru vis-tot-scc-999        .
      *                  *---------------------------------------------*
      *                  * Percentuale sconto in chiusura              *
      *                  *---------------------------------------------*
           perform   vis-per-scc-000      thru vis-per-scc-999        .
      *                  *---------------------------------------------*
      *                  * Totale sconto pagamento                     *
      *                  *---------------------------------------------*
           perform   vis-tot-scp-000      thru vis-tot-scp-999        .
      *                  *---------------------------------------------*
      *                  * Percentuale sconto pagamento                *
      *                  *---------------------------------------------*
           perform   vis-per-scp-000      thru vis-per-scp-999        .
      *                  *---------------------------------------------*
      *                  * Si/No addebito spese                        *
      *                  *---------------------------------------------*
           perform   vis-spe-snx-000      thru vis-spe-snx-999        .
      *                  *---------------------------------------------*
      *                  * Importi spese                               *
      *                  *---------------------------------------------*
           perform   vis-spe-imp-000      thru vis-spe-imp-999        .
      *                  *---------------------------------------------*
      *                  * Percentuali spese                           *
      *                  *---------------------------------------------*
           perform   vis-spe-per-000      thru vis-spe-per-999        .
      *                  *---------------------------------------------*
      *                  * Riepilogo totali                            *
      *                  *---------------------------------------------*
           perform   vis-rie-tot-000      thru vis-rie-tot-999        .
           go to     vis-pie-reg-999.
       vis-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts piede                             *
      *    *-----------------------------------------------------------*
       pmt-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     pmt-pie-reg-100
                     pmt-pie-reg-200
                     depending            on   w-cnt-sts-imp-npp      .
           go to     pmt-pie-reg-999.
       pmt-pie-reg-100.
      *                  *---------------------------------------------*
      *                  * Trasporto a cura                            *
      *                  *---------------------------------------------*
           perform   pmt-tra-cur-000      thru pmt-tra-cur-999        .
      *                  *---------------------------------------------*
      *                  * Causale del trasporto                       *
      *                  *---------------------------------------------*
           perform   pmt-cau-tra-000      thru pmt-cau-tra-999        .
      *                  *---------------------------------------------*
      *                  * Aspetto esteriore dei beni                  *
      *                  *---------------------------------------------*
           perform   pmt-cod-aeb-000      thru pmt-cod-aeb-999        .
      *                  *---------------------------------------------*
      *                  * Numero colli                                *
      *                  *---------------------------------------------*
           perform   pmt-num-col-000      thru pmt-num-col-999        .
      *                  *---------------------------------------------*
      *                  * Peso totale                                 *
      *                  *---------------------------------------------*
           perform   pmt-pes-tot-000      thru pmt-pes-tot-999        .
      *                  *---------------------------------------------*
      *                  * Data inizio trasporto                       *
      *                  *---------------------------------------------*
           perform   pmt-dat-itr-000      thru pmt-dat-itr-999        .
      *                  *---------------------------------------------*
      *                  * Ora inizio trasporto                        *
      *                  *---------------------------------------------*
           perform   pmt-ora-itr-000      thru pmt-ora-itr-999        .
      *                  *---------------------------------------------*
      *                  * Codice primo vettore                        *
      *                  *---------------------------------------------*
           perform   pmt-cod-vet-000      thru pmt-cod-vet-999        .
      *                  *---------------------------------------------*
      *                  * Codice secondo vettore                      *
      *                  *---------------------------------------------*
           perform   pmt-cod-vt2-000      thru pmt-cod-vt2-999        .
      *                  *---------------------------------------------*
      *                  * Codice terzo vettore                        *
      *                  *---------------------------------------------*
           perform   pmt-cod-vt3-000      thru pmt-cod-vt3-999        .
      *                  *---------------------------------------------*
      *                  * Codice annotazioni per spedizione           *
      *                  *---------------------------------------------*
           perform   pmt-cod-aps-000      thru pmt-cod-aps-999        .
           go to     pmt-pie-reg-999.
       pmt-pie-reg-200.
      *                  *---------------------------------------------*
      *                  * Intestazione pagina totali                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "          Voce                   Importo     %    
      -              "|            Totali"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura fincatura                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "------------------------- ---------------- -----  
      -              "| ----------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Trattini verticali                      *
      *                      *-----------------------------------------*
           move      5                    to   I                      .
       pmt-pie-reg-210.
           add       1                    to   I                      .
           if        I                    >    21
                     go to pmt-pie-reg-220.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      I                    to   v-lin                  .
           move      51                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-pie-reg-210.
       pmt-pie-reg-220.
      *                  *---------------------------------------------*
      *                  * Sconto in chiusura                          *
      *                  *---------------------------------------------*
           perform   pmt-tot-scc-000      thru pmt-tot-scc-999        .
      *                  *---------------------------------------------*
      *                  * Sconto pagamento                            *
      *                  *---------------------------------------------*
           perform   pmt-tot-scp-000      thru pmt-tot-scp-999        .
      *                  *---------------------------------------------*
      *                  * Importi spese                               *
      *                  *---------------------------------------------*
           perform   pmt-spe-imp-000      thru pmt-spe-imp-999        .
      *                  *---------------------------------------------*
      *                  * Riepilogo totali                            *
      *                  *---------------------------------------------*
           perform   pmt-rie-tot-000      thru pmt-rie-tot-999        .
       pmt-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per Trasporto a cura              *
      *    *-----------------------------------------------------------*
       pmt-tra-cur-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Trasporto a cura del       :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tra-cur-999.
           exit.

