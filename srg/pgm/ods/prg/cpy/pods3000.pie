      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-vet-ope      .
           move      w-pie-cod-vt2 (1)    to   w-cod-mne-vet-cod      .
           move      18                   to   w-cod-mne-vet-lin      .
           move      30                   to   w-cod-mne-vet-pos      .
           move      18                   to   w-cod-mne-vet-rln      .
           move      41                   to   w-cod-mne-vet-rps      .
           move      zero                 to   w-cod-mne-vet-vln      .
           move      zero                 to   w-cod-mne-vet-vps      .
           move      zero                 to   w-cod-mne-vet-lln      .
           move      zero                 to   w-cod-mne-vet-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
       acc-cod-vt2-110.
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           if        w-cod-mne-vet-ope    =    "F+"
                     go to acc-cod-vt2-115.
           if        w-cod-mne-vet-ope    =    "AC"
                     go to acc-cod-vt2-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-vt2-115.
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
           go to     acc-cod-vt2-110.
       acc-cod-vt2-120.
           move      w-cod-mne-vet-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vt2-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vt2-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-vt2 (1)      .
       acc-cod-vt2-400.
      *              *-------------------------------------------------*
