       acc-cod-vt3-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    not  = 30
                     go to acc-cod-vt3-999.
           if        w-pie-cod-vt2 (1)    =    zero
                     go to acc-cod-vt3-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-cod-vt3 (1)    to   w-sav-cod-vet          .
       acc-cod-vt3-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-vet-ope      .
           move      w-pie-cod-vt3 (1)    to   w-cod-mne-vet-cod      .
           move      19                   to   w-cod-mne-vet-lin      .
           move      30                   to   w-cod-mne-vet-pos      .
           move      19                   to   w-cod-mne-vet-rln      .
           move      41                   to   w-cod-mne-vet-rps      .
           move      zero                 to   w-cod-mne-vet-vln      .
           move      zero                 to   w-cod-mne-vet-vps      .
           move      zero                 to   w-cod-mne-vet-lln      .
           move      zero                 to   w-cod-mne-vet-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
       acc-cod-vt3-110.
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           if        w-cod-mne-vet-ope    =    "F+"
                     go to acc-cod-vt3-115.
           if        w-cod-mne-vet-ope    =    "AC"
                     go to acc-cod-vt3-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-vt3-115.
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
           go to     acc-cod-vt3-110.
       acc-cod-vt3-120.
           move      w-cod-mne-vet-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vt3-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vt3-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-vt3 (1)      .
       acc-cod-vt3-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [vet]                      *
      *                  *---------------------------------------------*
           move      w-pie-cod-vt3 (1)    to   w-let-arc-vet-cod      .
           perform   let-arc-vet-000      thru let-arc-vet-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-vet-rag    to   w-pie-cod-vt3-des (1)  .
           perform   vis-cod-vt3-des-000  thru vis-cod-vt3-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-vet-flg    =    spaces
                     go to acc-cod-vt3-420.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice vettore non esistente !                    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vt3-100.
       acc-cod-vt3-420.
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' tipo di vettore    *
      *                  *---------------------------------------------*
           if        w-let-arc-vet-tip    =    "C"
                     go to acc-cod-vt3-600.
           if        w-pie-cod-vt3 (1)    =    zero
                     go to acc-cod-vt3-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Il vettore selezionato e' un trasportatore interno
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vt3-100.
       acc-cod-vt3-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-vt3-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-vt3-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-vt3-100.
       acc-cod-vt3-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Codice terzo vettore        *
      *    *-----------------------------------------------------------*
       vis-cod-vt3-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-cod-vt3 (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vt3-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione terzo vettore   *
      *    *-----------------------------------------------------------*
       vis-cod-vt3-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-pie-cod-vt3-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vt3-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Codice annotazioni             *
      *    *-----------------------------------------------------------*
       acc-cod-aps-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-cod-aps (1)    to   w-sav-cod-aps          .
       acc-cod-aps-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zsa-ope      .
           move      w-pie-cod-aps (1)    to   w-cod-mne-zsa-cod      .
           move      21                   to   w-cod-mne-zsa-lin      .
           move      30                   to   w-cod-mne-zsa-pos      .
           move      21                   to   w-cod-mne-zsa-dln      .
           move      37                   to   w-cod-mne-zsa-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zsa-cll-000  thru cod-mne-zsa-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zsa-foi-000  thru cod-mne-zsa-foi-999    .
       acc-cod-aps-110.
           perform   cod-mne-zsa-cll-000  thru cod-mne-zsa-cll-999    .
           if        w-cod-mne-zsa-ope    =    "F+"
                     go to acc-cod-aps-115.
           if        w-cod-mne-zsa-ope    =    "AC"
                     go to acc-cod-aps-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aps-115.
           perform   cod-mne-zsa-foi-000  thru cod-mne-zsa-foi-999    .
           go to     acc-cod-aps-110.
       acc-cod-aps-120.
           move      w-cod-mne-zsa-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-aps-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-aps-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-aps (1)      .
       acc-cod-aps-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zba]                       *
      *                  *---------------------------------------------*
           move      w-pie-cod-aps (1)    to   w-let-arc-zsa-cod      .
           perform   let-arc-zsa-000      thru let-arc-zsa-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zsa-flg    =    spaces
                     go to acc-cod-aps-500.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice annotazione non esistente !                
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-aps-100.
       acc-cod-aps-500.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-pie-cod-aps (1)    not  = zero
                     go to acc-cod-aps-550.
      *                      *-----------------------------------------*
      *                      * Se valore precedente a zero : oltre     *
      *                      *-----------------------------------------*
           if        w-sav-cod-aps        =    zero
                     go to acc-cod-aps-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti : normalizzazione e rivisua- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           move      spaces               to   w-pie-des-aps (1)      .
           perform   vis-des-aps-000      thru vis-des-aps-999        .
           go to     acc-cod-aps-600.
       acc-cod-aps-550.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valore letto            *
      *                      *-----------------------------------------*
           move      w-let-arc-zsa-des    to   w-pie-des-aps (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione annotazioni *
      *                      *-----------------------------------------*
           perform   vis-des-aps-000      thru vis-des-aps-999        .
       acc-cod-aps-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-aps-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-aps-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-aps-100.
       acc-cod-aps-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Codice annotazioni          *
      *    *-----------------------------------------------------------*
       vis-cod-aps-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-cod-aps (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aps-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Descrizione annotazioni        *
      *    *-----------------------------------------------------------*
       acc-des-aps-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-des-aps (1)    to   w-sav-des-aps          .
       acc-des-aps-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      21                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-des-aps (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-des-aps-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-des-aps-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-pie-des-aps (1)      .
       acc-des-aps-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-des-aps-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-pie-des-aps (1)    =    w-sav-des-aps
                     go to acc-des-aps-800.
      *                  *---------------------------------------------*
      *                  * Trattamento codice annotazioni              *
      *                  *---------------------------------------------*
           if        w-pie-cod-aps (1)    =    zero
                     go to acc-des-aps-800.
           move      zero                 to   w-pie-cod-aps (1)      .
           perform   vis-cod-aps-000      thru vis-cod-aps-999        .
       acc-des-aps-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-des-aps-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-des-aps-100.
       acc-des-aps-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione annotazioni     *
      *    *-----------------------------------------------------------*
       vis-des-aps-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      21                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-pie-des-aps (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-aps-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Totale sconto incondizionato   *
      *    *-----------------------------------------------------------*
       acc-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-tot-scc (1)    to   w-sav-tot-scc          .
       acc-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-tot-scc (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-tot-scc (1)      .
       acc-tot-scc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-scc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-tot-scc (1)    =    w-sav-tot-scc
                     go to acc-tot-scc-800.
      *                      *-----------------------------------------*
      *                      * Trattamento % sconto in chiusura        *
      *                      *-----------------------------------------*
           if        w-pie-per-scc (1)    not  = zero
                     move  zero           to   w-pie-per-scc (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-scc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-tot-scc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-scc-100.
       acc-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Totale sconto incondizionato*
      *    *-----------------------------------------------------------*
       vis-tot-scc-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-pie-tot-scc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : % sconto incondizionato        *
      *    *-----------------------------------------------------------*
       acc-per-scc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-per-scc (1)    to   w-sav-per-scc          .
       acc-per-scc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-per-scc (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-per-scc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-per-scc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-per-scc (1)      .
       acc-per-scc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-per-scc (1)    =    w-sav-per-scc
                     go to acc-per-scc-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-per-scc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-per-scc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-per-scc-100.
       acc-per-scc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : % sconto incondizionato     *
      *    *-----------------------------------------------------------*
       vis-per-scc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      w-pie-per-scc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-per-scc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Totale sconto pagamento        *
      *    *-----------------------------------------------------------*
       acc-tot-scp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-tot-scp (1)    to   w-sav-tot-scp          .
       acc-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-tot-scp (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-tot-scp (1)      .
       acc-tot-scp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-scp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-tot-scp (1)    =    w-sav-tot-scp
                     go to acc-tot-scp-800.
      *                      *-----------------------------------------*
      *                      * Trattamento % sconto pagamento          *
      *                      *-----------------------------------------*
           if        w-pie-per-scp (1)    not  = zero
                     move  zero           to   w-pie-per-scp (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-scp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-tot-scp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-scp-100.
       acc-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Totale sconto pagamento     *
      *    *-----------------------------------------------------------*
       vis-tot-scp-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-pie-tot-scp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-scp-999.
           exit.

