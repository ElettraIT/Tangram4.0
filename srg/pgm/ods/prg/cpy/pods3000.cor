      *                          * Ad accettazione nr riga selezionato *
      *                          *-------------------------------------*
           move      w-cnt-slc-num-rig    to   w-cnt-cor-nrg-dac      .
           go to     acc-cor-reg-000.
       acc-cor-reg-990.
      *                  *---------------------------------------------*
      *                  * Se Pf4 da primo campo di impostazione riga  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio video attuale               *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Test se tipo movimento spedizione lo    *
      *                      * prevede                                 *
      *                      *-----------------------------------------*
           if        w-tes-tip-mps-maf    not  = 02
                     go to acc-cor-reg-994.
       acc-cor-reg-992.
      *                      *-----------------------------------------*
      *                      * Accettazione dati identificativi ordine *
      *                      * cliente                                 *
      *                      *-----------------------------------------*
           move      "OC"                 to   l-eva-orc-tip-ope      .
           move      w-tes-tip-mps-dmf    to   l-eva-orc-tmo-orc      .
           move      "pgm/ods/prg/obj/pods300a"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-orc
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        l-eva-orc-exi-sts    not  = spaces
                     go to acc-cor-reg-994.
      *                      *-----------------------------------------*
      *                      * Confronto testata ordine cliente ri-    *
      *                      * chiamato con testata documento in corso *
      *                      * di trattamento                          *
      *                      *-----------------------------------------*
           move      "T+"                 to   l-eva-orc-tip-ope      .
           move      "pgm/ods/prg/obj/pods300a"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-orc
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Se esito operazione negativo : riciclo  *
      *                      * su accettazione dati identificativi or- *
      *                      * dine cliente                            *
      *                      *-----------------------------------------*
           if        l-eva-orc-exi-sts    not  = spaces
                     go to acc-cor-reg-992.
      *                      *-----------------------------------------*
      *                      * Set del flag di trattamento ordine      *
      *                      * cliente                                 *
      *                      *-----------------------------------------*
           move      "#"                  to   l-eva-orc-flg-orc      .
      *                      *-----------------------------------------*
      *                      * Assestamento flag di visualizzazione    *
      *                      * prompts                                 *
      *                      *-----------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-cor      .
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente  visualizzata *
      *                      * a zero per forzare la rivisualizzazione *
      *                      *-----------------------------------------*
           move      zero                 to   w-cnt-cor-nrp-vis      .
       acc-cor-reg-994.
      *                      *-----------------------------------------*
      *                      * Ripristino video precedentemente salva- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Rimozione record dalla catena           *
      *                      *-----------------------------------------*
           move      "RM"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           go to     acc-cor-reg-000.
       acc-cor-reg-997.
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione corpo       *
      *              *-------------------------------------------------*
           if        w-cat-rig-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-cor
           else      move  "#"            to   w-cnt-sts-imp-cor      .
      *              *-------------------------------------------------*
      *              * Abblencamento note in righe documento           *
      *              *-------------------------------------------------*
           move      "NO"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione pagina corpo numero : w-cnt-cor-nrp-dav   *
      *    *-----------------------------------------------------------*
       vis-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate, escluse fincature        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      06                   to   v-lin                  .
           move      12                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-cor-reg-150.
      *              *-------------------------------------------------*
      *              * Determinazione numero d'ordine del primo numero *
      *              * riga da visualizzare                            *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrp-dav    to   w-cnt-wrk-ctr-008      .
           multiply  w-lin-num-lin-vis    by   w-cnt-wrk-ctr-008      .
           add       1                    to   w-cnt-wrk-ctr-008      .
           subtract  w-lin-num-lin-vis    from w-cnt-wrk-ctr-008      .
      *              *-------------------------------------------------*
      *              * Determinazione numero d'ordine dell'ultimo nu-  *
      *              * mero riga da visualizzare                       *
      *              *-------------------------------------------------*
           move      w-cnt-wrk-ctr-008    to   w-cnt-wrk-ctr-009      .
           add       w-lin-num-lin-vis    to   w-cnt-wrk-ctr-009      .
           subtract  1                    from w-cnt-wrk-ctr-009      .
      *              *-------------------------------------------------*
      *              * Visualizzazione numero pagina in corso di trat- *
      *              * tamento                                         *
      *              *-------------------------------------------------*
           perform   vis-cor-reg-npg-000  thru vis-cor-reg-npg-999    .
      *              *-------------------------------------------------*
      *              * Operazione di Start su catena movimenti         *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      w-cnt-wrk-ctr-008    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se start errata : fine visualizzazione      *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to  vis-cor-reg-999.
       vis-cor-reg-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : fine visualizzazione      *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to  vis-cor-reg-999.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Riga singolo movimento                          *
      *              *-------------------------------------------------*
           move      "R"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-wrk-ctr-008    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *              *-------------------------------------------------*
      *              * Incremento numero riga da visualizzare          *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-wrk-ctr-008      .
      *              *-------------------------------------------------*
      *              * Test se oltre ultima riga da visualizzare       *
      *              *-------------------------------------------------*
           if        w-cnt-wrk-ctr-008    not  > w-cnt-wrk-ctr-009
                     go to vis-cor-reg-200.
       vis-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione pagina corpo                              *
      *    *                                                           *
      *    * Numero pagina corpo                                       *
      *    *-----------------------------------------------------------*
       vis-cor-reg-npg-000.
      *              *-------------------------------------------------*
      *              * Numero di pagina                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione pagina attuale               *
      *                  *---------------------------------------------*
           divide    w-lin-num-lin-vis    into w-cat-rig-max
                                        giving w-cnt-cor-pag-max
                                     remainder w-cnt-cor-pag-rem      .
           if        w-cnt-cor-pag-rem    >    zero
                     add 1                to   w-cnt-cor-pag-max      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-009
                                        giving w-cnt-cor-pag-att      .
      *                  *---------------------------------------------*
      *                  * Editing pagina attuale                      *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cnt-cor-pag-att    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   w-cnt-cor-pag-ep1      .
      *                  *---------------------------------------------*
      *                  * Editing pagina finale                       *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cnt-cor-pag-max    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   w-cnt-cor-pag-ep2      .
      *                  *---------------------------------------------*
      *                  * Composizione                                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-cor-pag-npa      .
           string    "["
                                delimited by   size
                     w-cnt-cor-pag-ep1
                                delimited by   spaces
                     "/"
                                delimited by   size
                     w-cnt-cor-pag-ep2
                                delimited by   spaces
                     "]"
                                delimited by   size
                                          into w-cnt-cor-pag-npa      .
      *                  *---------------------------------------------*
      *                  * Allineamento al centro                      *
      *                  *---------------------------------------------*
           move      09                   to   w-all-str-lun          .
           move      w-cnt-cor-pag-npa    to   w-all-str-alf          .
           perform   all-str-cen-000      thru all-str-cen-999        .
           move      w-all-str-alf        to   w-cnt-cor-pag-npa      .
      *                  *---------------------------------------------*
      *                  * Riempimento con '-'                         *
      *                  *---------------------------------------------*
           inspect   w-cnt-cor-pag-npa
                                     replacing all " " by   "-"       .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-cnt-cor-pag-npa    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-cor-reg-npg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-cor-reg-npg-999.
       vis-cor-reg-npg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione linea corpo numero : w-cnt-cor-nrg-dav    *
      *    *-----------------------------------------------------------*
       vis-lin-cor-000.
      *              *-------------------------------------------------*
      *              * Abblencamento immagine linea di corpo           *
      *              *-------------------------------------------------*
           move      spaces               to   w-lin-imm              .
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dav    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Test su tipo visualizzazione riga               *
      *              *-------------------------------------------------*
           if        w-cnt-cor-tvi-rig    =    "I"
                     go to vis-lin-cor-100
           else if   w-cnt-cor-tvi-rig    =    "S"
                     go to vis-lin-cor-200
           else if   w-cnt-cor-tvi-rig    =    "N"
                     go to vis-lin-cor-300
           else      go to vis-lin-cor-400.
       vis-lin-cor-100.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione indicatore linea         *
      *                  *---------------------------------------------*
           move      "==>"                to   w-lin-imm-num-lin      .
           move      03                   to   v-car                  .
           go to     vis-lin-cor-900.
       vis-lin-cor-200.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione numero linea a spaces    *
      *                  *---------------------------------------------*
           move      spaces               to   w-lin-imm-num-lin      .
           move      03                   to   v-car                  .
           go to     vis-lin-cor-900.
       vis-lin-cor-300.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione numero d'ordine riga     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-num-lin      .
           go to     vis-lin-cor-900.
       vis-lin-cor-400.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione riga intera              *
      *                  *---------------------------------------------*
       vis-lin-cor-405.
      *                      *-----------------------------------------*
      *                      * Se riga in append : uscita              *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     go to  vis-lin-cor-999.
       vis-lin-cor-410.
      *                      *-----------------------------------------*
      *                      * Editing Numero d'ordine riga            *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-num-lin      .
       vis-lin-cor-415.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo New : fine editing      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-lin-cor-800.
       vis-lin-cor-450.
      *                      *-----------------------------------------*
      *                      * Editing segnale tipo riga reale         *
      *                      *-----------------------------------------*
           if        w-rig-bld-rgb (1)    =    1
                     move  "*"            to   w-lin-imm-seg-trr      .
       vis-lin-cor-500.
      *                      *-----------------------------------------*
      *                      * Editing descrizione                     *
      *                      *-----------------------------------------*
       vis-lin-cor-502.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo riga  *
      *                          *-------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    spaces
                     go to vis-lin-cor-504
           else      go to vis-lin-cor-520.
       vis-lin-cor-504.
      *                          *-------------------------------------*
      *                          * Se il tipo riga indica che si sta   *
      *                          * trattando un codice di magazzino    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione a seconda della per- *
      *                              * sonalizzazione di tipo esposi-  *
      *                              * zione descrizione               *
      *                              *---------------------------------*
           if        w-prs-rig-scr-des    =    00
                     go to vis-lin-cor-506
           else if   w-prs-rig-scr-des    =    01
                     go to vis-lin-cor-508
           else if   w-prs-rig-scr-des    =    02
                     go to vis-lin-cor-510
           else if   w-prs-rig-scr-des    =    03
                     go to vis-lin-cor-512
           else if   w-prs-rig-scr-des    =    04
                     go to vis-lin-cor-514
           else if   w-prs-rig-scr-des    =    05
                     go to vis-lin-cor-516
           else if   w-prs-rig-scr-des    =    06
                     go to vis-lin-cor-518
           else      go to vis-lin-cor-506.
       vis-lin-cor-506.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 00  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * A visualizzazione della so- *
      *                                  * la intera descrizione       *
      *                                  *-----------------------------*
           go to     vis-lin-cor-522.
       vis-lin-cor-508.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 01  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing primi 25 caratteri  *
      *                                  * della descrizione           *
      *                                  *-----------------------------*
           move      w-rig-der-rig (1, 1) to   w-lin-imm-d25-p01      .
      *                                  *-----------------------------*
      *                                  * Editing codice magazzino    *
      *                                  *-----------------------------*
           move      w-rig-alf-pro (1)    to   w-lin-imm-cod-p01      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-524.
       vis-lin-cor-510.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 02  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing primi 21 caratteri  *
      *                                  * della descrizione           *
      *                                  *-----------------------------*
           move      w-rig-der-rig (1, 1) to   w-lin-imm-d21-p02      .
      *                                  *-----------------------------*
      *                                  * Editing parentesi sinistra  *
      *                                  *-----------------------------*
           move      "["                  to   w-lin-imm-pqs-p02      .
      *                                  *-----------------------------*
      *                                  * Editing tipo codice di ma-  *
      *                                  * gazzino                     *
      *                                  *-----------------------------*
           if        w-rig-tip-mag (1)    =    01
                     move  "P"            to   w-lin-imm-tco-p02
           else if   w-rig-tip-mag (1)    =    02
                     move  "S"            to   w-lin-imm-tco-p02
           else if   w-rig-tip-mag (1)    =    03
                     move  "M"            to   w-lin-imm-tco-p02
           else      move  "?"            to   w-lin-imm-tco-p02      .
      *                                  *-----------------------------*
      *                                  * Editing parentesi destra    *
      *                                  *-----------------------------*
           move      "]"                  to   w-lin-imm-pqd-p02      .
      *                                  *-----------------------------*
      *                                  * Editing codice magazzino    *
      *                                  *-----------------------------*
           move      w-rig-alf-pro (1)    to   w-lin-imm-cod-p02      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-524.
       vis-lin-cor-512.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 03  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing codice magazzino    *
      *                                  *-----------------------------*
           move      w-rig-alf-pro (1)    to   w-lin-imm-cod-p03      .
      *                                  *-----------------------------*
      *                                  * Editing primi 25 caratteri  *
      *                                  * della descrizione           *
      *                                  *-----------------------------*
           move      w-rig-der-rig (1, 1) to   w-lin-imm-d25-p03      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-524.
       vis-lin-cor-514.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 04  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing parentesi sinistra  *
      *                                  *-----------------------------*
           move      "["                  to   w-lin-imm-pqs-p04      .
      *                                  *-----------------------------*
      *                                  * Editing tipo codice di ma-  *
      *                                  * gazzino                     *
      *                                  *-----------------------------*
           if        w-rig-tip-mag (1)    =    01
                     move  "P"            to   w-lin-imm-tco-p04
           else if   w-rig-tip-mag (1)    =    02
                     move  "S"            to   w-lin-imm-tco-p04
           else if   w-rig-tip-mag (1)    =    03
                     move  "M"            to   w-lin-imm-tco-p04
           else      move  "?"            to   w-lin-imm-tco-p04      .
      *                                  *-----------------------------*
      *                                  * Editing parentesi destra    *
      *                                  *-----------------------------*
           move      "]"                  to   w-lin-imm-pqd-p04      .
      *                                  *-----------------------------*
      *                                  * Editing codice magazzino    *
      *                                  *-----------------------------*
           move      w-rig-alf-pro (1)    to   w-lin-imm-cod-p04      .
      *                                  *-----------------------------*
      *                                  * Editing primi 21 caratteri  *
      *                                  * della descrizione           *
      *                                  *-----------------------------*
           move      w-rig-der-rig (1, 1) to   w-lin-imm-d21-p04      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-524.
       vis-lin-cor-516.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 05  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing codice magazzino    *
      *                                  *-----------------------------*
           move      w-rig-alf-pro (1)    to   w-lin-imm-cod-p01      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-524.
       vis-lin-cor-518.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 06  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing parentesi sinistra  *
      *                                  *-----------------------------*
           move      "["                  to   w-lin-imm-pqs-p02      .
      *                                  *-----------------------------*
      *                                  * Editing tipo codice di ma-  *
      *                                  * gazzino                     *
      *                                  *-----------------------------*
           if        w-rig-tip-mag (1)    =    01
                     move  "P"            to   w-lin-imm-tco-p02
           else if   w-rig-tip-mag (1)    =    02
                     move  "S"            to   w-lin-imm-tco-p02
           else if   w-rig-tip-mag (1)    =    03
                     move  "M"            to   w-lin-imm-tco-p02
           else      move  "?"            to   w-lin-imm-tco-p02      .
      *                                  *-----------------------------*
      *                                  * Editing parentesi destra    *
      *                                  *-----------------------------*
           move      "]"                  to   w-lin-imm-pqd-p02      .
      *                                  *-----------------------------*
      *                                  * Editing codice magazzino    *
      *                                  *-----------------------------*
           move      w-rig-alf-pro (1)    to   w-lin-imm-cod-p02      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-524.
       vis-lin-cor-520.
      *                          *-------------------------------------*
      *                          * Se il tipo riga indica che non si   *
      *                          * sta trattando un codice di magaz-   *
      *                          * zino                                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * A visualizzazione della sola    *
      *                              * intera descrizione              *
      *                              *---------------------------------*
           go to     vis-lin-cor-522.
       vis-lin-cor-522.
      *                              *---------------------------------*
      *                              * Visualizzazione della sola in-  *
      *                              * tera descrizione                *
      *                              *---------------------------------*
           move      w-rig-der-rig (1, 1) to   w-lin-imm-des-rig      .
       vis-lin-cor-524.
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     vis-lin-cor-550.
       vis-lin-cor-550.
      *                      *-----------------------------------------*
      *                      * Se tipo riga 'C' : fine editing         *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Se tipo riga 'A' : ad editing importo   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-lin-cor-650.
      *                      *-----------------------------------------*
      *                      * Editing quantita' e prezzo              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing quantita' da incolonnare    *
      *                          *-------------------------------------*
           move      "ED"                 to   w-edt-qta-inc-ope      .
           move      w-rig-qta-ven (1)    to   w-edt-qta-inc-qta      .
           move      w-rig-dec-qta (1)    to   w-edt-qta-inc-dec      .
           move      "S"                  to   w-edt-qta-inc-sgn      .
           move      11                   to   w-edt-qta-inc-car      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
           move      w-edt-qta-inc-edt    to   w-lin-imm-qta-ven      .
      *                          *-------------------------------------*
      *                          * Editing segnale di valuta per il    *
      *                          * prezzo diversa da quella di fat-    *
      *                          * turazione                           *
      *                          *-------------------------------------*
           if        w-rig-sgl-vpp (1)    not  = w-tes-sgl-vpf (1)
                     move  "V"            to   w-lin-imm-sgn-vdf
           else      move  spaces         to   w-lin-imm-sgn-vdf      .
      *                          *-------------------------------------*
      *                          * Editing prezzo                      *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-rig-prz-ven (1)    >    9999999
                     move  09             to   v-car
           else      move  07             to   v-car                  .
           move      w-rig-dec-vpp (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           if        w-rig-prz-ven (1)    >    9999999
                     move  "B"            to   v-edm
           else      move  "GB"           to   v-edm                  .
           move      w-rig-prz-ven (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-prz-ven      .
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     vis-lin-cor-650.
       vis-lin-cor-650.
      *                      *-----------------------------------------*
      *                      * Editing importo                         *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-rig-imp-rig (1)    >    9999999999 or
                     w-rig-imp-rig (1)    <   -9999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           if        w-rig-imp-rig (1)    >    9999999999 or
                     w-rig-imp-rig (1)    <   -9999999999
                     move  "B"            to   v-edm
           else      move  "GB"           to   v-edm                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-imp-rig      .
       vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Parametri per visualizzazione           *
      *                      *-----------------------------------------*
           move      80                   to   v-car                  .
       vis-lin-cor-900.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione prima linea          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se una sola linea : uscita                      *
      *              *-------------------------------------------------*
           if        w-lin-num-lin-prc    =    1
                     go to vis-lin-cor-999.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione altre linee          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-wrk-ctr-003      .
       vis-lin-cor-925.
           add       1                    to   w-cnt-wrk-ctr-003      .
           if        w-cnt-wrk-ctr-003    >    w-lin-num-lin-prc
                     go to vis-lin-cor-999.
           add       1                    to   w-cnt-wrk-ctr-002      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin
                    (w-cnt-wrk-ctr-003)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-lin-cor-925.
       vis-lin-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate sia dall'area per la fin- *
      *              * catura che dall'area delle righe effettive      *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      12                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-200.
      *              *-------------------------------------------------*
      *              * Numero riga                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-300.
      *              *-------------------------------------------------*
      *              * Descrizione                                     *
      *              *-------------------------------------------------*
       pmt-cor-reg-310.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda della personalizzazio- *
      *                  * di tipo esposizione della descrizione       *
      *                  *---------------------------------------------*
           if        w-prs-rig-scr-des    =    00
                     go to pmt-cor-reg-320
           else if   w-prs-rig-scr-des    =    01 or
                     w-prs-rig-scr-des    =    05
                     go to pmt-cor-reg-330
           else if   w-prs-rig-scr-des    =    02 or
                     w-prs-rig-scr-des    =    06
                     go to pmt-cor-reg-340
           else if   w-prs-rig-scr-des    =    03
                     go to pmt-cor-reg-350
           else if   w-prs-rig-scr-des    =    04
                     go to pmt-cor-reg-360
           else      go to pmt-cor-reg-320.
       pmt-cor-reg-320.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 00              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "              Descrizione               "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "----------------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-400.
       pmt-cor-reg-330.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 01 oppure 05    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "       Descrizione            Codice    "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "------------------------- --------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-400.
       pmt-cor-reg-340.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 02 oppure 06    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "     Descrizione            Codice      "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "--------------------- ------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-400.
       pmt-cor-reg-350.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 03              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "    Codice            Descrizione       "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "-------------- -------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-400.
       pmt-cor-reg-360.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 04              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "      Codice            Descrizione     "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "------------------ ---------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-400.
       pmt-cor-reg-400.
      *              *-------------------------------------------------*
      *              * Quantita' e prezzo                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      21                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      " Quantita'   Prezzo  "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      21                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      "---------- ----------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-500.
      *              *-------------------------------------------------*
      *              * Importo                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "   Importo   "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "-------------"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-600.
      *              *-------------------------------------------------*
      *              * Trattini di chiusura                            *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
      *              *-------------------------------------------------*
      *              * Tipo riga                                       *
      *              *-------------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
      *              *-------------------------------------------------*
      *              * Codice addebito o commento                      *
      *              *-------------------------------------------------*
           perform   vis-cod-aoc-000      thru vis-cod-aoc-999        .
      *              *-------------------------------------------------*
      *              * Codice prodotto                                 *
      *              *-------------------------------------------------*
           perform   vis-cod-pro-000      thru vis-cod-pro-999        .
      *              *-------------------------------------------------*
      *              * Codice prodotto secondo il cliente              *
      *              *-------------------------------------------------*
           perform   vis-cop-scl-000      thru vis-cop-scl-999        .
      *              *-------------------------------------------------*
      *              * Descrizione riga                                *
      *              *-------------------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *              *-------------------------------------------------*
      *              * Quantita' di vendita                            *
      *              *-------------------------------------------------*
           perform   vis-qta-ven-000      thru vis-qta-ven-999        .
      *              *-------------------------------------------------*
      *              * Seconda quantita'                               *
      *              *-------------------------------------------------*
           perform   vis-qta-a02-000      thru vis-qta-a02-999        .
      *              *-------------------------------------------------*
      *              * Flag di forzatura a saldo riga ordine cliente   *
      *              *-------------------------------------------------*
           perform   vis-coc-fzs-000      thru vis-coc-fzs-999        .
      *              *-------------------------------------------------*
      *              * Unita' di misura                                *
      *              *-------------------------------------------------*
           perform   vis-umi-ven-000      thru vis-umi-ven-999        .
      *              *-------------------------------------------------*
      *              * Sigla valuta per il prezzo                      *
      *              *-------------------------------------------------*
           perform   vis-sgl-vpp-000      thru vis-sgl-vpp-999        .
      *              *-------------------------------------------------*
      *              * Prezzo di vendita                               *
      *              *-------------------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
      *              *-------------------------------------------------*
      *              * Sigla valuta per legame valutario               *
      *              *-------------------------------------------------*
           perform   vis-sgl-vpl-000      thru vis-sgl-vpl-999        .
      *              *-------------------------------------------------*
      *              * Coefficiente di cambio di riferimento per lega- *
      *              * me valutario                                    *
      *              *-------------------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
      *              *-------------------------------------------------*
      *              * Percentuale di limitazione per per legame valu- *
      *              * tario                                           *
      *              *-------------------------------------------------*
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
      *              *-------------------------------------------------*
      *              * Tipo di limitazione per per legame valutario    *
      *              *-------------------------------------------------*
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *              *-------------------------------------------------*
      *              * Percentuali di sconto in riga                   *
      *              *-------------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *              *-------------------------------------------------*
      *              * Importo in riga                                 *
      *              *-------------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Flag di significativita' provvigioni in riga    *
      *              *-------------------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
      *              *-------------------------------------------------*
      *              * Percentuali di provvigione in riga              *
      *              *-------------------------------------------------*
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
      *              *-------------------------------------------------*
      *              * Importo provvigione a forfait in riga           *
      *              *-------------------------------------------------*
           perform   vis-pvf-rig-000      thru vis-pvf-rig-999        .
      *              *-------------------------------------------------*
      *              * Codice iva                                      *
      *              *-------------------------------------------------*
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
      *              *-------------------------------------------------*
      *              * Contropartita vendite                           *
      *              *-------------------------------------------------*
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga corpo espansa  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo riga         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Codice prodotto                             *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
      *                  *---------------------------------------------*
      *                  * Quantita'                                   *
      *                  *---------------------------------------------*
           perform   pmt-qta-ven-000      thru pmt-qta-ven-999        .
      *                  *---------------------------------------------*
      *                  * Seconda quantita'                           *
      *                  *---------------------------------------------*
           perform   pmt-qta-a02-000      thru pmt-qta-a02-999        .
      *                  *---------------------------------------------*
      *                  * Prezzo                                      *
      *                  *---------------------------------------------*
           perform   pmt-prz-ven-000      thru pmt-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Legame valutario                            *
      *                  *---------------------------------------------*
           perform   pmt-ges-lvl-000      thru pmt-ges-lvl-999        .
      *                  *---------------------------------------------*
      *                  * % sconto                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "% sconto          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Importo                                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Importo           :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * % provvigione in riga                       *
      *                  *---------------------------------------------*
           perform   pmt-ppv-rig-000      thru pmt-ppv-rig-999        .
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice iva        :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Contropartita                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Contropartita     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per note in righe docu- *
      *              * mento                                           *
      *              *-------------------------------------------------*
           move      "PM"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Codice prodotto                                           *
      *    *-----------------------------------------------------------*
       pmt-cod-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  "Codice addebito   :"
                                          to   v-alf
           else if   w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento   :"
                                          to   v-alf
           else      move  "Codice prodotto   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Quantita'                        *
      *    *-----------------------------------------------------------*
       pmt-qta-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Quantita'         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-qta-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Seconda quantita'                *
      *    *-----------------------------------------------------------*
       pmt-qta-a02-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *                                                 *
      *              * N.B.: attualmente inibito                       *
      *              *-------------------------------------------------*
           go to     pmt-qta-a02-999.
      *
           if        w-rig-snx-2qt (1)    not  = 1
                     go to pmt-qta-a02-999.
       pmt-qta-a02-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      35                   to   v-pos                  .
      *
           if        w-rig-flg-puq (1)    =    "D"
                     move  "(DEC             )"
                                          to   v-alf
           else if   w-rig-flg-puq (1)    =    "C"
                     move  "(CEN             )"
                                          to   v-alf
           else if   w-rig-flg-puq (1)    =    "K"
                     move  "(MGL             )"
                                          to   v-alf
           else      move  "(MGL             )"
                                          to   v-alf                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-qta-a02-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts : Prezzo                          *
      *    *-----------------------------------------------------------*
       pmt-prz-ven-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione delle direttive          *
      *              *-------------------------------------------------*
           if        w-rig-flg-puq (1)    =    spaces
                     go to pmt-prz-ven-100
           else if   w-rig-flg-puq (1)    =    "D"
                     go to pmt-prz-ven-200
           else if   w-rig-flg-puq (1)    =    "C"
                     go to pmt-prz-ven-300
           else if   w-rig-flg-puq (1)    =    "K"
                     go to pmt-prz-ven-400
           else      go to pmt-prz-ven-100.
       pmt-prz-ven-100.
      *              *-------------------------------------------------*
      *              * Prezzo normale                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Prezzo            :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     pmt-prz-ven-800.
       pmt-prz-ven-200.
      *              *-------------------------------------------------*
      *              * Prezzo per 10 unita' di misura                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Prezzo x 10       :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     pmt-prz-ven-800.
       pmt-prz-ven-300.
      *              *-------------------------------------------------*
      *              * Prezzo per 100 unita' di misura                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Prezzo x 100      :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     pmt-prz-ven-800.
       pmt-prz-ven-400.
      *              *-------------------------------------------------*
      *              * Prezzo per 1000 unita' di misura                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Prezzo x 1000     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     pmt-prz-ven-800.
       pmt-prz-ven-800.
      *              *-------------------------------------------------*
      *              * Sigla valuta per il prezzo di vendita           *
      *              *-------------------------------------------------*
           perform   vis-sgl-vpp-000      thru vis-sgl-vpp-999        .
       pmt-prz-ven-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pmt-prz-ven-999.
       pmt-prz-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per gestione legame valutario     *
      *    *-----------------------------------------------------------*
       pmt-ges-lvl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to pmt-ges-lvl-999.
           if        w-tes-mac-lvl (1)    =    00
                     go to pmt-ges-lvl-999.
       pmt-ges-lvl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      47                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      "Legame valutario :                  +/-        "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-ges-lvl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Percentuali di provvigione in riga                        *
      *    *-----------------------------------------------------------*
       pmt-ppv-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to pmt-ppv-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to pmt-ppv-rig-999.
      *              *-------------------------------------------------*
      *              * Titolo                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare : se gestione lega- *
      *                  * valutario attiva, no visualizzazione        *
      *                  *---------------------------------------------*
           if        w-tes-mac-lvl (1)    not  = zero
                     go to pmt-ppv-rig-100.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "--------Provvigioni---------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-ppv-rig-100.
      *              *-------------------------------------------------*
      *              * Flag di significativita'                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      53                   to   v-pos                  .
           if        w-tes-mac-lvl (1)    not  = zero
                     move  "Provvigioni:" to   v-alf
           else      move  "Si/No      :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Percentuali                                     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Percentuali:"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Importo a forfait                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "A forfait  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-ppv-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : tipo    *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       acc-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-rig-025.
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    not  = spaces
                     go to acc-tip-rig-050.
           if        w-tes-tip-mps-dtr    not  = spaces
                     if    w-tes-tip-mps-dtr
                                          =    "-----"
                           move  spaces   to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050
                     else  move  w-tes-tip-mps-dtr
                                          to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050.
       acc-tip-rig-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig (1)    to   w-sav-tip-rig          .
       acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-rig        to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Pf2  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend e se le personalizzazioni   *
      *                      *        prevedono l'accettazione delle   *
      *                      *        righe bolla da lettore           *
      *                      *-----------------------------------------*
______*    if        w-cat-rig-new        not  = spaces and
______*              w-cat-rig-lst        not  = spaces and
______*              w-prs-snx-gbp        =    "S"
______*              move  "[2] "         to   v-pfk (15)             .
      *                      *-----------------------------------------*
      *                      * Pf4  : ammesso solo se gestione ordini  *
      *                      *        clienti attiva e il tipo movi-   *
      *                      *        mento per la spedizione lo con-  *
      *                      *        sente, il flag di fatturazione   *
      *                      *        separata non e' al valore 'O'    *
      *                      *        e si e' in un record New         *
      *                      *        e' in un record New              *
      *                      *-----------------------------------------*
           if       (w-prs-orc-snx        =    "S" and
                     w-tes-tip-mps-maf    =    02    ) and
                     w-tes-fat-sep (1)    not  = "O"   and
                     w-cat-rig-new        not  = spaces
                     move  "[4] "         to   v-pfk (17)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   v-alf                  .
       acc-tip-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-rig-250.
      *                  *---------------------------------------------*
      *                  * Test se ricerca per prodotto                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : find su tipi riga       *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-tip-rig-220.
           if        v-alf                =    spaces
                     go to acc-tip-rig-220.
           move      v-alf                to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    = spaces
                     go to acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su righe per codice prodotto           *
      *                  *---------------------------------------------*
           move      v-alf                to   w-fnd-mag-rig-alf      .
           move      w-cat-rig-cur        to   w-fnd-mag-rig-cur      .
           perform   fnd-mag-rig-000      thru fnd-mag-rig-999        .
           if        w-fnd-mag-rig-num    =    zero
                     go to acc-tip-rig-100.
           move      w-fnd-mag-rig-num    to   w-cnt-slc-rap-num      .
           go to     acc-tip-rig-320.
       acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su tipi riga                           *
      *                  *---------------------------------------------*
           perform   fnd-tip-rig-000      thru fnd-tip-rig-999        .
           if        w-fnd-tip-rig-sel    not  = spaces
                     go to acc-tip-rig-100.
           move      w-fnd-tip-rig-tri    to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo riga                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-rig-425.
       acc-tip-rig-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-rig-300
           else      go to acc-tip-rig-350.
       acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-rig-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-rig-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-rig-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-rig-310.
       acc-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-rig-999.
       acc-tip-rig-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-rig-999
                     else    go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf2                                          *
      *              *-------------------------------------------------*
______*    if        v-key                =    "[2] "
______*              move  "2"            to   w-cnt-tus-acc-rig
______*              go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "4"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
       acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-tip-rig (1)      .
       acc-tip-rig-425.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo tipo riga impostato           *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    not  = spaces
                     go to acc-tip-rig-100.
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : tipo riga 'A' non ammesso *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "C"
                     go to acc-tip-rig-450.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-tip-rig-450.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Tipo riga non ammesso per questo tipo documento ! 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-tip-rig-100.
       acc-tip-rig-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-rig-999
                     else  go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-rig-100.
       acc-tip-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo magazzino               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     move  01             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "S"
                     move  02             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     move  03             to   w-rig-tip-mag (1)
           else      move  zero           to   w-rig-tip-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura codice iva              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se il documento interessa l'archi- *
      *                      * vio Clienti                             *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto P                *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Solo se riga 'New'                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Solo se presente un titolo di esenzione *
      *                      * in testata                              *
      *                      *-----------------------------------------*
           if        w-tes-ass-iva (1)    =    zero or
                     w-tes-ass-iva-spl (1)
                                          =    "S"
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Esecuzione                              *
      *                      *-----------------------------------------*
           move      w-tes-ass-iva (1)    to   w-rig-coi-rig (1)      .
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           move      w-tes-ass-iva-des (1)
                                          to   w-rig-coi-rig-des (1)  .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
       acc-tip-rig-620.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura contropartita vendite   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se il documento interessa l'archi- *
      *                      * vio Clienti                             *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-tip-rig-700.
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto P                *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to acc-tip-rig-700.
           if        w-tes-ctp-ven (1)    =    zero
                     go to acc-tip-rig-700.
           move      w-tes-ctp-ven (1)    to   w-rig-ctv-rig (1)      .
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           move      w-tes-ctp-ven-des (1)
                                          to   w-rig-ctv-rig-des (1)  .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-tip-rig-700.
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt per codice prodotto  *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
       acc-tip-rig-800.
       acc-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo riga                         *
      *    *-----------------------------------------------------------*
       vis-tip-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Ricerca riga da codice di magazzino                       *
      *    *-----------------------------------------------------------*
       fnd-mag-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-fnd-mag-rig-num      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      w-fnd-mag-rig-cur    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to fnd-mag-rig-100.
       fnd-mag-rig-200.
      *              *-------------------------------------------------*
      *              * Confronto con il numero riga in corso di trat-  *
      *              * tamento                                         *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-cur    =    w-cat-rig-cur
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Confronto con il codice alfanumerico contenuto  *
      *              * nella riga                                      *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-alf    not  = w-rig-alf-pro (1)
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Riga trovata in campo do comodo                 *
      *              *-------------------------------------------------*
           move      w-cat-rig-cur        to   w-fnd-mag-rig-num      .
       fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       fnd-mag-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice addebito o commen- *
      *    *                                 to                        *
      *    *-----------------------------------------------------------*
       acc-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-cod-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig-cac (1)
                                          to   w-sav-cod-aoc          .
       acc-cod-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zac-ope      .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-cod-mne-zac-tip
           else      move  02             to   w-cod-mne-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-cod-mne-zac-cod      .
           move      15                   to   w-cod-mne-zac-lin      .
           move      21                   to   w-cod-mne-zac-pos      .
           move      16                   to   w-cod-mne-zac-dln      .
           move      21                   to   w-cod-mne-zac-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "<B"                 to   v-edm                  .
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
       acc-cod-aoc-110.
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           if        w-cod-mne-zac-ope    =    "F+"
                     go to acc-cod-aoc-115.
           if        w-cod-mne-zac-ope    =    "AC"
                     go to acc-cod-aoc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aoc-115.
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
           go to     acc-cod-aoc-110.
       acc-cod-aoc-120.
           move      w-cod-mne-zac-cod    to   v-num                  .
       acc-cod-aoc-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-tip-rig-cac (1)  .
       acc-cod-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zac]                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-let-arc-zac-tip
           else      move  02             to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato                            *
      *                  *---------------------------------------------*
           if        w-let-arc-zac-flg    =    spaces
                     go to acc-cod-aoc-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento non esistente !             
      -              "               "    to   w-err-box-err-msg
           else      move  "Codice addebito non esistente !             
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-aoc-100.
       acc-cod-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    w-sav-cod-aoc
                     go to acc-cod-aoc-800.
       acc-cod-aoc-610.
      *                  *---------------------------------------------*
      *                  * Descrizione addebito o commento             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-aoc-620.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-cod-aoc-800.
       acc-cod-aoc-630.
      *                  *---------------------------------------------*
      *                  * Flag di significativita' provvigioni in ri- *
      *                  * ga : No provvigioni                         *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    =    zero
                     move  02             to   w-rig-fsp-rig (1)
                     perform vis-fsp-rig-000
                                          thru vis-fsp-rig-999        .
       acc-cod-aoc-640.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se riga 'New'                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cod-aoc-650.
      *                      *-----------------------------------------*
      *                      * Se esiste un titolo di esenzione in te- *
      *                      * stata e il codice iva letto e' un impo- *
      *                      * nibile si forza il titolo di esenzione  *
      *                      * di testata, altrimento si forza il co-  *
      *                      * dice iva letto                          *
      *                      *-----------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero and
                     w-let-arc-zac-civ    <    00100
                     move  w-tes-ass-iva (1)
                                          to   w-rig-coi-rig (1)
           else      move  w-let-arc-zac-civ
                                          to   w-rig-coi-rig (1)      .
      *
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     move  w-let-arc-zac-civ
                                          to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zci]                  *
      *                      *-----------------------------------------*
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione codice e descrizione i- *
      *                      * va                                      *
      *                      *-----------------------------------------*
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
       acc-cod-aoc-650.
      *                  *---------------------------------------------*
      *                  * Contropartita vendite in  riga              *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctv-rig (1)      .
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-cod-aoc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-aoc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-aoc-100.
       acc-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Codice addebito o com- *
      *    *                                    mento                  *
      *    *-----------------------------------------------------------*
       vis-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to vis-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto           *
      *    *-----------------------------------------------------------*
       acc-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-cod-pro-999.
      *                      *-----------------------------------------*
      *                      * Test se riga 'new'                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cod-pro-999.
       acc-cod-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo magazzino   *
      *                  * indicato nel tipo riga                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     perform   acc-cod-dcp-000
                                          thru acc-cod-dcp-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     perform   acc-cod-dpm-000
                                          thru acc-cod-dpm-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "S"
                     perform   acc-cod-dps-000
                                          thru acc-cod-dps-999        .
       acc-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto                   *
      *    *-----------------------------------------------------------*
       vis-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cod-pro-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-alf-pro (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto secondo il clien- *
      *    * te                                                        *
      *    *-----------------------------------------------------------*
       vis-cop-scl-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cop-scl-999.
           if        w-rig-cop-scl (1)    =    spaces
                     go to vis-cop-scl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "[C]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-rig-cop-scl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cop-scl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-sav-num-pro          .
       acc-cod-dcp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      w-rig-num-pro (1)    to   w-cod-cod-dcp-num      .
           move      w-rig-alf-pro (1)    to   w-cod-cod-dcp-alf      .
           move      15                   to   w-cod-cod-dcp-lin      .
           move      21                   to   w-cod-cod-dcp-pos      .
           move      15                   to   w-cod-cod-dcp-dln      .
           move      36                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-pro (1)      .
           move      v-num                to   w-rig-num-pro (1)      .
       acc-cod-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    =    zero
                     go to acc-cod-dcp-100.
       acc-cod-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    =    w-sav-num-pro
                     go to acc-cod-dcp-999.
       acc-cod-dcp-602.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori associati al record  *
      *                  * [dcp]                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-610.
      *                      *-----------------------------------------*
      *                      * Categoria di sconto in riga associata   *
      *                      * al prodotto                             *
      *                      *-----------------------------------------*
           move      rf-dcp-cat-scr       to   w-rig-csr-aap (1)      .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto in riga associate *
      *                      * al prodotto                             *
      *                      *-----------------------------------------*
           move      rf-dcp-per-scr (1)   to   w-rig-psr-aap (1, 1)   .
           move      rf-dcp-per-scr (2)   to   w-rig-psr-aap (1, 2)   .
           move      rf-dcp-per-scr (3)   to   w-rig-psr-aap (1, 3)   .
           move      rf-dcp-per-scr (4)   to   w-rig-psr-aap (1, 4)   .
           move      rf-dcp-per-scr (5)   to   w-rig-psr-aap (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Categoria di provvigione associata al   *
      *                      * prodotto                                *
      *                      *-----------------------------------------*
           move      rf-dcp-cat-pvg       to   w-rig-cpv-aap (1)      .
      *                      *-----------------------------------------*
      *                      * Percentuali di provvigione associate al *
      *                      * prodotto                                *
      *                      *-----------------------------------------*
           move      rf-dcp-per-pvg (1)   to   w-rig-ppv-aap (1, 1)   .
           move      rf-dcp-per-pvg (2)   to   w-rig-ppv-aap (1, 2)   .
           move      rf-dcp-per-pvg (3)   to   w-rig-ppv-aap (1, 3)   .
       acc-cod-dcp-610.
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto o- *
      *                      * riginale                                *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione nuova descrizione        *
      *                      *-----------------------------------------*
           move      w-rig-des-por (1)    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-dcp-620.
      *                  *---------------------------------------------*
      *                  * Codice prodotto secondo il cliente          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-625.
      *                      *-----------------------------------------*
      *                      * Memorizzazione                          *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-cpc    to   w-rig-cop-scl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-cop-scl-000      thru vis-cop-scl-999        .
       acc-cod-dcp-625.
      *                  *---------------------------------------------*
      *                  * Tipo prodotto                               *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-tpr    to   w-rig-tip-pro (1)      .
       acc-cod-dcp-630.
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-umi    to   w-rig-umi-ven (1)      .
           perform   vis-umi-ven-000      thru vis-umi-ven-999        .
       acc-cod-dcp-640.
      *                  *---------------------------------------------*
      *                  * Tipo esposizione riga in fattura            *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-epz    to   w-rig-epz-rgf (1)      .
       acc-cod-dcp-650.
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-deq    to   w-rig-dec-qta (1)      .
       acc-cod-dcp-660.
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa l'archivio Clienti      *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-cod-dcp-800.
      *                  *---------------------------------------------*
      *                  * Decimali prezzo                             *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Sigla valuta per il prezzo di vendita       *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-rig-sgl-vpp (1)      .
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vpp (1)      .
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vpp (1)      .
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vpp (1)      .
           perform   vis-sgl-vpp-000      thru vis-sgl-vpp-999        .
       acc-cod-dcp-662.
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-664.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-cod-dcp-664.
      *                  *---------------------------------------------*
      *                  * Sigla valuta per i prezzi standard          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-666.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-rig-sgl-vps (1)      .
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vps (1)      .
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vps (1)      .
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vps (1)      .
       acc-cod-dcp-666.
      *                  *---------------------------------------------*
      *                  * Prezzo lordo standard                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-668.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-rig-prz-lrs (1)      .
      *                      *-----------------------------------------*
      *                      * Eventuale controllo di esistenza        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da eseguire                 *
      *                          *-------------------------------------*
           if        w-prs-cnt-prz-lrs    =    "N"
                     go to acc-cod-dcp-668.
      *                          *-------------------------------------*
      *                          * Test se da listino base             *
      *                          *-------------------------------------*
           if        w-prs-cnt-prz-lsu    =    "B"
                     move  d-prz-ven-prz-bas
                                          to   w-rig-prz-lrs (1)
                     go to acc-cod-dcp-668.
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-rig-prz-lrs (1)    not  = zero
                     go to acc-cod-dcp-668.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Prezzo di listino non esistente !                 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione o continuazione a  *
      *                          * seconda della personalizzazione     *
      *                          *-------------------------------------*
           if        w-prs-cnt-prz-lrs    =    "S"
                     go to acc-cod-dcp-100
           else if   w-prs-cnt-prz-lrs    =    "M"
                     go to acc-cod-dcp-668
           else if   w-prs-cnt-prz-lrs    =    "I"
                     go to acc-cod-dcp-668
           else if   w-prs-cnt-prz-lrs    =    "J"
                     go to acc-cod-dcp-668.
       acc-cod-dcp-668.
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-670.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione link-area              *
      *                          *-------------------------------------*
           move      "SR"                 to   d-per-scr-tip-ope      .
           move      w-rig-psr-aap (1, 1) to   d-per-scr-psr-pro (1)  .
           move      w-rig-psr-aap (1, 2) to   d-per-scr-psr-pro (2)  .
           move      w-rig-psr-aap (1, 3) to   d-per-scr-psr-pro (3)  .
           move      w-rig-psr-aap (1, 4) to   d-per-scr-psr-pro (4)  .
           move      w-rig-psr-aap (1, 5) to   d-per-scr-psr-pro (5)  .
           move      w-rig-csr-aap (1)    to   d-per-scr-csr-pro      .
           move      w-tes-psr-aac (1, 1) to   d-per-scr-psr-cli (1)  .
           move      w-tes-psr-aac (1, 2) to   d-per-scr-psr-cli (2)  .
           move      w-tes-psr-aac (1, 3) to   d-per-scr-psr-cli (3)  .
           move      w-tes-psr-aac (1, 4) to   d-per-scr-psr-cli (4)  .
           move      w-tes-psr-aac (1, 5) to   d-per-scr-psr-cli (5)  .
           move      w-tes-csr-aac (1)    to   d-per-scr-csr-cli      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-per-scr-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-per-scr-cod-cli      .
           move      w-tes-cod-lst (1)    to   d-per-scr-cod-lst      .
           move      w-rig-sgl-vpp (1)    to   d-per-scr-sgl-vpf      .
           move      w-rig-num-pro (1)    to   d-per-scr-num-pro      .
           move      w-tes-dat-doc        to   d-per-scr-dat-rif      .
      *                          *-------------------------------------*
      *                          * Richiamo del sottoprogramma         *
      *                          *-------------------------------------*
           move      "pgm/fat/prg/obj/dperscr0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-per-scr              .
      *                          *-------------------------------------*
      *                          * Memorizzazione valori determinati   *
      *                          *-------------------------------------*
           move      d-per-scr-per-scr (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-per-scr-per-scr (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-per-scr-per-scr (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-per-scr-per-scr (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-per-scr-per-scr (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-cod-dcp-670.
      *                  *---------------------------------------------*
      *                  * Prezzo netto standard                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-680.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-nts (1)      .
       acc-cod-dcp-680.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-cod-dcp-685.
      *                  *---------------------------------------------*
      *                  * Tipo esposizione prezzi e sconti            *
      *                  *---------------------------------------------*
           move      w-tes-epz-pes (1)    to   w-rig-epz-pes (1)      .
       acc-cod-dcp-690.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-cod-dcp-700.
      *                      *-----------------------------------------*
      *                      * Se flag significativita' provvigioni    *
      *                      * per il documento indica 'No' o 'A for-  *
      *                      * fait' : No provvigioni in riga          *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     move  02             to   w-rig-fsp-rig (1)
                     go to acc-cod-dcp-698.
      *                      *-----------------------------------------*
      *                      * Se flag significativita' provvigioni    *
      *                      * per il documento indica 'A forfait' in  *
      *                      * % : Forzatura provvigioni in riga       *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     move   03            to   w-rig-fsp-rig (1)
                     divide 100           into w-tes-pvf-age (1)
                                        giving w-rig-ppv-rig (1, 1)
                     go to acc-cod-dcp-698.
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : No provvigioni   *
      *                      * in riga                                 *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     move  02             to   w-rig-fsp-rig (1)
                     go to acc-cod-dcp-698.
      *                      *-----------------------------------------*
      *                      * Default per provvigioni in riga : Si    *
      *                      *-----------------------------------------*
           move      01                   to   w-rig-fsp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
       acc-cod-dcp-698.
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-cod-dcp-700.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     go to acc-cod-dcp-710.
      *
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dcp-720.
       acc-cod-dcp-710.
           move      w-let-dcp-pdx-coi    to   w-rig-coi-rig (1)      .
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
       acc-cod-dcp-720.
      *                  *---------------------------------------------*
      *                  * Contropartita vendite in  riga              *
      *                  *---------------------------------------------*
           if        w-tes-ctp-ven (1)    not  = zero
                     go to acc-cod-dcp-740.
           move      w-let-dcp-pdx-ctp    to   w-rig-ctv-rig (1)      .
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-cod-dcp-740.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dcp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dcp-100.
       acc-cod-dcp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dpm]     *
      *    *-----------------------------------------------------------*
       acc-cod-dpm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-sav-num-pro          .
       acc-cod-dpm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dpm-ope      .
           move      "A"                  to   w-cod-cod-dpm-tac      .
           move      w-rig-num-pro (1)    to   w-cod-cod-dpm-num      .
           move      w-rig-alf-pro (1)    to   w-cod-cod-dpm-alf      .
           move      15                   to   w-cod-cod-dpm-lin      .
           move      21                   to   w-cod-cod-dpm-pos      .
           move      15                   to   w-cod-cod-dpm-dln      .
           move      36                   to   w-cod-cod-dpm-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-dpm-cll-000  thru cod-cod-dpm-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dpm-foi-000  thru cod-cod-dpm-foi-999    .
       acc-cod-dpm-110.
           perform   cod-cod-dpm-cll-000  thru cod-cod-dpm-cll-999    .
           if        w-cod-cod-dpm-ope    =    "F+"
                     go to acc-cod-dpm-115.
           if        w-cod-cod-dpm-ope    =    "AC"
                     go to acc-cod-dpm-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dpm-115.
           perform   cod-cod-dpm-foi-000  thru cod-cod-dpm-foi-999    .
           go to     acc-cod-dpm-110.
       acc-cod-dpm-120.
           move      w-cod-cod-dpm-alf    to   v-alf                  .
           move      w-cod-cod-dpm-num    to   v-num                  .
       acc-cod-dpm-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-pro (1)      .
           move      v-num                to   w-rig-num-pro (1)      .
       acc-cod-dpm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dpm]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-arc-dpm-cod      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dpm-flg    not  = spaces
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    =    zero
                     go to acc-cod-dpm-100.
       acc-cod-dpm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto o- *
      *                      * riginale                                *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione nuova descrizione        *
      *                      *-----------------------------------------*
           move      w-rig-des-por (1)    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Tipo prodotto : forzato a Merce             *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-umi    to   w-rig-umi-ven (1)      .
           perform   vis-umi-ven-000      thru vis-umi-ven-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione riga in fattura : fisso a  *
      *                  * '1'                                         *
      *                  *---------------------------------------------*
           move      1                    to   w-rig-epz-rgf (1)      .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa l'archivio Clienti      *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-cod-dpm-800.
      *                  *---------------------------------------------*
      *                  * Sigla valuta per il prezzo di vendita       *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-rig-sgl-vpp (1)      .
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vpp (1)      .
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vpp (1)      .
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vpp (1)      .
           perform   vis-sgl-vpp-000      thru vis-sgl-vpp-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione prezzi e sconti            *
      *                  *---------------------------------------------*
           move      w-tes-epz-pes (1)    to   w-rig-epz-pes (1)      .
       acc-cod-dpm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dpm-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dpm-100.
       acc-cod-dpm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dps]     *
      *    *-----------------------------------------------------------*
       acc-cod-dps-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-sav-num-pro          .
       acc-cod-dps-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dps-ope      .
           move      "A"                  to   w-cod-cod-dps-tac      .
           move      w-rig-num-pro (1)    to   w-cod-cod-dps-num      .
           move      w-rig-alf-pro (1)    to   w-cod-cod-dps-alf      .
           move      15                   to   w-cod-cod-dps-lin      .
           move      21                   to   w-cod-cod-dps-pos      .
           move      15                   to   w-cod-cod-dps-dln      .
           move      36                   to   w-cod-cod-dps-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-dps-cll-000  thru cod-cod-dps-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dps-foi-000  thru cod-cod-dps-foi-999    .
       acc-cod-dps-110.
           perform   cod-cod-dps-cll-000  thru cod-cod-dps-cll-999    .
           if        w-cod-cod-dps-ope    =    "F+"
                     go to acc-cod-dps-115.
           if        w-cod-cod-dps-ope    =    "AC"
                     go to acc-cod-dps-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dps-115.
           perform   cod-cod-dps-foi-000  thru cod-cod-dps-foi-999    .
           go to     acc-cod-dps-110.
       acc-cod-dps-120.
           move      w-cod-cod-dps-alf    to   v-alf                  .
           move      w-cod-cod-dps-num    to   v-num                  .
       acc-cod-dps-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dps-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dps-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-pro (1)      .
           move      v-num                to   w-rig-num-pro (1)      .
       acc-cod-dps-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dps]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-arc-dps-cod      .
           perform   let-arc-dps-000      thru let-arc-dps-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dps-flg    not  = spaces
                     go to acc-cod-dps-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    =    zero
                     go to acc-cod-dps-100.
       acc-cod-dps-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto o- *
      *                      * riginale                                *
      *                      *-----------------------------------------*
           move      w-let-arc-dps-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione nuova descrizione        *
      *                      *-----------------------------------------*
           move      w-rig-des-por (1)    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Tipo prodotto : forzato a 'Merce'           *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dps-umi    to   w-rig-umi-ven (1)      .
           perform   vis-umi-ven-000      thru vis-umi-ven-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione riga in fattura : fisso a  *
      *                  * '1'                                         *
      *                  *---------------------------------------------*
           move      1                    to   w-rig-epz-rgf (1)      .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dps-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa l'archivio Clienti      *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-cod-dps-800.
      *                  *---------------------------------------------*
      *                  * Sigla valuta per il prezzo di vendita       *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-rig-sgl-vpp (1)      .
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vpp (1)      .
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vpp (1)      .
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vpp (1)      .
           perform   vis-sgl-vpp-000      thru vis-sgl-vpp-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione prezzi e sconti            *
      *                  *---------------------------------------------*
           move      w-tes-epz-pes (1)    to   w-rig-epz-pes (1)      .
       acc-cod-dps-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dps-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dps-100.
       acc-cod-dps-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Unita' di misura                  *
      *    *-----------------------------------------------------------*
       vis-umi-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-rig-umi-ven (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-umi-ven-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Descrizione in riga       *
      *    *-----------------------------------------------------------*
       acc-des-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-des-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      15                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    spaces
                     move  "INSR"         to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-des-rig (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-rig-des-rig (1)      .
       acc-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-des-rig-400.
      *                  *---------------------------------------------*
      *                  * Insr su archivio [pdx]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-ins-arc-pdx-cnp      .
           move      w-tes-tip-arc (1)    to   w-ins-arc-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-ins-arc-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-ins-arc-pdx-arc      .
           perform   ins-arc-pdx-000      thru ins-arc-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che la descrizione in  *
      *                  * riga attuale sia uguale o meno a quella del *
      *                  * prodotto                                    *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    =    w-rig-des-por (1)
                     go to acc-des-rig-310
           else      go to acc-des-rig-320.
       acc-des-rig-310.
      *                  *---------------------------------------------*
      *                  * Se descrizione in riga attuale pari a quel- *
      *                  * la del prodotto                             *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)
                                               w-rig-des-rig (1)      .
           perform   vis-des-rig-000      thru vis-des-rig-999        .
           go to     acc-des-rig-350.
       acc-des-rig-320.
      *                  *---------------------------------------------*
      *                  * Se descrizione in riga attuale diversa da   *
      *                  * quella del prodotto                         *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)      .
           go to     acc-des-rig-350.
       acc-des-rig-350.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice prodotto secondo il  *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-cpc    to   w-rig-cop-scl (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice prodotto secondo il  *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           perform   vis-cop-scl-000      thru vis-cop-scl-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-des-rig-100.
       acc-des-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spazi ammesso solo per tipi riga   *
      *                  * 'C', a meno che non si sia in Up            *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = spaces
                     go to acc-des-rig-600.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-des-rig-600.
           if        v-key                =    "UP  "
                     go to acc-des-rig-600
           else      go to acc-des-rig-100.
       acc-des-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione flag di estensione alla de-  *
      *                  * scrizione                                   *
      *                  *---------------------------------------------*
           perform   det-des-ext-000      thru det-des-ext-999        .
       acc-des-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-des-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-des-rig-100.
       acc-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione in riga               *
      *    *-----------------------------------------------------------*
       vis-des-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      15                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      w-rig-des-rig (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' di vendita      *
      *    *-----------------------------------------------------------*
       acc-qta-ven-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-ven-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-ven (1)    to   w-sav-qta-ven          .
       acc-qta-ven-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           if        w-prs-orc-snx        =    "S"    and
                     w-tes-tip-mps-maf    =    02     and
                     w-rig-coc-prt (1)    not  = zero and
                     w-rig-coc-prg (1)    not  = zero
                     move  "[1] "         to   v-pfk (14)             .
           move      w-rig-qta-ven (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ven-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ven-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-ven (1)      .
       acc-qta-ven-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-qta-ven (1)    =    w-sav-qta-ven
                     go to acc-qta-ven-600.
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-mac-prz        not  = 02
                     go to acc-qta-ven-600.
      *                  *---------------------------------------------*
      *                  * Ricalcolo del prezzo di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-qta-ven-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento flag di saldo forzato           *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-qta-ven-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           if        w-rig-coc-fzs (1)    =    spaces
                     move  "S"            to   w-rig-coc-fzs (1)
           else      move  spaces         to   w-rig-coc-fzs (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-coc-fzs-000      thru vis-coc-fzs-999        .
       acc-qta-ven-620.
      *                  *---------------------------------------------*
      *                  * Trattamento quantita' secondaria            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se trattamento necessario          *
      *                      *-----------------------------------------*
           if        w-rig-snx-2qt (1)    not  = 1
                     go to acc-qta-ord-700.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' secondaria     *
      *                      *-----------------------------------------*
           move      w-rig-qta-ven (1)    to   w-det-qta-a02-qim      .
           move      w-rig-dec-2qt (1)    to   w-det-qta-a02-ndu      .
           if        w-rig-flg-puq (1)    =    "K"
                     move  1000           to   w-det-qta-a02-cmu
           else      move  1              to   w-det-qta-a02-cmu      .
           move      1                    to   w-det-qta-a02-cdu      .
           perform   det-qta-a02-000      thru det-qta-a02-999        .
           move      w-det-qta-a02-qts    to   w-rig-qta-a02 (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione seconda quantita'       *
      *                      *-----------------------------------------*
           perform   vis-qta-a02-000      thru vis-qta-a02-999        .
       acc-qta-ord-700.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-ven-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-ven-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-ven-100.
       acc-qta-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' di vendita              *
      *    *-----------------------------------------------------------*
       vis-qta-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-qta-ven (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-ven-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Seconda quantita'                          *
      *    *-----------------------------------------------------------*
       acc-qta-a02-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * ATTUALMENTE MAI ACCETTATA                   *
      *                  *---------------------------------------------*
           go to     acc-qta-a02-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-snx-2qt (1)    not  = 1
                     go to acc-qta-a02-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-a02-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-a02 (1)    to   w-sav-qta-a02          .
       acc-qta-a02-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           perform   pmt-qta-a02-000      thru pmt-qta-a02-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      w-rig-dec-2qt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-qta-a02 (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-a02-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-a02-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-a02 (1)      .
       acc-qta-a02-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-qta-a02 (1)    =    w-sav-qta-a02
                     go to acc-qta-a02-800.
       acc-qta-a02-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione seconda quantita'           *
      *                  *---------------------------------------------*
           perform   vis-qta-a02-000      thru vis-qta-a02-999        .
       acc-qta-a02-700.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-a02-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-a02-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-a02-100.
       acc-qta-a02-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Seconda quantita'                       *
      *    *-----------------------------------------------------------*
       vis-qta-a02-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *                                                 *
      *              * N.B.: attualmente inibito                       *
      *              *-------------------------------------------------*
           go to     vis-qta-a02-999.
      *
           if        w-rig-snx-2qt (1)    not  = 1
                     go to vis-qta-a02-999.
       vis-qta-a02-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
       vis-qta-a02-200.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore da editare  *
      *                  *---------------------------------------------*
           if        w-rig-qta-a02 (1)    =    zero
                     go to vis-qta-a02-300
           else      go to vis-qta-a02-400.
       vis-qta-a02-300.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione a spaces                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-a02-999.
       vis-qta-a02-400.
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      w-rig-dec-2qt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      w-rig-qta-a02 (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione area editata completa      *
      *                      *-----------------------------------------*
           move      18                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "(MGL"               to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-a02-999.
       vis-qta-a02-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag di saldo riga ordine cliente *
      *    *-----------------------------------------------------------*
       vis-coc-fzs-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-orc-snx        not  = "S" or
                     w-tes-tip-mps-maf    not  = 02  or
                     w-rig-coc-prt (1)    =    zero  or
                     w-rig-coc-prg (1)    =    zero
                     go to vis-coc-fzs-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-coc-fzs-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      37                   to   v-pos                  .
           if        w-rig-coc-fzs (1)    =    "S"
                     move  "[S]"          to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-coc-fzs-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per il prez- *
      *    * zo di vendita                                             *
      *    *-----------------------------------------------------------*
       acc-sgl-vpp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-sgl-vpp-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione per gestione  *
      *                      * valuta per il prezzo                    *
      *                      *-----------------------------------------*
           if        w-prs-ges-vpp        =    zero
                     go to acc-sgl-vpp-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpp-999.
      *                      *-----------------------------------------*
      *                      * Salvataggio valore precedente           *
      *                      *-----------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-sav-sgl-vpp          .
       acc-sgl-vpp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpp (1)    to   w-cod-cod-zvl-cod      .
           move      17                   to   w-cod-cod-zvl-lin      .
           move      15                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpp-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpp-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpp-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpp-110.
       acc-sgl-vpp-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpp (1)      .
       acc-sgl-vpp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpp-100.
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    =    spaces
                     go to acc-sgl-vpp-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori connessi             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che la sigla valu- *
      *                      * ta per il prezzo sia uguale a quella di *
      *                      * fatturazione o no                       *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpp (1)    =    w-tes-sgl-vpf (1)
                     go to acc-sgl-vpp-420
           else      go to acc-sgl-vpp-440.
       acc-sgl-vpp-420.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta per il prezzo uguale a  *
      *                      * quella di fatturazione                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio della valuta di fatturazione *
      *                          *-------------------------------------*
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sgl-vpp-600.
       acc-sgl-vpp-440.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta per il prezzo diversa   *
      *                      * da quella di fatturazione               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio                                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpp (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpp (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpp-442.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpp-100.
       acc-sgl-vpp-442.
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio                              *
      *                          *-------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sgl-vpp-600.
       acc-sgl-vpp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    =    w-sav-sgl-vpp
                     go to acc-sgl-vpp-800.
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-sgl-vpp-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-sgl-vpp-620.
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-sgl-vpp-640.
      *                      *-----------------------------------------*
      *                      * Determinazione percentuali di sconto in *
      *                      * riga                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione link-area              *
      *                          *-------------------------------------*
           move      "SR"                 to   d-per-scr-tip-ope      .
           move      w-rig-psr-aap (1, 1) to   d-per-scr-psr-pro (1)  .
           move      w-rig-psr-aap (1, 2) to   d-per-scr-psr-pro (2)  .
           move      w-rig-psr-aap (1, 3) to   d-per-scr-psr-pro (3)  .
           move      w-rig-psr-aap (1, 4) to   d-per-scr-psr-pro (4)  .
           move      w-rig-psr-aap (1, 5) to   d-per-scr-psr-pro (5)  .
           move      w-rig-csr-aap (1)    to   d-per-scr-csr-pro      .
           move      w-tes-psr-aac (1, 1) to   d-per-scr-psr-cli (1)  .
           move      w-tes-psr-aac (1, 2) to   d-per-scr-psr-cli (2)  .
           move      w-tes-psr-aac (1, 3) to   d-per-scr-psr-cli (3)  .
           move      w-tes-psr-aac (1, 4) to   d-per-scr-psr-cli (4)  .
           move      w-tes-psr-aac (1, 5) to   d-per-scr-psr-cli (5)  .
           move      w-tes-csr-aac (1)    to   d-per-scr-csr-cli      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-per-scr-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-per-scr-cod-cli      .
           move      w-tes-cod-lst (1)    to   d-per-scr-cod-lst      .
           move      w-rig-sgl-vpp (1)    to   d-per-scr-sgl-vpf      .
           move      w-rig-num-pro (1)    to   d-per-scr-num-pro      .
           move      w-tes-dat-doc        to   d-per-scr-dat-rif      .
      *                          *-------------------------------------*
      *                          * Richiamo del sottoprogramma         *
      *                          *-------------------------------------*
           move      "pgm/fat/prg/obj/dperscr0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-per-scr              .
      *                          *-------------------------------------*
      *                          * Memorizzazione valori determinati   *
      *                          *-------------------------------------*
           move      d-per-scr-per-scr (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-per-scr-per-scr (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-per-scr-per-scr (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-per-scr-per-scr (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-per-scr-per-scr (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-sgl-vpp-640.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-sgl-vpp-660.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-sgl-vpp-680.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-sgl-vpp-680.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-sgl-vpp-680.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-sgl-vpp-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-sgl-vpp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpp-100.
       acc-sgl-vpp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla valuta per il prezzo di     *
      *    * vendita                                                   *
      *    *-----------------------------------------------------------*
       vis-sgl-vpp-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-rig-sgl-vpp (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo di vendita         *
      *    *-----------------------------------------------------------*
       acc-prz-ven-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-prz-ven-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-ven-999.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura del tasto Pf3 per fare  *
      *                  * in modo di accettare il prezzo lordo stan-  *
      *                  * dard                                        *
      *                  *---------------------------------------------*
           if       (w-prs-cnt-prz-lrs    =    "I" or
                     w-prs-cnt-prz-lrs    =    "J"  ) and
                     w-rig-prz-lrs (1)    =    zero
                     move  spaces         to   v-mod
                     move  "[3] "         to   v-key
                     go to acc-prz-ven-220.
       acc-prz-ven-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo di vendita                       *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-sav-prz-ven          .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto in riga           *
      *                      *-----------------------------------------*
           move      w-rig-per-scr (1, 1) to   w-sav-per-scr (1)      .
           move      w-rig-per-scr (1, 2) to   w-sav-per-scr (2)      .
           move      w-rig-per-scr (1, 3) to   w-sav-per-scr (3)      .
           move      w-rig-per-scr (1, 4) to   w-sav-per-scr (4)      .
           move      w-rig-per-scr (1, 5) to   w-sav-per-scr (5)      .
       acc-prz-ven-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-rig-dec-vpp (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           if        w-prs-cnt-prz-lrs    =    "I" or
                     w-prs-cnt-prz-lrs    =    "J"
                     move  "[3] "         to   v-pfk (16)             .
           move      w-rig-prz-ven (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-prz-ven-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-prz-ven-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-prz-ven-999.
       acc-prz-ven-220.
      *              *-------------------------------------------------*
      *              * Se Pf3                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[3] "
                     go to acc-prz-ven-300.
      *                  *---------------------------------------------*
      *                  * Se campo d'impostazione variato : reimpo-   *
      *                  * stazione                                    *
      *                  *---------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-prz-ven-100.
      *                  *---------------------------------------------*
      *                  * Accettazione prezzo lordo standard          *
      *                  *---------------------------------------------*
           perform   acc-prz-lrs-000      thru acc-prz-lrs-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-prz-ven-999.
      *                  *---------------------------------------------*
      *                  * A pre-accettazione e reimpostazione         *
      *                  *---------------------------------------------*
           go to     acc-prz-ven-050.
       acc-prz-ven-300.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-ven (1)      .
       acc-prz-ven-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Up e valore a zero : controllo superato  *
      *                  *---------------------------------------------*
           if        w-rig-prz-ven (1)    =    zero   and
                     v-key                =    "UP  "
                     go to acc-prz-ven-600.
      *                  *---------------------------------------------*
      *                  * Eventuale controllo di esistenza            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-prz-ven-600.
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-ven    =    "N"
                     go to acc-prz-ven-600.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-prz-ven (1)    not  = zero
                     go to acc-prz-ven-600.
      *                      *-----------------------------------------*
      *                      * A reimpostazione o continuazione a se-  *
      *                      * conda della personalizzazione           *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-ven    =    "S"
                     go to acc-prz-ven-100
           else if   w-prs-cnt-prz-ven    =    "M"
                     go to acc-prz-ven-600.
       acc-prz-ven-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-prz-ven-610.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda della personaliz-  *
      *                      * zazione sulle modalita' di accettazione *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        w-prs-mac-prz        =    zero
                     go to acc-prz-ven-602
           else if   w-prs-mac-prz        =    01
                     go to acc-prz-ven-604.
       acc-prz-ven-602.
      *                      *-----------------------------------------*
      *                      * Se modalita' di accettazione prezzo :   *
      *                      * Normale, azzeramento delle percentuali  *
      *                      * di sconto                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se percentuali di sconto gia' tutte *
      *                          * a zero : nessuna azione             *
      *                          *-------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-ven-610.
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-ven-610.
       acc-prz-ven-604.
      *                      *-----------------------------------------*
      *                      * Se modalita' di accettazione prezzo :   *
      *                      * 01, nessuna azione                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-ven-610.
       acc-prz-ven-610.
      *                  *---------------------------------------------*
      *                  * Trattamento percentuali di sconto in fun-   *
      *                  * zione della eventuale personalizzazione     *
      *                  * sulla modalita' di accettazione prezzo      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prezzo invariato : nessun trattamen- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           if        w-rig-prz-ven (1)    =    w-sav-prz-ven
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Se personalizzazione sulla modalita' di *
      *                      * accettazione prezzo non e' a valore 01, *
      *                      * nessun trattamento                      *
      *                      *-----------------------------------------*
           if        w-prs-mac-prz        not  = 01
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Se Pf1 : nessun trattamento             *
      *                      *-----------------------------------------*
           if        v-key                =    "[1] "
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Se percentuali di sconto gia' tutte a   *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Normalizzazione                         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-prz-ven-615.
      *                  *---------------------------------------------*
      *                  * Se valori attuali come precedenti : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-prz-ven (1)    =    w-sav-prz-ven     and
                     w-rig-per-scr (1, 1) =    w-sav-per-scr (1) and
                     w-rig-per-scr (1, 2) =    w-sav-per-scr (2) and
                     w-rig-per-scr (1, 3) =    w-sav-per-scr (3) and
                     w-rig-per-scr (1, 4) =    w-sav-per-scr (4) and
                     w-rig-per-scr (1, 5) =    w-sav-per-scr (5)
                     go to acc-prz-ven-800.
       acc-prz-ven-620.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-ven-640.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-prz-ven-680.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-prz-ven-680.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-prz-ven-680.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-ven-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-prz-ven-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-ven-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-ven-100.
       acc-prz-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Prezzo di vendita                 *
      *    *-----------------------------------------------------------*
       vis-prz-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-rig-dec-vpp (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-prz-ven (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-ven-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo lordo standard     *
      *    *-----------------------------------------------------------*
       acc-prz-lrs-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-prz-lrs-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-lrs-999.
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-prz-lrs-999.
      *                      *-----------------------------------------*
      *                      * Test se consentito dalla personalizza-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if       (w-prs-cnt-prz-lrs    =    "I"   ) or
                    (w-prs-cnt-prz-lrs    =    "J" and
                     w-rig-prz-lrs (1)    =    zero  )
                     go to acc-prz-lrs-050
           else      go to acc-prz-lrs-999.
       acc-prz-lrs-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo lordo standard                   *
      *                      *-----------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-sav-prz-lrs          .
      *                      *-----------------------------------------*
      *                      * Prezzo netto standard                   *
      *                      *-----------------------------------------*
           move      w-rig-prz-nts (1)    to   w-sav-prz-nts          .
      *                  *---------------------------------------------*
      *                  * Preparazione box per accettazione           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      16                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      68                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Prompt per prezzo di listino            *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Prezzo di listino :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-prz-lrs-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-rig-dec-vps (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-prz-lrs (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     perform acc-prz-lrs-900
                                          thru acc-prz-lrs-909
                     go to acc-prz-lrs-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     perform acc-prz-lrs-900
                                          thru acc-prz-lrs-909
                     go to acc-prz-lrs-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-lrs (1)      .
       acc-prz-lrs-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-prz-lrs (1)    not  = zero
                     go to acc-prz-lrs-600.
           if        v-key                =    "UP  "
                     go to acc-prz-lrs-600
           else      go to acc-prz-lrs-100.
       acc-prz-lrs-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per ripristino imma-  *
      *                  * gine video                                  *
      *                  *---------------------------------------------*
           perform   acc-prz-lrs-900      thru acc-prz-lrs-909        .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-prz-lrs (1)    =    w-sav-prz-lrs
                     go to acc-prz-lrs-800.
       acc-prz-lrs-620.
      *                  *---------------------------------------------*
      *                  * Trattamento prezzo netto standard           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che il lordo stan- *
      *                      * dard precedente sia a zero o no         *
      *                      *-----------------------------------------*
           if        w-sav-prz-lrs        =    zero
                     go to acc-prz-lrs-622
           else      go to acc-prz-lrs-624.
       acc-prz-lrs-622.
      *                      *-----------------------------------------*
      *                      * Se prezzo lordo standard precedente a   *
      *                      * zero                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione sconti in riga       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Preparazione link-area          *
      *                              *---------------------------------*
           move      "SR"                 to   d-per-scr-tip-ope      .
           move      w-rig-psr-aap (1, 1) to   d-per-scr-psr-pro (1)  .
           move      w-rig-psr-aap (1, 2) to   d-per-scr-psr-pro (2)  .
           move      w-rig-psr-aap (1, 3) to   d-per-scr-psr-pro (3)  .
           move      w-rig-psr-aap (1, 4) to   d-per-scr-psr-pro (4)  .
           move      w-rig-psr-aap (1, 5) to   d-per-scr-psr-pro (5)  .
           move      w-rig-csr-aap (1)    to   d-per-scr-csr-pro      .
           move      w-tes-psr-aac (1, 1) to   d-per-scr-psr-cli (1)  .
           move      w-tes-psr-aac (1, 2) to   d-per-scr-psr-cli (2)  .
           move      w-tes-psr-aac (1, 3) to   d-per-scr-psr-cli (3)  .
           move      w-tes-psr-aac (1, 4) to   d-per-scr-psr-cli (4)  .
           move      w-tes-psr-aac (1, 5) to   d-per-scr-psr-cli (5)  .
           move      w-tes-csr-aac (1)    to   d-per-scr-csr-cli      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-per-scr-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-per-scr-cod-cli      .
           move      w-tes-cod-lst (1)    to   d-per-scr-cod-lst      .
           move      w-rig-sgl-vpp (1)    to   d-per-scr-sgl-vpf      .
           move      w-rig-num-pro (1)    to   d-per-scr-num-pro      .
           move      w-tes-dat-doc        to   d-per-scr-dat-rif      .
      *                              *---------------------------------*
      *                              * Richiamo del sottoprogramma     *
      *                              *---------------------------------*
           move      "pgm/fat/prg/obj/dperscr0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-per-scr              .
      *                          *-------------------------------------*
      *                          * Determinazione prezzo netto stan-   *
      *                          * dard                                *
      *                          *-------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-cal-prz-net-prz      .
           move      d-per-scr-per-scr (1)
                                          to   w-cal-prz-net-psc (1)  .
           move      d-per-scr-per-scr (2)
                                          to   w-cal-prz-net-psc (2)  .
           move      d-per-scr-per-scr (3)
                                          to   w-cal-prz-net-psc (3)  .
           move      d-per-scr-per-scr (4)
                                          to   w-cal-prz-net-psc (4)  .
           move      d-per-scr-per-scr (5)
                                          to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-nts (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-lrs-630.
       acc-prz-lrs-624.
      *                      *-----------------------------------------*
      *                      * Se prezzo lordo standard precedente di- *
      *                      * verso da zero                           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione prezzo netto in base *
      *                          * al lordo e netto standard preceden- *
      *                          * ti                                  *
      *                          *-------------------------------------*
           multiply  w-sav-prz-nts        by   w-rig-prz-lrs (1)
                                        giving w-acc-prz-lrs-n17      .
           divide    w-sav-prz-lrs        into w-acc-prz-lrs-n17
                                        giving w-rig-prz-nts (1)
                                               rounded                .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-lrs-630.
       acc-prz-lrs-630.
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita, prezzo netto e importo   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prezzo di vendita diverso dal prezzo *
      *                      * lordo standard precedente : oltre       *
      *                      *-----------------------------------------*
           if        w-rig-prz-ven (1)    not  = w-sav-prz-lrs
                     go to acc-prz-lrs-680.
      *                      *-----------------------------------------*
      *                      * Prezzo di vendita                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzatura al prezzo lordo standard  *
      *                          * attuale                             *
      *                          *-------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-rig-prz-ven (1)      .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-prz-lrs-632.
      *                      *-----------------------------------------*
      *                      * Prezzo netto                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-lrs-634.
      *                      *-----------------------------------------*
      *                      * Importo in riga                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-lrs-680.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-prz-lrs-700.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-prz-lrs-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-prz-lrs-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-lrs-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-lrs-100.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-prz-lrs-999.
       acc-prz-lrs-900.
      *              *=================================================*
      *              * Subroutine interna per ripristino immagine vi-  *
      *              * deo                                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-prz-lrs-909.
           exit.
       acc-prz-lrs-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per legame   *
      *    * valutario                                                 *
      *    *-----------------------------------------------------------*
       acc-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Salvataggio valore precedente           *
      *                      *-----------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-sav-sgl-vpl          .
       acc-sgl-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpl (1)    to   w-cod-cod-zvl-cod      .
           move      17                   to   w-cod-cod-zvl-lin      .
           move      53                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpl-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpl-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpl-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpl-110.
       acc-sgl-vpl-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpl (1)      .
       acc-sgl-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpl-100.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per fatturazione                            *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-tes-sgl-vpf (1)
                     go to acc-sgl-vpl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per fatturazione del documento 
      -              "!              "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-500.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per il prezzo                               *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-rig-sgl-vpp (1)
                     go to acc-sgl-vpl-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per l'espressione del prezzo ! 
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    w-sav-sgl-vpl
                     go to acc-sgl-vpl-800.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che il valore sia esi- *
      *                  * stente o no                                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-sgl-vpl-620
           else      go to acc-sgl-vpl-640.
       acc-sgl-vpl-620.
      *                  *---------------------------------------------*
      *                  * Se valore non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori connessi         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-dec-vpl (1)      .
           move      spaces               to   w-rig-tdc-vpl (1)      .
           move      zero                 to   w-rig-cdc-vpl (1)      .
           move      zero                 to   w-rig-ccr-vpl (1)      .
           move      zero                 to   w-rig-plm-vpl (1)      .
           move      spaces               to   w-rig-tlm-vpl (1)      .
           move      spaces               to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori connessi         *
      *                      *-----------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-800.
       acc-sgl-vpl-640.
      *                  *---------------------------------------------*
      *                  * Se valore esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori connessi         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Prezzo di riferimento               *
      *                          *-------------------------------------*
           move      w-rig-prz-ven (1)    to   w-rig-prz-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio                                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpl-642.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-642.
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio                              *
      *                          *-------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Coefficiente di cambio di riferi-   *
      *                          * mento                               *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-ccr-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Percentuale di limitazione          *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-plm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Tipo di limitazione                 *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-tlm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Momento di applicazione cambio      *
      *                          *-------------------------------------*
           if        w-tes-mac-lvl (1)    =    11
                     move  "B"            to   w-rig-map-vpl (1)
           else if   w-tes-mac-lvl (1)    =    21
                     move  "F"            to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-800.
       acc-sgl-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpl-100.
       acc-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla valuta per legame valutario *
      *    *-----------------------------------------------------------*
       vis-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to vis-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-sgl-vpl-999.
       vis-sgl-vpl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      w-rig-sgl-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Coefficiente di cambio di *
      *    * riferimento per legame valutario                          *
      *    *-----------------------------------------------------------*
       acc-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-ccr-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-ccr-vpl (1)    to   w-sav-ccr-vpl          .
       acc-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           move      zero                 to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           move      "N"                  to   w-coe-cmb-vlt-snd      .
           move      w-rig-ccr-vpl (1)    to   w-coe-cmb-vlt-cdc      .
           move      17                   to   w-coe-cmb-vlt-lin      .
           move      57                   to   w-coe-cmb-vlt-pos      .
           move      zero                 to   w-coe-cmb-vlt-dln      .
           move      zero                 to   w-coe-cmb-vlt-dps      .
           move      "BD"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-ccr-vpl-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-ccr-vpl-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-ccr-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ccr-vpl-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-ccr-vpl-110.
       acc-ccr-vpl-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-ccr-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ccr-vpl (1)      .
       acc-ccr-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    not  = zero
                     go to acc-ccr-vpl-600.
           if        v-key                =    "UP  "
                     go to acc-ccr-vpl-600
           else      go to acc-ccr-vpl-100.
       acc-ccr-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    =    w-sav-ccr-vpl
                     go to acc-ccr-vpl-800.
       acc-ccr-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ccr-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ccr-vpl-100.
       acc-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Coefficiente di cambio di riferi- *
      *    * mento per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to vis-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-ccr-vpl-999.
       vis-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      17                   to   v-lin                  .
           move      57                   to   v-pos                  .
           move      w-rig-ccr-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuale di limitazio- *
      *    * ne per legame valutario                                   *
      *    *-----------------------------------------------------------*
       acc-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-plm-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-plm-vpl (1)    to   w-sav-plm-vpl          .
       acc-plm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      17                   to   v-lin                  .
           move      74                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
       acc-plm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-plm-vpl (1)      .
       acc-plm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-plm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    =    w-sav-plm-vpl
                     go to acc-plm-vpl-800.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    not  = zero
                     go to acc-plm-vpl-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione tipo di limitazione per le- *
      *                  * geme valutario                              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     move  spaces         to   w-rig-tlm-vpl (1)
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999        .
       acc-plm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-plm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-plm-vpl-100.
       acc-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Percentuale di   *
      *    * limitazione per legame valutario                          *
      *    *-----------------------------------------------------------*
       vis-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to vis-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-plm-vpl-999.
       vis-plm-vpl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      17                   to   v-lin                  .
           move      74                   to   v-pos                  .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Tipo di limitazione per   *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       acc-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su percentuale di limitazione per  *
      *                      * legame valutario                        *
      *                      *-----------------------------------------*
           if        w-rig-plm-vpl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-sav-tlm-vpl          .
       acc-tlm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
       acc-tlm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tlm-vpl-400.
      *                  *---------------------------------------------*
      *                  * Find per note operative                     *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-fnd-tlm-vpl-tlm      .
           perform   fnd-tlm-vpl-000      thru fnd-tlm-vpl-999        .
           move      w-fnd-tlm-vpl-tlm    to   w-rig-tlm-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tlm-vpl-100.
       acc-tlm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     go to acc-tlm-vpl-500.
           if        v-key                =    "UP  "
                     go to acc-tlm-vpl-600
           else      go to acc-tlm-vpl-100.
       acc-tlm-vpl-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = "T" and
                     w-rig-tlm-vpl (1)    not  = "F" and
                     w-rig-tlm-vpl (1)    not  = "M"
                     go to acc-tlm-vpl-100.
       acc-tlm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    =    w-sav-tlm-vpl
                     go to acc-tlm-vpl-800.
       acc-tlm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tlm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-tlm-vpl-100.
       acc-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Tipo di limita-  *
      *    * zione per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to vis-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-tlm-vpl-999.
       vis-tlm-vpl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuali sconto in riga*
      *    *-----------------------------------------------------------*
       acc-per-scr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-per-scr-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-per-scr-ctr      .
       acc-per-scr-100.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   w-sav-per-scr
                                              (w-acc-per-scr-ctr)     .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           if        w-acc-per-scr-ctr    >    5
                     subtract  5          from v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
       acc-per-scr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-per-scr
                                              (1, w-acc-per-scr-ctr)  .
       acc-per-scr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          =    w-sav-per-scr
                                              (w-acc-per-scr-ctr)
                     go to acc-per-scr-700.
       acc-per-scr-620.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-per-scr-640.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-per-scr-660.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-per-scr-660.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-per-scr-660.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-per-scr-680.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-per-scr-700.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione dell'impostazione        *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-scr-710
           else if   v-key                =    "DOWN"
                     go to acc-per-scr-720
           else if   v-key                =    "TAB "
                     go to acc-per-scr-740
           else if   v-key                =    "[1] "
                     go to acc-per-scr-730
           else if   v-key                =    "DO  "
                     go to acc-per-scr-800
           else      go to acc-per-scr-720.
       acc-per-scr-710.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr    =    1
                     go to acc-per-scr-999.
           subtract  1                    from w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-720.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-730.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento prezzo di vendita             *
      *                  *---------------------------------------------*
           move      w-rig-prz-net (1)    to   w-rig-prz-ven (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione prezzo di vendita           *
      *                  *---------------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Visualizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-per-scr-735.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-per-scr-735.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-per-scr-735.
      *                  *---------------------------------------------*
      *                  * Uscita come per Down                        *
      *                  *---------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-740.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr        =    05
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-per-scr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-per-scr-100.
       acc-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di sconto in riga     *
      *    *-----------------------------------------------------------*
       vis-per-scr-000.
           move      zero                 to   w-acc-per-scr-ctr      .
       vis-per-scr-200.
           add       1                    to   w-acc-per-scr-ctr      .
           if        w-acc-per-scr-ctr    >    5
                     go to vis-per-scr-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      w-rig-per-scr 
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-per-scr-200.
       vis-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Importo in riga           *
      *    *-----------------------------------------------------------*
       acc-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-imp-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-imp-rig-999.
       acc-imp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-imp-rig (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-rig (1)      .
       acc-imp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione a meno    *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    not  = zero
                     go to acc-imp-rig-600.
           if        v-key                =    "UP  "
                     go to acc-imp-rig-600
           else      go to acc-imp-rig-100.
       acc-imp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-rig-100.
       acc-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo in riga                   *
      *    *-----------------------------------------------------------*
       vis-imp-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag di significativita'  *
      *    * provvigioni in riga                                       *
      *    *-----------------------------------------------------------*
       acc-fsp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-fsp-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-fsp-rig-999.
           if        w-tes-fsp-doc (1)    not  = 01
                     go to acc-fsp-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-fsp-rig-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-fsp-rig (1)    to    w-sav-fsp-rig         .
      *                  *---------------------------------------------*
      *                  * Eventuale aggiustamento pop-up nel caso di  *
      *                  * righe di tipo 'A' o 'PN'                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio tabella pop-up attuale      *
      *                      *-----------------------------------------*
           move      w-exp-fsp-rig-tbl    to   w-exp-fsp-rig-svt      .
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "A"   ) or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to acc-fsp-rig-050
           else      go to acc-fsp-rig-100.
       acc-fsp-rig-050.
      *                      *-----------------------------------------*
      *                      * Modifica al numero elementi del pop-up  *
      *                      *-----------------------------------------*
           move      02                   to   w-exp-fsp-rig-num      .
      *                      *-----------------------------------------*
      *                      * Spostamento 2. elemento nel 1.          *
      *                      *-----------------------------------------*
           move      w-exp-fsp-rig-ele (2)
                                          to   w-exp-fsp-rig-ele (1)  .
      *                      *-----------------------------------------*
      *                      * Spostamento 3. elemento nel 2.          *
      *                      *-----------------------------------------*
           move      w-exp-fsp-rig-ele (3)
                                          to   w-exp-fsp-rig-ele (2)  .
       acc-fsp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-rig-lun    to   v-car                  .
           move      w-exp-fsp-rig-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-exp-fsp-rig-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
      *                  *---------------------------------------------*
      *                  * Valore di accettazione                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda sel tipo riga      *
      *                      *-----------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "A"   ) or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to acc-fsp-rig-120
           else      go to acc-fsp-rig-140.
       acc-fsp-rig-120.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'A' o 'PN'              *
      *                      *-----------------------------------------*
           if        w-rig-fsp-rig (1)    =    02
                     move  01             to   v-num
           else if   w-rig-fsp-rig (1)    =    03
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           go to     acc-fsp-rig-180.
       acc-fsp-rig-140.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'P'                     *
      *                      *-----------------------------------------*
           move      w-rig-fsp-rig (1)    to   v-num                  .
           go to     acc-fsp-rig-180.
       acc-fsp-rig-180.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fsp-rig-185.
      *              *-------------------------------------------------*
      *              * Ripristino                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino tabella pop-up precedentemente   *
      *                  * salvata                                     *
      *                  *---------------------------------------------*
           move      w-exp-fsp-rig-svt    to   w-exp-fsp-rig-tbl      .
      *                  *---------------------------------------------*
      *                  * Ripristino elementi pop-up a 3              *
      *                  *---------------------------------------------*
           move      03                   to   w-exp-fsp-rig-num      .
       acc-fsp-rig-190.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-fsp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-fsp-rig-999.
       acc-fsp-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo riga          *
      *                  *---------------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "A"   ) or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to acc-fsp-rig-220
           else      go to acc-fsp-rig-240.
       acc-fsp-rig-220.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'A' o 'PN'              *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  02             to   w-rig-fsp-rig (1)
           else if   v-num                =    02
                     move  03             to   w-rig-fsp-rig (1)
           else      move  zero           to   w-rig-fsp-rig (1)      .
           go to     acc-fsp-rig-400.
       acc-fsp-rig-240.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'P'                     *
      *                      *-----------------------------------------*
           move      v-num                to   w-rig-fsp-rig (1)      .
           go to     acc-fsp-rig-400.
       acc-fsp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    not  = zero
                     go to acc-fsp-rig-500.
           if        v-key                =    "UP  "
                     go to acc-fsp-rig-600
           else      go to acc-fsp-rig-100.
       acc-fsp-rig-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    not  = 01 and
                     w-rig-fsp-rig (1)    not  = 02 and
                     w-rig-fsp-rig (1)    not  = 03
                     go to acc-fsp-rig-100.
       acc-fsp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    =    w-sav-fsp-rig
                     go to acc-fsp-rig-800.
      *                  *---------------------------------------------*
      *                  * Trattamento percentuali di provvigione in   *
      *                  * riga                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore at-   *
      *                      * tuale                                   *
      *                      *-----------------------------------------*
           if        w-rig-fsp-rig (1)    =    01
                     go to acc-fsp-rig-602
           else if   w-rig-fsp-rig (1)    =    02
                     go to acc-fsp-rig-604
           else if   w-rig-fsp-rig (1)    =    03
                     go to acc-fsp-rig-606
           else      go to acc-fsp-rig-610.
       acc-fsp-rig-602.
      *                      *-----------------------------------------*
      *                      * Se valore attuale : Si                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione provvigioni in riga  *
      *                          *-------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione provvigioni in riga *
      *                          *-------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-fsp-rig-610.
       acc-fsp-rig-604.
      *                      *-----------------------------------------*
      *                      * Se valore attuale : No                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione percentuali         *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-fsp-rig-610.
       acc-fsp-rig-606.
      *                      *-----------------------------------------*
      *                      * Se valore attuale : Speciali            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-fsp-rig-610.
       acc-fsp-rig-610.
      *                  *---------------------------------------------*
      *                  * Trattamento importo provvigioni a forfait   *
      *                  * per la riga                                 *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    =    03
                     go to acc-fsp-rig-800.
           if        w-rig-pvf-rig (1)    =    zero
                     go to acc-fsp-rig-800.
           move      zero                 to   w-rig-pvf-rig (1)      .
           perform   vis-pvf-rig-000      thru vis-pvf-rig-999        .
       acc-fsp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-fsp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-fsp-rig-100.
       acc-fsp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Flag di significativi- *
      *    * ta' provvigioni in riga                                   *
      *    *-----------------------------------------------------------*
       vis-fsp-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-fsp-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-fsp-rig-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-rig-lun    to   v-car                  .
           move      w-exp-fsp-rig-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-exp-fsp-rig-tbl    to   v-txt                  .
           move      w-rig-fsp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fsp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuali di provvigio- *
      *    *                                 ne in riga                *
      *    *-----------------------------------------------------------*
       acc-ppv-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-ppv-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-ppv-rig-999.
           if        w-tes-fsp-doc (1)    not  = 01
                     go to acc-ppv-rig-999.
           if        w-rig-fsp-rig (1)    not  = 03
                     go to acc-ppv-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ppv-rig-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..03           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-ppv-rig-ctr      .
       acc-ppv-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           if        w-acc-ppv-rig-ctr    =    1
                     move  66             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    2
                     move  71             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    3
                     move  76             to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      w-rig-ppv-rig
                    (1, w-acc-ppv-rig-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ppv-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ppv-rig-999.
       acc-ppv-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ppv-rig
                                              (1, w-acc-ppv-rig-ctr)  .
       acc-ppv-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ppv-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento provvigione a forfait in riga   *
      *                  *---------------------------------------------*
           if        w-rig-ppv-rig
                    (1, w-acc-ppv-rig-ctr)
                                          =    zero
                     go to acc-ppv-rig-620.
           if        w-rig-pvf-rig (1)    =    zero
                     go to acc-ppv-rig-620.
           move      zero                 to   w-rig-pvf-rig (1)      .
           perform   vis-pvf-rig-000      thru vis-pvf-rig-999        .
       acc-ppv-rig-620.
      *                  *---------------------------------------------*
      *                  * Trattamento sequenza di impostazione        *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-ppv-rig-650
           else if   v-key                =    "DOWN"
                     go to acc-ppv-rig-700
           else if   v-key                =    "TAB "
                     go to acc-ppv-rig-710
           else if   v-key                =    "DO  "
                     go to acc-ppv-rig-800
           else      go to acc-ppv-rig-700.
       acc-ppv-rig-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-ppv-rig-ctr    =    1
                     go to acc-ppv-rig-999.
           subtract  1                    from w-acc-ppv-rig-ctr      .
           go to     acc-ppv-rig-100.
       acc-ppv-rig-700.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-ppv-rig-999.
       acc-ppv-rig-710.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-ppv-rig-ctr        =    03
                     go to acc-ppv-rig-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-ppv-rig-ctr      .
           go to     acc-ppv-rig-100.
       acc-ppv-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ppv-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ppv-rig-100.
       acc-ppv-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di provvigione in ri- *
      *    *                         ga                                *
      *    *-----------------------------------------------------------*
       vis-ppv-rig-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-ppv-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-ppv-rig-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-acc-ppv-rig-ctr      .
       vis-ppv-rig-200.
           add       1                    to   w-acc-ppv-rig-ctr      .
           if        w-acc-ppv-rig-ctr    >    3
                     go to vis-ppv-rig-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           if        w-acc-ppv-rig-ctr    =    1
                     move  66             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    2
                     move  71             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    3
                     move  76             to   v-pos                  .
           move      w-rig-ppv-rig 
                    (1, w-acc-ppv-rig-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-ppv-rig-200.
       vis-ppv-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Provvigioni a forfait in  *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       acc-pvf-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-pvf-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-pvf-rig-999.
           if        w-tes-fsp-doc (1)    not  = 01
                     go to acc-pvf-rig-999.
           if        w-rig-fsp-rig (1)    not  = 03
                     go to acc-pvf-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-pvf-rig-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-pvf-rig (1)    to    w-sav-pvf-rig         .
       acc-pvf-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-pvf-rig (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-pvf-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-pvf-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-pvf-rig (1)      .
       acc-pvf-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pvf-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-pvf-rig (1)    =    w-sav-pvf-rig
                     go to acc-pvf-rig-800.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-pvf-rig (1)    =    zero
                     go to acc-pvf-rig-800.
      *                  *---------------------------------------------*
      *                  * Trattamento percentuali di provvigione in   *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           if        w-rig-ppv-rig (1, 1) =    zero and
                     w-rig-ppv-rig (1, 2) =    zero and
                     w-rig-ppv-rig (1, 3) =    zero
                     go to acc-pvf-rig-800.
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-pvf-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-pvf-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-pvf-rig-100.
       acc-pvf-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Provvigioni a forfait in riga     *
      *    *-----------------------------------------------------------*
       vis-pvf-rig-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-pvf-rig-999.
           if        w-tes-tip-arc (1)    not  = "C"
                     go to vis-pvf-rig-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-rig-pvf-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pvf-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice iva                *
      *    *-----------------------------------------------------------*
       acc-coi-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-coi-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-coi-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-coi-rig-100.
       acc-coi-rig-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      20                   to   w-cod-mne-zci-lin      .
           move      21                   to   w-cod-mne-zci-pos      .
           move      20                   to   w-cod-mne-zci-dln      .
           move      32                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-civ-rig-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-civ-rig-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-civ-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-civ-rig-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-civ-rig-110.
       acc-civ-rig-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-coi-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-coi-rig-999.
       acc-coi-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-coi-rig (1)      .
       acc-coi-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   d-imp-iva-cod-iva      .
           move      "1"                  to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Se errore : messaggio e reimpostazione      *
      *                  *---------------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-coi-rig-500.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-coi-rig-100.
       acc-coi-rig-500.
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-ctl-coi-rig-des    to   w-rig-coi-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-cir-000      thru vis-des-cir-999        .
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero : reimpostazione a meno*
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-rig-coi-rig (1)    not  = zero
                     go to acc-coi-rig-600.
           if        v-key                =    "UP  "
                     go to acc-coi-rig-600
           else      go to acc-coi-rig-100.
       acc-coi-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-coi-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-coi-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-coi-rig-100.
       acc-coi-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice iva                *
      *    *-----------------------------------------------------------*
       vis-coi-rig-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-coi-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione codice IVA    *
      *    *-----------------------------------------------------------*
       vis-des-cir-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           if        w-edt-iva-cod-003    =    zero
                     go to vis-des-cir-999.
       vis-des-cir-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-coi-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cir-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice contropartita      *
      *    *-----------------------------------------------------------*
       acc-ctv-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa l'archi- *
      *                      * vio Clienti : uscita                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-ctv-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ctv-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ctv-rig-100.
           if        w-tes-ctp-ven (1)    not  = zero
                     go to acc-ctv-rig-999.
       acc-ctv-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rig-ctv-rig (1)    to   w-cod-mne-pdc-cod      .
           move      21                   to   w-cod-mne-pdc-lin      .
           move      21                   to   w-cod-mne-pdc-pos      .
           move      21                   to   w-cod-mne-pdc-dln      .
           move      32                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctv-rig-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctv-rig-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctv-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctv-rig-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctv-rig-110.
       acc-ctv-rig-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ctv-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ctv-rig-999.
       acc-ctv-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ctv-rig (1)      .
       acc-ctv-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctv-rig-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-ctv-rig (1)    =    zero
                     go to acc-ctv-rig-100.
       acc-ctv-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctv-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ctv-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ctv-rig-100.
       acc-ctv-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita vendite in  *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       vis-ctv-rig-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rig-ctv-rig (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctv-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione contropartita *
      *    * vendite in riga                                           *
      *    *-----------------------------------------------------------*
       vis-des-cvr-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-ctv-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cvr-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo di vendita                          *
      *    *-----------------------------------------------------------*
       det-prz-ven-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri                          *
      *              *-------------------------------------------------*
           move      "PV"                 to   d-prz-ven-tip-ope      .
      *
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-prz-ven-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-prz-ven-cod-cli      .
      *
           move      w-rig-sgl-vpp (1)    to   d-prz-ven-sgl-vpp      .
           move      w-rig-dec-vpp (1)    to   d-prz-ven-dec-vpp      .
           move      w-rig-num-pro (1)    to   d-prz-ven-num-pro      .
           move      w-tes-cod-lst (1)    to   d-prz-ven-cod-lst      .
           move      w-let-dcp-pdx-plb    to   d-prz-ven-prz-lsb      .
           move      w-let-dcp-pdx-vlb    to   d-prz-ven-sgl-vlb      .
           move      w-let-dcp-pdx-dlb    to   d-prz-ven-dec-vlb      .
           move      spaces               to   d-prz-ven-tfu-prz      .
           move      w-tes-dat-doc        to   d-prz-ven-dat-rfp      .
           move      w-rig-qta-ven (1)    to   d-prz-ven-qta-rif      .
      *              *-------------------------------------------------*
      *              * Richiamo del sottoprogramma                     *
      *              *-------------------------------------------------*
           move      "pgm/fat/prg/obj/dprzven0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-prz-ven              .
      *              *-------------------------------------------------*
      *              * Memorizzazione valore determinato               *
      *              *-------------------------------------------------*
           move      d-prz-ven-prz-ven    to   w-rig-prz-ven (1)      .
       det-prz-ven-999.
           exit.

