                     go to prn-liv-det-999.
       prn-liv-det-200.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Quantita' etichette                             *
      *              *                                                 *
      *              * N.B.: la posizione di stampa dei campi deve es- *
      *              *       sere riportata esattamente nei parametri  *
      *              *       relativi                                  *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-rig-qta-eti        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Codice prodotto                                 *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-prm-pst-chm-lfl (1)
                                          to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-prm-pst-chm-pfl (1)
                                          to   p-pos                  .
           move      w-rig-alf-mag        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Descrizione prodotto                            *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-prm-pst-chm-lfl (2)
                                          to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-prm-pst-chm-pfl (2)
                                          to   p-pos                  .
           move      w-rig-des-rig        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Codice articolo per il cliente                  *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-prm-pst-chm-lfl (3)
                                          to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-prm-pst-chm-pfl (3)
                                          to   p-pos                  .
           move      w-rig-cop-scl        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Quantita' in riga per etichetta                 *
      *              *                                                 *
      *              * (Quantita' in riga / quantita' etichette)       *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      03                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BGD"                to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      w-prm-pst-chm-pfl (4)
                                          to   p-pos                  .
           move      w-rig-qta-ven        to   p-num                  .
           divide    w-rig-qta-eti        into p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
