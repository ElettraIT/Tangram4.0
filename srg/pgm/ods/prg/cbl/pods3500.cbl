           move      04                   to   w-cod-des-zsc-dln      .
           move      24                   to   w-cod-des-zsc-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-zsc-cll-000  thru cod-des-zsc-cll-999    .
