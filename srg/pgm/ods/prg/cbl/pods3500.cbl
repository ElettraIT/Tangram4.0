           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-rig-dec-qta        to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BGD"                to   v-edm                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-rig-qta-ven        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-ven-999.
           exit.

