           move      "NUMPRT    "         to   f-key                  .
           move      srt-prt-key          to   rf-osr-num-prt         .
           move      srt-prg-key          to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-out-800.
       rou-let-reg-out-400.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave riga corpo      *
      *              *-------------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
       rou-let-reg-out-600.
      *              *-------------------------------------------------*
      *              * Composizione area w-rig                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valori contenuti direttamente in record     *
      *                  * [osr]                                       *
      *                  *---------------------------------------------*
           move      rf-osr-num-prg       to   w-rig-num-prg          .
           move      rf-osr-tip-rig       to   w-rig-tip-rig          .
           move      rf-osr-tip-rig (1:1) to   w-rig-tip-rig-tpr      .
           move      rf-osr-tip-rig (2:1) to   w-rig-tip-rig-tfu      .
           move      rf-osr-tip-mag       to   w-rig-tip-mag          .
           move      rf-osr-num-pro       to   w-rig-num-mag          .
           move      rf-osr-alf-pro       to   w-rig-alf-mag          .
           move      rf-osr-cop-scl       to   w-rig-cop-scl          .
           move      rf-osr-des-rig       to   w-rig-des-rig          .
           move      rf-osr-dec-qta       to   w-rig-dec-qta          .
           move      rf-osr-qta-ven       to   w-rig-qta-ven          .
           move      rf-osr-ocl-dat       to   w-rig-ocl-dat          .
           move      rf-osr-ocl-num       to   w-rig-ocl-num          .
       rou-let-reg-out-605.
      *                  *---------------------------------------------*
      *                  * Valori contenuti indirettamente in record   *
      *                  * [osr]                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione                             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura preliminare file [osx]      *
      *                          *-------------------------------------*
           move      w-tes-num-prt        to   w-let-arc-osx-prt      .
           move      w-rig-num-prg        to   w-let-arc-osx-prg      .
           move      11                   to   w-let-arc-osx-trc      .
           perform   let-arc-osx-000      thru let-arc-osx-999        .
      *
           if        w-let-arc-osx-flg    not  = spaces
                     go to rou-let-reg-out-609.
      *
           move      w-let-arc-osx-des    to   w-rig-des-rig          .
      *
           go to     rou-let-reg-out-640.
       rou-let-reg-out-609.
      *                          *-------------------------------------*
      *                          * Descrizione : deviazione in funzio- *
      *                          * ne del tipo di estensione           *
      *                          *-------------------------------------*
           if        rf-osr-des-ext       =    0
                     go to rou-let-reg-out-610
           else if   rf-osr-des-ext       =    1
                     go to rou-let-reg-out-620
           else if   rf-osr-des-ext       =    2
                     go to rou-let-reg-out-630.
       rou-let-reg-out-610.
      *                              *---------------------------------*
      *                              * Se nessuna estensione : nessuna *
      *                              * azione in quanto la descrizione *
      *                              * e' gia' stata bufferizzata      *
      *                              *---------------------------------*
           go to     rou-let-reg-out-640.
       rou-let-reg-out-620.
      *                              *---------------------------------*
      *                              * Se estensione nel file [osx]    *
      *                              *---------------------------------*
           go to     rou-let-reg-out-640.
       rou-let-reg-out-630.
      *                              *---------------------------------*
      *                              * Se estensione nel file [pdx]    *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Lettura archivio [dcp]      *
      *                                  *-----------------------------*
           move      w-rig-num-mag        to   w-let-arc-dcp-num      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           move      w-let-arc-dcp-des    to   w-rig-des-rig          .
           go to     rou-let-reg-out-640.
       rou-let-reg-out-640.
      *                          *-------------------------------------*
      *                          * Lotto di vendita                    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Lettura archivio [dcp]          *
      *                              *---------------------------------*
           move      w-rig-num-mag        to   w-let-arc-dcp-num      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           move      w-let-arc-dcp-ldv    to   w-rig-qta-ldv          .
       rou-let-reg-out-650.
      *                          *-------------------------------------*
      *                          * Default quantita' etichette         *
      *                          *-------------------------------------*
           move      rf-osr-qta-ven       to   w-rig-qta-eti          .
      *                              *---------------------------------*
      *                              * Eventuale suddivisione per il   *
      *                              * lotto di vendita                *
      *                              *---------------------------------*
           if        w-rig-qta-eti        =    zero
                     go to rou-let-reg-out-700.
           if        w-rig-qta-ldv        =    zero
                     go to rou-let-reg-out-700.
      *
           move      w-rig-qta-eti        to   w-det-qta-eti-ven      .
           divide    w-rig-qta-ldv        into w-det-qta-eti-ven
                                        giving w-det-qta-eti-eti
                                     remainder w-det-qta-eti-wq0      .
           if        w-det-qta-eti-wq0    >    zero
                     add  1               to   w-det-qta-eti-eti      .
           move      w-det-qta-eti-eti    to   w-rig-qta-eti          .
       rou-let-reg-out-700.
      *              *-------------------------------------------------*
      *              * Put su file relative di appoggio                *
      *              *-------------------------------------------------*
           move      "PT"                 to   w-rlt-sup-ope          .
           move      w-rig                to   w-rlt-sup-buf          .
           perform   cll-rlt-sup-000      thru cll-rlt-sup-999        .
       rou-let-reg-out-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura record da sort               *
      *              *-------------------------------------------------*
           go to     rou-let-reg-out-200.
       rou-let-reg-out-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-let-reg-out-999.
       rou-let-reg-out-999.
           exit.

      *    *===========================================================*
