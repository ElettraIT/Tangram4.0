       vis-qta-eti-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      48                   to   v-pos                  .
           move      w-rig-qta-eti        to   v-num                  .
