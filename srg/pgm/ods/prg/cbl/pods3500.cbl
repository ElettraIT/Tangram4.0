           move      "A"                  to   p-tip                  .
           move      w-prm-pst-chm-lfl (6)
                                          to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-prm-pst-chm-pfl (6)
                                          to   p-pos                  .
           move      rf-aaq-cdp-pdt       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-500.
