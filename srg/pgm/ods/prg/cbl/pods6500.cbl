           move      "cod-tms"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-arc-ost-sel
                     go to fnd-arc-ost-999.
           move      s-alf                to   w-fnd-arc-ost-tms      .
      *                  *---------------------------------------------*
