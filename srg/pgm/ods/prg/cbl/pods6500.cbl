           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      74                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Carattere accettato                             *
      *              *-------------------------------------------------*
           move      v-alf                to   w-ctl-rig-doc-cud      .
      *              *-------------------------------------------------*
      *              * Test su carattere accettato                     *
      *              *-------------------------------------------------*
           if        v-alf                not  = "V" and
                     v-alf                not  = "v" and
                     v-alf                not  = "C" and
                     v-alf                not  = "c"
                     go to box-msg-es2-200.
       box-msg-es2-900.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-es2-999.
           exit.

