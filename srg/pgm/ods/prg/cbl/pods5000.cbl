           move      rf-ost-dpz-arc       to   w-let-arc-ost-dcl      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-ost-999.
       let-arc-ost-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-ost-flg      .
           go to     let-arc-ost-600.
       let-arc-ost-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
       let-arc-ost-600.
           move      zero                 to   w-let-arc-ost-cli      .
           move      spaces               to   w-let-arc-ost-dcl      .
       let-arc-ost-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [dcp] e [pdx]                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcp/prg/cpy/ldcppdx0.lts"                   .

      *    *===========================================================*
      *    * Routine di lettura archivio [osx]                         *
      *    *-----------------------------------------------------------*
       let-arc-osx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-osx-flg      .
      *              *-------------------------------------------------*
      *              * Test se codici nulli                            *
      *              *-------------------------------------------------*
           if        w-let-arc-osx-prt    =    zero   or
                     w-let-arc-osx-prg    =    zero   or
                     w-let-arc-osx-trc    =    zero
                     go to let-arc-osx-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-let-arc-osx-prt    to   rf-osx-num-prt         .
           move      w-let-arc-osx-prg    to   rf-osx-num-prg         .
           move      w-let-arc-osx-trc    to   rf-osx-tip-rec         .
           move      "pgm/ods/fls/ioc/obj/iofosx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osx                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-osx-400.
       let-arc-osx-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-osx-des-400       to   w-let-arc-osx-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-osx-999.
       let-arc-osx-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-osx-flg      .
           move      spaces               to   w-let-arc-osx-des      .
           move      all   "."            to   w-let-arc-osx-drg (1)  .
           go to     let-arc-osx-999.
       let-arc-osx-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-osx-des      .
       let-arc-osx-999.
           exit.

      *    *===========================================================*
      *    * Saldaconto per evasione righe ordine cliente              *
      *    *-----------------------------------------------------------*
       acc-fun-sdc-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero massimo pagine            *
      *              *-------------------------------------------------*
           move      w-bro-num-ele        to   w-sdc-npg-max          .
           divide    w-sdc-num-lpp        into w-sdc-npg-max
                                        giving w-sdc-npg-max
                                     remainder w-sdc-wrk-rem          .
           if        w-sdc-wrk-rem        >    zero
                     add    1             to   w-sdc-npg-max          .
      *              *-------------------------------------------------*
      *              * Numero pagina visualizzata                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-sdc-npg-vis          .
      *              *-------------------------------------------------*
      *              * Numero riga da trattare                         *
      *              *                                                 *
      *              * Se il flag di rientro all'ultima riga per la    *
      *              * funzione di saldaconto e' in on : si esegue un  *
      *              * Back simulato e si pone il flag in off          *
      *              *-------------------------------------------------*
           if        w-sdc-fdr-aur        not  = spaces
                     move  spaces         to   w-sdc-fdr-aur
                     move   w-bro-num-ele to   w-sdc-ctr-rig
                     go to  acc-fun-sdc-300.
      *
           move      zero                 to   w-sdc-ctr-rig          .
       acc-fun-sdc-200.
           add       1                    to   w-sdc-ctr-rig          .
           if        w-sdc-ctr-rig        >    w-bro-num-ele
                     move  "DOWN"         to   v-key
                     go to  acc-fun-sdc-999.
       acc-fun-sdc-300.
      *              *-------------------------------------------------*
      *              * Determinazione numero pagina da trattare        *
      *              *-------------------------------------------------*
           divide    w-sdc-num-lpp        into w-sdc-ctr-rig
                                        giving w-sdc-npg-dat
                                     remainder w-sdc-wrk-rem          .
           if        w-sdc-wrk-rem        >    zero
                     add    1             to   w-sdc-npg-dat          .
      *              *-------------------------------------------------*
      *              * Visualizzazione pagina da trattare              *
      *              *-------------------------------------------------*
           if        w-sdc-npg-dat        not  = w-sdc-npg-vis
                     perform vis-pag-sdc-000
                                          thru vis-pag-sdc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione numero linea                     *
      *              *-------------------------------------------------*
           subtract  1                    from w-sdc-npg-dat
                                        giving w-sdc-wrk-rig          .
           multiply  w-sdc-num-lpp        by   w-sdc-wrk-rig          .
           subtract  w-sdc-wrk-rig        from w-sdc-ctr-rig
                                        giving w-sdc-wrk-lin          .
           add       8                    to   w-sdc-wrk-lin          .
       acc-fun-sdc-400.
      *              *-------------------------------------------------*
      *              * Accettazione riga saldaconto                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Quantita' assegnata                         *
      *                  *---------------------------------------------*
           perform   acc-qta-ass-000      thru acc-qta-ass-999        .
      *                  *---------------------------------------------*
      *                  * Test su tipo uscita                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Do                                   *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  "
                     move  "S"            to   w-cnt-tus-acc-tes
                     go to acc-fun-sdc-999.
      *                      *-----------------------------------------*
      *                      * Se Exit                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fun-sdc-999.
      *                      *-----------------------------------------*
      *                      * Se Delt                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fun-sdc-999.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-fun-sdc-450.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DOWN"
                     go to  acc-fun-sdc-200.
      *                      *-----------------------------------------*
      *                      * Se Next Screen                          *
      *                      *-----------------------------------------*
           if        v-key                not  = "NXSC"
                     go to  acc-fun-sdc-500.
           if        w-sdc-npg-dat        =    w-sdc-npg-max
                     go to  acc-fun-sdc-999.
           multiply  w-sdc-num-lpp        by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           add       1                    to   w-sdc-ctr-rig          .
           go to     acc-fun-sdc-300.
       acc-fun-sdc-450.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        w-sdc-ctr-rig        >    1
                     subtract  1          from w-sdc-ctr-rig
                     go to     acc-fun-sdc-300
           else      go to     acc-fun-sdc-999.
       acc-fun-sdc-500.
      *                      *-----------------------------------------*
      *                      * Se Prev Screen                          *
      *                      *-----------------------------------------*
           if        v-key                not  = "PRSC"
                     go to  acc-fun-sdc-600.
           subtract  1                    from w-sdc-npg-dat          .
           if        w-sdc-npg-dat        =    zero
                     go to  acc-fun-sdc-999.
           multiply  w-sdc-num-lpp        by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           subtract  w-sdc-num-lpp        from w-sdc-ctr-rig          .
           add       1                    to   w-sdc-ctr-rig          .
           go to     acc-fun-sdc-300.
       acc-fun-sdc-600.
      *                      *-----------------------------------------*
      *                      * Se Tab                                  *
      *                      *-----------------------------------------*
           if        v-key                =    "TAB "
                     move   w-bro-num-ele to   w-sdc-ctr-rig
                     go to  acc-fun-sdc-300.
      *                      *-----------------------------------------*
      *                      * Se Back                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "BACK"
                     move   1             to   w-sdc-ctr-rig
                     go to  acc-fun-sdc-300.
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     acc-fun-sdc-200.
       acc-fun-sdc-999.
           exit.

      *    *===========================================================*
      *    * Prompt : Funzione saldaconto                              *
      *    *-----------------------------------------------------------*
       pmt-fun-sdc-000.
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-fun-sdc-200.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      07                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-fun-sdc-300.
      *              *-------------------------------------------------*
      *              * Linea di fincatura                              *
      *              *-------------------------------------------------*
           if        w-prs-rig-scr-des    =    01
                     move  "       Descrizione            Codice    "
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    02
                     move  "     Descrizione            Codice      "
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    03
                     move  "    Codice            Descrizione       "
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    04
                     move  "      Codice            Descrizione     "
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    05
                     move  "       Descrizione            Codice    "
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    06
                     move  "     Descrizione            Codice      "
                                          to   w-pmt-sdc-asx
           else      move  "               Descrizione              "
                                          to   w-pmt-sdc-asx          .
      *
           move      "|Da assegnare|  Assegnato  |   Residuo  "
                                          to   w-pmt-sdc-adx          .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-pmt-sdc            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-fun-sdc-400.
      *              *-------------------------------------------------*
      *              * Linea di sottolineatura fincatura               *
      *              *-------------------------------------------------*
           if        w-prs-rig-scr-des    =    01
                     move  "------------------------- --------------"
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    02
                     move  "--------------------- ------------------"
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    03
                     move  "-------------- -------------------------"
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    04
                     move  "------------------ ---------------------"
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    05
                     move  "------------------------- --------------"
                                          to   w-pmt-sdc-asx
           else if   w-prs-rig-scr-des    =    06
                     move  "--------------------- ------------------"
                                          to   w-pmt-sdc-asx
           else      move  "----------------------------------------"
                                          to   w-pmt-sdc-asx          .
      *
           move      "|------------|-------------|------------"
                                          to   w-pmt-sdc-adx          .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-pmt-sdc            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-fun-sdc-500.
      *              *-------------------------------------------------*
      *              * Colonne per saldaconto                          *
      *              *-------------------------------------------------*
           move      zero                 to   w-sdc-wrk-c01          .
       pmt-fun-sdc-510.
           add       1                    to   w-sdc-wrk-c01          .
           if        w-sdc-wrk-c01        >    w-sdc-num-lpp
                     go to pmt-fun-sdc-900.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       8
                     w-sdc-wrk-c01      giving v-lin                  .
           move      01                   to   v-pos                  .
           move      "                                        |         
      -              "   |             |            "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     pmt-fun-sdc-510.
       pmt-fun-sdc-900.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-fun-sdc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione pagina saldaconto                         *
      *    *-----------------------------------------------------------*
       vis-pag-sdc-000.
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           perform   pmt-fun-sdc-000      thru pmt-fun-sdc-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento numero pagina visualizzata        *
      *              *-------------------------------------------------*
           move      w-sdc-npg-dat        to   w-sdc-npg-vis          .
      *              *-------------------------------------------------*
      *              * Determinazione contatore righe iniziale         *
      *              *-------------------------------------------------*
           multiply  w-sdc-num-lpp        by   w-sdc-npg-dat
                                      giving   w-sdc-wrk-rig          .
           subtract  w-sdc-num-lpp        from w-sdc-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Ciclo di visualizzazione                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-sdc-wrk-c01          .
       vis-pag-sdc-100.
           add       1                    to   w-sdc-wrk-c01          .
           if        w-sdc-wrk-c01        >    w-sdc-num-lpp
                     go to  vis-pag-sdc-900.
           add       1                    to   w-sdc-wrk-rig          .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che sia una riga vuo-  *
      *                  * ta o piena                                  *
      *                  *---------------------------------------------*
           if        w-sdc-wrk-rig        >    w-bro-num-ele
                     go to vis-pag-sdc-200
           else      go to vis-pag-sdc-300.
       vis-pag-sdc-200.
      *                  *---------------------------------------------*
      *                  * Se riga vuota                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       8
                     w-sdc-wrk-c01      giving v-lin                  .
           move      01                   to   v-pos                  .
           move      "                                        |         
      -              "   |             |            "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     vis-pag-sdc-100.
       vis-pag-sdc-300.
      *                  *---------------------------------------------*
      *                  * Visualizzazione riga piena                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione                             *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           add       8
                     w-sdc-wrk-c01      giving v-lin                  .
           move      01                   to   v-pos                  .
           move      w-bro-des-rgs
                    (w-sdc-wrk-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Quantita' da assegnare                  *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       8
                     w-sdc-wrk-c01      giving v-lin                  .
           move      42                   to   v-pos                  .
           move      w-bro-qta-das
                    (w-sdc-wrk-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Quantita' assegnata                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       8
                     w-sdc-wrk-c01      giving v-lin                  .
           move      56                   to   v-pos                  .
           move      w-bro-qta-ass
                    (w-sdc-wrk-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Quantita' residua                       *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       8
                     w-sdc-wrk-c01      giving v-lin                  .
           move      70                   to   v-pos                  .
           move      w-bro-qta-das
                    (w-sdc-wrk-rig)       to   v-num                  .
           subtract  w-bro-qta-ass
                    (w-sdc-wrk-rig)       from v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-sdc-400.
      *                      *-----------------------------------------*
      *                      * Riciclo su riga successiva              *
      *                      *-----------------------------------------*
           go to     vis-pag-sdc-100.
       vis-pag-sdc-900.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-sdc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo saldaconto : Quantita' assegnata       *
      *    *-----------------------------------------------------------*
       acc-qta-ass-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-bro-qta-ass
                    (w-sdc-ctr-rig)       to   w-sav-qta-ass          .
       acc-qta-ass-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-bro-dec-qta
                    (w-sdc-ctr-rig)       to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (06)             .
           move      "PRSC"               to   v-pfk (07)             .
           if        w-sdc-ctr-rig        <    w-bro-num-ele
                     move   "TAB "        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
           move      "SLCT"               to   v-pfk (10)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-bro-qta-ass
                    (w-sdc-ctr-rig)       to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     go to acc-qta-ass-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     go to acc-qta-ass-999.
       acc-qta-ass-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-bro-qta-ass
                                              (w-sdc-ctr-rig)         .
       acc-qta-ass-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo che la quantita' da assegnare non *
      *                  * superi la quantita' da spedire              *
      *                  *---------------------------------------------*
           if        w-bro-qta-das
                    (w-sdc-ctr-rig)       >    zero and
                     w-bro-qta-ass
                    (w-sdc-ctr-rig)       >    w-bro-qta-das
                                              (w-sdc-ctr-rig)
                     go to acc-qta-ass-100
           else if   w-bro-qta-das
                    (w-sdc-ctr-rig)       <    zero and
                     w-bro-qta-ass
                    (w-sdc-ctr-rig)       <    w-bro-qta-das
                                              (w-sdc-ctr-rig)
                     go to acc-qta-ass-100.
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' fra segno quantita'*
      *                  * da spedire e segno quantita' da assegnare   *
      *                  *---------------------------------------------*
           if        w-bro-qta-das
                    (w-sdc-ctr-rig)       >    zero and
                     w-bro-qta-ass
                    (w-sdc-ctr-rig)       <    zero
                     go to acc-qta-ass-100
           else if   w-bro-qta-das
                    (w-sdc-ctr-rig)       <    zero and
                     w-bro-qta-ass
                    (w-sdc-ctr-rig)       >    zero
                     go to acc-qta-ass-100.
       acc-qta-ass-420.
      *                  *---------------------------------------------*
      *                  * Se Slct : controllo che il valore impostato *
      *                  * sia uguale al precedente                    *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-qta-ass-600.
           if        w-bro-qta-ass
                    (w-sdc-ctr-rig)       not  = w-sav-qta-ass
                     move   w-sav-qta-ass to   w-bro-qta-ass
                                              (w-sdc-ctr-rig)
                     go to  acc-qta-ass-100.
       acc-qta-ass-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Quantita' da assegnare e quantita' assegna- *
      *                  * ta in work di comodo senza segno            *
      *                  *---------------------------------------------*
           move      w-bro-qta-das
                    (w-sdc-ctr-rig)       to   w-qss-qta-das          .
           move      w-bro-qta-ass
                    (w-sdc-ctr-rig)       to   w-qss-qta-ass          .
      *                  *---------------------------------------------*
      *                  * Se Slct                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to  acc-qta-ass-700.
      *                      *-----------------------------------------*
      *                      * Se valore gia' presente                 *
      *                      *-----------------------------------------*
           if        w-bro-qta-ass
                    (w-sdc-ctr-rig)       =    zero
                     go to acc-qta-ass-610.
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           move      zero                 to   w-bro-qta-ass
                                              (w-sdc-ctr-rig)         .
           move      zero                 to   w-qss-qta-ass          .
           go to     acc-qta-ass-700.
       acc-qta-ass-610.
      *                      *-----------------------------------------*
      *                      * Se valore non presente                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           move      w-bro-qta-das
                    (w-sdc-ctr-rig)       to   w-bro-qta-ass
                                              (w-sdc-ctr-rig)         .
           move      w-bro-qta-das
                    (w-sdc-ctr-rig)       to   w-qss-qta-ass          .
           go to     acc-qta-ass-700.
       acc-qta-ass-700.
      *                  *---------------------------------------------*
      *                  * Visualizzazione valori riga                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Quantita' assegnata                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      56                   to   v-pos                  .
           move      w-bro-qta-ass
                    (w-sdc-ctr-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Quantita' residua                       *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      70                   to   v-pos                  .
           move      w-bro-qta-das
                    (w-sdc-ctr-rig)       to   v-num                  .
           subtract  w-bro-qta-ass
                    (w-sdc-ctr-rig)       from v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-qta-ass-800.
      *                  *---------------------------------------------*
