           move      w-tes-num-prt-prg    to   w-acc-num-prt-prg      .
       acc-num-prt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      04                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-acc-num-prt-num    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
       acc-num-prt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in work per accettazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-acc-num-prt-num      .
      *              *-------------------------------------------------*
      *              * Work per accettazione in campo di destinazione  *
      *              *-------------------------------------------------*
           if        w-acc-num-prt-num    =    zero
                     go to acc-num-prt-300.
           move      w-acc-num-prt-saa    to   w-tes-num-prt-saa      .
           move      w-tes-cod-dpz        to   w-tes-num-prt-dpz      .
           move      w-acc-num-prt-prg    to   w-tes-num-prt-prg      .
       acc-num-prt-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-prt-400.
      *                  *---------------------------------------------*
      *                  * Find su archivio [ost]                      *
      *                  *---------------------------------------------*
           perform   fnd-arc-ost-000      thru fnd-arc-ost-999        .
           if        w-fnd-arc-ost-sel    not  = spaces
                     go to acc-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Protocollo letto                            *
      *                  *---------------------------------------------*
           move      w-fnd-arc-ost-prt    to   w-tes-num-prt          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione protocollo letto            *
      *                  *---------------------------------------------*
           perform   vis-num-prt-000      thru vis-num-prt-999        .
       acc-num-prt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [ost]                        *
      *                  *---------------------------------------------*
           move      w-tes-num-prt        to   w-let-arc-ost-prt      .
           perform   let-arc-ost-000      thru let-arc-ost-999        .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc]                        *
      *                  *---------------------------------------------*
           move      w-let-arc-ost-cli    to   w-let-arc-dcc-cli      .
           move      w-let-arc-ost-dcl    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione ragione sociale              *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-num-prt-rcl      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione ragione sociale cliente     *
      *                  *---------------------------------------------*
           perform   vis-num-prt-rcl-000  thru vis-num-prt-rcl-999    .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita                      *
      *                  *---------------------------------------------*
           if        w-let-arc-ost-flg    not  = spaces
                     go to acc-num-prt-100.
       acc-num-prt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento valore di default generale    *
      *                  * per il numero protocollo                    *
      *                  *---------------------------------------------*
           move      w-tes-num-prt        to   w-def-num-prt          .
       acc-num-prt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-num-prt-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-num-prt-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
       acc-num-prt-999.
           exit.

