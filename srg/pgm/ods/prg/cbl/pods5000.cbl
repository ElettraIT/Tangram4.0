      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-key-flg      .
      *                  *---------------------------------------------*
      *                  * Box di errore                               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-key-999.
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
      *              *-------------------------------------------------*
      *              * Test                                            *
      *              *-------------------------------------------------*
           if        w-tes-num-prt        =    zero and
                     w-tes-num-prc        =    zero
                     move  "#"            to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controllo su contrassegno collo                 *
      *              *-------------------------------------------------*
           if        w-tes-cts-prc (1)    not  = spaces
                     go to cnt-tdo-nok-150.
           move      "Manca il contrassegno per il collo !              
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-150.
      *              *-------------------------------------------------*
      *              * Controllo su peso lordo                         *
      *              *-------------------------------------------------*
           if        w-tes-lrd-prc (1)    not  = zero
                     go to cnt-tdo-nok-200.
           move      "Manca il peso lordo !                             
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-200.
      *              *-------------------------------------------------*
      *              * Controllo su dimensioni                         *
      *              *  - Larghezza                                    *
      *              *  - Altezza                                      *
      *              *  - Profondita'                                  *
      *              *-------------------------------------------------*
           if        w-tes-dim-lar (1)    not  = zero and
                     w-tes-dim-alt (1)    not  = zero and
                     w-tes-dim-prf (1)    not  = zero
                     go to cnt-tdo-nok-800.
           if        w-tes-dim-lar (1)    =    zero and
                     w-tes-dim-alt (1)    =    zero and
                     w-tes-dim-prf (1)    =    zero
                     go to cnt-tdo-nok-800.
           move      "Le dimensioni del collo devono essere tutte presen
      -              "ti             "    to   w-err-box-err-msg      .
           move      "o tutte assenti !                                 
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-900.
      *              *-------------------------------------------------*
      *              * Uscita per controlli non superati               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-nok-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-999.
           exit.
           
      *    *===========================================================*
      *    * Normalizzazione dati chiave e non chiave                  *
      *    *-----------------------------------------------------------*
       nor-key-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati chiave                     *
      *              *-------------------------------------------------*
           perform   nor-key-reg-000      thru nor-key-reg-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave testata         *
      *              *-------------------------------------------------*
           perform   nor-nok-tes-000      thru nor-nok-tes-999        .
       nor-key-nok-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave                               *
      *    *-----------------------------------------------------------*
       nor-key-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di rientro all'ultima riga per la funzione *
      *              * di saldaconto : in off                          *
      *              *-------------------------------------------------*
           move      spaces               to   w-sdc-fdr-aur          .
      *              *-------------------------------------------------*
      *              * Numero protocollo ordine di spedizione          *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-num-prt          .
      *              *-------------------------------------------------*
      *              * Ragione sociale del cliente cui si riferisce    *
      *              * l'ordine di spedizione                          *
      *              *-------------------------------------------------*
           move      spaces               to   w-tes-num-prt-rcl      .
      *              *-------------------------------------------------*
      *              * Numero collo nel packing list                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-num-prc          .
       nor-key-reg-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave testata                   *
      *    *-----------------------------------------------------------*
       nor-nok-tes-000.
      *              *-------------------------------------------------*
      *              * Contrassegno collo                              *
      *              *-------------------------------------------------*
           move      spaces               to   w-tes-cts-prc (1)      .
      *              *-------------------------------------------------*
      *              * Peso tara espresso in Kg.                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-tar-prc (1)      .
      *              *-------------------------------------------------*
      *              * Peso lordo espresso in Kg.                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-lrd-prc (1)      .
      *              *-------------------------------------------------*
      *              * Dimensioni : Larghezza                          *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-dim-lar (1)      .
      *              *-------------------------------------------------*
      *              * Dimensioni : Altezza                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-dim-alt (1)      .
      *              *-------------------------------------------------*
      *              * Dimensioni : Profondita'                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-dim-prf (1)      .
      *              *-------------------------------------------------*
      *              * Data approntamento collo                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-dat-prc (1)      .
      *              *-------------------------------------------------*
      *              * Annotazione per il collo                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-tes-not-prc (1)      .
       nor-nok-tes-999.
           exit.

      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Determinazione se per il progressivo collo in   *
      *              * corso di trattamento si e' in modifica o in     *
      *              * inserimento                                     *
      *              *-------------------------------------------------*
           move      w-tes-num-prt        to   w-det-tip-fun-prt      .
           move      w-tes-num-prc        to   w-det-tip-fun-prc      .
           perform   det-tip-fun-000      thru det-tip-fun-999        .
           if        w-det-tip-fun-ctr    =    zero
                     move  "I"            to   w-cnt-mfu-tip-fun
           else      move  "M"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-050.
      *              *-------------------------------------------------*
      *              * Test se inserimento consentito                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-vis-sgr    not  = "V"
                     go to rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Inserimento non consentito !                      
      -              "               "    to   w-err-box-err-msg      .
      *                  *---------------------------------------------*
      *                  * Box di errore                               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     rou-let-reg-900.
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test per visualizzazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-vis-sgr    =    "V"
                     move  "V"            to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Numero righe lette dall'ordine di spedizio- *
      *                  * ne : a zero                                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-bro-num-rlo          .
      *                  *---------------------------------------------*
      *                  * Numero righe nel buffer righe ordine di     *
      *                  * spedizione : a zero                         *
      *                  *---------------------------------------------*
           move      zero                 to   w-bro-num-ele          .
       rou-let-reg-200.
      *              *-------------------------------------------------*
      *              * Caricamento dell'ordine di spedizione           *
      *              *-------------------------------------------------*
       rou-let-reg-210.
      *                  *---------------------------------------------*
      *                  * Start su [osr] secondo il numero di proto-  *
      *                  * collo dell'ordine di spedizione             *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-osr-num-prt         .
           move      zero                 to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : a fine caricamento righe  *
      *                  * dell'ordine di spedizione                   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-300.
       rou-let-reg-220.
      *                  *---------------------------------------------*
      *                  * Read Next su [osr] secondo il numero di     *
      *                  * protocollo dell'ordine di spedizione        *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : a fine caricamento righe     *
      *                  * dell'ordine di spedizione                   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-300.
      *                  *---------------------------------------------*
      *                  * Se fine logica : a fine caricamento righe   *
      *                  * dell'ordine di spedizione                   *
      *                  *---------------------------------------------*
           if        rf-osr-num-prt       not  = w-tes-num-prt
                     go to rou-let-reg-300.
       rou-let-reg-230.
      *                  *---------------------------------------------*
      *                  * Incremento numero righe lette dall'ordine   *
      *                  * di spedizione                               *
      *                  *---------------------------------------------*
           add       1                    to   w-bro-num-rlo          .
      *                  *---------------------------------------------*
      *                  * Selezione su riga ordine di spedizione; se  *
      *                  * non e' una riga da includere nel buffer :   *
      *                  * la si ignora                                *
      *                  *---------------------------------------------*
           if        rf-osr-tip-rig       =    "P    " or
                     rf-osr-tip-rig       =    "PN   "
                     go to rou-let-reg-240
           else      go to rou-let-reg-220.
       rou-let-reg-240.
      *                  *---------------------------------------------*
      *                  * Determinazione della quantita' assegnata    *
      *                  * solo se in inserimento                      *
      *                  *                                             *
      *                  * N.B.: Questo per far si che vengano escluse *
      *                  *       le righe ordine di spedizione che     *
      *                  *       sono gia' state assegnate             *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to rou-let-reg-245.
           move      rf-osr-num-prt       to   w-det-qta-ass-prt      .
           move      rf-osr-num-prg       to   w-det-qta-ass-prg      .
           perform   det-qta-ass-000      thru det-qta-ass-999        .
           if        w-det-qta-ass-qta    not  < rf-osr-qta-ven
                     go to rou-let-reg-220.
       rou-let-reg-245.
      *                  *---------------------------------------------*
      *                  * Incremento numero righe ordine di spedi-    *
      *                  * zione nel buffer                            *
      *                  *---------------------------------------------*
           add       1                    to   w-bro-num-ele          .
      *                  *---------------------------------------------*
      *                  * Inizializzazione buffer riga ordine         *
      *                  *---------------------------------------------*
           move      zero                 to   w-bro-num-prg
                                              (w-bro-num-ele)         .
           move      spaces               to   w-bro-tip-rig
                                              (w-bro-num-ele)         .
           move      zero                 to   w-bro-dec-qta
                                              (w-bro-num-ele)         .
           move      zero                 to   w-bro-qta-das
                                              (w-bro-num-ele)         .
           move      zero                 to   w-bro-qta-ass
                                              (w-bro-num-ele)         .
           move      spaces               to   w-bro-alf-pro
                                              (w-bro-num-ele)         .
           move      spaces               to   w-bro-des-rig
                                              (w-bro-num-ele)         .
           move      spaces               to   w-bro-des-rgs
                                              (w-bro-num-ele)         .
       rou-let-reg-250.
      *                  *---------------------------------------------*
      *                  * Memorizzazione in buffer riga ordine degli  *
      *                  * elementi provenienti da [osr]               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Progressivo riga                        *
      *                      *-----------------------------------------*
           move      rf-osr-num-prg       to   w-bro-num-prg
                                              (w-bro-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Tipo riga                               *
      *                      *-----------------------------------------*
           move      rf-osr-tip-rig       to   w-bro-tip-rig
                                              (w-bro-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Decimali quantita'                      *
      *                      *-----------------------------------------*
           move      rf-osr-dec-qta       to   w-bro-dec-qta
                                              (w-bro-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Quantita' da assegnare                  *
      *                      *-----------------------------------------*
           move      rf-osr-qta-ven       to   w-bro-qta-das
                                              (w-bro-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico del prodotto        *
      *                      *-----------------------------------------*
           move      rf-osr-alf-pro       to   w-bro-alf-pro
                                              (w-bro-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Descrizione per la riga                 *
      *                      *-----------------------------------------*
           perform   det-des-bro-000      thru det-des-bro-999        .
      *                      *-----------------------------------------*
      *                      * Descrizione per la riga di scroll       *
      *                      *-----------------------------------------*
           perform   det-des-rgs-000      thru det-des-rgs-999        .
       rou-let-reg-260.
      *                  *---------------------------------------------*
      *                  * Se raggiunto il max numero di elementi nel  *
      *                  * buffer : a fine lettura                     *
      *                  *---------------------------------------------*
           if        w-bro-num-ele        =    w-bro-max-ele
                     go to rou-let-reg-300.
      *                  *---------------------------------------------*
      *                  * Altrimenti : riciclo a lettura riga ordine  *
      *                  * di spedizione successiva                    *
      *                  *---------------------------------------------*
           go to     rou-let-reg-220.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se non e' stata letta alcuna riga dall'ordine   *
      *              * di spedizione : si emette un messaggio di er-   *
      *              * rore e si esce con flag di uscita ad errore     *
      *              *-------------------------------------------------*
           if        w-bro-num-rlo        >    zero
                     go to rou-let-reg-310.
           move      "Ordine di spedizione non esistente !              
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-310.
      *              *-------------------------------------------------*
      *              * Se l'ordine di spedizione non contiene alcuna   *
      *              * riga selezionabile per il packing list : si e-  *
      *              * mette un messaggio di errore e si esce con flag *
      *              * di uscita ad errore                             *
      *              *-------------------------------------------------*
           if        w-bro-num-ele        >    zero
                     go to rou-let-reg-400.
           move      "L'ordine di spedizione non contiene alcuna riga se
      -              "lezionabile    "    to   w-err-box-err-msg      .
           move      "per essere inclusa nel packing list !             
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-400.
      *              *-------------------------------------------------*
      *              * Lettura del progressivo riga zero relativo al   *
      *              * collo del packing list trattato                 *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRTPRC    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-osk-num-prt         .
           move      w-tes-num-prc        to   rf-osk-num-prc         .
           move      zero                 to   rf-osk-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osk                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-600.
       rou-let-reg-500.
      *              *-------------------------------------------------*
      *              * Se record non trovato                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Continuazione per determinare, per ogni ri- *
      *                  * ga dell'ordine di spedizione bufferizzata,  *
      *                  * la quantita' relativa ad altri colli del    *
      *                  * packing list                                *
      *                  *---------------------------------------------*
           go to     rou-let-reg-650.
       rou-let-reg-600.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
       rou-let-reg-610.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Modifica               *
      *                  *---------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-620.
      *                  *---------------------------------------------*
      *                  * Determinazione valori attuali contenuti di- *
      *                  * rettamente in [osk]                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Contrassegno collo                      *
      *                      *-----------------------------------------*
           move      rf-osk-cts-prc       to   w-tes-cts-prc (1)      .
      *                      *-----------------------------------------*
      *                      * Peso tara espresso in Kg.               *
      *                      *-----------------------------------------*
           move      rf-osk-tar-prc       to   w-tes-tar-prc (1)      .
      *                      *-----------------------------------------*
      *                      * Peso lordo espresso in Kg.              *
      *                      *-----------------------------------------*
           move      rf-osk-lrd-prc       to   w-tes-lrd-prc (1)      .
      *                      *-----------------------------------------*
      *                      * Dimensioni : Larghezza                  *
      *                      *-----------------------------------------*
           move      rf-osk-dim-lar       to   w-tes-dim-lar (1)      .
      *                      *-----------------------------------------*
      *                      * Dimensioni : Altezza                    *
      *                      *-----------------------------------------*
           move      rf-osk-dim-alt       to   w-tes-dim-alt (1)      .
      *                      *-----------------------------------------*
      *                      * Dimensioni : Profondita'                *
      *                      *-----------------------------------------*
           move      rf-osk-dim-prf       to   w-tes-dim-prf (1)      .
      *                      *-----------------------------------------*
      *                      * Data approntamento collo                *
      *                      *-----------------------------------------*
           move      rf-osk-dat-prc       to   w-tes-dat-prc (1)      .
      *                      *-----------------------------------------*
      *                      * Annotazione per il collo                *
      *                      *-----------------------------------------*
           move      rf-osk-not-prc       to   w-tes-not-prc (1)      .
       rou-let-reg-630.
      *                  *---------------------------------------------*
      *                  * Determinazione valori precedenti            *
      *                  *---------------------------------------------*
           move      w-tes-val-aep (1)    to   w-tes-val-aep (2)      .
       rou-let-reg-650.
      *                  *---------------------------------------------*
      *                  * Determinazione, per ogni riga dell'ordine   *
      *                  * di spedizione bufferizzata, della quantita' *
      *                  * relativa al collo del packing list          *
      *                  *---------------------------------------------*
       rou-let-reg-660.
      *                      *-----------------------------------------*
      *                      * Indice su elementi in tabella : a zero  *
      *                      *-----------------------------------------*
           move      zero                 to   w-bro-inx-ele          .
       rou-let-reg-670.
      *                      *-----------------------------------------*
      *                      * Incremento indice su elementi in tabel- *
      *                      * la, e test se fine scansione            *
      *                      *-----------------------------------------*
           add       1                    to   w-bro-inx-ele          .
           if        w-bro-inx-ele        >    w-bro-num-ele
                     go to rou-let-reg-800.
       rou-let-reg-680.
      *                      *-----------------------------------------*
      *                      * Start su [osk] per i records relativi   *
      *                      * alla riga dell'ordine di spedizione in  *
      *                      * esame                                   *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-osk-num-prt         .
           move      w-bro-num-prg
                    (w-bro-inx-ele)       to   rf-osk-num-prg         .
           move      zero                 to   rf-osk-num-prc         .
           move      "pgm/ods/fls/ioc/obj/iofosk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osk                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : a riga successiva     *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-670.
       rou-let-reg-690.
      *                      *-----------------------------------------*
      *                      * Read next da [osk]                      *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osk                 .
      *                      *-----------------------------------------*
      *                      * Se fine file : a riga successiva        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-670.
      *                      *-----------------------------------------*
      *                      * Se fine logica : a riga successiva      *
      *                      *-----------------------------------------*
           if        rf-osk-num-prt       not  = w-tes-num-prt
                     go to rou-let-reg-670.
           if        rf-osk-num-prg       not  = w-bro-num-prg
                                                (w-bro-inx-ele)
                     go to rou-let-reg-670.
       rou-let-reg-700.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda se e' stato letto  *
      *                      * un record relativo al collo trattato o  *
      *                      * no                                      *
      *                      *-----------------------------------------*
           if        rf-osk-num-prc       =    w-tes-num-prc
                     go to rou-let-reg-710
           else      go to rou-let-reg-720.
       rou-let-reg-710.
      *                      *-----------------------------------------*
      *                      * Se e' stato letto un record relativo al *
      *                      * collo trattato                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Memorizzazione quantita' assegnata  *
      *                          *-------------------------------------*
           move      rf-osk-qta-prc       to   w-bro-qta-ass
                                              (w-bro-inx-ele)         .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura                   *
      *                          *-------------------------------------*
           go to     rou-let-reg-690.
       rou-let-reg-720.
      *                      *-----------------------------------------*
      *                      * Se e' stato letto un record relativo ad *
      *                      * un collo diverso da quello trattato     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Decremento della quantita' da asse- *
      *                          * gnare                               *
      *                          *-------------------------------------*
           subtract rf-osk-qta-prc        from w-bro-qta-das
                                              (w-bro-inx-ele)         .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura                   *
      *                          *-------------------------------------*
           go to     rou-let-reg-690.
       rou-let-reg-800.
      *                  *---------------------------------------------*
      *                  * Ordinamento delle righe secondo la persona- *
      *                  * lizzazione relativa all'ordinamento righe   *
      *                  * per stampa ordine di spedizione             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo ordinamento                     *
      *                      *  - 00 : Per progressivo riga            *
      *                      * nessun ordinamento in quanto le righe   *
      *                      * sono gia' ordinate                      *
      *                      *-----------------------------------------*
           if        w-prs-tor-rco-tip    =    00
                     go to rou-let-reg-850.
      *                      *-----------------------------------------*
      *                      * Se tipo ordinamento                     *
      *                      *  - 01 : Per classe, gruppo, sottogruppo,*
      *                      *         codice                          *
      *                      *  - 02 : Per classe, gruppo, sottogruppo,*
      *                      *         descrizione                     *
      *                      *  - 10 : Per percorso di ubicazione, e   *
      *                      *         progressivo riga                *
      *                      *  - 13 : Per percorso di ubicazione, e   *
      *                      *         codice prodotto                 *
      *                      *  - 14 : Per percorso di ubicazione, e   *
      *                      *         descrizione prodotto            *
      *                      * nessun ordinamento in quanto tipi di    *
      *                      * ordinamento non ancora implementati     *
      *                      *-----------------------------------------*
           if        w-prs-tor-rco-tip    =    01 or
                     w-prs-tor-rco-tip    =    02 or
                     w-prs-tor-rco-tip    =    10 or
                     w-prs-tor-rco-tip    =    13 or
                     w-prs-tor-rco-tip    =    14
                     go to rou-let-reg-850.
      *                      *-----------------------------------------*
      *                      * Se tipo ordinamento                     *
      *                      *  - 03 : Per codice prodotto             *
      *                      *  - 04 : Per descrizione prodotto        *
      *                      * si esegue l'ordinamento                 *
      *                      *-----------------------------------------*
           if        w-prs-tor-rco-tip    =    03 or
                     w-prs-tor-rco-tip    =    04
                     go to rou-let-reg-825.
      *                      *-----------------------------------------*
      *                      * Se tipo ordinamento non riconosciuto :  *
      *                      * non si esegue alcun ordinamento         *
      *                      *-----------------------------------------*
           go to     rou-let-reg-850.
       rou-let-reg-825.
      *                      *-----------------------------------------*
      *                      * Sort di ordinamento                     *
      *                      *-----------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   stp-srt-out-000
                                          thru stp-srt-out-999        .
       rou-let-reg-850.
      *                  *---------------------------------------------*
      *                  * Altre operazioni                            *
      *                  *---------------------------------------------*
       rou-let-reg-900.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Sort per ordinamento righe corpo : Input  procedure       *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Trasferimento al sort della tabella in memoria  *
      *              *-------------------------------------------------*
           move      zero                 to   w-bro-inx-ele          .
       stp-srt-inp-100.
           add       1                    to   w-bro-inx-ele          .
           if        w-bro-inx-ele        >    w-bro-num-ele
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
           move      spaces               to   srt-rec.               .
           if        w-prs-tor-rco-tip    =    03
                     go to stp-srt-inp-300
           else if   w-prs-tor-rco-tip    =    04
                     go to stp-srt-inp-400.
       stp-srt-inp-300.
           string    w-bro-alf-pro
                    (w-bro-inx-ele)
                                delimited by   size
                     w-bro-num-prg
                    (w-bro-inx-ele)
                                delimited by   size
                                          into srt-k01                .
           go to     stp-srt-inp-500.
       stp-srt-inp-400.
           string    w-bro-des-rgs
                    (w-bro-inx-ele)
                                delimited by   size
                     w-bro-num-prg
                    (w-bro-inx-ele)
                                delimited by   size
                                          into srt-k01                .
           go to     stp-srt-inp-500.
       stp-srt-inp-500.
           move      w-bro-sng-ele-uno
                    (w-bro-inx-ele)       to   srt-dat-001            .
           move      w-bro-sng-ele-due
                    (w-bro-inx-ele)       to   srt-dat-002            .
           move      w-bro-sng-ele-tre
                    (w-bro-inx-ele)       to   srt-dat-003            .
       stp-srt-inp-600.
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Sort per ordinamento righe corpo : Output procedure       *
      *    *-----------------------------------------------------------*
       stp-srt-out-000.
      *              *-------------------------------------------------*
      *              * Trasferimento dal sort alla tabella in memoria  *
      *              *-------------------------------------------------*
           move      zero                 to   w-bro-inx-ele          .
       stp-srt-out-100.
           return    srt    at end
                            go to stp-srt-out-999.
           add       1                    to   w-bro-inx-ele          .
           move      srt-dat-001          to   w-bro-sng-ele-uno
                                              (w-bro-inx-ele)         .
           move      srt-dat-002          to   w-bro-sng-ele-due
                                              (w-bro-inx-ele)         .
           move      srt-dat-003          to   w-bro-sng-ele-tre
                                              (w-bro-inx-ele)         .
           go to     stp-srt-out-100.
       stp-srt-out-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione per buffer riga ordine di spe- *
      *    * dizione in corso di trattamento                           *
      *    *-----------------------------------------------------------*
       det-des-bro-000.
      *              *-------------------------------------------------*
      *              * Deviazione secondo il flag di estensione alla   *
      *              * descrizione                                     *
      *              *-------------------------------------------------*
           if        rf-osr-des-ext       =    0
                     go to det-des-bro-200
           else if   rf-osr-des-ext       =    1
                     go to det-des-bro-400
           else if   rf-osr-des-ext       =    2
                     go to det-des-bro-600.
       det-des-bro-200.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione contenuta nel   *
      *                  * record [osr]                                *
      *                  *---------------------------------------------*
           move      rf-osr-des-rig       to   w-bro-des-rig
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-bro-900.
       det-des-bro-400.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [osx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [osx]                          *
      *                  *---------------------------------------------*
           move      rf-osr-num-prt       to   w-let-arc-osx-prt      .
           move      rf-osr-num-prg       to   w-let-arc-osx-prg      .
           move      11                   to   w-let-arc-osx-trc      .
           perform   let-arc-osx-000      thru let-arc-osx-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione contenuta nel   *
      *                  * record [osx]                                *
      *                  *---------------------------------------------*
           move      w-let-arc-osx-des    to   w-bro-des-rig
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-bro-900.
       det-des-bro-600.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [pdx]                          *
      *                  *---------------------------------------------*
           move      rf-osr-num-pro       to   w-let-dcp-pdx-cod      .
           move      spaces               to   w-let-dcp-pdx-tar      .
           move      zero                 to   w-let-dcp-pdx-arc      .
           move      "I  "                to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione contenuta nel   *
      *                  * record [pdx]                                *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-des    to   w-bro-des-rig
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-bro-900.
       det-des-bro-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-bro-999.
       det-des-bro-999.
           exit.

      *    *===========================================================*
      *    * Composizione descrizione per riga di scroll dell'elemento *
      *    * del buffer righe ordine di spedizione                     *
      *    *-----------------------------------------------------------*
       det-des-rgs-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se si sta trattando un co- *
      *              * dice di magazzino oppure no                     *
      *              *-------------------------------------------------*
           if        w-bro-tip-rig
                    (w-bro-num-ele)       =    "P "
                     go to det-des-rgs-200
           else if   w-bro-tip-rig
                    (w-bro-num-ele)       =    "PN"
                     go to det-des-rgs-100
           else      go to det-des-rgs-200.
       det-des-rgs-100.
      *              *-------------------------------------------------*
      *              * Se non si sta trattando un codice di magazzino  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Si pone la descrizione per la riga di       *
      *                  * scroll pari alla descrizione per la riga    *
      *                  *---------------------------------------------*
           move      w-bro-des-rig
                    (w-bro-num-ele)       to   w-bro-des-rgs
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rgs-999.
       det-des-rgs-200.
      *              *-------------------------------------------------*
      *              * Se si sta trattando un codice di magazzino      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare dell'area di    *
      *                  * lavoro per la composizione                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-des-scr-000          .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore della per-  *
      *                  * sonalizzazione del tipo di visualizzazione  *
      *                  * della riga di scroll                        *
      *                  *---------------------------------------------*
           if        w-prs-rig-scr-des    =    00
                     go to det-des-rgs-400
           else if   w-prs-rig-scr-des    =    01
                     go to det-des-rgs-420
           else if   w-prs-rig-scr-des    =    02
                     go to det-des-rgs-440
           else if   w-prs-rig-scr-des    =    03
                     go to det-des-rgs-460
           else if   w-prs-rig-scr-des    =    04
                     go to det-des-rgs-480
           else if   w-prs-rig-scr-des    =    05
                     go to det-des-rgs-500
           else if   w-prs-rig-scr-des    =    06
                     go to det-des-rgs-520
           else      go to det-des-rgs-400.
       det-des-rgs-400.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 00              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione di 40 caratteri             *
      *                      *-----------------------------------------*
           move      w-bro-des-rig
                    (w-bro-num-ele)       to   w-des-scr-000-d40      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-420.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 01              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione di 25 caratteri             *
      *                      *-----------------------------------------*
           move      w-bro-des-rig
                    (w-bro-num-ele)       to   w-des-scr-001-d25      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-bro-alf-pro
                    (w-bro-num-ele)       to   w-des-scr-001-cod      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-440.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 02              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione di 21 caratteri             *
      *                      *-----------------------------------------*
           move      w-bro-des-rig
                    (w-bro-num-ele)       to   w-des-scr-002-d21      .
      *                      *-----------------------------------------*
      *                      * Parentesi quadra sinistra               *
      *                      *-----------------------------------------*
           move      "["                  to   w-des-scr-002-pqs      .
      *                      *-----------------------------------------*
      *                      * Tipo codice                             *
      *                      *-----------------------------------------*
           move      w-bro-tip-rig
                    (w-bro-num-ele)       to   w-des-scr-002-tco      .
      *                      *-----------------------------------------*
      *                      * Parentesi quadra destra                 *
      *                      *-----------------------------------------*
           move      "]"                  to   w-des-scr-002-pqd      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      rf-osr-alf-pro       to   w-des-scr-002-cod      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-460.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 03              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-bro-alf-pro
                    (w-bro-num-ele)       to   w-des-scr-003-cod      .
      *                      *-----------------------------------------*
      *                      * Descrizione di 25 caratteri             *
      *                      *-----------------------------------------*
           move      w-bro-des-rig
                    (w-bro-num-ele)       to   w-des-scr-003-d25      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-480.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 04              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Parentesi quadra sinistra               *
      *                      *-----------------------------------------*
           move      "["                  to   w-des-scr-004-pqs      .
      *                      *-----------------------------------------*
      *                      * Tipo codice                             *
      *                      *-----------------------------------------*
           move      w-bro-tip-rig
                    (w-bro-num-ele)       to   w-des-scr-004-tco      .
      *                      *-----------------------------------------*
      *                      * Parentesi quadra destra                 *
      *                      *-----------------------------------------*
           move      "]"                  to   w-des-scr-004-pqd      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-bro-alf-pro
                    (w-bro-num-ele)       to   w-des-scr-004-cod      .
      *                      *-----------------------------------------*
      *                      * Descrizione di 21 caratteri             *
      *                      *-----------------------------------------*
           move      w-bro-des-rig
                    (w-bro-num-ele)       to   w-des-scr-004-d21      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-500.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 05              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-bro-alf-pro
                    (w-bro-num-ele)       to   w-des-scr-005-cod      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-520.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 06              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Parentesi quadra sinistra               *
      *                      *-----------------------------------------*
           move      "["                  to   w-des-scr-006-pqs      .
      *                      *-----------------------------------------*
      *                      * Tipo codice                             *
      *                      *-----------------------------------------*
           move      w-bro-tip-rig
                    (w-bro-num-ele)       to   w-des-scr-006-tco      .
      *                      *-----------------------------------------*
      *                      * Parentesi quadra destra                 *
      *                      *-----------------------------------------*
           move      "]"                  to   w-des-scr-006-pqd      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-bro-alf-pro
                    (w-bro-num-ele)       to   w-des-scr-006-cod      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-des-rgs-700.
       det-des-rgs-700.
      *                  *---------------------------------------------*
      *                  * Composizione eseguita in area di destina-   *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           move      w-des-scr-000        to   w-bro-des-rgs
                                              (w-bro-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rgs-999.
       det-des-rgs-999.
           exit.

