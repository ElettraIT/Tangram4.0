      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [ost]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZSCH    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-ost-cod-dpz         .
           move      spaces               to   rf-ost-flg-sch         .
           move      zero                 to   rf-ost-num-prt         .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ost]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofost"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ost                 .
      *                  *---------------------------------------------*
      *                  * Se 'At end' : ad uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-ost-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Test su flag di ordine chiuso               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-121
                     stp-srt-inp-122
                     stp-srt-inp-123
                     depending            on   rr-sts-ods             .
       stp-srt-inp-121.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di ordine chiuso       *
      *                          *-------------------------------------*
           if        rf-ost-flg-sch       not  = spaces
                     go to stp-srt-inp-900.
           go to     stp-srt-inp-130.
       stp-srt-inp-122.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-130.
       stp-srt-inp-123.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-130.
       stp-srt-inp-130.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces
                     go to stp-srt-inp-140.
           if        rf-ost-cod-tms       not  = rr-tip-mov
                     go to stp-srt-inp-100.
       stp-srt-inp-140.
      *                  *---------------------------------------------*
      *                  * Test su data ordine minima e massima        *
      *                  *---------------------------------------------*
           if        rf-ost-dat-doc       <    rr-dat-min  or
                     rf-ost-dat-doc       >    rr-dat-max
                     go to stp-srt-inp-100.
       stp-srt-inp-160.
      *                  *---------------------------------------------*
      *                  * Test su numero ordine minimo                *
      *                  *---------------------------------------------*
           if        rr-noc-min           not  = zero and
                     rf-ost-num-prt       <    rr-noc-min
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su numero ordine massimo               *
      *                  *---------------------------------------------*
           if        rr-noc-max           not  = zero and
                     rf-ost-num-prt       >    rr-noc-max
                     go to stp-srt-inp-100.
       stp-srt-inp-180.
      *              *-------------------------------------------------*
      *              * Start su file [osr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ost-num-prt       to   rf-osr-num-prt         .
           move      zero                 to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : riciclo a testata succes- *
      *                  * siva                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-100.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
