      *                          *-------------------------------------*
           move      rf-ost-cod-arc       to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-buf-doc-mvm-rsa
                                              (w-buf-doc-mvm-crb)     .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     buf-doc-mvm-480.
       buf-doc-mvm-436.
      *                      *-----------------------------------------*
      *                      * Dipendenza                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura file [ada]                  *
      *                          *-------------------------------------*
           move      rf-ost-cod-arc       to   w-let-arc-dpz-cod      .
           perform   let-arc-dpz-000      thru let-arc-dpz-999        .
           move      w-let-arc-dpz-des    to   w-buf-doc-mvm-rsa
                                              (w-buf-doc-mvm-crb)     .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     buf-doc-mvm-480.
       buf-doc-mvm-440.
      *                      *-----------------------------------------*
      *                      * Tipo archivio non riconosciuto          *
      *                      *-----------------------------------------*
           move      spaces               to   w-buf-doc-mvm-rsa
                                              (w-buf-doc-mvm-crb)     .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     buf-doc-mvm-480.
       buf-doc-mvm-480.
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura                           *
      *                  *---------------------------------------------*
           go to     buf-doc-mvm-200.
       buf-doc-mvm-500.
      *                  *---------------------------------------------*
      *                  * Controllo numero records letti con lo stes- *
      *                  * so valore                                   *
      *                  *---------------------------------------------*
           if        w-buf-doc-mvm-crb    =    zero
                     move  "#"            to   w-buf-doc-mvm-fds
                     go to buf-doc-mvm-999.
