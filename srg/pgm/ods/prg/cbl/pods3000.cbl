      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo ordini di spe-  *
      *    * dizione                                                   *
      *    *-----------------------------------------------------------*
       att-ods-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [odsprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-ods-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-ods-prt-saa      .
           move      w-att-ods-prt-saa    to   rn-ods-prt-scl-ann     .
           move      w-att-ods-prt-dpz    to   rn-ods-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [odsprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-ods-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-ods-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-ods-prt-000.
       att-ods-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-ods-prt-num-prt   to   w-att-ods-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-ods-prt-wpr      .
           if        w-att-ods-prt-wpr    =    zero
                     move  1              to   w-att-ods-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-ods-prt-saa    to   w-att-ods-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-ods-prt-dpz    to   w-att-ods-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-ods-prt-wnu    to   rn-ods-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-ods-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-ods-prt-num-prt   to   w-att-ods-prt-num      .
       att-ods-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo ordini di spedi-  *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       rip-ods-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [odsprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-ods-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-ods-prt-saa      .
           move      w-att-ods-prt-saa    to   rn-ods-prt-scl-ann     .
           move      w-att-ods-prt-dpz    to   rn-ods-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [odsprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-ods-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-ods-prt-num-prt   not  = w-att-ods-prt-num
                     go to  rip-ods-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           move      w-att-ods-prt-num    to   w-att-ods-prt-wnu      .
           subtract  1                    from w-att-ods-prt-wpr      .
           if        w-att-ods-prt-wpr    =    zero
                     move  zero           to   w-att-ods-prt-wnu      .
           move      w-att-ods-prt-wnu    to   rn-ods-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
       rip-ods-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/ods/num/ioc/obj/inodsprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ods-prt             .
       rip-ods-prt-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [osr]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-osr-000      thru del-rec-osr-999        .
      *              *-------------------------------------------------*
      *              * Delete [osx]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-osx-000      thru del-rec-osx-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento record [ocr] per Delete           *
      *              *-------------------------------------------------*
           perform   agg-ocr-del-000      thru agg-ocr-del-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = w-tes-tip-arc (2) or
                     w-tes-cod-arc (1)    not  = w-tes-cod-arc (2) or
                     w-tes-dpz-arc (1)    not  = w-tes-dpz-arc (2) or
                     w-tes-cod-lng (1)    not  = w-tes-cod-lng (2) or
                     w-tes-sgl-vpf (1)    not  = w-tes-sgl-vpf (2) or
                     w-tes-dec-vpf (1)    not  = w-tes-dec-vpf (2) or
                     w-tes-tdc-vpf (1)    not  = w-tes-tdc-vpf (2) or
                     w-tes-cdc-vpf (1)    not  = w-tes-cdc-vpf (2)
                     move  "#"            to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento file righe [osr]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [osr]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-osr-000      thru wrt-rec-osr-999        .
      *                      *-----------------------------------------*
      *                      * Write record [osx]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-osx-000      thru wrt-rec-osx-999        .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [ocr] per Write    *
      *                      *-----------------------------------------*
           perform   agg-ocr-wrt-000      thru agg-ocr-wrt-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig (2)    =    spaces
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-cnt-var-tes-cor    not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [osr]                       *
      *                          *-------------------------------------*
           perform   rew-rec-osr-000      thru rew-rec-osr-999        .
      *                          *-------------------------------------*
      *                          * Rewrite [osx]                       *
      *                          *-------------------------------------*
           perform   rew-rec-osx-000      thru rew-rec-osx-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento record [ocr] per Re-  *
      *                          * write                               *
      *                          *-------------------------------------*
           perform   agg-ocr-rew-000      thru agg-ocr-rew-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Trattamento file testata [ost]                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-800.
      *                      *-----------------------------------------*
      *                      * Write record [ost]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-ost-000      thru wrt-rec-ost-999        .
      *                      *-----------------------------------------*
      *                      * Write record [osx] di appoggio alla te- *
      *                      * stata                                   *
      *                      *-----------------------------------------*
           perform   wrt-osx-tes-000      thru wrt-osx-tes-999        .
           go to     scr-mov-fil-900.
       scr-mov-fil-800.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Rewrite record [ost]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-ost-000      thru rew-rec-ost-999        .
      *                      *-----------------------------------------*
      *                      * Delete record [osx] di appoggio alla te-*
      *                      * stata                                   *
      *                      *-----------------------------------------*
           perform   del-osx-tes-000      thru del-osx-tes-999        .
      *                      *-----------------------------------------*
      *                      * Write record [osx] di appoggio alla te- *
      *                      * stata                                   *
      *                      *-----------------------------------------*
           perform   wrt-osx-tes-000      thru wrt-osx-tes-999        .
       scr-mov-fil-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-999.
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Cancellazione righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
