           move      w-rig-cdc-vps (1)    to   rf-osr-cdc-vps         .
           move      w-rig-prz-lrs (1)    to   rf-osr-prz-lrs         .
           move      w-rig-prz-nts (1)    to   rf-osr-prz-nts         .
           move      w-rig-sgl-vpp (1)    to   rf-osr-sgl-vpp         .
           move      w-rig-dec-vpp (1)    to   rf-osr-dec-vpp         .
           move      w-rig-tdc-vpp (1)    to   rf-osr-tdc-vpp         .
           move      w-rig-cdc-vpp (1)    to   rf-osr-cdc-vpp         .
           move      w-rig-prz-ven (1)    to   rf-osr-prz-ven         .
