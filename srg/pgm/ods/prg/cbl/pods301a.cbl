      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   rr-dpz-cli-rag         .
           move      w-let-arc-dcc-via    to   rr-dpz-cli-via         .
           move      w-let-arc-dcc-loc    to   rr-dpz-cli-loc         .
      *                  *---------------------------------------------*
      *                  * Dipendenza cliente                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-ipc-dpz-cli-val    to   rr-dpz-cli             .
      *                      *-----------------------------------------*
      *                      * Controllo                               *
      *                      *-----------------------------------------*
           move      "D"                  to   w-let-arc-dcc-tle      .
           move      rr-cod-cli           to   w-let-arc-dcc-cod      .
           move      rr-dpz-cli           to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           if        w-let-arc-dcc-flg    not  = spaces
                     go to pre-tip-fun-400.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   rr-dpz-cli-rag         .
           move      w-let-arc-dcc-via    to   rr-dpz-cli-via         .
           move      w-let-arc-dcc-loc    to   rr-dpz-cli-loc         .
      *                  *---------------------------------------------*
      *                  * Forzatura altre richieste                   *
      *                  *---------------------------------------------*
           move      zero                 to   rr-dem-min             .
           move      zero                 to   rr-dem-max             .
           move      02                   to   rr-sts-ods             .
      *                  *---------------------------------------------*
      *                  * Si/No richieste ad utente : No              *
      *                  *---------------------------------------------*
           move      "N"                  to   w-cnt-fun-snx-ric      .
           go to     pre-tip-fun-600.
       pre-tip-fun-400.
      *              *-------------------------------------------------*
      *              * Se variabili di i.p.c. da livello precedente    *
      *              * per le richieste non esistenti                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Si/No richieste ad utente : Si              *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-ric      .
           go to     pre-tip-fun-600.
       pre-tip-fun-600.
