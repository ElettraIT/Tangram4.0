           go to     acc-cod-com-110.
       acc-cod-com-120.
           move      w-cod-cod-lgv-num    to   v-num                  .
           move      w-cod-cod-lgv-alf    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cod-com-999.
       acc-cod-com-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-num-com             .
           move      v-alf                to   rr-alf-com             .
       acc-cod-com-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-com-420.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [lgv]                      *
      *                  *---------------------------------------------*
           move      rr-num-com           to   w-let-arc-lgv-num      .
           perform   let-arc-lgv-000      thru let-arc-lgv-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione, unita' di mi-   *
      *                  * sura, e numero decimali quantita' assieme   *
      *                  *---------------------------------------------*
           move      w-let-arc-lgv-des    to   rr-des-com             .
           move      w-let-arc-lgv-umi    to   rr-umi-com             .
           move      w-let-arc-lgv-deq    to   rr-deq-com             .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-com-000      thru vis-des-com-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non trovato : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-lgv-flg    not  = spaces
                     go to acc-cod-com-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione a meno  *
      *                  * che non sia stato premuto 'Up'              *
      *                  *---------------------------------------------*
           if        rr-alf-com           not  = spaces
                     go to acc-cod-com-440.
           if        v-key                =    "UP  "
                     go to acc-cod-com-600
           else      go to acc-cod-com-100.
       acc-cod-com-440.
      *                  *---------------------------------------------*
      *                  * Fine controlli                              *
      *                  *---------------------------------------------*
           go to     acc-cod-com-600.
       acc-cod-com-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-com-625.
      *                  *---------------------------------------------*
      *                  * Normalizzazione e visualizzazione della     *
      *                  * quantita' da implodere in funzione del      *
      *                  * numero decimali quantita'                   *
      *                  *---------------------------------------------*
           if        rr-deq-com           =    zero
                     divide   1000        into rr-qdi-com
                     multiply 1000        by   rr-qdi-com
           else if   rr-deq-com           =    1
                     divide   100         into rr-qdi-com
                     multiply 100         by   rr-qdi-com
           else if   rr-deq-com           =    2
                     divide   10          into rr-qdi-com
                     multiply 10          by   rr-qdi-com
           else if   rr-deq-com           =    3
                     divide   1           into rr-qdi-com
                     multiply 1           by   rr-qdi-com
           else      divide   1000        into rr-qdi-com
                     multiply 1000        by   rr-qdi-com             .
           perform   vis-qdi-com-000      thru vis-qdi-com-999        .
       acc-cod-com-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cod-com-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cod-com-100.
       acc-cod-com-999.
           exit.

