                     move  03             to   w-rig-tpm-cpt (1)
           else if   v-alf                =    "D  "
                     move  99             to   w-rig-tpm-cpt (1)
           else      move  00             to   w-rig-tpm-cpt (1)      .
       acc-tpm-cpt-425.
       acc-tpm-cpt-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tpm-cpt (1)    =    zero
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
