      *    *===========================================================*
      *    * Accettazione campo chiave : Tipo distinta                 *
      *    *-----------------------------------------------------------*
       acc-tpm-ass-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tpm-ass        to   w-sav-tpm-ass          .
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           move      w-def-tpm-ass        to   w-tes-tpm-ass          .
       acc-tpm-ass-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tpm-ass-lun    to   v-car                  .
           move      w-exp-tpm-ass-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tpm-ass-tbl    to   v-txt                  .
           move      04                   to   v-lin                  .
           move      26                   to   v-pos                  .
           if        w-tes-tpm-ass        =    01
                     move  01             to   v-num
           else if   w-tes-tpm-ass        =    02
                     move  02             to   v-num
           else if   w-tes-tpm-ass        =    99
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-tpm-ass-999.
       acc-tpm-ass-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tpm-ass
           else if   v-num                =    02
                     move  02             to   w-tes-tpm-ass
           else if   v-num                =    03
                     move  99             to   w-tes-tpm-ass
           else      move  zero           to   w-tes-tpm-ass          .
      *              *-------------------------------------------------*
      *              * Preparazione default per accettazione successi- *
      *              * va                                              *
      *              *-------------------------------------------------*
           move      w-tes-tpm-ass        to   w-def-tpm-ass          .
       acc-tpm-ass-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che il valore sia accettabile          *
      *                  *---------------------------------------------*
           if        w-tes-tpm-ass        =    zero
                     go to acc-tpm-ass-100.
       acc-tpm-ass-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione codice e descrizione della  *
      *                  * distinta                                    *
      *                  *---------------------------------------------*
           if        w-tes-nrm-ass        =    zero
                     go to acc-tpm-ass-800.
           move      zero                 to   w-tes-nrm-ass          .
           move      spaces               to   w-tes-afm-ass          .
           move      spaces               to   w-tes-nrm-ass-des      .
           move      zero                 to   w-tes-nrm-ass-deq      .
           perform   vis-nrm-ass-000      thru vis-nrm-ass-999        .
           perform   vis-des-ass-000      thru vis-des-ass-999        .
       acc-tpm-ass-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-tpm-ass-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-tpm-ass-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-tpm-ass-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-tpm-ass-999.
       acc-tpm-ass-999.
           exit.

