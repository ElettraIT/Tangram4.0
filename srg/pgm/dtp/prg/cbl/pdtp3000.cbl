      *    *===========================================================*
      *    * Controllo che la distinta base non sia presente in altre  *
      *    * distinte come componente                                  *
      *    *-----------------------------------------------------------*
       ctl-dst-dst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-dst-dst-exi      .
      *              *-------------------------------------------------*
      *              * Lettura righe distinte [lgr]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CPTASS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-ctl-dst-dst-tpm    to   rf-lgr-tpm-cpt         .
           move      w-ctl-dst-dst-nrm    to   rf-lgr-nrm-cpt         .
           move      zero                 to   rf-lgr-tpm-ass         .
           move      zero                 to   rf-lgr-nrm-ass         .
           move      zero                 to   rf-lgr-num-prg         .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita Ok              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  ctl-dst-dst-999.
       ctl-dst-dst-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [lgr]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita Ok                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  ctl-dst-dst-999.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : uscita Ok             *
      *                  *---------------------------------------------*
           if        rf-lgr-tpm-cpt       not  = w-ctl-dst-dst-tpm or
                     rf-lgr-nrm-cpt       not  = w-ctl-dst-dst-nrm
                     go to  ctl-dst-dst-999.
      *                  *---------------------------------------------*
      *                  * Se il record letto appartiene all'assieme   *
      *                  * in esame, lo si ignora                      *
      *                  *---------------------------------------------*
           if        rf-lgr-tpm-ass       =    w-ctl-dst-dst-tpm and
                     rf-lgr-nrm-ass       =    w-ctl-dst-dst-nrm
                     go to ctl-dst-dst-100.
      *                  *---------------------------------------------*
      *                  * ALtrimenti si esce per Ko                   *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ctl-dst-dst-exi      .
       ctl-dst-dst-999.
           exit.

      *    *===========================================================*
      *    * Controllo di non-involuzione della distinta base che si   *
      *    * trova depositata nella catena 'rig'                       *
      *    *                                                           *
      *    * Input  : w-ctl-nid-tpm-ass = tipo magazzino dell'assieme  *
      *    *                              da controllare               *
      *    *                                                           *
      *    *          w-ctl-nid-nrm-ass = codice numerico magazzino    *
      *    *                              dell'assieme da controllare  *
      *    *                                                           *
      *    *          w-ctl-nid-afm-ass = codice alfanumerico magazzi- *
      *    *                              no dell' assieme da control- *
      *    *                              lare                         *
      *    *                                                           *
      *    *          w-cat-rig         = area di comunicazione per    *
      *    *                              la catena 'rig' relativa     *
      *    *                              alle righe dell'assieme      *
      *    *                                                           *
      *    *                                                           *
      *    *                                                           *
      *    * Output : w-ctl-nid-flg-exi = flag di uscita               *
      *    *                              - Spaces : Ok, non involve   *
      *    *                              - #      : Ko, involuzione   *
      *    *                                                           *
      *    *          w-ctl-nid-ter-exi = tipo di errore in uscita :   *
      *    *                                                           *
      *    *                              01) Un componente incontrato *
      *    *                              durante l'esplosione della   *
      *    *                              distinta corrisponde ad una  *
      *    *                              delle sub-distinte gia' in   *
      *    *                              corso di esame durante       *
      *    *                              l'esplosione stessa, oppure  *
      *    *                              addirittura alla distinta    *
      *    *                              stessa da esaminare.         *
      *    *                                                           *
      *    *                              02) L'esplosione della dis-  *
      *    *                              tinta comporta un livello di *
      *    *                              profondita' maggiore del     *
      *    *                              massimo numero di livelli    *
      *    *                              consentito per una distinta  *
      *    *                              come definito dal valore del *
      *    *                              campo 'w-ctl-nid-max-liv'    *
      *    *                                                           *
      *    *          w-ctl-nid-tpm-exi = tipo magazzino del componen- *
      *    *                              te della distinta base che   *
      *    *                              ha determinato involuzione   *
      *    *                                                           *
      *    *          w-ctl-nid-nrm-exi = codice numerico magazzino    *
      *    *                              del componente della distin- *
      *    *                              ta base che ha determinato   *
      *    *                              involuzione                  *
      *    *                                                           *
      *    *          w-ctl-nid-afm-exi = codice alfanumerico magazzi- *
      *    *                              no del componente della di-  *
      *    *                              stinta base che ha determi-  *
      *    *                              nato involuzione             *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       ctl-nid-cat-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-nid-flg-exi      .
      *              *-------------------------------------------------*
      *              * Salvataggio parametri della catena 'rig'        *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-ctl-nid-sav-cat      .
      *              *-------------------------------------------------*
      *              * Salvataggio attuale contenuto area 'w-rig'      *
      *              *-------------------------------------------------*
           move      w-rig                to   w-ctl-nid-sav-wri      .
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore livello attuale di   *
      *              * profondita' durante la scansione della distinta *
      *              * base                                            *
      *              *-------------------------------------------------*
           move      1                    to   w-ctl-nid-liv-att      .
      *              *-------------------------------------------------*
      *              * Inizializzazione 1. livello della distinta      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo magazzino per l'assieme in esame       *
      *                  *---------------------------------------------*
           move      w-ctl-nid-tpm-ass    to   w-ctl-nid-buf-tma (1)  .
      *                  *---------------------------------------------*
      *                  * Codice numerico magazzino per l'assieme in  *
      *                  * esame                                       *
      *                  *---------------------------------------------*
           move      w-ctl-nid-nrm-ass    to   w-ctl-nid-buf-nma (1)  .
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico magazzino per l'assieme *
      *                  * in esame                                    *
      *                  *---------------------------------------------*
           move      w-ctl-nid-afm-ass    to   w-ctl-nid-buf-ama (1)  .
      *                  *---------------------------------------------*
      *                  * Numero progressivo elemento della distinta  *
      *                  * in esame a questo livello di profondita'    *
      *                  *---------------------------------------------*
           move      zero                 to   w-ctl-nid-buf-prg (1)  .
      *                  *---------------------------------------------*
      *                  * Tipo magazzino per il componente in esame   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ctl-nid-buf-tmc (1)  .
      *                  *---------------------------------------------*
      *                  * Codice numerico magazzino per il componente *
      *                  * in esame                                    *
      *                  *---------------------------------------------*
           move      zero                 to   w-ctl-nid-buf-nmc (1)  .
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico magazzino per il compo- *
      *                  * nente in esame                              *
      *                  *---------------------------------------------*
           move      spaces               to   w-ctl-nid-buf-amc (1)  .
       ctl-nid-cat-100.
      *              *-------------------------------------------------*
      *              * Start su livello di profondita'                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero di livel- *
      *                  * lo di profondita' attuale                   *
      *                  *---------------------------------------------*
           if        w-ctl-nid-liv-att    =    01
                     go to ctl-nid-cat-120
           else      go to ctl-nid-cat-160.
       ctl-nid-cat-120.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale = 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'attuale nume- *
      *                      * ro progressivo elemento in esame        *
      *                      *-----------------------------------------*
           if        w-ctl-nid-buf-prg (1)
                                          =    zero
                     go to ctl-nid-cat-130
           else      go to ctl-nid-cat-140.
       ctl-nid-cat-130.
      *                      *-----------------------------------------*
      *                      * Se dell'attuale numero progressivo ele- *
      *                      * mento in esame pari a zero              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Operazione di Start su catena 'rig' *
      *                          *-------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      00001                to   w-cat-rig-num          .
           call      "pgm/dtp/prg/obj/pdtp3002"
                                         using w-cat-rig              .
      *                          *-------------------------------------*
      *                          * Deviazione a seconda dell'esito     *
      *                          * della Start                         *
      *                          * - Se Ok : a Read Next               *
      *                          * - Se Ko : a Decremento di livello   *
      *                          *-------------------------------------*
           if        w-cat-rig-exs        =    spaces
                     go to ctl-nid-cat-300
           else      go to ctl-nid-cat-200.
       ctl-nid-cat-140.
      *                      *-----------------------------------------*
      *                      * Se dell'attuale numero progressivo ele- *
      *                      * mento in esame maggiore di zero         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Direttamente e Read Next            *
      *                          *-------------------------------------*
           go to     ctl-nid-cat-300.
       ctl-nid-cat-160.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale > 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start su [lgr] per l'assieme in esame,  *
      *                      * per numeri progressivi maggiori del nu- *
      *                      * mero progressivo ultimo gia' esaminato  *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "TNMASS"             to   f-key                  .
           move      "GT"                 to   f-cfr                  .
           move      w-ctl-nid-buf-tma
                    (w-ctl-nid-liv-att)   to   rf-lgr-tpm-ass         .
           move      w-ctl-nid-buf-nma
                    (w-ctl-nid-liv-att)   to   rf-lgr-nrm-ass         .
           move      w-ctl-nid-buf-prg
                    (w-ctl-nid-liv-att)   to   rf-lgr-num-prg         .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito della   *
      *                      * Start                                   *
      *                      * - Se Ok : a Read Next                   *
      *                      * - Se Ko : a Decremento di livello       *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to ctl-nid-cat-300
           else      go to ctl-nid-cat-200.
       ctl-nid-cat-200.
      *              *-------------------------------------------------*
      *              * Decremento livello di profondita'               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Decremento                                  *
      *                  *---------------------------------------------*
           subtract  1                    from w-ctl-nid-liv-att      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del nuovo valore del   *
      *                  * livello di profondita'                      *
      *                  * - Se = zero : Ad uscita per non involuzione *
      *                  * - Se > zero : Riciclo a Start su livello    *
      *                  *---------------------------------------------*
           if        w-ctl-nid-liv-att    =    zero
                     go to ctl-nid-cat-900
           else      go to ctl-nid-cat-100.
       ctl-nid-cat-300.
      *              *-------------------------------------------------*
      *              * Read Next a livello di profondita'              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero di livel- *
      *                  * lo di profondita' attuale                   *
      *                  *---------------------------------------------*
           if        w-ctl-nid-liv-att    =    01
                     go to ctl-nid-cat-320
           else      go to ctl-nid-cat-360.
       ctl-nid-cat-320.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale = 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Operazione di Read Next su catena 'rig' *
      *                      *-----------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           call      "pgm/dtp/prg/obj/pdtp3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito della   *
      *                      * Read                                    *
      *                      * - Se Ok : a Test Max                    *
      *                      * - Se Ko : a Decremento di livello       *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        =    spaces
                     go to ctl-nid-cat-400
           else      go to ctl-nid-cat-200.
       ctl-nid-cat-360.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale > 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Read Next su [lgr]                      *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito della   *
      *                      * Read                                    *
      *                      * - Se Ok : a Test Max                    *
      *                      * - Se Ko : a Decremento di livello       *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to ctl-nid-cat-400
           else      go to ctl-nid-cat-200.
       ctl-nid-cat-400.
      *              *-------------------------------------------------*
      *              * Test max su livello di profondita'              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero di livel- *
      *                  * lo di profondita' attuale                   *
      *                  *---------------------------------------------*
           if        w-ctl-nid-liv-att    =    01
                     go to ctl-nid-cat-420
           else      go to ctl-nid-cat-460.
       ctl-nid-cat-420.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale = 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessun Test Max; direttamente ad esame  *
      *                      * componente letto                        *
      *                      *-----------------------------------------*
           go to     ctl-nid-cat-500.
       ctl-nid-cat-460.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale > 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test e deviazione a seconda dell'esito  *
      *                      * del test                                *
      *                      * - Se Ok : a Esame componente letto      *
      *                      * - Se Ko : a Decremento di livello       *
      *                      *-----------------------------------------*
           if        rf-lgr-tpm-ass       =    w-ctl-nid-buf-tma
                                              (w-ctl-nid-liv-att) and
                     rf-lgr-nrm-ass       =    w-ctl-nid-buf-nma
                                              (w-ctl-nid-liv-att)
                     go to ctl-nid-cat-500
           else      go to ctl-nid-cat-200.
       ctl-nid-cat-500.
      *              *-------------------------------------------------*
      *              * Esame componente letto                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero di livel- *
      *                  * lo di profondita' attuale                   *
      *                  *---------------------------------------------*
           if        w-ctl-nid-liv-att    =    01
                     go to ctl-nid-cat-520
           else      go to ctl-nid-cat-560.
       ctl-nid-cat-520.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale = 01      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da area della catena ad a-  *
      *                      * rea di ridefinizione 'w-rig'            *
      *                      *-----------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
       ctl-nid-cat-525.
      *                      *-----------------------------------------*
      *                      * Test che l'elemento letto non corri-    *
      *                      * sponda ad una delle distinte gia' in    *
      *                      * corso di esame; se non e' cosi' si e-   *
      *                      * sce per involuzione                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-ctl-nid-liv-inx       .
       ctl-nid-cat-526.
           add       1                    to   w-ctl-nid-liv-inx       .
           if        w-ctl-nid-liv-inx    >    w-ctl-nid-liv-att
                     go to ctl-nid-cat-530.
           if        w-ctl-nid-buf-tma
                    (w-ctl-nid-liv-inx)   =    w-rig-tpm-cpt (1) and
                     w-ctl-nid-buf-nma
                    (w-ctl-nid-liv-inx)   =    w-rig-nrm-cpt (1)
                     go to ctl-nid-cat-527
           else      go to ctl-nid-cat-526.
       ctl-nid-cat-527.
      *                      *-----------------------------------------*
      *                      * Uscita per involuzione                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di uscita ad errore            *
      *                          *-------------------------------------*
           move      "#"                  to   w-ctl-nid-flg-exi      .
      *                          *-------------------------------------*
      *                          * Tipo di errore in uscita : 01       *
      *                          *-------------------------------------*
           move      01                   to   w-ctl-nid-ter-exi      .
      *                          *-------------------------------------*
      *                          * Tipo magazzino del componente al    *
      *                          * 1. livello che ha determinato in-   *
      *                          * voluzione                           *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-tmc (1)
                                          to   w-ctl-nid-tpm-exi      .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino del com-  *
      *                          * ponente al 1. livello che ha deter- *
      *                          * minato involuzione                  *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-nmc (1)
                                          to   w-ctl-nid-nrm-exi      .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino del   *
      *                          * componente al 1. livello che ha     *
      *                          * determinato involuzione             *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-amc (1)
                                          to   w-ctl-nid-afm-exi      .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     ctl-nid-cat-900.
       ctl-nid-cat-530.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione componente in esame     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Numero progressivo                  *
      *                          *-------------------------------------*
           move      w-rig-num-prg (1)    to   w-ctl-nid-buf-prg
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Tipo magazzino componente           *
      *                          *-------------------------------------*
           move      w-rig-tpm-cpt (1)    to   w-ctl-nid-buf-tmc
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino componen- *
      *                          * te                                  *
      *                          *-------------------------------------*
           move      w-rig-nrm-cpt (1)    to   w-ctl-nid-buf-nmc
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino com-  *
      *                          * ponente                             *
      *                          *-------------------------------------*
           move      w-rig-afm-cpt (1)    to   w-ctl-nid-buf-amc
                                              (w-ctl-nid-liv-att)     .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo di ele-   *
      *                      * mento                                   *
      *                      * - Se l'elemento ha una sua propria di-  *
      *                      *   stinta base si va' a Incremento di    *
      *                      *   livello                               *
      *                      * - Se l'elemento non ha una sua propria  *
      *                      *   distinta base, ovvero e' un elemento  *
      *                      *   semplice, si ricicla sulla Read Next  *
      *                      *   allo stesso livello di profondita'    *
      *                      *-----------------------------------------*
           if        w-rig-tpm-cpt (1)    =    02 or
                     w-rig-tpm-cpt (1)    =    99
                     go to ctl-nid-cat-600
           else      go to ctl-nid-cat-300.
       ctl-nid-cat-560.
      *                  *---------------------------------------------*
      *                  * Se livello di profondita' attuale > 01      *
      *                  *---------------------------------------------*
       ctl-nid-cat-565.
      *                      *-----------------------------------------*
      *                      * Test che l'elemento letto non corri-    *
      *                      * sponda ad una delle distinte gia' in    *
      *                      * corso di esame; se non e' cosi' si e-   *
      *                      * sce per involuzione                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-ctl-nid-liv-inx       .
       ctl-nid-cat-566.
           add       1                    to   w-ctl-nid-liv-inx       .
           if        w-ctl-nid-liv-inx    >    w-ctl-nid-liv-att
                     go to ctl-nid-cat-570.
           if        w-ctl-nid-buf-tma
                    (w-ctl-nid-liv-inx)   =    rf-lgr-tpm-cpt and
                     w-ctl-nid-buf-nma
                    (w-ctl-nid-liv-inx)   =    rf-lgr-nrm-cpt
                     go to ctl-nid-cat-567
           else      go to ctl-nid-cat-566.
       ctl-nid-cat-567.
      *                      *-----------------------------------------*
      *                      * Uscita per involuzione                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di uscita ad errore            *
      *                          *-------------------------------------*
           move      "#"                  to   w-ctl-nid-flg-exi      .
      *                          *-------------------------------------*
      *                          * Tipo di errore in uscita : 01       *
      *                          *-------------------------------------*
           move      01                   to   w-ctl-nid-ter-exi      .
      *                          *-------------------------------------*
      *                          * Tipo magazzino del componente al    *
      *                          * 1. livello che ha determinato in-   *
      *                          * voluzione                           *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-tmc (1)
                                          to   w-ctl-nid-tpm-exi      .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino del com-  *
      *                          * ponente al 1. livello che ha deter- *
      *                          * minato involuzione                  *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-nmc (1)
                                          to   w-ctl-nid-nrm-exi      .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino del   *
      *                          * componente al 1. livello che ha     *
      *                          * determinato involuzione             *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-amc (1)
                                          to   w-ctl-nid-afm-exi      .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     ctl-nid-cat-900.
       ctl-nid-cat-570.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione componente in esame     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Numero progressivo                  *
      *                          *-------------------------------------*
           move      rf-lgr-num-prg       to   w-ctl-nid-buf-prg
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Tipo magazzino componente           *
      *                          *-------------------------------------*
           move      rf-lgr-tpm-cpt       to   w-ctl-nid-buf-tmc
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino componen- *
      *                          * te                                  *
      *                          *-------------------------------------*
           move      rf-lgr-nrm-cpt       to   w-ctl-nid-buf-nmc
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino com-  *
      *                          * ponente                             *
      *                          *-------------------------------------*
           move      rf-lgr-afm-cpt       to   w-ctl-nid-buf-amc
                                              (w-ctl-nid-liv-att)     .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo di ele-   *
      *                      * mento                                   *
      *                      * - Se l'elemento ha una sua propria di-  *
      *                      *   stinta base si va' a Incremento di    *
      *                      *   livello                               *
      *                      * - Se l'elemento non ha una sua propria  *
      *                      *   distinta base, ovvero e' un elemento  *
      *                      *   semplice, si ricicla sulla Read Next  *
      *                      *   allo stesso livello di profondita'    *
      *                      *-----------------------------------------*
           if        rf-lgr-tpm-cpt       =    02 or
                     rf-lgr-tpm-cpt       =    99
                     go to ctl-nid-cat-600
           else      go to ctl-nid-cat-300.
       ctl-nid-cat-600.
      *              *-------------------------------------------------*
      *              * Incremento di livello                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero di livello attuale in area di comodo *
      *                  *---------------------------------------------*
           move      w-ctl-nid-liv-att    to   w-ctl-nid-liv-inx      .
      *                  *---------------------------------------------*
      *                  * Incremento numero di livello attuale        *
      *                  *---------------------------------------------*
           add       1                    to   w-ctl-nid-liv-att      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se si e' superato op-  *
      *                  * pure no il massimo livello di profondita'   *
      *                  * consentito per una distinta                 *
      *                  *---------------------------------------------*
           if        w-ctl-nid-liv-att    >    w-ctl-nid-max-liv
                     go to ctl-nid-cat-620
           else      go to ctl-nid-cat-660.
       ctl-nid-cat-620.
      *                  *---------------------------------------------*
      *                  * Se si e' superato il massimo livello di     *
      *                  * profondita consentito per una distinta      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita per involuzione                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di uscita ad errore            *
      *                          *-------------------------------------*
           move      "#"                  to   w-ctl-nid-flg-exi      .
      *                          *-------------------------------------*
      *                          * Tipo di errore in uscita : 02       *
      *                          *-------------------------------------*
           move      02                   to   w-ctl-nid-ter-exi      .
      *                          *-------------------------------------*
      *                          * Tipo magazzino del componente al    *
      *                          * 1. livello che ha determinato in-   *
      *                          * voluzione                           *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-tmc (1)
                                          to   w-ctl-nid-tpm-exi      .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino del com-  *
      *                          * ponente al 1. livello che ha deter- *
      *                          * minato involuzione                  *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-nmc (1)
                                          to   w-ctl-nid-nrm-exi      .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino del   *
      *                          * componente al 1. livello che ha     *
      *                          * determinato involuzione             *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-amc (1)
                                          to   w-ctl-nid-afm-exi      .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     ctl-nid-cat-900.
       ctl-nid-cat-660.
      *                  *---------------------------------------------*
      *                  * Se non si e' superato il massimo livello di *
      *                  * profondita consentito per una distinta      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione nuovo livello di pro-  *
      *                      * fondita'                                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo magazzino per l'assieme in e-  *
      *                          * same                                *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-tmc
                    (w-ctl-nid-liv-inx)   to   w-ctl-nid-buf-tma
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino per l'as- *
      *                          * sieme in esame                      *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-nmc
                    (w-ctl-nid-liv-inx)   to   w-ctl-nid-buf-nma
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino per   *
      *                          * l'assieme in esame                  *
      *                          *-------------------------------------*
           move      w-ctl-nid-buf-amc
                    (w-ctl-nid-liv-inx)   to   w-ctl-nid-buf-ama
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Numero progressivo elemento della   *
      *                          * distinta in esame al nuovo livel-   *
      *                          * lo di profondita'                   *
      *                          *-------------------------------------*
           move      zero                 to   w-ctl-nid-buf-prg
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Tipo magazzino per il componente in *
      *                          * esame                               *
      *                          *-------------------------------------*
           move      zero                 to   w-ctl-nid-buf-tmc
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice numerico magazzino per il    *
      *                          * componente in esame                 *
      *                          *-------------------------------------*
           move      zero                 to   w-ctl-nid-buf-nmc
                                              (w-ctl-nid-liv-att)     .
      *                          *-------------------------------------*
      *                          * Codice alfanumerico magazzino per   *
      *                          * il componente in esame              *
      *                          *-------------------------------------*
           move      spaces               to   w-ctl-nid-buf-amc
                                              (w-ctl-nid-liv-att)     .
      *                      *-----------------------------------------*
      *                      * Riciclo a Start su nuovo livello di     *
      *                      * profondita                              *
      *                      *-----------------------------------------*
           go to     ctl-nid-cat-100.
       ctl-nid-cat-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino parametri della catena 'rig'     *
      *                  *---------------------------------------------*
           move      w-ctl-nid-sav-cat    to   w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Ripristino contenuto area 'w-rig'           *
      *                  *---------------------------------------------*
           move      w-ctl-nid-sav-wri    to   w-rig                  .
       ctl-nid-cat-999.
           exit.

      *    *===========================================================*
      *    * Controllo di non-ripetizione dello stesso componente in   *
      *    * distinta base                                             *
      *    *                                                           *
      *    * Input  : w-cat-rig         = area di comunicazione per    *
      *    *                              la catena 'rig' relativa     *
      *    *                              alle righe dell'assieme      *
      *    *                                                           *
      *    *                                                           *
      *    *                                                           *
      *    * Output : w-ctl-nrc-flg-exi = flag di uscita               *
      *    *                              - Spaces : Ok                *
      *    *                              - #      : Ko                *
      *    *                                                           *
      *    *          w-ctl-nrc-tpm-cpt = tipo magazzino del componen- *
      *    *                              te della distinta base che   *
      *    *                              si ripete                    *
      *    *                                                           *
      *    *          w-ctl-nrc-afm-cpt = codice alfanumerico magazzi- *
      *    *                              no del componente della di-  *
      *    *                              stinta base che si ripete    *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       ctl-nrc-cpt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-nrc-flg-exi      .
      *              *-------------------------------------------------*
      *              * Salvataggio parametri della catena 'rig'        *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-ctl-nrc-sav-cat      .
      *              *-------------------------------------------------*
      *              * Salvataggio attuale contenuto area 'w-rig'      *
      *              *-------------------------------------------------*
           move      w-rig                to   w-ctl-nrc-sav-wri      .
      *              *-------------------------------------------------*
      *              * Inizializzazione elementi nel buffer            *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-nrc-inx-001      .
       ctl-nrc-cpt-100.
      *              *-------------------------------------------------*
      *              * Operazione di Start su catena 'rig'             *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      00001                to   w-cat-rig-num          .
           call      "pgm/dtp/prg/obj/pdtp3002"
                                         using w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Se Start errata : controllo superato            *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to ctl-nrc-cpt-900.
       ctl-nrc-cpt-200.
      *              *-------------------------------------------------*
      *              * Operazione di Read Next su catena 'rig'         *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           call      "pgm/dtp/prg/obj/pdtp3002"
                                         using w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Se Fine Catena : controllo superato             *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to ctl-nrc-cpt-900.
       ctl-nrc-cpt-300.
      *              *-------------------------------------------------*
      *              * Spostamento da area della catena ad area di ri- *
      *              * definizione 'w-rig'                             *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
       ctl-nrc-cpt-400.
      *              *-------------------------------------------------*
      *              * Incremento elementi nel buffer                  *
      *              *-------------------------------------------------*
           add       1                    to   w-ctl-nrc-inx-001      .
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : controllo superato        *
      *              *-------------------------------------------------*
           if        w-ctl-nrc-inx-001    >    w-ctl-nrc-inx-max
                     go to ctl-nrc-cpt-900.
