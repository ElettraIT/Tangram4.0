           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           if        v-key                =    "DO  " or
                     v-key                =    "EXIT"
                     go to box-err-nrc-700.
           if        v-alf                not  = "OK"
                     go to box-err-nrc-650.
       box-err-nrc-700.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       box-err-nrc-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione funzione di duplicazione distinta              *
      *    *-----------------------------------------------------------*
       exe-fun-dup-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-exe-fun-dup-flg      .
      *              *-------------------------------------------------*
      *              * Salvataggio video attuale                       *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione richieste di selezione             *
      *              *-------------------------------------------------*
           perform   imp-dis-dup-000      thru imp-dis-dup-999        .
      *                  *---------------------------------------------*
      *                  * Se uscita per Exit                          *
      *                  *---------------------------------------------*
           if        w-imp-dis-dup-sel    =    "E"
                     move  "#"            to   w-exe-fun-dup-flg
                     go to exe-fun-dup-900.
      *              *-------------------------------------------------*
      *              * Esecuzione duplicazione righe                   *
      *              *-------------------------------------------------*
           perform   exe-dup-rig-000      thru exe-dup-rig-999        .
       exe-fun-dup-900.
      *              *-------------------------------------------------*
      *              * Rispristino video precedentemente salvato       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-fun-dup-999.
           exit.

      *    *===========================================================*
      *    * Impostazione parametri distinta da duplicare              *
      *    *-----------------------------------------------------------*
       imp-dis-dup-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-imp-dis-dup-sel      .
      *              *-------------------------------------------------*
      *              * Normalizzazione parametri di selezione          *
      *              *-------------------------------------------------*
           move      zero                 to   w-dup-tpm-dup          .
           move      zero                 to   w-dup-nrm-dup          .
           move      spaces               to   w-dup-nrm-dup-des      .
           move      spaces               to   w-dup-afm-dup          .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box internamente vuoto                      *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      21                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Titolo centrale                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "Pre-caricamento righe da altra distinta"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "---------------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Prompt per Tipo distinta                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Tipo   distinta    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Prompt per Codice distinta                  *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Codice distinta    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       imp-dis-dup-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Tipo distinta da duplicare                  *
      *                  *---------------------------------------------*
           perform   acc-tpm-dup-000      thru acc-tpm-dup-999        .
           if        w-imp-dis-dup-sel    not  = spaces
                     go to imp-dis-dup-999.
       imp-dis-dup-200.
      *                  *---------------------------------------------*
      *                  * Codice distinta da duplicare                *
      *                  *---------------------------------------------*
           perform   acc-nrm-dup-000      thru acc-nrm-dup-999        .
           if        w-imp-dis-dup-sel    not  = spaces
                     go to imp-dis-dup-999.
           if        v-key                =    "UP  "
                     go to imp-dis-dup-100.
       imp-dis-dup-900.
      *                  *---------------------------------------------*
      *                  * Prompt per conferma                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      31                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Conferma impostazioni (S/N/E) ?"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       imp-dis-dup-910.
      *                  *---------------------------------------------*
      *                  * Accettazione conferma                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      "S"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione risposta utente             *
      *                  *---------------------------------------------*
           if        v-key                not  = spaces
                     go to imp-dis-dup-920.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "EXIT"        to   v-key
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key
           else      go to imp-dis-dup-910.
       imp-dis-dup-920.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to imp-dis-dup-930
           else if   v-key                =    "EXIT"
                     go to imp-dis-dup-940
           else if   v-key                =    "UP  "
                     go to imp-dis-dup-950
           else      go to imp-dis-dup-910.
       imp-dis-dup-930.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           perform   tdo-ric-sel-000      thru tdo-ric-sel-999        .
           if        w-imp-dis-dup-flg    =    spaces
                     move  "S"            to   w-imp-dis-dup-sel
                     go to imp-dis-dup-999
           else      move  spaces         to   w-imp-dis-dup-flg
                     go to imp-dis-dup-900.
       imp-dis-dup-940.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
           move      "E"                  to   w-imp-dis-dup-sel      .
           go to     imp-dis-dup-999.
       imp-dis-dup-950.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazioni                         *
      *                      *-----------------------------------------*
           go to     imp-dis-dup-100.
       imp-dis-dup-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Tipo distinta da duplicare *
      *    *-----------------------------------------------------------*
       acc-tpm-dup-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-dup-tpm-dup        to   w-sav-tpm-dup          .
       acc-tpm-dup-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tpm-ass-lun    to   v-car                  .
           move      w-exp-tpm-ass-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tpm-ass-tbl    to   v-txt                  .
           move      13                   to   v-lin                  .
           move      24                   to   v-pos                  .
           if        w-dup-tpm-dup        =    01
                     move  01             to   v-num
           else if   w-dup-tpm-dup        =    02
                     move  02             to   v-num
           else if   w-dup-tpm-dup        =    99
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-imp-dis-dup-sel
                     go to acc-tpm-dup-999.
       acc-tpm-dup-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  01             to   w-dup-tpm-dup 
           else if   v-num                =    02
                     move  02             to   w-dup-tpm-dup
           else if   v-num                =    03
                     move  99             to   w-dup-tpm-dup
           else      move  zero           to   w-dup-tpm-dup          .
       acc-tpm-dup-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che il valore sia accettabile          *
      *                  *---------------------------------------------*
           if        w-dup-tpm-dup        =    zero
                     go to acc-tpm-dup-100.
       acc-tpm-dup-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-dup-tpm-dup        =    w-sav-tpm-dup
                     go to acc-tpm-dup-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione codice e descrizione della  *
      *                  * distinta                                    *
      *                  *---------------------------------------------*
           if        w-dup-nrm-dup        =    zero
                     go to acc-tpm-dup-800.
           move      zero                 to   w-dup-nrm-dup          .
           move      spaces               to   w-dup-afm-dup          .
           move      spaces               to   w-dup-nrm-dup-des      .
           perform   vis-nrm-dup-000      thru vis-nrm-dup-999        .
           perform   vis-nrm-dup-des-000  thru vis-nrm-dup-des-999    .
       acc-tpm-dup-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-imp-dis-dup-flg
                                          =    spaces
                             move  "S"    to   w-imp-dis-dup-sel
                             go to acc-tpm-dup-999
                     else    move  spaces to   w-imp-dis-dup-flg
                             go to acc-tpm-dup-100.
       acc-tpm-dup-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Codice distinta da duplic. *
      *    *-----------------------------------------------------------*
       acc-nrm-dup-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di distinta     *
      *              *-------------------------------------------------*
           if        w-dup-tpm-dup        =    01
                     go to acc-nrm-dup-200
           else if   w-dup-tpm-dup        =    02
                     go to acc-nrm-dup-400
           else if   w-dup-tpm-dup        =    99
                     go to acc-nrm-dup-600
           else      go to acc-nrm-dup-999.
       acc-nrm-dup-200.
      *                  *---------------------------------------------*
      *                  * Se Prodotto di vendita                      *
      *                  *---------------------------------------------*
           perform   acc-pro-dup-000      thru acc-pro-dup-999        .
           go to     acc-nrm-dup-999.
       acc-nrm-dup-400.
      *                  *---------------------------------------------*
      *                  * Se Semilavorato                             *
      *                  *---------------------------------------------*
           perform   acc-sem-dup-000      thru acc-sem-dup-999        .
           go to     acc-nrm-dup-999.
       acc-nrm-dup-600.
      *                  *---------------------------------------------*
      *                  * Se Distinta virtuale                        *
      *                  *---------------------------------------------*
           perform   acc-lgv-dup-000      thru acc-lgv-dup-999        .
           go to     acc-nrm-dup-999.
       acc-nrm-dup-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Codice distinta da dup. *
      *    *-----------------------------------------------------------*
       vis-nrm-dup-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      24                   to   v-pos                  .
           move      w-dup-afm-dup        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nrm-dup-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Descrizione distinta da *
      *    * duplicare                                                 *
      *    *-----------------------------------------------------------*
       vis-nrm-dup-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      39                   to   v-pos                  .
           move      w-dup-nrm-dup-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nrm-dup-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Codice prodotto da duplic. *
      *    *-----------------------------------------------------------*
       acc-pro-dup-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-pro-dup-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      w-dup-nrm-dup        to   w-cod-cod-dcp-num      .
           move      w-dup-afm-dup        to   w-cod-cod-dcp-alf      .
           move      15                   to   w-cod-cod-dcp-lin      .
           move      24                   to   w-cod-cod-dcp-pos      .
           move      15                   to   w-cod-cod-dcp-dln      .
           move      39                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-pro-dup-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-pro-dup-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-pro-dup-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-pro-dup-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-pro-dup-110.
       acc-pro-dup-120.
           move      w-cod-cod-dcp-num    to   v-num                  .
           move      w-cod-cod-dcp-alf    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-imp-dis-dup-sel
                     go to acc-pro-dup-999.
       acc-pro-dup-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-dup-nrm-dup          .
           move      v-alf                to   w-dup-afm-dup          .
       acc-pro-dup-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-dup-nrm-dup        to   w-let-arc-dcp-num      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-des    to   w-dup-nrm-dup-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nrm-dup-des-000  thru vis-nrm-dup-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non trovato : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-pro-dup-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione a meno  *
      *                  * che non sia stato premuto 'Up'              *
      *                  *---------------------------------------------*
           if        w-dup-afm-dup        not  = spaces
                     go to acc-pro-dup-500.
           if        v-key                =    "UP  "
                     go to acc-pro-dup-600
           else      go to acc-pro-dup-100.
       acc-pro-dup-500.
      *                  *---------------------------------------------*
      *                  * Controllo che il tipo prodotto sia 'M'      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-tpr    =    "M"
                     go to acc-pro-dup-600.
           move      "Il prodotto deve essere di tipo : Merce "
                                          to   w-err-tdo-nok-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-pro-dup-100.
       acc-pro-dup-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pro-dup-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-imp-dis-dup-flg
                                          =    spaces
                             move  "S"    to   w-imp-dis-dup-sel
                             go to acc-pro-dup-999
                     else    move  spaces to   w-imp-dis-dup-flg
                             go to acc-pro-dup-100.
       acc-pro-dup-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice semilavorato da dup.  *
      *    *-----------------------------------------------------------*
       acc-sem-dup-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-sem-dup-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dps-ope      .
           move      "A"                  to   w-cod-cod-dps-tac      .
           move      w-dup-nrm-dup        to   w-cod-cod-dps-num      .
           move      w-dup-afm-dup        to   w-cod-cod-dps-alf      .
           move      15                   to   w-cod-cod-dps-lin      .
           move      24                   to   w-cod-cod-dps-pos      .
           move      15                   to   w-cod-cod-dps-dln      .
           move      39                   to   w-cod-cod-dps-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           perform   cod-cod-dps-cll-000  thru cod-cod-dps-cll-999    .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           perform   cod-cod-dps-foi-000  thru cod-cod-dps-foi-999    .
       acc-sem-dup-110.
           perform   cod-cod-dps-cll-000  thru cod-cod-dps-cll-999    .
           if        w-cod-cod-dps-ope    =    "F+"
                     go to acc-sem-dup-115.
           if        w-cod-cod-dps-ope    =    "AC"
                     go to acc-sem-dup-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sem-dup-115.
           perform   cod-cod-dps-foi-000  thru cod-cod-dps-foi-999    .
           go to     acc-sem-dup-110.
       acc-sem-dup-120.
           move      w-cod-cod-dps-num    to   v-num                  .
           move      w-cod-cod-dps-alf    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-imp-dis-dup-sel
                     go to acc-sem-dup-999.
       acc-sem-dup-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-dup-nrm-dup          .
           move      v-alf                to   w-dup-afm-dup          .
       acc-sem-dup-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dps]                      *
      *                  *---------------------------------------------*
           move      w-dup-nrm-dup        to   w-let-arc-dps-num      .
           perform   let-arc-dps-000      thru let-arc-dps-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-dps-des    to   w-dup-nrm-dup-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nrm-dup-des-000  thru vis-nrm-dup-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non trovato : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dps-flg    not  = spaces
                     go to acc-sem-dup-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione a meno  *
      *                  * che non sia stato premuto 'Up'              *
      *                  *---------------------------------------------*
           if        w-dup-afm-dup        not  = spaces
                     go to acc-sem-dup-600.
           if        v-key                =    "UP  "
                     go to acc-sem-dup-600
           else      go to acc-sem-dup-100.
       acc-sem-dup-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sem-dup-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-imp-dis-dup-flg
                                          =    spaces
                             move  "S"    to   w-imp-dis-dup-sel
                             go to acc-sem-dup-999
                     else    move  spaces to   w-imp-dis-dup-flg
                             go to acc-sem-dup-100.
       acc-sem-dup-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice sub-distinta da dup.  *
      *    *-----------------------------------------------------------*
       acc-lgv-dup-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-lgv-dup-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-lgv-ope      .
           move      "A"                  to   w-cod-cod-lgv-tac      .
           move      w-dup-nrm-dup        to   w-cod-cod-lgv-num      .
           move      w-dup-afm-dup        to   w-cod-cod-lgv-alf      .
           move      15                   to   w-cod-cod-lgv-lin      .
           move      24                   to   w-cod-cod-lgv-pos      .
           move      15                   to   w-cod-cod-lgv-dln      .
           move      39                   to   w-cod-cod-lgv-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           perform   cod-cod-lgv-cll-000  thru cod-cod-lgv-cll-999    .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           perform   cod-cod-lgv-foi-000  thru cod-cod-lgv-foi-999    .
       acc-lgv-dup-110.
           perform   cod-cod-lgv-cll-000  thru cod-cod-lgv-cll-999    .
           if        w-cod-cod-lgv-ope    =    "F+"
                     go to acc-lgv-dup-115.
           if        w-cod-cod-lgv-ope    =    "AC"
                     go to acc-lgv-dup-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-lgv-dup-115.
           perform   cod-cod-lgv-foi-000  thru cod-cod-lgv-foi-999    .
           go to     acc-lgv-dup-110.
       acc-lgv-dup-120.
           move      w-cod-cod-lgv-num    to   v-num                  .
           move      w-cod-cod-lgv-alf    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-imp-dis-dup-sel
                     go to acc-lgv-dup-999.
       acc-lgv-dup-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-dup-nrm-dup          .
           move      v-alf                to   w-dup-afm-dup          .
       acc-lgv-dup-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [lgv]                      *
      *                  *---------------------------------------------*
           move      w-dup-nrm-dup        to   w-let-arc-lgv-num      .
           perform   let-arc-lgv-000      thru let-arc-lgv-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-lgv-des    to   w-dup-nrm-dup-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nrm-dup-des-000  thru vis-nrm-dup-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non trovato : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-lgv-flg    not  = spaces
                     go to acc-lgv-dup-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione a meno  *
      *                  * che non sia stato premuto 'Up'              *
      *                  *---------------------------------------------*
           if        w-dup-afm-dup           not  = spaces
                     go to acc-lgv-dup-600.
           if        v-key                =    "UP  "
                     go to acc-lgv-dup-600
           else      go to acc-lgv-dup-100.
       acc-lgv-dup-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-lgv-dup-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-imp-dis-dup-flg
                                          =    spaces
                             move  "S"    to   w-imp-dis-dup-sel
                             go to acc-lgv-dup-999
                     else    move  spaces to   w-imp-dis-dup-flg
                             go to acc-lgv-dup-100.
       acc-lgv-dup-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-imp-dis-dup-flg      .
      *              *-------------------------------------------------*
      *              * Controllo su tipo distinta da duplicare         *
      *              *-------------------------------------------------*
           if        w-dup-tpm-dup        not  = zero
                     go to tdo-ric-sel-100.
           move      "Manca il tipo distinta da duplicare !"
                                          to   w-err-tdo-nok-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su codice distinta da duplicare       *
      *              *-------------------------------------------------*
           if        w-dup-nrm-dup        not  = zero
                     go to tdo-ric-sel-200.
           move      "Manca il codice distinta da duplicare !"
                                          to   w-err-tdo-nok-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo che la distinta da duplicare non sia  *
      *              * quella in corso di trattamento                  *
      *              *-------------------------------------------------*
           if not   (w-dup-tpm-dup        =    w-tes-tpm-ass and
                     w-dup-nrm-dup        =    w-tes-nrm-ass   )
                     go to tdo-ric-sel-300.
           move      "La distinta da duplicare non puo' essere quella in
      -              " corso"
                                          to   w-err-tdo-nok-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo che la distinta da duplicare esista   *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TNMASS    "         to   f-key                  .
           move      w-dup-tpm-dup        to   rf-lgt-tpm-ass         .
           move      w-dup-nrm-dup        to   rf-lgt-nrm-ass         .
           move      "pgm/dtp/fls/ioc/obj/ioflgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgt                 .
           if        f-sts                =    e-not-err
                     go to tdo-ric-sel-400.
           move      "La distinta da duplicare non esiste in archivio !"
                                          to   w-err-tdo-nok-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-imp-dis-dup-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione duplicazione righe                             *
      *    *-----------------------------------------------------------*
       exe-dup-rig-000.
      *              *-------------------------------------------------*
      *              * Rimozione record attuale dalla catena           *
      *              *-------------------------------------------------*
           move      "RM"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Caricamento righe                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "TNMASS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-dup-tpm-dup        to   rf-lgr-tpm-ass         .
           move      w-dup-nrm-dup        to   rf-lgr-nrm-ass         .
           move      zero                 to   rf-lgr-num-prg         .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                      *-----------------------------------------*
      *                      * Se errore di start : fine lettura       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  exe-dup-rig-500.
       exe-dup-rig-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [lgr]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                      *-----------------------------------------*
      *                      * Se at end : fine lettura                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  exe-dup-rig-500.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : fine lettura          *
      *                  *---------------------------------------------*
           if        rf-lgr-tpm-ass       not  = w-dup-tpm-dup or
                     rf-lgr-nrm-ass       not  = w-dup-nrm-dup
                     go to  exe-dup-rig-500.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riga                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori attuali                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [lgr]                        *
      *                          *-------------------------------------*
           move      rf-lgr-num-prg       to   w-rig-num-prg (1)      .
           move      rf-lgr-tpm-cpt       to   w-rig-tpm-cpt (1)      .
           move      rf-lgr-nrm-cpt       to   w-rig-nrm-cpt (1)      .
           move      rf-lgr-afm-cpt       to   w-rig-afm-cpt (1)      .
           move      rf-lgr-umi-prd       to   w-rig-umi-prd (1)      .
           move      rf-lgr-dec-qta       to   w-rig-dec-qta (1)      .
           move      rf-lgr-qta-ipm       to   w-rig-qta-ipm (1)      .
           move      rf-lgr-qta-ipd       to   w-rig-qta-ipd (1)      .
           move      rf-lgr-not-cpt       to   w-rig-not-cpt (1)      .
           move      rf-lgr-alx-exp       to   w-rig-alx-exp (1)      .
      *                          *-------------------------------------*
      *                          * Valori contenuti indirettamente in  *
      *                          * record [lgr]                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Descrizione componente          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Deviazione in funzione del  *
      *                                  * tipo componente             *
      *                                  *-----------------------------*
           if        w-rig-tpm-cpt (1)    =    02
                     go to exe-dup-rig-140
           else if   w-rig-tpm-cpt (1)    =    03
                     go to exe-dup-rig-160
           else if   w-rig-tpm-cpt (1)    =    99
                     go to exe-dup-rig-180
           else      go to exe-dup-rig-200.
       exe-dup-rig-140.
      *                                  *-----------------------------*
      *                                  * Se semilavorato             *
      *                                  *-----------------------------*
           move      w-rig-nrm-cpt (1)    to   w-let-arc-dps-num      .
           perform   let-arc-dps-000      thru let-arc-dps-999        .
           move      w-let-arc-dps-des    to   w-rig-nrm-cpt-des (1)  .
           go to     exe-dup-rig-200.
       exe-dup-rig-160.
      *                                  *-----------------------------*
      *                                  * Se materia prima            *
      *                                  *-----------------------------*
           move      w-rig-nrm-cpt (1)    to   w-let-arc-dpm-num      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
           move      w-let-arc-dpm-des    to   w-rig-nrm-cpt-des (1)  .
           go to     exe-dup-rig-200.
       exe-dup-rig-180.
      *                                  *-----------------------------*
      *                                  * Se sub-distinta virtuale    *
      *                                  *-----------------------------*
           move      w-rig-nrm-cpt (1)    to   w-let-arc-lgv-num      .
           perform   let-arc-lgv-000      thru let-arc-lgv-999        .
           move      w-let-arc-lgv-des    to   w-rig-nrm-cpt-des (1)  .
           go to     exe-dup-rig-200.
       exe-dup-rig-200.
      *                      *-----------------------------------------*
      *                      * Valori precedenti                       *
      *                      *-----------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                      *-----------------------------------------*
      *                      * Put su catena movimenti [rig]           *
      *                      *-----------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-lgr-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura [lgr] successivo          *
      *                  *---------------------------------------------*
           go to     exe-dup-rig-100.
       exe-dup-rig-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-dup-rig-999.
       exe-dup-rig-999.
           exit.

      *    *===========================================================*
      *    * Tasto funzione "Pf3" disponibile ad ogni impostazione     *
      *    *-----------------------------------------------------------*
       pf3-dtp-300-000.
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pdtp4000"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to  pf3-dtp-300-999.
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "pgm/dtp/prg/obj/pdtp4000"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
       pf3-dtp-300-999.
           exit.

      *    *===========================================================*
      *    * Richiamo sottoprogramma per esplosione scalare            *
      *    *-----------------------------------------------------------*
       esp-sca-psv-000.
      *              *-------------------------------------------------*
      *              * Se programma di interrogazione gia' attivo :    *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pdtp4000"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to esp-sca-psv-999.
       esp-sca-psv-100.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'tip-int' per il  *
      *              * livello successivo per il tipo di interrogazio- *
      *              * ne                                              *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "tip-int"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      10                   to   s-car                  .
           if        w-esp-sca-tip-ass    =    01
                     move  "ESCPRO    "   to   s-alf
           else if   w-esp-sca-tip-ass    =    02
                     move  "ESCSEM    "   to   s-alf
           else if   w-esp-sca-tip-ass    =    99
                     move  "ESCSDV    "   to   s-alf
           else      move  spaces         to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-sca-psv-200.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'snx-slc' per il  *
      *              * livello successivo per l'ammissibilita' del ta- *
      *              * sto Slct a No                                   *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-slc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "N"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-sca-psv-300.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'num-ass' per il  *
      *              * livello successivo per il codice numerico del-  *
      *              * l'assieme da esplodere                          *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "num-ass"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      07                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-esp-sca-num-ass    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-sca-psv-400.
      *              *-------------------------------------------------*
      *              * Richiamo del programma di interrogazione        *
      *              *-------------------------------------------------*
           move      "pgm/dtp/prg/obj/pdtp4000"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
       esp-sca-psv-500.
      *              *-------------------------------------------------*
      *              * Cancellazione del programma di interrogazione   *
      *              *-------------------------------------------------*
           cancel    s-pat                                            .
       esp-sca-psv-600.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     esp-sca-psv-999.
       esp-sca-psv-999.
           exit.

