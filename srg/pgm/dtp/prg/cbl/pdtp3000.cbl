      *    *-----------------------------------------------------------*
       cnt-tdo-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-100.
      *              *-------------------------------------------------*
      *              * Test che non manchi il codice componente        *
      *              *-------------------------------------------------*
           if        w-rig-nrm-cpt (1)    not  = zero
                     go to cnt-tdo-rig-120.
           move      "Manca il codice componente !"
                                          to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-120.
      *              *-------------------------------------------------*
      *              * Test che il componente sia a sua volta una dis- *
      *              * tinta a meno che non si tratti di materia prima *
      *              *-------------------------------------------------*
           if        w-rig-tpm-cpt (1)    =    03
                     go to cnt-tdo-rig-200.
      *                  *---------------------------------------------*
      *                  * Routine di controllo                        *
      *                  *---------------------------------------------*
           move      w-rig-tpm-cpt (1)    to   w-ctl-dst-cpt-tpm      .
           move      w-rig-nrm-cpt (1)    to   w-ctl-dst-cpt-nrm      .
           perform   ctl-dst-cpt-000      thru ctl-dst-cpt-999        .
           if        w-ctl-dst-cpt-exi    =    spaces
                     go to cnt-tdo-rig-200.
           move      "Il componente non ha la distinta base !"
                                          to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-200.
      *              *-------------------------------------------------*
      *              * Test che non manchi la quantita' d'impiego      *
      *              *-------------------------------------------------*
           if        w-rig-qta-ipm (1)    not  = zero
                     go to cnt-tdo-rig-300.
           move      "Manca la quantita' d'impiego !"
                                          to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-300.
      *              *-------------------------------------------------*
      *              * Test che il divisore non sia zero               *
      *              *-------------------------------------------------*
           if        w-rig-qta-ipd (1)    not  = zero
                     go to cnt-tdo-rig-600.
           move      "Il divisore non puo' essere a zero !"
                                          to   w-err-tdo-nok-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-600.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo                  *
      *    *-----------------------------------------------------------*
       pre-rig-cor-000.
       pre-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Attribuzione del numero progressivo per la riga New       *
      *    *-----------------------------------------------------------*
       prg-rig-cor-000.
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
       prg-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo                       *
      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
       pos-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave e non chiave                  *
      *    *-----------------------------------------------------------*
       nor-key-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati chiave                     *
      *              *-------------------------------------------------*
           perform   nor-key-reg-000      thru nor-key-reg-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave testata         *
      *              *-------------------------------------------------*
           perform   nor-nok-tes-000      thru nor-nok-tes-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave riga corpo      *
      *              *-------------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave piede           *
      *              *-------------------------------------------------*
           perform   nor-nok-pie-000      thru nor-nok-pie-999        .
      *              *-------------------------------------------------*
      *              * Inizializzazione catena [rig]                   *
      *              *-------------------------------------------------*
           move      "BE"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       nor-key-nok-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave                               *
      *    *-----------------------------------------------------------*
       nor-key-reg-000.
           move      zero                 to   w-tes-tpm-ass          .
           move      zero                 to   w-tes-nrm-ass          .
           move      spaces               to   w-tes-nrm-ass-des      .
           move      zero                 to   w-tes-nrm-ass-deq      .
           move      spaces               to   w-tes-afm-ass          .
       nor-key-reg-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave testata                   *
      *    *-----------------------------------------------------------*
       nor-nok-tes-000.
           move      spaces               to   w-tes-sig-dis (1)      .
           move      spaces               to   w-tes-cmt-ass (1)      .
           move      zero                 to   w-tes-prc-sct (1)      .
           move      zero                 to   w-tes-prc-rlv (1)      .
           move      spaces               to   w-tes-cod-lvr (1)      .
           move      spaces               to   w-tes-cod-lvr-des (1)  .
           move      zero                 to   w-tes-tmp-lvr (1)      .
           move      spaces               to   w-tes-cod-mcn (1)      .
           move      spaces               to   w-tes-cod-mcn-des (1)  .
           move      zero                 to   w-tes-tmp-mcn (1)      .
           move      zero                 to   w-tes-pes-ini (1)      .
           move      zero                 to   w-tes-pes-fin (1)      .
           move      spaces               to   w-tes-alx-exp (1)      .
       nor-nok-tes-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave riga corpo                *
      *    *-----------------------------------------------------------*
       nor-nok-rig-000.
           move      zero                 to   w-rig-num-prg (1)      .
           move      zero                 to   w-rig-tpm-cpt (1)      .
           move      zero                 to   w-rig-nrm-cpt (1)      .
           move      spaces               to   w-rig-nrm-cpt-des (1)  .
           move      spaces               to   w-rig-nrm-cpt-umi (1)  .
           move      spaces               to   w-rig-afm-cpt (1)      .
           move      spaces               to   w-rig-umi-prd (1)      .
           move      zero                 to   w-rig-dec-qta (1)      .
           move      zero                 to   w-rig-qta-ipm (1)      .
           move      zero                 to   w-rig-qta-ipd (1)      .
           move      spaces               to   w-rig-not-cpt (1)      .
           move      spaces               to   w-rig-alx-exp (1)      .
       nor-nok-rig-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave piede                     *
      *    *-----------------------------------------------------------*
       nor-nok-pie-000.
       nor-nok-pie-999.
           exit.

      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
       rou-let-reg-050.
      *              *-------------------------------------------------*
      *              * Lettura record [lgt]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TNMASS    "         to   f-key                  .
           move      w-tes-tpm-ass        to   rf-lgt-tpm-ass         .
           move      w-tes-nrm-ass        to   rf-lgt-nrm-ass         .
           move      "pgm/dtp/fls/ioc/obj/ioflgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgt                 .
           if        f-sts                =    e-not-err
                     go to rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : Inserimento        *
      *                      *-----------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                      *-----------------------------------------*
      *                      * Attivazione flag di duplicazione righe  *
      *                      * distinta                                *
      *                      *-----------------------------------------*
           move      spaces               to   w-dup-flg-dup          .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : Modifica           *
      *                      *-----------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                      *-----------------------------------------*
      *                      * Inibizione flag di duplicazione righe   *
      *                      * distinta                                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-dup-flg-dup          .
      *                      *-----------------------------------------*
      *                      * Completamento valori attuali chiave     *
      *                      *-----------------------------------------*
           move      rf-lgt-afm-ass       to   w-tes-afm-ass          .
      *                      *-----------------------------------------*
      *                      * Determinazione valori attuali testata   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente da    *
      *                          * record [lgt]                        *
      *                          *-------------------------------------*
           move      rf-lgt-sig-dis       to   w-tes-sig-dis (1)      .
           move      rf-lgt-cmt-ass       to   w-tes-cmt-ass (1)      .
           move      rf-lgt-prc-sct       to   w-tes-prc-sct (1)      .
           move      rf-lgt-prc-rlv       to   w-tes-prc-rlv (1)      .
           move      rf-lgt-cod-lvr       to   w-tes-cod-lvr (1)      .
           move      rf-lgt-tmp-lvr       to   w-tes-tmp-lvr (1)      .
           move      rf-lgt-cod-mcn       to   w-tes-cod-mcn (1)      .
           move      rf-lgt-tmp-mcn       to   w-tes-tmp-mcn (1)      .
           move      rf-lgt-pes-ini       to   w-tes-pes-ini (1)      .
           move      rf-lgt-pes-fin       to   w-tes-pes-fin (1)      .
      *
           if        rf-lgt-tmp-lvr       not  numeric
                     move  zero           to   w-tes-tmp-lvr (1)      .
           if        rf-lgt-tmp-mcn       not  numeric
                     move  zero           to   w-tes-tmp-mcn (1)      .
           if        rf-lgt-pes-ini       not  numeric
                     move  zero           to   w-tes-pes-ini (1)      .
           if        rf-lgt-pes-fin       not  numeric
                     move  zero           to   w-tes-pes-fin (1)      .
      *
           move      rf-lgt-alx-exp       to   w-tes-alx-exp (1)      .
      *                          *-------------------------------------*
      *                          * Valori contenuti indirettamente da  *
      *                          * record [lgt]                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Valori dipendenti dal codice    *
      *                              * lavorazione                     *
      *                              *---------------------------------*
           move      w-tes-cod-lvr (1)    to   w-let-arc-zcl-cod      .
           perform   let-arc-zcl-000      thru let-arc-zcl-999        .
           move      w-let-arc-zcl-des    to   w-tes-cod-lvr-des (1)  .
      *                              *---------------------------------*
      *                              * Valori dipendenti dal codice    *
      *                              * macchinario                     *
      *                              *---------------------------------*
           move      w-tes-cod-mcn (1)    to   w-let-arc-zcm-cod      .
           perform   let-arc-zcm-000      thru let-arc-zcm-999        .
           move      w-let-arc-zcm-des    to   w-tes-cod-mcn-des (1)  .
       rou-let-reg-400.
      *                      *-----------------------------------------*
      *                      * Valori precedenti testata               *
      *                      *-----------------------------------------*
           move      w-tes-val-aep (1)    to   w-tes-val-aep (2)      .
       rou-let-reg-500.
      *              *-------------------------------------------------*
      *              * Lettura righe                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "TNMASS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-tpm-ass        to   rf-lgr-tpm-ass         .
           move      w-tes-nrm-ass        to   rf-lgr-nrm-ass         .
           move      zero                 to   rf-lgr-num-prg         .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                      *-----------------------------------------*
      *                      * Se errore di start : fine lettura       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-999.
       rou-let-reg-600.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [lgr]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                      *-----------------------------------------*
      *                      * Se at end : fine lettura                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-999.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : fine lettura          *
      *                  *---------------------------------------------*
           if        rf-lgr-tpm-ass       not  = w-tes-tpm-ass or
                     rf-lgr-nrm-ass       not  = w-tes-nrm-ass
                     go to  rou-let-reg-999.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riga                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori attuali                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [lgr]                        *
      *                          *-------------------------------------*
           move      rf-lgr-num-prg       to   w-rig-num-prg (1)      .
           move      rf-lgr-tpm-cpt       to   w-rig-tpm-cpt (1)      .
           move      rf-lgr-nrm-cpt       to   w-rig-nrm-cpt (1)      .
           move      rf-lgr-afm-cpt       to   w-rig-afm-cpt (1)      .
           move      rf-lgr-umi-prd       to   w-rig-umi-prd (1)      .
           move      rf-lgr-dec-qta       to   w-rig-dec-qta (1)      .
           move      rf-lgr-qta-ipm       to   w-rig-qta-ipm (1)      .
           move      rf-lgr-qta-ipd       to   w-rig-qta-ipd (1)      .
           move      rf-lgr-not-cpt       to   w-rig-not-cpt (1)      .
           move      rf-lgr-alx-exp       to   w-rig-alx-exp (1)      .
      *                          *-------------------------------------*
      *                          * Valori contenuti indirettamente in  *
      *                          * record [lgr]                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Descrizione componente          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Deviazione in funzione del  *
      *                                  * tipo componente             *
      *                                  *-----------------------------*
           if        w-rig-tpm-cpt (1)    =    02
                     go to rou-let-reg-640
           else if   w-rig-tpm-cpt (1)    =    03
                     go to rou-let-reg-660
           else if   w-rig-tpm-cpt (1)    =    99
                     go to rou-let-reg-680
           else      go to rou-let-reg-800.
       rou-let-reg-640.
      *                                  *-----------------------------*
      *                                  * Se semilavorato             *
      *                                  *-----------------------------*
           move      w-rig-nrm-cpt (1)    to   w-let-arc-dps-num      .
           perform   let-arc-dps-000      thru let-arc-dps-999        .
           if        w-let-arc-dps-alf    not  = spaces
                     move  w-let-arc-dps-alf
                                          to   w-rig-afm-cpt (1)      .
           move      w-let-arc-dps-des    to   w-rig-nrm-cpt-des (1)  .
           go to     rou-let-reg-800.
       rou-let-reg-660.
      *                                  *-----------------------------*
      *                                  * Se materia prima            *
      *                                  *-----------------------------*
           move      w-rig-nrm-cpt (1)    to   w-let-arc-dpm-num      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
           if        w-let-arc-dpm-alf    not  = spaces
                     move  w-let-arc-dpm-alf
                                          to   w-rig-afm-cpt (1)      .
           move      w-let-arc-dpm-des    to   w-rig-nrm-cpt-des (1)  .
           move      w-let-arc-dpm-umi    to   w-rig-nrm-cpt-umi (1)  .
           go to     rou-let-reg-800.
       rou-let-reg-680.
      *                                  *-----------------------------*
      *                                  * Se sub-distinta virtuale    *
      *                                  *-----------------------------*
           move      w-rig-nrm-cpt (1)    to   w-let-arc-lgv-num      .
           perform   let-arc-lgv-000      thru let-arc-lgv-999        .
           if        w-let-arc-lgv-alf    not  = spaces
                     move  w-let-arc-lgv-alf
                                          to   w-rig-afm-cpt (1)      .
           move      w-let-arc-lgv-des    to   w-rig-nrm-cpt-des (1)  .
           go to     rou-let-reg-800.
       rou-let-reg-800.
      *                      *-----------------------------------------*
      *                      * Valori precedenti                       *
      *                      *-----------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                      *-----------------------------------------*
      *                      * Put su catena movimenti [rig]           *
      *                      *-----------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-lgr-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura [lgr] successivo          *
      *                  *---------------------------------------------*
           go to     rou-let-reg-600.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
