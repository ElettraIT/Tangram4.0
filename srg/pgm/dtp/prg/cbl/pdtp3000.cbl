           move      w-exp-tpm-cpt-lun    to   v-car                  .
           move      w-exp-tpm-cpt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tpm-cpt-tbl    to   v-txt                  .
           move      17                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      zero                 to   v-num                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
