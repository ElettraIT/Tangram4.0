      *                  *---------------------------------------------*
           if        w-prn-liv-flg-val    =    spaces
                     go to prn-liv-det-876
           else      go to prn-liv-det-877.
       prn-liv-det-876.
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "G"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      066                  to   p-pos                  .
           move      w-prn-liv-det-val    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     prn-liv-det-900.
       prn-liv-det-877.
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      15                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      066                  to   p-pos                  .
           move      "Non determ.    "    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     prn-liv-det-900.
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Uscita dal livello di dettaglio                 *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
