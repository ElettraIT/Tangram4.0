      *                  *---------------------------------------------*
           move      zero                 to   w-srt-pre-num-rec      .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start filtro di ordinamento e selezione per il  *
      *              * file [lgv]                                      *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           if        rr-tip-ord           =    01
                     move  "D"            to   l-zos-lgv-tip-ord
           else if   rr-tip-ord           =    02
                     move  "C"            to   l-zos-lgv-tip-ord
           else if   rr-tip-ord           =    03
                     move  "S"            to   l-zos-lgv-tip-ord
           else      move  "C"            to   l-zos-lgv-tip-ord      .
           move      rr-cod-min           to   l-zos-lgv-cod-min      .
           move      rr-cod-max           to   l-zos-lgv-cod-max      .
           move      rr-des-min           to   l-zos-lgv-des-min      .
           move      rr-des-max           to   l-zos-lgv-des-max      .
           move      rr-sin-min           to   l-zos-lgv-sin-min      .
           move      rr-sin-max           to   l-zos-lgv-sin-max      .
           move      "pgm/dtp/prg/obj/bzoslgv0"
                                          to   s-pat                  .
