                   15  fil-des-key        pic  x(40)                  .
                   15  fil-cod-tpu-2      pic  x(20)                  .
      *        *-------------------------------------------------------*
      *        * Dati                                                  *
      *        *-------------------------------------------------------*
           05  fil-dat.
               10  fil-des-tpu.
                   15  fil-rig-des  occurs 05
                                          pic  x(40)                  .
               10  fil-mod-utl            pic  x(01)                  .
               10  fil-tip-sez            pic  9(02)                  .
               10  fil-snx-rrt            pic  x(01)                  .
               10  fil-snx-ran            pic  x(01)                  .
               10  fil-snx-cat            pic  x(01)                  .
               10  fil-snx-cuf            pic  x(01)                  .
