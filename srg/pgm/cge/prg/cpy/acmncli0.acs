      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice cliente conta-  *
      *    * bile                                                      *
      *    *-----------------------------------------------------------*
       cod-mne-cli-opn-000.
           move      "pgm/cge/prg/obj/acmncli0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-mne-cli-pth      .
           move      "OP"                 to   w-cod-mne-cli-ope      .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
       cod-mne-cli-opn-999.
           exit.
       cod-mne-cli-cls-000.
           move      "CL"                 to   w-cod-mne-cli-ope      .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           move      "C?"                 to   w-cod-mne-cli-ope      .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           if        w-cod-mne-cli-ope    not  = spaces
                     go to cod-mne-cli-cls-999.
           cancel    w-cod-mne-cli-pth                                .
       cod-mne-cli-cls-999.
           exit.
       cod-mne-cli-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-mne-cli-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pcge4000"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-cli-foi-999.
           move      "pgm/cge/prg/obj/pcge4000"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-mne-cli-ope      .
           go to     cod-mne-cli-foi-999.
       cod-mne-cli-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-mne-cli-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pcge4010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-cli-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/cge/prg/obj/pcge4010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-mne-cli-ope      .
           go to     cod-mne-cli-foi-999.
       cod-mne-cli-foi-999.
           exit.
       cod-mne-cli-cll-000.
           call      w-cod-mne-cli-pth   using w-cod-mne-cli
                                               v
                                               s                      .
       cod-mne-cli-cll-999.
           exit.

