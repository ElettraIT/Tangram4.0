      *    *===========================================================*
      *    * Subroutines per determinazione movimenti cespiti          *
      *    *-----------------------------------------------------------*
       det-mov-csp-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-mov-csp-tip-ope      .
           perform   det-mov-csp-cll-000  thru det-mov-csp-cll-999    .
       det-mov-csp-opn-999.
           exit.

       det-mov-csp-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-mov-csp-tip-ope      .
           perform   det-mov-csp-cll-000  thru det-mov-csp-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-mov-csp-tip-ope      .
           perform   det-mov-csp-cll-000  thru det-mov-csp-cll-999    .
           if        d-mov-csp-exi-sts    not  = spaces
                     go to det-mov-csp-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/cge/prg/obj/dmovcsp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       det-mov-csp-cls-999.
           exit.

       det-mov-csp-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/cge/prg/obj/dmovcsp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-mov-csp              .
       det-mov-csp-cll-999.
           exit.

