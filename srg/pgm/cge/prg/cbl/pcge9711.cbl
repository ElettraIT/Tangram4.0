      *    *===========================================================*
      *    * Stampa riepilogo finale                                   *
      *    *-----------------------------------------------------------*
       stp-rie-fin-000.
      *              *-------------------------------------------------*
      *              * Scansione tabella ordinamento per aliquota fin- *
      *              * che' non si trova il primo elemento libero      *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-ctr-001          .
       stp-rie-fin-100.
           add       1                    to   w-wrk-ctr-001          .
           if        w-wrk-ctr-001        >    200
                     go to  stp-rie-fin-999.
           if        w-sor-cod-iva
                    (w-wrk-ctr-001)       =    zero  and
                     w-sor-imp-ibl
                    (w-wrk-ctr-001)       =    zero  and
                     w-sor-imp-iva
                    (w-wrk-ctr-001)       =    zero
                     go to  stp-rie-fin-200
           else      go to  stp-rie-fin-100.
       stp-rie-fin-200.
      *              *-------------------------------------------------*
      *              * Memorizzazione numero di aliquote massimo       *
      *              *-------------------------------------------------*
           subtract  1                    from w-wrk-ctr-001
                                        giving w-sor-ctr-max          .
      *              *-------------------------------------------------*
      *              * Richiamo routine di ordinamento per aliquota    *
      *              *-------------------------------------------------*
           perform   ord-cod-iva-000      thru ord-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Se linee residue non sufficienti : intestazione *
      *              * pagina                                          *
      *              *-------------------------------------------------*
           if        p-res                not  < 3
                     go to  stp-rie-fin-300.
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                  *---------------------------------------------*
      *                  * Se errori di i-o : uscita                   *
      *                  *---------------------------------------------*
           if        OK                   not  = spaces
                     go to stp-rie-fin-999.
       stp-rie-fin-300.
      *              *-------------------------------------------------*
      *              * Una interlinea subordinata                      *
      *              *-------------------------------------------------*
           move      "VS"                 to   p-ope                  .
           add       1
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rie-fin-310.
      *              *-------------------------------------------------*
      *              * Linea di '-' iniziale                           *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      92                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      21                   to   p-pos                  .
           move      all   "-"            to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Ciclo per estrazione aliquote ordinate          *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-ctr-001          .
       stp-rie-fin-400.
           add       1                    to   w-wrk-ctr-001          .
           if        w-wrk-ctr-001        >    w-sor-ctr-max
                     go to  stp-rie-fin-800.
      *                  *---------------------------------------------*
      *                  * Test su linee residue                       *
      *                  *---------------------------------------------*
           if        p-res                >    zero
                     go to  stp-rie-fin-500.
      *                      *-----------------------------------------*
      *                      * Se non sufficienti: intestazione pagina *
      *                      *-----------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                          *-------------------------------------*
      *                          * Se errori di i-o : uscita           *
      *                          *-------------------------------------*
           if        OK                   not  = spaces
                     go to stp-rie-fin-999.
       stp-rie-fin-500.
      *                  *---------------------------------------------*
      *                  * 'Totali divisi per aliquota :'              *
      *                  *---------------------------------------------*
           if        w-wrk-ctr-001        not  = 1
                     go to  stp-rie-fin-520.
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      28                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      49                   to   p-pos                  .
           move      "Totali divisi per aliquota :"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rie-fin-520.
      *              *-------------------------------------------------*
      *              * Imponibile                                      *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      78                   to   p-pos                  .
           move      w-sor-imp-ibl
                    (w-wrk-ctr-001)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Codice iva                                      *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "B"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      94                   to   p-pos                  .
           move      w-sor-cod-iva
                    (w-wrk-ctr-001)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Imposta iva o titolo esenzione                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Caso imposta iva                            *
      *                  *---------------------------------------------*
           if        w-sor-imp-iva
                    (w-wrk-ctr-001)       =    zero
                     go to  stp-rie-fin-540.
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      98                   to   p-pos                  .
           move      w-sor-imp-iva
                    (w-wrk-ctr-001)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     stp-rie-fin-550.
       stp-rie-fin-540.
      *                  *---------------------------------------------*
      *                  * Caso titolo di esenzione                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [zci]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
           move      w-sor-cod-iva
                    (w-wrk-ctr-001)       to   rf-zci-cod-iva         .
      *                      *-----------------------------------------*
      *                      * Lettura record [zci]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODIVA    "         to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                          *-------------------------------------*
      *                          * Test su esito lettura               *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-fnd
                     move   all "."       to   rf-zci-des-doc         .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione titolo      *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      15                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      98                   to   p-pos                  .
           move      rf-zci-des-doc       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rie-fin-550.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su aliquota ordinata successiva     *
      *                  *---------------------------------------------*
           go to     stp-rie-fin-400.
       stp-rie-fin-800.
      *              *-------------------------------------------------*
      *              * Test su linee residue                           *
      *              *-------------------------------------------------*
           if        p-res                >    zero
                     go to  stp-rie-fin-820.
      *                  *---------------------------------------------*
      *                  * Se non sufficienti: intestazione pagina     *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                      *-----------------------------------------*
      *                      * Se errori di i-o : uscita               *
      *                      *-----------------------------------------*
           if        OK                   not  = spaces
                     go to stp-rie-fin-999.
       stp-rie-fin-820.
      *              *-------------------------------------------------*
      *              * Linea di '-' finale                             *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      92                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      21                   to   p-pos                  .
           move      all   "-"            to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rie-fin-999.
           exit.

      *    *===========================================================*
      *    * Routine di ordinamento per aliquota                       *
      *    *-----------------------------------------------------------*
       ord-cod-iva-000.
      *              *-------------------------------------------------*
      *              * Test se almeno due aliquote da ordinare         *
      *              *-------------------------------------------------*
           if        w-sor-ctr-max        <    2
                     go to  ord-cod-iva-999.
      *              *-------------------------------------------------*
      *              * Ciclo di ordinamento                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-sor-ctr-001          .
       ord-cod-iva-100.
           add       1                    to   w-sor-ctr-001          .
           if        w-sor-ctr-001        =    w-sor-ctr-max
                     go to  ord-cod-iva-999.
           move      w-sor-ctr-001        to   w-wrk-ctr-001
                                               w-wrk-ctr-002          .
           move      w-sor-cod-iva
                    (w-sor-ctr-001)       to   w-sor-www-cod          .
       ord-cod-iva-200.
           add       1                    to   w-wrk-ctr-001          .
           if        w-wrk-ctr-001        >    w-sor-ctr-max
                     go to  ord-cod-iva-300.
           if        w-sor-cod-iva
                    (w-wrk-ctr-001)       >    w-sor-www-cod
                     go to  ord-cod-iva-200.
           move      w-wrk-ctr-001        to   w-wrk-ctr-002          .
           move      w-sor-cod-iva
                    (w-wrk-ctr-001)       to   w-sor-www-cod          .
           go to     ord-cod-iva-200.
       ord-cod-iva-300.
           move      w-sor-ctr-001        to   w-wrk-ctr-003          .          
           if        w-sor-www-cod        >    w-sor-cod-iva
                                              (w-wrk-ctr-003)
                     go to  ord-cod-iva-100.
           move      w-sor-cod-iva
                    (w-wrk-ctr-002)       to   w-sor-www-cod          .
           move      w-sor-cod-iva
                    (w-wrk-ctr-003)       to   w-sor-cod-iva
                                              (w-wrk-ctr-002)         .
           move      w-sor-www-cod        to   w-sor-cod-iva
                                              (w-wrk-ctr-003)         .
           move      w-sor-imp-ibl
                    (w-wrk-ctr-002)       to   w-sor-www-ibl          .
           move      w-sor-imp-ibl
                    (w-wrk-ctr-003)       to   w-sor-imp-ibl
                                              (w-wrk-ctr-002)         .
           move      w-sor-www-ibl        to   w-sor-imp-ibl
                                              (w-wrk-ctr-003)         .
           move      w-sor-imp-iva
                    (w-wrk-ctr-002)       to   w-sor-www-imp          .
           move      w-sor-imp-iva
                    (w-wrk-ctr-003)       to   w-sor-imp-iva
                                              (w-wrk-ctr-002)         .
           move      w-sor-www-imp        to   w-sor-imp-iva
                                              (w-wrk-ctr-003)         .
           go to     ord-cod-iva-100.
       ord-cod-iva-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa asterischi finali                       *
      *    *-----------------------------------------------------------*
       stp-ast-fin-000.
      *              *-------------------------------------------------*
      *              * Riempimento resto del foglio con asterischi     *
      *              *-------------------------------------------------*
           if        p-res                not  > 1
                     go to  stp-ast-fin-999.
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza stringhe di asterischi    *
      *                  * normale (per tutte le linee tranne l'ultima)*
      *                  *---------------------------------------------*
           divide    p-res                into p-sel-als-sel
                                        giving w-ast-lun-nor          .
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza ultima stringa di aste-   *
      *                  * rischi                                      *
      *                  *---------------------------------------------*
           multiply  w-ast-lun-nor        by   p-res
                                        giving w-ast-num-003
           subtract  w-ast-num-003        from p-sel-als-sel
                                        giving w-ast-lun-ult          .
      *                  *---------------------------------------------*
      *                  * Posizione di stampa iniziale                *
      *                  *---------------------------------------------*
           move      1                    to   w-ast-ctr-pos          .
       stp-ast-fin-100.
      *                  *---------------------------------------------*
      *                  * Ciclo di stampa fino ad esaurimento p-res   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stringa di asterischi                   *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-ast-lun-nor        to   p-car                  .
           if        p-res                =    1
                     add    w-ast-lun-ult to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-ast-ctr-pos        to   p-pos                  .
           move      all "*"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Interlinea                          *
      *                          *-------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Test su linee residue                   *
      *                      *-----------------------------------------*
           if        p-res                =    zero
                     go to  stp-ast-fin-999.
      *                      *-----------------------------------------*
      *                      * Aggiornamento contatore di posizione    *
      *                      *-----------------------------------------*
           add       w-ast-lun-nor        to   w-ast-ctr-pos          .
      *                      *-----------------------------------------*
      *                      * Riciclo a riga successiva               *
      *                      *-----------------------------------------*
           go to     stp-ast-fin-100.
       stp-ast-fin-999.
           exit.

