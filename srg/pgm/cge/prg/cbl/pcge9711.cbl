           exit.

      *    *===========================================================*
      *    * Lettura tabella causali contabili                         *
      *    *-----------------------------------------------------------*
       let-tbl-cau-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record tabella [zcc]            *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
      *                      *-----------------------------------------*
      *                      * Lettura record tabella [zcc]            *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      rf-mgi-cod-cau       to   rf-zcc-cod-cau         .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
      *                          *-------------------------------------*
      *                          * Test su esito lettura               *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-fnd
                     go to  let-tbl-cau-500.
           if        rf-zcc-tip-moi       not  = "4"  and
                     rf-zcc-tip-moi       not  = "D"  and
                     rf-zcc-tip-moi       not  = "5"  and
                     rf-zcc-tip-moi       not  = "E"  and
                     rf-zcc-tip-moi       not  = "6"
                     go to  let-tbl-cau-600.
           go to     let-tbl-cau-999.
       let-tbl-cau-500.
      *                      *-----------------------------------------*
      *                      * Causale non trovata                     *
      *                      *-----------------------------------------*
           perform   int-msg-err-000      thru int-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Editing codice causale              *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-zcc-cod-cau       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Composizione messaggio di errore    *
      *                          *-------------------------------------*
           move      spaces               to   m-msg                  .
           string    "   Causale "        
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     " non esistente in archivio"
                                delimited by   size
                                          into m-msg                  .
      *                          *-------------------------------------*
      *                          * Richiamo modulo messaggi di errore  *
      *                          *-------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           go to     let-tbl-cau-800.
       let-tbl-cau-600.
      *                      *-----------------------------------------*
      *                      * Causale non iva fornitori               *
      *                      *-----------------------------------------*
           perform   int-msg-err-000      thru int-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Editing codice causale              *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-zcc-cod-cau       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Composizione messaggio di errore    *
      *                          *-------------------------------------*
           move      spaces               to   m-msg                  .
           string    "   Causale "        
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     " non iva fornitori"
                                delimited by   size
                                          into m-msg                  .
      *                          *-------------------------------------*
      *                          * Richiamo modulo messaggi di errore  *
      *                          *-------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       let-tbl-cau-800.
           move      "#"                  to   OK
                                               w-wrk-cau-mnf          .
       let-tbl-cau-999.
           exit.

      *    *===========================================================*
