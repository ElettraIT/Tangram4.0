      *    *===========================================================*
      *    * Elaborazione registrazione iva                            *
      *    *-----------------------------------------------------------*
       ela-reg-iva-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione work-area iva                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-ctr-001          .
       ela-reg-iva-100.
           add       1                    to   w-wrk-ctr-001          .
           if        w-wrk-ctr-001        >    6
                     go to  ela-reg-iva-200.
           move      zero                 to   w-wrk-cst-ibl
                                              (w-wrk-ctr-001)
                                               w-wrk-cst-cod
                                              (w-wrk-ctr-001)
                                               w-wrk-cst-imp
                                              (w-wrk-ctr-001)         .
           move      spaces               to   w-wrk-cst-des
                                              (w-wrk-ctr-001)         .
           go to     ela-reg-iva-100.
       ela-reg-iva-200.
      *              *-------------------------------------------------*
      *              * Determinazione moltiplicatore unitario          *
      *              *-------------------------------------------------*
           if        rf-zcc-tip-moi       =    "5" or
                     rf-zcc-tip-moi       =    "E" or
                     rf-zcc-tip-moi       =    "6"
                     move   1             to   w-wrk-mol-uni
           else      move  -1             to   w-wrk-mol-uni          .
      *              *-------------------------------------------------*
      *              * Determinazione castelletto iva                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-ctr-002          .
           move      zero                 to   w-wrk-ctr-001          .
       ela-reg-iva-300.
           add       1                    to   w-wrk-ctr-001          .
           if        w-wrk-ctr-001        >    6
                     go to  ela-reg-iva-400.
           if        rf-mgi-ibl-iva
                    (w-wrk-ctr-001)       =    zero and
                     rf-mgi-cod-iva
                    (w-wrk-ctr-001)       =    zero and
                     rf-mgi-imp-iva
                    (w-wrk-ctr-001)       =    zero
                     go to  ela-reg-iva-300.
           add       1                    to   w-wrk-ctr-002          .
           multiply  w-wrk-mol-uni        by   rf-mgi-ibl-iva
                                              (w-wrk-ctr-001)
                                      giving   w-wrk-cst-ibl
                                              (w-wrk-ctr-002)         .
           move      rf-mgi-cod-iva
                    (w-wrk-ctr-001)       to   w-wrk-cst-cod
                                              (w-wrk-ctr-002)         .
           multiply  w-wrk-mol-uni        by   rf-mgi-imp-iva
                                              (w-wrk-ctr-001)
                                      giving   w-wrk-cst-imp
                                              (w-wrk-ctr-002)         .
      *                  *---------------------------------------------*
      *                  * Lettura eventuale descrizione titolo di e-  *
      *                  * senzione                                    *
      *                  *---------------------------------------------*
           move      w-wrk-cst-cod
                    (w-wrk-ctr-002)       to   w-wrk-cod-iva          .
           if        w-wrk-cod-iva-345    >    300 and
                     w-wrk-cod-iva-345    <    700
                     go to  ela-reg-iva-320
           else      go to  ela-reg-iva-300.
       ela-reg-iva-320.
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [zci]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
           move      w-wrk-cod-iva-345    to   rf-zci-cod-iva         .
      *                      *-----------------------------------------*
      *                      * Lettura record [zci]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODIVA    "         to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                          *-------------------------------------*
      *                          * Test su esito lettura               *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-fnd
                     move   all "."       to   rf-zci-des-doc         .
           move      rf-zci-des-doc       to   w-wrk-cst-des
                                              (w-wrk-ctr-002)         .
           go to     ela-reg-iva-300.
       ela-reg-iva-400.
      *              *-------------------------------------------------*
      *              * Totale documento                                *
      *              *-------------------------------------------------*
           multiply  w-wrk-mol-uni        by   rf-mgi-tot-doc
                                      giving   w-wrk-cst-tot          .
      *              *-------------------------------------------------*
      *              * Bufferizzazione ragione sociale fornitore       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record file [fnt]           *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
           move      rf-mgi-cod-arc       to   rf-fnt-cod-fnt         .
      *                  *---------------------------------------------*
      *                  * Lettura record file [fnt]                   *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-fnd
                     go to  ela-reg-iva-999.
      *                  *---------------------------------------------*
      *                  * Trattamento per fornitore non trovato       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di fornitore non trovato attivo    *
      *                      *-----------------------------------------*
           move      "#"                  to   w-wrk-fnt-mnf          .
      *                      *-----------------------------------------*
      *                      * Puntini nella ragione sociale           *
      *                      *-----------------------------------------*
           move      all "."              to   rf-fnt-rag-soc         .
      *                      *-----------------------------------------*
      *                      * Zero nella partita iva                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-fnt-prt-iva         .
      *                      *-----------------------------------------*
      *                      * Intestazione comune messaggio di errore *
      *                      *-----------------------------------------*
           perform   int-msg-err-000      thru int-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Editing codice fornitore                *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-fnt-cod-fnt       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Composizione messaggio di errore        *
      *                      *-----------------------------------------*
           move      spaces               to   m-msg                  .
           string    " Fornitore "        
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     " non esistente in archivio"
                                delimited by   size
                                          into m-msg                  .
      *                      *-----------------------------------------*
      *                      * Richiamo modulo messaggi di errore      *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       ela-reg-iva-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento riepilogo finale                            *
      *    *-----------------------------------------------------------*
       agg-rie-fin-000.
      *              *-------------------------------------------------*
      *              * Codice iva di riga di castelletto in area di    *
      *              * comodo                                          *
      *              *-------------------------------------------------*
           move      w-wrk-cst-cod
                    (w-wrk-ctr-003)       to   w-wrk-cod-iva          .
      *              *-------------------------------------------------*
      *              * Ciclo per ordinamento                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-ctr-001          .
       agg-rie-fin-100.
           add       1                    to   w-wrk-ctr-001          .
      *              *-------------------------------------------------*
      *              * Se oltre il limite massimo si esce al messaggio *
      *              * di errore                                       *
      *              *-------------------------------------------------*
           if        w-wrk-ctr-001        >    200
                     go to  agg-rie-fin-900.
      *              *-------------------------------------------------*
      *              * Se codice iva gia' presente tra quelli attuali  *
      *              * si procede per l'aggiornamento                  *
      *              *-------------------------------------------------*
           if        w-sor-cod-iva
                    (w-wrk-ctr-001)       =    w-wrk-cod-iva-345
                     go to  agg-rie-fin-200.
      *              *-------------------------------------------------*
      *              * Se codice iva non trovato tra quelli attuali    *
      *              * viene aggiunto                                  *
      *              *-------------------------------------------------*
           if        w-sor-cod-iva
                    (w-wrk-ctr-001)       =    zero
                     go to  agg-rie-fin-300
      *              *-------------------------------------------------*
      *              * Altrimenti si ricicla                           *
      *              *-------------------------------------------------*
           else      go to  agg-rie-fin-100.
       agg-rie-fin-200.
           add       w-wrk-cst-ibl
                    (w-wrk-ctr-003)       to   w-sor-imp-ibl
                                              (w-wrk-ctr-001)         .
           add       w-wrk-cst-imp
                    (w-wrk-ctr-003)       to   w-sor-imp-iva
                                              (w-wrk-ctr-001)         .
           go to     agg-rie-fin-999.                                      
       agg-rie-fin-300.
           move      w-wrk-cod-iva-345    to   w-sor-cod-iva
                                              (w-wrk-ctr-001)         .
           move      w-wrk-cst-ibl
                    (w-wrk-ctr-003)       to   w-sor-imp-ibl
                                              (w-wrk-ctr-001)         .
           move      w-wrk-cst-imp
                    (w-wrk-ctr-003)       to   w-sor-imp-iva
                                              (w-wrk-ctr-001)         .
           go to     agg-rie-fin-999.                                      
       agg-rie-fin-900.
      *                      *-----------------------------------------*
      *                      * Composizione messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Il programma e' interrotto per superamento massimo
      -              " numero di aliquote."
                                          to   m-msg                  .
      *                      *-----------------------------------------*
      *                      * Richiamo modulo messaggi di errore      *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Segnale di interruzione immediata       *
      *                      *-----------------------------------------*
           move      "#"                  to   w-wrk-flg-fin          .
       agg-rie-fin-999.
           exit.

