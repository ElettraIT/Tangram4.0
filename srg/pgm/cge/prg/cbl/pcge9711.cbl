      *    *===========================================================*
      *    * Routine stampa corrispettivo in valuta                    *
      *    *-----------------------------------------------------------*
       stp-cor-inv-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se gestione iva intracomunitaria non atti-  *
      *                  * gestione : oltre                            *
      *                  *---------------------------------------------*
           if        w-prs-iic-snx        not  = "S"
                     go to stp-cor-inv-999.
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione gestione doppio   *
      *                  * giornale iva intracomunitario               *
      *                  *---------------------------------------------*
           if        w-prs-snx-dgi        =    "S"
                     go to stp-cor-inv-999.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento iva                  *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-iva       not  = "D" and
                     rf-mgi-tip-iva       not  = "E"
                     go to stp-cor-inv-999.
      *              *-------------------------------------------------*
      *              * Esecuzione                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Stampa literal                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      36                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      77                   to   p-pos                  .
           move      "Corrispettivo operazione in valuta :"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Lettura record [iit]                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start su file [iit]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFCGE    "         to   f-key                  .
           move      rf-mgi-dat-reg       to   rf-iit-dtr-cge         .
           move      rf-mgi-num-prt       to   rf-iit-prt-cge         .
           move      zero                 to   rf-iit-dat-reg         .
           move      zero                 to   rf-iit-num-prt         .
           move      "pgm/iic/fls/ioc/obj/iofiit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-iit                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-cor-inv-100.
      *                      *-----------------------------------------*
      *                      * Lettura primo record [iit]              *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/iic/fls/ioc/obj/iofiit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-iit                 .
      *                          *-------------------------------------*
      *                          * Test se 'At end'                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-cor-inv-100.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-iit-dtr-cge       not  = rf-mgi-dat-reg or
                     rf-iit-prt-cge       not  = rf-mgi-num-prt
                     go to stp-cor-inv-100.
      *                      *-----------------------------------------*
      *                      * Se valore a zero : come per non trovato *
      *                      *-----------------------------------------*
           if        rf-iit-tco-eiv       =    zero
                     go to stp-cor-inv-100.
      *                      *-----------------------------------------*
      *                      * Stampa valore corrispettivo in valuta   *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        rf-iit-tco-eiv       >    9999999999 or
                     rf-iit-tco-eiv       <   -9999999999
                     move  13             to   p-car
           else      move  10             to   p-car                  .
           move      03                   to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        rf-iit-tco-eiv       >    9999999999 or
                     rf-iit-tco-eiv       <   -9999999999
                     move  "<BD"          to   p-edm
           else      move  "<GBD"         to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      115                  to   p-pos                  .
           move      rf-iit-tco-eiv       to   p-num                  .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * A interlinea                            *
      *                      *-----------------------------------------*
           go to     stp-cor-inv-900.
       stp-cor-inv-100.
