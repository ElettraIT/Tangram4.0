      *                  *---------------------------------------------*
           move      w-fnd-arc-zcn-pdc    to   w-mcs-cod-pdc          .
           if        w-mcs-cod-con        not  = zero and
                     w-mcs-cod-stc        =    zero
                     go to acc-cod-con-224
           else if   w-mcs-cod-con        not  = zero and
                     w-mcs-cod-stc        not  = zero
                     go to acc-cod-con-226
           else      go to acc-cod-con-100.
       acc-cod-con-224.
