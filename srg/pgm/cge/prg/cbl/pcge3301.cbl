           move      "UN"                 to   p-ope                  .
           move      p-lnr                to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           if        p-pos                >    22
                     move   "#"           to   p-mrk
           else      move   spaces        to   p-mrk                  .
           if        p-mrk                not  = spaces
                     go to  int-pag-sta-340.
       int-pag-sta-320.
      *                      *-----------------------------------------*
      *                      * Titolo stampa                           *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      24                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      25                   to   p-pos                  .
           move      "SITUAZIONE CONTABILE AL "
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Data situazione contabile               *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      p-lnr                to   p-lin                  .
           add       24                   to   p-pos                  .
           move      rr-dat-sit           to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           if        p-mrk                =    spaces
                     go to  int-pag-sta-340.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     int-pag-sta-360.
       int-pag-sta-340.
      *                      *-----------------------------------------*
      *                      * Data stampa                             *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      p-lnr                to   p-lin                  .
           move      61                   to   p-pos                  .
           if        p-pag                <    10
                     add   4              to   p-pos
           else if   p-pag                <    100
                     add   3              to   p-pos
           else if   p-pag                <    1000
                     add   2              to   p-pos
           else if   p-pag                <    10000
                     add   1              to   p-pos                  .
           move      s-dat                to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Literal per numero pagina               *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           add       10                   to   p-pos                  .
           move      "Pag."               to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Numero pagina                           *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        p-pag                <    10
                     move  1              to   p-car
           else if   p-pag                <    100
                     move  2              to   p-car
           else if   p-pag                <    1000
                     move  3              to   p-car
           else if   p-pag                <    10000
                     move  4              to   p-car
           else      move  5              to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           add       5                    to   p-pos                  .
           move      p-pag                to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Se non e' ancora stato stampato         *
      *                      * il titolo, lo si fa' ora                *
      *                      *-----------------------------------------*
           if        p-mrk                not  = spaces
                     go to  int-pag-sta-320.
       int-pag-sta-360.
      *                  *---------------------------------------------*
      *                  * Linea di '-'                                *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      80                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      all   "-"            to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Linea della fincatura                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * 'Codice e descrizione mastro'           *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      27                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      01                   to   p-pos                  .
           move      "Codice e descrizione mastro"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * 'Saldo alla data'                       *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      15                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      56                   to   p-pos                  .
           move      "Saldo alla data"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Posizionamento fisso per lasciare una in-   *
      *                  * terlinea di separazione                     *
      *                  *---------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

      *    *===========================================================*
