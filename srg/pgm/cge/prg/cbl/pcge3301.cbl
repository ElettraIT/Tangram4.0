      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-sdo-bil          .
      *              *-------------------------------------------------*
      *              * Normalizzazione area per bufferizzazione        *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-tbl              .
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore record letti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-num-ele          .
       det-ini-sdi-100.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per la start             *
      *              *-------------------------------------------------*
           move      rr-cod-mas           to   w-mcs-cod-mas          .
           move      rr-cod-con           to   w-mcs-cod-con          .
           move      zero                 to   w-mcs-cod-stc          .
      *              *-------------------------------------------------*
      *              * Start du [pdc]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODSTC"             to   f-key                  .
           move      w-mcs-cod-pdc        to   rf-pdc-cod-pdc         .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                  *---------------------------------------------*
      *                  * Test su uscita                              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  det-ini-sdi-900.
       det-ini-sdi-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [pdc]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                  *---------------------------------------------*
      *                  * Test se at end                              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  det-ini-sdi-900.
       det-ini-sdi-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessari test su mastro o conto    *
      *                  *---------------------------------------------*
           if        rr-cod-mas           =    zero and
                     rr-cod-con           =    zero
                     go to det-ini-sdi-400.
      *                  *---------------------------------------------*
      *                  * Scomposizione sottoconto per eventuali      *
      *                  * selezioni                                   *
      *                  *---------------------------------------------*
           move      rf-pdc-cod-pdc       to   w-mcs-cod-pdc          .
      *                  *---------------------------------------------*
      *                  * Confronto con mastro                        *
      *                  *---------------------------------------------*
           if        w-prs-liv-pdc        =    2
                     go to det-ini-sdi-320.
           if        rr-cod-mas           =    zero
                     go to det-ini-sdi-320.
           if        w-mcs-cod-mas        not  = rr-cod-mas
                     go to det-ini-sdi-900.
       det-ini-sdi-320.
      *                  *---------------------------------------------*
      *                  * Confronto con conto                         *
      *                  *---------------------------------------------*
           if        rr-cod-con           =    zero
                     go to det-ini-sdi-400.
           if        w-mcs-cod-con        not  = rr-cod-con
                     go to det-ini-sdi-900.
       det-ini-sdi-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [pdc]                              *
      *              *-------------------------------------------------*
       det-ini-sdi-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore record letti               *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-num-ele          .
      *                  *---------------------------------------------*
      *                  * Test se oltre il massimo                    *
      *                  *---------------------------------------------*
           if        w-buf-num-ele        >    1000
                     go to  det-ini-sdi-900.
       det-ini-sdi-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice sottoconto               *
      *              *-------------------------------------------------*
           move      rf-pdc-cod-pdc       to   w-buf-cod-pdc
                                              (w-buf-num-ele)         .
      *              *-------------------------------------------------*
      *              * Bufferizzazione descrizione sottoconto          *
      *              *-------------------------------------------------*
           move      rf-pdc-des-pdc       to   w-buf-des-pdc
                                              (w-buf-num-ele)         .
      *              *-------------------------------------------------*
      *              * Inizializzazione saldo alla data                *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-sdo-dat
                                              (w-buf-num-ele)         .
      *              *-------------------------------------------------*
      *              * Richiamo routine determinazione saldo alla data *
      *              *-------------------------------------------------*
           perform   det-sdo-dat-000      thru det-sdo-dat-999        .
           move      w-sad-sdo-dat        to   w-buf-sdo-dat
                                              (w-buf-num-ele)         .
       det-ini-sdi-800.
      *              *-------------------------------------------------*
      *              * Riciclo nella lettura del file [pdc]            *
      *              *-------------------------------------------------*
           go to     det-ini-sdi-200.
       det-ini-sdi-900.
      *              *-------------------------------------------------*
      *              * Chiusura file [pdc]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *              *-------------------------------------------------*
      *              * Chiusura file [mgs]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *              *-------------------------------------------------*
      *              * Chiusura file [mgr]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
       det-ini-sdi-999.
           exit.

      *    *===========================================================*
      *    * Routine di determinazione saldo alla data                 *
      *    *-----------------------------------------------------------*
       det-sdo-dat-000.
      *              *-------------------------------------------------*
      *              * Determinazione saldo ad inizio anno             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione se necessario lettura di una *
      *                  * o due schede saldi                          *
      *                  *                                             *
      *                  * - Se non e' mai stata eseguita una chiusura *
      *                  *   si leggono comunque due schede            *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio richiesto e' uguale o in-  *
      *                  *   feriore all'ultimo esercizio di chiusura  *
      *                  *   si legge una sola scheda                  *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio precedente quello della    *
      *                  *   data richiesta e' pari all'esercizio del- *
      *                  *   l'ultima chiusura si legge una sola sche- *
      *                  *   da                                        *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Si leggono due schede                     *
      *                  *---------------------------------------------*
           if        rn-dat-bil-ese-bil   =    zero
                     move  w-sit-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-sit-ann-sit        not  > rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else if   rn-dat-bil-flg-bil   not  = spaces
                     move  rn-dat-bil-ese-bil
                                          to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-sit-ann-pre        =    rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else      move  w-sit-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010.
       det-sdo-dat-010.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio di chiusura        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se conto di tipo Economico : saldo ini- *
      *                      * ziale zero                              *
      *                      *-----------------------------------------*
           if        rf-pdc-tip-cnt       =    "E"
                     move   zero          to   w-sad-sdo-ini
                     go to  det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Se conto di tipo Patrimoniale : deter-  *
      *                      * minazione saldo finale esercizio di bi- *
      *                      * lancio                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione campi chiave           *
      *                          *-------------------------------------*
           move      w-wrk-ann-ese        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Determinazione saldo finale eserci- *
      *                          * zio di bilancio                     *
      *                          *-------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
           move      zero                 to   I                      .
       det-sdo-dat-020.
           add       1                    to   I                      .
           if        I                    >    12
                     go to  det-sdo-dat-040.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-ini          .
           go to     det-sdo-dat-020.
       det-sdo-dat-040.
           add       rf-mgs-dar-bil       to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-ini          .
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo bilancio        *
      *                          *-------------------------------------*
           add       w-sad-sdo-ini        to   w-wrk-sdo-bil          .
       det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Lettura [mgs] esercizio richiesto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione chiave per [mgs]       *
      *                          *-------------------------------------*
           move      w-sit-ann-sit        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
           go to     det-sdo-dat-200.
       det-sdo-dat-100.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio richiesto          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record file [mgs]       *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Preparazione chiave per [mgs]           *
      *                      *-----------------------------------------*
           move      w-sit-ann-sit        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                      *-----------------------------------------*
      *                      * Lettura file [mgs]                      *
      *                      *-----------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Determinazione saldo inizio anno        *
      *                      *-----------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
       det-sdo-dat-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo alla data di partenza      *
      *              *-------------------------------------------------*
           move      w-sad-sdo-ini        to   w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per accumulo progressivi men-*
      *              * sili anno in corso fino a mese precedente a     *
      *              * quello indicato da data situazione              *
      *              *-------------------------------------------------*
           move      w-sit-mes-sit        to   I                      .
       det-sdo-dat-220.
           subtract  1                    from I                      .
           if        I                    =    zero
                     go to  det-sdo-dat-240.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-dat          .
           go to     det-sdo-dat-220.
       det-sdo-dat-240.
      *              *-------------------------------------------------*
      *              * Se data situazione contabile uguale a data at-  *
      *              * tuale si aggiungono i progressivi del mese at-  *
      *              * tuale                                           *
      *              *-------------------------------------------------*
           if        rr-dat-sit           not  = w-wrk-dat-att
                     go to  det-sdo-dat-250.
           add       rf-mgs-dar-mes
                     (w-sit-mes-sit)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-sit-mes-sit)      from w-sad-sdo-dat          .
           go to     det-sdo-dat-999.
       det-sdo-dat-250.
      *              *-------------------------------------------------*
      *              * Controllo se giorno situazione e' fine mese     *
      *              *-------------------------------------------------*
           move      rr-dat-sit           to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Se la data e' corretta vuol dire che il     *
      *                  * giorno situazione non e' a fine mese        *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to  det-sdo-dat-300.
      *                      *-----------------------------------------*
      *                      * Se fine mese si aggiungono i progressivi*
      *                      * del mese attuale                        *
      *                      *-----------------------------------------*
           add       rf-mgs-dar-mes
                     (w-sit-mes-sit)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-sit-mes-sit)      from w-sad-sdo-dat          .
      *                      *-----------------------------------------*
      *                      * Se mese richiesto e' quello di chiusura *
      *                      * esercizio, si aggiungono i progressivi  *
      *                      * di bilancio                             *
      *                      *-----------------------------------------*
           if        w-sit-mes-sit        not  = w-ese-cge-mce
                     go to  det-sdo-dat-999.
           add       rf-mgs-dar-bil       to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-dat          .
           go to     det-sdo-dat-999.
       det-sdo-dat-300.
      *              *-------------------------------------------------*
      *              * Normalizzazione record file [mgr]               *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura file [mgr]      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
           move      rf-pdc-cod-pdc       to   rf-mgr-cod-pdc         .
      *                  *---------------------------------------------*
      *                  * Data di registrazione                       *
      *                  *---------------------------------------------*
           move      zero                 to   s-dat                  .
           move      01                   to   s-gio                  .
           move      w-sit-mes-sit        to   s-mes                  .
           move      w-sit-ann-sit        to   s-saa                  .
           move      s-dat                to   rf-mgr-dat-reg         .
      *                  *---------------------------------------------*
      *                  * Numero protocollo                           *
      *                  *---------------------------------------------*
           move      zero                 to   rf-mgr-num-prt         .
      *                  *---------------------------------------------*
      *                  * Numero progressivo                          *
      *                  *---------------------------------------------*
           move      zero                 to   rf-mgr-num-prg         .
      *              *-------------------------------------------------*
      *              * Start file [mgr] per chiave "PDCDAT"            *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PDCDAT"             to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
       det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mgr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
      *              *-------------------------------------------------*
      *              * Test se superamento limiti massimi              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
           if        rf-mgr-cod-pdc       not  = rf-pdc-cod-pdc
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Data registrazione                          *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-reg       >    rr-dat-sit
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Se movimento di bilancio si ricicla         *
      *                  *---------------------------------------------*
           if        rf-mgr-snx-mob        not  = "N"
                     go to  det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo alla data                   *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-sad-sdo-dat
           else      add      rf-mgr-imp-mov
                                          to   w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura [mgr]                        *
      *              *-------------------------------------------------*
           go to     det-sdo-dat-500.
       det-sdo-dat-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .
