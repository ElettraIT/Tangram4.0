      *                  *---------------------------------------------*
           if        rf-zti-cod-top       =    1110
                     move  "IVP18"        to   w-rig-val-det (1)
      *                  *---------------------------------------------*
      *                  * Codice Fiscale Dichiarante                  *
      *                  *---------------------------------------------*
           else if   rf-zti-cod-top       =    1120
                     move  w-det-val-det-cfd
                                          to   w-rig-val-det (1)
      *                  *---------------------------------------------*
      *                  * Codice Carica                               *
      *                  *---------------------------------------------*
           else if   rf-zti-cod-top       =    1130
                     move  rf-ada-cca-lgr to   w-rig-val-det (1)
      *                  *---------------------------------------------*
      *                  * Codice Fiscale                              *
      *                  *---------------------------------------------*
