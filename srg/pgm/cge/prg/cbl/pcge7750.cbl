           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivc                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-fun-900.
       rou-let-reg-fun-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [ivc]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivc                 .
      *                  *---------------------------------------------*
      *                  * Se fine file                                *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-fun-900.
       rou-let-reg-fun-300.
      *              *-------------------------------------------------*
      *              * Max su [ivc]                                    *
      *              *-------------------------------------------------*
           if        rf-ivc-ann-ivc       not  = w-tes-ann-dic    or
                     rf-ivc-mes-ivc       not  = w-det-val-det-min
                     go to rou-let-reg-fun-900.
       rou-let-reg-fun-400.
