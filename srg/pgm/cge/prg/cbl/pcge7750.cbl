       pre-snx-del-999.
           exit.

      *    *===========================================================*
      *    * Routine post-richiesta di ratifica tasto Delete           *
      *    *-----------------------------------------------------------*
       pos-snx-del-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pos-snx-del      .
       pos-snx-del-999.
           exit.

      *    *===========================================================*
      *    * Routine post-exit su inserimento                          *
      *    *-----------------------------------------------------------*
       pos-exi-ins-000.
       pos-exi-ins-999.
           exit.

      *    *===========================================================*
      *    * Routine post-exit su modifica                             *
      *    *-----------------------------------------------------------*
       pos-exi-mod-000.
       pos-exi-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine post-exit su visualizzazione                      *
      *    *-----------------------------------------------------------*
       pos-exi-vis-000.
       pos-exi-vis-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Scrittura movimento su files                    *
      *              *-------------------------------------------------*
           perform   scr-mov-fil-000      thru scr-mov-fil-999        .
      *              *-------------------------------------------------*
      *              * Stampa eventuale                                *
      *              *-------------------------------------------------*
           perform   exe-stp-ele-000      thru exe-stp-ele-999        .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Scrittura movimento su files                    *
      *              *-------------------------------------------------*
           perform   scr-mov-fil-000      thru scr-mov-fil-999        .
      *              *-------------------------------------------------*
      *              * Stampa eventuale                                *
      *              *-------------------------------------------------*
           perform   exe-stp-ele-000      thru exe-stp-ele-999        .
       pos-cnf-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Delete movimento da files                       *
      *              *-------------------------------------------------*
           perform   del-mov-fil-000      thru del-mov-fil-999        .
       pos-cnf-ann-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [ivc]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-ivc-000      thru del-rec-ivc-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Test se separatore                              *
      *              *-------------------------------------------------*
           if        w-rig-cod-top (1)    =    zero
                     go to scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Trattamento file righe [ivc]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [ivc]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-ivc-000      thru wrt-rec-ivc-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-cnt-var-tes-cor    not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [ivc]                       *
      *                          *-------------------------------------*
           perform   rew-rec-ivc-000      thru rew-rec-ivc-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Nessun trattamento file testata                 *
      *              *-------------------------------------------------*
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Cancellazione righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a testata             *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-mov-fil-500.
       del-mov-fil-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale righe corpo             *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a testata                       *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Test se separatore                          *
      *                  *---------------------------------------------*
           if        w-rig-cod-top (1)    =    zero
                     go to del-mov-fil-100.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Delete record file righe [ivc]              *
      *                  *---------------------------------------------*
           perform   del-rec-ivc-000      thru del-rec-ivc-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura riga corpo successiva     *
      *                  *---------------------------------------------*
           go to     del-mov-fil-100.
       del-mov-fil-500.
      *              *-------------------------------------------------*
      *              * Cancellazione testata file [ivc]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Delete record [ivc]                         *
      *                  *---------------------------------------------*
           perform   del-rec-ivc-000      thru del-rec-ivc-999        .
       del-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record righe [ivc]                           *
      *    *-----------------------------------------------------------*
       cmp-rec-ivc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivc                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      w-tes-ann-dic        to   rf-ivc-ann-ivc         .
           move      w-rig-mes-dic (1)    to   rf-ivc-mes-ivc         .
           move      w-rig-cod-top (1)    to   rf-ivc-cod-top         .
           move      w-rig-val-imp (1)    to   rf-ivc-val-imp         .
           move      w-rig-val-det (1)    to   rf-ivc-val-det         .
       cmp-rec-ivc-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record righe [ivc]                              *
      *    *-----------------------------------------------------------*
       wrt-rec-ivc-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-ivc-000      thru cmp-rec-ivc-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivc                 .
       wrt-rec-ivc-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record righe [ivc]                            *
      *    *-----------------------------------------------------------*
       rew-rec-ivc-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-ivc-000      thru cmp-rec-ivc-999        .
      *              *-------------------------------------------------*
      *              * Force Put record                                *
      *              *-------------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivc                 .
       rew-rec-ivc-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record righe [ivc]                          *
      *    *-----------------------------------------------------------*
       del-rec-ivc-000.
      *              *-------------------------------------------------*
      *              * Composizione chiave primaria                    *
      *              *-------------------------------------------------*
           move      w-tes-ann-dic        to   rf-ivc-ann-ivc         .
           move      w-rig-mes-dic (2)    to   rf-ivc-mes-ivc         .
           move      w-rig-cod-top (2)    to   rf-ivc-cod-top         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivc                 .
       del-rec-ivc-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/werrbox0.cps"                   .

      *    *===========================================================*
      *    * Esecuzione stampa                                         *
      *    *-----------------------------------------------------------*
       exe-stp-ele-000.
      *              *-------------------------------------------------*
      *              * Se flag di stampa in Off : uscita               *
      *              *-------------------------------------------------*
           if        w-cnt-mst-flg        =    spaces
                     go to exe-stp-ele-999.
       exe-stp-ele-050.
      *              *-------------------------------------------------*
      *              * Esecuzione della stampa ad uso interno          *
      *              *-------------------------------------------------*
           perform   stp-frg-inc-000      thru stp-frg-inc-999        .
       exe-stp-ele-060.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      13                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      68                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      48                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      "STAMPA IN ESECUZIONE - ATTENDERE ..."
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-stp-ele-080.
      *              *-------------------------------------------------*
      *              * Wait di 3 secondi                               *
      *              *-------------------------------------------------*
           call      "swd/mod/prg/obj/mwait0"                         .
           call      "swd/mod/prg/obj/mwait0"                         .
           call      "swd/mod/prg/obj/mwait0"                         .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-stp-ele-100.
      *              *-------------------------------------------------*
      *              * Ciclo di stampa del frontespizione in formato   *
      *              * ministeriale e dei moduli di dettaglio          *
      *              *-------------------------------------------------*
           move      04                   to   w-sta-sco-max-ele      .
           move      zero                 to   w-sta-sco-ctr-ele      .
       exe-stp-ele-200.
           add       1                    to   w-sta-sco-ctr-ele      .
           if        w-sta-sco-ctr-ele    >    w-sta-sco-max-ele
                     go to exe-stp-ele-500.
       exe-stp-ele-300.
      *              *-------------------------------------------------*
      *              * Fase di stampa                                  *
      *              *                                                 *
      *              * N.B.: serve per leggere i parametri precablati  *
      *              *       che devono essere inseriti per differen-  *
      *              *       ziare Frontespizio da Dettaglio           *
      *              *-------------------------------------------------*
           if        w-sta-sco-ctr-ele    =    1
                     move  "cge77f"       to   i-ide-fas
           else      move  "cge77d"       to   i-ide-fas              .
       exe-stp-ele-350.
      *              *-------------------------------------------------*
      *              * Apertura modulo di stampa documento             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul contatore                          *
      *                  *---------------------------------------------*
           if        w-sta-sco-ctr-ele    >    2
                     go to exe-stp-ele-400.
      *                  *---------------------------------------------*
      *                  * Solo al primo e al secondo passaggio        *
      *                  *---------------------------------------------*
           perform   opn-mod-stp-000      thru opn-mod-stp-999        .
       exe-stp-ele-400.
      *              *-------------------------------------------------*
      *              * Esecuzione stampa documento                     *
      *              *-------------------------------------------------*
           perform   exe-mod-stp-000      thru exe-mod-stp-999        .
       exe-stp-ele-450.
      *              *-------------------------------------------------*
      *              * Chiusura modulo di stampa documento             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul contatore                          *
      *                  *---------------------------------------------*
           if        w-sta-sco-ctr-ele    not  = 1 and
                     w-sta-sco-ctr-ele    not  = 4
                     go to exe-stp-ele-490.
      *                  *---------------------------------------------*
      *                  * Solo al primo e al quarto passaggio         *
      *                  *---------------------------------------------*
           perform   cls-mod-stp-000      thru cls-mod-stp-999        .
       exe-stp-ele-490.
      *              *-------------------------------------------------*
      *              * Riciclo a stampa copia                          *
      *              *-------------------------------------------------*
           go to     exe-stp-ele-200.
       exe-stp-ele-500.
       exe-stp-ele-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-stp-ele-999.
       exe-stp-ele-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione di una stampa, in foreground, inclusa in un    *
      *    * programma non dedicato alla sola stampa                   *
      *    *                                                           *
      *    * Prerequisiti :                                            *
      *    *                                                           *
      *    * - Se la stampa prevede un sort, devono esistere :         *
      *    *                                                           *
      *    *   - L'Input-Output Section per il file [srt]              *
      *    *   - La File Section per il file [srt] con il suo record   *
      *    *                                                           *
      *    * - In ogni caso devono esistere in Working-Storage :       *
      *    *                                                           *
      *    *   - L'area di comunicazione per modulo 'mpslct'           *
      *    *   - L'area di comunicazione per modulo 'mbckgx'           *
      *    *   - L'area di comunicazione per modulo 'mmessg'           *
      *    *   - L'area di comunicazione per modulo 'mprint'           *
      *    *                                                           *
      *    *   - La work-area di controllo sub-funzione di stampa      *
      *    *   - La work-area per controllo rotture di livello         *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       stp-frg-inc-000.
      *              *-------------------------------------------------*
      *              * Flag di stampa effettivamente eseguita a : No   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-stp-frg-inc-flg      .
      *              *-------------------------------------------------*
      *              * Open files per sub-funzione di stampa, con u-   *
      *              * scita in caso di errore                         *
      *              *-------------------------------------------------*
           perform   opn-fls-stp-000      thru opn-fls-stp-999        .
           if        w-stp-opn-fls-stp    not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Preparazione defaults per parametri di selezio- *
      *              * ne stampa                                       *
      *              *-------------------------------------------------*
           perform   pre-prm-stp-000      thru pre-prm-stp-999        .
      *              *-------------------------------------------------*
      *              * Selezione parametri stampa, con uscita in caso  *
      *              * di mancata selezione                            *
      *              *-------------------------------------------------*
           perform   sel-prm-stp-000      thru sel-prm-stp-999        .
           if        w-stp-sel-prm-stp    not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Inizializzazione rullino messaggi di foreground *
      *              * con uscita in caso di errore                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
            if       m-rsc                not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Lettura parametri di selezione stampa, con u-   *
      *              * scita in caso di errore                         *
      *              *-------------------------------------------------*
           perform   let-sel-stp-000      thru let-sel-stp-999        .
           if        w-stp-let-sel-stp    not  = spaces
                     go to stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Esecuzione eventuale sort preliminare           *
      *              *-------------------------------------------------*
           perform   exe-srt-stp-000      thru exe-srt-stp-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se sort eseguito           *
      *              *-------------------------------------------------*
           if        w-stp-exe-srt-stp    =    spaces
                     go to stp-frg-inc-400
           else      go to stp-frg-inc-500.
       stp-frg-inc-400.
      *              *-------------------------------------------------*
      *              * Se sort non eseguito                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di report-program                     *
      *                  *---------------------------------------------*
           perform   prn-rou-pri-000      thru prn-rou-pri-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     stp-frg-inc-600.
       stp-frg-inc-500.
      *              *-------------------------------------------------*
      *              * Se sort eseguito                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     stp-frg-inc-600.
       stp-frg-inc-600.
      *              *-------------------------------------------------*
      *              * Cancellazione modulo stampa                     *
      *              *-------------------------------------------------*
           cancel    "swd/mod/prg/obj/mprint"                         .
       stp-frg-inc-900.
      *              *-------------------------------------------------*
      *              * Visualizzazione eventuali errori di esecuzione  *
      *              *-------------------------------------------------*
           move      "VE"                 to   b-ope                  .
           move      "F"                  to   b-tfe                  .
           move      i-ide-des            to   b-chr                  .
           call      "swd/mod/prg/obj/mbckgv"
                                         using b                      .
           cancel    "swd/mod/prg/obj/mbckgv"                         .
       stp-frg-inc-800.
      *              *-------------------------------------------------*
      *              * Close files per sub-funzione di stampa          *
      *              *-------------------------------------------------*
           perform   cls-fls-stp-000      thru cls-fls-stp-999        .
       stp-frg-inc-999.
           exit.

      *    *===========================================================*
      *    *  Selezione parametri stampa, per sub-funzione di stampa   *
      *    *-----------------------------------------------------------*
       sel-prm-stp-000.
      *              *-------------------------------------------------*
