      *                  *---------------------------------------------*
           else if   rf-zti-cod-top       =    2130
                     move  w-det-val-det-pti
                                          to   w-rig-val-det (1)
      *                  *---------------------------------------------*
      *                  * Codice Fiscale Dichiarante                  *
      *                  *---------------------------------------------*
           else if   rf-zti-cod-top       =    2170
                     move  w-det-val-det-cfd
                                          to   w-rig-val-det (1)
      *                  *---------------------------------------------*
