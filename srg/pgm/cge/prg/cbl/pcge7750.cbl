      *                  *---------------------------------------------*
      *                  * Forzatura tag 'Comunicazione'               *
      *                  *                                             *
      *                  * N.B.: chiarire ruolo di identificativo      *
      *                  *---------------------------------------------*
           move      "    <iv:Comunicazione identificativo=""00001"">"
                                          to   g-rec                  .
      *                  *---------------------------------------------*
      *                  * Scrittura record                            *
      *                  *---------------------------------------------*
           perform   put-nxt-out-000      thru put-nxt-out-999        .
      *                  *---------------------------------------------*
      *                  * Apertura tag 'Frontespizio'                 *
      *                  *---------------------------------------------*
           move      "Frontespizio"       to   w-sta-emi-xml-pmt      .
           move      "A"                  to   w-sta-emi-xml-ope      .
           move      "+"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *                  *---------------------------------------------*
      *                  * Flag di trattamento tag modulo              *
      *                  *---------------------------------------------*
           move      "1"                  to   w-sta-emi-xml-atm      .
       emi-fil-xml-450.
      *                  *---------------------------------------------*
      *                  * Se inizio 'Dati contabili'                  *
      *                  *---------------------------------------------*
           if        w-rig-cod-top (1)    not  = 5005
                     go to emi-fil-xml-500.
           if        w-sta-emi-xml-fro    =    spaces
                     go to emi-fil-xml-480.
      *                  *---------------------------------------------*
      *                  * Flag di 'Frontespizio' chiuso               *
      *                  *---------------------------------------------*
           move      spaces               to   w-sta-emi-xml-fro      .
      *                  *---------------------------------------------*
      *                  * Chiusura tag 'Frontespizio'                 *
      *                  *---------------------------------------------*
           move      "Frontespizio"       to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *                  *---------------------------------------------*
      *                  * Apertura tag 'DatiContabili'                *
      *                  *---------------------------------------------*
           move      "DatiContabili"      to   w-sta-emi-xml-pmt      .
           move      "A"                  to   w-sta-emi-xml-ope      .
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-480.
      *                  *---------------------------------------------*
      *                  * Apertura tag 'Modulo'                       *
      *                  *---------------------------------------------*
           move      "Modulo"             to   w-sta-emi-xml-pmt      .
           move      "A"                  to   w-sta-emi-xml-ope      .
      *
           if        w-sta-emi-xml-atm    =    "2"
                     move  "="            to   w-sta-emi-xml-ind
           else      move  "+"            to   w-sta-emi-xml-ind
                     move  "2"            to   w-sta-emi-xml-atm      .
      *
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-500.
       emi-fil-xml-600.
      *              *-------------------------------------------------*
      *              * Emissione tag                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su valore impostato                    *
      *                  *---------------------------------------------*
           if        w-rig-val-imp (1)    =    spaces
                     go to emi-fil-xml-700.
      *                  *---------------------------------------------*
      *                  * Estrazione prompt                           *
      *                  *---------------------------------------------*
           move      w-rig-cod-top-des (1)
                                          to   w-all-str-alf          .
           move      " "                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
      *
           move      40                   to   w-all-str-lun          .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Emissione tag                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prompt                                  *
      *                      *-----------------------------------------*
           move      w-all-str-alf        to   w-sta-emi-xml-pmt      .
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "E"                  to   w-sta-emi-xml-ope      .
      *                      *-----------------------------------------*
      *                      * Valore                                  *
      *                      *-----------------------------------------*
           move      w-rig-val-imp (1)    to   w-sta-emi-xml-val      .
      *                      *-----------------------------------------*
      *                      * Indentazione                            *
      *                      *-----------------------------------------*
           if        w-rig-cod-top (1)    =    1110 or
                     w-rig-cod-top (1)    =    2110 or
                     w-rig-cod-top (1)    =    5005
                     move  "+"            to   w-sta-emi-xml-ind
           else      move  "="            to   w-sta-emi-xml-ind      .
      *                      *-----------------------------------------*
      *                      * Emissione                               *
      *                      *-----------------------------------------*
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-700.
      *                  *---------------------------------------------*
      *                  * Se fine 'Dati contabili'                    *
      *                  *---------------------------------------------*
           if        w-rig-cod-top (1)    not  = 5190
                     go to emi-fil-xml-800.
      *                  *---------------------------------------------*
      *                  * Chiusura tag 'Modulo'                       *
      *                  *---------------------------------------------*
           move      "Modulo"             to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     emi-fil-xml-200.
       emi-fil-xml-900.
      *              *-------------------------------------------------*
      *              * Chiusura tag 'DatiContabili'                    *
      *              *-------------------------------------------------*
           move      "DatiContabili"      to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *              *-------------------------------------------------*
      *              * Chiusura tag 'Comunicazione'                    *
      *              *-------------------------------------------------*
           move      "Comunicazione"      to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *              *-------------------------------------------------*
      *              * Chiusura tag 'Fornitura'                        *
      *              *-------------------------------------------------*
           move      "Fornitura"          to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *              *-------------------------------------------------*
      *              * Chiusura file di output                         *
      *              *-------------------------------------------------*
           move      "CL"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo utilizzato             *
      *                  *---------------------------------------------*
           cancel    "swd/mod/prg/obj/mcvout"                         .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-fil-xml-999.
       emi-fil-xml-999.
           exit.

      *    *===========================================================*
      *    * Emissione file ministeriale in formato XML                *
      *    *                                                           *
      *    * Intestazione                                              *
      *    *-----------------------------------------------------------*
       emi-fil-xml-int-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Progressivo univoco                         *
      *                  *                                             *
      *                  * Il progressivo univoco del file e' rappre-  *
      *                  * sentato da una stringa alfanumerica di lun- *
      *                  * ghezza massima di 5 caratteri e con valori  *
      *                  * ammessi [a-z], [A-Z], [0-9]                 *
      *                  *                                             *
      *                  * Attualmente e' composta da:                 *
      *                  *                                             *
      *                  * - Anno dichiarazione       : 9999           *
      *                  * - Indicatore del trimestre : 9              *
      *                  *                                             *
      *                  * Esempio: 20171 = Primo trimestre 2017       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing anno dichiarazione              *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      w-tes-ann-dic        to   p-num                  .
           add       1900                 to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-val-ann      .
      *                      *-----------------------------------------*
      *                      * Editing trimestre dichiarazione         *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      w-tes-tri-dic        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-val-tri      .
      *                  *---------------------------------------------*
      *                  * Composizione identificatore univoco         *
      *                  *---------------------------------------------*
           move      05                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-det-edt-val-ann    to   w-all-str-cat (1)      .
           move      w-det-edt-val-tri    to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-det-edt-val-ide      .
      *                  *---------------------------------------------*
      *                  * Composizione nome file                      *
      *                  *---------------------------------------------*
           move      30                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "IT"                 to   w-all-str-cat (1)      .
           move      rf-ada-cod-fis       to   w-all-str-cat (2)      .
           move      "_LI_"               to   w-all-str-cat (3)      .
           move      w-det-edt-val-ide    to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Apertura del file in output                 *
      *                  *---------------------------------------------*
           move      w-all-str-alf        to   w-det-pth-fso-nam      .
           perform   det-pth-fso-000      thru det-pth-fso-999        .
      *                  *---------------------------------------------*
      *                  * Apertura del file in output                 *
      *                  *---------------------------------------------*
           move      "OO"                 to   g-ope                  .
           move      "seq "               to   g-nam                  .
           move      w-det-pth-fso-pth    to   g-pat                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       emi-fil-xml-int-100.
      *              *-------------------------------------------------*
      *              * Pulizia preliminare record sequenziale          *
      *              *-------------------------------------------------*
           move      spaces               to   g-rec                  .
      *              *-------------------------------------------------*
      *              * Normalizzazione indice di indentazione xml      *
      *              *-------------------------------------------------*
           move      zero                 to   w-sta-emi-xml-inx      .
       emi-fil-xml-int-150.
      *              *-------------------------------------------------*
      *              * Apertura file - direttiva xml                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura                                   *
      *                  *---------------------------------------------*
           move      "<?xml version=""1.0"" encoding=""UTF-8"" standalon
      -              "e=""yes""?>"        to   g-rec                  .
      *                  *---------------------------------------------*
      *                  * Scrittura record                            *
      *                  *---------------------------------------------*
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       emi-fil-xml-int-400.
      *              *-------------------------------------------------*
      *              * Apertura tag 'Fornitura'                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura                                   *
      *                  *---------------------------------------------*
           move      "<iv:Fornitura xmlns:iv=""urn:www.agenziaentrate.go
      -              "v.it:specificheTecniche:sco:ivp"" xmlns:ds=""http:
      -              "//www.w3.org/2000/09/xmldsig#"">"
                                          to   g-rec                  .
      *                  *---------------------------------------------*
      *                  * Scrittura record                            *
      *                  *---------------------------------------------*
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       emi-fil-xml-int-500.
      *              *-------------------------------------------------*
      *              * Apertura tag 'Intestazione'                     *
      *              *-------------------------------------------------*
           move      "Intestazione"       to   w-sta-emi-xml-pmt      .
           move      "A"                  to   w-sta-emi-xml-ope      .
           move      "+"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-int-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-fil-xml-int-999.
       emi-fil-xml-int-999.
           exit.

      *    *===========================================================*
      *    * Determinazione pathname completo per il file di appoggio  *
      *    * in output                                                 *
      *    *-----------------------------------------------------------*
       det-pth-fso-000.
      *              *-------------------------------------------------*
      *              * Preparazione nome file completo                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-pth-fso-pth      .
      *              *-------------------------------------------------*
      *              * Richiesta informazioni generali a segreteria    *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-ute                to   w-det-pth-fso-ute      .
      *              *-------------------------------------------------*
      *              * Pathname di base da segreteria                  *
      *              *-------------------------------------------------*
           move      "PB"                 to   s-ope                  .
           move      "asc "               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                          using s                     .
      *              *-------------------------------------------------*
      *              * Preparazione pathname per file completato       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione nome file completo             *
      *                  *---------------------------------------------*
           move      spaces               to   w-det-pth-fso-pth      .
           string    s-pat      delimited by   spaces
                     "/cbi/"    delimited by   size
                     w-det-pth-fso-nam
                                delimited by   spaces
                     ".xml"     delimited by   size
                                          into w-det-pth-fso-pth      .
       det-pth-fso-999.
           exit.

      *    *===========================================================*
      *    * Put next generica per output in sequenziale               *
      *    *-----------------------------------------------------------*
       put-nxt-out-000.
      *              *-------------------------------------------------*
      *              * Scrittura su sequenziale                        *
      *              *-------------------------------------------------*
           move      "PN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       put-nxt-out-999.
           exit.

      *    *===========================================================*
      *    * Emissione tag 'xml'                                       *
      *    *-----------------------------------------------------------*
       emi-tag-xml-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare prompt              *
      *              *-------------------------------------------------*
           move      w-sta-emi-xml-pmt    to   w-sta-emi-xml-pma      .
           move      w-sta-emi-xml-pmt    to   w-sta-emi-xml-pmc      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-sta-emi-xml-ope    =    "A"
                     go to emi-tag-xml-100
           else if   w-sta-emi-xml-ope    =    "E"
                     go to emi-tag-xml-300
           else      go to emi-tag-xml-500.
       emi-tag-xml-100.
      *              *=================================================*
      *              * Composizione tag xml di apertura                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "<"                  to   w-all-str-cat (1)      .
           move      w-sta-emi-xml-pre    to   w-all-str-cat (2)      .
           move      w-sta-emi-xml-pmt    to   w-all-str-cat (3)      .
           move      ">"                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-sta-emi-xml-str      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale indentazione                   *
      *                  *---------------------------------------------*
           go to     emi-tag-xml-800.
       emi-tag-xml-300.
      *              *=================================================*
      *              * Composizione tag xml con valore                 *
      *              *                                                 *
      *              * '<prompt> valore </prompt>'                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore presente                     *
      *                  *---------------------------------------------*
           if        w-sta-emi-xml-val    =    spaces
                     go to emi-tag-xml-900.
      *                  *---------------------------------------------*
      *                  * Filtraggio per eliminare eventuali carat-   *
      *                  * teri incompatibili con XML                  *
      *                  *---------------------------------------------*
           inspect   w-sta-emi-xml-val
                                replacing all  "&"
                                          by   "e"                    .
      *
           inspect   w-sta-emi-xml-val
                                replacing all  "<"
                                          by   "("                    .
      *
           inspect   w-sta-emi-xml-val
                                replacing all  ">"
                                          by   ")"                    .
      *                  *---------------------------------------------*
      *                  * Test se prompt composito                    *
      *                  *---------------------------------------------*
           move      w-sta-emi-xml-pmt    to   w-all-str-alf          .
           move      " "                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           if        w-all-str-num        not  > 1
                     go to emi-tag-xml-320.
      *                  *---------------------------------------------*
      *                  * Scorporo prompt                             *
      *                  *---------------------------------------------*
           move      w-all-str-cat (1)    to   w-sta-emi-xml-pmc      .
       emi-tag-xml-320.
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      220                  to   w-all-str-lun          .
           move      09                   to   w-all-str-num          .
           move      "<"                  to   w-all-str-cat (1)      .
           move      w-sta-emi-xml-pre    to   w-all-str-cat (2)      .
           move      w-sta-emi-xml-pma    to   w-all-str-cat (3)      .
           move      ">"                  to   w-all-str-cat (4)      .
           move      w-sta-emi-xml-val    to   w-all-str-cat (5)      .
           move      "</"                 to   w-all-str-cat (6)      .
           move      w-sta-emi-xml-pre    to   w-all-str-cat (7)      .
           move      w-sta-emi-xml-pmc    to   w-all-str-cat (8)      .
           move      ">"                  to   w-all-str-cat (9)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-sta-emi-xml-str      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale indentazione                   *
      *                  *---------------------------------------------*
           go to     emi-tag-xml-800.
       emi-tag-xml-500.
      *              *=================================================*
      *              * Composizione tag xml di chiusura                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "</"                 to   w-all-str-cat (1)      .
           move      w-sta-emi-xml-pre    to   w-all-str-cat (2)      .
           move      w-sta-emi-xml-pmt    to   w-all-str-cat (3)      .
           move      ">"                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-sta-emi-xml-str      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale indentazione                   *
      *                  *---------------------------------------------*
           go to     emi-tag-xml-800.
       emi-tag-xml-800.
      *              *=================================================*
      *              * Eventuale indentazione                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice di indentazione       *
      *                  *---------------------------------------------*
           if        w-sta-emi-xml-ind    =    "+"
                     add      w-sta-emi-xml-tab
                                          to   w-sta-emi-xml-inx
           else if   w-sta-emi-xml-ind    =    "-"
                     subtract w-sta-emi-xml-tab
                                          from w-sta-emi-xml-inx      .
      *                  *---------------------------------------------*
      *                  * Determinazione lunghezza stringa            *
      *                  *---------------------------------------------*
           move      w-sta-emi-xml-str    to   w-all-str-alf          .
           perform   all-str-lun-000      thru all-str-lun-999        .
           move      w-all-str-lun        to   w-sta-emi-xml-lun      .
      *                  *---------------------------------------------*
      *                  * Indentazione                                *
      *                  *---------------------------------------------*
           move      spaces               to   w-all-str-alf          .
           move      w-sta-emi-xml-inx    to   w-sta-emi-xml-inw      .
           add       1                    to   w-sta-emi-xml-inw      .
           move      w-sta-emi-xml-str    to   w-all-str-alf
                                              (w-sta-emi-xml-inw :
                                               w-sta-emi-xml-lun)     .
           move      w-all-str-alf        to   w-sta-emi-xml-str      .
       emi-tag-xml-850.
      *              *=================================================*
      *              * Emissione                                       *
      *              *-------------------------------------------------*
           move      w-sta-emi-xml-str    to   g-rec                  .
      *              *-------------------------------------------------*
      *              * Scrittura record in file Line-Sequential        *
      *              *-------------------------------------------------*
           perform   put-nxt-out-000      thru put-nxt-out-999        .
       emi-tag-xml-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-tag-xml-999.
       emi-tag-xml-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [zci]                         *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/larczci0.lts"                   .

      *    *===========================================================*
      *    * Subroutines per allineamenti a destra o a sinistra oppure *
      *    * al centro di campi alfanumerici di varia lunghezza, fi-   *
      *    * no ad un massimo di 240 caratteri, oppure per il conca-   *
      *    * tenamento, con o senza separazione, di max 10 substrin-   *
      *    * ghe in una unica substringa                               *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wallstr0.cps"                   .

      *    *===========================================================*
      *    * Richiamo sottoprogramma per gestione catena righe         *
      *    *-----------------------------------------------------------*
       cll-sub-cat-000.
           call      "pgm/cge/prg/obj/pcge7752"
                                         using w-cat-rig              .
       cll-sub-cat-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione sottoprogramma per gestione catena righe    *
      *    *-----------------------------------------------------------*
       cnc-sub-cat-000.
           cancel    "pgm/cge/prg/obj/pcge7752"                       .
       cnc-sub-cat-999.
           exit.

