                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *              *-------------------------------------------------*
      *              * Lettura record record file [cli]                *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      rf-mgr-cod-arc       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                  *---------------------------------------------*
      *                  * Se trovato : uscita                         *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to  let-arc-cli-999.
       let-arc-cli-100.
      *                  *---------------------------------------------*
      *                  * Se non trovato                              *
      *                  *---------------------------------------------*
           perform   int-msg-err-000      thru int-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Editing codice cliente                  *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-cli-cod-cli       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      spaces               to   m-msg                  .
           string    "Cliente "        
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     " non esistente in archivio"
                                delimited by   size
                                          into m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Puntini in ragione sociale              *
      *                      *-----------------------------------------*
           move      all "."              to   rf-cli-rag-soc         .
       let-arc-cli-999.
           exit.

