      *              *-------------------------------------------------*
           move      spaces               to   w-det-snx-sbl-flg      .
           move      zero                 to   w-det-snx-sbl-dar      .
           move      zero                 to   w-det-snx-sbl-ave      .
       det-snx-sbl-100.
      *              *-------------------------------------------------*
      *              * Start su file [mgr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATREG    "         to   f-key                  .
           move      w-det-snx-sbl-dat    to   rf-mgr-dat-reg         .
           move      w-det-snx-sbl-prt    to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : fine determinazione       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snx-sbl-800.
       det-snx-sbl-200.
      *              *-------------------------------------------------*
      *              * Read next da file [mgr]                         *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se at end : fine determinazione             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snx-sbl-800.
       det-snx-sbl-300.
      *              *-------------------------------------------------*
      *              * Test max su file [mgr]                          *
      *              *-------------------------------------------------*
           if        rf-mgr-dat-reg       not  = w-det-snx-sbl-dat or
                     rf-mgr-num-prt       not  = w-det-snx-sbl-prt
                     go to det-snx-sbl-800.
