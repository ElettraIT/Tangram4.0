      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo stampa          *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    "I"
                     go to stp-srt-inp-120.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Se tipo stampa per data registrazione           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per chiave 'DATREG'                   *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATREG"             to   f-key                  .
           move      rr-dat-ini           to   rf-mgt-dat-reg         .
           move      zero                 to   rf-mgt-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                      *-----------------------------------------*
      *                      * Se start errata                         *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Se tipo stampa per data immissione              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per chiave 'DATSYS'                   *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATSYS"             to   f-key                  .
           move      rr-dat-ini           to   rf-mgt-ide-dat         .
           move      zero                 to   rf-mgt-dat-reg         .
           move      zero                 to   rf-mgt-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                      *-----------------------------------------*
      *                      * Se start errata                         *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale [mgt]                       *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test se oltre il massimo                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo stampa                         *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "I"
                     go to stp-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se stampa per data registrazione            *
      *                  *---------------------------------------------*
           if        rf-mgt-dat-reg       >    rr-dat-fin
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se stampa per data immissione               *
      *                  *---------------------------------------------*
           if        rf-mgt-ide-dat       >    rr-dat-fin
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo stampa                         *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "I"
                     go to stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Se stampa per data registrazione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Selezione su codice causale             *
      *                      *-----------------------------------------*
           if        rr-cod-cau           =    zero
                     go to  stp-srt-inp-500.
           if        rr-cod-cau           not  = rf-mgt-cod-cau
                     go to  stp-srt-inp-200.
       stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Se stampa per data immissione               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Selezione su codice utente              *
      *                      *-----------------------------------------*
           if        rr-cod-ute           =    spaces
                     go to  stp-srt-inp-470.
           if        rr-cod-ute           not  = rf-mgt-ide-ute
                     go to  stp-srt-inp-200.
       stp-srt-inp-470.
      *                      *-----------------------------------------*
      *                      * Selezione su codice fase                *
      *                      *-----------------------------------------*
           if        rr-cod-fas           =    spaces
                     go to  stp-srt-inp-500.
           if        rr-cod-fas           not  = rf-mgt-ide-fas
                     go to  stp-srt-inp-200.
       stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Eventuali selezioni su Movimenti Iva        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su richieste                       *
      *                      *-----------------------------------------*
           if        rr-tip-rfp           =    spaces
                     go to stp-srt-inp-550.
      *                      *-----------------------------------------*
      *                      * Test su tipo Iva                        *
      *                      *-----------------------------------------*
           if        rf-mgt-tip-iva       =    "0" or
                     rf-mgt-tip-iva       =    spaces
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Normalizzazione [mgi]                   *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                      *-----------------------------------------*
      *                      * Lettura [mgi]                           *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DATPRT"             to   f-key                  .
           move      rf-mgt-dat-reg       to   rf-mgi-dat-reg         .
           move      rf-mgt-num-prt       to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                          *-------------------------------------*
      *                          * Se non trovato : a riciclo          *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione delle richieste  *
      *                      *-----------------------------------------*
           if        rr-tip-rfp           =    "N"
                     go to stp-srt-inp-510
           else if   rr-tip-rfp           =    "S"
                     go to stp-srt-inp-520
           else if   rr-tip-rfp           =    "R"
                     go to stp-srt-inp-530
           else if   rr-tip-rfp           =    "E"
                     go to stp-srt-inp-540
           else      go to stp-srt-inp-550.
       stp-srt-inp-510.
      *                      *-----------------------------------------*
      *                      * Se regime fiscale normale               *
      *                      *-----------------------------------------*
           if        rf-mgi-flg-rfp       =    spaces or
                     rf-mgi-flg-rfp       =    "N"
                     go to stp-srt-inp-550
           else      go to stp-srt-inp-200.
       stp-srt-inp-520.
      *                      *-----------------------------------------*
      *                      * Se Split Payment                        *
      *                      *-----------------------------------------*
           if        rf-mgi-flg-rfp       =    "S"
                     go to stp-srt-inp-550
           else      go to stp-srt-inp-200.
       stp-srt-inp-530.
      *                      *-----------------------------------------*
      *                      * Se Reverse Charge                       *
      *                      *-----------------------------------------*
           if        rf-mgi-flg-rfp       =    "R"
                     go to stp-srt-inp-550
           else      go to stp-srt-inp-200.
       stp-srt-inp-540.
      *                      *-----------------------------------------*
      *                      * Se Esclusi                              *
      *                      *-----------------------------------------*
           if        rf-mgi-flg-rfp       =    "E"
                     go to stp-srt-inp-550
           else      go to stp-srt-inp-200.
       stp-srt-inp-550.
      *              *-------------------------------------------------*
      *              * Subroutine di prescansione righe per eventuale  *
      *              * selezione                                       *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-sel-000  thru stp-srt-inp-sel-999    .
           if        w-wrk-flg-sel        =    spaces
                     go to stp-srt-inp-600
           else      go to stp-srt-inp-200.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Subroutine per caricamento righe                *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-mgr-000  thru stp-srt-inp-mgr-999    .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo a [mgt] successivo                      *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di prescansione per selezioni sulle righe      *
      *    *-----------------------------------------------------------*
       stp-srt-inp-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-wrk-flg-sel          .
       stp-srt-inp-sel-050.
      *              *-------------------------------------------------*
      *              * Test se prescansione necessaria                 *
      *              *-------------------------------------------------*
           if        rr-tip-arc           =    spaces or
                     rr-cod-arc           =    zero
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-100.
      *              *-------------------------------------------------*
      *              * Attivazione flag di uscita                      *
      *              *-------------------------------------------------*
           move      "#"                  to   w-wrk-flg-sel          .
      *              *-------------------------------------------------*
      *              * Start su [mgr]                                  *
      *              *-------------------------------------------------*
