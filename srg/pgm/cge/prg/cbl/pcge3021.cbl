                     go to int-pag-sta-500.
      *                          *-------------------------------------*
      *                          * Literal '[utente]'                  *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      87                   to   p-pos                  .
           move      "[utente]"           to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Literal '[progr.]'                  *
