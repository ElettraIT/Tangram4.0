           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      rf-pdc-cod-pdc       to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-adx-000      thru edt-pdc-adx-999        .
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      spaces               to   m-msg                  .
           string    "Sottoconto "        
                                delimited by   size
                     w-edt-cod-pdc-edt
                                delimited by   spaces
                     " non esistente in archivio"
                                delimited by   size
                                          into m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Puntini in descrizione sottoconto       *
      *                      *-----------------------------------------*
           move      all "."              to   rf-pdc-des-pdc         .
       let-arc-pdc-999.
