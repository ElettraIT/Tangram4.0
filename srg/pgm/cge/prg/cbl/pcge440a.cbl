      *              *-------------------------------------------------*
      *              * Normalizzazione area rottura partita            *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-cat-par-rdr      .
           move      spaces               to   w-car-cat-par-rnr      .
           move      zero                 to   w-car-cat-par-nle      .
      *              *-------------------------------------------------*
      *              * Inizializzazione saldo partita                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-cat-par-sdp      .
      *              *-------------------------------------------------*
      *              * Inizializzazione saldo cliente                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-sdo-cli (1)      .
      *              *-------------------------------------------------*
      *              * Start su file [mgr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      "C"                  to   rf-mgr-tip-arc         .
           move      w-tes-cod-cli        to   rf-mgr-cod-arc         .
           move      zero                 to   rf-mgr-dat-rif         .
           move      spaces               to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-cat-par-300.
       car-cat-par-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [mgr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-cat-par-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-mgr-tip-arc       not  = "C"           or
                     rf-mgr-cod-arc       not  = w-tes-cod-cli
                     go to car-cat-par-300.
       car-cat-par-150.
      *              *-------------------------------------------------*
      *              * Se rottura della partita                        *
      *              *-------------------------------------------------*
