      *                  *---------------------------------------------*
           add       1                    to   w-car-cat-par-nle      .
      *                  *---------------------------------------------*
      *                  * Se prima linea letta : inizio partita       *
      *                  *---------------------------------------------*
           if        w-car-cat-par-nle    =    1
                     go to car-cat-par-180.
      *                  *---------------------------------------------*
      *                  * Confronto con elementi di rottura           *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-rif       =    w-car-cat-par-rdr and
                     rf-mgr-num-rif       =    w-car-cat-par-rnr
                     go to car-cat-par-200.
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per fine partita      *
      *                  *---------------------------------------------*
           perform   car-cat-par-900      thru car-cat-par-909        .
      *                  *---------------------------------------------*
      *                  * Se Append in catena non possibile : uscita  *
      *                  *---------------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to car-cat-par-800.
       car-cat-par-180.
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per inizio partita    *
      *                  *---------------------------------------------*
           perform   car-cat-par-910      thru car-cat-par-919        .
       car-cat-par-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo partita                     *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-car-cat-par-sdp
           else      add      rf-mgr-imp-mov
                                          to   w-car-cat-par-sdp      .
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo cliente                     *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-tes-sdo-cli (1)
           else      add      rf-mgr-imp-mov
                                          to   w-tes-sdo-cli (1)      .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [mgr]     *
      *              *-------------------------------------------------*
           go to     car-cat-par-100.
       car-cat-par-300.
      *              *-------------------------------------------------*
      *              * Esecuzione subroutine per fine partita          *
