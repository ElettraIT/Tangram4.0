           move      "#"                  to   w-car-cat-par-flg      .
       car-cat-par-850.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-par-999.
       car-cat-par-900.
      *              *=================================================*
      *              * Subroutine interna per fine partita             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se linea 1 in trattamento : uscita          *
      *                  *---------------------------------------------*
           if        w-car-cat-par-nle    =    1
                     go to car-cat-par-909.
      *                  *---------------------------------------------*
      *                  * Se tipo selezione richiesta, solo partite   *
      *                  * aperte, e saldo partita a zero : uscita     *
      *                  *---------------------------------------------*
           if        w-tes-tip-sel        =    01 and
                     w-car-cat-par-sdp    =    zero
                     go to car-cat-par-909.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione elemento in catena          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Append non possibile : uscita        *
      *                      *-----------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to car-cat-par-909.
      *                      *-----------------------------------------*
      *                      * Append                                  *
      *                      *-----------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Composizione riga                       *
      *                      *-----------------------------------------*
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
           move      w-car-cat-par-rnr    to   w-rig-num-par (1)      .
           move      w-car-cat-par-rdr    to   w-rig-dat-par (1)      .
           move      w-car-cat-par-sdp    to   w-rig-sdo-par (1)      .
           move      spaces               to   w-rig-sel-par (1)      .
           move      spaces               to   w-rig-npr-dst (1)      .
           move      zero                 to   w-rig-dpr-dst (1)      .
      *                      *-----------------------------------------*
      *                      * Update catena                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-cat-par-909.
           exit.
       car-cat-par-910.
      *              *=================================================*
      *              * Subroutine interna per inizio partita           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento area rottura partita          *
      *                  *---------------------------------------------*
           move      rf-mgr-dat-rif       to   w-car-cat-par-rdr      .
           move      rf-mgr-num-rif       to   w-car-cat-par-rnr      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione saldo partita              *
      *                  *---------------------------------------------*
           move      zero                 to   w-car-cat-par-sdp      .
       car-cat-par-919.
           exit.
       car-cat-par-999.
           exit.

