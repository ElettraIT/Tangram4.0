           if        w-cat-rig-exs        not  = spaces
                     go to  vis-cor-reg-900.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Riga singolo movimento                          *
      *              *-------------------------------------------------*
           move      "R"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-wrk-ctr-008    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *              *-------------------------------------------------*
      *              * Incremento numero riga da visualizzare          *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-wrk-ctr-008      .
      *              *-------------------------------------------------*
      *              * Test se oltre ultima riga da visualizzare       *
      *              *-------------------------------------------------*
           if        w-cnt-wrk-ctr-008    not  > w-cnt-wrk-ctr-009
                     go to vis-cor-reg-200.
       vis-cor-reg-900.
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione linea corpo numero : w-cnt-cor-nrg-dav    *
      *    *-----------------------------------------------------------*
       vis-lin-cor-000.
      *              *-------------------------------------------------*
      *              * Abblencamento immagine linea di corpo           *
      *              *-------------------------------------------------*
           move      spaces               to   w-lin-imm              .
      *              *-------------------------------------------------*
      *              * Forzatura barre verticali                       *
      *              *-------------------------------------------------*
           move      "|"                  to   w-lin-imm-brv-001
                                               w-lin-imm-brv-002
                                               w-lin-imm-brv-003
                                               w-lin-imm-brv-004
                                               w-lin-imm-brv-005      .
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dav    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Test su tipo visualizzazione riga               *
      *              *-------------------------------------------------*
           if        w-cnt-cor-tvi-rig    =    "I"
                     go to vis-lin-cor-100
           else if   w-cnt-cor-tvi-rig    =    "S"
                     go to vis-lin-cor-200
           else if   w-cnt-cor-tvi-rig    =    "N"
                     go to vis-lin-cor-300
           else      go to vis-lin-cor-400.
       vis-lin-cor-100.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione indicatore linea         *
      *                  *---------------------------------------------*
           move      "====>"              to   w-lin-imm-num-lin      .
           move      05                   to   v-car                  .
           go to     vis-lin-cor-900.
       vis-lin-cor-200.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione numero linea a spaces    *
      *                  *---------------------------------------------*
           move      spaces               to   w-lin-imm-num-lin      .
           move      05                   to   v-car                  .
           go to     vis-lin-cor-900.
       vis-lin-cor-300.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione numero d'ordine riga     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-num-lin      .
           move      05                   to   v-car                  .
           go to     vis-lin-cor-900.
       vis-lin-cor-400.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione riga intera              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga in append : uscita              *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     go to  vis-lin-cor-999.
      *                      *-----------------------------------------*
      *                      * Editing Numero d'ordine riga            *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-num-lin      .
      *                      *-----------------------------------------*
      *                      * Se riga di tipo New : fine editing      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Editing numero partita                  *
      *                      *-----------------------------------------*
           move      w-rig-num-par (1)    to   w-all-str-alf          .
           move      10                   to   w-all-str-lun          .
           perform   all-str-adx-000      thru all-str-adx-999        .
           move      w-all-str-alf        to   w-lin-imm-num-par      .
      *                      *-----------------------------------------*
      *                      * Editing data partita                    *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-dat-par (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-dat-par      .
      *                      *-----------------------------------------*
      *                      * Editing saldo partita                   *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-rig-sdo-par (1)    >    9999999999 or
                     w-rig-sdo-par (1)    <   -9999999999
                     move  13             to   v-car
           else      move  11             to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           if        w-rig-sdo-par (1)    >    9999999999 or
                     w-rig-sdo-par (1)    <   -9999999999
                     move  spaces         to   v-edm
           else      move  "G"            to   v-edm                  .
           move      w-rig-sdo-par (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-sdo-par      .
      *                      *-----------------------------------------*
      *                      * Editing selezione partita               *
      *                      *-----------------------------------------*
           move      w-rig-sel-par (1)    to   w-lin-imm-sel-par      .
       vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Parametri per visualizzazione           *
      *                      *-----------------------------------------*
           move      80                   to   v-car                  .
       vis-lin-cor-900.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione prima linea          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se una sola linea : uscita                      *
      *              *-------------------------------------------------*
           if        w-lin-num-lin-prc    =    1
                     go to vis-lin-cor-999.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione altre linee          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-wrk-ctr-003      .
       vis-lin-cor-925.
           add       1                    to   w-cnt-wrk-ctr-003      .
           if        w-cnt-wrk-ctr-003    >    w-lin-num-lin-prc
                     go to vis-lin-cor-999.
           add       1                    to   w-cnt-wrk-ctr-002      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin
                    (w-cnt-wrk-ctr-003)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-lin-cor-925.
       vis-lin-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate sia dall'area per la fin- *
      *              * catura che dall'area delle righe effettive      *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-050.
      *              *-------------------------------------------------*
      *              * Cliente                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione stringa                        *
      *                  *---------------------------------------------*
           move      spaces               to   w-pmt-cor-reg-x80      .
           move      1                    to   w-pmt-cor-reg-pnt      .
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           string    "Cliente : "
                                delimited by   size
                                          into w-pmt-cor-reg-x80
                                  with pointer w-pmt-cor-reg-pnt      .
      *                  *---------------------------------------------*
      *                  * Codice                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-cod-cli        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    v-edt
                                delimited by   spaces
                                          into w-pmt-cor-reg-x80
                                  with pointer w-pmt-cor-reg-pnt      .
      *                  *---------------------------------------------*
      *                  * Ragione sociale                             *
      *                  *---------------------------------------------*
           string    "  "
                                delimited by   size
                     w-tes-cod-cli-rag
                                delimited by   size
                                          into w-pmt-cor-reg-x80
                                  with pointer w-pmt-cor-reg-pnt      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-pmt-cor-reg-x80    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Saldo cliente                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione stringa                        *
      *                  *---------------------------------------------*
           move      spaces               to   w-pmt-cor-reg-x80      .
           move      1                    to   w-pmt-cor-reg-pnt      .
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-tes-sdo-cli (1)    >    9999999999 or
                     w-tes-sdo-cli (1)    <   -9999999999
                     move  13             to   v-car
           else      move  11             to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           if        w-tes-sdo-cli (1)    >    9999999999 or
                     w-tes-sdo-cli (1)    <   -9999999999
                     move  "<"            to   v-edm
           else      move  "G<"           to   v-edm                  .
           move      w-tes-sdo-cli (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    "["
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     "]"
                                delimited by   size
                                          into w-pmt-cor-reg-x80
                                  with pointer w-pmt-cor-reg-pnt      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-pmt-cor-reg-pnt    to   v-car                  .
           move      04                   to   v-lin                  .
           move      80                   to   v-pos                  .
           subtract  w-pmt-cor-reg-pnt    from v-pos                  .
           add       2                    to   v-pos                  .
           move      w-pmt-cor-reg-x80    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Trattini a linea 05                             *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "                | N.R. |Riferimento Partita| Saldo
      -              " Partita | S |                "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "                |------|-------------------|------
      -              "---------|---|                "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Sele-   *
      *    * zione partita                                             *
      *    *-----------------------------------------------------------*
       acc-sel-par-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-sel-par (1)    to   w-sav-sel-par          .
       acc-sel-par-100.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "Tasto di selezione o 'S' per selezionare elemento 
      -              "da pareggiare"      to   v-nt1                  .
           move      "[F1] per operazione di pareggiamento su elemento b
      -              "ase"
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-sel-par        to   w-rig-sel-par (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      62                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : non ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso, a meno che non   *
      *                      *        ci sia una sola riga             *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        >    1
                     move  "REMV"         to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "SLCT"               to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Expd : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "EXPD"               to   v-pfk (12)             .
      *                      *-----------------------------------------*
      *                      * Pf1  : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "[1] "               to   v-pfk (14)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-sel-par (1)    to   v-alf                  .
       acc-sel-par-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sel-par-220.
      *              *-------------------------------------------------*
      *              * Cancellazione note operative attuali            *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Return o Pf1                                 *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-sel-par-400.
       acc-sel-par-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-sel-par-300
           else      go to acc-sel-par-350.
       acc-sel-par-300.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che sia stato variato  *
      *                  * il campo di impostazione                    *
      *                  *---------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-sel-par-310
           else      go to acc-sel-par-320.
       acc-sel-par-310.
      *                  *---------------------------------------------*
      *                  * Se e' stato variato il campo di impostazio- *
      *                  * ne : trattamento tasto SLCT per posiziona-  *
      *                  * mento su riga                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Conversione numero riga impostato in    *
      *                      * formato numerico                        *
      *                      *-----------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-sel-par-312.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-sel-par-314.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-sel-par-312.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-sel-par-312.
       acc-sel-par-314.
      *                      *-----------------------------------------*
      *                      * Se numero riga impostato minore di 1 o  *
      *                      * maggiore del massimo : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-sel-par-100.
      *                      *-----------------------------------------*
      *                      * Se numero riga impostato pari a numero  *
      *                      * riga attuale : reimpostazione           *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-sel-par-100.
      *                      *-----------------------------------------*
      *                      * Preparazione parametri e uscita         *
      *                      *-----------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione selezione partita       *
      *                      *-----------------------------------------*
           perform   vis-sel-par-000      thru vis-sel-par-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-sel-par-999.
       acc-sel-par-320.
      *                  *---------------------------------------------*
      *                  * Se non e' stato variato il campo di impo-   *
      *                  * stazione : trattamento tasto SLCT per in-   *
      *                  * versione del campo                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se partita gia' selezionata             *
      *                      *-----------------------------------------*
           if        w-rig-sel-par (1)    =    spaces
                     go to acc-sel-par-335.
      *                          *-------------------------------------*
      *                          * Normalizzazione selezione partita   *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-sel-par (1)      .
      *                          *-------------------------------------*
      *                          * Controggiornamento numero partite   *
      *                          * selezionate                         *
      *                          *-------------------------------------*
           subtract  1                    from w-tes-num-pse (1)      .
      *                          *-------------------------------------*
      *                          * Controggiornamento saldo partite    *
      *                          * selezionate                         *
      *                          *-------------------------------------*
           subtract  w-rig-sdo-par (1)    from w-tes-sdo-pse (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sel-par-338.
       acc-sel-par-335.
      *                      *-----------------------------------------*
      *                      * Se partita non selezionata              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Attivazione selezione partita       *
      *                          *-------------------------------------*
           move      "S"                  to   w-rig-sel-par (1)      .
      *                          *-------------------------------------*
      *                          * Aggiornamento numero partite sele-  *
      *                          * zionate                             *
      *                          *-------------------------------------*
           add       1                    to   w-tes-num-pse (1)      .
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo partite sele-   *
      *                          * zionate                             *
      *                          *-------------------------------------*
           add       w-rig-sdo-par (1)    to   w-tes-sdo-pse (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sel-par-338.
       acc-sel-par-338.
      *                      *-----------------------------------------*
      *                      * Visualizzazione selezione partita       *
      *                      *-----------------------------------------*
           perform   vis-sel-par-000      thru vis-sel-par-999        .
      *                      *-----------------------------------------*
      *                      * Uscita come per Return                  *
      *                      *-----------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
           go to     acc-sel-par-999.
       acc-sel-par-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-sel-par-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sel-par-999
                     else    go to acc-sel-par-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Expd o Find                                  *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD" and
                     v-key                not  = "FIND"
                     go to acc-sel-par-360.
      *                  *---------------------------------------------*
      *                  * Espansione su partita cliente               *
      *                  *---------------------------------------------*
           perform   esp-par-cli-000      thru esp-par-cli-999        .
      *                  *---------------------------------------------*
      *                  * Reimpostazione                              *
      *                  *---------------------------------------------*
           go to     acc-sel-par-100.
       acc-sel-par-360.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-sel-par-380.
      *                  *---------------------------------------------*
      *                  * Richiamo routine di pareggiamento partite   *
      *                  * selezionate                                 *
      *                  *---------------------------------------------*
           perform   prg-par-sel-000      thru prg-par-sel-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        w-prg-par-sel-flg    =    spaces
                     go to acc-sel-par-362
           else      go to acc-sel-par-364.
       acc-sel-par-362.
      *                  *---------------------------------------------*
      *                  * Se esito operazione : Positivo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente visualizzato  *
      *                      * a zero                                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-cnt-cor-nrp-vis      .
      *                      *-----------------------------------------*
      *                      * Attivazione flag di non-incremento nu-  *
      *                      * mero riga da accettare                  *
      *                      *-----------------------------------------*
           move      "#"                  to   w-acc-cor-reg-fni      .
      *                      *-----------------------------------------*
      *                      * Assestamento numero riga da accettare   *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    >    w-cat-rig-max
                     move  w-cat-rig-max  to   w-cnt-cor-nrg-dac      .
      *                      *-----------------------------------------*
      *                      * Simulazione uscita come per Down        *
      *                      *-----------------------------------------*
           move      "D"                  to   w-cnt-tus-acc-rig      .
           go to     acc-sel-par-999.
       acc-sel-par-364.
      *                  *---------------------------------------------*
      *                  * Se esito operazione : Negativo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sel-par-100.
       acc-sel-par-380.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-sel-par-999.
       acc-sel-par-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-sel-par (1)      .
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-sel-par (1)    not  = spaces and
                     w-rig-sel-par (1)    not  = "S"
                     go to acc-sel-par-100.
       acc-sel-par-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sel-par (1)    =    w-sav-sel-par
                     go to acc-sel-par-800.
      *                  *---------------------------------------------*
      *                  * Trattamento numero e saldo partite selezio- *
      *                  * nate                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore im-   *
      *                      * postato                                 *
      *                      *-----------------------------------------*
           if        w-rig-sel-par (1)    =    spaces
                     go to acc-sel-par-610
           else if   w-rig-sel-par (1)    =    "S"
                     go to acc-sel-par-620.
       acc-sel-par-610.
      *                      *-----------------------------------------*
      *                      * Se a spaces                             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controggiornamento numero partite   *
      *                          * selezionate                         *
      *                          *-------------------------------------*
           subtract  1                    from w-tes-num-pse (1)      .
      *                          *-------------------------------------*
      *                          * Controggiornamento saldo partite    *
      *                          * selezionate                         *
      *                          *-------------------------------------*
           subtract  w-rig-sdo-par (1)    from w-tes-sdo-pse (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sel-par-800.
       acc-sel-par-620.
      *                      *-----------------------------------------*
      *                      * Se 'S'                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento numero partite sele-  *
      *                          * zionate                             *
      *                          *-------------------------------------*
           add       1                    to   w-tes-num-pse (1)      .
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo partite sele-   *
      *                          * zionate                             *
      *                          *-------------------------------------*
           add       w-rig-sdo-par (1)    to   w-tes-sdo-pse (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sel-par-800.
       acc-sel-par-800.
       acc-sel-par-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Selezione partita                 *
      *    *-----------------------------------------------------------*
       vis-sel-par-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      62                   to   v-pos                  .
           move      w-rig-sel-par (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sel-par-999.
           exit.

      *    *===========================================================*
      *    * Routine di pareggiamento partite selezionate              *
      *    *-----------------------------------------------------------*
       prg-par-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-prg-par-sel-flg      .
      *              *-------------------------------------------------*
      *              * Test se operazione effettuabile                 *
      *              *-------------------------------------------------*
           if        w-tes-num-pse (1)    not  = zero
                     go to prg-par-sel-020.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Non e' stata selezionata alcuna partita !         
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           go to     prg-par-sel-900.
       prg-par-sel-020.
      *              *-------------------------------------------------*
      *              * Test se sono state selezionate almeno due par-  *
      *              * tite                                            *
      *              *-------------------------------------------------*
           if        w-tes-num-pse (1)    >    1
                     go to prg-par-sel-100.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Devono essere selezionate almeno due partite !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           go to     prg-par-sel-900.
       prg-par-sel-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento records catena con data e numero  *
      *              * partita di destinazione                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se operazione richiesta da una parti-  *
      *                  * ta selezionata                              *
      *                  *---------------------------------------------*
           if        w-rig-sel-par (1)    not  = spaces
                     go to prg-par-sel-510.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "L'operazione e' eseguibile solo da una delle parti
      -              "te selezionate "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita con errore                       *
      *                      *-----------------------------------------*
           go to     prg-par-sel-900.
       prg-par-sel-510.
      *                  *---------------------------------------------*
      *                  * Salvataggio data e numero partita           *
      *                  *---------------------------------------------*
           move      w-rig-dat-par (1)    to   w-sav-dat-par          .
           move      w-rig-num-par (1)    to   w-sav-num-par          .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione catena movimenti         *
      *                  *---------------------------------------------*
           move      zero                 to   w-prg-par-sel-ctr      .
       prg-par-sel-520.
           add       1                    to   w-prg-par-sel-ctr      .
           if        w-prg-par-sel-ctr    >    w-cat-rig-max
                     go to prg-par-sel-800.
      *                  *---------------------------------------------*
      *                  * Lettura record da catena                    *
      *                  *---------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-prg-par-sel-ctr    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       prg-par-sel-530.
      *                  *---------------------------------------------*
      *                  * Se lettura errata : riciclo                 *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to prg-par-sel-520.
      *                  *---------------------------------------------*
      *                  * Se buffer catena a spaces : riciclo         *
      *                  *---------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to prg-par-sel-520.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena a w-rig          *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Selezioni sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se partita selezionata             *
      *                      *-----------------------------------------*
           if        w-rig-sel-par (1)    =    spaces
                     go to prg-par-sel-520.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che la partita     *
      *                      * letta sia pari a quella salvata o no    *
      *                      *-----------------------------------------*
           if        w-rig-dat-par (1)    =    w-sav-dat-par and
                     w-rig-num-par (1)    =    w-sav-num-par
                     go to prg-par-sel-540
           else      go to prg-par-sel-560.
       prg-par-sel-540.
      *                      *-----------------------------------------*
      *                      * Se partita letta pari a quella salvata  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo partita per il  *
      *                          * totale partite selezionate          *
      *                          *-------------------------------------*
           move      w-tes-sdo-pse (1)    to   w-rig-sdo-par (1)      .
      *                          *-------------------------------------*
      *                          * Normalizzazione segnale di partita  *
      *                          * selezionata                         *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-sel-par (1)      .
      *                          *-------------------------------------*
      *                          * Aggiornamento record catena         *
      *                          *-------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                          *-------------------------------------*
      *                          * Riciclo                             *
      *                          *-------------------------------------*
           go to     prg-par-sel-520.
       prg-par-sel-560.
      *                      *-----------------------------------------*
      *                      * Se partita letta diversa da quella      *
      *                      * salvata                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento dati partita di de-   *
      *                          * stinazione                          *
      *                          *-------------------------------------*
           move      w-sav-dat-par        to   w-rig-dpr-dst (1)      .
           move      w-sav-num-par        to   w-rig-npr-dst (1)      .
      *                          *-------------------------------------*
      *                          * Aggiornamento record catena         *
      *                          *-------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                          *-------------------------------------*
      *                          * Poiche' con l'operazione di Remove  *
      *                          * di un record dalla catena, ci si    *
      *                          * posiziona sul record successivo, si *
      *                          * ricicla al punto di lettura avvenu- *
      *                          * ta                                  *
      *                          *-------------------------------------*
           go to     prg-par-sel-530.
       prg-par-sel-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * per operazione di pareggiamento partite     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-num-pse (1)      .
           move      zero                 to   w-tes-sdo-pse (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita con successo                         *
      *                  *---------------------------------------------*
           go to     prg-par-sel-999.
       prg-par-sel-900.
      *                  *---------------------------------------------*
      *                  * Uscita senza successo                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-prg-par-sel-flg      .
       prg-par-sel-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo selezione partite          *
      *              *-------------------------------------------------*
           if        w-tes-tip-sel        =    zero
                     move  01             to   w-tes-tip-sel
                     perform vis-tip-sel-000
                                          thru vis-tip-sel-999        .
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
      *              *-------------------------------------------------*
      *              * Test su codice cliente                          *
      *              *-------------------------------------------------*
           if        w-tes-cod-cli        =    zero
                     move  "#"            to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo su impostazione tasto Do riga corpo             *
      *    *-----------------------------------------------------------*
       cnt-tdo-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo                  *
      *    *-----------------------------------------------------------*
       pre-rig-cor-000.
       pre-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Attribuzione del numero progressivo per la riga New       *
      *    *-----------------------------------------------------------*
       prg-rig-cor-000.
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
       prg-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo                       *
      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
       pos-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave e non chiave                  *
      *    *-----------------------------------------------------------*
       nor-key-nok-000.
      *              *-------------------------------------------------*
