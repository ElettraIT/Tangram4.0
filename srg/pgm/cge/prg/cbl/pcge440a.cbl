      *                      *-----------------------------------------*
           move      zero                 to   w-brc-num-ele          .
      *                      *-----------------------------------------*
      *                      * Start su file [mgr]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      "C"                  to   rf-mgr-tip-arc         .
           move      w-tes-cod-cli        to   rf-mgr-cod-arc         .
           move      w-bpd-dat-par
                    (w-bpd-ctr-001)       to   rf-mgr-dat-rif         .
           move      w-bpd-num-par
                    (w-bpd-ctr-001)       to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to scr-mov-fil-250.
       scr-mov-fil-230.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale record [mgr]        *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                          *-------------------------------------*
      *                          * Test se 'At End'                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to scr-mov-fil-250.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       not  = "C"            or
                     rf-mgr-cod-arc       not  = w-tes-cod-cli  or
                     rf-mgr-dat-rif       not  = w-bpd-dat-par
                                                (w-bpd-ctr-001) or
                     rf-mgr-num-rif       not  = w-bpd-num-par
                                                (w-bpd-ctr-001)
                     go to scr-mov-fil-250.
      *                      *-----------------------------------------*
      *                      * Incremento numero elementi              *
      *                      *-----------------------------------------*
           if        w-brc-num-ele        <    w-brc-max-ele
                     add   1              to   w-brc-num-ele          .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione elemento                *
      *                      *-----------------------------------------*
           move      rf-mgr-dat-reg       to   w-brc-dat-reg
                                              (w-brc-num-ele)         .
           move      rf-mgr-num-prt       to   w-brc-num-prt
                                              (w-brc-num-ele)         .
           move      rf-mgr-num-prg       to   w-brc-num-prg
                                              (w-brc-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura sequenziale record   *
      *                      * [mgr]                                   *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-230.
       scr-mov-fil-250.
      *                  *---------------------------------------------*
      *                  * Aggiornamento records [mgr] da scansione    *
      *                  * buffer                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-brc-ctr-001          .
       scr-mov-fil-260.
           add       1                    to   w-brc-ctr-001          .
           if        w-brc-ctr-001        >    w-brc-num-ele
                     go to scr-mov-fil-280.
      *                      *-----------------------------------------*
      *                      * Ottenimento record [mgr]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "DATREG"             to   f-key                  .
           move      w-brc-dat-reg
                    (w-brc-ctr-001)       to   rf-mgr-dat-reg         .
           move      w-brc-num-prt
                    (w-brc-ctr-001)       to   rf-mgr-num-prt         .
           move      w-brc-num-prg
                    (w-brc-ctr-001)       to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : riciclo       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to scr-mov-fil-260.
      *                      *-----------------------------------------*
      *                      * Aggiornamento dati partita              *
      *                      *-----------------------------------------*
           move      w-bpd-dpr-dst
                    (w-bpd-ctr-001)       to   rf-mgr-dat-rif         .
           move      w-bpd-npr-dst
                    (w-bpd-ctr-001)       to   rf-mgr-num-rif         .
      *                      *-----------------------------------------*
      *                      * Update record [mgr]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Rilascio record [mgr]                   *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer righe movi- *
      *                      * menti contabili                         *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-260.
       scr-mov-fil-280.
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione buffer                 *
      *                  *---------------------------------------------*
           go to     scr-mov-fil-220.
       scr-mov-fil-900.
      *              *-------------------------------------------------*
      *              * A uscita                                        *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-999.
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Espansione su partita cliente                             *
      *    *-----------------------------------------------------------*
       esp-par-cli-000.
      *              *-------------------------------------------------*
      *              * Se programma di espansione gia' attivo : uscita *
      *              * senza alcuna azione                             *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pcge4430"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to esp-par-cli-999.
       esp-par-cli-100.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'select codcli'   *
      *              * per il livello successivo per il codice cliente *
      *              * su cui eseguire l'espansione                    *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "select codcli"      to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      07                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-tes-cod-cli        to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-par-cli-150.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'select datrif'   *
      *              * per il livello successivo per la data partita   *
      *              * su cui eseguire l'espansione                    *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "select datrif"      to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "D"                  to   s-tip                  .
           move      w-rig-dat-par (1)    to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-par-cli-200.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'select numrif'   *
      *              * per il livello successivo per il numero partita *
      *              * su cui eseguire l'espansione                    *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "select numrif"      to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      10                   to   s-car                  .
           move      w-rig-num-par (1)    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-par-cli-300.
      *              *-------------------------------------------------*
      *              * Richiamo del programma di interrogazione        *
      *              *-------------------------------------------------*
           move      "pgm/cge/prg/obj/pcge4430"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
       esp-par-cli-400.
      *              *-------------------------------------------------*
      *              * Cancellazione del programma di interrogazione   *
      *              *-------------------------------------------------*
           cancel    s-pat                                            .
       esp-par-cli-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cli]                         *
      *    *-----------------------------------------------------------*
       let-arc-cli-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a zero                           *
      *              *-------------------------------------------------*
           if        w-let-arc-cli-cod    =    zero
                     go to let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      w-let-arc-cli-cod    to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-cli-400.
       let-arc-cli-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-cli-rag-soc       to   w-let-arc-cli-rag      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-cli-999.
       let-arc-cli-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-cli-flg      .
           move      all   "."            to   w-let-arc-cli-rag      .
           go to     let-arc-cli-999.
       let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-rag      .
       let-arc-cli-999.
           exit.

