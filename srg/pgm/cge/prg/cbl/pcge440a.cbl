      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Composizione buffer partite destinate           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero elementi nel buffer *
      *                  *---------------------------------------------*
           move      zero                 to   w-bpd-num-ele          .
       scr-mov-fil-020.
      *                  *---------------------------------------------*
      *                  * Lettura riga "last removed"                 *
      *                  *---------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine : oltre                             *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-100.
      *                  *---------------------------------------------*
      *                  * Se buffer catena movimenti a spaces : rici- *
      *                  * clo                                         *
      *                  *---------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to scr-mov-fil-020.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Se partita di destinazione non esistente :  *
      *                  * riciclo                                     *
      *                  *---------------------------------------------*
           if        w-rig-npr-dst (1)    =    spaces and
                     w-rig-dpr-dst (1)    =    zero
                     go to scr-mov-fil-020.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi               *
      *                  *---------------------------------------------*
           if        w-bpd-num-ele        <    w-bpd-max-ele
                     add   1              to   w-bpd-num-ele          .
      *                  *---------------------------------------------*
      *                  * Memorizzazione nuovo elemento               *
      *                  *---------------------------------------------*
           move      w-rig-num-par (1)    to   w-bpd-num-par
                                              (w-bpd-num-ele)         .
           move      w-rig-dat-par (1)    to   w-bpd-dat-par
                                              (w-bpd-num-ele)         .
           move      w-rig-npr-dst (1)    to   w-bpd-npr-dst
                                              (w-bpd-num-ele)         .
           move      w-rig-dpr-dst (1)    to   w-bpd-dpr-dst
                                              (w-bpd-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura riga "last removed"      *
      *                  *---------------------------------------------*
           go to     scr-mov-fil-020.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Aggiustamento buffer partite destinate          *
      *              *-------------------------------------------------*
           move      zero                 to   w-bpd-ctr-001          .
       scr-mov-fil-120.
           add       1                    to   w-bpd-ctr-001          .
           if        w-bpd-ctr-001        >    w-bpd-num-ele
                     go to scr-mov-fil-200.
       scr-mov-fil-140.
      *                  *---------------------------------------------*
      *                  * Ciclo per determinare se la partita di de-  *
      *                  * stinazione dell'elemento in esame sia pre-  *
      *                  * sente fra gli altri elementi del buffer     *
      *                  *---------------------------------------------*
           move      zero                 to   w-bpd-ctr-002          .
       scr-mov-fil-160.
           add       1                    to   w-bpd-ctr-002          .
           if        w-bpd-ctr-002        >    w-bpd-num-ele
                     go to scr-mov-fil-120.
      *                      *-----------------------------------------*
      *                      * Se stesso elemento di quello in esame : *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-bpd-ctr-002        =    w-bpd-ctr-001
                     go to scr-mov-fil-160.
      *                      *-----------------------------------------*
      *                      * Test su riferimenti partita con partita *
      *                      * di destinazione dell'elemento in esame  *
      *                      *-----------------------------------------*
           if        w-bpd-num-par
                    (w-bpd-ctr-002)       =    w-bpd-npr-dst
                                              (w-bpd-ctr-001) and
                     w-bpd-dat-par
                    (w-bpd-ctr-002)       =    w-bpd-dpr-dst
                                              (w-bpd-ctr-001)
                     go to scr-mov-fil-162
           else      go to scr-mov-fil-164.
       scr-mov-fil-162.
      *                      *-----------------------------------------*
      *                      * Se uguali                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzatura partita di destinazione   *
      *                          * dell'elemento in esame con partita  *
      *                          * di destinazione dell'elemento tro-  *
      *                          * vato                                *
      *                          *-------------------------------------*
           move      w-bpd-npr-dst
                    (w-bpd-ctr-002)       to   w-bpd-npr-dst
                                              (w-bpd-ctr-001)         .
           move      w-bpd-dpr-dst
                    (w-bpd-ctr-002)       to   w-bpd-dpr-dst
                                              (w-bpd-ctr-001)         .
      *                          *-------------------------------------*
      *                          * A riesecuzione del ciclo            *
      *                          *-------------------------------------*
           go to     scr-mov-fil-140.
       scr-mov-fil-164.
      *                      *-----------------------------------------*
      *                      * Se diversi                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo su scansione                *
      *                          *-------------------------------------*
           go to     scr-mov-fil-160.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Ciclo su buffer partite destinate aggiustate    *
      *              * per aggiornamento record [mgr]                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-bpd-ctr-001          .
       scr-mov-fil-220.
           add       1                    to   w-bpd-ctr-001          .
           if        w-bpd-ctr-001        >    w-bpd-num-ele
                     go to scr-mov-fil-900.
      *                  *---------------------------------------------*
      *                  * Composizione buffer righe registrazioni     *
