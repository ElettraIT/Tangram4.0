      *    *===========================================================*
      *    * Routine di stampa asterischi finali                       *
      *    *-----------------------------------------------------------*
       stp-ast-fin-000.
      *              *-------------------------------------------------*
      *              * Riempimento resto del foglio con asterischi     *
      *              *-------------------------------------------------*
           if        p-res                not  > 1
                     go to  stp-ast-fin-999.
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza stringhe di asterischi    *
      *                  * normale (per tutte le linee tranne l'ultima)*
      *                  *---------------------------------------------*
           divide    p-res                into p-sel-als-sel
                                        giving w-ast-lun-nor          .
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza ultima stringa di aste-   *
      *                  * rischi                                      *
      *                  *---------------------------------------------*
           multiply  w-ast-lun-nor        by   p-res
                                        giving w-ast-num-003
           subtract  w-ast-num-003        from p-sel-als-sel
                                        giving w-ast-lun-ult          .
      *                  *---------------------------------------------*
      *                  * Posizione di stampa iniziale                *
      *                  *---------------------------------------------*
           move      1                    to   w-ast-ctr-pos          .
       stp-ast-fin-100.
      *                  *---------------------------------------------*
      *                  * Ciclo di stampa fino ad esaurimento p-res   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stringa di asterischi                   *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-ast-lun-nor        to   p-car                  .
           if        p-res                =    1
                     add    w-ast-lun-ult to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-ast-ctr-pos        to   p-pos                  .
           move      all "*"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Test su linee residue                   *
      *                      *-----------------------------------------*
           if        p-res                =    zero
                     go to  stp-ast-fin-999.
      *                          *-------------------------------------*
      *                          * Interlinea                          *
      *                          *-------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento contatore di posizione    *
      *                      *-----------------------------------------*
           add       w-ast-lun-nor        to   w-ast-ctr-pos          .
      *                      *-----------------------------------------*
      *                      * Riciclo a riga successiva               *
      *                      *-----------------------------------------*
           go to     stp-ast-fin-100.
       stp-ast-fin-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento numero ultima pagina             *
      *    *-----------------------------------------------------------*
       agg-ult-pag-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-ylp-iva-ult-agg    =    zero
                     go to agg-ult-pag-900.
       agg-ult-pag-100.
      *              *-------------------------------------------------*
      *              * Lettura year last page                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Secolo anno da data iniziale                *
      *                  *---------------------------------------------*
           move      w-ylp-iva-dat-ini    to   s-dat                  .
           move      s-saa                to   w-ylp-iva-dat-saa      .
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "Yg"                 to   s-ope                  .
           move      rr-num-cod           to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to agg-ult-pag-400.
       agg-ult-pag-200.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "Yp"                 to   s-ope                  .
           move      rr-num-cod           to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           move      zero                 to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     agg-ult-pag-100.
       agg-ult-pag-400.
      *              *-------------------------------------------------*
      *              * Record esistente                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "Yu"                 to   s-ope                  .
           move      rr-num-cod           to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           move      w-ylp-iva-ult-agg    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione di *
      *                      * aggiornamento                           *
      *                      *-----------------------------------------*
           if        s-sts                not  = spaces
                     go to agg-ult-pag-100.
       agg-ult-pag-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-ult-pag-999.
       agg-ult-pag-999.
           exit.

