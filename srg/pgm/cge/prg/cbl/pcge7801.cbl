      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo stampa          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se stampa definitiva                        *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "P"
                     go to  int-pag-sta-100.
      *                  *---------------------------------------------*
      *                  * Se carta vidimata                           *
      *                  *---------------------------------------------*
           if        rr-snx-cvd           =    "S"
                     go to  int-pag-sta-050.
      *                  *---------------------------------------------*
      *                  * Intestazione se carta NON vidimata          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine                              *
      *                      *-----------------------------------------*
           perform   int-pag-sta-scb-000  thru int-pag-sta-scb-999    .
      *                      *-----------------------------------------*
      *                      * A stampa fincatura                      *
      *                      *-----------------------------------------*
           go to     int-pag-sta-200.
       int-pag-sta-050.
      *                  *---------------------------------------------*
      *                  * Intestazione se carta vidimata              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Avanzamento pagina                      *
      *                      *-----------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Test su esito                       *
      *                          *-------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to  int-pag-sta-999.
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero pagina             *
      *                      * ghe di intestazione                     *
      *                      *-----------------------------------------*
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       rr-ult-pst           to   w-cnt-tit-num-pag      .
      *                      *-----------------------------------------*
      *                      * Posizionamento fisso per saltare le ri- *
      *                      * ghe di intestazione                     *
      *                      *-----------------------------------------*
           move      "VP"                 to   p-ope                  .
           move      06                   to   p-lnr                  .
           move      p-lnr                to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * A stampa fincatura                      *
      *                      *-----------------------------------------*
           go to     int-pag-sta-200.
       int-pag-sta-100.
      *                  *---------------------------------------------*
      *                  * Se stampa di prova                          *
      *                  *---------------------------------------------*
           move      "BROGLIACCIO DELLE VENDITE"
                                          to   w-cnt-tit-des-tit      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       rr-ult-pst           to   w-cnt-tit-num-pag      .
      *                  *---------------------------------------------*
      *                  * Intestazione standard                       *
      *                  *---------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
       int-pag-sta-200.
      *              *-------------------------------------------------*
      *              * Prima linea di fincatura                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Posizionamento fisso per lasciare una in-   *
      *                  * terlinea di separazione                     *
      *                  *---------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *                                                           *
      *    * Intestazione carta non vidimata                           *
      *    *-----------------------------------------------------------*
       int-pag-sta-scb-000.
      *              *-------------------------------------------------*
      *              * Avanzamento pagina                              *
      *              *-------------------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Se errore grave di i-o su stampa si esce    *
      *                  * con status di errore                        *
      *                  *---------------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to int-pag-sta-scb-999.
       int-pag-sta-scb-100.
      *              *-------------------------------------------------*
      *              * Preparazione numero pagina                      *
      *              *-------------------------------------------------*
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       rr-ult-pst           to   w-cnt-tit-num-pag      .
       int-pag-sta-scb-200.
      *              *-------------------------------------------------*
      *              * Linea di '='                                    *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      p-sel-als-sel        to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      all   "="            to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-scb-300.
      *              *-------------------------------------------------*
      *              * Prima linea intestazione                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ragione sociale azienda                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-azi-rag-soc        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Determinazione posizione iniziale per nume- *
      *                  * ro pagina                                   *
      *                  *---------------------------------------------*
           subtract  14                   from p-sel-als-sel
                                        giving p-pos                  .
           if        w-cnt-tit-num-pag    <    10
                     add   4              to   p-pos
           else if   w-cnt-tit-num-pag    <    100
                     add   3              to   p-pos
           else if   w-cnt-tit-num-pag    <    1000
                     add   2              to   p-pos
           else if   w-cnt-tit-num-pag    <    10000
                     add   1              to   p-pos                  .
      *                  *---------------------------------------------*
      *                  * Literal 'Pag.'                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      "Pag."               to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Numero pagina                               *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        w-cnt-tit-num-pag    <    10
                     move  1              to   p-car
           else if   w-cnt-tit-num-pag    <    100
                     move  2              to   p-car
           else if   w-cnt-tit-num-pag    <    1000
                     move  3              to   p-car
           else if   w-cnt-tit-num-pag    <    10000
                     move  4              to   p-car
           else      move  5              to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           add       5                    to   p-pos                  .
           move      w-cnt-tit-num-pag    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal '/'                                 *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           subtract  04                   from p-sel-als-sel
                                        giving p-pos                  .
           move      "/"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Secolo - anno                               *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           subtract  03                   from p-sel-als-sel
                                        giving p-pos                  .
           move      w-wrk-saa-ini        to   p-num                  .
           add       1900                 to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-scb-400.
      *              *-------------------------------------------------*
      *              * Seconda linea intestazione                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Indirizzo azienda                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      30                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-azi-ind-azi        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Titolo stampa                               *
      *                  *---------------------------------------------*
           move      "REGISTRO DELLE LETTERE D'INTENTI RICEVUTE"
      -                                   to   w-cnt-tit-des-tit      .
      *                      *-----------------------------------------*
      *                      * Determinazione posizione                *
      *                      *-----------------------------------------*
           move      zero                 to   w-wrk-ctr-004          .
           inspect   w-cnt-tit-des-tit
                                      tallying w-wrk-ctr-004
                                  for trailing spaces                 .
           subtract  w-wrk-ctr-004        from 80
                                        giving w-wrk-ctr-005          .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
