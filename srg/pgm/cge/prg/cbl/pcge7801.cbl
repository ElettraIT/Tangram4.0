      *    *===========================================================*
      *    * Aggiornamento file numerazioni [givven]                   *
      *    *-----------------------------------------------------------*
       agg-fil-num-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivven"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-ven             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave                             *
      *              *-------------------------------------------------*
           move      rr-num-num           to   rn-giv-ven-cod-num     .
      *              *-------------------------------------------------*
      *              * Ottenimento record                              *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivven"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-ven             .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to  agg-fil-num-100.
      *                      *-----------------------------------------*
      *                      * Se invalid key                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati record         *
      *                          *-------------------------------------*
           move      zero                 to   rn-giv-ven-dat-stp     .
           move      zero                 to   rn-giv-ven-ult-num     .
      *                          *-------------------------------------*
      *                          * Scrittura record                    *
      *                          *-------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivven"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-ven             .
      *                          *-------------------------------------*
      *                          * Riciclo a inizio                    *
      *                          *-------------------------------------*
           go to     agg-fil-num-000.
       agg-fil-num-100.
      *                      *-----------------------------------------*
      *                      * Se non invalid key                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento dati record           *
      *                          *-------------------------------------*
           move      rr-dat-fin           to   rn-giv-ven-dat-stp     .
           move      w-ctr-prt-iva        to   rn-giv-ven-ult-num     .
      *                          *-------------------------------------*
      *                          * Aggiornamento record file           *
      *                          *-------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivven"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-ven             .
      *                              *---------------------------------*
      *                              * Test su esito operazione        *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Se invalid key              *
      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to  agg-fil-num-000.
      *                                  *-----------------------------*
      *                                  * Se non invalid key          *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Rilascio record         *
      *                                      *-------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivven"
                                          to   s-pat                  .
