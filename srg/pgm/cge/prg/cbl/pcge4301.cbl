           move      "-------   ----------------------------------------
      -              "       ----------- -----------"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno e mese di esercizio                   *
      *    *-----------------------------------------------------------*
       ann-mes-ese-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-exe-pgm      .
      *              *-------------------------------------------------*
      *              * Lettura [num] dati di bilancio                  *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
      *              *-------------------------------------------------*
      *              * Lettura scelta mese di chiusura bilancio        *
      *              *-------------------------------------------------*
           move      "P:"                 to   s-ope                  .
           move      "pgm/cge[mes-chi]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  s-num          to   w-ese-cge-mce
           else      move  12             to   w-ese-cge-mce          .
           if        w-ese-cge-mce        <    01 or
                     w-ese-cge-mce        >    12
                     move  12             to   w-ese-cge-mce          .
      *              *-------------------------------------------------*
      *              * Determinazione data attuale                     *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-wrk-dat-att          .
      *              *-------------------------------------------------*
      *              * Determinazione mese e anno di esercizio relati- *
      *              * vo alla data situazione                         *
      *              *-------------------------------------------------*
           move      rr-dat-sit           to   w-ese-cge-dtr          .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
           move      w-ese-cge-esa        to   w-sit-ann-sit          .
           move      w-ese-cge-esm        to   w-sit-mes-sit          .
      *              *-------------------------------------------------*
      *              * Determinazione anno precedente quello della da- *
      *              * ta situazione                                   *
      *              *-------------------------------------------------*
           move      zero                 to   s-dat                  .
           move      w-sit-ann-sit        to   s-saa                  .
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-sit-ann-pre          .
       ann-mes-ese-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-ese-cge-dtr        to   s-dat                  .
           if        w-ese-cge-mce        =    12         or
                     s-mes                >    w-ese-cge-mce
                     move  s-saa          to   w-ese-cge-esa
                     go to det-ese-cge-500.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-ese-cge-esa          .
       det-ese-cge-500.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-ese-cge-esm          .
           if        w-ese-cge-mce        =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-ese-cge-mce
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-ese-cge-mce
                     add   12             to   w-ese-cge-esm
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-ese-cge-esm          .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
      *    * Routine di determinazione saldo alla data cliente         *
      *    *-----------------------------------------------------------*
       det-sdo-dat-000.
      *              *-------------------------------------------------*
      *              * Determinazione saldo ad inizio anno             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione se necessario lettura di una *
      *                  * o due schede saldi                          *
      *                  *                                             *
      *                  * - Se non e' mai stata eseguita una chiusura *
      *                  *   si leggono comunque due schede            *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio richiesto e' uguale o in-  *
      *                  *   feriore all'ultimo esercizio di chiusura  *
      *                  *   si legge una sola scheda                  *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio precedente quello della    *
      *                  *   data richiesta e' pari all'esercizio del- *
      *                  *   l'ultima chiusura si legge una sola sche- *
      *                  *   da                                        *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Si leggono due schede                     *
      *                  *---------------------------------------------*
           if        rn-dat-bil-ese-bil   =    zero
                     move  w-sit-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-sit-ann-sit        not  > rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else if   rn-dat-bil-flg-bil   not  = spaces
                     move  rn-dat-bil-ese-bil
                                          to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-sit-ann-pre        =    rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else      move  w-sit-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010.
       det-sdo-dat-010.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio di chiusura        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione saldo finale esercizio   *
      *                      * di bilancio                             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione campi chiave           *
      *                          *-------------------------------------*
           move      w-wrk-ann-ese        to   rf-mgs-ann-ese         .
           move      "C"                  to   rf-mgs-tip-rec         .
           move      rf-cli-cod-cli       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Determinazione saldo finale eserci- *
      *                          * zio di bilancio                     *
      *                          *-------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
           move      zero                 to   I                      .
       det-sdo-dat-020.
           add       1                    to   I                      .
           if        I                    >    12
                     go to  det-sdo-dat-040.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-ini          .
           go to     det-sdo-dat-020.
       det-sdo-dat-040.
           add       rf-mgs-dar-bil       to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-ini          .
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo bilancio        *
      *                          *-------------------------------------*
           add       w-sad-sdo-ini        to   w-wrk-sdo-bil          .
      *                      *-----------------------------------------*
      *                      * Lettura [mgs] esercizio richiesto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione chiave per [mgs]       *
      *                          *-------------------------------------*
           move      w-sit-ann-sit        to   rf-mgs-ann-ese         .
           move      "C"                  to   rf-mgs-tip-rec         .
           move      rf-cli-cod-cli       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
           go to     det-sdo-dat-200.
       det-sdo-dat-100.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio richiesto          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record file [mgs]       *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Preparazione chiave per [mgs]           *
      *                      *-----------------------------------------*
           move      w-sit-ann-sit        to   rf-mgs-ann-ese         .
           move      "C"                  to   rf-mgs-tip-rec         .
           move      rf-cli-cod-cli       to   rf-mgs-cod-con         .
      *                      *-----------------------------------------*
      *                      * Lettura file [mgs]                      *
      *                      *-----------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Determinazione saldo inizio anno        *
      *                      *-----------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
       det-sdo-dat-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo alla data di partenza      *
      *              *-------------------------------------------------*
           move      w-sad-sdo-ini        to   w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per accumulo progressivi men-*
      *              * sili anno in corso fino a mese precedente a     *
      *              * quello indicato da data situazione              *
      *              *-------------------------------------------------*
           move      w-sit-mes-sit        to   I                      .
       det-sdo-dat-220.
           subtract  1                    from I                      .
           if        I                    =    zero
                     go to  det-sdo-dat-240.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-dat          .
           go to     det-sdo-dat-220.
       det-sdo-dat-240.
      *              *-------------------------------------------------*
      *              * Se data situazione contabile uguale a data at-  *
      *              * tuale si aggiungono i progressivi del mese at-  *
      *              * tuale                                           *
      *              *-------------------------------------------------*
           if        rr-dat-sit           not  = w-wrk-dat-att
                     go to  det-sdo-dat-250.
           add       rf-mgs-dar-mes
                     (w-sit-mes-sit)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-sit-mes-sit)      from w-sad-sdo-dat          .
           go to     det-sdo-dat-999.
       det-sdo-dat-250.
      *              *-------------------------------------------------*
      *              * Controllo se giorno situazione e' fine mese     *
      *              *-------------------------------------------------*
           move      rr-dat-sit           to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Se la data e' corretta vuol dire che il     *
      *                  * giorno situazione non e' a fine mese        *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to  det-sdo-dat-300.
      *                      *-----------------------------------------*
      *                      * Se fine mese si aggiungono i progressivi*
      *                      * del mese attuale                        *
      *                      *-----------------------------------------*
           add       rf-mgs-dar-mes
                     (w-sit-mes-sit)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-sit-mes-sit)      from w-sad-sdo-dat          .
      *                      *-----------------------------------------*
      *                      * Se mese richiesto e' quello di chiusura *
      *                      * esercizio, si aggiungono i progressivi  *
      *                      * di bilancio                             *
      *                      *-----------------------------------------*
           if        w-sit-mes-sit        not  = w-ese-cge-mce
                     go to  det-sdo-dat-999.
           add       rf-mgs-dar-bil       to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-dat          .
           go to     det-sdo-dat-999.
       det-sdo-dat-300.
      *              *-------------------------------------------------*
      *              * Normalizzazione record file [mgr]               *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura file [mgr]      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo e codice archivio                      *
      *                  *---------------------------------------------*
           move      "C"                  to   rf-mgr-tip-arc         .
           move      rf-cli-cod-cli       to   rf-mgr-cod-arc         .
      *                  *---------------------------------------------*
      *                  * Data di registrazione                       *
      *                  *---------------------------------------------*
           move      zero                 to   s-dat                  .
           move      01                   to   s-gio                  .
           move      w-sit-mes-sit        to   s-mes                  .
           move      w-sit-ann-sit        to   s-saa                  .
           move      s-dat                to   rf-mgr-dat-reg         .
      *                  *---------------------------------------------*
      *                  * Numero protocollo                           *
      *                  *---------------------------------------------*
           move      zero                 to   rf-mgr-num-prt         .
      *                  *---------------------------------------------*
      *                  * Numero progressivo                          *
      *                  *---------------------------------------------*
           move      zero                 to   rf-mgr-num-prg         .
      *              *-------------------------------------------------*
      *              * Start file [mgr] per chiave "ARCDAT"            *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCDAT"             to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
       det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mgr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
      *              *-------------------------------------------------*
      *              * Test se superamento limiti massimi              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo e codice archivio                      *
      *                  *---------------------------------------------*
           if        rf-mgr-tip-arc        not  = "C"            or
                     rf-mgr-cod-arc        not  = rf-cli-cod-cli
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Data registrazione                          *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-reg       >    rr-dat-sit
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Se movimento di bilancio si ricicla         *
      *                  *---------------------------------------------*
           if        rf-mgr-snx-mob        not  = "N"
                     go to  det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo alla data                   *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-sad-sdo-dat
           else      add      rf-mgr-imp-mov
                                          to   w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura [mgr]                        *
      *              *-------------------------------------------------*
           go to     det-sdo-dat-500.
       det-sdo-dat-999.
           exit.

