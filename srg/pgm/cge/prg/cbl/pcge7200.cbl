                     go to tdo-ric-sel-150.
           if        w-prs-mul-gic-snx    =    "S"
                     go to tdo-ric-sel-102.
           move      "Numero giornale iva errato !                      
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-102.
           if        w-prs-mul-gic-max    not  < rr-num-num
                     go to tdo-ric-sel-150.
           move      "Numero giornale iva errato !                      
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-150.
      *              *-------------------------------------------------*
      *              * Test su tipo stampa                             *
      *              *-------------------------------------------------*
           if        rr-tip-stp           not  = spaces
                     go to tdo-ric-sel-152.
           move      "Manca la scelta se stampa di prova o definitiva ! 
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-152.
           if        rr-tip-stp           =    "P" or
                     rr-tip-stp           =    "D" or
                     rr-tip-stp           =    "R"
                     go to tdo-ric-sel-200.
           move      "Tipo stampa errato !                              
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
