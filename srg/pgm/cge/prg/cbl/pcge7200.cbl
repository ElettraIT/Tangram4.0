      *              *-------------------------------------------------*
      *              * Lettura file numerazioni giornali iva           *
      *              *-------------------------------------------------*
           move      rr-num-num           to   rn-giv-cor-cod-num     .
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivcor"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-cor             .
           if        f-sts                not  = e-not-err
                     move   zero          to   rn-giv-cor-dat-stp     .
           move      rn-giv-cor-dat-stp   to   w-wrk-ult-dat          .
      *              *-------------------------------------------------*
      *              * Determinazione valore default per data iniziale *
      *              *-------------------------------------------------*
           if        w-wrk-ult-dat        =    zero
                     go to let-num-iva-999.
           move      w-wrk-ult-dat        to   s-dat                  .
      *                  *---------------------------------------------*
      *                  * Controllo data                              *
      *                  *---------------------------------------------*
           move      "CD"                 to   s-ope                  .
           move      w-wrk-ult-dat        to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     move   zero          to   w-wrk-ult-dat
                     go to  let-num-iva-999.
      *                  *---------------------------------------------*
      *                  * Calcolo del giorno seguente                 *
      *                  *---------------------------------------------*
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to let-num-iva-900.
           move      1                    to   s-gio                  .
           add       1                    to   s-mes                  .
           if        s-mes                not  > 12
                     go to let-num-iva-900.
           move      1                    to   s-mes                  .
           if        s-ann                <    99
                     add   1              to   s-ann
                     go to let-num-iva-900.
           move      zero                 to   s-ann                  .
           add       1                    to   s-sec                  .
       let-num-iva-900.
           move      s-dat                to   w-wrk-ult-dat          .
       let-num-iva-999.
           exit.

