           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      rr-num-num           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Sostituzione carattere '@'                  *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      rr-num-des           to   w-all-str-alf          .
           move      "@"                  to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
