           move      "E"                  to   v-tip                  .
           move      w-exp-tip-stp-lun    to   v-car                  .
           move      w-exp-tip-stp-num    to   v-ldt                  .
           move      "PDR#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      33                   to   v-pos                  .
           move      w-exp-tip-stp-tbl    to   v-txt                  .
           if        w-prs-mul-gic-snx    =    "S" and
                     w-prs-mul-gic-max    >    zero
                     move  "UP  "         to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
      *
           if        rr-tip-stp           =    "P"
                     move  01             to   v-num
           else if   rr-tip-stp           =    "D"
                     move  02             to   v-num
           else if   rr-tip-stp           =    "R"
                     move  03             to   v-num
