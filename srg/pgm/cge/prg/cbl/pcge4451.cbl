      *                      *-----------------------------------------*
           if        rf-mgr-tip-iva       =    "1" or
                     rf-mgr-tip-iva       =    "A" or
                     rf-mgr-tip-iva       =    "2" or
                     rf-mgr-tip-iva       =    "B"
                     move  2              to   w-par-flg-dnp
           else      move  1              to   w-par-flg-dnp          .
