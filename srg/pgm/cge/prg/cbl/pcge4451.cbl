      *              *-------------------------------------------------*
           move      zero                 to   I                      .
       ord-par-cli-100.
           add       1                    to   I                      .
           if        I                    =    w-par-num-ele
                     go to ord-par-cli-999.
           move      I                    to   J
                                               K                      .
           move      w-par-dat-doc (I)    to   w-par-rot-dat          .
       ord-par-cli-200.
           add       1                    to   J                      .
           if        J                    >    w-par-num-ele
                     go to ord-par-cli-300.
           if        w-par-dat-doc (J)    >    w-par-rot-dat
                     go to ord-par-cli-200.
           move      J                    to   K                      .
           move      w-par-dat-doc (J)    to   w-par-rot-dat          .
           go to     ord-par-cli-200.
       ord-par-cli-300.
           move      I                    to   L                      .          
           if        w-par-rot-dat        >    w-par-dat-doc (L)
                     go to ord-par-cli-100.
           move      w-par-tbl-par (K)    to   w-par-tbl-par (1000)   .
           move      w-par-tbl-par (L)    to   w-par-tbl-par (K)      .
           move      w-par-tbl-par (1000) to   w-par-tbl-par (L)      .
           go to     ord-par-cli-100.
       ord-par-cli-999.
           exit.

