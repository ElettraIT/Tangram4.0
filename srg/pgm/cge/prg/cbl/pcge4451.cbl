           if        w-prs-soc-tol        =    zero
                     go to car-par-cli-910.
           move      w-par-sdo-par (1000) to   w-par-sdo-ass          .
           if        w-par-sdo-ass        not  > w-prs-soc-tol
                     go to car-par-cli-919.
       car-par-cli-910.
      *                  *---------------------------------------------*
