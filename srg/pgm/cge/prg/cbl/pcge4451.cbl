      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      80                   to   p-car                  .
           move      08                   to   p-pos                  .
           move      p-lnr                to   p-lin                  .
           move      w-ref-stp-rtp-des
                    (w-int-pag-sta-ctr)   to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     int-pag-sta-520.
