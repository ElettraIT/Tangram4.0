       wrt-mov-cge-eff-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiunta di un elemento eventuale per la    *
      *                  * Banca, se saldo diverso da zero             *
      *                  *---------------------------------------------*
           if        w-wrt-mov-cge-deb    =    w-wrt-mov-cge-cre
                     go to wrt-mov-cge-eff-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione elemento Banca               *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-cge-ele      .
           move      w-wrt-mov-cge-ban    to   w-wrt-mov-cge-cod
                                              (w-wrt-mov-cge-ele)     .
           move      "A"                  to   w-wrt-mov-cge-doa
                                              (w-wrt-mov-cge-ele)     .
           move      w-wrt-mov-cge-deb    to   w-wrt-mov-cge-imp
                                              (w-wrt-mov-cge-ele)     .
           subtract  w-wrt-mov-cge-cre    from w-wrt-mov-cge-imp
                                              (w-wrt-mov-cge-ele)     .
       wrt-mov-cge-eff-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto sottoconti       *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrt-mov-cge-ctr      .
       wrt-mov-cge-eff-200.
           add       1                    to   w-wrt-mov-cge-ctr      .
           if        w-wrt-mov-cge-ctr    >    w-wrt-mov-cge-ele
                     go to wrt-mov-cge-eff-900.
           if        w-wrt-mov-cge-ctr    >    w-wrt-mov-cge-max
                     go to wrt-mov-cge-eff-900.
       wrt-mov-cge-eff-300.
      *              *-------------------------------------------------*
      *              * Trattamento prima riga, compresa la testata     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se prima riga                          *
      *                  *---------------------------------------------*
           if        w-wrt-mov-cge-ctr    >    1
                     go to wrt-mov-cge-eff-400.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per scrittura testata  *
      *                  * e prima riga movimento di CGE               *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Valori per testata registrazione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data registrazione                      *
      *                      *-----------------------------------------*
           move      w-wrt-mov-cge-dat    to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-num-prt      .
      *                      *-----------------------------------------*
      *                      * Causale                                 *
