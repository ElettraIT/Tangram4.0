                     w-rig-tip-sez (1)    =    "REGIO"   or
                     w-rig-tip-sez (1)    =    "ENLOC"   or
                     w-rig-tip-sez (1)    =    "INAIL"   or
                     w-rig-tip-sez (1)    =    "ENPRE"   or
                     w-rig-tip-sez (1)    =    "C    "   or
