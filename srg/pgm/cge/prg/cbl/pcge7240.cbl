           move      w-rig-dat-zzz (1)    to   w-tes-dat-zzz (1)      .
           move      w-rig-snx-zzz (1)    to   w-tes-snx-zzz (1)      .
       cnt-tdo-rig-zzz-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli tutti superati             *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rig-zzz-999.
       cnt-tdo-rig-zzz-900.
      *              *-------------------------------------------------*
      *              * Emissione flag di uscita ad errore              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-zzz-999.
       cnt-tdo-rig-zzz-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo                  *
      *    *-----------------------------------------------------------*
       pre-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valori riga pre-accettazione        *
      *              *-------------------------------------------------*
           move      w-rig-imp-deb (1)    to   w-srp-imp-deb          .
           move      w-rig-imp-cre (1)    to   w-srp-imp-cre          .
       pre-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo                       *
      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Test su tipo sezione                            *
      *              *-------------------------------------------------*
           if        w-rig-tip-sez (1)    =    "P    "
                     go to pos-rig-cor-999.
      *              *-------------------------------------------------*
      *              * Se chiusura                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo sezione                        *
      *                  *---------------------------------------------*
           if        w-rig-tip-sez (1)    not  = "C    "
                     go to pos-rig-cor-200.
      *                  *---------------------------------------------*
      *                  * Solo se cancellazione riga                  *
      *                  *---------------------------------------------*
           if        w-cnt-cor-tip-agg    not  = "-"
                     go to pos-rig-cor-999.
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori di testata di comodo *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-dat-zzz (1)      .
           move      "N"                  to   w-tes-snx-zzz (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-rig-cor-999.
       pos-rig-cor-200.
      *              *-------------------------------------------------*
      *              * Controaggiornamento saldo totale                *
      *              *-------------------------------------------------*
           subtract  w-srp-imp-deb        from w-tes-sdo-tot (1)      .
           add       w-srp-imp-cre        to   w-tes-sdo-tot (1)      .
      *              *-------------------------------------------------*
      *              * Controaggiornamento saldi sezioni               *
      *              *-------------------------------------------------*
           if        w-rig-tip-sez (1)    =    "ERARI"
                     subtract w-srp-imp-deb
                                          from   w-tot-sdd-era
                     subtract w-srp-imp-cre
                                          from   w-tot-sdc-era
           else if   w-rig-tip-sez (1)    =    "INPS "
                     subtract w-srp-imp-deb
                                          from   w-tot-sdd-ips
                     subtract w-srp-imp-cre
                                          from   w-tot-sdc-ips
           else if   w-rig-tip-sez (1)    =    "REGIO"
                     subtract w-srp-imp-deb
                                          from   w-tot-sdd-rgn
                     subtract w-srp-imp-cre
                                          from   w-tot-sdc-rgn
           else if   w-rig-tip-sez (1)    =    "ENLOC"
                     subtract w-srp-imp-deb
                                          from   w-tot-sdd-enl
                     subtract w-srp-imp-cre
                                          from   w-tot-sdc-enl
           else if   w-rig-tip-sez (1)    =    "INAIL"
                     subtract w-srp-imp-deb
                                          from   w-tot-sdd-inl
                     subtract w-srp-imp-cre
                                          from   w-tot-sdc-inl
           else if   w-rig-tip-sez (1)    =    "ENPRE"
                     subtract w-srp-imp-deb
                                          from   w-tot-sdd-enp
                     subtract w-srp-imp-cre
                                          from   w-tot-sdc-enp        .
       pos-rig-cor-300.
      *              *-------------------------------------------------*
      *              * Controlli per sezioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Erario                                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-sez (1)    not  = "ERARI"
                     go to pos-rig-cor-500.
      *                  *---------------------------------------------*
      *                  * Solo se cancellazione riga                  *
      *                  *---------------------------------------------*
           if        w-cnt-cor-tip-agg    not  = "-"
                     go to pos-rig-cor-500.
      *                  *---------------------------------------------*
      *                  * Test se riga iniziale                       *
      *                  *---------------------------------------------*
           if        w-ctl-sez-era-rig    not  = zero
                     move  zero           to   w-ctl-sez-era-rig      .
       pos-rig-cor-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldi, se necessario              *
      *              *-------------------------------------------------*
           if        w-cnt-cor-tip-agg    not  = "+"
                     go to pos-rig-cor-900.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo totale                      *
      *              *-------------------------------------------------*
           add       w-rig-imp-deb (1)    to   w-tes-sdo-tot (1)      .
           subtract  w-rig-imp-cre (1)    from w-tes-sdo-tot (1)      .
      *              *-------------------------------------------------*
      *              * Aggiornamento saldi sezioni                     *
      *              *-------------------------------------------------*
           if        w-rig-tip-sez (1)    =    "ERARI"
                     add  w-rig-imp-deb (1)
                                          to   w-tot-sdd-era
                     add  w-rig-imp-cre (1)
                                          to   w-tot-sdc-era
           else if   w-rig-tip-sez (1)    =    "INPS "
                     add  w-rig-imp-deb (1)
                                          to   w-tot-sdd-ips
                     add  w-rig-imp-cre (1)
                                          to   w-tot-sdc-ips
           else if   w-rig-tip-sez (1)    =    "REGIO"
                     add  w-rig-imp-deb (1)
                                          to   w-tot-sdd-rgn
                     add  w-rig-imp-cre (1)
                                          to   w-tot-sdc-rgn
           else if   w-rig-tip-sez (1)    =    "ENLOC"
                     add  w-rig-imp-deb (1)
                                          to   w-tot-sdd-enl
                     add  w-rig-imp-cre (1)
                                          to   w-tot-sdc-enl
           else if   w-rig-tip-sez (1)    =    "INAIL"
                     add  w-rig-imp-deb (1)
                                          to   w-tot-sdd-inl
                     add  w-rig-imp-cre (1)
                                          to   w-tot-sdc-inl
           else if   w-rig-tip-sez (1)    =    "ENPRE"
                     add  w-rig-imp-deb (1)
                                          to   w-tot-sdd-enp
                     add  w-rig-imp-cre (1)
                                          to   w-tot-sdc-enp          .
       pos-rig-cor-900.
      *              *-------------------------------------------------*
      *              * Saldo finale                                    *
      *              *-------------------------------------------------*
           perform   vis-sdo-reg-000      thru vis-sdo-reg-999        .
       pos-rig-cor-999.
           exit.

