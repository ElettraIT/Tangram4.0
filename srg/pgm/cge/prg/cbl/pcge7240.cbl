       nor-pre-rig-ips-000.
           move      spaces               to   w-rig-sed-ips (1)      .
           move      spaces               to   w-rig-sed-ips-des (1)  .
           move      spaces               to   w-rig-trb-ips (1)      .
           move      spaces               to   w-rig-trb-ips-des (1)  .
           move      spaces               to   w-rig-mat-ips (1)      .
           move      zero                 to   w-rig-mda-ips (1)      .
           move      zero                 to   w-rig-maa-ips (1)      .
           move      zero                 to   w-rig-aaa-ips (1)      .
       nor-pre-rig-ips-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione preliminare righe corpo                   *
      *    *                                                           *
      *    * Subroutine : Regione                                      *
      *    *-----------------------------------------------------------*
       nor-pre-rig-rgn-000.
           move      spaces               to   w-rig-cod-rgn (1)      .
           move      spaces               to   w-rig-cod-rgn-des (1)  .
           move      spaces               to   w-rig-trb-rgn (1)      .
           move      spaces               to   w-rig-trb-rgn-des (1)  .
           move      spaces               to   w-rig-rtz-rgn (1)      .
           move      zero                 to   w-rig-ann-rgn (1)      .
       nor-pre-rig-rgn-999.
           exit.

