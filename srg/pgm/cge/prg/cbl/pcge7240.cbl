      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Tipo sezione                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Sezione           :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo servizio        *
      *              *-------------------------------------------------*
           if        w-rig-tip-sez (1)    =    "P    "
                     perform pmt-rig-cor-pre-000
                                          thru pmt-rig-cor-pre-999
           else if   w-rig-tip-sez (1)    =    "ERARI"
                     perform pmt-rig-cor-era-000
                                          thru pmt-rig-cor-era-999
           else if   w-rig-tip-sez (1)    =    "INPS "
                     perform pmt-rig-cor-ips-000
                                          thru pmt-rig-cor-ips-999
           else if   w-rig-tip-sez (1)    =    "REGIO"
                     perform pmt-rig-cor-rgn-000
                                          thru pmt-rig-cor-rgn-999
           else if   w-rig-tip-sez (1)    =    "ENLOC"
                     perform pmt-rig-cor-enl-000
                                          thru pmt-rig-cor-enl-999
           else if   w-rig-tip-sez (1)    =    "INAIL"
                     perform pmt-rig-cor-inl-000
                                          thru pmt-rig-cor-inl-999
           else if   w-rig-tip-sez (1)    =    "ENPRE"
                     perform pmt-rig-cor-enp-000
                                          thru pmt-rig-cor-enp-999
           else if   w-rig-tip-sez (1)    =    "C    "
                     perform pmt-rig-cor-zzz-000
                                          thru pmt-rig-cor-zzz-999
           else      go to pmt-rig-cor-400.                   
       pmt-rig-cor-400.
      *              *-------------------------------------------------*
      *              * Se presentazione o chiusura : oltre             *
      *              *-------------------------------------------------*
