       nor-pre-rig-enl-000.
           move      spaces               to   w-rig-cod-enl (1)      .
           move      spaces               to   w-rig-cod-enl-des (1)  .
           move      spaces               to   w-rig-trb-enl (1)      .
           move      spaces               to   w-rig-trb-enl-des (1)  .
           move      spaces               to   w-rig-rtz-enl (1)      .
           move      zero                 to   w-rig-ann-enl (1)      .
      *
           move      spaces               to   w-rig-pi1-enl (1)      .
           move      spaces               to   w-rig-pi2-enl (1)      .
           move      spaces               to   w-rig-pi3-enl (1)      .
           move      spaces               to   w-rig-pi4-enl (1)      .
           move      zero                 to   w-rig-nim-enl (1)      .
           move      zero                 to   w-rig-dia-enl (1)      .
      *
           move      spaces               to   w-rig-ide-enl (1)      .
       nor-pre-rig-enl-999.
