                                          to   w-lin-imm-cod-trb
                     move  w-rig-cau-enp-des (1)
                                          to   w-lin-imm-des-trb
           else if   w-rig-tip-sez (1)    =    "C    "
                     move  "*****"        to   w-lin-imm-cod-trb
                     move  "CHIUSURA                                "
                                          to   w-lin-imm-des-trb
           else      move  "?                                       "
                                          to   w-lin-imm-des-trb      .
      *                      *-----------------------------------------*
