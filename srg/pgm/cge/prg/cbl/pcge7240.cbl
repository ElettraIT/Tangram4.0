      *              *-------------------------------------------------*
           move      w-tes-num-prt        to   rf-mpu-num-prt         .
           move      w-rig-num-prg (2)    to   rf-mpu-num-prg         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
       del-rec-mpu-999.
           exit.

