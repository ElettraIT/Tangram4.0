       prs-gep-sia-400.
      *              *-------------------------------------------------*
      *              * Se record personalizzazioni non esistente       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area per ridefinizione del- *
      *                  * le personalizzazioni portafoglio S.I.A.     *
      *                  *---------------------------------------------*
           move      spaces               to   w-prs-sia-daz-001      .
           move      spaces               to   w-prs-sia-daz-002      .
           move      spaces               to   w-prs-sia-daz-003      .
           move      spaces               to   w-prs-sia-daz-004      .
           move      spaces               to   w-prs-sia-fir-emi      .
           move      spaces               to   w-prs-sia-cda-sia      .
           move      spaces               to   w-prs-sia-cor-ndg      .
           move      spaces               to   w-prs-sia-pvc-aut      .
           move      zero                 to   w-prs-sia-num-aut      .
           move      zero                 to   w-prs-sia-dat-aut      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prs-gep-sia-999.
       prs-gep-sia-999.
           exit.

      *    *===========================================================*
      *    * Stampa documento                                          *
      *    *                                                           *
      *    * Subroutine : Intestazione                                 *
      *    *-----------------------------------------------------------*
       gen-ads-cbi-int-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           if        w-rig-cod-int (1)    not  numeric
                     move  zero           to   w-rig-cod-int (1)      .
           move      "N"                  to   w-azi-snx-prf          .
       gen-ads-cbi-int-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del codice intestatario  *
      *              *-------------------------------------------------*
           if        w-rig-cod-int (1)    not  = zero
                     go to gen-ads-cbi-int-500.
       gen-ads-cbi-int-200.
      *              *-------------------------------------------------*
      *              * Se modello intestato all'azienda                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Dati anagrafici azienda                     *
      *                  *---------------------------------------------*
           move      "IA"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-asx                to   w-azi-rag-soc          .
      *                  *---------------------------------------------*
      *                  * Normalizzazione [ada]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Lettura [ada] dati anagrafici Azienda       *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Salvataggio dati azienda letti              *
      *                  *---------------------------------------------*
           move      rf-ada-via-azi       to   w-azi-ind-azi          .
           move      rf-ada-loc-azi       to   w-azi-loc-azi          .
           move      rf-ada-cod-fis       to   w-azi-cod-fis          .
           move      rf-ada-cod-cmn       to   w-azi-cod-cmn          .
       gen-ads-cbi-int-480.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     gen-ads-cbi-int-900.
       gen-ads-cbi-int-500.
      *              *-------------------------------------------------*
      *              * Se modello intestato a fornitore                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [fnt]                          *
      *                  *---------------------------------------------*
           move      w-rig-cod-int (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzaione file [raa]                   *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/rda/fls/ioc/obj/iofraa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-raa                 .
      *                  *---------------------------------------------*
      *                  * Lettura file [raa]                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-rig-cod-int (1)    to   rf-raa-cod-fnt         .
           move      "pgm/rda/fls/ioc/obj/iofraa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-raa                 .
       gen-ads-cbi-int-520.
      *                  *---------------------------------------------*
      *                  * Stampa in funzione del segnale di si/no     *
      *                  * persona fisica                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Indicatore di persona fisica            *
      *                      *-----------------------------------------*
           if        rf-raa-snx-prf       =    02
                     move  "S"            to   w-azi-snx-prf          .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rf-raa-snx-prf       =    01
                     go to gen-ads-cbi-int-600
           else      go to gen-ads-cbi-int-700.
       gen-ads-cbi-int-600.
      *                      *-----------------------------------------*
      *                      * Se Societa'                             *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-rag    to   w-azi-rag-soc          .
           move      w-let-arc-fnt-via    to   w-azi-ind-azi          .
           move      w-let-arc-fnt-loc    to   w-azi-loc-azi          .
           move      w-let-arc-fnt-cfi    to   w-azi-cod-fis          .
           move      w-let-arc-fnt-cmn    to   w-azi-cod-cmn          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     gen-ads-cbi-int-900.
       gen-ads-cbi-int-700.
      *                      *-----------------------------------------*
      *                      * Se Persona fisica                       *
      *                      *-----------------------------------------*
           move      rf-raa-cgn-fnt       to   w-azi-rag-cgn          .
           move      rf-raa-nom-fnt       to   w-azi-rag-nom          .
           move      rf-raa-dat-nsc       to   w-azi-dat-nsc          .
           move      rf-raa-loc-nsc       to   w-azi-loc-nsc          .
      *                          *-------------------------------------*
      *                          * Individuazione codice provincia     *
      *                          *-------------------------------------*
           move      rf-raa-loc-nsc       to   w-det-cod-prv-loc      .
           perform   det-cod-prv-000      thru det-cod-prv-999        .
           move      w-det-cod-prv-cod    to   w-azi-prv-nsc          .
           if        w-det-cod-prv-cod    =    spaces or
                     w-det-cod-prv-pos    =    zero
                     go to gen-ads-cbi-int-720.
      *                          *-------------------------------------*
      *                          * Si toglie il codice provincia dalla *
      *                          * localita'                           *
      *                          *-------------------------------------*
           move      spaces               to   w-azi-loc-nsc
                                              (w-det-cod-prv-pos : 02).
       gen-ads-cbi-int-720.
           if        rf-raa-sex-fnt       =    01
                     move  "M"            to   w-azi-sex-int
           else      move  "F"            to   w-azi-sex-int          .
      *
           move      rf-raa-via-fnt       to   w-azi-ind-azi          .
           move      rf-raa-loc-fnt       to   w-azi-loc-azi          .
           move      w-let-arc-fnt-cfi    to   w-azi-cod-fis          .
           move      w-let-arc-fnt-cmn    to   w-azi-cod-cmn          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     gen-ads-cbi-int-900.
       gen-ads-cbi-int-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     gen-ads-cbi-int-999.
       gen-ads-cbi-int-999.
           exit.

      *    *===========================================================*
