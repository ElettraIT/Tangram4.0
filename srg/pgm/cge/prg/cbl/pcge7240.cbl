      *                      *-----------------------------------------*
           if        w-rig-tip-sez (1)    =    "P    "
                     move  w-rig-cod-cbp (1)
                                          to   w-lin-imm-cod-trb
                     move  w-rig-cod-cbp-des (1)
                                          to   w-lin-imm-des-trb
           else if   w-rig-tip-sez (1)    =    "ERARI"
                     move  w-rig-trb-era (1)
                                          to   w-lin-imm-cod-trb
                     move  w-rig-trb-era-des (1)
                                          to   w-lin-imm-des-trb
           else if   w-rig-tip-sez (1)    =    "INPS "
                     move  w-rig-trb-ips (1)
                                          to   w-lin-imm-cod-trb
                     move  w-rig-trb-ips-des (1)
                                          to   w-lin-imm-des-trb
