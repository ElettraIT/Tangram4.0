                     move  w-rig-trb-rgn (1)
                                          to   w-lin-imm-cod-trb
                     move  w-rig-trb-rgn-des (1)
                                          to   w-lin-imm-des-trb
           else if   w-rig-tip-sez (1)    =    "ENLOC"
