      *              * Normalizzazione area per saldi                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-tot-sdd-era          .
           move      zero                 to   w-tot-sdc-era          .
           move      zero                 to   w-tot-sdd-ips          .
           move      zero                 to   w-tot-sdc-ips          .
           move      zero                 to   w-tot-sdd-rgn          .
           move      zero                 to   w-tot-sdc-rgn          .
           move      zero                 to   w-tot-sdd-enl          .
           move      zero                 to   w-tot-sdc-enl          .
           move      zero                 to   w-tot-sdd-inl          .
           move      zero                 to   w-tot-sdc-inl          .
           move      zero                 to   w-tot-sdd-enp          .
           move      zero                 to   w-tot-sdc-enp          .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati chiave                     *
      *              *-------------------------------------------------*
           perform   nor-key-reg-000      thru nor-key-reg-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave testata         *
      *              *-------------------------------------------------*
           perform   nor-nok-tes-000      thru nor-nok-tes-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave riga corpo      *
      *              *-------------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave piede           *
      *              *-------------------------------------------------*
           perform   nor-nok-pie-000      thru nor-nok-pie-999        .
       nor-key-nok-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati chiave                               *
      *    *-----------------------------------------------------------*
       nor-key-reg-000.
           move      zero                 to   w-tes-num-prt          .
           move      zero                 to   w-tes-dat-reg          .
       nor-key-reg-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave testata                   *
      *    *-----------------------------------------------------------*
       nor-nok-tes-000.
           move      zero                 to   w-tes-sdo-tot (1)      .
           move      spaces               to   w-tes-sez-pre (1)      .
           move      zero                 to   w-tes-dat-pre (1)      .
           move      zero                 to   w-tes-dat-zzz (1)      .
           move      spaces               to   w-tes-snx-zzz (1)      .
       nor-nok-tes-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione dati non chiave riga corpo                *
      *    *-----------------------------------------------------------*
       nor-nok-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione elementi comuni                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-rig-num-prg (1)      .
           move      spaces               to   w-rig-tip-sez (1)      .
           move      zero                 to   w-rig-imp-deb (1)      .
           move      zero                 to   w-rig-imp-cre (1)      .
           move      spaces               to   w-rig-ele-sez (1)      .
           move      spaces               to   w-rig-flg-stp (1)      .
           move      spaces               to   w-rig-alx-exp (1)      .
       nor-nok-rig-999.
           exit.

      *    *===========================================================*
