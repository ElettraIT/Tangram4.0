      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Literal del mese                    *
      *                          *-------------------------------------*
           move      w-wrt-mov-cge-dat    to   s-dat                  .
      *
           move      "LM"                 to   s-ope                  .
           move      "A"                  to   s-tip                  .
           move      s-mes                to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-alf                to   w-all-str-cat (2)      .
      *                          *-------------------------------------*
      *                          * Anno                                *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      s-saa                to   v-num                  .
           add       1900                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (3)      .
      *                          *-------------------------------------*
      *                          * Assemblaggio                        *
      *                          *-------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Registrazione pagamento F24 -"
                                          to   w-all-str-cat (1)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "N"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-sca      .
      *                  *---------------------------------------------*
      *                  * Valori per prima riga registrazione         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice piano dei conti                  *
      *                      *-----------------------------------------*
           move      w-wrt-mov-cge-cod
                    (w-wrt-mov-cge-ctr)   to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Commento in riga                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-com-rig      .
      *                      *-----------------------------------------*
      *                      * Data e numero riferimento               *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
           move      spaces               to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      w-wrt-mov-cge-doa
                    (w-wrt-mov-cge-ctr)   to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-wrt-mov-cge-imp
                    (w-wrt-mov-cge-ctr)   to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Flag di regime fiscale particolare      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-flg-rfp      .
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-sgl-num      .
      *                      *-----------------------------------------*
      *                      * Data acquisizione                       *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-acq      .
      *                  *---------------------------------------------*
      *                  * Richiamo modulo scrittura CGE               *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Recupero del numero protocollo              *
      *                  *---------------------------------------------*
           move      l-cge-300-num-prt    to   w-wrt-mov-cge-prc      .
      *                  *---------------------------------------------*
      *                  * Riciclo a riga successiva                   *
      *                  *---------------------------------------------*
           go to     wrt-mov-cge-eff-200.
       wrt-mov-cge-eff-400.
      *              *-------------------------------------------------*
      *              * Trattamento righe successive alla prima         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area riga movimento    *
      *                  * per aggiornamenti contabili                 *
      *                  *---------------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per seconda riga     *
      *                  * movimento                                   *
      *                  *                                             *
      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
