      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione progressivo righe               *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-ctr-prg
      *              *-------------------------------------------------*
      *              * Normalizzazione comodi per controlli sezioni    *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-sez-era-rig      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort per ordinamento richiesto       *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   stp-srt-out-000
                                          thru stp-srt-out-999        .
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di records ca-  *
      *              * ricati nel file relative di appoggio            *
      *              *-------------------------------------------------*
           if        w-ctl-ctr-prg        =    zero
                     go to rou-let-reg-200
           else      go to rou-let-reg-300.
       rou-let-reg-200.
      *              *-------------------------------------------------*
      *              * Se numero di records caricati : zero            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se impostato protocollo                *
      *                  *---------------------------------------------*
           if        w-tes-num-prt        =    zero
                     go to rou-let-reg-240.
      *                  *---------------------------------------------*
      *                  * Se protocollo impostato non trovato         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Modello di Pagamento non trovato in archivio !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Flag di errore                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-240.
      *                  *---------------------------------------------*
      *                  * Test se inserimento consentito              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-vis-sgr    not  = "V"
                     go to rou-let-reg-250.
      *                      *-----------------------------------------*
      *                      * Flag di uscita                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Inserimento non consentito !                      
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     rou-let-reg-900.
       rou-let-reg-250.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-900.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se numero di records caricati maggiore di zero  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valori precedenti testata                   *
      *                  *---------------------------------------------*
           move      w-tes-val-aep (1)    to   w-tes-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Modifica                                    *
      *                  *---------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di duplicazione     *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-dup-rec-flg      .
      *                  *---------------------------------------------*
      *                  * Test per visualizzazione                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su flag da segreteria              *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-vis-sgr    =    "V"
                     move  "V"            to   w-cnt-mfu-tip-fun
                     go to rou-let-reg-900.
      *                      *-----------------------------------------*
      *                      * Test su data chiusura                   *
      *                      *-----------------------------------------*
           if        w-tes-dat-zzz (1)    =    zero
                     go to rou-let-reg-900.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Modello di Pagamento gia' chiuso !                
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Test su flag di registrazione           *
      *                      *-----------------------------------------*
           if        w-tes-snx-zzz (1)    not  = "S"
                     go to rou-let-reg-900.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Modello di Pagamento gia' registrato, pertanto non
      -              " modificabile! "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Flag di visualizzazione                 *
      *                      *-----------------------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [mpu]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-num-prt        to   rf-mpu-num-prt         .
           move      zero                 to   rf-mpu-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mpu]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo : uscita                       *
      *              *-------------------------------------------------*
           if        rf-mpu-num-prt       not  = w-tes-num-prt
                     go to stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [mpu]                      *
      *              *-------------------------------------------------*
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento progressivo righe                 *
      *              *-------------------------------------------------*
           add       1                    to   w-ctl-ctr-prg          .
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record di sort              *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo sezione                            *
      *                      *-----------------------------------------*
           if        rf-mpu-tip-sez       =    "P    "
                     move  00             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "ERARI"
                     move  01             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "INPS "
                     move  02             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "REGIO"
                     move  03             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "ENLOC"
                     move  04             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "INAIL"
                     move  05             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "ENPRE"
                     move  06             to   srt-tip-sez
           else if   rf-mpu-tip-sez       =    "C    "
                     move  99             to   srt-tip-sez            .
      *                      *-----------------------------------------*
      *                      * Progressivo righe                       *
      *                      *-----------------------------------------*
           move      rf-mpu-num-prg       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Record [mpu]                            *
      *                      *-----------------------------------------*
           move      rf-mpu               to   srt-rec-mpu            .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione caricamento file relative di appoggio          *
      *    *-----------------------------------------------------------*
       stp-srt-out-000.
      *              *-------------------------------------------------*
      *              * La preparazione della catena avviene dai record *
      *              * rilasciati dalla routine in input di sort       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se righe trovate                       *
      *                  *---------------------------------------------*
           if        w-ctl-ctr-prg        =    zero
                     go to stp-srt-out-999.
      *                  *---------------------------------------------*
      *                  * Normalizzazione catena righe                *
      *                  *---------------------------------------------*
           move      "BE"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       stp-srt-out-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se At End : uscita                          *
      *                  *---------------------------------------------*
           return    srt    at end
                            go to stp-srt-out-999                     .
       stp-srt-out-200.
      *              *-------------------------------------------------*
      *              * Composizione area 'w-rig'                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione [mpu]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmpu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mpu                 .
      *                  *---------------------------------------------*
      *                  * Recupero record                             *
      *                  *---------------------------------------------*
           move      srt-rec-mpu          to   rf-mpu                 .
      *                  *---------------------------------------------*
      *                  * Completamento valori testata                *
      *                  *---------------------------------------------*
           move      rf-mpu-dat-reg       to   w-tes-dat-reg          .
           perform   vis-dat-reg-000      thru vis-dat-reg-999        .
      *                  *---------------------------------------------*
      *                  * Valori attuali                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori contenuti direttamente in record *
      *                      * [mpu]                                   *
      *                      *-----------------------------------------*
           move      rf-mpu-num-prg       to   w-rig-num-prg (1)      .
           move      rf-mpu-tip-sez       to   w-rig-tip-sez (1)      .
           move      rf-mpu-imp-deb       to   w-rig-imp-deb (1)      .
           move      rf-mpu-imp-cre       to   w-rig-imp-cre (1)      .
           move      rf-mpu-ele-sez       to   w-rig-ele-sez (1)      .
           move      rf-mpu-flg-stp       to   w-rig-flg-stp (1)      .
           move      rf-mpu-alx-exp       to   w-rig-alx-exp (1)      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento saldo totale              *
      *                      *-----------------------------------------*
           add       w-rig-imp-deb (1)    to   w-tes-sdo-tot (1)      .
           subtract  w-rig-imp-cre (1)    from w-tes-sdo-tot (1)      .
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo sezione *
      *                      *-----------------------------------------*
           if        w-rig-tip-sez (1)    =    "P    "
                     perform stp-srt-out-pre-000
                                          thru stp-srt-out-pre-999
           else if   w-rig-tip-sez (1)    =    "ERARI"
                     perform stp-srt-out-era-000
                                          thru stp-srt-out-era-999
           else if   w-rig-tip-sez (1)    =    "INPS "
                     perform stp-srt-out-ips-000
                                          thru stp-srt-out-ips-999
           else if   w-rig-tip-sez (1)    =    "REGIO"
                     perform stp-srt-out-rgn-000
                                          thru stp-srt-out-rgn-999
           else if   w-rig-tip-sez (1)    =    "ENLOC"
                     perform stp-srt-out-enl-000
                                          thru stp-srt-out-enl-999
           else if   w-rig-tip-sez (1)    =    "INAIL"
                     perform stp-srt-out-inl-000
                                          thru stp-srt-out-inl-999
           else if   w-rig-tip-sez (1)    =    "ENPRE"
                     perform stp-srt-out-enp-000
                                          thru stp-srt-out-enp-999
           else if   w-rig-tip-sez (1)    =    "C    "
                     perform stp-srt-out-zzz-000
                                          thru stp-srt-out-zzz-999
           else      go to stp-srt-out-900.
       stp-srt-out-900.
      *                  *---------------------------------------------*
      *                  * Valori precedenti                           *
      *                  *---------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Put su catena movimenti [rig]               *
      *                  *---------------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-mpu-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura record di sort            *
      *                  *---------------------------------------------*
           go to     stp-srt-out-100.
       stp-srt-out-999.
           exit.

