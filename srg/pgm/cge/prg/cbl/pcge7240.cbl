       f24-412-cbi-100.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Filler a posizione uno, e tipo record       *
      *                  *---------------------------------------------*
           move      spaces               to   w-f24-cbi-412-fpu      .
           move      "40"                 to   w-f24-cbi-412-tre      .
      *                  *---------------------------------------------*
      *                  * Numero delega F24                           *
      *                  *---------------------------------------------*
           move      w-ads-cbi-gen-pro    to   w-f24-cbi-412-nud      .
      *                  *---------------------------------------------*
      *                  * Sub-tipo record                             *
      *                  *---------------------------------------------*
           move      "12"                 to   w-f24-cbi-412-str      .
      *                  *---------------------------------------------*
      *                  * Codice Ente                                 *
      *                  *---------------------------------------------*
           move      w-rig-cod-enp (1)    to   w-f24-cbi-412-cen      .
      *                  *---------------------------------------------*
      *                  * Importo a debito totale                     *
      *                  *---------------------------------------------*
           move      w-ads-cbi-deb-enp    to   w-f24-cbi-412-idt      .
      *                  *---------------------------------------------*
      *                  * Importo a credito compensato totale         *
      *                  *---------------------------------------------*
           move      w-ads-cbi-cre-enp    to   w-f24-cbi-412-icc      .
      *                  *---------------------------------------------*
      *                  * Segno sezione                               *
      *                  *---------------------------------------------*
           move      "P"                  to   w-f24-cbi-412-sgn      .
      *
           if        w-ads-cbi-cre-enp    >    w-ads-cbi-deb-enp
                     move  "N"            to   w-f24-cbi-412-sgn      .
      *                  *---------------------------------------------*
      *                  * Saldo sezione                               *
      *                  *---------------------------------------------*
           move      w-ads-cbi-deb-enp    to   w-ads-cbi-sdo-sez      .
           subtract  w-ads-cbi-cre-enp    from w-ads-cbi-sdo-sez      .
           move      w-ads-cbi-sdo-sez    to   w-f24-cbi-412-sdo      .
      *                  *---------------------------------------------*
      *                  * Incremento totali generali                  *
      *                  *---------------------------------------------*
           perform   f24-tot-sez-000      thru f24-tot-sez-999        .
      *                  *---------------------------------------------*
      *                  * Filler a spaces                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-f24-cbi-412-f58      .
       f24-412-cbi-900.
      *              *-------------------------------------------------*
      *              * Scrittura record in file [ouf] in formato per   *
      *              * Binario                                         *
      *              *-------------------------------------------------*
           move      spaces               to   ouf-rec                .
           move      w-f24-cbi-412        to   ouf-dat                .
           perform   ouf-fil-wrt-000      thru ouf-fil-wrt-999        .
       f24-412-cbi-999.
           exit.

