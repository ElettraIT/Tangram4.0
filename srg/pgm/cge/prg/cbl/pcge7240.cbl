           move      spaces               to   w-rig-cod-enp-des (1)  .
           move      spaces               to   w-rig-sed-enp (1)      .
           move      spaces               to   w-rig-sed-enp-des (1)  .
           move      spaces               to   w-rig-cau-enp (1)      .
           move      spaces               to   w-rig-cau-enp-des (1)  .
           move      spaces               to   w-rig-pos-enp (1)      .
           move      zero                 to   w-rig-mda-enp (1)      .
           move      zero                 to   w-rig-ada-enp (1)      .
           move      zero                 to   w-rig-maa-enp (1)      .
           move      zero                 to   w-rig-aaa-enp (1)      .
       nor-pre-rig-enp-999.
