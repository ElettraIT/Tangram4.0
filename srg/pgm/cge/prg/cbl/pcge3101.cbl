      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-let-seq-100.
      *              *-------------------------------------------------*
      *              * Se primo giro : lettura [mgt]                   *
      *              *-------------------------------------------------*
           if        w-reg-dat-reg        =    zero and
                     w-reg-num-prt        =    zero
                     go to prn-let-seq-200
           else      go to prn-let-seq-500.
       prn-let-seq-200.
      *              *-------------------------------------------------*
      *              * Se primo giro                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale [mgt]                   *
      *                  *---------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to  prn-let-seq-999.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo si rilascia il record e *
      *                  * si attiva il flag di fine lettura           *
      *                  *---------------------------------------------*
           if        rf-mgt-dat-reg       not  > rr-dat-fin
                     go to prn-let-seq-300.
      *                  *---------------------------------------------*
      *                  * Release [mgt]                               *
      *                  *---------------------------------------------*
           perform   prn-let-seq-rel-000  thru prn-let-seq-rel-999    .
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-prn-flg-sub      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-let-seq-999.
       prn-let-seq-300.
      *                  *---------------------------------------------*
      *                  * Se record non selezionabile si rilascia il  *
      *                  * record e si legge il successivo             *
      *                  *---------------------------------------------*
           if        rf-mgt-flg-gio       =    spaces
                     go to prn-let-seq-400.
      *                  *---------------------------------------------*
      *                  * Test se ristampa                            *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "R"
                     go to prn-let-seq-400.
      *                  *---------------------------------------------*
      *                  * Release [mgt]                               *
      *                  *---------------------------------------------*
           perform   prn-let-seq-rel-000  thru prn-let-seq-rel-999    .
      *                  *---------------------------------------------*
      *                  * Riciclo su [mgt]                            *
      *                  *---------------------------------------------*
           go to     prn-let-seq-200.
       prn-let-seq-400.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data registrazione e numero  *
      *                  * protocollo in corso di trattamento          *
      *                  *---------------------------------------------*
           move      rf-mgt-dat-reg       to   w-reg-dat-reg          .
           move      rf-mgt-num-prt       to   w-reg-num-prt          .
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero progressivo in cor- *
      *                  * so di trattamento                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-reg-num-prg          .
      *                  *---------------------------------------------*
      *                  * Start su [mgr]                              *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATREG"             to   f-key                  .
           move      rf-mgt-dat-reg       to   rf-mgr-dat-reg         .
           move      rf-mgt-num-prt       to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start si aggiorna il flag di   *
      *                  * stampa giornale di [mgt] con rilascio del   *
      *                  * record e si ricicla a leggere il successi-  *
      *                  * vo [mgt]                                    *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to prn-let-seq-500.
      *                  *---------------------------------------------*
      *                  * Aggiornamento [mgt]                         *
      *                  *---------------------------------------------*
           perform   agg-fil-mgt-000      thru agg-fil-mgt-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo su [mgt]                            *
      *                  *---------------------------------------------*
           go to     prn-let-seq-200.
       prn-let-seq-500.
      *              *-------------------------------------------------*
      *              * Se non primo giro : lettura [mgr]               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale [mgr]                   *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  prn-let-seq-600.
      *                  *---------------------------------------------*
      *                  * Test se oltre il massimo                    *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-reg       not  = w-reg-dat-reg or
