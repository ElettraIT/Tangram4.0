       prn-fin-lr1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-fin-lr1-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *-----------------------------------------------------------*
       prn-liv-det-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-liv-det-010.
      *              *-------------------------------------------------*
      *              * Se numero linee residue insufficiente per una   *
      *              * ulteriore linea : intestazione foglio           *
      *              *-------------------------------------------------*
           if        p-res                >    zero
                     go to  prn-liv-det-100.
      *                  *---------------------------------------------*
      *                  * Intestazione foglio                         *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-100.
      *              *-------------------------------------------------*
      *              * Riga per sottoconto                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing con appoggio a destra           *
      *                      *-----------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      rf-mgr-cod-pdc       to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-adx-000      thru edt-pdc-adx-999        .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      40                   to   p-pos                  .
           move      w-edt-cod-pdc-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Descrizione sottoconto                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      50                   to   p-pos                  .
           move      rf-pdc-des-pdc       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Importo movimento                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      13                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "G"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           if        rf-mgr-dar-ave       =    "A"
                     move   115           to   p-pos
           else      move    95           to   p-pos                  .
           move      rf-mgr-imp-mov       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Riga per cliente o fornitore                    *
      *              *-------------------------------------------------*
           if        rf-mgr-tip-arc       =    "C"
                     go to prn-liv-det-200
           else if   rf-mgr-tip-arc       =    "F"
                     go to prn-liv-det-300
           else      go to prn-liv-det-900.
       prn-liv-det-200.
      *                  *---------------------------------------------*
      *                  * Riga per cliente                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se linee residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-res                >    zero
                     go to  prn-liv-det-220.
      *                          *-------------------------------------*
      *                          * Intestazione foglio                 *
      *                          *-------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-220.
      *                      *-----------------------------------------*
      *                      * Lettura archivio clienti                *
      *                      *-----------------------------------------*
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                      *-----------------------------------------*
      *                      * Codice cliente                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing codice cliente              *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-cli-cod-cli       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Preparazione stringa 'C/nnnnnnn'    *
      *                          *-------------------------------------*
           move      09                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "C/"                 to   w-all-str-cat (1)      .
           move      p-edt                to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                          *-------------------------------------*
      *                          * Allineamento a destra               *
      *                          *-------------------------------------*
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                          *-------------------------------------*
      *                          * Stampa codice                       *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      50                   to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Stampa ragione sociale              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      60                   to   p-pos                  .
           move      rf-cli-rag-soc       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     prn-liv-det-900.
       prn-liv-det-300.
      *                  *---------------------------------------------*
      *                  * Riga per fornitore                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se linee residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-res                >    zero
                     go to  prn-liv-det-320.
      *                          *-------------------------------------*
      *                          * Intestazione foglio                 *
      *                          *-------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-320.
      *                      *-----------------------------------------*
      *                      * Lettura archivio fornitori              *
      *                      *-----------------------------------------*
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                      *-----------------------------------------*
      *                      * Codice fornitore                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing codice fornitore            *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-fnt-cod-fnt       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Preparazione stringa 'F/nnnnnnn'    *
      *                          *-------------------------------------*
           move      09                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "F/"                 to   w-all-str-cat (1)      .
           move      p-edt                to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                          *-------------------------------------*
      *                          * Allineamento a destra               *
      *                          *-------------------------------------*
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                          *-------------------------------------*
      *                          * Stampa codice                       *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      50                   to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Stampa ragione sociale              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      60                   to   p-pos                  .
           move      rf-fnt-rag-soc       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Aggiornamento totali giornalieri                *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     add    rf-mgr-imp-mov
                                          to   w-wrk-tot-ave
           else      add    rf-mgr-imp-mov
                                          to   w-wrk-tot-dar          .
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo stampa          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se carta vidimata                           *
      *                  *---------------------------------------------*
           if        rr-snx-cvd           =    "S"
                     go to  int-pag-sta-050.
      *                  *---------------------------------------------*
      *                  * Intestazione se carta NON vidimata          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine                              *
      *                      *-----------------------------------------*
           perform   int-pag-sta-scb-000  thru int-pag-sta-scb-999    .
      *                      *-----------------------------------------*
      *                      * A stampa fincatura                      *
      *                      *-----------------------------------------*
           go to     int-pag-sta-600.
       int-pag-sta-050.
      *                  *---------------------------------------------*
      *                  * Intestazione se carta vidimata              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Avanzamento pagina                      *
      *                      *-----------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Test su esito                       *
      *                          *-------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to  int-pag-sta-999.
       int-pag-sta-200.
      *                      *-----------------------------------------*
      *                      * Posizionamento fisso per saltare le ri- *
      *                      * ghe di intestazione                     *
      *                      *-----------------------------------------*
           move      "VP"                 to   p-ope                  .
           move      06                   to   p-lnr                  .
           move      p-lnr                to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Incremento numero di intestazione       *
      *                      * stampe eseguita                         *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-num-int          .
      *                      *-----------------------------------------*
      *                      * Se questa non e' la prima intestazione  *
      *                      * stampa eseguita si omette in ogni caso  *
      *                      * la stampa della data di stampa effetti- *
      *                      * va                                      *
      *                      *-----------------------------------------*
           if        w-stp-num-int        not  = 1
                     go to int-pag-sta-600.
      *                      *-----------------------------------------*
      *                      * Se la stampa della data effettiva non   *
      *                      * deve essere eseguita la si omette       *
      *                      *-----------------------------------------*
           if        rr-snx-dse           not  = "S"
                     go to int-pag-sta-600.
      *                      *-----------------------------------------*
      *                      * Se la data effettiva di stampa e' a ze- *
      *                      * ro : non la si esegue                   *
      *                      *-----------------------------------------*
           if        rr-dat-sef           =    zero
                     go to int-pag-sta-600.
       int-pag-sta-400.
      *              *-------------------------------------------------*
      *              * Stampa date effettiva di stampa                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Literal                                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      38                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      48                   to   p-pos                  .
           move      "== STAMPA ESEGUITA IN DATA          =="
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      p-lnr                to   p-lin                  .
           move      75                   to   p-pos                  .
           move      rr-dat-sef           to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Posizionamento verticale di separazione         *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           move      p-lnr                to   p-lin                  .
           add       2                    to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-600.
      *              *-------------------------------------------------*
      *              * Linea di fincatura                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Literal 'Data reg.'                         *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      01                   to   p-pos                  .
           move      "Data reg."          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal 'Data doc.'                         *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      12                   to   p-pos                  .
           move      "Data doc."          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal 'Num. doc.'                         *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      24                   to   p-pos                  .
           move      "Num. doc."          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal 'Descrizione operazione'            *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      22                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      35                   to   p-pos                  .
           move      "Descrizione operazione"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal 'Dare'                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      109                  to   p-pos                  .
           move      "Dare"               to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal 'Avere'                             *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      128                  to   p-pos                  .
           move      "Avere"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Posizionamento fisso per lasciare una in-   *
      *                  * terlinea di separazione                     *
      *                  *---------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *                                                           *
      *    * Intestazione carta non vidimata                           *
      *    *-----------------------------------------------------------*
       int-pag-sta-scb-000.
      *              *-------------------------------------------------*
      *              * Avanzamento pagina                              *
      *              *-------------------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Se errore grave di i-o su stampa si esce    *
      *                  * con status di errore                        *
      *                  *---------------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to int-pag-sta-scb-999.
       int-pag-sta-scb-100.
      *              *-------------------------------------------------*
      *              * Preparazione numero pagina                      *
      *              *-------------------------------------------------*
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       rr-ult-pst           to   w-cnt-tit-num-pag      .
       int-pag-sta-scb-200.
      *              *-------------------------------------------------*
      *              * Linea di '='                                    *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      p-sel-als-sel        to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      all   "="            to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-scb-300.
      *              *-------------------------------------------------*
      *              * Prima linea intestazione                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ragione sociale azienda                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-azi-rag-soc        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Determinazione posizione iniziale per nume- *
      *                  * ro pagina                                   *
      *                  *---------------------------------------------*
           subtract  14                   from p-sel-als-sel
                                        giving p-pos                  .
           if        w-cnt-tit-num-pag    <    10
                     add   4              to   p-pos
           else if   w-cnt-tit-num-pag    <    100
                     add   3              to   p-pos
           else if   w-cnt-tit-num-pag    <    1000
                     add   2              to   p-pos
           else if   w-cnt-tit-num-pag    <    10000
                     add   1              to   p-pos                  .
      *                  *---------------------------------------------*
      *                  * Literal 'Pag.'                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      "Pag."               to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Numero pagina                               *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        w-cnt-tit-num-pag    <    10
                     move  1              to   p-car
           else if   w-cnt-tit-num-pag    <    100
                     move  2              to   p-car
           else if   w-cnt-tit-num-pag    <    1000
                     move  3              to   p-car
           else if   w-cnt-tit-num-pag    <    10000
                     move  4              to   p-car
           else      move  5              to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           add       5                    to   p-pos                  .
           move      w-cnt-tit-num-pag    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal '/'                                 *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           subtract  04                   from p-sel-als-sel
                                        giving p-pos                  .
           move      "/"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Secolo - anno                               *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           subtract  03                   from p-sel-als-sel
                                        giving p-pos                  .
           move      w-wrk-saa-ini        to   p-num                  .
           add       1900                 to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-scb-400.
      *              *-------------------------------------------------*
      *              * Seconda linea intestazione                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Indirizzo azienda                           *
      *                  *---------------------------------------------*
