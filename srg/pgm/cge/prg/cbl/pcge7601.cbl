      *    * Riepilogo - castelletto Iva                               *
      *    *-----------------------------------------------------------*
       emi-fil-xml-rie-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cst-iva-ctr      .
       emi-fil-xml-rie-200.
           add       1                    to   w-det-cst-iva-ctr      .
           if        w-det-cst-iva-ctr    >    6
                     go to emi-fil-xml-rie-900.
           if        srt-cod-iva
                    (w-det-cst-iva-ctr)   =    zero
                     go to emi-fil-xml-rie-200.
      *              *-------------------------------------------------*
      *              * Test se codice Iva da escludere dall'elenco     *
      *              *-------------------------------------------------*
           if        srt-snx-lqp
                    (w-det-cst-iva-ctr)   =    "N"
                     go to emi-fil-xml-rie-200.
       emi-fil-xml-rie-300.
      *              *-------------------------------------------------*
      *              * Apertura tag 'DatiRiepilogo'                    *
      *              *-------------------------------------------------*
           move      "DatiRiepilogo"      to   w-sta-emi-xml-pmt      .
           move      "A"                  to   w-sta-emi-xml-ope      .
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-rie-400.
      *              *-------------------------------------------------*
      *              * Valore imponibile in campo di trattamento       *
      *              *-------------------------------------------------*
           move      srt-ibl-iva
                    (w-det-cst-iva-ctr)   to   w-det-trt-iva-ibl      .
      *              *-------------------------------------------------*
      *              * Eccezione per Omaggi                            *
      *              *                                                 *
      *              * Si trattano come fatture normali, calcolando al *
      *              * volo l'imponibile tramite la formula:           *
      *              *                                                 *
      *              * Imponibile = (Imposta / Aliquota) * 100         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul codice Iva                         *
      *                  *---------------------------------------------*
           move      srt-cod-iva
                    (w-det-cst-iva-ctr)   to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    not  = 9
                     go to emi-fil-xml-rie-420.
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
           move      srt-imp-iva
                    (w-det-cst-iva-ctr)   to   w-det-trt-iva-imp      .
      *                  *---------------------------------------------*
      *                  * Scorporo aliquota dal codice                *
      *                  *---------------------------------------------*
           subtract  900                  from srt-cod-iva
                                              (w-det-cst-iva-ctr)     .
      *
           move      srt-cod-iva
                    (w-det-cst-iva-ctr)   to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Calcolo Imponibile                          *
      *                  *---------------------------------------------*
           divide    w-edt-iva-cie        into w-det-trt-iva-imp
                                        giving w-det-trt-iva-w01      .
           multiply  100                  by   w-det-trt-iva-w01      .
           move      w-det-trt-iva-w01    to   w-det-trt-iva-ibl      .
       emi-fil-xml-rie-420.
      *              *-------------------------------------------------*
      *              * Emissione tag 'ImponibileImporto'               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-det-trt-iva-ibl    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Preparazione tag                            *
      *                  *---------------------------------------------*
           move      "ImponibileImporto"  to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      p-edt                to   w-sta-emi-xml-val      .
      *                  *---------------------------------------------*
      *                  * Sostituzione virgole con punti              *
      *                  *---------------------------------------------*
           inspect   w-sta-emi-xml-val
                                replacing all  ","
                                          by   "."                    .
      *                  *---------------------------------------------*
      *                  * Se a zero                                   *
      *                  *---------------------------------------------*
           if        w-det-trt-iva-ibl    =    zero
                     move  "0.00"         to   w-sta-emi-xml-val      .
      *                  *---------------------------------------------*
      *                  * Completamento tag                           *
      *                  *---------------------------------------------*
           move      "+"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-rie-500.
      *              *-------------------------------------------------*
      *              * Apertura tag 'DatiIVA'                          *
      *              *-------------------------------------------------*
           move      "DatiIVA"            to   w-sta-emi-xml-pmt      .
           move      "A"                  to   w-sta-emi-xml-ope      .
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *              *-------------------------------------------------*
      *              * Emissione tag 'Imposta'                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      srt-imp-iva
                    (w-det-cst-iva-ctr)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *
           move      "Imposta"            to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      p-edt                to   w-sta-emi-xml-val      .
      *
           inspect   w-sta-emi-xml-val
                                replacing all  ","
                                          by   "."                    .
      *
           if        srt-imp-iva
                    (w-det-cst-iva-ctr)   =    zero
                     move  "0.00"         to   w-sta-emi-xml-val      .
      *
           move      "+"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
      *              *-------------------------------------------------*
      *              * Emissione tag 'Aliquota'                        *
      *              *-------------------------------------------------*
           perform   emi-fil-xml-ali-000  thru emi-fil-xml-ali-999    .
      *              *-------------------------------------------------*
      *              * Chiusura tag 'DatiIVA'                          *
      *              *-------------------------------------------------*
           move      "DatiIVA"            to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-rie-520.
      *              *-------------------------------------------------*
      *              * Emissione tag 'Natura'                          *
      *              *                                                 *
      *              * N.B.: vedi tabella contenuta in 'zci'           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura fatture CEE fornitori   *
      *                  *                                             *
      *                  * da verificare ___ ??? ___                   *
      *                  *---------------------------------------------*
           if        w-rot-l02-tip-arc    =    "F" and
                     srt-tip-iva          =    "E" and
                     srt-tip-doc          =    "F" and
                     srt-cod-iva
                    (w-det-cst-iva-ctr)   <    99
______*              move  "N6.9"         to   w-det-edt-val-nat
                     move  "N6"           to   w-det-edt-val-nat
                     go to emi-fil-xml-rie-580.      
