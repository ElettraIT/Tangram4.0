      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Preparazione del tipo archivio in base alle     *
      *              * richieste                                       *
      *              *-------------------------------------------------*
           move      "C"                  to   w-stp-srt-tip          .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore archivi esclusi       *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-arc-esc-ctr      .
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Preparazione delle date per la scansione        *
      *              *-------------------------------------------------*
           move      rr-dat-ini           to   w-det-dat-srt-min      .
           move      rr-dat-fin           to   w-det-dat-srt-max      .
      *              *-------------------------------------------------*
      *              * Preparazione file di appoggio per le sigle      *
      *              * numerazione fatture di vendita                  *
      *              *                                                 *
      *              * N.B.: resa necessaria dalla mancanza della      *
      *              *       sigla numerazione nel file [mgi]          *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-sgl-000  thru stp-srt-inp-sgl-999    .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su file [mgi]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATDOC    "         to   f-key                  .
           move      w-stp-srt-tip        to   rf-mgi-tip-rec         .
           move      w-det-dat-srt-min    to   rf-mgi-dat-reg         .
           move      zero                 to   rf-mgi-cod-num         .
           move      zero                 to   rf-mgi-prt-iva         .
           move      zero                 to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [mgi]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-mgi-tip-rec       not  = w-stp-srt-tip   or
                     rf-mgi-dat-reg       >    w-det-dat-srt-max
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se movimento gia' inviato a SDI        *
      *                  *                                             *
      *                  * Si utilizza il secondo carattere di         *
      *                  * 'alx-exp' scritto eventualmente da          *
      *                  * 'pscf420d' o 'pscf420z'                     *
      *                  *---------------------------------------------*
           if        rf-mgi-alx-exp
                    (02 : 01)             =    "#"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento iva                  *
      *                  *                                             *
      *                  * Attualmente considerati                     *
      *                  * -----------------------                     *
      *                  *                                             *
      *                  * Tutti, ad esclusione dei Corrispettivi      *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-iva       =    "3"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su flag di regime fiscale particolare  *
      *                  *---------------------------------------------*
           if        rf-mgi-flg-rfp       =    "E"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su bolle doganali                      *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-iva       =    "6"
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Letture archivi                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        w-stp-srt-tip        =    "C"
                     go to stp-srt-inp-520
           else if   w-stp-srt-tip        =    "F"
                     go to stp-srt-inp-540.
       stp-srt-inp-520.
      *                  *---------------------------------------------*
      *                  * Lettura record [cli]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-mgi-cod-arc       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-cli-rag-soc
                     move  spaces         to   rf-cli-rag-key         .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-560.
       stp-srt-inp-540.
      *                  *---------------------------------------------*
      *                  * Test se Bolle Doganali                      *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-iva       not  = "6"
                     move  zero           to   w-det-fnt-bdg-cod
                     go to stp-srt-inp-542.
      *                  *---------------------------------------------*
      *                  * Eventuale fornitore reale Bolle Doganali    *
      *                  *---------------------------------------------*
           if        rf-mgi-cod-fbd       not  numeric
                     move  zero           to   w-det-fnt-bdg-cod
           else      move  rf-mgi-cod-fbd to   w-det-fnt-bdg-cod      .
       stp-srt-inp-542.
      *                  *---------------------------------------------*
      *                  * Lettura record [fnt]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
      *
           if        w-det-fnt-bdg-cod    not  = zero
                     move  w-det-fnt-bdg-cod
                                          to   rf-fnt-cod-fnt
           else      move  rf-mgi-cod-arc to   rf-fnt-cod-fnt         .
      *
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-fnt-rag-soc
                     move  spaces         to   rf-fnt-rag-key         .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-560.
       stp-srt-inp-560.
      *                  *---------------------------------------------*
      *                  * Selezioni su anagrafiche lette              *
      *                  *---------------------------------------------*
           if        w-stp-srt-tip        =    "C"
                     go to stp-srt-inp-570
           else      go to stp-srt-inp-580.
       stp-srt-inp-570.
      *                  *---------------------------------------------*
      *                  * Clienti                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice nazione                  *
      *                      *-----------------------------------------*
           if        rf-cli-cod-naz       =    "IT "
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test su Si/no in elenco                 *
      *                      *-----------------------------------------*
           if        rf-cli-snx-a13       not  = "N"
                     go to stp-srt-inp-600.
      *                      *-----------------------------------------*
      *                      * Test se codice destinatario 'XXXXXXX'   *
      *                      * che significa che la fattura e' gia'    *
      *                      * stata inviata tramite SDI               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record [dcc]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                          *-------------------------------------*
      *                          * Lettura record [dcc]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-mgi-cod-arc       to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                          *-------------------------------------*
      *                          * Test su codice SDI                  *
      *                          *-------------------------------------*
           if        rf-dcc-idn-em2       =    "XXXXXXX"
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test se codice archivio gia' trattato   *
      *                      *-----------------------------------------*
           set       w-stp-arc-esc-inx    to   1                      .
           search    w-stp-arc-esc-ele
                     when    w-stp-arc-esc-tip
                            (w-stp-arc-esc-inx)
                                          =    w-stp-srt-tip and
                             w-stp-arc-esc-cod
                            (w-stp-arc-esc-inx)
                                          =    rf-mgi-cod-arc
                     go to   stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Aggiornamento tabella                   *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-arc-esc-ctr      .
           move      w-stp-srt-tip        to   w-stp-arc-esc-tip
                                              (w-stp-arc-esc-ctr)     .
           move      rf-mgi-cod-arc       to   w-stp-arc-esc-cod
                                              (w-stp-arc-esc-ctr)     .
      *                      *-----------------------------------------*
      *                      * Editing codice archivio                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-mgi-cod-arc       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (2)      .
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Il Cliente :"       to   w-all-str-cat (1)      .
           move      " - risulta escluso" to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Scrittura in rullino messaggi           *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      w-all-str-alf        to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-580.
      *                  *---------------------------------------------*
      *                  * Fornitori                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice nazione                  *
      *                      *-----------------------------------------*
           if        rf-fnt-cod-naz       =    "IT "
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test su Si/no in elenco                 *
      *                      *-----------------------------------------*
           if        rf-fnt-snx-a13       not  = "N"
                     go to stp-srt-inp-600.
      *                      *-----------------------------------------*
      *                      * Test se codice archivio gia' trattato   *
      *                      *-----------------------------------------*
           set       w-stp-arc-esc-inx    to   1                      .
           search    w-stp-arc-esc-ele
                     when    w-stp-arc-esc-tip
                            (w-stp-arc-esc-inx)
                                          =    w-stp-srt-tip and
                             w-stp-arc-esc-cod
                            (w-stp-arc-esc-inx)
                                          =    rf-mgi-cod-arc
                     go to   stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Aggiornamento tabella                   *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-arc-esc-ctr      .
           move      w-stp-srt-tip        to   w-stp-arc-esc-tip
                                              (w-stp-arc-esc-ctr)     .
           move      rf-mgi-cod-arc       to   w-stp-arc-esc-cod
                                              (w-stp-arc-esc-ctr)     .
      *                      *-----------------------------------------*
      *                      * Editing codice archivio                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-mgi-cod-arc       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (2)      .
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Il Fornitore :"     to   w-all-str-cat (1)      .
           move      " - risulta escluso" to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
