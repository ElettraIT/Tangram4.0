           perform   all-str-csb-000      thru all-str-csb-999        .
      *              *-------------------------------------------------*
      *              * Scrittura in rullino messaggi                   *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      w-all-str-alf        to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *              *-------------------------------------------------*
      *              * Separatore                                      *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      all "*"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       emi-fil-xml-erm-100.
      *              *-------------------------------------------------*
      *              * Start su file [kk1]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
           move      zero                 to   kk1-ctr-prg            .
      *                  *---------------------------------------------*
      *                  * Operazione di Start                         *
      *                  *---------------------------------------------*
           start     kk1    key not less
                            kk1-key
                            invalid key
                            go to emi-fil-xml-erm-900.
       emi-fil-xml-erm-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file di appoggio [kk1]      *
      *              *-------------------------------------------------*
           read      kk1    next
                            with no lock
                            at end
                            go to emi-fil-xml-erm-900.
       emi-fil-xml-erm-600.
      *              *-------------------------------------------------*
      *              * Scrittura in rullino messaggi                   *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      kk1-str-err          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       emi-fil-xml-erm-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     emi-fil-xml-erm-200.
       emi-fil-xml-erm-900.
      *              *-------------------------------------------------*
      *              * Separatore                                      *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      all "*"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *              *-------------------------------------------------*
      *              * Chiusura messaggi di errore                     *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "(E' possibile stampare queste informazioni tramite
      -              " il tasto di stampa)"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
