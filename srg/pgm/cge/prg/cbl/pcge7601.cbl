      *                  *---------------------------------------------*
      *                  * Test se da emettere                         *
      *                  *---------------------------------------------*
           if        w-det-edt-cod-fis    =    spaces
                     go to emi-fil-xml-idf-500.
           if        w-det-edt-cod-flg    =    spaces
                     go to emi-fil-xml-idf-500.
      *                  *---------------------------------------------*
      *                  * Emissione tag                               *
      *                  *---------------------------------------------*
           move      "CodiceFiscale"      to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      w-det-edt-cod-fis    to   w-sta-emi-xml-val      .
           move      "+"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-idf-500.
      *              *-------------------------------------------------*
      *              * Chiusura tag 'IdentificativiFiscali'            *
      *              *-------------------------------------------------*
           move      "IdentificativiFiscali"
                                          to   w-sta-emi-xml-pmt      .
           move      "C"                  to   w-sta-emi-xml-ope      .
           move      "-"                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       emi-fil-xml-idf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-fil-xml-idf-999.
       emi-fil-xml-idf-999.
           exit.

