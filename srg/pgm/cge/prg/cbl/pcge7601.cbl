                                          to   w-err-ana-cof-err      .
           perform   emi-fil-xml-msg-000  thru emi-fil-xml-msg-999    .
       emi-fil-xml-idf-120.
      *                      *-----------------------------------------*
      *                      * Editing Partita Iva                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      srt-prt-iva          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-cod-fis      .
      *                      *-----------------------------------------*
      *                      * A emissione TAG                         *
      *                      *-----------------------------------------*
           go to     emi-fil-xml-idf-300.
       emi-fil-xml-idf-130.
      *                      *-----------------------------------------*
      *                      * Se assente Partita Iva                  *
      *                      *-----------------------------------------*
           if        srt-cod-fis          not  = spaces
                     move  srt-cod-fis    to   w-det-edt-cod-fis
                     move  "#"            to   w-det-edt-cod-flg
                     go to emi-fil-xml-idf-300.
      *                      *-----------------------------------------*
      *                      * A errore                                *
      *                      *-----------------------------------------*
           go to     emi-fil-xml-idf-200.
       emi-fil-xml-idf-150.
      *                  *---------------------------------------------*
      *                  * Estero                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se codice fiscale presente         *
      *                      *-----------------------------------------*
           if        srt-cod-fis          =    spaces
                     go to emi-fil-xml-idf-200.
      *                      *-----------------------------------------*
      *                      * Codice fiscale                          *
      *                      *-----------------------------------------*
           move      srt-cod-fis          to   w-det-edt-cod-fis      .                  
      *                      *-----------------------------------------*
      *                      * A emissione TAG                         *
      *                      *-----------------------------------------*
           go to     emi-fil-xml-idf-300.
       emi-fil-xml-idf-200.
      *                  *---------------------------------------------*
      *                  * Segnalazione errore                         *
      *                  *---------------------------------------------*
           move      w-rot-l02-tip-arc    to   w-err-ana-cof-tip      .
           move      srt-cod-arc          to   w-err-ana-cof-cod      .
           move      srt-rag-soc          to   w-err-ana-cof-rag      .
           move      "manca il codice Fiscale!      "
                                          to   w-err-ana-cof-err      .
           perform   emi-fil-xml-msg-000  thru emi-fil-xml-msg-999    .
      *                  *---------------------------------------------*
      *                  * Si prosegue                                 *
      *                  *---------------------------------------------*
           go to     emi-fil-xml-idf-300.
       emi-fil-xml-idf-300.
      *                  *---------------------------------------------*
      *                  * Emissione tag                               *
      *                  *---------------------------------------------*
           move      "IdCodice"           to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      w-det-edt-cod-fis    to   w-sta-emi-xml-val      .                  
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
