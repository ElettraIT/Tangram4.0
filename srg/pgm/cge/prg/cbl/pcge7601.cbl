      *                  *---------------------------------------------*
           write     kk2-rec                                          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-fil-csv-900.
       emi-fil-csv-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-fil-csv-999.
       emi-fil-csv-999.
           exit.

      *    *===========================================================*
      *    * Emissione file sequenziale in formato CSV                 *
      *    *                                                           *
      *    * Subroutine di emissione file per tipo archivio            *
      *    *-----------------------------------------------------------*
       emi-fil-csv-arc-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione [ada]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Lettura [ada] Sede                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Progressivo univoco                         *
      *                  *                                             *
      *                  * Il progressivo univoco del file e' rappre-  *
      *                  * sentato da una stringa alfanumerica di lun- *
      *                  * ghezza massima di 5 caratteri e con valori  *
      *                  * ammessi [a-z], [A-Z], [0-9]                 *
      *                  *                                             *
      *                  * Attualmente e' composta da:                 *
      *                  *                                             *
      *                  * - Tipo di fatture          : E o R          *
      *                  * - Mese dichiarazione       : 99             *
      *                  * - Anno dichiarazione       : 99             *
      *                  *                                             *
      *                  * Esempio: E0119 = Fatt. Emesse gennaio 2019  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing periodo dichiarazione           *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      rr-prd-tpr-inx       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-val-mes      .
      *                      *-----------------------------------------*
      *                      * Editing anno dichiarazione              *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      rr-dat-ini
                    (02 : 02)             to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-val-ann      .
      *                  *---------------------------------------------*
      *                  * Composizione identificatore univoco         *
      *                  *---------------------------------------------*
           move      05                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
      *
           if        w-sta-emi-csv-tip    =    "C"
                     move  "E"            to   w-all-str-cat (1)
           else      move  "R"            to   w-all-str-cat (1)      .
      *
           move      w-det-edt-val-ann    to   w-all-str-cat (2)      .
           move      rr-prd-tpr-rng       to   w-all-str-cat (3)      .
           move      w-det-edt-val-mes    to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-det-edt-val-ide      .
      *                  *---------------------------------------------*
      *                  * Composizione nome file                      *
      *                  *---------------------------------------------*
           move      30                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "IT"                 to   w-all-str-cat (1)      .
           move      rf-ada-cod-fis       to   w-all-str-cat (2)      .
           move      "_DF_"               to   w-all-str-cat (3)      .
           move      w-det-edt-val-ide    to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Apertura del file in output                 *
      *                  *---------------------------------------------*
           move      w-all-str-alf        to   w-det-pth-fso-nam      .
           move      "csv"                to   w-det-pth-fso-ext      .
           perform   det-pth-fso-000      thru det-pth-fso-999        .
      *                  *---------------------------------------------*
      *                  * Apertura del file in output                 *
      *                  *---------------------------------------------*
           move      "OO"                 to   g-ope                  .
           move      "seq "               to   g-nam                  .
           move      w-det-pth-fso-pth    to   g-pat                  .
           call      "swd/mod/prg/obj/mcvout"
                                         using g                      .
       emi-fil-csv-arc-100.
      *              *-------------------------------------------------*
      *              * Start su file [kk2]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore di comodo         *
      *                  *---------------------------------------------*
           move      zero                 to   w-sta-emi-csv-ctw      .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
           move      zero                 to   kk2-ctr-prg            .
      *                  *---------------------------------------------*
      *                  * Operazione di Start                         *
      *                  *---------------------------------------------*
           start     kk2    key not less
                            kk2-key
                            invalid key
                            go to emi-fil-csv-arc-900.
       emi-fil-csv-arc-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file di appoggio [kk2]      *
      *              *-------------------------------------------------*
           read      kk2    next
                            with no lock
                            at end
                            go to emi-fil-csv-arc-900.
       emi-fil-csv-arc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo archivio                      *
      *              *-------------------------------------------------*
           if        kk2-tip-rec          not  = w-sta-emi-csv-tip
                     go to emi-fil-csv-arc-200.
      *              *-------------------------------------------------*
      *              * Incremento contatore di comodo                  *
      *              *-------------------------------------------------*
           add       1                    to   w-sta-emi-csv-ctw      .
       emi-fil-csv-arc-400.
      *              *-------------------------------------------------*
      *              * Fincatura iniziale                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da emettere                         *
      *                  *---------------------------------------------*
           if        w-sta-emi-csv-ctw    >    1
                     go to emi-fil-csv-arc-500.
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           perform   emi-fil-csv-fin-000  thru emi-fil-csv-fin-999    .
       emi-fil-csv-arc-500.
      *              *-------------------------------------------------*
      *              * Scrittura su file                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Pulizia preliminare                         *
      *                  *---------------------------------------------*
           move      spaces               to   g-rec                  .
      *                  *---------------------------------------------*
      *                  * Recupero record 'srt-rec'                   *
      *                  *---------------------------------------------*
           move      kk2-srt-rec          to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione record                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Separatori dati fissi                   *
      *                      *-----------------------------------------*
           move      w-det-fin-rig-pvg    to   w-out-doc-sep-001
                                               w-out-doc-sep-002
                                               w-out-doc-sep-003
                                               w-out-doc-sep-004
                                               w-out-doc-sep-005
                                               w-out-doc-sep-006
                                               w-out-doc-sep-007
                                               w-out-doc-sep-008
                                               w-out-doc-sep-009
