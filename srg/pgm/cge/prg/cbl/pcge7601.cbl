      *                  *---------------------------------------------*
           move      1                    to   w-det-cst-iva-ctr      .
      *
           if        srt-cod-iva
                    (w-det-cst-iva-ctr)   =    zero
                     go to  prn-liv-det-300.
      *
           perform   ibl-cod-imp-000      thru ibl-cod-imp-999        .
       prn-liv-det-300.
      *                  *---------------------------------------------*
      *                  * Totale documento                            *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      10                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      118                  to   p-pos                  .
           move      srt-tot-doc          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Seconda riga di dettaglio                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Griglia vuota per il dettaglio              *
      *                  *---------------------------------------------*
           perform   gri-vuo-det-000      thru gri-vuo-det-999        .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      13                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      07                   to   p-pos                  .
           move      srt-num-doc          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Partita iva                                 *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9B"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      27                   to   p-pos                  .
           move      srt-prt-iva          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Codice fiscale                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      39                   to   p-pos                  .
           move      srt-cod-fis          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Tipo documento da causale contabile         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [mgt]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [mgt]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DATREG"             to   f-key                  .
           move      srt-dat-reg          to   rf-mgt-dat-reg         .
           move      srt-num-prt          to   rf-mgt-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgt                 .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-mgt-des-cau         .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      59                   to   p-pos                  .
           move      rf-mgt-des-cau       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Imponibile, codice iva, imposta             *
      *                  *---------------------------------------------*
           move      2                    to   w-det-cst-iva-ctr      .
      *
           if        srt-cod-iva
                    (w-det-cst-iva-ctr)   =    zero
                     go to  prn-liv-det-500.
      *
           perform   ibl-cod-imp-000      thru ibl-cod-imp-999        .
       prn-liv-det-500.
      *              *-------------------------------------------------*
      *              * Successive eventuali righe di dettaglio         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo 3..6                                  *
      *                  *---------------------------------------------*
           move      2                    to   w-det-cst-iva-ctr      .
       prn-liv-det-520.
           add       1                    to   w-det-cst-iva-ctr      .
           if        w-det-cst-iva-ctr    >    6
                     go to prn-liv-det-800.
      *                  *---------------------------------------------*
      *                  * Test su codice Iva                          *
      *                  *---------------------------------------------*
           if        srt-cod-iva
                    (w-det-cst-iva-ctr)   =    zero
                     go to  prn-liv-det-520.
      *                  *---------------------------------------------*
      *                  * Test se righe residue sufficienti           *
      *                  *---------------------------------------------*
           if        p-res                >    2
                     go to  prn-liv-det-540.
      *                  *---------------------------------------------*
      *                  * Reintestazione                              *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  prn-liv-det-999.
       prn-liv-det-540.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Griglia vuota per il dettaglio              *
      *                  *---------------------------------------------*
           perform   gri-vuo-det-000      thru gri-vuo-det-999        .
      *                  *---------------------------------------------*
      *                  * Imponibile, codice iva, imposta             *
      *                  *---------------------------------------------*
           perform   ibl-cod-imp-000      thru ibl-cod-imp-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     prn-liv-det-520.
       prn-liv-det-800.
      *              *-------------------------------------------------*
      *              * Dettaglio per emissione sequenziale XML         *
      *              *-------------------------------------------------*
           move      "DE"                 to   w-out-gen-tip-ope      .
           perform   emi-fil-xml-000      thru emi-fil-xml-999        .
      *              *-------------------------------------------------*
      *              * Dettaglio per emissione sequenziale CSV         *
      *              *-------------------------------------------------*
           move      "DE"                 to   w-sta-emi-csv-ope      .
           perform   emi-fil-csv-000      thru emi-fil-csv-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento file [mgi]                        *
      *              *-------------------------------------------------*
           perform   agg-fil-mgi-000      thru agg-fil-mgi-999        .
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Linea di fincatura                              *
      *              *-------------------------------------------------*
           perform   int-lin-sep-000      thru int-lin-sep-999        .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *                                                           *
      *    * Subroutine di aggiornamento totali mensili                *
      *    *-----------------------------------------------------------*
       prn-liv-det-agg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare totali              *
      *              *-------------------------------------------------*
           move      zero                 to   w-tot-ibl-fat          .
           move      zero                 to   w-tot-imp-fat          .
           move      zero                 to   w-tot-ibl-acq          .
           move      zero                 to   w-tot-imp-acq          .
       prn-liv-det-agg-100.
      *              *-------------------------------------------------*
      *              * Ciclo 1..6                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-tot-iva-ele-ctr      .
       prn-liv-det-agg-200.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-tot-iva-ele-ctr      .
      *                  *---------------------------------------------*
      *                  * Test sul contatore                          *
      *                  *---------------------------------------------*
           if        w-tot-iva-ele-ctr    >    6
                     go to prn-liv-det-agg-900.
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero : riciclo castelletto  *
      *                  *---------------------------------------------*
           if        srt-cod-iva
                    (w-tot-iva-ele-ctr)   =    zero
                     go to prn-liv-det-agg-200.
      *                  *---------------------------------------------*
      *                  * Esclusione Fuori campo Iva                  *
      *                  *---------------------------------------------*
           move      srt-cod-iva
                    (w-tot-iva-ele-ctr)   to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    6
                     go to prn-liv-det-agg-200.
      *                  *---------------------------------------------*
      *                  * Esclusione art.15                           *
      *                  *---------------------------------------------*
           if        srt-cod-iva
                    (w-tot-iva-ele-ctr)   =    00515
                     go to prn-liv-det-agg-200.
       prn-liv-det-agg-300.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo record      *
      *                  *---------------------------------------------*
           if        w-rot-l02-tip-arc    =    "C"
                     go to prn-liv-det-agg-400
           else if   w-rot-l02-tip-arc    =    "F"
                     go to prn-liv-det-agg-600
           else      go to prn-liv-det-agg-900.
       prn-liv-det-agg-400.
      *              *-------------------------------------------------*
      *              * Tipo record : Cliente                           *
      *              *-------------------------------------------------*
       prn-liv-det-agg-410.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo iva         *
      *                  *---------------------------------------------*
           if        srt-tip-iva          =    "1" or
                     srt-tip-iva          =    "A"
                     go to prn-liv-det-agg-420
           else if   srt-tip-iva          =    "2" or
                     srt-tip-iva          =    "B"
                     go to prn-liv-det-agg-440
           else      go to prn-liv-det-agg-800.
       prn-liv-det-agg-420.
      *                  *=============================================*
      *                  * Tipo iva : Dare clienti                     *
      *                  *---------------------------------------------*
           add       srt-ibl-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-ibl-fat          .
      *                  *---------------------------------------------*
      *                  * Test su flag di regime particolare per      *
      *                  * Split Payement                              *
      *                  *---------------------------------------------*
           if        srt-flg-rfp          =    "S"
                     go to prn-liv-det-agg-430.
           add       srt-imp-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-imp-fat          .
       prn-liv-det-agg-430.
      *                  *---------------------------------------------*
      *                  * A riciclo su castelletto Iva                *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-800.
       prn-liv-det-agg-440.
      *                  *=============================================*
      *                  * Tipo iva : Avere clienti                    *
      *                  *---------------------------------------------*
           subtract  srt-ibl-iva
                    (w-tot-iva-ele-ctr)   from w-tot-ibl-fat          .
      *                  *---------------------------------------------*
      *                  * Test su flag di regime particolare per      *
      *                  * Split Payement                              *
      *                  *---------------------------------------------*
           if        srt-flg-rfp          =    "S"
                     go to prn-liv-det-agg-450.
           subtract  srt-imp-iva
                    (w-tot-iva-ele-ctr)   from w-tot-imp-fat          .
       prn-liv-det-agg-450.
      *                  *---------------------------------------------*
      *                  * A riciclo su castelletto Iva                *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-800.
       prn-liv-det-agg-600.
      *              *-------------------------------------------------*
      *              * Tipo record : Fornitore                         *
      *              *-------------------------------------------------*
       prn-liv-det-agg-610.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo iva         *
      *                  *---------------------------------------------*
           if        srt-tip-iva          =    "5" or
                     srt-tip-iva          =    "6"
                     go to prn-liv-det-agg-620
           else if   srt-tip-iva          =    "4"
                     go to prn-liv-det-agg-640
           else if   srt-tip-iva          =    "E"
                     go to prn-liv-det-agg-660
           else if   srt-tip-iva          =    "D"
                     go to prn-liv-det-agg-680
           else      go to prn-liv-det-agg-800.
       prn-liv-det-agg-620.
      *                  *=============================================*
      *                  * Tipo iva : Avere fornitori Italia           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento imponibile                *
      *                      *-----------------------------------------*
           add       srt-ibl-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-ibl-acq          .
      *                      *-----------------------------------------*
      *                      * Se Iva indetraibile                     *
      *                      *-----------------------------------------*
           move      srt-cod-iva
                    (w-tot-iva-ele-ctr)   to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    7
                     go to prn-liv-det-agg-624.
      *                      *-----------------------------------------*
      *                      * Aggiornamento Imposta                   *
      *                      *-----------------------------------------*
           add       srt-imp-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-imp-acq          .
       prn-liv-det-agg-624.
      *                      *-----------------------------------------*
      *                      * Se Reverse Charge : decremento totali   *
      *                      *                     vendite             *
      *                      *                                         *
      *                      * N.B.: non si esegue, in quanto le auto- *
      *                      *       fatture vengono gia' escluse tra- *
      *                      *       mite l'inibizione del Cliente     *
      *                      *       relativo                          *
      *                      *-----------------------------------------*
           go to     prn-liv-det-agg-628.
      *
           if        srt-flg-rfp          not  = "R"
                     go to prn-liv-det-agg-628.
           subtract  srt-ibl-iva
                    (w-tot-iva-ele-ctr)   from w-tot-ibl-fat          .
           subtract  srt-imp-iva
                    (w-tot-iva-ele-ctr)   from w-tot-imp-fat          .
       prn-liv-det-agg-628.
      *                  *---------------------------------------------*
      *                  * A riciclo su castelletto Iva                *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-800.
       prn-liv-det-agg-640.
      *                  *=============================================*
      *                  * Tipo iva : Dare fornitori Italia            *
      *                  *---------------------------------------------*
           subtract  srt-ibl-iva
                    (w-tot-iva-ele-ctr)   from w-tot-ibl-acq          .
           subtract  srt-imp-iva
                    (w-tot-iva-ele-ctr)   from w-tot-imp-acq          .
      *                  *---------------------------------------------*
      *                  * Se Reverse Charge : incremento totali       *
      *                  * vendite                                     *
      *                  *                                             *
      *                  * N.B.: non si esegue, in quanto le autofat-  *
      *                  *       ture vengono gia' escluse tramite     *
      *                  *       l'inibizione del Cliente Autofatture  *
      *                  *---------------------------------------------*
           if        srt-flg-rfp          not  = "R"
                     go to prn-liv-det-agg-648.
           go to     prn-liv-det-agg-648.
      *
           add       srt-ibl-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-ibl-fat          .
           add       srt-imp-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-imp-fat          .
       prn-liv-det-agg-648.
      *                  *---------------------------------------------*
      *                  * A riciclo su castelletto Iva                *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-800.
       prn-liv-det-agg-660.
      *                  *=============================================*
      *                  * Tipo iva : Avere fornitori CEE              *
      *                  *---------------------------------------------*
           add       srt-ibl-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-ibl-acq          .
           add       srt-imp-iva
                    (w-tot-iva-ele-ctr)   to   w-tot-imp-acq          .
      *                  *---------------------------------------------*
      *                  * A riciclo su castelletto Iva                *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-800.
       prn-liv-det-agg-680.
      *                  *=============================================*
      *                  * Tipo iva : Dare fornitori CEE               *
      *                  *---------------------------------------------*
           subtract  srt-ibl-iva
                    (w-tot-iva-ele-ctr)   from w-tot-ibl-acq          .
           subtract  srt-imp-iva
                    (w-tot-iva-ele-ctr)   from w-tot-imp-acq          .
      *                  *---------------------------------------------*
      *                  * A riciclo su castelletto Iva                *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-800.
       prn-liv-det-agg-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     prn-liv-det-agg-200.
       prn-liv-det-agg-900.
      *              *-------------------------------------------------*
      *              * Estrazione anno e mese di esercizio dalla data  *
      *              * di registrazione                                *
      *              *-------------------------------------------------*
           move      srt-dat-reg          to   s-dat                  .
           move      s-saa                to   w-tot-iva-ele-sax      .
           move      s-mes                to   w-tot-iva-ele-mex      .
      *              *-------------------------------------------------*
      *              * Ricerca del singolo elemento per aggiornare     *
      *              *-------------------------------------------------*
           set       w-tot-iva-ele-inx    to   1                      .
           search    w-tot-iva-ele-ele
                     when    w-tot-iva-ele-saa
                            (w-tot-iva-ele-inx)
                                          =    w-tot-iva-ele-sax and
                             w-tot-iva-ele-mes
                            (w-tot-iva-ele-inx)
                                          =    w-tot-iva-ele-mex
                     go to   prn-liv-det-agg-920.
       prn-liv-det-agg-910.
      *                  *---------------------------------------------*
      *                  * Se elemento non trovato                     *
      *                  *---------------------------------------------*
           move      w-tot-iva-ele-sax    to   w-tot-iva-ele-saa
                                              (w-tot-iva-ele-mex)     .
           move      w-tot-iva-ele-mex    to   w-tot-iva-ele-mes
                                              (w-tot-iva-ele-mex)     .
           move      w-tot-ibl-fat        to   w-tot-iva-ele-ibv
                                              (w-tot-iva-ele-mex)     .
           move      w-tot-imp-fat        to   w-tot-iva-ele-imv
                                              (w-tot-iva-ele-mex)     .
           move      w-tot-ibl-acq        to   w-tot-iva-ele-iba
                                              (w-tot-iva-ele-mex)     .
           move      w-tot-imp-acq        to   w-tot-iva-ele-ima
                                              (w-tot-iva-ele-mex)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-990.    
       prn-liv-det-agg-920.
      *                  *---------------------------------------------*
      *                  * Se elemento trovato                         *
      *                  *---------------------------------------------*
           add       w-tot-ibl-fat        to   w-tot-iva-ele-ibv
                                              (w-tot-iva-ele-mex)     .
           add       w-tot-imp-fat        to   w-tot-iva-ele-imv
                                              (w-tot-iva-ele-mex)     .
           add       w-tot-ibl-acq        to   w-tot-iva-ele-iba
                                              (w-tot-iva-ele-mex)     .
           add       w-tot-imp-acq        to   w-tot-iva-ele-ima
                                              (w-tot-iva-ele-mex)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     prn-liv-det-agg-990.    
       prn-liv-det-agg-990.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-agg-999.
       prn-liv-det-agg-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri intestazione standard    *
      *              *-------------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "ELENCO DOCUMENTI -" to   w-all-str-cat (1)      .
           move      rr-prd-tpr-lit       to   w-all-str-cat (2)      .
      *
           if        w-rot-l02-tip-arc    =    "C"
                     move  "- FATTURE EMESSE"
                                          to   w-all-str-cat (3)
           else      move  "- FATTURE RICEVUTE"
                                          to   w-all-str-cat (3)      .
      *
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-cnt-tit-des-tit      .
       int-pag-sta-300.
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
      *              *-------------------------------------------------*
      *              * Intestazione standard                           *
      *              *-------------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                  *---------------------------------------------*
      *                  * Se uscita per interruzione forzata          *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
      *              *-------------------------------------------------*
      *              * Fincatura per dettaglio                         *
      *              *-------------------------------------------------*
           perform   fin-liv-det-000      thru fin-liv-det-999        .
      *              *-------------------------------------------------*
      *              * Posizionamento fisso per lasciare una inter-    *
      *              * linea di separazione                            *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       1
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Fincatura per il livello di dettaglio                     *
      *    *-----------------------------------------------------------*
       fin-liv-det-000.
      *              *-------------------------------------------------*
      *              * Interlinea subordinata                          *
      *              *-------------------------------------------------*
           move      "VS"                 to   p-ope                  .
           add       02
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * 1. linea di fincatura                           *
      *              *-------------------------------------------------*
           perform   int-lin-sep-000      thru int-lin-sep-999        .
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
