      *    *===========================================================*
      *    * Controllo formale su partita i.v.a.                       *
      *    *                                                           *
      *    * Input  : w-cnt-piv-piv = partita i.v.a. da controllare    *
      *    *                                                           *
      *    * Output : w-cnt-piv-flg = - spaces : p.i. corretta         *
      *    *                          - #      : p.i. errata           *
      *    *-----------------------------------------------------------*
       cnt-prt-iva-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-piv-flg          .
      *              *-------------------------------------------------*
      *              * Se p.i. a zero si esce per OK                   *
      *              *-------------------------------------------------*
           if        w-cnt-piv-piv        =    zero
                     go to cnt-prt-iva-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore caratteri e sommato- *
      *              * ria dei primi dieci caratteri                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-piv-ctr
                                               w-cnt-piv-sum          .
       cnt-prt-iva-100.
      *              *-------------------------------------------------*
      *              * Incremento contatore caratteri                  *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-piv-ctr          .
      *              *-------------------------------------------------*
      *              * Se entro i primi dieci caratteri                *
      *              *-------------------------------------------------*
           if        w-cnt-piv-ctr        >    10
                     go to cnt-prt-iva-500.
      *                  *---------------------------------------------*
      *                  * Se 1. o 3. o 5. o 7. o 9. carattere         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Somma del carattere nella sommatoria    *
      *                      *-----------------------------------------*
           add       w-cnt-piv-chr
                    (w-cnt-piv-ctr)       to   w-cnt-piv-sum          .
      *                  *---------------------------------------------*
      *                  * Se 2. o 4. o 6. o 8. o 10. carattere        *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-piv-ctr          .
      *                      *-----------------------------------------*
      *                      * Moltiplica il carattere per due         *
      *                      *-----------------------------------------*
           multiply  2                    by   w-cnt-piv-chr
                                              (w-cnt-piv-ctr)
                                        giving w-cnt-piv-w20          .
      *                      *-----------------------------------------*
      *                      * Somma nella sommatoria il carattere si- *
      *                      * nistro e il carattere destro del risul- *
      *                      * tato della moltiplicazione              *
      *                      *-----------------------------------------*
           add       w-cnt-piv-w21        to   w-cnt-piv-sum          .
           add       w-cnt-piv-w22        to   w-cnt-piv-sum          .
      *                  *---------------------------------------------*
      *                  * Ricicla su prossimo carattere               *
      *                  *---------------------------------------------*
           go to     cnt-prt-iva-100.
       cnt-prt-iva-500.
      *              *-------------------------------------------------*
      *              * Se undicesimo carattere                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo della differenza tra 100 e la som-  *
      *                  * matoria calcolata                           *
      *                  *---------------------------------------------*
           subtract  w-cnt-piv-sum        from 100
                                        giving w-cnt-piv-w20          .
      *                  *---------------------------------------------*
      *                  * Confronto tra la cifra di destra della dif- *
      *                  * ferenza e l'undicesimo carattere : se  non  *
      *                  * sono uguali c'e' un errore formale          *
      *                  *---------------------------------------------*
           if        w-cnt-piv-w22        not  = w-cnt-piv-chr
                                                (w-cnt-piv-ctr)
                     move  "#"            to   w-cnt-piv-flg          .
       cnt-prt-iva-999.
           exit.

      *    *===========================================================*
      *    * Emissione file sequenziale in formato XML                 *
      *    *-----------------------------------------------------------*
       emi-fil-xml-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-out-gen-tip-ope    =    "IN"
                     go to emi-fil-xml-100
           else if   w-out-gen-tip-ope    =    "ID"
                     go to emi-fil-xml-200
           else if   w-out-gen-tip-ope    =    "DE"
                     go to emi-fil-xml-300
           else if   w-out-gen-tip-ope    =    "CD"
                     go to emi-fil-xml-400
           else if   w-out-gen-tip-ope    =    "AA"
                     go to emi-fil-xml-500
           else if   w-out-gen-tip-ope    =    "CA"
                     go to emi-fil-xml-600
           else if   w-out-gen-tip-ope    =    "CL"
                     go to emi-fil-xml-800
           else      go to emi-fil-xml-900.
       emi-fil-xml-100.
      *              *=================================================*
      *              * Inizializzazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione [ada]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Lettura [ada] Sede                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Progressivo univoco                         *
      *                  *                                             *
      *                  * Il progressivo univoco del file e' rappre-  *
      *                  * sentato da una stringa alfanumerica di lun- *
      *                  * ghezza massima di 5 caratteri e con valori  *
      *                  * ammessi [a-z], [A-Z], [0-9]                 *
      *                  *                                             *
      *                  * Attualmente e' composta da:                 *
      *                  *                                             *
      *                  * - Tipo di fatture          : E o R          *
      *                  * - Semestre o trimestre     : 9              *
      *                  * - Indicatore               : S o T          *
      *                  * - Anno dichiarazione       : 99             *
      *                  *                                             *
      *                  * Esempio: E1S17 = Fatture Emesse 1' semestre *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing periodo dichiarazione           *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      rr-prd-tpr-inx       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-val-mes      .
      *                      *-----------------------------------------*
      *                      * Editing anno dichiarazione              *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
           move      rr-dat-ini
                    (02 : 02)             to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-edt-val-ann      .
      *                  *---------------------------------------------*
      *                  * Composizione identificatore univoco         *
      *                  *---------------------------------------------*
           move      05                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
      *
           if        w-rot-l02-tip-arc    =    "C"
                     move  "E"            to   w-all-str-cat (1)
           else      move  "R"            to   w-all-str-cat (1)      .
      *
           move      w-det-edt-val-mes    to   w-all-str-cat (2)      .
           move      w-det-edt-val-ann    to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-det-edt-val-ide      .
      *                  *---------------------------------------------*
      *                  * Composizione nome file                      *
      *                  *---------------------------------------------*
           move      30                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "IT"                 to   w-all-str-cat (1)      .
           move      rf-ada-cod-fis       to   w-all-str-cat (2)      .
           move      "_DF_"               to   w-all-str-cat (3)      .
           move      w-det-edt-val-ide    to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
