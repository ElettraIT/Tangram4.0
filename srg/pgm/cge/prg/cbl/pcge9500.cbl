           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-arc-pdc-des    to   w-tes-des-con          .
           perform   vis-des-con-000      thru vis-des-con-999        .
           go to acc-cod-con-500.
       acc-cod-con-450.
      *                  *---------------------------------------------*
      *                  * Se archivio clienti                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica                      *
      *                      *-----------------------------------------*
           move      w-tes-cod-con        to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione ragione sociale         *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-rag    to   w-tes-des-con          .
           perform   vis-des-con-000      thru vis-des-con-999        .
           go to acc-cod-con-500.
       acc-cod-con-475.
      *                  *---------------------------------------------*
      *                  * Se archivio fornitori                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica                      *
      *                      *-----------------------------------------*
           move      w-tes-cod-con        to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione ragione sociale         *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-rag    to   w-tes-des-con          .
           perform   vis-des-con-000      thru vis-des-con-999        .
           go to acc-cod-con-500.
       acc-cod-con-500.
      *                  *---------------------------------------------*
      *                  * Se anagrafica non esistente : oltre         *
      *                  *---------------------------------------------*
           if       (w-tes-tip-rec        =    "G"  and
                     w-let-arc-pdc-flg    not  = spaces) or
                    (w-tes-tip-rec        =    "C"  and
                     w-let-arc-cli-flg    not  = spaces) or
                    (w-tes-tip-rec        =    "F"  and
                     w-let-arc-fnt-flg    not  = spaces) 
                     go to acc-cod-con-600.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : oltre                    *
      *                  *---------------------------------------------*
           if        w-tes-cod-con        not  = zero
                     go to acc-cod-con-600.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : codice a zero !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-con-600.
       acc-cod-con-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-con-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cod-con-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-con-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cod-con-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cod-con-999.
       acc-cod-con-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Codice conto               *
      *    *-----------------------------------------------------------*
       vis-cod-con-000.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-tes-cod-con        to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      30                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
       vis-cod-con-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Descrizione conto          *
      *    *-----------------------------------------------------------*
       vis-des-con-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-des-con        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-con-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campi non chiave della registrazione         *
      *    *-----------------------------------------------------------*
       acc-nok-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-nok      .
      *              *-------------------------------------------------*
      *              * Visualizzazione tipo funzionamento              *
      *              *-------------------------------------------------*
           perform   vis-tip-fun-000      thru vis-tip-fun-999        .
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione se in modi- *
      *              * fica o visualizzazione, per testata             *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M" or
                     w-cnt-mfu-tip-fun    =    "V"
                     move  "#"            to   w-cnt-sts-imp-tes      .
       acc-nok-reg-200.
      *              *-------------------------------------------------*
      *              * Trattamento testata                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Prompts per campi chiave                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-key    =    spaces
                     perform pmt-key-reg-000
                                          thru pmt-key-reg-999
                     move    "#"          to   w-cnt-sts-pmt-key      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati campi chiave           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-key    =    spaces
                     perform vis-key-reg-000
                                          thru vis-key-reg-999
                     move    "#"          to   w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Prompts per testata                         *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-tes    =    spaces
                     perform pmt-tes-reg-000
                                          thru pmt-tes-reg-999
                     move    "#"          to   w-cnt-sts-pmt-tes      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati testata                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"   or
                     w-cnt-mfu-tip-fun    =    "V"   or
                     w-cnt-sts-imp-tes    not  = spaces
                     if    w-cnt-sts-vis-tes
                                          =    spaces
                           perform vis-tes-reg-000
                                          thru vis-tes-reg-999
                           move    "#"    to   w-cnt-sts-vis-tes      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati testata                   *
      *                  *---------------------------------------------*
           perform   acc-tes-reg-000      thru acc-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "S" or
                     w-cnt-tus-acc-tes    =    "X" or
                     w-cnt-tus-acc-tes    =    "E"
                     move  w-cnt-tus-acc-tes
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
       acc-nok-reg-800.
      *              *-------------------------------------------------*
      *              * Conferma impostazioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Cancellazione eventuali note operative      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-nok-reg-810.
      *                  *---------------------------------------------*
      *                  * Test se sola visualizzazione                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-nok-reg-820
           else      go to acc-nok-reg-830.
       acc-nok-reg-820.
      *                      *-----------------------------------------*
      *                      * Accettazione se sola visualizzazione    *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#VIS"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "E"                  to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "E"
                     move  "EXIT"         to   v-key                  .
           go to     acc-nok-reg-840.
       acc-nok-reg-830.
      *                      *-----------------------------------------*
      *                      * Accettazione se inserimento o modifica  *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#SAV"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "SNE"                to   v-msk                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "EXIT"        to   v-key
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key                  .
       acc-nok-reg-840.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to acc-nok-reg-850
           else if   v-key                =    "EXIT"
                     go to acc-nok-reg-860
           else if   v-key                =    "UP  "
                     go to acc-nok-reg-870
           else      go to acc-nok-reg-810.
       acc-nok-reg-850.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    =    spaces
                     move  "S"            to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999
           else      move  spaces         to   w-cnt-tdo-nok-flg
                     go to acc-nok-reg-800.
       acc-nok-reg-860.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-nok      .
           go to     acc-nok-reg-999.
       acc-nok-reg-870.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazione testata                 *
      *                      *-----------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione testata registrazione                        *
      *    *-----------------------------------------------------------*
       acc-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-tes      .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : testata                     *
      *              *-------------------------------------------------*
           move      "T"                  to   w-cnt-mfu-tip-imp      .
       acc-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Saldo a inizio anno                         *
      *                  *---------------------------------------------*
           perform   acc-sdo-ini-000      thru acc-sdo-ini-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
      *                      *-----------------------------------------*
      *                      * Normalizzazione contatore per progres-  *
      *                      * sivi mensili                            *
      *                      *-----------------------------------------*
           move      zero                 to   w-wrk-cnt-mes          .
       acc-tes-reg-200.
      *                      *-----------------------------------------*
      *                      * Incremento contatore per progressivi    *
      *                      * mensili                                 *
      *                      *-----------------------------------------*
           add       1                    to   w-wrk-cnt-mes          .
      *                      *-----------------------------------------*
      *                      * Se superiore al massimo si prosegue     *
      *                      *-----------------------------------------*
           if        w-wrk-cnt-mes        >    12
                     go to acc-tes-reg-600.
       acc-tes-reg-250.
      *                  *---------------------------------------------*
      *                  * Progressivi dare per mese                   *
      *                  *---------------------------------------------*
           perform   acc-dar-mes-000      thru acc-dar-mes-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-tes-reg-275.
      *                      *-----------------------------------------*
      *                      * Se su primo mese : a saldo inizio anno  *
      *                      *-----------------------------------------*
           if        w-wrk-cnt-mes        =    zero
                     go to acc-tes-reg-100.
      *                      *-----------------------------------------*
      *                      * A inizio mese precedente                *
      *                      *-----------------------------------------*
           subtract  1                    from w-wrk-cnt-mes          .
           if        w-wrk-cnt-mes        =    zero
                     go to acc-tes-reg-100.
           go to     acc-tes-reg-250.
       acc-tes-reg-275.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "DOWN"
                     go to acc-tes-reg-300.
      *                      *-----------------------------------------*
      *                      * Se su ultimo mese : a progressivo dare  *
      *                      * movimenti di bilancio                   *
      *                      *-----------------------------------------*
           if        w-wrk-cnt-mes        =    12
                     go to acc-tes-reg-600.
      *                      *-----------------------------------------*
      *                      * A inizio mese successivo                *
      *                      *-----------------------------------------*
           add       1                    to   w-wrk-cnt-mes          .
           go to     acc-tes-reg-250.
       acc-tes-reg-300.
      *                  *---------------------------------------------*
      *                  * Progressivi avere per mese                  *
      *                  *---------------------------------------------*
           perform   acc-ave-mes-000      thru acc-ave-mes-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-250.
       acc-tes-reg-400.
      *                  *---------------------------------------------*
      *                  * Importo rettifica per mese                  *
      *                  *---------------------------------------------*
           perform   acc-imp-ret-000      thru acc-imp-ret-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-300.
       acc-tes-reg-500.
      *                  *---------------------------------------------*
      *                  * Flag importo rettifica per mese             *
      *                  *---------------------------------------------*
           perform   acc-dav-ret-000      thru acc-dav-ret-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-400.
      *                      *-----------------------------------------*
      *                      * Riciclo a mese successivo               *
      *                      *-----------------------------------------*
           go to     acc-tes-reg-200.
       acc-tes-reg-600.
      *                  *---------------------------------------------*
      *                  * Progressivo dare movimenti di bilancio      *
      *                  *---------------------------------------------*
           perform   acc-dar-bil-000      thru acc-dar-bil-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  12             to   w-wrk-cnt-mes
                     go to acc-tes-reg-500.
       acc-tes-reg-700.
      *                  *---------------------------------------------*
      *                  * Progressivo avere movimenti di bilancio     *
      *                  *---------------------------------------------*
           perform   acc-ave-bil-000      thru acc-ave-bil-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-600.
       acc-tes-reg-800.
      *                  *---------------------------------------------*
      *                  * Data ultima chiusura                        *
      *                  *---------------------------------------------*
           perform   acc-dat-chi-000      thru acc-dat-chi-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-700.
       acc-tes-reg-900.
      *              *-------------------------------------------------*
      *              * Assestamento status di uscita                   *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     move   "S"           to   w-cnt-tus-acc-tes
           else if   v-key                =    "DELT"
                     move   "X"           to   w-cnt-tus-acc-tes
           else if   v-key                =    "EXIT"
                     move   "E"           to   w-cnt-tus-acc-tes
           else      move   "+"           to   w-cnt-tus-acc-tes      .
       acc-tes-reg-990.
      *              *-------------------------------------------------*
      *              * Flag di status impostazione testata             *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-tes      .
      *              *-------------------------------------------------*
      *              * Flag di status visualizzazione dati testata     *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-sts-vis-tes      .
       acc-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione testata registrazione                     *
      *    *-----------------------------------------------------------*
       vis-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Saldo a inizio anno                             *
      *              *-------------------------------------------------*
           perform   vis-sdo-ini-000      thru vis-sdo-ini-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore per progres-      *
      *                  * sivi mensili                                *
      *                  *---------------------------------------------*
           move      zero                 to   w-wrk-cnt-mes          .
       vis-tes-reg-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore per progressivi        *
      *                  * mensili                                     *
      *                  *---------------------------------------------*
           add       1                    to   w-wrk-cnt-mes          .
      *                  *---------------------------------------------*
      *                  * Se superiore al massimo si prosegue         *
      *                  *---------------------------------------------*
           if        w-wrk-cnt-mes        >    12
                     go to vis-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Progressivi dare per mese                       *
      *              *-------------------------------------------------*
           perform   vis-dar-mes-000      thru vis-dar-mes-999        .
      *              *-------------------------------------------------*
      *              * Progressivi avere per mese                      *
      *              *-------------------------------------------------*
           perform   vis-ave-mes-000      thru vis-ave-mes-999        .
      *              *-------------------------------------------------*
      *              * Flag importo rettifica per mese                 *
      *              *-------------------------------------------------*
           perform   vis-dav-ret-000      thru vis-dav-ret-999        .
      *              *-------------------------------------------------*
      *              * Importo rettifica per mese                      *
      *              *-------------------------------------------------*
           perform   vis-imp-ret-000      thru vis-imp-ret-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a mese successivo                   *
      *                  *---------------------------------------------*
           go to     vis-tes-reg-100.
       vis-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Progressivo dare movimenti di bilancio          *
      *              *-------------------------------------------------*
           perform   vis-dar-bil-000      thru vis-dar-bil-999        .
      *              *-------------------------------------------------*
      *              * Progressivo avere movimenti di bilancio         *
      *              *-------------------------------------------------*
           perform   vis-ave-bil-000      thru vis-ave-bil-999        .
      *              *-------------------------------------------------*
      *              * Data ultima chiusura                            *
      *              *-------------------------------------------------*
           perform   vis-dat-chi-000      thru vis-dat-chi-999        .
       vis-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts testata                           *
      *    *-----------------------------------------------------------*
       pmt-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      06                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Saldo a inizio anno                             *
      *              *-------------------------------------------------*
           perform   pmt-sdo-ini-000      thru pmt-sdo-ini-999        .
