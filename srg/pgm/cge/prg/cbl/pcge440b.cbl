      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cli-ope      .
           move      rr-cod-cli           to   w-cod-mne-cli-cod      .
           move      10                   to   w-cod-mne-cli-lin      .
           move      30                   to   w-cod-mne-cli-pos      .
           move      10                   to   w-cod-mne-cli-rln      .
           move      41                   to   w-cod-mne-cli-rps      .
           move      zero                 to   w-cod-mne-cli-vln      .
           move      zero                 to   w-cod-mne-cli-vps      .
           move      zero                 to   w-cod-mne-cli-lln      .
           move      zero                 to   w-cod-mne-cli-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
       acc-cod-cli-110.
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           if        w-cod-mne-cli-ope    =    "F+"
                     go to acc-cod-cli-115.
           if        w-cod-mne-cli-ope    =    "AC"
                     go to acc-cod-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cli-115.
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
           go to     acc-cod-cli-110.
       acc-cod-cli-120.
           move      w-cod-mne-cli-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative                    *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cod-cli-999.
       acc-cod-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-cod-cli             .
       acc-cod-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cli]                      *
      *                  *---------------------------------------------*
           move      rr-cod-cli           to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   rr-cod-cli-rag         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-cli-rag-000  thru vis-cod-cli-rag-999    .
      *                  *---------------------------------------------*
      *                  * Se codice non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces
                     go to acc-cod-cli-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero                            *
      *                  *---------------------------------------------*
           if        rr-cod-cli           not  = zero
                     go to acc-cod-cli-600.
      *                      *-----------------------------------------*
      *                      * Visualizzazione literal 'Tutti'         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "Tutti"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cod-cli-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cod-cli-100.
       acc-cod-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Ragione sociale cliente *
      *    *-----------------------------------------------------------*
       vis-cod-cli-rag-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      rr-cod-cli-rag       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cli-rag-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      zero                 to   rr-cod-cli             .
           move      spaces               to   rr-cod-cli-rag         .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Programma di esecuzione in foreground                     *
      *    *-----------------------------------------------------------*
       exe-pgm-frg-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione rullino messaggi di foreground *
      *              *-------------------------------------------------*
           move      "OF"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Se errore : uscita                          *
      *                  *---------------------------------------------*
            if       m-rsc                not  = spaces
                     go to exe-pgm-frg-999.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Esecuzione del programma                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Pareggiamento automatico partite clienti    *
      *                  *---------------------------------------------*
           perform   par-aut-pcl-000      thru par-aut-pcl-999        .
      *              *-------------------------------------------------*
      *              * Messaggio di fine programma in esecuzione       *
      *              *-------------------------------------------------*
           move      "FE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visual. eventuali errori di esecuzione      *
      *                  *---------------------------------------------*
           move      "VE"                 to   b-ope                  .
           move      "F"                  to   b-tfe                  .
           move      "     PAREGGIAMENTO PARTITE CLIENTI      "
                                          to   b-chr                  .
           call      "swd/mod/prg/obj/mbckgv"
                                         using b                      .
           cancel    "swd/mod/prg/obj/mbckgv"                         .
       exe-pgm-frg-999.
           exit.

      *    *===========================================================*
      *    * Pareggiamento partite clienti                             *
      *    *-----------------------------------------------------------*
       par-aut-pcl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di almeno un pareggiamento *
      *              * eseguito                                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-par-aut-pcl-flg      .
      *              *-------------------------------------------------*
      *              * Start su file [cli]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODCLI    "         to   f-key                  .
           move      rr-cod-cli           to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to par-aut-pcl-800.
       par-aut-pcl-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [cli]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to par-aut-pcl-800.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rr-cod-cli           not  = zero   and
                     rf-cli-cod-cli       not  = rr-cod-cli
                     go to par-aut-pcl-800.
      *              *-------------------------------------------------*
      *              * Caricamento partite cliente                     *
      *              *-------------------------------------------------*
           perform   car-par-cli-000      thru car-par-cli-999        .
           if        w-car-par-cli-flg    not  = spaces
                     go to par-aut-pcl-200.
      *              *-------------------------------------------------*
      *              * Esecuzione pareggiamento partite                *
      *              *-------------------------------------------------*
           perform   exe-par-aut-000      thru exe-par-aut-999        .
           if        w-exe-par-aut-flg    not  = spaces
                     go to par-aut-pcl-200.
      *              *-------------------------------------------------*
      *              * Esecuzione aggiornamento file [mgr]             *
      *              *-------------------------------------------------*
           perform   agg-fil-mgr-000      thru agg-fil-mgr-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento flag di almeno un pareggiamento   *
      *              * eseguito                                        *
      *              *-------------------------------------------------*
           if        w-par-aut-pcl-flg    =    spaces
                     move  "#"            to   w-par-aut-pcl-flg      .
       par-aut-pcl-200.
           go to     par-aut-pcl-100.
       par-aut-pcl-800.
      *              *-------------------------------------------------*
      *              * Test su flag di almeno un pareggiamento esegui- *
      *              * to                                              *
      *              *-------------------------------------------------*
           if        w-par-aut-pcl-flg    not  = spaces
                     go to par-aut-pcl-999.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Nessun pareggiamento da eseguire !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       par-aut-pcl-999.
           exit.

      *    *===========================================================*
      *    * Routine di caricamento partite cliente                    *
      *    *-----------------------------------------------------------*
       car-par-cli-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-par-cli-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di primo passaggio         *
      *              *-------------------------------------------------*
           move      spaces               to   w-par-flg-uno          .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero elementi in tabella     *
      *              *-------------------------------------------------*
           move      zero                 to   w-par-num-ele          .
      *              *-------------------------------------------------*
      *              * Normalizzazione area di comodo per rottura par- *
      *              * tita                                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-par-rot-dat          .
           move      spaces               to   w-par-rot-num          .
      *              *-------------------------------------------------*
      *              * Start su file [mgr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      "C"                  to   rf-mgr-tip-arc         .
           move      rf-cli-cod-cli       to   rf-mgr-cod-arc         .
           move      zero                 to   rf-mgr-dat-rif         .
           move      spaces               to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-par-cli-300.
       car-par-cli-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mgr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-par-cli-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-mgr-tip-arc       not  = "C"            or
                     rf-mgr-cod-arc       not  = rf-cli-cod-cli
                     go to car-par-cli-300.
      *              *-------------------------------------------------*
      *              * Se rottura data e numero partita                *
      *              *-------------------------------------------------*
           if        rf-mgr-dat-rif       =    w-par-rot-dat and
                     rf-mgr-num-rif       =    w-par-rot-num
                     go to car-par-cli-200.
      *                  *---------------------------------------------*
      *                  * Aggiornamento area rottura partita          *
      *                  *---------------------------------------------*
           move      rf-mgr-dat-rif       to   w-par-rot-dat          .
           move      rf-mgr-num-rif       to   w-par-rot-num          .
      *                  *---------------------------------------------*
      *                  * Fine partita precedente                     *
      *                  *---------------------------------------------*
           perform   car-par-cli-900      thru car-par-cli-919        .
      *                  *---------------------------------------------*
      *                  * Inizio partita successiva                   *
      *                  *---------------------------------------------*
           perform   car-par-cli-920      thru car-par-cli-949        .
           if        w-par-num-ele        >    w-par-max-ele
                     go to  car-par-cli-800.
       car-par-cli-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo partita                     *
      *              *-------------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-par-sdo-par (1000)
           else      add      rf-mgr-imp-mov
                                          to   w-par-sdo-par (1000)   .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura file [mgr]                   *
      *              *-------------------------------------------------*
           go to     car-par-cli-100.
       car-par-cli-300.
      *              *-------------------------------------------------*
      *              * Fine lettura partite                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fine ultima partita                         *
      *                  *---------------------------------------------*
           perform   car-par-cli-900      thru car-par-cli-919        .
      *                  *---------------------------------------------*
      *                  * Se nessuna partita memorizzata : Flag di u- *
      *                  * scita ad errore                             *
      *                  *---------------------------------------------*
           if        w-par-num-ele        =    zero
                     move  "#"            to   w-car-par-cli-flg      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-par-cli-999.
       car-par-cli-800.
      *              *-------------------------------------------------*
      *              * Se esubero numero partite per cliente           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prima riga messaggio di errore              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione messaggio di errore        *
      *                      *-----------------------------------------*
           move      spaces               to   m-msg                  .
      *                          *-------------------------------------*
      *                          * Editing codice cliente              *
      *                          *-------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      rf-cli-cod-cli       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    "Cliente :"
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     "  "
                                delimited by   size
                     rf-cli-rag-soc
                                delimited by   size
                                          into m-msg                  .
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Seconda riga messaggio di errore            *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "- numero partite oltre il massimo consentito."
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-car-par-cli-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     car-par-cli-999.
       car-par-cli-900.
      *              *=================================================*
      *              * Subroutine interna di fine partita precedente   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se primo passaggio : uscita                 *
      *                  *---------------------------------------------*
           if        w-par-flg-uno        =    spaces
                     move  "#"            to   w-par-flg-uno
                     go to car-par-cli-919.
      *                  *---------------------------------------------*
      *                  * Se saldo partita a zero : uscita            *
      *                  *---------------------------------------------*
           if        w-par-sdo-par (1000) =    zero
                     go to car-par-cli-919.
      *                  *---------------------------------------------*
      *                  * Incremento contatore numero partite         *
      *                  *---------------------------------------------*
           add       1                    to   w-par-num-ele          .
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : uscita                *
      *                  *---------------------------------------------*
           if        w-par-num-ele        >    w-par-max-ele
                     go to car-par-cli-919.
      *                  *---------------------------------------------*
      *                  * Memorizzazione elemento in tabella          *
      *                  *---------------------------------------------*
           move      w-par-dat-rif (1000) to   w-par-dat-rif
                                              (w-par-num-ele)         .
           move      w-par-num-rif (1000) to   w-par-num-rif
                                              (w-par-num-ele)         .
           move      w-par-sdo-par (1000) to   w-par-sdo-par
                                              (w-par-num-ele)         .
           move      zero                 to   w-par-new-dri
                                              (w-par-num-ele)         .
           move      spaces               to   w-par-new-nri
                                              (w-par-num-ele)         .
       car-par-cli-919.
           exit.
       car-par-cli-920.
      *              *=================================================*
      *              * Subroutine interna di inizio partita successi-  *
      *              * va                                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione dati partita               *
      *                  *---------------------------------------------*
           move      rf-mgr-dat-rif       to   w-par-dat-rif (1000)   .
           move      rf-mgr-num-rif       to   w-par-num-rif (1000)   .
           move      zero                 to   w-par-sdo-par (1000)   .
       car-par-cli-949.
           exit.
       car-par-cli-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione pareggiamento automatico partite               *
      *    *-----------------------------------------------------------*
       exe-par-aut-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione flag di almeno un pareggiamen- *
      *              * to eseguito a No                                *
      *              *-------------------------------------------------*
           move      "#"                  to   w-exe-par-aut-flg      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella partite           *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-par-aut-c01      .
       exe-par-aut-100.
           add       1                    to   w-exe-par-aut-c01      .
           if        w-exe-par-aut-c01    >    w-par-num-ele
                     go to exe-par-aut-800.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo partita ma di segno    *
      *                  * opposto                                     *
      *                  *---------------------------------------------*
           multiply  -1                   by   w-par-sdo-par
                                              (w-exe-par-aut-c01)
                                        giving w-exe-par-aut-wsp      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su partite rimanenti     *
      *                  *---------------------------------------------*
           move      w-exe-par-aut-c01    to   w-exe-par-aut-c02      .
       exe-par-aut-200.
           add       1                    to   w-exe-par-aut-c02      .
           if        w-exe-par-aut-c02    >    w-par-num-ele
                     go to exe-par-aut-100.
      *                      *-----------------------------------------*
      *                      * Se partita in esame gia' aggiornata :   *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-par-new-dri
                    (w-exe-par-aut-c02)   not  = zero   and
                     w-par-new-nri
                    (w-exe-par-aut-c02)   not  = spaces
                     go to exe-par-aut-200.
      *                      *-----------------------------------------*
      *                      * Se la partita in esame non ha lo stesso *
      *                      * importo e di segno opposto : riciclo    *
      *                      *-----------------------------------------*
           if        w-par-sdo-par
                    (w-exe-par-aut-c02)   not  = w-exe-par-aut-wsp
                     go to exe-par-aut-200.
      *                      *-----------------------------------------*
      *                      * Aggiornamento data e numero partita     *
      *                      *-----------------------------------------*
           move      w-par-dat-rif
                    (w-exe-par-aut-c01)   to   w-par-new-dri
                                              (w-exe-par-aut-c02)     .
           move      w-par-num-rif
                    (w-exe-par-aut-c01)   to   w-par-new-nri
                                              (w-exe-par-aut-c02)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento flag di almeno un pareg-  *
      *                      * giamento eseguito                       *
      *                      *-----------------------------------------*
           if        w-exe-par-aut-flg    not  = spaces
                     move  spaces         to   w-exe-par-aut-flg      .
      *                      *-----------------------------------------*
      *                      * Riciclo su prima scansione tabella par- *
      *                      * tite                                    *
      *                      *-----------------------------------------*
           go to     exe-par-aut-100.
       exe-par-aut-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-par-aut-999.
       exe-par-aut-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento file [mgr]                                  *
      *    *-----------------------------------------------------------*
       agg-fil-mgr-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella partite           *
      *              *-------------------------------------------------*
           move      zero                 to   w-agg-fil-mgr-c01      .
       agg-fil-mgr-100.
           add       1                    to   w-agg-fil-mgr-c01      .
           if        w-agg-fil-mgr-c01    >    w-par-num-ele
                     go to agg-fil-mgr-800.
      *                  *---------------------------------------------*
      *                  * Test se partita da aggiornare               *
      *                  *---------------------------------------------*
           if        w-par-new-dri
                    (w-agg-fil-mgr-c01)   =    zero   and
                     w-par-new-nri
                    (w-agg-fil-mgr-c01)   =    spaces
                     go to agg-fil-mgr-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione contatore per tabella pro-  *
      *                  * tocolli [mgr]                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-agg-fil-mgr-c02      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione saldo partita per riscontro *
      *                  *---------------------------------------------*
           move      zero                 to   w-agg-fil-mgr-wsp      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione file [mgr] per la parti- *
      *                  * ta in esame                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start su file [mgr]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      "C"                  to   rf-mgr-tip-arc         .
           move      rf-cli-cod-cli       to   rf-mgr-cod-arc         .
           move      w-par-dat-rif
                    (w-agg-fil-mgr-c01)   to   rf-mgr-dat-rif         .
           move      w-par-num-rif
                    (w-agg-fil-mgr-c01)   to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-fil-mgr-300.
       agg-fil-mgr-200.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale file [mgr]          *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                          *-------------------------------------*
      *                          * Test se 'At end'                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-fil-mgr-300.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       not  = "C"                or
                     rf-mgr-cod-arc       not  = rf-cli-cod-cli     or
                     rf-mgr-dat-rif       not  = w-par-dat-rif
                                                (w-agg-fil-mgr-c01) or
                     rf-mgr-num-rif       not  = w-par-num-rif
                                                (w-agg-fil-mgr-c01)
                     go to agg-fil-mgr-300.
      *                      *-----------------------------------------*
      *                      * Incremento contatore protocolli [mgr]   *
      *                      * memorizzati                             *
      *                      *-----------------------------------------*
           if        w-agg-fil-mgr-c02    <    w-agg-fil-mgr-max
                     add   1              to   w-agg-fil-mgr-c02      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valori chiave [mgr]      *
      *                      *-----------------------------------------*
           move      rf-mgr-dat-reg       to   w-agg-fil-mgr-dtr
                                              (w-agg-fil-mgr-c02)     .
           move      rf-mgr-num-prt       to   w-agg-fil-mgr-npr
                                              (w-agg-fil-mgr-c02)     .
           move      rf-mgr-num-prg       to   w-agg-fil-mgr-npg
                                              (w-agg-fil-mgr-c02)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento saldo partita per riscon- *
      *                      * tro                                     *
      *                      *-----------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-agg-fil-mgr-wsp
           else      add      rf-mgr-imp-mov
                                          to   w-agg-fil-mgr-wsp      .
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura sequenziale [mgr]    *
      *                      *-----------------------------------------*
           go to     agg-fil-mgr-200.
       agg-fil-mgr-300.
      *                  *---------------------------------------------*
      *                  * Se saldo cosi' ottenuto non e' pari a quel- *
      *                  * lo originario, vuol dire che nel frattempo  *
      *                  * sono state modificate delle righe di regi-  *
      *                  * strazione all'interno della partita e quin- *
      *                  * di non si continua nell'aggiornamento       *
      *                  *---------------------------------------------*
           if        w-agg-fil-mgr-wsp    not  = w-par-sdo-par
                                                (w-agg-fil-mgr-c01)
                     go to agg-fil-mgr-600.
      *                  *---------------------------------------------*
      *                  * Ciclo di aggiornamento file [mgr] vero e    *
      *                  * proprio                                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-agg-fil-mgr-c03      .
       agg-fil-mgr-400.
           add       1                    to   w-agg-fil-mgr-c03      .
           if        w-agg-fil-mgr-c03    >    w-agg-fil-mgr-c02
                     go to agg-fil-mgr-600.
      *                      *-----------------------------------------*
      *                      * Ottenimento record [mgr]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "DATREG    "         to   f-key                  .
           move      w-agg-fil-mgr-dtr
                    (w-agg-fil-mgr-c03)   to   rf-mgr-dat-reg         .
           move      w-agg-fil-mgr-npr
                    (w-agg-fil-mgr-c03)   to   rf-mgr-num-prt         .
           move      w-agg-fil-mgr-npg
                    (w-agg-fil-mgr-c03)   to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-fil-mgr-500.
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [mgr]              *
      *                      *-----------------------------------------*
           move      w-par-new-dri
                    (w-agg-fil-mgr-c01)   to   rf-mgr-dat-rif         .
           move      w-par-new-nri
                    (w-agg-fil-mgr-c01)   to   rf-mgr-num-rif         .
      *                      *-----------------------------------------*
      *                      * Update record [mgr]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Release record [mgr]                    *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
       agg-fil-mgr-500.
      *                      *-----------------------------------------*
      *                      * Riciclo su tabella valori chiave [mgr]  *
      *                      *-----------------------------------------*
           go to     agg-fil-mgr-400.
       agg-fil-mgr-600.
      *                  *---------------------------------------------*
      *                  * Riciclo su tabella partite                  *
      *                  *---------------------------------------------*
           go to     agg-fil-mgr-100.
       agg-fil-mgr-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-fil-mgr-999.
       agg-fil-mgr-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cli]                         *
      *    *-----------------------------------------------------------*
       let-arc-cli-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a zero                           *
      *              *-------------------------------------------------*
           if        w-let-arc-cli-cod    =    zero
                     go to let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      w-let-arc-cli-cod    to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-cli-400.
       let-arc-cli-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-cli-rag-soc       to   w-let-arc-cli-rag      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-cli-999.
       let-arc-cli-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-cli-flg      .
           move      all   "."            to   w-let-arc-cli-rag      .
           go to     let-arc-cli-999.
       let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-rag      .
       let-arc-cli-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice cliente         *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/acmncli0.acs"                   .
