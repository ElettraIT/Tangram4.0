           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      72                   to   v-pos                  .
           move      "Avere"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura per area di scroll     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---  ----------------------------------------     
