           if        w-cnt-cor-tip-agg    not  = "+"
                     go to pos-rig-cor-900.
           if        w-rig-dar-ave (1)    =    "A"
                     subtract  w-rig-imp-mov (1)
                                          from w-tes-sdo-reg
           else      add        w-rig-imp-mov (1)
                                          to   w-tes-sdo-reg          .
       pos-rig-cor-900.
