      *    *===========================================================*
      *    * Accettazione campo : Importo movimento                    *
      *    *-----------------------------------------------------------*
       acc-imp-mov-000.
      *              *-------------------------------------------------*
      *              * Preparazione default di Dare o Avere e Importo  *
      *              * movimento                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valori attuali gia' presenti : nessuna   *
      *                  * azione                                      *
      *                  *---------------------------------------------*
           if        w-rig-dar-ave (1)    not  = spaces
                     go to acc-imp-mov-100.
      *                  *---------------------------------------------*
      *                  * Default standard                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione del dare/avere in funzio-  *
      *                      * ne del saldo registrazione              *
      *                      *-----------------------------------------*
           if        w-tes-sdo-reg        >    zero
                     move  "A"            to   w-rig-dar-ave (1)
           else      move  "D"            to   w-rig-dar-ave (1)      .
      *                      *-----------------------------------------*
      *                      * Importo : valore assoluto del saldo     *
      *                      * registrazione                           *
      *                      *-----------------------------------------*
           move      w-tes-sdo-reg        to   w-rig-imp-mov (1)      .
           if        w-rig-imp-mov (1)    <    zero
                     multiply   -1        by   w-rig-imp-mov (1)      .
       acc-imp-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
           if        w-rig-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
           move      "GB"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      w-rig-imp-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-mov-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-mov-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-mov (1)      .
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "TAB "
                     go to acc-imp-mov-400.
      *                  *---------------------------------------------*
      *                  * Salvataggio importo movimento precedente    *
      *                  *---------------------------------------------*
           move      w-rig-imp-mov (1)    to   w-sav-imp-mov          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo movimento a zero    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-imp-mov (1)      .
           perform   vis-imp-mov-000      thru vis-imp-mov-999        .
      *                  *---------------------------------------------*
      *                  * Ripristino importo movimento precedente     *
      *                  *---------------------------------------------*
           move      w-sav-imp-mov        to   w-rig-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Inversione del segnale di Dare o Avere      *
      *                  *---------------------------------------------*
           if        w-rig-dar-ave (1)    =    "A"
                     move  "D"            to   w-rig-dar-ave (1)
           else      move  "A"            to   w-rig-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-imp-mov-100.
       acc-imp-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se impostazione normale                     *
      *                  *---------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to acc-imp-mov-500.
      *                      *-----------------------------------------*
      *                      * Zero non ammesso a meno che non si sia  *
      *                      * in Up di una riga nuova                 *
      *                      *-----------------------------------------*
           if        w-rig-imp-mov (1)    =    zero
                     if    w-cnt-sts-imp-rig
                                          =    spaces
                           go to acc-imp-mov-600
                     else  go to acc-imp-mov-100
           else      go to acc-imp-mov-600.
       acc-imp-mov-500.
      *                  *---------------------------------------------*
      *                  * Se impostazione skeleton                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non zero non ammesso                    *
      *                      *-----------------------------------------*
           if        w-rig-imp-mov (1)    =    zero
                     go to acc-imp-mov-600
           else      go to acc-imp-mov-100.
       acc-imp-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-mov-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-mov-100.
       acc-imp-mov-999.
           exit.

