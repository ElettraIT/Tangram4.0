      *                  * Visualizzazione box internamente vuoto      *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      13                   to   v-pos                  .
           move      16                   to   v-lto                  .
           move      67                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione messaggio interno al box    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      51                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      "Attenzione : il saldo rettifiche e' diverso da zer
      -              "o"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
