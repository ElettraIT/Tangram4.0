      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Start su archivio [rdb]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATREG "            to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-dat-reg        to   rf-rdb-dat-reg         .
           move      zero                 to   rf-rdb-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : inserimento            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Lettura primo record [rdb]                      *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                  *---------------------------------------------*
      *                  * Se errore di lettura : inserimento          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : inserimento           *
      *                  *---------------------------------------------*
           if        rf-rdb-dat-reg       not  = w-tes-dat-reg
                     go to rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Se tutto bene : modifica                    *
      *                  *---------------------------------------------*
           go to     rou-let-reg-200.
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Se lettura primo record eseguita senza successo *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se inserimento consentito              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-vis-sgr    not  = "V"
                     go to rou-let-reg-120.
      *                      *-----------------------------------------*
      *                      * Flag di uscita                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Inserimento non consentito !                      
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     rou-let-reg-900.
       rou-let-reg-120.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Precaricamento righe skeleton               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se in impostazione skeleton : uscita    *
      *                      *-----------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to rou-let-reg-999.
      *                      *-----------------------------------------*
      *                      * Start su archivio [rdb]                 *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATREG "            to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      zero                 to   rf-rdb-dat-reg         .
           move      zero                 to   rf-rdb-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                          *-------------------------------------*
      *                          * Se errore di start : fine precari-  *
      *                          * camento                             *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-999.
       rou-let-reg-150.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale file [rdb]          *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                          *-------------------------------------*
      *                          * Se at end : fine precaricamento     *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-999.
      *                          *-------------------------------------*
      *                          * Se oltre il massimo : fine precari- *
      *                          * camento                             *
      *                          *-------------------------------------*
           if        rf-rdb-dat-reg       not  = zero
                     go to  rou-let-reg-999.
      *                      *-----------------------------------------*
      *                      * Precaricamento riga                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [rdb]                        *
      *                          *-------------------------------------*
           move      rf-rdb-num-prg       to   w-rig-num-prg (1)      .
           move      "G"                  to   w-rig-tip-con (1)      .
           move      rf-rdb-cod-pdc       to   w-rig-cod-pdc (1)      .
           move      w-rig-cod-pdc (1)    to   w-let-cod-pdc-cod      .
           perform   let-cod-pdc-000      thru let-cod-pdc-999        .
           move      w-let-cod-pdc-des    to   w-rig-des-pdc (1)      .
           move      rf-rdb-com-rig       to   w-rig-com-rig (1)      .
           move      rf-rdb-dar-ave       to   w-rig-dar-ave (1)      .
           move      zero                 to   w-rig-imp-mov (1)      .
      *                      *-----------------------------------------*
      *                      * Put su catena movimenti [rig]           *
      *                      *-----------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-rdb-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura [rdb] successivo      *
      *                      *-----------------------------------------*
           go to     rou-let-reg-150.
       rou-let-reg-200.
      *              *-------------------------------------------------*
      *              * Se lettura primo record eseguita con successo   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Modifica               *
      *                  *---------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Start su archivio [rdb]                     *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATREG "            to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-dat-reg        to   rf-rdb-dat-reg         .
           move      zero                 to   rf-rdb-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                      *-----------------------------------------*
      *                      * Se errore di start : fine lettura       *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-fnd
                     go to  rou-let-reg-800.
       rou-let-reg-300.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [rdb]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                      *-----------------------------------------*
      *                      * Se at end : fine lettura                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-800.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : fine lettura          *
      *                  *---------------------------------------------*
           if        rf-rdb-dat-reg       not  = w-tes-dat-reg
                     go to  rou-let-reg-800.
