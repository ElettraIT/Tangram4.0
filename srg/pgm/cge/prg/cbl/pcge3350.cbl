           move      33                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      48                   to   v-pos                  .
           move      "---------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * 'Saldo rettifiche :'                            *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "Saldo rettifiche :"
