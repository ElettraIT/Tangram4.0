           move      w-tes-dat-reg        to   w-agg-mgs-dat-reg      .
           move      w-rig-cod-pdc (1)    to   w-agg-mgs-cod-pdc      .
           move      "+"                  to   w-agg-mgs-tip-agg      .
           move      w-rig-dar-ave (1)    to   w-agg-mgs-dar-ave      .
           move      w-rig-imp-mov (1)    to   w-agg-mgs-imp-mov      .
           perform   agg-con-000-000      thru agg-con-000-999        .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-rdb-000      thru cmp-rec-rdb-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
       wrt-rec-rdb-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record [rdb]                                  *
      *    *-----------------------------------------------------------*
       rew-rec-rdb-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento [mgs] corrispondente              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In meno                                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-reg        to   w-agg-mgs-dat-reg      .
           move      w-rig-cod-pdc (2)    to   w-agg-mgs-cod-pdc      .
           move      "-"                  to   w-agg-mgs-tip-agg      .
           move      w-rig-dar-ave (2)    to   w-agg-mgs-dar-ave      .
           move      w-rig-imp-mov (2)    to   w-agg-mgs-imp-mov      .
           perform   agg-con-000-000      thru agg-con-000-999        .
      *                  *---------------------------------------------*
      *                  * In piu'                                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-reg        to   w-agg-mgs-dat-reg      .
           move      w-rig-cod-pdc (1)    to   w-agg-mgs-cod-pdc      .
           move      "+"                  to   w-agg-mgs-tip-agg      .
           move      w-rig-dar-ave (1)    to   w-agg-mgs-dar-ave      .
           move      w-rig-imp-mov (1)    to   w-agg-mgs-imp-mov      .
           perform   agg-con-000-000      thru agg-con-000-999        .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-rdb-000      thru cmp-rec-rdb-999        .
      *              *-------------------------------------------------*
      *              * Force Put record                                *
      *              *-------------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
       rew-rec-rdb-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record [rdb]                                *
      *    *-----------------------------------------------------------*
       del-rec-rdb-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento [mgs] corrispondente              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In meno                                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-reg        to   w-agg-mgs-dat-reg      .
           move      w-rig-cod-pdc (2)    to   w-agg-mgs-cod-pdc      .
           move      "-"                  to   w-agg-mgs-tip-agg      .
           move      w-rig-dar-ave (2)    to   w-agg-mgs-dar-ave      .
           move      w-rig-imp-mov (2)    to   w-agg-mgs-imp-mov      .
           perform   agg-con-000-000      thru agg-con-000-999        .
      *              *-------------------------------------------------*
      *              * Composizione chiave primaria                    *
      *              *-------------------------------------------------*
           move      w-tes-dat-reg        to   rf-rdb-dat-reg         .
           move      w-rig-num-prg (2)    to   rf-rdb-num-prg         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
       del-rec-rdb-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento [mgs] in funzione di w-agg-mgs              *
      *    *-----------------------------------------------------------*
       agg-con-000-000.
      *              *-------------------------------------------------*
      *              * Se in impostazione skeleton : uscita            *
      *              *-------------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to agg-con-000-999.
      *              *-------------------------------------------------*
      *              * Determinazione se data registrazione di fine    *
      *              * mese                                            *
      *              *-------------------------------------------------*
           move      w-agg-mgs-dat-reg    to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Se la data non e' di fine mese non si aggiorna  *
      *              * il [mgs]                                        *
      *              *-------------------------------------------------*
           if        s-sts                =    spaces
                     go to  agg-con-000-999.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio contabilita'   *
      *              *-------------------------------------------------*
           move      w-agg-mgs-dat-reg    to   w-det-ese-cge-dtr      .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *              *-------------------------------------------------*
      *              * Lettura con lock                                *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "ESECOD"             to   f-key                  .
           move      w-det-ese-cge-esa    to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      w-agg-mgs-cod-pdc    to   rf-mgs-cod-con         .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                  *---------------------------------------------*
      *                  * Se non trovato si scrive il record normaliz-*
      *                  * zato e si ritorna a leggere                 *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to  agg-con-000-250.
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
           go to     agg-con-000-000.
       agg-con-000-250.
      *                  *---------------------------------------------*
      *                  * Aggiornamento dati record [mgs]             *
      *                  *---------------------------------------------*
           perform   agg-con-000-500      thru agg-con-000-899        .
      *                  *---------------------------------------------*
      *                  * Update record [mgs]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                  *---------------------------------------------*
      *                  * Unlock file [mgs]                           *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     agg-con-000-999.
       agg-con-000-500.
      *              *-------------------------------------------------*
      *              * Subroutine interna di aggiornamento record      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione work di comodo                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-agg-mgs-wrk-dar      .
           move      zero                 to   w-agg-mgs-wrk-ave      .
           if        rf-mgs-dav-ret
                    (w-det-ese-cge-esm)   =    "A"
                     move   rf-mgs-imp-ret
                           (w-det-ese-cge-esm)
                                          to   w-agg-mgs-wrk-ave
           else      move   rf-mgs-imp-ret
                           (w-det-ese-cge-esm)
                                          to   w-agg-mgs-wrk-dar      .
      *                  *---------------------------------------------*
      *                  * Se aggiornamento in "+"                     *
      *                  *---------------------------------------------*
           if        w-agg-mgs-tip-agg    =    "-"
                     go to agg-con-000-600.
      *                      *-----------------------------------------*
      *                      * Aggiornamento work di comodo            *
      *                      *-----------------------------------------*
           if        w-agg-mgs-dar-ave    =    "A"
                     add      w-agg-mgs-imp-mov
                                          to   w-agg-mgs-wrk-ave
           else      add      w-agg-mgs-imp-mov
                                          to   w-agg-mgs-wrk-dar      .

           go to     agg-con-000-700.
       agg-con-000-600.
      *                  *---------------------------------------------*
      *                  * Se aggiornamento in "-"                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento work di comodo            *
      *                      *-----------------------------------------*
           if        w-agg-mgs-dar-ave     =    "A"
                     subtract w-agg-mgs-imp-mov
                                          from w-agg-mgs-wrk-ave
           else      subtract w-agg-mgs-imp-mov
                                          from w-agg-mgs-wrk-dar      .
       agg-con-000-700.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo rettifiche da work di   *
      *                  * comodo                                      *
      *                  *---------------------------------------------*
           move      w-agg-mgs-wrk-dar    to   rf-mgs-imp-ret
                                              (w-det-ese-cge-esm)     .
           subtract  w-agg-mgs-wrk-ave    from rf-mgs-imp-ret
                                              (w-det-ese-cge-esm)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento dare/avere rettifiche         *
      *                  *---------------------------------------------*
           if        rf-mgs-imp-ret
                    (w-det-ese-cge-esm)   >    zero
                     move   "D"           to   rf-mgs-dav-ret
                                              (w-det-ese-cge-esm)
           else if   rf-mgs-imp-ret
                    (w-det-ese-cge-esm)   <    zero
                     move   "A"           to   rf-mgs-dav-ret
                                              (w-det-ese-cge-esm)
                     multiply -1          by   rf-mgs-imp-ret
                                              (w-det-ese-cge-esm)
           else      move   spaces        to   rf-mgs-dav-ret
                                              (w-det-ese-cge-esm)     .
       agg-con-000-899.
           exit.
       agg-con-000-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Se non e' ancora stato fatto si legge la scelta *
      *              * del mese di chiusura esercizio                  *
      *              *-------------------------------------------------*
           if        w-det-ese-cge-mce    not  = zero
                     go to det-ese-cge-300.
           move      "P:"                 to   s-ope                  .
           move      "pgm/cge[mes-chi]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  s-num          to   w-det-ese-cge-mce
           else      move  12             to   w-det-ese-cge-mce      .
           if        w-det-ese-cge-mce    <    01 or
                     w-det-ese-cge-mce    >    12
                     move  12             to   w-det-ese-cge-mce      .
       det-ese-cge-300.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-det-ese-cge-dtr    to   s-dat                  .
           if        w-det-ese-cge-mce    =    12             or
                     s-mes                >    w-det-ese-cge-mce
                     move  s-saa          to   w-det-ese-cge-esa
                     go to det-ese-cge-600.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-det-ese-cge-esa      .
       det-ese-cge-600.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-det-ese-cge-esm      .
           if        w-det-ese-cge-mce    =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-det-ese-cge-mce
                     subtract w-det-ese-cge-mce
                                          from w-det-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-det-ese-cge-mce
                     add   12             to   w-det-ese-cge-esm
                     subtract w-det-ese-cge-mce
                                          from w-det-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-det-ese-cge-esm      .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

