           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
           if        w-rig-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
           move      "GB"                 to   v-edm                  .
           move      w-rig-imp-mov (1)    to   v-num                  .
