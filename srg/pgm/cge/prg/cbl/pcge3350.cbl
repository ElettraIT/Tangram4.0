      *              *-------------------------------------------------*
           if        w-srp-dar-ave        =    "A"
                     add        w-srp-imp-mov
                                          to   w-tes-sdo-reg
           else      subtract   w-srp-imp-mov
                                          from w-tes-sdo-reg          .
