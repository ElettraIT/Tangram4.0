      *                      * Valori attuali                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [rdb]                        *
      *                          *-------------------------------------*
           move      rf-rdb-num-prg       to   w-rig-num-prg (1)      .
           move      "G"                  to   w-rig-tip-con (1)      .
           move      rf-rdb-cod-pdc       to   w-rig-cod-pdc (1)      .
           move      w-rig-cod-pdc (1)    to   w-let-cod-pdc-cod      .
           perform   let-cod-pdc-000      thru let-cod-pdc-999        .
           move      w-let-cod-pdc-des    to   w-rig-des-pdc (1)      .
           move      rf-rdb-com-rig       to   w-rig-com-rig (1)      .
           move      rf-rdb-dar-ave       to   w-rig-dar-ave (1)      .
           move      rf-rdb-imp-mov       to   w-rig-imp-mov (1)      .
      *                      *-----------------------------------------*
      *                      * Valori precedenti                       *
      *                      *-----------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                      *-----------------------------------------*
      *                      * Put su catena movimenti [rig]           *
      *                      *-----------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-rdb-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Aggiornamento saldo registrazione       *
      *                      *-----------------------------------------*
           if        w-rig-dar-ave (1)    =    "A"
                     subtract  w-rig-imp-mov (1)
                                          from w-tes-sdo-reg
           else      add        w-rig-imp-mov (1)
                                          to   w-tes-sdo-reg          .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura [rdb] successivo          *
      *                  *---------------------------------------------*
           go to     rou-let-reg-300.
       rou-let-reg-800.
      *              *-------------------------------------------------*
