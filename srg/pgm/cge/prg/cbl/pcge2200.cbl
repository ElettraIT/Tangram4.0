       acc-tip-cdb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-cdb-lun    to   v-car                  .
           move      w-exp-tip-cdb-num    to   v-ldt                  .
           move      w-exp-tip-cdb-tbl    to   v-txt                  .
           move      "APOCR#"             to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      04                   to   v-lin                  .
           move      28                   to   v-pos                  .
      *
           if        w-tes-tip-cdb        =    "A"
                     move  01             to   v-num
           else if   w-tes-tip-cdb        =    "P"
                     move  02             to   v-num
           else if   w-tes-tip-cdb        =    "O"
                     move  03             to   v-num
           else if   w-tes-tip-cdb        =    "C"
                     move  04             to   v-num
           else if   w-tes-tip-cdb        =    "R"
                     move  05             to   v-num
           else      move  zero           to   v-num                  .
