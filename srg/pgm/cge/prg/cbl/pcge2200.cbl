                     move  "P"            to   w-tes-tip-cdb
           else if   v-num                =    03
                     move  "O"            to   w-tes-tip-cdb
           else if   v-num                =    04
                     move  "C"            to   w-tes-tip-cdb
           else if   v-num                =    05
