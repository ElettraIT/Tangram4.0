           if        rr-snx-tdf           =    "S"
                     go to stp-srt-inp-500.
           if        rr-tip-stp           =    "P"
                     go to stp-srt-inp-100
           else if   rr-tip-stp           =    "D"
                     go to stp-srt-inp-500.
       stp-srt-inp-100.
