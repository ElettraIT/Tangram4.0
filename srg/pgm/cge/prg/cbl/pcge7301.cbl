      *                      *-----------------------------------------*
           move      zero                 to   w-tai-ctr-002          .
       stp-srt-inp-150.
           add       1                    to   w-tai-ctr-002          .
           if        w-tai-ctr-002        >    w-tai-num-ele
                     go to stp-srt-inp-160.
           if        rf-mgi-cod-iva
                    (w-tai-ctr-001)       =    w-tai-cod-iva
                                              (w-tai-ctr-002) and
                     w-tai-cau-wrk        =    w-tai-cau-iva
                                              (w-tai-ctr-002)
                     go to stp-srt-inp-200.
           go to     stp-srt-inp-150.
       stp-srt-inp-160.
      *                          *-------------------------------------*
      *                          * Se elemento non trovato             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
