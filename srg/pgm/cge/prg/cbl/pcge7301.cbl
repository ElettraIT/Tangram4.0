           if        w-tai-ctr-001        >    6
                     go to stp-srt-inp-300.
      *                      *-----------------------------------------*
      *                      * Se codice iva a zero : riciclo          *
      *                      *-----------------------------------------*
           if        rf-mgi-cod-iva
                    (w-tai-ctr-001)       =    zero
                     go to stp-srt-inp-140.
      *                      *-----------------------------------------*
      *                      * Comodo per confronto con causale        *
      *                      *-----------------------------------------*
           move      zero                 to   w-tai-cau-wrk          .
           if        w-ref-iva-mau        =    zero
                     go to stp-srt-inp-145.
           if        rf-mgi-cod-cau       =    zero
                     go to stp-srt-inp-145.
           if        rf-mgi-cod-cau       =    w-ref-iva-mau
                     move  rf-mgi-cod-cau to   w-tai-cau-wrk          .
       stp-srt-inp-145.
      *                      *-----------------------------------------*
