           go to     agg-fil-ivp-100.
       agg-fil-ivp-040.
      *                  *---------------------------------------------*
      *                  * Tipo dichiarazione : Trimestrale            *
      *                  *---------------------------------------------*
           move      rr-ann-dic           to   w-agg-fil-ivp-wsa      .
           move      rr-mes-fin           to   w-agg-fil-ivp-wms      .
           go to     agg-fil-ivp-100.
       agg-fil-ivp-060.
      *                  *---------------------------------------------*
      *                  * Tipo dichiarazione : Annuale                *
      *                  *---------------------------------------------*
           move      rr-ann-dic           to   w-agg-fil-ivp-wsa      .
           add       1                    to   w-agg-fil-ivp-wsa      .
           move      zero                 to   w-agg-fil-ivp-wms      .
           go to     agg-fil-ivp-100.
       agg-fil-ivp-100.
      *              *-------------------------------------------------*
      *              * Ottenimento record [ivp]                        *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "ANNMESALI "         to   f-key                  .
           move      w-agg-fil-ivp-wsa    to   rf-ivp-ann-ivp         .
           move      w-agg-fil-ivp-wms    to   rf-ivp-mes-ivp         .
           move      zero                 to   rf-ivp-cod-iva         .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *              *-------------------------------------------------*
      *              * Se record non trovato                           *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to agg-fil-ivp-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ivp]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                  *---------------------------------------------*
      *                  * Ricomposizione dati chiave                  *
      *                  *---------------------------------------------*
           move      w-agg-fil-ivp-wsa    to   rf-ivp-ann-ivp         .
           move      w-agg-fil-ivp-wms    to   rf-ivp-mes-ivp         .
           move      zero                 to   rf-ivp-cod-iva         .
      *                  *---------------------------------------------*
      *                  * Scrittura record [ivp]                      *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                  *---------------------------------------------*
      *                  * Riciclo a inizio                            *
      *                  *---------------------------------------------*
           go to     agg-fil-ivp-100.
       agg-fil-ivp-200.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se credito o debito    *
      *                  *---------------------------------------------*
           if        w-tot-imp-scd        <    zero
                     go to agg-fil-ivp-220
           else      go to agg-fil-ivp-240.
       agg-fil-ivp-220.
      *                  *---------------------------------------------*
      *                  * Se iva a debito                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento progressivo imponibile    *
      *                      * vendite                                 *
      *                      *-----------------------------------------*
           move      w-tot-imp-scd        to   rf-ivp-ibl-ven         .
           multiply  -1                   by   rf-ivp-ibl-ven         .
           go to     agg-fil-ivp-300.
       agg-fil-ivp-240.
      *                  *---------------------------------------------*
      *                  * Se iva a credito                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento progressivo imponibile    *
      *                      * acquisti                                *
      *                      *-----------------------------------------*
           move      w-tot-imp-scd        to   rf-ivp-ibl-acq         .
           go to     agg-fil-ivp-300.
       agg-fil-ivp-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [ivp]                  *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                  *---------------------------------------------*
      *                  * Rilascio record [ivp]                       *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
       agg-fil-ivp-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento numero ultima pagina             *
      *    *-----------------------------------------------------------*
       agg-ult-pag-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-ylp-iva-ult-agg    =    zero
                     go to agg-ult-pag-900.
           if        rr-snx-tdf           =    "S"
                     go to agg-ult-pag-100.
           if        rr-tip-stp           not  = "D"
                     go to agg-ult-pag-900.
       agg-ult-pag-100.
      *              *-------------------------------------------------*
      *              * Lettura year last page                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Secolo anno da data iniziale                *
      *                  *---------------------------------------------*
           move      w-ylp-iva-dat-ini    to   s-dat                  .
           move      s-saa                to   w-ylp-iva-dat-saa      .
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "Yg"                 to   s-ope                  .
           move      w-ref-giv-ven-cod    to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to agg-ult-pag-400.
       agg-ult-pag-200.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "Yp"                 to   s-ope                  .
           move      w-ref-giv-ven-cod    to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           move      zero                 to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     agg-ult-pag-100.
       agg-ult-pag-400.
      *              *-------------------------------------------------*
      *              * Record esistente                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "Yu"                 to   s-ope                  .
           move      w-ref-giv-ven-cod    to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           move      w-ylp-iva-ult-agg    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione di *
      *                      * aggiornamento                           *
      *                      *-----------------------------------------*
           if        s-sts                not  = spaces
                     go to agg-ult-pag-100.
       agg-ult-pag-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-ult-pag-999.
       agg-ult-pag-999.
           exit.

