           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "------------------------------------------   -----
      -              "-------------------------------------   ----------
      -              "--------------------------------"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     prn-fin-cic-120.
       prn-fin-cic-104.
      *                      *-----------------------------------------*
      *                      * Se corrispettivi assenti                *
