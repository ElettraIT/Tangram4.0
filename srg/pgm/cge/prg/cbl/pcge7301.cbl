      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Totali fatture                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Imponibile                              *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-tot-ibl-fat        >    9999999999 or
                     w-tot-ibl-fat        <   -9999999999
                     move  13             to   p-car
                     move  "B"            to   p-edm
           else      move  10             to   p-car
                     move  "GB"           to   p-edm                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      p-lnr                to   p-lin                  .
           move      002                  to   p-pos                  .
           move      w-tot-ibl-fat        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Prompt                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
