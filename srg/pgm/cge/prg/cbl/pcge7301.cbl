      *                      *-----------------------------------------*
           if        rr-tip-dic           =    "A"
                     add   rf-ivp-ibl-ven to   w-tai-imp-vrs
                     add   rf-ivp-ibl-cor to   w-tai-cmp-ann          .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-520.
       stp-srt-inp-530.
      *                  *---------------------------------------------*
      *                  * Ricerca in tabella dell'aliquota letta      *
      *                  *---------------------------------------------*
           move      zero                 to   w-tai-ctr-001          .
       stp-srt-inp-540.
           add       1                    to   w-tai-ctr-001          .
           if        w-tai-ctr-001        >    w-tai-num-ele
                     go to stp-srt-inp-560.
           if        rf-ivp-cod-iva       =    w-tai-cod-iva
                                              (w-tai-ctr-001)
                     go to stp-srt-inp-580.
           go to     stp-srt-inp-540.
       stp-srt-inp-560.
      *                      *-----------------------------------------*
      *                      * Se elemento non trovato                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Incremento contatore elementi       *
      *                          *-------------------------------------*
           add       1                    to   w-tai-num-ele          .
      *                          *-------------------------------------*
      *                          * Inizializzazione nuovo elemento     *
      *                          *-------------------------------------*
           move      rf-ivp-cod-iva       to   w-tai-cod-iva
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-ibl-fat
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-imp-fat
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-ibl-cor
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-imp-cor
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-ibl-acq
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-imp-acq
                                              (w-tai-num-ele)         .
       stp-srt-inp-580.
      *                      *-----------------------------------------*
      *                      * Se elemento trovato                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento progressivi           *
      *                          *-------------------------------------*
           add       rf-ivp-ibl-ven       to   w-tai-ibl-fat
                                              (w-tai-ctr-001)         .
           add       rf-ivp-imp-ven       to   w-tai-imp-fat
                                              (w-tai-ctr-001)         .
           add       rf-ivp-ibl-cor       to   w-tai-ibl-cor
                                              (w-tai-ctr-001)         .
           add       rf-ivp-imp-cor       to   w-tai-imp-cor
                                              (w-tai-ctr-001)         .
           add       rf-ivp-ibl-acq       to   w-tai-ibl-acq
                                              (w-tai-ctr-001)         .
           add       rf-ivp-imp-acq       to   w-tai-imp-acq
                                              (w-tai-ctr-001)         .
       stp-srt-inp-600.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [ivp] *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-520.
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Eventuale calcolo Iva versata nell'anno         *
      *              *                                                 *
      *              * Solo se tipo stampa Annuale e di Prova          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se stampa Annuale                      *
      *                  *---------------------------------------------*
           if        rr-tip-dic           not  = "A"
                     go to  stp-srt-inp-810.
      *                  *---------------------------------------------*
      *                  * Test se stampa di prova                     *
      *                  *---------------------------------------------*
           if        rr-tip-stp           not  = "P"
                     go to  stp-srt-inp-810.
      *                  *---------------------------------------------*
      *                  * Test se stampa tipo definitiva              *
      *                  *---------------------------------------------*
           if        rr-snx-tdf           =    "S"
                     go to  stp-srt-inp-810.
      *                  *---------------------------------------------*
      *                  * Subroutine                                  *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-vrs-000  thru stp-srt-inp-vrs-999    .
       stp-srt-inp-810.
      *              *-------------------------------------------------*
      *              * Rilettura tabella con rilascio records al Sort  *
      *              * e determinazione presenza progressivi per cor-  *
      *              * rispettivi e aliquote per legenda               *
      *              *-------------------------------------------------*
           move      spaces               to   w-tai-snx-cor          .
           move      spaces               to   w-tai-snx-asc          .
           move      spaces               to   w-tai-snx-and          .
           move      spaces               to   w-tai-snx-asi          .
           move      spaces               to   w-tai-snx-mau          .
           move      zero                 to   w-tai-ctr-001          .
       stp-srt-inp-820.
           add       1                    to   w-tai-ctr-001          .
           if        w-tai-ctr-001        >    w-tai-num-ele
                     go to stp-srt-inp-880.
      *                  *---------------------------------------------*
      *                  * Eventuale attivazione Si/No presenza valori *
      *                  * per corrispettivi                           *
      *                  *---------------------------------------------*
           if        w-tai-ibl-cor
                    (w-tai-ctr-001)       not  = zero or
                     w-tai-imp-cor
                    (w-tai-ctr-001)       not  = zero
                     move  "S"            to   w-tai-snx-cor          .
      *                  *---------------------------------------------*
      *                  * Eventuale attivazione Si/No presenza ali-   *
      *                  * quota di scorporo                           *
      *                  *---------------------------------------------*
           move      w-tai-cod-iva
                    (w-tai-ctr-001)       to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    1
                     move  "S"            to   w-tai-snx-asc          .
      *                  *---------------------------------------------*
      *                  * Eventuale attivazione Si/No presenza ali-   *
      *                  * quota non deducibile                        *
      *                  *---------------------------------------------*
           if        w-edt-iva-cod-003    =    7
                     move  "S"            to   w-tai-snx-and          .
      *                  *---------------------------------------------*
      *                  * Eventuale attivazione Si/No presenza ali-   *
      *                  * quota per sola iva                          *
      *                  *---------------------------------------------*
           if        w-edt-iva-cod-003    =    9
                     move  "S"            to   w-tai-snx-asi          .
      *                  *---------------------------------------------*
      *                  * Eventuale attivazione Si/No presenza movi-  *
      *                  * menti con causale di manutenzione veicoli   *
      *                  *---------------------------------------------*
           if        w-tai-cau-iva
                    (w-tai-ctr-001)       not  = zero
                     move  "S"            to   w-tai-snx-mau          .
      *                  *---------------------------------------------*
      *                  * Composizione record di Sort                 *
      *                  *---------------------------------------------*
           move      w-tai-cod-iva
                    (w-tai-ctr-001)       to   srt-cod-iva            .
           move      w-tai-ibl-fat
                    (w-tai-ctr-001)       to   srt-ibl-fat            .
           move      w-tai-imp-fat
                    (w-tai-ctr-001)       to   srt-imp-fat            .
           move      w-tai-ibl-cor
                    (w-tai-ctr-001)       to   srt-ibl-cor            .
           move      w-tai-imp-cor
                    (w-tai-ctr-001)       to   srt-imp-cor            .
           move      w-tai-cau-iva
                    (w-tai-ctr-001)       to   srt-cau-acq            .
           move      w-tai-ibl-acq
                    (w-tai-ctr-001)       to   srt-ibl-acq            .
           move      w-tai-imp-acq
                    (w-tai-ctr-001)       to   srt-imp-acq            .
       stp-srt-inp-860.
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * Riciclo su rilettura tabella                *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-820.
       stp-srt-inp-880.
      *              *-------------------------------------------------*
      *              * Test su numero elementi per eventuale emissione *
      *              * di un record vuoto                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tai-num-ele        not  = zero
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Composizione record di Sort                 *
      *                  *---------------------------------------------*
           move      zero                 to   srt-cod-iva
                                               srt-ibl-fat
                                               srt-imp-fat
                                               srt-ibl-cor
                                               srt-imp-cor
                                               srt-cau-acq
                                               srt-ibl-acq
                                               srt-imp-acq            .
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Dichiarazione priva di movimenti ! Stampa comunque
      -              " eseguita ..."      to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di calcolo iva versata nell'anno               *
      *    *                                                           *
      *    * Solo se tipo stampa Annuale e di Prova                    *
      *    *-----------------------------------------------------------*
       stp-srt-inp-vrs-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
       stp-srt-inp-vrs-100.
      *              *-------------------------------------------------*
      *              * Start su file [ivp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ANNMESALI "         to   f-key                  .
           move      rr-ann-dic           to   rf-ivp-ann-ivp         .
           move      rr-mes-ini           to   rf-ivp-mes-ivp         .
           move      zero                 to   rf-ivp-cod-iva         .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-vrs-900.
       stp-srt-inp-vrs-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ivp]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-vrs-900.
       stp-srt-inp-vrs-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ivp-ann-ivp       not  = rr-ann-dic or
                     rf-ivp-mes-ivp       >    rr-mes-fin
                     go to stp-srt-inp-vrs-900.
       stp-srt-inp-vrs-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero                        *
      *                  *---------------------------------------------*
           if        rf-ivp-cod-iva       not  = zero
                     go to stp-srt-inp-vrs-200.
       stp-srt-inp-vrs-500.
      *              *-------------------------------------------------*
      *              * Accumulo Iva versata                            *
      *              *-------------------------------------------------*
           add       rf-ivp-ibl-ven       to   w-tai-imp-vrs          .
       stp-srt-inp-vrs-600.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-vrs-200.
       stp-srt-inp-vrs-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-vrs-999.
       stp-srt-inp-vrs-999.
           exit.

      *    *===========================================================*
