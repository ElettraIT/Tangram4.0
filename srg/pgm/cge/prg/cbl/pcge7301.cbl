      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per fine ciclo          *
      *    *                                                           *
      *    * Stampa riepiloghi CEE, Reverse Charge e Split Payment     *
      *    *-----------------------------------------------------------*
       prn-fin-cic-rca-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione area totali                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-tot-ibl-ace          .
           move      zero                 to   w-tot-imp-ace          .
           move      zero                 to   w-tot-ibl-sce          .
           move      zero                 to   w-tot-imp-sce          .
           move      zero                 to   w-tot-ibl-faa          .
           move      zero                 to   w-tot-imp-faa          .
           move      zero                 to   w-tot-ibl-fsp          .
           move      zero                 to   w-tot-imp-fsp          .
       prn-fin-cic-rca-100.
      *              *-------------------------------------------------*
      *              * Start su file [mgi]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATPRT    "         to   f-key                  .
           move      rr-dat-ini           to   rf-mgi-dat-reg         .
           move      zero                 to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-fin-cic-rca-800.
       prn-fin-cic-rca-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [mgi]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-fin-cic-rca-800.
       prn-fin-cic-rca-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-mgi-dat-reg       >    rr-dat-fin
                     go to prn-fin-cic-rca-800.
       prn-fin-cic-rca-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se Split Payment                       *
      *                  *---------------------------------------------*
           if        rf-mgi-flg-rfp       not  = "S"
                     go to prn-fin-cic-rca-420.
      *                  *---------------------------------------------*
      *                  * Incremento totali Split Payment             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se nota credito                         *
      *                      *-----------------------------------------*
           if        rf-mgi-tip-iva       =    "2"
                     subtract rf-mgi-ibl-iva (01)
                                          from w-tot-ibl-fsp
                     subtract rf-mgi-imp-iva (01)
                                          from w-tot-imp-fsp          .
      *                      *-----------------------------------------*
      *                      * Se fattura                              *
      *                      *-----------------------------------------*
           if        rf-mgi-tip-iva       =    "1"
                     add      rf-mgi-ibl-iva (01)
                                          to   w-tot-ibl-fsp
                     add      rf-mgi-imp-iva (01)
                                          to   w-tot-imp-fsp          .
      *                  *---------------------------------------------*
      *                  * A riciclo			               *
      *                  *---------------------------------------------*
           go to 	prn-fin-cic-rca-200.
       prn-fin-cic-rca-420.
      *                  *---------------------------------------------*
      *                  * Test su tipo iva                            *
      *                  *---------------------------------------------*
           if        rf-mgi-tip-iva       not  = "D" and
                     rf-mgi-tip-iva       not  = "E" and
                     rf-mgi-tip-iva       not  = "5"
                     go to prn-fin-cic-rca-200.
       prn-fin-cic-rca-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento totali CEE                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [zcc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
