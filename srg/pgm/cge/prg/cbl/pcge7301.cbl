      *              *-------------------------------------------------*
           if        w-tai-snx-asc        =    spaces and
                     w-tai-snx-and        =    spaces and
                     w-tai-snx-asi        =    spaces and
                     w-tai-snx-mau        =    spaces
                     go to stp-lgd-civ-999.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe necessario          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 2 interlinee di separazione dai totali      *
      *                  *---------------------------------------------*
           move      2                    to   w-stp-lgd-civ-nrn      .
      *                  *---------------------------------------------*
      *                  * 2 linee per trattini                        *
      *                  *---------------------------------------------*
           add       2                    to   w-stp-lgd-civ-nrn      .
      *                  *---------------------------------------------*
      *                  * Linea per aliquota di scorporo              *
      *                  *---------------------------------------------*
           if        w-tai-snx-asc        =    "S"
                     add   1              to   w-stp-lgd-civ-nrn      .
      *                  *---------------------------------------------*
      *                  * Linea per aliquota non deducibile           *
      *                  *---------------------------------------------*
           if        w-tai-snx-and        =    "S"
                     add   1              to   w-stp-lgd-civ-nrn      .
      *                  *---------------------------------------------*
      *                  * Linea per aliquota per sola iva             *
      *                  *---------------------------------------------*
           if        w-tai-snx-asi        =    "S"
                     add   1              to   w-stp-lgd-civ-nrn      .
      *                  *---------------------------------------------*
      *                  * Linea per causale manutenzione veicoli      *
      *                  *---------------------------------------------*
           if        w-tai-snx-mau        =    "S"
                     add   1              to   w-stp-lgd-civ-nrn      .
      *              *-------------------------------------------------*
      *              * Test se righe residue sufficienti               *
      *              *-------------------------------------------------*
           if        p-res                >    w-stp-lgd-civ-nrn
                     go to stp-lgd-civ-100.
