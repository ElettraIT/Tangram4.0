      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Deviazione in funzione del  *
      *                                  * tipo record                 *
      *                                  *-----------------------------*
           if        rf-mgi-tip-rec       =    "C"
                     go to stp-srt-inp-220
           else if   rf-mgi-tip-rec       =    "F"
                     go to stp-srt-inp-240
           else if   rf-mgi-tip-rec       =    "V"
                     go to stp-srt-inp-260.
       stp-srt-inp-220.
      *                                  *-----------------------------*
      *                                  * Tipo record : Cliente       *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Test su flag di regime  *
      *                                      * fiscale particolare:    *
      *                                      * scissione dei pagamenti *
      *                                      * (Split Payement)        *
      *                                      *-------------------------*
           if        rf-mgi-flg-rfp       not  = "S"
                     go to stp-srt-inp-221.
      *                                      *-------------------------*
      *                                      * L'imposta viene azzera- *
      *                                      * ta                      *
      *                                      *-------------------------*
           move      zero                 to   rf-mgi-imp-iva
                                              (w-tai-ctr-001)         .
       stp-srt-inp-221.
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "1" or
                     rf-mgi-tip-iva       =    "A"
                     go to stp-srt-inp-222
           else if   rf-mgi-tip-iva       =    "2" or
                     rf-mgi-tip-iva       =    "B"
                     go to stp-srt-inp-224
           else      go to stp-srt-inp-280.
       stp-srt-inp-222.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare clienti *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
       stp-srt-inp-224.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere clien- *
      *                                      * ti                      *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
       stp-srt-inp-240.
      *                                  *-----------------------------*
      *                                  * Tipo record : Fornitore     *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Test su flag di regime  *
      *                                      * fiscale particolare:    *
      *                                      * reverse charge          *
      *                                      *                         *
      *                                      * ___ DA FARE ??? ___     *
      *                                      *-------------------------*

      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "5" or
                     rf-mgi-tip-iva       =    "6"
                     go to stp-srt-inp-242
           else if   rf-mgi-tip-iva       =    "4"
                     go to stp-srt-inp-244
           else if   rf-mgi-tip-iva       =    "E"
                     go to stp-srt-inp-246
           else if   rf-mgi-tip-iva       =    "D"
                     go to stp-srt-inp-248
           else      go to stp-srt-inp-280.
       stp-srt-inp-242.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere forni- *
      *                                      * tori Italia             *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
       stp-srt-inp-244.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare forni-  *
      *                                      * tori Italia             *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
       stp-srt-inp-246.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere forni- *
      *                                      * tori CEE                *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
       stp-srt-inp-248.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare forni-  *
      *                                      * tori CEE                *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
       stp-srt-inp-260.
      *                                  *-----------------------------*
      *                                  * Tipo record : Corrispettivi *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "3"
                     go to stp-srt-inp-262
           else      go to stp-srt-inp-280.
       stp-srt-inp-262.
      *                                      *-------------------------*
      *                                      * Tipo iva : Corrispetti- *
      *                                      * vi                      *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-cor
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-cor
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-280.
