      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ANNMESALI "         to   f-key                  .
           move      rr-ann-dic           to   rf-ivp-ann-ivp         .
           move      rr-mes-ini           to   rf-ivp-mes-ivp         .
           move      zero                 to   rf-ivp-cod-iva         .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-800.
       stp-srt-inp-520.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [ivp]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofivp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ivp                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At End'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-800.
