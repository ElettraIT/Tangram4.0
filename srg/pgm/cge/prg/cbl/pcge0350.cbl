      *                  *---------------------------------------------*
           if        w-rig-tip-doc        =    spaces
                     move  spaces         to   w-lin-imm-tip-doc
           else if   w-rig-tip-doc        =    "F"
                     move  "Fattura       "
                                          to   w-lin-imm-tip-doc
           else if   w-rig-tip-doc        =    "M"
