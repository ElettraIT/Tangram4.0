                     move  "Corrispettivi "
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "4"
                     move  "Dare Fo no CEE"
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "5"
                     move  "Aver Fo no CEE"
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "6"
                     move  "Bolla doganale"
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "A"
                     move  "Dare Cli Cee  "
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "B"
                     move  "Avere Cli Cee "
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "D"
                     move  "Dare For Cee  "
                                          to   w-lin-imm-tip-moi
           else if   w-rig-tip-moi        =    "E"
                     move  "Avere For Cee "
                                          to   w-lin-imm-tip-moi
           else      move  spaces         to   w-lin-imm-tip-moi      .
      *
           if        w-rig-snx-bil        not  = "N"
                     move  "(di bilancio) "
