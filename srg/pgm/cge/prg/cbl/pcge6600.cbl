           if        rr-acq-max           =    zero
                     go to tdo-ric-sel-300.
           if        rr-acq-max           not  < rr-acq-min
                     go to tdo-ric-sel-300.
           move      "Data acquisto massima inferiore alla minima !"
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
