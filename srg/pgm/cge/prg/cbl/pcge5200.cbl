           cancel    "swd/mod/prg/obj/mmessg"                         .
       exe-pgm-bkg-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-esecuzione programma                          *
      *    *-----------------------------------------------------------*
       pre-exe-pgm-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-pre-exe-pgm      .
       pre-exe-pgm-010.
      *              *-------------------------------------------------*
      *              * Lettura personalizzazioni                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Mese di chiusura esercizio                  *
      *                  *---------------------------------------------*
           perform   prs-mes-chi-000      thru prs-mes-chi-999        .
       pre-exe-pgm-020.
      *              *-------------------------------------------------*
      *              * Lettura dati relativi alla chiusura bilanci     *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/indatbil"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-bil             .
      *              *-------------------------------------------------*
      *              * Lettura dati relativi partitari fornitori       *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
      *              *-------------------------------------------------*
      *              * Determinazione valore data iniziale in caso di  *
      *              * stampa definitiva                               *
      *              *-------------------------------------------------*
           if        rn-par-fnt-dat-fin   not  = zero
                     go to pre-exe-pgm-300.
      *                  *---------------------------------------------*
      *                  * Se data finale ultimo partitario non tro-   *
      *                  * vata : determinazione data registrazione    *
      *                  * primo movimento                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Apertura file [mgr]                     *
      *                      *-----------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Normalizzazione flag di esito lettura   *
      *                      * [mgr]                                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-wrk-flg-mgr          .
      *                      *-----------------------------------------*
      *                      * Start su  file [mgr]                    *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATREG"             to   f-key                  .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
           if        f-sts                not  = e-not-err
                     go to  pre-exe-pgm-100.
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  pre-exe-pgm-075.
       pre-exe-pgm-050.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale file [mgr]          *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'at end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  pre-exe-pgm-075.
      *                      *-----------------------------------------*
      *                      * Selezione sul record                    *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       not  = "C"
                     go to pre-exe-pgm-050.
      *                      *-----------------------------------------*
      *                      * Attivazione flag di lettura [mgr]       *
      *                      *-----------------------------------------*
           move      "#"                  to   w-wrk-flg-mgr          .
       pre-exe-pgm-075.
      *                      *-----------------------------------------*
      *                      * Chiusura file [mgr]                     *
      *                      *-----------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su flag di lettura [mgr]           *
      *                      *-----------------------------------------*
           if        w-wrk-flg-mgr        not  = spaces
                     go to  pre-exe-pgm-200.
       pre-exe-pgm-100.
      *                      *-----------------------------------------*
      *                      * Se record non trovato                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "ME"                 to   v-ope                  .
           move      "Nessuna registrazione di contabilita' fornitori da
      -              " stampare; il programma "
                                          to   v-nt1                  .
           move      "pertanto non puo' essere eseguito"
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Flag di interruzione programma      *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-pre-exe-pgm      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     pre-exe-pgm-999.
       pre-exe-pgm-200.
      *                      *-----------------------------------------*
      *                      * Determinazione anno di esercizio        *
      *                      *-----------------------------------------*
           move      rf-mgr-dat-reg       to   w-ese-cge-dtr          .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
           move      w-ese-cge-esa        to   w-std-ann-ese          .
      *                      *-----------------------------------------*
      *                      * Determinazione primo giorno anno di e-  *
      *                      * sercizio                                *
      *                      *-----------------------------------------*
           move      zero                 to   s-dat                  .
           move      w-ese-cge-esa        to   s-saa                  .
           if        w-ese-cge-mce        =    12
                     move   01            to   s-mes
           else      move   w-ese-cge-mce to   s-mes
                     add    1             to   s-mes                  .
           move      01                   to   s-gio                  .
           move      s-dat                to   w-std-dat-ini          .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pre-exe-pgm-999.
       pre-exe-pgm-300.
      *                  *---------------------------------------------*
      *                  * Se data finale ultimo partitario trovata    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se stampa partitario ancora in corso :  *
      *                      * uscita                                  *
      *                      *-----------------------------------------*
           if        rn-par-fnt-flg-avs   not  = spaces
                     go to  pre-exe-pgm-999.
      *                      *-----------------------------------------*
      *                      * Controllo data                          *
      *                      *-----------------------------------------*
           move      rn-par-fnt-dat-fin   to   s-dat                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to  pre-exe-pgm-400.
      *                          *-------------------------------------*
      *                          * Se esito negativo                   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "ME"                 to   v-ope                  .
           move      "Attenzione : la data ultima stampa partitario non 
      -              "risulta corretta; il programma"
                                          to   v-nt1                  .
           move      "pertanto non puo' essere eseguito"
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Flag di interruzione programma  *
      *                              *---------------------------------*
           move      "#"                  to   w-cnt-pre-exe-pgm      .
      *                              *---------------------------------*
      *                              * Uscita                          *
      *                              *---------------------------------*
           go to     pre-exe-pgm-999.
       pre-exe-pgm-400.
      *                      *-----------------------------------------*
      *                      * Calcolo del giorno seguente             *
      *                      *-----------------------------------------*
           move      rn-par-fnt-dat-fin   to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to pre-exe-pgm-900.
           move      1                    to   s-gio                  .
           add       1                    to   s-mes                  .
           if        s-mes                not  > 12
                     go to pre-exe-pgm-900.
           move      1                    to   s-mes                  .
           add       1                    to   s-saa                  .
       pre-exe-pgm-900.
           move      s-dat                to   w-std-dat-ini          .
       pre-exe-pgm-999.
           exit.

      *    *===========================================================*
      *    * Lettura delle personalizzazione relativa al mese di       *
      *    * chiusura esercizio                                        *
      *    *-----------------------------------------------------------*
       prs-mes-chi-000.
      *              *-------------------------------------------------*
      *              * Lettura scelta mese di chiusura bilancio        *
      *              *-------------------------------------------------*
           move      "P:"                 to   s-ope                  .
           move      "pgm/cge[mes-chi]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  s-num          to   w-ese-cge-mce
           else      move  12             to   w-ese-cge-mce          .
           if        w-ese-cge-mce        <    01 or
                     w-ese-cge-mce        >    12
                     move  12             to   w-ese-cge-mce          .
       prs-mes-chi-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-ese-cge-dtr        to   s-dat                  .
           if        w-ese-cge-mce        =    12         or
                     s-mes                >    w-ese-cge-mce
                     move  s-saa          to   w-ese-cge-esa
                     go to det-ese-cge-500.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-ese-cge-esa          .
       det-ese-cge-500.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-ese-cge-esm          .
           if        w-ese-cge-mce        =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-ese-cge-mce
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-ese-cge-mce
                     add   12             to   w-ese-cge-esm
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-ese-cge-esm          .
       det-ese-cge-999.
           exit.

