                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-fnt-max-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-fnt-max-100.
       acc-fnt-max-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su data minima e massima              *
      *              *-------------------------------------------------*
           if        rr-dat-max           =    zero
                     go to tdo-ric-sel-200.
           if        rr-dat-max           not  < rr-dat-min
                     go to tdo-ric-sel-200.
           move      "La data massima non puo' essere inferiore a quella
      -              " minima !      "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su codice min e max                   *
      *              *-------------------------------------------------*
           if        rr-fnt-max           =    zero
                     go to tdo-ric-sel-800.
           if        rr-fnt-max           not  < rr-fnt-min
                     go to tdo-ric-sel-800.
           move      "Il codice finale non puo' essere inferiore all'ini
      -              "ziale !        "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      spaces               to   rr-tip-stp             .
           move      zero                 to   rr-dat-min             .
           move      zero                 to   rr-dat-max             .
           move      zero                 to   rr-fnt-min             .
           move      zero                 to   rr-fnt-max             .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Data min - max                                  *
      *              *-------------------------------------------------*
           if        rr-dat-max           not  = zero
                     go to reg-ric-sel-200.
           if        rr-dat-min           =    zero
                     move  9999999        to   rr-dat-max
           else      move  rr-dat-min     to   rr-dat-max             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Codice min e max                                *
      *              *-------------------------------------------------*
           if        rr-fnt-min           =    zero and
                     rr-fnt-max           =    zero
                     move   9999999       to   rr-fnt-max
           else if   rr-fnt-min           not  = zero and
                     rr-fnt-max           =    zero
                     move  rr-fnt-min     to   rr-fnt-max             .
       reg-ric-sel-300.
       
      *              *-------------------------------------------------*
      *              * Se stampa di prova o flag di stampa partitari   *
      *              * gia' in corso attivo : uscita                   *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    "P"   or
                     rn-par-fnt-flg-avs   not  = spaces
                     go to  reg-ric-sel-999.
      *              *-------------------------------------------------*
      *              * Aggiornamento numerazioni partitari contabilita'*
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Open                                        *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
      *                  *---------------------------------------------*
      *                  * Preparazione date                           *
      *                  *---------------------------------------------*
           move      rr-dat-min           to   rn-par-fnt-dat-ini     .
           move      rr-dat-max           to   rn-par-fnt-dat-fin     .
           move      "#"                  to   rn-par-fnt-flg-avs     .
      *                  *---------------------------------------------*
      *                  * Update                                      *
      *                  *---------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
      *                  *---------------------------------------------*
      *                  * Close                                       *
      *                  *---------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inparfnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-par-fnt             .
       reg-ric-sel-999.
           exit.

