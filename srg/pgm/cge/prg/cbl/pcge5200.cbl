      *                  * Determinazione anno esercizio data finale   *
      *                  *---------------------------------------------*
           move      rr-dat-max           to   w-ese-cge-dtr          .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
           move      w-ese-cge-esa        to   w-stp-ese-fin          .
      *                  *---------------------------------------------*
      *                  * Se data massima a zero si saltano tutti i   *
      *                  * controlli per dare possibilita' tasto 'UP'  *
      *                  *---------------------------------------------*
           if        rr-dat-max           =    zero
                     go to acc-dat-max-600.
      *                      *-----------------------------------------*
      *                      * Se data iniziale e finale non dello     *
      *                      * stesso esercizio                        *
      *                      *-----------------------------------------*
           if        w-stp-ese-ini        =    w-stp-ese-fin
                     go to acc-dat-max-420.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Le date iniziale e finale devono appartenere allo 
      -              "stesso eserc.! "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Emissione messaggio                 *
      *                          *-------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Riciclo su impostazione             *
      *                          *-------------------------------------*
           go to     acc-dat-max-100.
       acc-dat-max-420.
      *                  *---------------------------------------------*
      *                  * Se stampa definitiva si controlla anche che *
      *                  * la data sia a fine mese                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-tip-stp           =    "P"
                     go to acc-dat-max-600.
      *                      *-----------------------------------------*
      *                      * Calcolo                                 *
      *                      *-----------------------------------------*
           move      rr-dat-max           to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     go to acc-dat-max-600.
      *                      *-----------------------------------------*
      *                      * Se non a fine mese                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "La data finale deve essere di fine mese"
                                          to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Emissione messaggio                 *
      *                          *-------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Riciclo su impostazione             *
      *                          *-------------------------------------*
           go to     acc-dat-max-100.
       acc-dat-max-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-max-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-max-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-max-100.
       acc-dat-max-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice min                           *
      *    *-----------------------------------------------------------*
       acc-fnt-min-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-fnt-min-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-fnt-ope      .
           move      rr-fnt-min           to   w-cod-mne-fnt-cod      .
           move      11                   to   w-cod-mne-fnt-lin      .
           move      29                   to   w-cod-mne-fnt-pos      .
           move      zero                 to   w-cod-mne-fnt-rln      .
           move      zero                 to   w-cod-mne-fnt-rps      .
           move      zero                 to   w-cod-mne-fnt-vln      .
           move      zero                 to   w-cod-mne-fnt-vps      .
           move      zero                 to   w-cod-mne-fnt-lln      .
           move      zero                 to   w-cod-mne-fnt-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-fnt-foi-000  thru cod-mne-fnt-foi-999    .
       acc-fnt-min-110.
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
           if        w-cod-mne-fnt-ope    =    "F+"
                     go to acc-fnt-min-115.
           if        w-cod-mne-fnt-ope    =    "AC"
                     go to acc-fnt-min-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fnt-min-115.
           perform   cod-mne-fnt-foi-000  thru cod-mne-fnt-foi-999    .
           go to     acc-fnt-min-110.
       acc-fnt-min-120.
           move      w-cod-mne-fnt-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-fnt-min-999.
       acc-fnt-min-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-fnt-min             .
       acc-fnt-min-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-fnt-min-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fnt-min-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-fnt-min-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-fnt-min-100.
       acc-fnt-min-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice max                           *
      *    *-----------------------------------------------------------*
       acc-fnt-max-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-fnt-max-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-fnt-ope      .
           move      rr-fnt-max           to   w-cod-mne-fnt-cod      .
           move      11                   to   w-cod-mne-fnt-lin      .
           move      65                   to   w-cod-mne-fnt-pos      .
           move      zero                 to   w-cod-mne-fnt-rln      .
           move      zero                 to   w-cod-mne-fnt-rps      .
           move      zero                 to   w-cod-mne-fnt-vln      .
           move      zero                 to   w-cod-mne-fnt-vps      .
           move      zero                 to   w-cod-mne-fnt-lln      .
           move      zero                 to   w-cod-mne-fnt-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
