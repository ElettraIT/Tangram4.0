      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-let-seq-200.
      *              *-------------------------------------------------*
      *              * Test se flag di fine attivo                     *
      *              *-------------------------------------------------*
           if        w-wrk-flg-fin        not  = spaces
                     go to  prn-let-seq-900.
      *              *-------------------------------------------------*
      *              * Tipo operazione: Read Next se stampa di prova   *
      *              *                  Get  Next se stampa definitiva *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    "P" or
                     rr-tip-stp           =    "R"
                     move   "RN"          to   f-ope
           else      move   "GN"          to   f-ope                  .
      *              *-------------------------------------------------*
      *              * Richiamo modulo di input-output                 *
      *              *-------------------------------------------------*
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *              *-------------------------------------------------*
      *              * Test se 'At End'                                *
      *              *-------------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  prn-let-seq-900.
      *              *-------------------------------------------------*
      *              * Test se fine logica                             *
      *              *-------------------------------------------------*
           if        rf-mgi-tip-rec       not  = "V"
                     go to  prn-let-seq-900.
           if        rf-mgi-dat-reg       >    rr-dat-fin
                     go to  prn-let-seq-900.
      *              *-------------------------------------------------*
      *              * Test se cambio numerazione                      *
      *              *-------------------------------------------------*
           if        rf-mgi-cod-num       =    rr-num-num
                     go to prn-let-seq-999.
       prn-let-seq-500.
      *              *-------------------------------------------------*
      *              * Se cambio numerazione                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se numerazione letta inferiore o supe- *
      *                  * riore a quella trattata                     *
      *                  *---------------------------------------------*
           if        rf-mgi-cod-num       >    rr-num-num
                     go to prn-let-seq-525.
           move      rf-mgi-dat-reg       to   s-dat                  .
           go to     prn-let-seq-550.
       prn-let-seq-525.
      *                  *---------------------------------------------*
      *                  * Incremento data                             *
      *                  *---------------------------------------------*
           move      rf-mgi-dat-reg       to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to prn-let-seq-550.
           move      01                   to   s-gio                  .
           add       01                   to   s-mes                  .
           if        s-mes                not  > 12
                     go to prn-let-seq-550.
           move      01                   to   s-mes                  .
           add       01                   to   s-saa                  .
       prn-let-seq-550.
      *                  *---------------------------------------------*
      *                  * Re-start su nuova data                      *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATDOC"             to   f-key                  .
           move      "V"                  to   rf-mgi-tip-rec         .
           move      s-dat                to   rf-mgi-dat-reg         .
           move      rr-num-num           to   rf-mgi-cod-num         .
           move      zero                 to   rf-mgi-prt-iva         .
           move      zero                 to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : fine                      *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  prn-let-seq-900.
      *                  *---------------------------------------------*
      *                  * Riciclo su Next                             *
      *                  *---------------------------------------------*
           go to     prn-let-seq-200.
       prn-let-seq-900.
      *              *-------------------------------------------------*
      *              * Se fine file                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-prn-flg-sub      .
      *                  *---------------------------------------------*
      *                  * Se stampa di prova o ristampa : uscita      *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "P" or
                     rr-tip-stp           =    "R"
                     go to prn-let-seq-999.
      *                  *---------------------------------------------*
      *                  * Rilascio record [mgi]                       *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
       prn-let-seq-999.
           exit.

