      *              *-------------------------------------------------*
      *              * Elaborazione registrazione iva                  *
      *              *-------------------------------------------------*
           perform   ela-reg-iva-000      thru ela-reg-iva-999        .
      *              *-------------------------------------------------*
      *              * Se stampa provvisoria si procede comunque nel   *
      *              * dettaglio                                       *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    "P" or
                     rr-tip-stp           =    "R"
                     go to  prn-liv-det-100.
      *              *-------------------------------------------------*
      *              * Se stampa definitiva si controlla se il flag di *
      *              * stampa giornale e' a 'S'; se si' si salta il    *
      *              * dettaglio                                       *
      *              *-------------------------------------------------*
           if        rf-mgi-flg-gio       =    "S"
                     go to  prn-liv-det-500.
      *              *-------------------------------------------------*
      *              * Ciclo di dettaglio                              *
      *              *-------------------------------------------------*
       prn-liv-det-100.
           move      zero                 to   w-wrk-ctr-003          .
       prn-liv-det-200.
           add       1                    to   w-wrk-ctr-003          .
           if        w-wrk-ctr-003        >    6
                     go to  prn-liv-det-500.
           if        w-wrk-cst-ibl
                    (w-wrk-ctr-003)       =    zero and
                     w-wrk-cst-cod
                    (w-wrk-ctr-003)       =    zero and
                     w-wrk-cst-imp
                    (w-wrk-ctr-003)       =    zero
                     go to  prn-liv-det-200.
      *              *-------------------------------------------------*
      *              * Se richiesta stampa del riepilogo finale si ag- *
      *              * giornano i totali per aliquota                  *
      *              *-------------------------------------------------*
           if        rr-rie-fin           =    "N"
                     go to  prn-liv-det-300.
           perform   agg-rie-fin-000      thru agg-rie-fin-999        .
       prn-liv-det-300.
      *              *-------------------------------------------------*
      *              * Se numero linee residue insufficiente per una   *
      *              * ulteriore linea : intestazione foglio           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se stampa definitiva: sufficiente un'inter- *
      *                  * linea                                       *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "D" or
                     rr-tip-stp           =    "R"
                     if     p-res         >    zero
                     go to  prn-liv-det-350.
      *                  *---------------------------------------------*
      *                  * Se stampa di prova: sufficienti due inter-  *
      *                  * linee                                       *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    "P"
                     if     p-res         >    1
                     go to  prn-liv-det-350.
      *                  *---------------------------------------------*
      *                  * Intestazione foglio                         *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                      *-----------------------------------------*
      *                      * Se errori di i-o : uscita               *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-350.
      *              *-------------------------------------------------*
      *              * Se stampa definitiva si prosegue                *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    "D" or
                     rr-tip-stp           =    "R"
                     go to  prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Altrimenti si esegue un'interlinea              *
      *              *-------------------------------------------------*
           if        w-wrk-ctr-003        not  = 1
                     go to  prn-liv-det-400.
           move      "VS"                 to   p-ope                  .
           add       1
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero riga da stam- *
      *              * pare                                            *
      *              *-------------------------------------------------*
           if        w-wrk-ctr-003        =    1
                     go to  prn-liv-det-410
           else      go to  prn-liv-det-420.
       prn-liv-det-410.
      *              *-------------------------------------------------*
      *              * Prima riga di dettaglio                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data registrazione                          *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      p-lnr                to   p-lin                  .
           move      01                   to   p-pos                  .
           move      rf-mgi-dat-reg       to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
