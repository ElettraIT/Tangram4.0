           if        rr-tip-stp           =    "P"
                     go to prn-sel-rec-100.
           if        rf-mgi-flg-gio       not   = spaces and
                     rr-tip-stp           =     "D"
                     go to prn-sel-rec-900.
           if        rf-mgi-flg-gio       =     spaces and
                     rr-tip-stp           =     "R"
                     go to prn-sel-rec-900.
       prn-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Richiamo routine di lettura causale contabile   *
      *              *-------------------------------------------------*
           perform   let-tbl-cau-000      thru let-tbl-cau-999        .
