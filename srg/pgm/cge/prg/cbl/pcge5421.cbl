      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si                    *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [fnt]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    "C"
                     go to stp-srt-inp-020
           else if   rr-tip-ord           =    "R"
                     go to stp-srt-inp-040
           else if   rr-tip-ord           =    "M"
                     go to stp-srt-inp-060.
       stp-srt-inp-020.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start per codice                        *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODFNT    "         to   f-key                  .
           move      rr-cod-min           to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * A controllo esito operazione            *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-080.
       stp-srt-inp-040.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per ragione sociale          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start per ragione sociale in uppercase  *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RAGKEY    "         to   f-key                  .
           move      rr-rag-min           to   rf-fnt-rag-key         .
           move      zero                 to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * A controllo esito operazione            *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-080.
       stp-srt-inp-060.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per mnemonico                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start per mnemonico                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODMNE    "         to   f-key                  .
           move      rr-mne-min           to   rf-fnt-cod-mne         .
           move      zero                 to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * A controllo esito operazione            *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-080.
       stp-srt-inp-080.
      *                  *---------------------------------------------*
      *                  * Controllo esito operazione                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [fnt]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    "C"
                     go to stp-srt-inp-122
           else if   rr-tip-ord           =    "R"
                     go to stp-srt-inp-124
           else if   rr-tip-ord           =    "M"
                     go to stp-srt-inp-126.
       stp-srt-inp-122.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test per codice                         *
      *                      *-----------------------------------------*
           if        rf-fnt-cod-fnt       >    rr-cod-max
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni sul record                  *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-140.
       stp-srt-inp-124.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per ragione sociale          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su Ragione sociale                 *
      *                      *-----------------------------------------*
           if        rf-fnt-rag-key       >    rr-rag-max
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni sul record                  *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-140.
       stp-srt-inp-126.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per mnemonico                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su Mnemonico                       *
      *                      *-----------------------------------------*
           if        rf-fnt-cod-mne       >    rr-mne-max
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni sul record                  *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-140.
       stp-srt-inp-140.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice fornitore                    *
      *                  *---------------------------------------------*
           if        rf-fnt-cod-fnt       <    rr-cod-min or
                     rf-fnt-cod-fnt       >    rr-cod-max
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su ragione sociale fornitore           *
      *                  *---------------------------------------------*
           if        rf-fnt-rag-key       <    rr-rag-min or
                     rf-fnt-rag-key       >    rr-rag-max
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su mnemonico fornitore                 *
      *                  *---------------------------------------------*
           if        rf-fnt-cod-mne       <    rr-mne-min or
                     rf-fnt-cod-mne       >    rr-mne-max
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su partita iva fornitore               *
      *                  *---------------------------------------------*
           if        rf-fnt-prt-iva       <    rr-pti-min or
                     rf-fnt-prt-iva       >    rr-pti-max
                     go to stp-srt-inp-100.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Caricamento partite fornitore                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura partita        *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-srt-inp-rdr      .
           move      spaces               to   w-stp-srt-inp-rnr      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione saldo partita              *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-srt-inp-sdp      .
      *                  *---------------------------------------------*
      *                  * Start su file [mgr]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      "F"                  to   rf-mgr-tip-arc         .
           move      rf-fnt-cod-fnt       to   rf-mgr-cod-arc         .
           move      rr-dat-chi           to   rf-mgr-dat-rif         .
           move      spaces               to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-300.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Indicatore di programma in esecuzione       *
      *                  *---------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mgr]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At End'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-mgr-tip-arc       not  = "F"         or
                     rf-mgr-cod-arc       not  = rf-fnt-cod-fnt
                     go to stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-reg       >    rr-dat-esc
                     go to stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Se rottura della partita                    *
      *                  *---------------------------------------------*
           if        rf-mgr-dat-rif       =    w-stp-srt-inp-rdr and
                     rf-mgr-num-rif       =    w-stp-srt-inp-rnr
                     go to stp-srt-inp-240.
      *                      *-----------------------------------------*
      *                      * Esecuzione subroutine per fine partita  *
      *                      *-----------------------------------------*
           perform   stp-srt-inp-900      thru stp-srt-inp-909        .
      *                      *-----------------------------------------*
      *                      * Esecuzione subroutine per inizio partita*
      *                      *-----------------------------------------*
           perform   stp-srt-inp-910      thru stp-srt-inp-919        .
       stp-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo partita                 *
      *                  *---------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-stp-srt-inp-sdp
           else      add      rf-mgr-imp-mov
                                          to   w-stp-srt-inp-sdp      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [mgr] *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-220.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per fine partita      *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-900      thru stp-srt-inp-909        .
      *              *-------------------------------------------------*
      *              * Riciclo su prossimo fornitore                   *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-900.
      *              *=================================================*
      *              * Subroutine interna per fine partita             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se solo partite aperte e saldo partita a    *
      *                  * zero : uscita                               *
      *                  *---------------------------------------------*
           if        rr-snx-chi           =    "N"  and
                     w-stp-srt-inp-sdp    =    zero
                     go to stp-srt-inp-909.
      *                  *---------------------------------------------*
      *                  * Test su soglia minima                       *
      *                  *---------------------------------------------*
           if        rr-sgl-min           =    zero
                     go to stp-srt-inp-905.
           move      w-stp-srt-inp-sdp    to   w-stp-srt-inp-sda      .
           if        w-stp-srt-inp-sda    <    rr-sgl-min
                     go to stp-srt-inp-909.
