      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su [cea] per categoria                    *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CGSDES    "         to   f-key                  .
           move      rr-cla-csp           to   rf-cea-cla-csp         .
           move      zero                 to   rf-cea-gru-csp         .
           move      zero                 to   rf-cea-sgr-csp         .
           move      spaces               to   rf-cea-des-key         .
           move      zero                 to   rf-cea-cod-csp         .
           move      "pgm/cge/fls/ioc/obj/iofcea"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cea                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [cea]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcea"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cea                 .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : uscita                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data massima                        *
      *                  *---------------------------------------------*
           if        rr-cla-csp           =    zero
                     go to stp-srt-inp-400.
           if        rf-cea-cla-csp       not  = rr-cla-csp
                     go to stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione status cespite               *
      *                  *---------------------------------------------*
           perform   det-sts-csp-000      thru det-sts-csp-999        .
      *                  *---------------------------------------------*
      *                  * Selezioni su data di acquisto               *
      *                  *---------------------------------------------*
           if        d-mov-csp-dat-acq    =    zero
                     go to stp-srt-inp-200.
           move      d-mov-csp-dat-acq    to   s-dat                  .
           if        s-saa                =    rr-ann-ese
                     go to stp-srt-inp-500.
           if        s-saa                >    rr-ann-ese
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezioni su data di cessione               *
      *                  *---------------------------------------------*
           move      d-mov-csp-dat-ven    to   s-dat                  .
           if        s-saa                =    rr-ann-ese
                     go to stp-srt-inp-500.
           if        d-mov-csp-dat-ven    =    zero
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Selezione su residuo                        *
      *                  *---------------------------------------------*
           if        d-mov-csp-val-res    not  = zero
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Selezione su status                         *
      *                  *---------------------------------------------*
           if        d-mov-csp-sts-csp    =    01
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Determinazione movimenti cespite            *
      *                  *---------------------------------------------*
           perform   det-mov-csp-000      thru det-mov-csp-999        .
      *                  *---------------------------------------------*
      *                  * Selezione su movimentato                    *
      *                  *---------------------------------------------*
           if        d-mov-csp-val-amm    not  = zero
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Selezioni non superate                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di sort                 *
      *                  *---------------------------------------------*
           move      rf-cea-cla-csp       to   srt-cla-csp            .
           move      d-mov-csp-dat-acq    to   srt-dat-acq            .
           move      rf-cea-cod-csp       to   srt-cod-csp            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore iniziale                         *
      *                      *-----------------------------------------*
           move      d-mov-csp-val-ini    to   srt-val-ini            .
      *                      *-----------------------------------------*
      *                      * Valore indeducibile                     *
      *                      *-----------------------------------------*
           move      d-mov-csp-val-ind    to   srt-val-ind            .
      *                      *-----------------------------------------*
      *                      * Valore ammortamento                     *
      *                      *-----------------------------------------*
           move      d-mov-csp-val-amm    to   srt-val-amm            .
      *                      *-----------------------------------------*
      *                      * Valore residuo                          *
      *                      *-----------------------------------------*
           move      d-mov-csp-val-res    to   srt-val-res            .
      *                      *-----------------------------------------*
      *                      * Valore venduto                          *
      *                      *                                         *
      *                      * N.B.: la sommatoria dei valori iniziali *
      *                      *       dei beni venduti nell'esercizio   *
      *                      *-----------------------------------------*
           if        d-mov-csp-val-ven    not  = zero
                     move  d-mov-csp-val-ini
                                          to   srt-val-ven            .
      *                      *-----------------------------------------*
      *                      * Valore venduto ammortizzato             *
      *                      *                                         *
      *                      * N.B.: la sommatoria dei valori di am-   *
      *                      *       mortamento dei beni venduti       *
      *                      *       nell'esercizio                    *
      *                      *-----------------------------------------*
           if        d-mov-csp-val-ven    not  = zero
                     move  d-mov-csp-val-amm
                                          to   srt-val-vam            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo a record [cea] successivo               *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

