      *              * Inizializzazione saldo bilancio esercizio pre-  *
      *              * cedente                                         *
      *              *-------------------------------------------------*
           move      zero                 to   w-bil-uop-pre          .
      *              *-------------------------------------------------*
      *              * Normalizzazione record file [pdc]               *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *              *-------------------------------------------------*
      *              * Start su file [pdc] con chiave normalizzata     *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move   "#"           to   w-car-tbl-cdb-flg
                     go to  car-tbl-cdb-999.
       car-tbl-cdb-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [pdc]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                  *---------------------------------------------*
      *                  * Test se at end                              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  car-tbl-cdb-200.
      *              *-------------------------------------------------*
      *              * Richiamo routine determinazione saldo bilancio  *
      *              *-------------------------------------------------*
           perform   det-sdo-dat-000      thru det-sdo-dat-999        .
      *              *-------------------------------------------------*
      *              * Se saldo bilancio zero si ricicla nella lettura *
      *              *-------------------------------------------------*
           if        w-sad-sdo-dat        =    zero
                     go to  car-tbl-cdb-100.
      *              *-------------------------------------------------*
      *              * Lettura archivio [cdb]                          *
      *              *-------------------------------------------------*
           if        w-sad-sdo-dat        >    zero
                     move  rf-pdc-tcb-dar to   w-let-arc-cdb-tip
                     move  rf-pdc-ccb-dar to   w-let-arc-cdb-cod
           else      move  rf-pdc-tcb-ave to   w-let-arc-cdb-tip
                     move  rf-pdc-ccb-ave to   w-let-arc-cdb-cod      .
           perform   let-arc-cdb-000      thru let-arc-cdb-999        .
           if        w-let-arc-cdb-flg    not  = spaces
                     move   "#"           to   w-car-tbl-cdb-flg
                     go to  car-tbl-cdb-100.
      *              *-------------------------------------------------*
      *              * Bufferizzazione in tabella classificatori       *
      *              *-------------------------------------------------*
           move      w-let-arc-cdb-tip    to   w-buf-tbl-cla-tip      .
           move      w-let-arc-cdb-cod    to   w-buf-tbl-cla-cod      .
           move      rf-pdc-cod-pdc       to   w-buf-tbl-cla-stc      .
           move      w-let-arc-cdb-dee    to   w-buf-tbl-cla-dee      .
           move      w-let-arc-cdb-der    to   w-buf-tbl-cla-der      .
           move      rf-pdc-des-pdc       to   w-buf-tbl-cla-des      .
           move      w-sad-sdo-dat        to   w-buf-tbl-cla-sdo      .
           perform   buf-tbl-cla-000      thru buf-tbl-cla-999        .
           if        w-buf-tbl-cla-flg    not  = spaces
                     move   "#"           to   w-car-tbl-cdb-flg
                     go to  car-tbl-cdb-300.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura [pdc]                        *
      *              *-------------------------------------------------*
           go to     car-tbl-cdb-100.
       car-tbl-cdb-200.
      *              *-------------------------------------------------*
      *              * Elaborazioni su tabella classificatori          *
      *              *-------------------------------------------------*
           perform   ela-tbl-cla-000      thru ela-tbl-cla-999        .
       car-tbl-cdb-300.
       car-tbl-cdb-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-tbl-cdb-999.
       car-tbl-cdb-999.
           exit.

      *    *===========================================================*
      *    * Routine di determinazione saldo alla data                 *
      *    *-----------------------------------------------------------*
       det-sdo-dat-000.
      *              *-------------------------------------------------*
      *              * Determinazione saldo ad inizio anno             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione se necessario lettura di una *
      *                  * o due schede saldi                          *
      *                  *                                             *
      *                  * - Se non e' mai stata eseguita una chiusura *
      *                  *   si leggono comunque due schede            *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio richiesto e' uguale o in-  *
      *                  *   feriore all'ultimo esercizio di chiusura  *
      *                  *   si legge una sola scheda                  *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio precedente quello della    *
      *                  *   data richiesta e' pari all'esercizio del- *
      *                  *   l'ultima chiusura si legge una sola sche- *
      *                  *   da                                        *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Si leggono due schede                     *
      *                  *---------------------------------------------*
           if        rn-dat-bil-ese-bil   =    zero
                     move  w-bil-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-bil-ann-bil        not  > rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else if   rn-dat-bil-flg-bil   not  = spaces
                     move  rn-dat-bil-ese-bil
                                          to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-bil-ann-pre        =    rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else      move  w-bil-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010.
       det-sdo-dat-010.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio di chiusura        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se conto di tipo Economico : saldo ini- *
      *                      * ziale zero                              *
      *                      *-----------------------------------------*
           if        rf-pdc-tip-cnt       =    "E"
                     move   zero          to   w-sad-sdo-ini
                     go to  det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Se conto di tipo Patrimoniale : deter-  *
      *                      * minazione saldo finale esercizio di bi- *
      *                      * lancio                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione campi chiave           *
      *                          *-------------------------------------*
           move      w-wrk-ann-ese        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Determinazione saldo finale eserci- *
      *                          * zio di bilancio                     *
      *                          *-------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
           move      zero                 to   I                      .
       det-sdo-dat-020.
           add       1                    to   I                      .
           if        I                    >    12
                     go to  det-sdo-dat-040.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-ini          .
           go to     det-sdo-dat-020.
       det-sdo-dat-040.
      *                          *-------------------------------------*
      *                          * Rettifiche di bilancio              *
      *                          *-------------------------------------*
           add       rf-mgs-dar-bil       to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-ini          .
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo bilancio        *
      *                          *-------------------------------------*
           add       w-sad-sdo-ini        to   w-bil-uop-pre          .
       det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Lettura [mgs] esercizio richiesto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione chiave per [mgs]       *
      *                          *-------------------------------------*
           move      w-bil-ann-bil        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
           go to     det-sdo-dat-200.
       det-sdo-dat-100.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio richiesto          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record file [mgs]       *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Preparazione chiave per [mgs]           *
      *                      *-----------------------------------------*
           move      w-bil-ann-bil        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                      *-----------------------------------------*
      *                      * Lettura file [mgs]                      *
      *                      *-----------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Determinazione saldo inizio anno        *
      *                      *-----------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
       det-sdo-dat-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo alla data di partenza      *
      *              *-------------------------------------------------*
           move      w-sad-sdo-ini        to   w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per accumulo progressivi men-*
      *              * sili anno in corso fino a mese precedente a     *
      *              * quello indicato da data situazione              *
      *              *-------------------------------------------------*
           move      w-bil-mes-bil        to   I                      .
       det-sdo-dat-220.
           subtract  1                    from I                      .
           if        I                    =    zero
                     go to  det-sdo-dat-240.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-dat          .
           go to     det-sdo-dat-220.
       det-sdo-dat-240.
      *              *-------------------------------------------------*
      *              * Controllo se giorno situazione e' fine mese     *
      *              *-------------------------------------------------*
           move      rr-dat-bil           to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Se la data e' corretta vuol dire che il     *
      *                  * giorno situazione non e' a fine mese        *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to  det-sdo-dat-250.
      *                      *-----------------------------------------*
      *                      * Se fine mese si aggiungono i progressivi*
      *                      * del mese attuale                        *
      *                      *-----------------------------------------*
           add       rf-mgs-dar-mes
                     (w-bil-mes-bil)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-bil-mes-bil)      from w-sad-sdo-dat          .
      *                      *-----------------------------------------*
      *                      * Se mese richiesto e' quello di chiusura *
      *                      * esercizio, si aggiungono i progressivi  *
      *                      * di bilancio                             *
      *                      *-----------------------------------------*
           if        w-bil-mes-bil        not  = w-ese-cge-mce
                     go to  det-sdo-dat-245.
           add       rf-mgs-dar-bil       to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-dat          .
       det-sdo-dat-245.
      *                      *-----------------------------------------*
      *                      * Si aggiorna il saldo con le rettifiche  *
      *                      * extracontabili desunte dal [mgs] stesso *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da aggiornare               *
      *                          *-------------------------------------*
           if        rr-snx-rec           =    02
                     go to det-sdo-dat-247.
      *                          *-------------------------------------*
      *                          * Aggiornamento                       *
      *                          *-------------------------------------*
           if        rf-mgs-dav-ret
                     (w-bil-mes-bil)      =    "A"
                     subtract rf-mgs-imp-ret
                              (w-bil-mes-bil)
                                          from w-sad-sdo-dat
           else      add      rf-mgs-imp-ret
                              (w-bil-mes-bil)
                                          to   w-sad-sdo-dat          .
       det-sdo-dat-247.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-sdo-dat-999.
       det-sdo-dat-250.
      *              *-------------------------------------------------*
      *              * Se data bilancio uguale a data attuale si ag-   *
      *              * giungono i progressivi del mese attuale         *
      *              *-------------------------------------------------*
           if        rr-dat-bil           not  = w-wrk-dat-att
                     go to  det-sdo-dat-300.
           add       rf-mgs-dar-mes
                     (w-bil-mes-bil)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-bil-mes-bil)      from w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Ad aggiornamento con rettifiche bilancio desunte*
      *              * da [rdb]                                        *
      *              *-------------------------------------------------*
           go to     det-sdo-dat-500.
       det-sdo-dat-300.
      *              *-------------------------------------------------*
      *              * Altrimenti si spazzola il file [mgr] per aggior-*
      *              * nare il saldo con i movimenti contabili fino al-*
      *              * la data richiesta                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record file [mgr]           *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Preparazione chiave per lettura file [mgr]  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      rf-pdc-cod-pdc       to   rf-mgr-cod-pdc         .
      *                      *-----------------------------------------*
      *                      * Data di registrazione                   *
      *                      *-----------------------------------------*
           move      01                   to   s-gio                  .
           move      w-bil-mes-bil        to   s-mes                  .
           move      w-bil-ann-bil        to   s-saa                  .
           move      s-dat                to   rf-mgr-dat-reg         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      zero                 to   rf-mgr-num-prt         .
      *                      *-----------------------------------------*
      *                      * Numero progressivo                      *
      *                      *-----------------------------------------*
           move      zero                 to   rf-mgr-num-prg         .
      *                  *---------------------------------------------*
      *                  * Start file [mgr] per chiave "PDCDAT"        *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PDCDAT"             to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito start                     *
      *                      *-----------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-500.
       det-sdo-dat-400.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [mgr]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-500.
      *                  *---------------------------------------------*
      *                  * Test se superamento limiti massimi          *
      *                  *---------------------------------------------*
           if        rf-mgr-cod-pdc        not  = rf-pdc-cod-pdc or
                     rf-mgr-dat-reg        >    rr-dat-bil
                     go to  det-sdo-dat-500.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se movimento di bilancio si ricicla     *
      *                      *-----------------------------------------*
           if        rf-mgr-snx-mob        not  = "N"
                     go to  det-sdo-dat-400.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo alla data               *
      *                  *---------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-sad-sdo-dat
           else      add      rf-mgr-imp-mov
                                          to   w-sad-sdo-dat          .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [mgr]                    *
      *                  *---------------------------------------------*
           go to     det-sdo-dat-400.
       det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo con eventuali movimenti di  *
      *              * rettifica desunti dal file [rdb]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non sono state richieste le rettifiche   *
      *                  * extracontabili : nessuna azione             *
      *                  *---------------------------------------------*
           if        rr-snx-rec           =    02
                     go to det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Start file [rdb] per chiave "DATPDC"        *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATPDC"             to   f-key                  .
           move      rr-dat-bil           to   rf-rdb-dat-reg         .
           move      rf-pdc-cod-pdc       to   rf-rdb-cod-pdc         .
           move      zero                 to   rf-rdb-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                      *-----------------------------------------*
      *                      * Test su esito start                     *
      *                      *-----------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
       det-sdo-dat-600.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [rdb]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Test se superamento limiti massimi          *
      *                  *---------------------------------------------*
           if        rf-rdb-dat-reg        not  = rr-dat-bil     or
                     rf-rdb-cod-pdc        not  = rf-pdc-cod-pdc
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo alla data               *
      *                  *---------------------------------------------*
           if        rf-rdb-dar-ave       =    "A"
                     subtract rf-rdb-imp-mov
                                          from w-sad-sdo-dat
           else      add      rf-rdb-imp-mov
                                          to   w-sad-sdo-dat          .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [rdb]                    *
      *                  *---------------------------------------------*
           go to     det-sdo-dat-600.
       det-sdo-dat-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cdb]                         *
      *    *                                                           *
      *    * Input   : w-let-arc-cdb-tip = Tipo classificatore         *
      *    *           w-let-arc-cdb-cod = Codice classificatore       *
      *    *                                                           *
      *    * Output  : w-let-arc-cdb-flg = spaces; lettura OK          *
      *    *                               "#"     lettura errata      *
      *    *           w-let-arc-cdb-dee = Descrizione classificatore  *
      *    *                               elementare                  *
      *    *           w-let-arc-cdb-der = Descrizione classificatore  *
      *    *                               raggruppamento              *
      *    *-----------------------------------------------------------*
       let-arc-cdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cdb-flg      .
      *              *-------------------------------------------------*
      *              * Lettura classificatore elementare               *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCDB    "         to   f-key                  .
           move      w-let-arc-cdb-tip    to   rf-cdb-tip-cdb         .
           move      w-let-arc-cdb-cod    to   rf-cdb-cod-cdb         .
           move      "pgm/cge/fls/ioc/obj/iofcdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cdb                 .
      *                  *---------------------------------------------*
      *                  * Se lettura senza successo                   *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to  let-arc-cdb-100.
      *                      *-----------------------------------------*
      *                      * Scrittura messaggio di errore           *
      *                      *-----------------------------------------*
           perform   wrt-msg-001-000      thru wrt-msg-001-999        .
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-cdb-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-cdb-999.
       let-arc-cdb-100.
      *              *-------------------------------------------------*
      *              * Memorizzazione descrizione classificatore       *
      *              *-------------------------------------------------*
           move      rf-cdb-des-cdb       to   w-let-arc-cdb-dee      .
      *              *-------------------------------------------------*
      *              * Lettura raggruppamento                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCDB    "         to   f-key                  .
           move      w-let-arc-cdb-tip    to   rf-cdb-tip-cdb         .
           move      w-let-arc-cdb-cod    to   w-wrk-cdb-cod          .
           move      zero                 to   w-wrk-cdb-ele          .
           move      w-wrk-cdb-cod        to   rf-cdb-cod-cdb         .
           move      "pgm/cge/fls/ioc/obj/iofcdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cdb                 .
      *                  *---------------------------------------------*
      *                  * Se lettura senza successo                   *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to  let-arc-cdb-200.
      *                      *-----------------------------------------*
      *                      * Scrittura messaggio di errore           *
      *                      *-----------------------------------------*
           perform   wrt-msg-002-000      thru wrt-msg-002-999        .
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-cdb-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-cdb-999.
       let-arc-cdb-200.
      *              *-------------------------------------------------*
      *              * Memorizzazione descrizione raggruppamento       *
      *              *-------------------------------------------------*
           move      rf-cdb-des-cdb       to   w-let-arc-cdb-der      .
       let-arc-cdb-999.
           exit.

      *    *===========================================================*
      *    * Scrittura messaggi di errore tipo 1                       *
      *    *-----------------------------------------------------------*
       wrt-msg-001-000.
      *              *-------------------------------------------------*
      *              * Scrittura messaggio di errore                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing codice sottoconto                   *
      *                  *---------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      rf-pdc-cod-pdc       to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      w-edt-cod-pdc-edt    to   w-all-str-cat (1)      .
           move      "-"                  to   w-all-str-cat (2)      .
           move      rf-pdc-des-pdc       to   w-all-str-cat (3)      .
           move      ": manca classificatore in"
                                          to   w-all-str-cat (4)      .
      *
           if        w-sad-sdo-dat        >    zero
                     move   "Dare"        to   w-all-str-cat (5)
           else      move   "Avere"       to   w-all-str-cat (5)      .
      *
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Scrittura                                   *
      *                  *---------------------------------------------*
           move      w-all-str-alf        to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Scrittura                                   *
      *                  *---------------------------------------------*
           move      all "-"              to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       wrt-msg-001-999.
           exit.

      *    *===========================================================*
      *    * Scrittura messaggi di errore tipo 2                       *
      *    *-----------------------------------------------------------*
       wrt-msg-002-000.
      *              *-------------------------------------------------*
      *              * Scrittura messaggio di errore                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo classificatore                         *
      *                  *---------------------------------------------*
           move      w-let-arc-cdb-tip    to   w-msg-002-tip          .
      *                  *---------------------------------------------*
      *                  * Codice classificatore                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing con appoggio a sinistra         *
      *                      *-----------------------------------------*
           move      2                    to   w-edt-cod-pdc-liv      .
           move      w-let-arc-cdb-cod    to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
           move      w-edt-cod-pdc-edt    to   w-msg-002-cod          .
      *                  *---------------------------------------------*
      *                  * Scrittura                                   *
      *                  *---------------------------------------------*
           move      w-msg-002            to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       wrt-msg-002-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione in tabella classificatori                 *
      *    *                                                           *
      *    * Input   : w-buf-tbl-cla-tip = Tipo classificatore         *
      *    *           w-buf-tbl-cla-cod = Codice classificatore       *
      *    *           w-buf-tbl-cla-stc = Codice sottoconto           *
      *    *           w-buf-tbl-cla-dee = Descrizione classificatore  *
      *    *                               elementare                  *
      *    *           w-buf-tbl-cla-der = Descrizione classificatore  *
      *    *                               raggruppamento              *
      *    *           w-buf-tbl-cla-des = Descrizione sottoconto      *
      *    *           w-buf-tbl-cla-sdo = Saldo alla data richiesta   *
      *    *                                                           *
      *    * Output  : w-buf-tbl-cla-flg = spaces; tutto OK            *
      *    *                               "#"     errore              *
      *    *-----------------------------------------------------------*
       buf-tbl-cla-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-tbl-cla-flg      .
      *              *-------------------------------------------------*
      *              * Determinazione codice tipo classificatore       *
      *              * 1 - Attivita'                                   *
      *              * 2 - Conti d'ordine attivi                       *
      *              * 3 - Passivita'                                  *
      *              * 4 - Conti d'ordine passivi                      *
      *              * 5 - Costi                                       *
      *              * 6 - Ricavi                                      *
      *              *-------------------------------------------------*
           if        w-buf-tbl-cla-tip    =    "A"
                     move   1             to   w-buf-tbl-cla-cot
           else if   w-buf-tbl-cla-tip    =    "P"
                     move   3             to   w-buf-tbl-cla-cot
           else if   w-buf-tbl-cla-tip    =    "C"
                     move   5             to   w-buf-tbl-cla-cot
           else if   w-buf-tbl-cla-tip    =    "R"
                     move   6             to   w-buf-tbl-cla-cot
           else      if     w-buf-tbl-cla-sdo
                                          >    zero
                            move   2      to   w-buf-tbl-cla-cot
                     else   move   4      to   w-buf-tbl-cla-cot      .
       buf-tbl-cla-100.
      *              *-------------------------------------------------*
      *              * Bufferizzazione raggruppamento                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tentativo di lettura record [ky1]           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-cot    to   ky1-cod-tip            .
           move      w-buf-tbl-cla-rgp    to   ky1-cod-rgp            .
           move      zero                 to   ky1-cod-ele            .
           move      zero                 to   ky1-cod-pdc            .
      *                      *-----------------------------------------*
      *                      * Lettura record [ky1]                    *
      *                      *-----------------------------------------*
           read      ky1    with no lock
                            key  is ky1-key
                            invalid key
                            go to buf-tbl-cla-120.
           go to     buf-tbl-cla-140.
       buf-tbl-cla-120.
      *                      *-----------------------------------------*
      *                      * Se record non esistente                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Inizializzazione area dati          *
      *                          *-------------------------------------*
           move      w-buf-tbl-cla-der    to   ky1-des-cdb            .
           move      zero                 to   ky1-sdo-cdb            .
      *                          *-------------------------------------*
      *                          * Scrittura record [ky1]              *
      *                          *-------------------------------------*
           write     ky1-rec                                          .
      *                          *-------------------------------------*
      *                          * A ripetizione dell'operazione       *
      *                          *-------------------------------------*
           go to     buf-tbl-cla-100.
       buf-tbl-cla-140.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo raggruppamento          *
      *                  *---------------------------------------------*
           if        w-buf-tbl-cla-cot    =    1 or
                     w-buf-tbl-cla-cot    =    2 or
                     w-buf-tbl-cla-cot    =    5
                     add      w-buf-tbl-cla-sdo
                                          to   ky1-sdo-cdb
           else      subtract w-buf-tbl-cla-sdo
                                          from ky1-sdo-cdb            .
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [ky1]                  *
      *                  *---------------------------------------------*
           rewrite   ky1-rec                                          .
       buf-tbl-cla-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione classificatore elementare       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tentativo di lettura record [ky1]           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-cot    to   ky1-cod-tip            .
           move      w-buf-tbl-cla-rgp    to   ky1-cod-rgp            .
           move      w-buf-tbl-cla-ele    to   ky1-cod-ele            .
           move      zero                 to   ky1-cod-pdc            .
      *                      *-----------------------------------------*
      *                      * Lettura record [ky1]                    *
      *                      *-----------------------------------------*
           read      ky1    with no lock
                            key  is ky1-key
                            invalid key
                            go to buf-tbl-cla-220.
           go to     buf-tbl-cla-240.
       buf-tbl-cla-220.
      *                      *-----------------------------------------*
      *                      * Se record non esistente                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Inizializzazione area dati          *
      *                          *-------------------------------------*
           move      w-buf-tbl-cla-dee    to   ky1-des-cdb            .
           move      zero                 to   ky1-sdo-cdb            .
      *                          *-------------------------------------*
      *                          * Scrittura record [ky1]              *
      *                          *-------------------------------------*
           write     ky1-rec                                          .
      *                          *-------------------------------------*
      *                          * A ripetizione dell'operazione       *
      *                          *-------------------------------------*
           go to     buf-tbl-cla-200.
       buf-tbl-cla-240.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo classificatore          *
      *                  *---------------------------------------------*
           if        w-buf-tbl-cla-cot    =    1 or
                     w-buf-tbl-cla-cot    =    2 or
                     w-buf-tbl-cla-cot    =    5
                     add      w-buf-tbl-cla-sdo
                                          to   ky1-sdo-cdb
           else      subtract w-buf-tbl-cla-sdo
                                          from ky1-sdo-cdb            .
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [ky1]                  *
      *                  *---------------------------------------------*
           rewrite   ky1-rec                                          .
       buf-tbl-cla-300.
      *              *-------------------------------------------------*
      *              * Bufferizzazione sottoconto                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    01
                     go to buf-tbl-cla-400.
      *                  *---------------------------------------------*
      *                  * Composizione record [ky1]                   *
      *                  *---------------------------------------------*
           move      spaces               to   ky1-rec                .
      *                      *-----------------------------------------*
      *                      * Area chiave                             *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-cot    to   ky1-cod-tip            .
           move      w-buf-tbl-cla-rgp    to   ky1-cod-rgp            .
           move      w-buf-tbl-cla-ele    to   ky1-cod-ele            .
           move      w-buf-tbl-cla-stc    to   ky1-cod-pdc            .
      *                      *-----------------------------------------*
      *                      * Area dati                               *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-des    to   ky1-des-cdb            .
           move      w-buf-tbl-cla-sdo    to   ky1-sdo-cdb            .
      *                  *---------------------------------------------*
      *                  * Scrittura record [ky1]                      *
      *                  *---------------------------------------------*
           write     ky1-rec                                          .
       buf-tbl-cla-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-tbl-cla-999.
       buf-tbl-cla-900.
      *              *-------------------------------------------------*
      *              * Se superato il limite massimo elementi          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      spaces               to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "Il programma viene interrotto per superamento del 
      -              "limite massimo previsto in"
                                          to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "termini di numero classificatori di bilancio limit
      -              "e massimo previsto di"
                                          to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Flag di errore                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-buf-tbl-cla-flg      .
       buf-tbl-cla-999.
           exit.

      *    *===========================================================*
      *    * Elaborazioni su tabella classificatori                    *
      *    *-----------------------------------------------------------*
       ela-tbl-cla-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione area totalizzatori             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bil-tot-att          .
           move      zero                 to   w-bil-tot-pas          .
           move      zero                 to   w-bil-tot-cos          .
           move      zero                 to   w-bil-tot-ric          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella classificatori    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [ky1]                         *
      *                  *---------------------------------------------*
           move      low-value            to   ky1-key                .
           start     ky1    key not less
                            ky1-key
                            invalid key
                            go to ela-tbl-cla-200.
       ela-tbl-cla-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [ky1]            *
      *                  *---------------------------------------------*
           read      ky1    next
                            with no lock
                            at end
                            go to ela-tbl-cla-200.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
           if        ky1-cod-ele          not  = zero
                     go to ela-tbl-cla-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatori di bilancio     *
      *                  *---------------------------------------------*
           if        ky1-cod-tip          =    1
                     add   ky1-sdo-cdb    to   w-bil-tot-att
           else if   ky1-cod-tip          =    2
                     add   ky1-sdo-cdb    to   w-bil-tot-coa
           else if   ky1-cod-tip          =    3
                     add   ky1-sdo-cdb    to   w-bil-tot-pas
           else if   ky1-cod-tip          =    4
                     add   ky1-sdo-cdb    to   w-bil-tot-cop
           else if   ky1-cod-tip          =    5
                     add   ky1-sdo-cdb    to   w-bil-tot-cos
           else if   ky1-cod-tip          =    6
                     add   ky1-sdo-cdb    to   w-bil-tot-ric          .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [ky1] *
      *                  *---------------------------------------------*
           go to     ela-tbl-cla-100.
       ela-tbl-cla-200.
      *              *-------------------------------------------------*
      *              * Risultato precedente                            *
      *              *-------------------------------------------------*
           if        w-bil-uop-pre        =    zero
                     go to  ela-tbl-cla-300.
      *                  *---------------------------------------------*
      *                  * Determinazione tipo risultato esercizio     *
      *                  * precedente                                  *
      *                  *---------------------------------------------*
           if        w-bil-uop-pre        <    zero
                     move   "P"           to   w-bil-tip-rep
           else      move   "U"           to   w-bil-tip-rep          .
      *                  *---------------------------------------------*
      *                  * Determinazione saldo risultato esercizio    *
      *                  * precedente                                  *
      *                  *---------------------------------------------*
           move      w-bil-uop-pre        to   w-bil-sdo-rep          .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatori                 *
      *                  *---------------------------------------------*
           if        w-bil-tip-rep        =    "U"
                     add    w-bil-sdo-rep to   w-bil-tot-pas
           else      add    w-bil-sdo-rep to   w-bil-tot-att          .
       ela-tbl-cla-300.
      *              *-------------------------------------------------*
      *              * Risultato attuale                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo in base allo stato patrimoniale     *
      *                  *---------------------------------------------*
           subtract  w-bil-tot-pas        from w-bil-tot-att
                                        giving w-bil-ris-pat          .
      *                  *---------------------------------------------*
      *                  * Calcolo in base al conto economico          *
      *                  *---------------------------------------------*
           subtract  w-bil-tot-cos        from w-bil-tot-ric
                                        giving w-bil-ris-cec          .
      *                  *---------------------------------------------*
      *                  * Confronto                                   *
      *                  *---------------------------------------------*
           if        w-bil-ris-pat        not  = w-bil-ris-cec
                     go to  ela-tbl-cla-900.
      *                  *---------------------------------------------*
      *                  * Determinazione tipo risultato esercizio     *
      *                  * attuale                                     *
      *                  *---------------------------------------------*
           if        w-bil-ris-cec        <    zero
                     move   "P"           to   w-bil-tip-rea
           else      move   "U"           to   w-bil-tip-rea          .
      *                  *---------------------------------------------*
      *                  * Determinazione saldo risultato esercizio    *
      *                  * attuale                                     *
      *                  *---------------------------------------------*
           move      w-bil-ris-cec        to   w-bil-sdo-rea          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     ela-tbl-cla-999.
       ela-tbl-cla-900.
      *                  *---------------------------------------------*
      *                  * Se il risultato calcolato sullo stato       *
      *                  * patrimoniale e' diverso da quello del       *
      *                  * conto economico                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      spaces               to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      13                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "<G"                 to   p-edm                  .
           subtract  w-bil-ris-pat        from w-bil-ris-cec
                                        giving p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      spaces               to   m-msg                  .
           string    "Attenzione il bilancio non quadra per "
                                delimited by   size
                     c-sgl      delimited by   spaces
                     " "        delimited by   size
                     p-edt      delimited by   spaces
                     ". "       delimited by   size
                                          into m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Uscita con errore                       *
      *                      *-----------------------------------------*
           move      "#"                  to   w-car-tbl-cdb-flg      .
       ela-tbl-cla-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Subroutines per allineamenti a destra o a sinistra oppure *
      *    * al centro di campi alfanumerici di varia lunghezza, fi-   *
      *    * no ad un massimo di 240 caratteri, oppure per il conca-   *
      *    * tenamento, con o senza separazione, di max 10 substrin-   *
      *    * ghe in una unica substringa                               *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wallstr0.cps"                   .
