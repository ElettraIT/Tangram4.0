      *                  * Test se impostate righe corpo               *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to pre-cor-reg-900.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento non iva : nessun control- *
      *                  * lo ulteriore                                *
      *                  *---------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0"
                     go to pre-cor-reg-900.
      *                  *---------------------------------------------*
      *                  * Test se totali non ancora inseriti          *
      *                  *---------------------------------------------*
           if        w-sav-iva-tib        not  = zero or
                     w-sav-iva-tim        not  = zero or
                     w-sav-iva-tnd        not  = zero or
                     w-sav-iva-tdo        not  = zero
                     go to pre-cor-reg-200.
      *                  *---------------------------------------------*
      *                  * Salvataggio totali Iva                      *
      *                  *---------------------------------------------*
           move      w-tes-iva-tib (1)    to   w-sav-iva-tib          .
           move      w-tes-iva-tim (1)    to   w-sav-iva-tim          .
           move      w-tes-iva-tnd (1)    to   w-sav-iva-tnd          .
           move      w-tes-iva-tdo (1)    to   w-sav-iva-tdo          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     pre-cor-reg-900.
       pre-cor-reg-200.
      *                  *---------------------------------------------*
      *                  * Test se variato anche uno solo dei totali   *
      *                  * del castelletto Iva                         *
      *                  *---------------------------------------------*
           if        w-tes-iva-tib (1)    =    w-sav-iva-tib and
                     w-tes-iva-tim (1)    =    w-sav-iva-tim and
                     w-tes-iva-tnd (1)    =    w-sav-iva-tnd and
                     w-tes-iva-tdo (1)    =    w-sav-iva-tdo
                     go to pre-cor-reg-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di avvertimento                   *
      *                  *---------------------------------------------*
           perform   pre-cor-reg-e01-000  thru pre-cor-reg-e01-999    .
      *                  *---------------------------------------------*
      *                  * Salvataggio totali Iva                      *
      *                  *---------------------------------------------*
           move      w-tes-iva-tib (1)    to   w-sav-iva-tib          .
           move      w-tes-iva-tim (1)    to   w-sav-iva-tim          .
           move      w-tes-iva-tnd (1)    to   w-sav-iva-tnd          .
           move      w-tes-iva-tdo (1)    to   w-sav-iva-tdo          .
       pre-cor-reg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pre-cor-reg-999.
       pre-cor-reg-999.
           exit.

