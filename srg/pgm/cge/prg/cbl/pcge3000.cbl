      *                  *---------------------------------------------*
           if        w-agg-mgs-tip-agg    =    "-"
                     go to agg-con-000-800.
           if        w-agg-mgs-dar-ave    =    "A"
                     add      w-agg-mgs-imp-mov
                                          to   rf-mgs-ave-bil
           else      add      w-agg-mgs-imp-mov
                                          to   rf-mgs-dar-bil         .
           go to     agg-con-000-899.
       agg-con-000-800.
      *                  *---------------------------------------------*
      *                  * Se aggiornamento in "-"                     *
      *                  *---------------------------------------------*
           if        w-agg-mgs-dar-ave    =    "A"
                     subtract w-agg-mgs-imp-mov
                                          from rf-mgs-ave-bil
           else      subtract w-agg-mgs-imp-mov
                                          from rf-mgs-dar-bil         .
       agg-con-000-899.
           exit.
       agg-con-000-999.
           exit.

      *    *===========================================================*
      *    * Scrittura pareggiamento automatico acconti clienti o for- *
      *    * nitori                                                    *
      *    *-----------------------------------------------------------*
       scr-pau-acf-000.
      *              *-------------------------------------------------*
      *              * Se nessun pareggiamento automatico effettuato : *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-tes-imp-pap        =    spaces
                     go to scr-pau-acf-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella partite           *
      *              *-------------------------------------------------*
           move      zero                 to   w-scr-pau-acf-ctr      .
       scr-pau-acf-100.
           add       1                    to   w-scr-pau-acf-ctr      .
           if        w-scr-pau-acf-ctr    >    w-lpa-num-ele
                     go to scr-pau-acf-999.
      *                  *---------------------------------------------*
      *                  * Se l'importo assegnato alla partita e' zero *
      *                  * : riciclo                                   *
      *                  *---------------------------------------------*
           if        w-lpa-imp-ass
                    (w-scr-pau-acf-ctr)   =    zero
                     go to scr-pau-acf-100.
      *                  *---------------------------------------------*
      *                  * Se i riferimenti della partita sono uguali  *
      *                  * a quelli da forzare : riciclo               *
      *                  *---------------------------------------------*
           if        w-lpa-dat-rif
                    (w-scr-pau-acf-ctr)   =    w-lpa-dri-doc and
                     w-lpa-num-rif
                    (w-scr-pau-acf-ctr)   =    w-lpa-nri-doc
                     go to scr-pau-acf-100.
      *                  *---------------------------------------------*
      *                  * Scansione delle righe di contabilita' rela- *
      *                  * tive alla partita in esame                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start su file [mgr]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      w-lpa-tip-arc        to   rf-mgr-tip-arc         .
           move      w-lpa-cod-arc        to   rf-mgr-cod-arc         .
           move      w-lpa-dat-rif
                    (w-scr-pau-acf-ctr)   to   rf-mgr-dat-rif         .
           move      w-lpa-num-rif
                    (w-scr-pau-acf-ctr)   to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to scr-pau-acf-300.
       scr-pau-acf-200.
      *                      *-----------------------------------------*
      *                      * Ottenimento sequenziale record [mgr]    *
      *                      *-----------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'at end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to scr-pau-acf-300.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       not  = w-lpa-tip-arc      or
                     rf-mgr-cod-arc       not  = w-lpa-cod-arc      or
                     rf-mgr-dat-rif       not  = w-lpa-dat-rif
                                                (w-scr-pau-acf-ctr) or
                     rf-mgr-num-rif       not  = w-lpa-num-rif
                                                (w-scr-pau-acf-ctr)
                     go to scr-pau-acf-300.
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [mgr]              *
      *                      *-----------------------------------------*
           move      w-lpa-dri-doc        to   rf-mgr-dat-rif         .
           move      w-lpa-nri-doc        to   rf-mgr-num-rif         .
      *                      *-----------------------------------------*
      *                      * Update record [mgr]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Unlock record [mgr]                     *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su prossimo record [mgr]        *
      *                      *-----------------------------------------*
           go to     scr-pau-acf-200.
       scr-pau-acf-300.
      *              *-------------------------------------------------*
      *              * Unlock ultimo record [mgr]                      *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella partite            *
      *              *-------------------------------------------------*
           go to     scr-pau-acf-100.
       scr-pau-acf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Se non e' ancora stato fatto si legge la scelta *
      *              * del mese di chiusura esercizio                  *
      *              *-------------------------------------------------*
           if        w-det-ese-cge-mce    not  = zero
                     go to det-ese-cge-300.
           move      "P:"                 to   s-ope                  .
           move      "pgm/cge[mes-chi]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  s-num          to   w-det-ese-cge-mce
           else      move  12             to   w-det-ese-cge-mce      .
           if        w-det-ese-cge-mce    <    01 or
                     w-det-ese-cge-mce    >    12
                     move  12             to   w-det-ese-cge-mce      .
       det-ese-cge-300.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-det-ese-cge-dtr    to   s-dat                  .
           if        w-det-ese-cge-mce    =    12             or
                     s-mes                >    w-det-ese-cge-mce
                     move  s-saa          to   w-det-ese-cge-esa
                     go to det-ese-cge-600.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-det-ese-cge-esa      .
       det-ese-cge-600.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-det-ese-cge-esm      .
           if        w-det-ese-cge-mce    =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-det-ese-cge-mce
                     subtract w-det-ese-cge-mce
                                          from w-det-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-det-ese-cge-mce
                     add   12             to   w-det-ese-cge-esm
                     subtract w-det-ese-cge-mce
                                          from w-det-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-det-ese-cge-esm      .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
      *    * Caricamento righe skeleton                                *
      *    *-----------------------------------------------------------*
       car-rig-ske-000.
      *              *-------------------------------------------------*
      *              * Test se caricamento da effettuare               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se in impostazione skeleton : no            *
      *                  *---------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to car-rig-ske-999.
      *                  *---------------------------------------------*
      *                  * Se non in inserimento registrazione : no    *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to car-rig-ske-999.
      *                  *---------------------------------------------*
      *                  * Se gia' registrata una riga corpo : no      *
      *                  *---------------------------------------------*
           if        w-tes-imp-rig        not  = spaces
                     go to car-rig-ske-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione catena [rig]                   *
      *              *-------------------------------------------------*
           move      "BE"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Start su tabella [zsk]                          *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-cod-cau (1)    to   rf-zsk-cod-cau         .
           move      zero                 to   rf-zsk-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofzsk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsk                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-rig-ske-999.
       car-rig-ske-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale tabella [zsk]               *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzsk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsk                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-rig-ske-999.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-zsk-cod-cau       not  = w-tes-cod-cau (1)
                     go to car-rig-ske-999.
      *              *-------------------------------------------------*
      *              * Bufferizzazione riga                            *
      *              *-------------------------------------------------*
           move      rf-zsk-num-prg       to   w-rig-num-prg (1)      .
           move      rf-zsk-tip-arc       to   w-rig-tip-con (1)      .
      *
           if        rf-zsk-tip-arc       =    "C"   or
                     rf-zsk-tip-arc       =    "F"
                     move  rf-zsk-cod-arc to   w-rig-cod-con (1)
           else      move  rf-zsk-cod-pdc to   w-rig-cod-con (1)      .
      *
           if        rf-zsk-tip-arc       =    "C"
                     go to car-rig-ske-200.
      *
           if        rf-zsk-tip-arc       =    "F"
                     go to car-rig-ske-250.
      *
           move      rf-zsk-cod-pdc       to   w-let-cod-pdc-cod      .
           perform   let-cod-pdc-000      thru let-cod-pdc-999        .
           move      w-let-cod-pdc-des    to   w-rig-des-con (1)      .
           go to     car-rig-ske-300.
       car-rig-ske-200.
           move      rf-zsk-cod-arc       to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-rig-des-con (1)      .
           go to     car-rig-ske-300.
       car-rig-ske-250.
           move      rf-zsk-cod-arc       to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
           move      w-let-arc-fnt-rag    to   w-rig-des-con (1)      .
       car-rig-ske-300.
           move      rf-zsk-cod-pdc       to   w-rig-cod-pdc (1)      .
      *
           if        rf-zsk-tip-arc       =    "C"   or
                     rf-zsk-tip-arc       =    "F"
                     move  rf-zsk-tip-arc to   w-rig-tip-arc (1)
                     move  rf-zsk-cod-arc to   w-rig-cod-arc (1)
           else      move  spaces         to   w-rig-tip-arc (1)
                     move  zero           to   w-rig-cod-arc (1)      .
           move      rf-zsk-com-rig       to   w-rig-com-rig (1)      .
           move      zero                 to   w-rig-dat-rif (1)      .
           move      spaces               to   w-rig-num-rif (1)      .
           move      rf-zsk-dar-ave       to   w-rig-dar-ave (1)      .
           move      zero                 to   w-rig-imp-mov (1)      .
           move      spaces               to   w-rig-flg-pge (1)      .
           move      spaces               to   w-rig-flg-pcf (1)      .
      *                  *---------------------------------------------*
      *                  * Valori precedenti                           *
      *                  *---------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *              *-------------------------------------------------*
      *              * Put su catena movimenti [rig]                   *
      *              *-------------------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-zsk-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura tabella [zsk]                *
      *              *-------------------------------------------------*
           go to     car-rig-ske-100.
       car-rig-ske-999.
           exit.

      *    *===========================================================*
      *    * Scrittura skeleton su file                                *
      *    *-----------------------------------------------------------*
       scr-ske-fil-000.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-ske-fil-200.
       scr-ske-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Se fine : a trattamento righe "in vita"     *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-ske-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-ske-fil-100.
      *              *-------------------------------------------------*
      *              * Composizione chiave per la cancellazione        *
      *              *-------------------------------------------------*
           move      w-tes-cod-cau (1)    to   rf-zsk-cod-cau         .
           move      w-rig-num-prg (2)    to   rf-zsk-num-prg         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzsk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsk                 .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-ske-fil-100.
       scr-ske-fil-200.
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Se start non valida : uscita                *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-ske-fil-999.
       scr-ske-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-ske-fil-999.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento tabella [zsk]                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-ske-fil-500.
       scr-ske-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [zsk]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-zsk-000      thru wrt-rec-zsk-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-ske-fil-300.
       scr-ske-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-con (2)    =    spaces
                     go to scr-ske-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata         *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2)
                     go to scr-ske-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-ske-fil-300.
       scr-ske-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [zsk]                       *
      *                          *-------------------------------------*
           perform   rew-rec-zsk-000      thru rew-rec-zsk-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-ske-fil-300.
       scr-ske-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete skeleton da file                                   *
      *    *-----------------------------------------------------------*
       del-ske-fil-000.
      *              *-------------------------------------------------*
      *              * Cancellazione righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Se start non valida : a testata         *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-ske-fil-999.
       del-ske-fil-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale righe corpo             *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Se at end : a testata                   *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-ske-fil-999.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Delete record tabella [zsk]                 *
      *                  *---------------------------------------------*
           perform   del-rec-zsk-000      thru del-rec-zsk-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura riga corpo successiva     *
      *                  *---------------------------------------------*
           go to     del-ske-fil-100.
       del-ske-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record [zsk]                                 *
      *    *-----------------------------------------------------------*
       cmp-rec-zsk-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzsk"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsk                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      w-tes-cod-cau (1)    to   rf-zsk-cod-cau         .
           move      w-cat-rig-prg        to   rf-zsk-num-prg         .
           move      w-rig-cod-pdc (1)    to   rf-zsk-cod-pdc         .
           move      w-rig-tip-con (1)    to   rf-zsk-tip-arc         .
           if        rf-zsk-tip-arc       =    "G"
                     move  zero           to   rf-zsk-cod-arc
           else      move  w-rig-cod-arc (1)
                                          to   rf-zsk-cod-arc         .
           move      w-rig-com-rig (1)    to   rf-zsk-com-rig         .
           move      w-rig-dar-ave (1)    to   rf-zsk-dar-ave         .
       cmp-rec-zsk-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [zsk]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-zsk-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-zsk-000      thru cmp-rec-zsk-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
