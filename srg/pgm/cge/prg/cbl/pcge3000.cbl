      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    not  = "F"
                     go to det-num-dfd-900.
      *                  *---------------------------------------------*
      *                  * Su codice archivio                          *
      *                  *---------------------------------------------*
           if        w-rig-cod-con (1)    =    zero
                     go to det-num-dfd-900.
      *                  *---------------------------------------------*
      *                  * Su data documento                           *
      *                  *---------------------------------------------*
           if        w-tes-dat-doc (1)    =    zero
                     go to det-num-dfd-900.
      *                  *---------------------------------------------*
      *                  * Su numero documento                         *
      *                  *---------------------------------------------*
           if        w-tes-num-doc (1)    =    spaces
                     go to det-num-dfd-900.
       det-num-dfd-100.
      *              *-------------------------------------------------*
      *              * Start su file [mgr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TARDOC"             to   f-key                  .
           move      w-rig-tip-con (1)    to   rf-mgr-tip-arc         .
           move      w-tes-dat-doc (1)    to   rf-mgr-dat-doc         .
           move      w-tes-num-doc (1)    to   rf-mgr-num-doc         .
           move      w-rig-cod-con (1)    to   rf-mgr-cod-arc         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se start non valida : ad uscita             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-num-dfd-900.
       det-num-dfd-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [mgr]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : ad uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-num-dfd-900.
       det-num-dfd-300.
      *              *-------------------------------------------------*
      *              * Test se oltre il massimo                        *
      *              *-------------------------------------------------*
           if        rf-mgr-tip-arc       not  = w-rig-tip-con (1) or
                     rf-mgr-dat-doc       not  = w-tes-dat-doc (1) or
                     rf-mgr-num-doc       not  = w-tes-num-doc (1) or
                     rf-mgr-cod-arc       not  = w-rig-cod-con (1)
                     go to det-num-dfd-900.
       det-num-dfd-400.
