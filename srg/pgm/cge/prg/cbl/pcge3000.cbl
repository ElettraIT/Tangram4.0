      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      "Attenzione : Il movimento non puo' essere variato 
      -              ""                   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      "             per i seguenti motivi :              
      -              ""                   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Parte variabile                             *
      *                  *---------------------------------------------*
