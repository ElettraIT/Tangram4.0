      *    *===========================================================*
      *    * Prompt per campo : Data documento                         *
      *    *-----------------------------------------------------------*
       pmt-dat-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Data   documento  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-dat-doc-999.
           exit.

      *    *===========================================================*
      *    * Prompt per campo : Numero documento                       *
      *    *-----------------------------------------------------------*
       pmt-num-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Numero documento  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-num-doc-999.
           exit.

      *    *===========================================================*
      *    * Prompt per campo : Numero giornale iva                    *
      *    *-----------------------------------------------------------*
       pmt-ngi-iva-000.
      *              *-------------------------------------------------*
      *              * Test se prompt da visualizzare                  *
      *              *-------------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0" or
                     w-tes-tip-mgi (1)    =    spaces
                     go to pmt-ngi-iva-999.
           if       (w-tes-tip-mgi (1)    =    "1" or
                     w-tes-tip-mgi (1)    =    "2" or
                     w-tes-tip-mgi (1)    =    "A" or
                     w-tes-tip-mgi (1)    =    "B"  ) and
                     w-prs-mul-giv-snx    not  = "S"
                     go to pmt-ngi-iva-999.
           if        w-tes-tip-mgi (1)    =    "3"     and
                     w-prs-mul-gic-snx    not  = "S"
                     go to pmt-ngi-iva-999.
           if       (w-tes-tip-mgi (1)    =    "4" or
                     w-tes-tip-mgi (1)    =    "5" or
                     w-tes-tip-mgi (1)    =    "6" or
                     w-tes-tip-mgi (1)    =    "D" or
                     w-tes-tip-mgi (1)    =    "E"  ) and
                     w-prs-mul-gia-snx    not  = "S"
                     go to pmt-ngi-iva-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "Nr. giornale iva   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-ngi-iva-999.
           exit.

      *    *===========================================================*
      *    * Prompt per campo : Numero protocollo iva                  *
      *    *-----------------------------------------------------------*
       pmt-prt-iva-000.
      *              *-------------------------------------------------*
      *              * Test se prompt da visualizzare                  *
      *              *-------------------------------------------------*
           if        w-tes-tip-mgi (1)    not  = "4" and
                     w-tes-tip-mgi (1)    not  = "5" and
                     w-tes-tip-mgi (1)    not  = "6" and
                     w-tes-tip-mgi (1)    not  = "D" and
                     w-tes-tip-mgi (1)    not  = "E"
                     go to pmt-prt-iva-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "Protocollo iva     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-prt-iva-999.
           exit.

      *    *===========================================================*
      *    * Prompt per campo : Castelletto iva                        *
      *    *-----------------------------------------------------------*
       pmt-cst-iva-000.
      *              *-------------------------------------------------*
      *              * Test se prompt da visualizzare                  *
      *              *-------------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0" or
                     w-tes-tip-mgi (1)    =    spaces
                     go to pmt-cst-iva-999.
           if        w-tes-imp-ske        not  = spaces
                     go to pmt-cst-iva-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione fincatura                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "       Codice iva       Imponibile          Impost
      -              "a            Totale           "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione sottolineatura                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "       ----------    ---------------    ----------
      -              "-----    ---------------      "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sopralineatura totali                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "       ----------    ---------------    ----------
      -              "-----    ---------------      "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * 'Totali :'                                      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      12                   to   v-pos                  .
           move      "Totali :"           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cst-iva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice causale contabile             *
      *    *-----------------------------------------------------------*
       acc-cod-cau-000.
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su fase di impostazione                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-imp    =    "K"
                     go to acc-cod-cau-020
           else      go to acc-cod-cau-040.
       acc-cod-cau-020.
      *                  *---------------------------------------------*
      *                  * Se in impostazione chiave                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non si e' in impostazione di uno     *
      *                      * skeleton : uscita                       *
      *                      *-----------------------------------------*
           if        w-tes-imp-ske        =    spaces
                     go to acc-cod-cau-999
           else      go to acc-cod-cau-050.
       acc-cod-cau-040.
      *                  *---------------------------------------------*
      *                  * Se in impostazione testata                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se si e' in impostazione di uno skele-  *
      *                      * ton : uscita                            *
      *                      *-----------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to acc-cod-cau-999.
      *                      *-----------------------------------------*
      *                      * Test se causale a zero                  *
      *                      *-----------------------------------------*
           if        w-tes-cod-cau (1)    =    zero
                     go to acc-cod-cau-050.
      *                      *-----------------------------------------*
      *                      * Test se in modalita' utility            *
      *                      *-----------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "UT"
                     go to acc-cod-cau-050.
      *                      *-----------------------------------------*
      *                      * Se la causale attuale e' una causale    *
      *                      * iva non si permette la re-impostazione  *
      *                      *-----------------------------------------*
           if        w-tes-tip-mgi (1)    not  = "0"
                     go to acc-cod-cau-999.
       acc-cod-cau-050.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-tes-cod-cau (1)    to   w-sav-cod-cau          .
       acc-cod-cau-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zcc-ope      .
           move      w-tes-cod-cau (1)    to   w-cod-mne-zcc-cod      .
           move      06                   to   w-cod-mne-zcc-lin      .
           move      21                   to   w-cod-mne-zcc-pos      .
           move      06                   to   w-cod-mne-zcc-dln      .
           move      26                   to   w-cod-mne-zcc-dps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-tes-imp-ske        not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cnt-sts-imp-tes    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
           if        w-tes-imp-ske        not  = spaces
                     move  spaces         to   v-pfk (05)             .
           perform   cod-mne-zcc-cll-000  thru cod-mne-zcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zcc-foi-000  thru cod-mne-zcc-foi-999    .
       acc-cod-cau-110.
           perform   cod-mne-zcc-cll-000  thru cod-mne-zcc-cll-999    .
           if        w-cod-mne-zcc-ope    =    "F+"
                     go to acc-cod-cau-115.
           if        w-cod-mne-zcc-ope    =    "AC"
                     go to acc-cod-cau-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cau-115.
           perform   cod-mne-zcc-foi-000  thru cod-mne-zcc-foi-999    .
           go to     acc-cod-cau-110.
       acc-cod-cau-120.
           move      w-cod-mne-zcc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     if    w-tes-imp-ske  =    spaces
                           move  "E"      to   w-cnt-tus-acc-tes
                           go to acc-cod-cau-999
                     else  move  "E"      to   w-cnt-tus-acc-key
                           go to acc-cod-cau-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cau-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cau (1)      .
       acc-cod-cau-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se causale a zero : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-tes-cod-cau (1)    =    zero
                     go to acc-cod-cau-100.
      *                  *---------------------------------------------*
      *                  * Lettura tabella causali                     *
      *                  *---------------------------------------------*
           move      w-tes-cod-cau (1)    to   w-let-arc-zcc-cod      .
           perform   let-arc-zcc-000      thru let-arc-zcc-999        .
      *                  *---------------------------------------------*
      *                  * Se causale non esistente : messaggio di er- *
      *                  * rore e reimpostazione                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zcc-flg    =    spaces
                     go to acc-cod-cau-425.
           move      "ME"                 to   v-ope                  .
           move      "Causale contabile non esistente !"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-cod-cau-100.
       acc-cod-cau-425.
      *                  *---------------------------------------------*
      *                  * Se si e' in impostazione di uno skeleton    *
      *                  * non si esegue nessun altro controllo        *
      *                  *---------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to acc-cod-cau-550.
      *                  *---------------------------------------------*
      *                  * I due controlli seguenti vengono by-passati *
      *                  * in caso di Visualizzazione, per lasciare la *
      *                  * possibilita' di visualizzare l'intera regi- *
      *                  * strazione                                   *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-cod-cau-475.
      *                  *---------------------------------------------*
      *                  * Se causale di bilancio e non si e' in pe-   *
      *                  * riodo di bilancio : messaggio di errore e   *
      *                  * reimpostazione                              *
      *                  *---------------------------------------------*
           if        w-let-arc-zcc-snb    =    "N"
                     go to acc-cod-cau-450.
           if        w-dnu-300-bil-flg    not  = spaces
                     go to acc-cod-cau-450.
           move      "ME"                 to   v-ope                  .
           move      "La causale contabile e' di rettifica al bilancio m
      -              "a non e' ancora stato dichia-"
                                          to   v-nt1                  .
           move      "rato l'inizio periodo bilanci !"
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-cod-cau-500.
       acc-cod-cau-450.
      *                  *---------------------------------------------*
      *                  * Se la causale attuale e' di bilancio, e la  *
      *                  * causale precedente non lo era, o viceversa, *
      *                  * messaggio di errore e reimpostazione        *
      *                  *---------------------------------------------*
           if        w-sav-cod-cau        =    zero
                     go to acc-cod-cau-475.
           if        w-tes-snx-mob (1)    =    w-let-arc-zcc-snb
                     go to acc-cod-cau-475.
           move      "ME"                 to   v-ope                  .
           move      "La causale contabile e' incompatibile con la causa
      -              "le precedente"
                                          to   v-nt1                  .
           move      "sotto il profilo di 'movimento di bilancio' !"
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-cod-cau-500.
       acc-cod-cau-475.
      *                  *---------------------------------------------*
      *                  * Se la causale attuale e' di iva, e la cau-  *
      *                  * sale precedente non lo era, messaggio di    *
      *                  * errore e reimpostazione                     *
      *                  *---------------------------------------------*
           if        w-sav-cod-cau        =    zero
                     go to acc-cod-cau-550.
           if        w-let-arc-zcc-tmi    not  = "0" and
                     w-tes-tip-mgi (1)    =    "0"
                     go to acc-cod-cau-480
           else      go to acc-cod-cau-550.
