                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Data rif.  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Num. rif.  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      29                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "     Dare           Avere    "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      29                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "-------------- --------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      38                   to   v-pos                  .
           move      "Importo :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo conto                           *
      *    *-----------------------------------------------------------*
       acc-tip-con-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rig-tip-con (1)    to   w-sav-tip-con          .
      *              *-------------------------------------------------*
      *              * Preparazione valore di default                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore di default           *
      *                  *---------------------------------------------*
           move      spaces               to   w-sav-def-tco          .
      *                  *---------------------------------------------*
      *                  * Se valore attuale gia' presente : nessuna   *
      *                  * azione                                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    not  = spaces
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento non iva : nessuna azione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0"
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 1                   *
      *                  *---------------------------------------------*
           if        w-cat-rig-cur        not  = 1
                     go to acc-tip-con-020.
      *                      *-----------------------------------------*
      *                      * Preparazione del default in funzione    *
      *                      * del tipo movimento iva                  *
      *                      *-----------------------------------------*
           if        w-tes-tip-mgi (1)    =   "1" or
                     w-tes-tip-mgi (1)    =   "2" or
                     w-tes-tip-mgi (1)    =   "A" or
                     w-tes-tip-mgi (1)    =   "B"
                     move  "C"            to  w-sav-def-tco
           else if   w-tes-tip-mgi (1)    =   "3"
                     move  "G"            to  w-sav-def-tco
           else if   w-tes-tip-mgi (1)    =   "4" or
                     w-tes-tip-mgi (1)    =   "5" or
                     w-tes-tip-mgi (1)    =   "6" or
                     w-tes-tip-mgi (1)    =   "D" or
                     w-tes-tip-mgi (1)    =   "E"
                     move  "F"            to  w-sav-def-tco           .
           go to     acc-tip-con-100.
       acc-tip-con-020.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 2                   *
      *                  *---------------------------------------------*
           if        w-cat-rig-cur        not  = 2
                     go to acc-tip-con-040.
      *                      *-----------------------------------------*
      *                      * Preparazione del default 'G'            *
      *                      *-----------------------------------------*
           move      "G"                  to   w-sav-def-tco          .
           go to     acc-tip-con-100.
       acc-tip-con-040.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 3                   *
      *                  *---------------------------------------------*
           if        w-cat-rig-cur        not  = 3
                     go to acc-tip-con-050.
      *                      *-----------------------------------------*
      *                      * Preparazione del default 'G' purche' il *
      *                      * totale iva sia diverso da zero e diver- *
      *                      * so dal totale non deducibile            *
      *                      *-----------------------------------------*
           if        w-tes-iva-tim (1)    not  = zero      and
                     w-tes-iva-tim (1)    not  = w-tes-iva-tnd (1)
                     move  "G"            to  w-sav-def-tco           .
           go to     acc-tip-con-100.
       acc-tip-con-050.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 4                   *
      *                  *---------------------------------------------*
           if        w-cat-rig-cur        not  = 4
                     go to acc-tip-con-100.
      *                      *-----------------------------------------*
      *                      * Test su tipo movimento iva              *
      *                      *-----------------------------------------*
           if        w-tes-tip-mgi (1)    not  = "D" and
                     w-tes-tip-mgi (1)    not  = "E"
                     go to acc-tip-con-100.
      *                      *-----------------------------------------*
      *                      * Preparazione del default 'G' purche' il *
      *                      * totale iva sia diverso da zero e diver- *
      *                      * so dal totale non deducibile            *
      *                      *-----------------------------------------*
           if        w-tes-iva-tim (1)    not  = zero      and
                     w-tes-iva-tim (1)    not  = w-tes-iva-tnd (1)
                     move  "G"            to  w-sav-def-tco           .
           go to     acc-tip-con-100.
       acc-tip-con-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      14                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso a meno che non si *
      *                      *        sia in impostazione skeleton e   *
      *                      *        si sia sulla prima riga          *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
           if        w-tes-imp-ske        not  = spaces and
                     w-cat-rig-cur        =    1
                     move  spaces         to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : ammesso solo se valore preceden- *
      *                      *        te a spazi e nessun default      *
      *                      *-----------------------------------------*
           if        w-sav-tip-con        =    spaces   and
                     w-sav-def-tco        =    spaces
                     move  "FIND"         to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso a meno che non si *
      *                      *        sia in impostazione skeleton e   *
      *                      *        la pagina attualmente visualiz-  *
      *                      *        zata e' la prima                 *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
           if        w-tes-imp-ske        not  = spaces and
                     w-cnt-cor-nrp-vis    =    1
                     move  spaces         to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-con (1)    to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Rivisitazione dei tasti funzione ammes- *
      *                      * si in funzione del tipo movimento       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se tipo movimento non iva : nessuna *
      *                          * azione particolare                  *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0"
                     go to acc-tip-con-200.
      *                          *-------------------------------------*
      *                          * Se tipo movimento corrispettivi  :  *
      *                          * nessuna azione particolare          *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "3"
                     go to acc-tip-con-200.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 1 si disa-  *
      *                          * bilitano Insr e Remv                *
      *                          *-------------------------------------*
           if        w-cat-rig-cur        =    1
                     move  spaces         to   v-pfk (04)
                     move  spaces         to   v-pfk (06)             .
       acc-tip-con-200.
      *                      *-----------------------------------------*
      *                      * Se e' stato preparato un valore di de-  *
      *                      * fault si propone questo                 *
      *                      *-----------------------------------------*
           if        w-sav-def-tco        not  = spaces
                     move  w-sav-def-tco  to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-con-220.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-con-400.
       acc-tip-con-240.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-con-280.
       acc-tip-con-250.
      *                  *---------------------------------------------*
      *                  * Find su tipi conto                          *
      *                  *---------------------------------------------*
           perform   fnd-tip-con-000      thru fnd-tip-con-999        .
           if        w-fnd-tip-con-sel    not  = spaces
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Valore selezionato in campo di destinazione *
      *                  *---------------------------------------------*
           move      w-fnd-tip-con-tip    to    v-alf                 .
           move      v-alf                to    w-rig-tip-con (1)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo conto                  *
      *                  *---------------------------------------------*
           perform   vis-tip-con-000      thru vis-tip-con-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A controllo valore impostato                *
      *                  *---------------------------------------------*
           go to     acc-tip-con-400.
       acc-tip-con-280.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-con-300
           else      go to acc-tip-con-350.
       acc-tip-con-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-con-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-con-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-con-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-con-310.
       acc-tip-con-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-con-999.
       acc-tip-con-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-con-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-con-999
                     else    go to acc-tip-con-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-con-999.
       acc-tip-con-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga non new                             *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-tip-con-450.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento iva                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0"
                     go to acc-tip-con-450.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 1                   *
      *                  *---------------------------------------------*
           if        w-cat-rig-cur        not  = 1
                     go to acc-tip-con-450.
      *                      *-----------------------------------------*
      *                      * Se tipo movimento corrispettivi         *
      *                      *-----------------------------------------*
           if        w-tes-tip-mgi (1)    not  = "3"
                     go to acc-tip-con-410.
      *                          *-------------------------------------*
      *                          * Il valore attuale puo' essere solo  *
      *                          * 'G' oppure 'C'                      *
      *                          *-------------------------------------*
           if        v-alf                =    "G" or
                     v-alf                =    "C"
                     go to acc-tip-con-450
           else      go to acc-tip-con-100.
       acc-tip-con-410.
      *                      *-----------------------------------------*
      *                      * Se altro tipo movimento iva             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Il valore attuale deve essere ugua- *
      *                          * le al valore di default             *
      *                          *-------------------------------------*
           if        v-alf                =    w-sav-def-tco
                     go to acc-tip-con-450
           else      go to acc-tip-con-100.
       acc-tip-con-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        v-alf                =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-con-999
                     else  go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Se non e' uno dei tipi conto previsti si    *
      *                  * tratta come per il tasto Slct               *
      *                  *---------------------------------------------*
           if        v-alf                not  = "G  " and
                     v-alf                not  = "C  " and
                     v-alf                not  = "F  "
                     go to acc-tip-con-300.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Valore impostato in campo di destinazione   *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-tip-con (1)      .
       acc-tip-con-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo trattamento invariato : uscita      *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    =    w-sav-tip-con
                     go to acc-tip-con-800.
       acc-tip-con-800.
       acc-tip-con-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo conto                        *
      *    *-----------------------------------------------------------*
       vis-tip-con-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-rig-tip-con (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-con-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice conto                         *
      *    *-----------------------------------------------------------*
       acc-cod-con-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rig-cod-con (1)    to   w-sav-cod-con          .
      *              *-------------------------------------------------*
      *              * Preparazione valore di default                  *
      *              *-------------------------------------------------*
           perform   acc-cod-con-def-000  thru acc-cod-con-def-999    .
       acc-cod-con-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo conto       *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    =    "C"
                     go to acc-cod-con-110
           else if   w-rig-tip-con (1)    =    "F"
                     go to acc-cod-con-120
           else      go to acc-cod-con-130.
       acc-cod-con-110.
      *                  *---------------------------------------------*
      *                  * Accettazione codice cliente                 *
      *                  *---------------------------------------------*
           move      "AC"                 to   w-cod-mne-cli-ope      .
           if        w-sav-def-cco        not  = zero
                     move  w-sav-def-cco  to   w-cod-mne-cli-cod
           else      move  w-rig-cod-con (1)
                                          to   w-cod-mne-cli-cod      .
           move      17                   to   w-cod-mne-cli-lin      .
           move      14                   to   w-cod-mne-cli-pos      .
           move      17                   to   w-cod-mne-cli-rln      .
           move      25                   to   w-cod-mne-cli-rps      .
           move      zero                 to   w-cod-mne-cli-vln      .
           move      zero                 to   w-cod-mne-cli-vps      .
           move      zero                 to   w-cod-mne-cli-lln      .
           move      zero                 to   w-cod-mne-cli-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if not   (w-tes-tip-mgi (1)    not  = "0"  and
                     w-cat-rig-cur        =    1        )
                     move  "REMV"         to   v-pfk (06)             .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
       acc-cod-con-112.
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           if        w-cod-mne-cli-ope    =    "F+"
                     go to acc-cod-con-113.
           if        w-cod-mne-cli-ope    =    "AC"
                     go to acc-cod-con-114.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-con-113.
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
           go to     acc-cod-con-112.
       acc-cod-con-114.
           move      w-cod-mne-cli-cod    to   v-num                  .
           go to     acc-cod-con-150.
       acc-cod-con-120.
      *                  *---------------------------------------------*
      *                  * Accettazione codice fornitore               *
      *                  *---------------------------------------------*
           move      "AC"                 to   w-cod-mne-fnt-ope      .
           if        w-sav-def-cco        not  = zero
                     move  w-sav-def-cco  to   w-cod-mne-fnt-cod
           else      move  w-rig-cod-con (1)
                                          to   w-cod-mne-fnt-cod      .
           move      17                   to   w-cod-mne-fnt-lin      .
           move      14                   to   w-cod-mne-fnt-pos      .
           move      17                   to   w-cod-mne-fnt-rln      .
           move      25                   to   w-cod-mne-fnt-rps      .
           move      zero                 to   w-cod-mne-fnt-vln      .
           move      zero                 to   w-cod-mne-fnt-vps      .
           move      zero                 to   w-cod-mne-fnt-lln      .
           move      zero                 to   w-cod-mne-fnt-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if not   (w-tes-tip-mgi (1)    not  = "0"  and
                     w-cat-rig-cur        =    1        )
                     move  "REMV"         to   v-pfk (06)             .
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-fnt-foi-000  thru cod-mne-fnt-foi-999    .
       acc-cod-con-122.
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
           if        w-cod-mne-fnt-ope    =    "F+"
                     go to acc-cod-con-123.
           if        w-cod-mne-fnt-ope    =    "AC"
                     go to acc-cod-con-124.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-con-123.
           perform   cod-mne-fnt-foi-000  thru cod-mne-fnt-foi-999    .
           go to     acc-cod-con-122.
       acc-cod-con-124.
           move      w-cod-mne-fnt-cod    to   v-num                  .
           go to     acc-cod-con-150.
       acc-cod-con-130.
      *                  *---------------------------------------------*
      *                  * Accettazione conto di generale              *
      *                  *---------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           if        w-sav-def-cco        not  = zero
                     move  w-sav-def-cco  to   w-cod-mne-pdc-cod
           else      move  w-rig-cod-con (1)
                                          to   w-cod-mne-pdc-cod      .
           move      17                   to   w-cod-mne-pdc-lin      .
           move      14                   to   w-cod-mne-pdc-pos      .
           move      17                   to   w-cod-mne-pdc-dln      .
           move      25                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if not   (w-tes-tip-mgi (1)    not  = "0"  and
                     w-cat-rig-cur        =    1        )
                     move  "REMV"         to   v-pfk (06)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-cod-con-132.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-cod-con-133.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-cod-con-134.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-con-133.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-cod-con-132.
       acc-cod-con-134.
           move      w-cod-mne-pdc-cod    to   v-num                  .
       acc-cod-con-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-con-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-con-999.
       acc-cod-con-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-cod-con (1)      .
       acc-cod-con-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    =    "C"
                     go to acc-cod-con-425.
           if        w-rig-tip-con (1)    =    "F"
                     go to acc-cod-con-450.
      *                  *---------------------------------------------*
      *                  * Se conto di generale                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica piano dei conti      *
      *                      *-----------------------------------------*
           move      w-rig-cod-con (1)    to   w-let-cod-pdc-cod      .
           perform   let-cod-pdc-000      thru let-cod-pdc-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-cod-pdc-des    to   w-rig-des-con (1)      .
           perform   vis-des-con-000      thru vis-des-con-999        .
      *                      *-----------------------------------------*
      *                      * Se anagrafica non esistente : reimpost. *
      *                      *-----------------------------------------*
           if        w-let-cod-pdc-flg    not  = spaces
                     go to acc-cod-con-100.
      *                      *-----------------------------------------*
      *                      * Se codice a zero : reimpostazione, a    *
      *                      * meno che non si sia in impostazione di  *
      *                      * uno skeleton                            *
      *                      *-----------------------------------------*
           if        w-rig-cod-con (1)    not  = zero
                     go to acc-cod-con-600.
           if        w-tes-imp-ske        =    spaces
                     go to acc-cod-con-100
           else      go to acc-cod-con-600.
       acc-cod-con-425.
      *                  *---------------------------------------------*
      *                  * Se conto clienti                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica clienti              *
      *                      *-----------------------------------------*
           move      w-rig-cod-con (1)    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-rag    to   w-rig-des-con (1)      .
           perform   vis-des-con-000      thru vis-des-con-999        .
      *                      *-----------------------------------------*
      *                      * Se anagrafica non esistente : reimpost. *
      *                      *-----------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces
                     go to acc-cod-con-100.
      *                      *-----------------------------------------*
      *                      * Se codice a zero : reimpostazione, a    *
      *                      * meno che non si sia in impostazione di  *
      *                      * uno skeleton                            *
      *                      *-----------------------------------------*
           if        w-rig-cod-con (1)    not  = zero
                     go to acc-cod-con-600.
           if        w-tes-imp-ske        =    spaces
                     go to acc-cod-con-100
           else      go to acc-cod-con-600.
       acc-cod-con-450.
      *                  *---------------------------------------------*
      *                  * Se conto fornitori                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica fornitori            *
      *                      *-----------------------------------------*
           move      w-rig-cod-con (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-rag    to   w-rig-des-con (1)      .
           perform   vis-des-con-000      thru vis-des-con-999        .
      *                      *-----------------------------------------*
      *                      * Se anagrafica non esistente : reimpost. *
      *                      *-----------------------------------------*
           if        w-let-arc-fnt-flg    not  = spaces
                     go to acc-cod-con-100.
      *                      *-----------------------------------------*
      *                      * Se codice a zero : reimpostazione, a    *
      *                      * meno che non si sia in impostazione di  *
      *                      * uno skeleton                            *
      *                      *-----------------------------------------*
           if        w-rig-cod-con (1)    not  = zero
                     go to acc-cod-con-500.
           if        w-tes-imp-ske        =    spaces
                     go to acc-cod-con-100
           else      go to acc-cod-con-600.
       acc-cod-con-500.
      *                      *-----------------------------------------*
      *                      * Controllo se numero documento inserito  *
      *                      *-----------------------------------------*
           perform   det-num-dfd-000      thru det-num-dfd-999        .
           if        w-det-num-dfd-flg    =    spaces
                     go to acc-cod-con-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Attenzione : il documento sembrerebbe gia' inserit
      -              "o con questi   "    to   w-err-box-err-msg      .
           move      "estremi. Si consiglia una verifica prima di proseg
      -              "uire.          "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-cod-con-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    =    "C" or
                     w-rig-tip-con (1)    =    "F"
                     go to acc-cod-con-650.
      *                  *---------------------------------------------*
      *                  * Se conto di generale                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice conto in codice sottoconto       *
      *                      *-----------------------------------------*
           move      w-rig-cod-con (1)    to   w-rig-cod-pdc (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio a spaces                  *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-tip-arc (1)      .
      *                      *-----------------------------------------*
      *                      * Codice archivio a zero                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-cod-arc (1)      .
           go to     acc-cod-con-800.
       acc-cod-con-650.
      *                  *---------------------------------------------*
      *                  * Se conto clienti o fornitori                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo archivio := tipo conto             *
      *                      *-----------------------------------------*
           move      w-rig-tip-con (1)    to   w-rig-tip-arc (1)      .
      *                      *-----------------------------------------*
      *                      * Codice archivio := codice conto         *
      *                      *-----------------------------------------*
           move      w-rig-cod-con (1)    to   w-rig-cod-arc (1)      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto al valore anagrafico  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il codice archivio e' uguale al  *
      *                          * precedente non si esegue l'azione   *
      *                          *-------------------------------------*
           if        w-rig-cod-arc (1)    =    w-sav-cod-con
                     go to acc-cod-con-660.
      *                          *-------------------------------------*
      *                          * Altrimenti si esegue                *
      *                          *-------------------------------------*
           if        w-rig-tip-con (1)    =    "C"
                     move  w-let-arc-cli-cge
                                          to   w-rig-cod-pdc (1)
           else      move  w-let-arc-fnt-cge
                                          to   w-rig-cod-pdc (1)      .
       acc-cod-con-660.
      *                          *-------------------------------------*
      *                          * Controllo che il codice sottoconto  *
      *                          * associato al cliente o fornitore    *
      *                          * esista                              *
      *                          *-------------------------------------*
           move      w-rig-cod-pdc (1)    to   w-let-cod-pdc-cod      .
           perform   let-cod-pdc-000      thru let-cod-pdc-999        .
           if        w-let-cod-pdc-flg    not  = spaces
                     go to acc-cod-con-670.
      *                          *-------------------------------------*
      *                          * Controllo che il codice sottoconto  *
      *                          * associato al cliente o fornitore    *
      *                          * non sia a zero, a meno che non si   *
      *                          * sia in impostazione di uno skeleton *
      *                          * con codice cliente o fornitore man- *
      *                          * cante                               *
      *                          *-------------------------------------*
           if        w-rig-cod-arc (1)    =    zero and
                     w-tes-imp-ske        not  = spaces
                     go to acc-cod-con-700.
           if        w-let-cod-pdc-cod    not  = zero
                     go to acc-cod-con-700.
      *                              *---------------------------------*
      *                              * Messaggio di errore per sotto-  *
      *                              * conto a zero                    *
      *                              *---------------------------------*
           move      "ME"                 to   v-ope                  .
           move      "Il sottoconto contabile relativo e' a zero !"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-cod-con-100.
       acc-cod-con-670.
      *                              *---------------------------------*
      *                              * Messaggio di errore per sotto-  *
      *                              * conto non esistente             *
      *                              *---------------------------------*
           move      "ME"                 to   v-ope                  .
           move      "Sottoconto contabile relativo non esistente !"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-cod-con-100.
       acc-cod-con-700.
      *                      *-----------------------------------------*
      *                      * Codice archivio per movimento iva, solo *
      *                      * se si e' sulla prima riga               *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 1
                     go to acc-cod-con-800.
           if        w-tes-tip-mgi (1)    =    "0" or
                     w-tes-tip-mgi (1)    =    "3"
                     go to acc-cod-con-800.
           move      w-rig-cod-con (1)    to   w-tes-iva-arc (1)      .
       acc-cod-con-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-con-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-con-100.
       acc-cod-con-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice conto                         *
      *    *                                                           *
      *    * Subroutine di trattamento default di accettazione         *
      *    *-----------------------------------------------------------*
       acc-cod-con-def-000.
      *              *-------------------------------------------------*
      *              * Preparazione valore di default                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore di default           *
      *                  *---------------------------------------------*
           move      zero                 to   w-sav-def-cco          .
      *                  *---------------------------------------------*
      *                  * Se valore attuale gia' presente : nessuna   *
      *                  * azione                                      *
      *                  *---------------------------------------------*
           if        w-rig-cod-con (1)    not  = zero
                     go to acc-cod-con-def-900.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento non iva : nessuna azione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0"
                     go to acc-cod-con-def-900.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 1                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su numero riga                     *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 1
                     go to acc-cod-con-def-200.
      *                      *-----------------------------------------*
      *                      * Preparazione del default in funzione    *
      *                      * del tipo movimento iva                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * 3: Cassa                            *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "3"
                     move  w-ref-stc-cas  to   w-sav-def-cco          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     acc-cod-con-def-900.
       acc-cod-con-def-200.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 2                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su numero riga                     *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 2
                     go to acc-cod-con-def-400.
      *                      *-----------------------------------------*
      *                      * Se imposta non presente si preparano i  *
      *                      * defaults relativi alla riga numero 3    *
      *                      *-----------------------------------------*
           if        w-tes-iva-tim (1)    =    zero       or
                     w-tes-iva-tim (1)    =    w-tes-iva-tnd (1)
                     go to acc-cod-con-def-420.
      *                      *-----------------------------------------*
      *                      * Preparazione del default in funzione    *
      *                      * del tipo movimento iva                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * 1-2-A-B: Iva vendite                *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "1" or
                     w-tes-tip-mgi (1)    =    "2" or
                     w-tes-tip-mgi (1)    =    "A" or
                     w-tes-tip-mgi (1)    =    "B"
                     move  w-ref-iva-ven  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * 3: Iva corrispettivi                *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "3"
                     move  w-ref-iva-cor  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * 4-5-6: Iva acquisti                 *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "4" or
                     w-tes-tip-mgi (1)    =    "5" or
                     w-tes-tip-mgi (1)    =    "6"
                     move  w-ref-iva-acq  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * D-E: Iva a credito acquisti intrac. *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "D" or
                     w-tes-tip-mgi (1)    =    "E"
                     move  w-ref-iva-cai  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * Se Reverse Charge                   *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "D" and
                     w-tes-iva-rfp (1)    =    "R"
                     move  w-ref-iva-car  to   w-sav-def-cco          .
           if        w-tes-tip-mgi (1)    =    "E" and
                     w-tes-iva-rfp (1)    =    "R"
                     move  w-ref-iva-car  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     acc-cod-con-def-900.
       acc-cod-con-def-400.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 3                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su numero riga                     *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 3
                     go to acc-cod-con-def-500.
      *                      *-----------------------------------------*
      *                      * Se imposta non presente si preparano i  *
      *                      * defaults relativi alla riga numero 4    *
      *                      *-----------------------------------------*
           if        w-tes-iva-tim (1)    =    zero       or
                     w-tes-iva-tim (1)    =    w-tes-iva-tnd (1)
                     go to acc-cod-con-def-520.
       acc-cod-con-def-420.
      *                      *-----------------------------------------*
      *                      * Preparazione del default in funzione    *
      *                      * del tipo movimento iva                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * 1: Vendite                          *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "1" or
                     w-tes-tip-mgi (1)    =    "A"
                     move  w-ref-stc-ven  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * 2: Resi su vendite                  *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "2" or
                     w-tes-tip-mgi (1)    =    "B"
                     move  w-ref-res-ven  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * 3: Corrispettivi                    *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "3"
                     move  w-ref-stc-cor  to   w-sav-def-cco          .
      *                          *-------------------------------------*
      *                          * 4: Resi su acquisti                 *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =    "4"
