      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo CGE             *
      *    *-----------------------------------------------------------*
       att-num-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [prtcge]                                  *
      *              *-------------------------------------------------*
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   rn-prt-cge-saa-dtr     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [prtcge]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-num-prt-000.
       att-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   rn-prt-cge-num-prt     .
           if        rn-prt-cge-num-prt   =    zero
                     move  1              to   rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      rn-prt-cge-num-prt   to   w-tes-num-prt          .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-num-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero protocollo           *
      *                  *---------------------------------------------*
           perform   vis-num-prt-000      thru vis-num-prt-999        .
       att-num-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo                   *
      *    *-----------------------------------------------------------*
       rip-num-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [prtcge]                                  *
      *              *-------------------------------------------------*
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   rn-prt-cge-saa-dtr     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [prtcge]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato : uscita                 *
      *                  *---------------------------------------------*
           go to     rip-num-prt-999.
       rip-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Confronto con attuale numero protocollo *
      *                      *-----------------------------------------*
           if        rn-prt-cge-num-prt   =    w-tes-num-prt
                     go to  rip-num-prt-200.
      *                          *-------------------------------------*
      *                          * Se diverso non si esegue alcun con- *
      *                          * troaggiornamento                    *
      *                          *-------------------------------------*
           go to     rip-num-prt-900.
       rip-num-prt-200.
      *                          *-------------------------------------*
      *                          * Se uguale si esegue il contro-      *
      *                          * aggiornamento                       *
      *                          *-------------------------------------*
           subtract  1                    from rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
       rip-num-prt-900.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
       rip-num-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo iva fornitori   *
      *    *-----------------------------------------------------------*
       att-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
       att-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       att-prt-ivf-150.
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-prt-ivf-300.
       att-prt-ivf-200.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                  *---------------------------------------------*
      *                  * A ripetizione operazione                    *
      *                  *---------------------------------------------*
           go to     att-prt-ivf-100.
       att-prt-ivf-300.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore originale            *
      *                  *---------------------------------------------*
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-dec      .
      *                  *---------------------------------------------*
      *                  * Incremento numero protocollo                *
      *                  *---------------------------------------------*
           add       1                    to   rn-prt-ivf-num-prt     .
           if        rn-prt-ivf-num-prt   =    zero
                     move  1              to   rn-prt-ivf-num-prt     .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero protocollo           *
      *                  *---------------------------------------------*
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-prt      .
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-inc      .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                  *---------------------------------------------*
      *                  * Se errori ripete l'intera operazione        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-prt-ivf-100.
      *                  *---------------------------------------------*
      *                  * Unlock                                      *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       att-prt-ivf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     att-prt-ivf-999.
       att-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di ratifica numero protocollo iva fornitori       *
      *    *-----------------------------------------------------------*
       rat-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Se il valore e' stato ratificato : uscita       *
      *              *-------------------------------------------------*
           if        w-num-prt-ivf-prt    =    w-num-prt-ivf-inc
                     go to rat-prt-ivf-999.
      *              *-------------------------------------------------*
      *              * Se il valore impostato e' inferiore al valore   *
      *              * originale si esegue il ripristino               *
      *              *-------------------------------------------------*
           if        w-num-prt-ivf-prt    >    w-num-prt-ivf-inc
                     go to rat-prt-ivf-200.
           perform   rip-prt-ivf-000      thru rip-prt-ivf-999        .
           move      spaces               to   w-num-prt-ivf-flg      .
           go to     rat-prt-ivf-999.
       rat-prt-ivf-200.
      *              *-------------------------------------------------*
      *              * Se il valore impostato e' superiore al valore   *
      *              * originale si chiede all'operatore se la numera- *
      *              * zione dovra' poi proseguire con il numero suc-  *
      *              * cessivo                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero progressivo editato     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-num-prt-ivf-prt    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Richiesta all'operatore                     *
      *                  *---------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      spaces               to   v-not                  .
           string    "La numerazione dovra' poi proseguire dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " (S/N) ?" delimited by   size
                                          into v-not                  .
           move      spaces               to   v-alf                  .
           move      "SN"                 to   v-msk                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Esame risposta                              *
      *                  *---------------------------------------------*
           if        v-alf                =    "S"
                     go to rat-prt-ivf-400
           else if   v-alf                =    "N"
                     go to rat-prt-ivf-999
           else      go to rat-prt-ivf-200.
       rat-prt-ivf-400.
      *                  *---------------------------------------------*
      *                  * Se risposta 'Si'                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento numerazione               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura numerazione                 *
      *                          *-------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to rat-prt-ivf-600.
      *                          *-------------------------------------*
      *                          * Se numerazione non esistente la si  *
      *                          * crea normalizzata a zero            *
      *                          *-------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rat-prt-ivf-400.
       rat-prt-ivf-600.
      *                          *-------------------------------------*
      *                          * Aggiornamento numerazione           *
      *                          *-------------------------------------*
           move      w-num-prt-ivf-prt    to   rn-prt-ivf-num-prt     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                not  = e-not-err
                     go to rat-prt-ivf-400.
       rat-prt-ivf-800.
      *                          *-------------------------------------*
      *                          * Unlock della numerazione            *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       rat-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo iva fornitori     *
      *    *-----------------------------------------------------------*
       rip-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to rip-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rip-prt-ivf-000.
       rip-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-prt-ivf-num-prt   =    w-num-prt-ivf-inc
                     go to rip-prt-ivf-200
           else      go to rip-prt-ivf-400.
       rip-prt-ivf-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento numerazione         *
      *                      *-----------------------------------------*
           move      w-num-prt-ivf-dec    to   rn-prt-ivf-num-prt     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-prt-ivf-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rip-prt-ivf-999.
       rip-prt-ivf-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-prt-ivf-num-prt   =    w-num-prt-ivf-prt
                     go to rip-prt-ivf-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Preparazione numero progressivo *
      *                              * editato                         *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-num-prt-ivf-inc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                              *---------------------------------*
      *                              * Messaggio all'operatore         *
      *                              *---------------------------------*
           move      "ME"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           move      "Attenzione : un altro utente ha nel frattempo prel
      -              "evato un numero."   to   v-nt1                  .
           string    "Pertanto il numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rip-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se impostazione skeleton si esegue l'apposita   *
      *              * routine di scrittura e si esce                  *
      *              *-------------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     perform scr-ske-fil-000
                                          thru scr-ske-fil-999
                     go to   scr-mov-fil-999.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Se fine : a trattamento righe "in vita"     *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [mgr]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-mgr-000      thru del-rec-mgr-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           move      spaces               to   w-tes-var-cor          .
           if        w-tes-cod-cau (1)    not  = w-tes-cod-cau (2) or
                     w-tes-snx-mob (1)    not  = w-tes-snx-mob (2) or
                     w-tes-tip-mgi (1)    not  = w-tes-tip-mgi (2) or
                     w-tes-dat-doc (1)    not  = w-tes-dat-doc (2) or
                     w-tes-num-doc (1)    not  = w-tes-num-doc (2)
                     move  "#"            to   w-tes-var-cor          .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Se start non valida : uscita                *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento file [mgr]                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se importo a zero si ignora la riga a meno  *
      *                  * che non si sia gia' accettato il totale del *
      *                  * documento a zero                            *
      *                  *---------------------------------------------*
           if        w-cst-flg-zer        not  = spaces
                     go to scr-mov-fil-320.
           if        w-rig-imp-mov (1)    =    zero
                     go to scr-mov-fil-300.
       scr-mov-fil-320.
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [mgr]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-mgr-000      thru wrt-rec-mgr-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-con (2)    =    spaces
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-tes-var-cor        not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [mgr]                       *
      *                          *-------------------------------------*
           perform   rew-rec-mgr-000      thru rew-rec-mgr-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Trattamento file [mgt]                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-800.
      *                      *-----------------------------------------*
      *                      * Write record [mgt]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-mgt-000      thru wrt-rec-mgt-999        .
      *                      *-----------------------------------------*
      *                      * Write record [mgi]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-mgi-000      thru wrt-rec-mgi-999        .
           go to     scr-mov-fil-900.
       scr-mov-fil-800.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Rewrite record [mgt]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-mgt-000      thru rew-rec-mgt-999        .
      *                      *-----------------------------------------*
      *                      * Trattamento record [mgi]                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se in modalita' utility        *
      *                          *-------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "UT"
                     go to scr-mov-fil-850.
      *                          *-------------------------------------*
      *                          * Test se variato solamente il flag   *
      *                          * di pertinenza anno precedente       *
      *                          *-------------------------------------*
           if        w-tes-iva-cop (1)    not  = w-tes-iva-cop (2)
                     go to scr-mov-fil-850.
      *                          *-------------------------------------*
      *                          * Test se la parte Iva e' gia' stata  *
      *                          * sottoposta alla stampa del giornale *
      *                          * Iva                                 *
      *                          *-------------------------------------*
           if        w-tes-iva-fgi (1)    not  = spaces
                     go to scr-mov-fil-900.
       scr-mov-fil-850.
      *                          *-------------------------------------*
      *                          * Rewrite record [mgi]                *
      *                          *-------------------------------------*
           perform   rew-rec-mgi-000      thru rew-rec-mgi-999        .
       scr-mov-fil-900.
      *              *-------------------------------------------------*
      *              * Scrittura pareggiamenti automatici acconti      *
      *              * clienti o fornitori                             *
      *              *-------------------------------------------------*
           perform   scr-pau-acf-000      thru scr-pau-acf-999        .
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se impostazione skeleton si esegue l'apposita   *
      *              * routine di cancellazione e si esce              *
      *              *-------------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     perform del-ske-fil-000
                                          thru del-ske-fil-999
                     go to   del-mov-fil-999.
      *              *-------------------------------------------------*
      *              * Cancellazione righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Se start non valida : a testata         *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-mov-fil-500.
       del-mov-fil-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale righe corpo             *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           call      "pgm/cge/prg/obj/pcge3002"
                                         using w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Se at end : a testata                   *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Delete record file [mgr]                    *
      *                  *---------------------------------------------*
           perform   del-rec-mgr-000      thru del-rec-mgr-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura riga corpo successiva     *
      *                  *---------------------------------------------*
           go to     del-mov-fil-100.
       del-mov-fil-500.
      *              *-------------------------------------------------*
      *              * Cancellazione testata file [mgt]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Delete record [mgt]                         *
      *                  *---------------------------------------------*
           perform   del-rec-mgt-000      thru del-rec-mgt-999        .
      *                  *---------------------------------------------*
      *                  * Delete record [mgi]                         *
      *                  *---------------------------------------------*
           perform   del-rec-mgi-000      thru del-rec-mgi-999        .
       del-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record [mgr]                                 *
      *    *-----------------------------------------------------------*
       cmp-rec-mgr-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      w-tes-dat-reg        to   rf-mgr-dat-reg         .
           move      w-tes-num-prt        to   rf-mgr-num-prt         .
           move      w-cat-rig-prg        to   rf-mgr-num-prg         .
           move      w-rig-cod-pdc (1)    to   rf-mgr-cod-pdc         .
           move      w-rig-tip-con (1)    to   rf-mgr-tip-arc         .
      *
           if        rf-mgr-tip-arc       =    "G"
                     move  zero           to   rf-mgr-cod-arc
           else      move  w-rig-cod-arc (1)
                                          to   rf-mgr-cod-arc         .
      *
           move      w-tes-cod-cau (1)    to   rf-mgr-cod-cau         .
           move      w-tes-snx-mob (1)    to   rf-mgr-snx-mob         .
           move      w-tes-tip-mgi (1)    to   rf-mgr-tip-iva         .
           move      w-rig-com-rig (1)    to   rf-mgr-com-rig         .
           move      w-tes-dat-doc (1)    to   rf-mgr-dat-doc         .
           move      w-tes-num-doc (1)    to   rf-mgr-num-doc         .
      *
           if        rf-mgr-tip-arc       =    "G"
                     move  zero           to   rf-mgr-dat-rif
                     move  spaces         to   rf-mgr-num-rif
                     go to cmp-rec-mgr-800.
       cmp-rec-mgr-600.
           if        w-rig-dat-rif (1)    not  = zero
                     move  w-rig-dat-rif (1)
                                          to   rf-mgr-dat-rif
                     go to cmp-rec-mgr-700.
           if        w-tes-dat-doc (1)    not  = zero
                     move  w-tes-dat-doc (1)
                                          to   rf-mgr-dat-rif
                     go to cmp-rec-mgr-700.
           move      w-tes-dat-reg        to   rf-mgr-dat-rif         .
       cmp-rec-mgr-700.
           if        w-rig-num-rif (1)    not  = spaces
                     move  w-rig-num-rif (1)
                                          to   rf-mgr-num-rif
                     go to cmp-rec-mgr-800.
           if        w-tes-num-doc (1)    not  = spaces
                     move  w-tes-num-doc (1)
                                          to   rf-mgr-num-rif
                     go to cmp-rec-mgr-800.
      *
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-prt        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   rf-mgr-num-rif         .
       cmp-rec-mgr-800.
           move      w-rig-dar-ave (1)    to   rf-mgr-dar-ave         .
           move      w-rig-imp-mov (1)    to   rf-mgr-imp-mov         .
           move      w-rig-flg-pge (1)    to   rf-mgr-flg-pge         .
           move      w-rig-flg-pcf (1)    to   rf-mgr-flg-pcf         .
       cmp-rec-mgr-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [mgr]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-mgr-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento [mgs] corrispondente              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In piu'                                     *
      *                  *---------------------------------------------*
           move      w-dnu-300-bil-ese    to   w-agg-mgs-ese-bil      .
           move      w-tes-dat-reg        to   w-agg-mgs-dat-reg      .
           move      w-rig-tip-con (1)    to   w-agg-mgs-tip-arc      .
           move      w-rig-cod-arc (1)    to   w-agg-mgs-cod-arc      .
           move      w-rig-cod-pdc (1)    to   w-agg-mgs-cod-pdc      .
           move      "+"                  to   w-agg-mgs-tip-agg      .
           move      w-tes-snx-mob (1)    to   w-agg-mgs-snx-mob      .
           move      w-rig-dar-ave (1)    to   w-agg-mgs-dar-ave      .
           move      w-rig-imp-mov (1)    to   w-agg-mgs-imp-mov      .
           perform   agg-con-000-000      thru agg-con-000-999        .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-mgr-000      thru cmp-rec-mgr-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
       wrt-rec-mgr-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record [mgr]                                  *
      *    *-----------------------------------------------------------*
       rew-rec-mgr-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento [mgs] corrispondente              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In meno                                     *
      *                  *---------------------------------------------*
           move      w-dnu-300-bil-ese    to   w-agg-mgs-ese-bil      .
           move      w-tes-dat-reg        to   w-agg-mgs-dat-reg      .
           move      w-rig-tip-con (2)    to   w-agg-mgs-tip-arc      .
