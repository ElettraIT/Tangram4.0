       acc-num-rif-200.
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    =    "C"
                     go to acc-num-rif-225
           else if   w-rig-tip-con (1)    =    "F"
                     go to acc-num-rif-250
           else      go to acc-num-rif-100.
       acc-num-rif-225.
      *                  *---------------------------------------------*
      *                  * Se conto clienti                            *
      *                  *---------------------------------------------*
           move      w-rig-cod-con (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-num-rif-100.
           move      w-fnd-rif-cli-dat    to   w-rig-dat-rif (1)      .
           move      w-fnd-rif-cli-num    to   w-rig-num-rif (1)      .
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
           move      spaces               to   v-key                  .
           go to     acc-num-rif-400.
       acc-num-rif-250.
      *                  *---------------------------------------------*
      *                  * Se conto fornitori                          *
      *                  *---------------------------------------------*
           move      w-rig-cod-con (1)    to   w-fnd-rif-fnt-cod      .
           perform   fnd-rif-fnt-000      thru fnd-rif-fnt-999        .
           if        w-fnd-rif-fnt-sel    not  = spaces
                     go to acc-num-rif-100.
           move      w-fnd-rif-fnt-dat    to   w-rig-dat-rif (1)      .
           move      w-fnd-rif-fnt-num    to   w-rig-num-rif (1)      .
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
           move      spaces               to   v-key                  .
           go to     acc-num-rif-400.
       acc-num-rif-300.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-num-rif-400.
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    =    "C"
                     go to acc-num-rif-325
           else if   w-rig-tip-con (1)    =    "F"
                     go to acc-num-rif-350
           else      go to acc-num-rif-100.
       acc-num-rif-325.
      *                  *---------------------------------------------*
      *                  * Se conto clienti                            *
      *                  *---------------------------------------------*
           move      spaces               to   w-lnk-exi-sts          .
           perform   ins-rif-cli-000      thru ins-rif-cli-999        .
           if        w-lnk-exi-sts        not  = spaces
                     move   "E"           to   w-cnt-tus-acc-rig
                     go to  acc-num-rif-999
           else      go to  acc-num-rif-100.
       acc-num-rif-350.
      *                  *---------------------------------------------*
      *                  * Se conto fornitori                          *
      *                  *---------------------------------------------*
           move      spaces               to   w-lnk-exi-sts          .
           perform   ins-rif-fnt-000      thru ins-rif-fnt-999        .
           if        w-lnk-exi-sts        not  = spaces
                     move   "E"           to   w-cnt-tus-acc-rig
                     go to  acc-num-rif-999
           else      go to  acc-num-rif-100.
       acc-num-rif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  " and
                     w-rig-num-rif (1)    =    spaces
                     go to acc-num-rif-999.
           if        w-rig-num-rif (1)    =    spaces
                     go to acc-num-rif-100.
       acc-num-rif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-rif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-num-rif-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-num-rif-100.
       acc-num-rif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero riferimento                *
      *    *-----------------------------------------------------------*
       vis-num-rif-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-imp-ske        not  = spaces
                     go to vis-num-rif-999.
           if        w-rig-tip-con (1)    not  = "C" and
                     w-rig-tip-con (1)    not  = "F"
                     go to vis-num-rif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-rig-num-rif (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-rif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Importo movimento                    *
      *    *-----------------------------------------------------------*
       acc-imp-mov-000.
      *              *-------------------------------------------------*
      *              * Preparazione default di Dare o Avere e Importo  *
      *              * movimento                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valori attuali gia' presenti : nessuna   *
      *                  * azione                                      *
      *                  *---------------------------------------------*
           if        w-rig-dar-ave (1)    not  = spaces and
                     w-rig-imp-mov (1)    not  = zero
                     go to acc-imp-mov-100.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento iva                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-mgi (1)    =    "0"
                     go to acc-imp-mov-050.
      *                      *-----------------------------------------*
      *                      * Se si e' in riga numero 1               *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 1
                     go to acc-imp-mov-010.
      *                          *-------------------------------------*
      *                          * Preparazione del dare/avere in fun- *
      *                          * zione del tipo movimento iva        *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =   "1" or
                     w-tes-tip-mgi (1)    =   "3" or
                     w-tes-tip-mgi (1)    =   "4" or
                     w-tes-tip-mgi (1)    =   "A" or
                     w-tes-tip-mgi (1)    =   "D"
                     move  "D"            to  w-rig-dar-ave (1)       .
           if        w-tes-tip-mgi (1)    =   "2" or
                     w-tes-tip-mgi (1)    =   "5" or
                     w-tes-tip-mgi (1)    =   "6" or
                     w-tes-tip-mgi (1)    =   "B" or
                     w-tes-tip-mgi (1)    =   "E"
                     move  "A"            to  w-rig-dar-ave (1)       .
      *                          *-------------------------------------*
      *                          * Importo movimento                   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se acquisto non intracomunit.   *
      *                              *---------------------------------*
           if        w-tes-tip-mgi (1)    not  = "D" and
                     w-tes-tip-mgi (1)    not  = "E"
                     move  w-tes-iva-tdo (1)
                                          to   w-rig-imp-mov (1)
                     go to acc-imp-mov-100.
      *                              *---------------------------------*
      *                              * Se acquisto intracomunitario    *
      *                              *---------------------------------*
           move      w-tes-iva-tib (1)    to   w-rig-imp-mov (1)      .
           add       w-tes-iva-tnd (1)    to   w-rig-imp-mov (1)      .
           go to     acc-imp-mov-100.
       acc-imp-mov-010.
      *                      *-----------------------------------------*
      *                      * Se si e' in riga numero 2               *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 2
                     go to acc-imp-mov-020.
      *                          *-------------------------------------*
      *                          * Preparazione del dare/avere in fun- *
      *                          * zione del tipo movimento iva        *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    =   "1" or
                     w-tes-tip-mgi (1)    =   "3" or
                     w-tes-tip-mgi (1)    =   "4" or
                     w-tes-tip-mgi (1)    =   "A" or
                     w-tes-tip-mgi (1)    =   "D"
                     move  "A"            to  w-rig-dar-ave (1)       .
           if        w-tes-tip-mgi (1)    =   "2" or
                     w-tes-tip-mgi (1)    =   "5" or
                     w-tes-tip-mgi (1)    =   "6" or
                     w-tes-tip-mgi (1)    =   "B" or
                     w-tes-tip-mgi (1)    =   "E"
                     move  "D"            to  w-rig-dar-ave (1)       .
      *                          *-------------------------------------*
      *                          * Preparazione dell'importo movim.    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se iva presente                 *
      *                              *---------------------------------*
           if        w-tes-iva-tim (1)    =    zero       or
                     w-tes-iva-tim (1)    =    w-tes-iva-tnd (1)
                     go to acc-imp-mov-050.
           subtract  w-tes-iva-tnd (1)    from w-tes-iva-tim (1)
                                        giving w-rig-imp-mov (1)      .
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-imp-mov-100.
       acc-imp-mov-020.
      *                      *-----------------------------------------*
      *                      * Se si e' in riga numero 3               *
      *                      *-----------------------------------------*
           if        w-cat-rig-cur        not  = 3
                     go to acc-imp-mov-050.
      *                          *-------------------------------------*
      *                          * Se imposta non presente : ad accet- *
      *                          * tazione                             *
      *                          *-------------------------------------*
           if        w-tes-iva-tim (1)    =    zero       or
                     w-tes-iva-tim (1)    =    w-tes-iva-tnd (1)
                     go to acc-imp-mov-050.
      *                          *-------------------------------------*
      *                          * Preparazione del dare/avere in fun- *
      *                          * zione del tipo movimento iva        *
      *                          *-------------------------------------*
           if        w-tes-tip-mgi (1)    not  = "D" and
                     w-tes-tip-mgi (1)    not  = "E"
                     go to acc-imp-mov-050.
           if        w-tes-tip-mgi (1)    =   "D"
                     move  "D"            to  w-rig-dar-ave (1)       .
           if        w-tes-tip-mgi (1)    =   "E"
                     move  "A"            to  w-rig-dar-ave (1)       .
      *                          *-------------------------------------*
      *                          * Preparazione dell'importo movim.    *
      *                          *-------------------------------------*
           subtract  w-tes-iva-tnd (1)    from w-tes-iva-tim (1)
                                        giving w-rig-imp-mov (1)      .
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-imp-mov-100.
       acc-imp-mov-050.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento non iva                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione del dare/avere in funzio-  *
      *                      * ne del saldo registrazione              *
      *                      *-----------------------------------------*
           if        w-rig-dar-ave (1)    not  = spaces
                     go to acc-imp-mov-075.
           if        w-tes-sdo-reg        >    zero
                     move  "A"            to   w-rig-dar-ave (1)
           else      move  "D"            to   w-rig-dar-ave (1)      .
       acc-imp-mov-075.
      *                      *-----------------------------------------*
      *                      * Importo : valore assoluto del saldo     *
      *                      * registrazione                           *
      *                      *-----------------------------------------*
           if        w-rig-imp-mov (1)    not  = zero
                     go to acc-imp-mov-100.
           if       (w-tes-sdo-reg        >    zero and
                     w-rig-dar-ave (1)    =    "D"    ) or
                    (w-tes-sdo-reg        <    zero and
                     w-rig-dar-ave (1)    =    "A"    )
                     go to acc-imp-mov-100.
           move      w-tes-sdo-reg        to   w-rig-imp-mov (1)      .
           if        w-rig-imp-mov (1)    <    zero
                     multiply   -1        by   w-rig-imp-mov (1)      .
       acc-imp-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
      *
           if        w-rig-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
      *
           move      "GB"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                  *---------------------------------------------*
      *                  * Se movimento IVA e prima riga REMV non      *
      *                  * attivo                                      *
      *                  *---------------------------------------------*
           if not   (w-tes-tip-mgi (1)    not  = "0"  and
                     w-cat-rig-cur        =    1        )
                     move  "REMV"         to   v-pfk (06)             .
      *                  *---------------------------------------------*
      *                  * Se movimento IVA e prima riga TAB non       *
      *                  * attivo                                      *
      *                  *---------------------------------------------*
           if not   (w-tes-tip-mgi (1)    not  = "0"  and
                     w-cat-rig-cur        =    1        )
                     move  "TAB "         to   v-pfk (10)             .
      *                  *---------------------------------------------*
      *                  * Test se in modalita' utility                *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "UT"
                     move  "TAB "         to   v-pfk (10)             .
      *                  *---------------------------------------------*
      *                  * Valore in campo di accettazione             *
      *                  *---------------------------------------------*
           move      w-rig-imp-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-mov-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-mov-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-mov (1)      .
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "TAB "
                     go to acc-imp-mov-400.
      *                  *---------------------------------------------*
      *                  * Salvataggio importo movimento precedente    *
      *                  *---------------------------------------------*
           move      w-rig-imp-mov (1)    to   w-sav-imp-mov          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo movimento a zero    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-imp-mov (1)      .
           perform   vis-imp-mov-000      thru vis-imp-mov-999        .
      *                  *---------------------------------------------*
      *                  * Ripristino importo movimento precedente     *
      *                  *---------------------------------------------*
           move      w-sav-imp-mov        to   w-rig-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Inversione del segnale di Dare o Avere      *
      *                  *---------------------------------------------*
           if        w-rig-dar-ave (1)    =    "A"
                     move  "D"            to   w-rig-dar-ave (1)
           else      move  "A"            to   w-rig-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-imp-mov-100.
       acc-imp-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-imp-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-mov-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-mov-100.
       acc-imp-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo movimento                 *
      *    *-----------------------------------------------------------*
       vis-imp-mov-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
      *
           if        w-rig-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
      *
           move      "G"                  to   v-edm                  .
           move      w-rig-imp-mov (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Saldo registrazione               *
      *    *-----------------------------------------------------------*
       vis-sdo-reg-000.
      *
           move      spaces               to   w-lin-imm-imp-mov      .
      *
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-tes-sdo-reg        to   v-num                  .
           if        v-num                <    zero
                     multiply  -1         by   v-num                  .
           move      "G"                  to   v-edm                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           if        w-tes-sdo-reg        <    zero
                     move  v-edt          to   w-lin-imm-imp-ave
           else      move  v-edt          to   w-lin-imm-imp-dar      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      33                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      48                   to   v-pos                  .
           move      w-lin-imm-imp-mov    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdo-reg-999.
           exit.

      *    *===========================================================*
      *    * Find su tipi conto                                        *
      *    *-----------------------------------------------------------*
       fnd-tip-con-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di selezione               *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-tip-con-sel      .
      *              *-------------------------------------------------*
      *              * Salvataggio del video attuale                   *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-con-lun    to   v-car                  .
           move      w-exp-tip-con-num    to   v-ldt                  .
           move      "GCF#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-exp-tip-con-tbl    to   v-txt                  .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Valore in campo di destinazione                 *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "G"            to   w-fnd-tip-con-tip
           else if   v-num                =    02
                     move  "C"            to   w-fnd-tip-con-tip
           else if   v-num                =    03
                     move  "F"            to   w-fnd-tip-con-tip
           else      move  spaces         to   w-fnd-tip-con-tip      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fnd-tip-con-999.
       fnd-tip-con-999.
           exit.

      *    *===========================================================*
      *    * Find su movimenti contabili                               *
      *    *-----------------------------------------------------------*
       fnd-mov-con-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-mov-con-sel      .
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pcge3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-mov-con-sel
                     go to  fnd-mov-con-999.
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per possibili- *
      *              * ta' di function-key "SLCT" durante l'interroga- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "pgm/cge/prg/obj/pcge3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
      *              *-------------------------------------------------*
      *              * Estrazione di eventuale variabile di i.p.c. de- *
      *              * terminata da function-key "SLCT" durante l'in-  *
      *              * terrogazione                                    *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "select datreg"      to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-mov-con-sel
                     go to fnd-mov-con-999.
           move      s-dat                to   w-fnd-mov-con-dat      .
           move      "CV"                 to   s-ope                  .
           move      "select numprt"      to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
