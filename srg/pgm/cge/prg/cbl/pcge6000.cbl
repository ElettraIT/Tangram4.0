      *              *-------------------------------------------------*
           if        w-sav-dat-mov        =    zero
                     go to ctl-rig-doc-600.
           if        w-rig-dat-mov (1)    not  < w-sav-dat-mov
                     go to ctl-rig-doc-600.
      *              *-------------------------------------------------*
      *              * Flag di uscita                                  *
      *              *-------------------------------------------------*
           move      "D"                  to   w-ctl-rig-doc-flg      .
           go to     ctl-rig-doc-850.
       ctl-rig-doc-600.
