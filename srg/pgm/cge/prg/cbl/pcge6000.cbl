      *              *-------------------------------------------------*
           if        w-ctl-rig-doc-flg    =    "D"
                     move  "Le date non rispettano la progressivita'"
                                          to   w-err-box-err-msg
           else if   w-ctl-rig-doc-flg    =    "S"
                     move  "Il bene e' stato ceduto ma risulta ancora da
      -                    " ammortizzare"
                                          to   w-err-box-err-msg
           else      move  spaces         to   w-err-box-err-msg      .
       ctl-rig-doc-900.
