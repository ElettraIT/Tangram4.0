           copy      "pgm/cge/prg/cpy/acmncea0.acs"                   .

      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice classe cespite  *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/acmnzc10.acs"                   .

      *    *===========================================================*
      *    * Subroutines per l'accettazione ubicazione cespite         *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/acmnzuc0.acs"                   .

      *    *===========================================================*
      *    * Subroutines per l'accettazione causale di ammortamento    *
      *    *-----------------------------------------------------------*
       cod-mne-zca-opn-000.
           move      "pgm/cge/prg/obj/acmnzca0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-mne-zca-pth      .
           move      "OP"                 to   w-cod-mne-zca-ope      .
           perform   cod-mne-zca-cll-000  thru cod-mne-zca-cll-999    .
       cod-mne-zca-opn-999.
           exit.
       cod-mne-zca-cls-000.
           move      "CL"                 to   w-cod-mne-zca-ope      .
           perform   cod-mne-zca-cll-000  thru cod-mne-zca-cll-999    .
           move      "C?"                 to   w-cod-mne-zca-ope      .
           perform   cod-mne-zca-cll-000  thru cod-mne-zca-cll-999    .
           if        w-cod-mne-zca-ope    not  = spaces
                     go to cod-mne-zca-cls-999.
           cancel    w-cod-mne-zca-pth                                .
       cod-mne-zca-cls-999.
           exit.
       cod-mne-zca-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-mne-zca-foi-500.
      *              *-------------------------------------------------*
      *              * Modifica per permettere l'Insr nelle righe      *
      *              * ----                                            *
      *              * Se Insr : nessuna azione. L'inserimento potra'  *
      *              *           essere effettuato tramite la ricerca  *
      *              * ----                                            *
      *              * Le istruzioni che seguono sono state inibite    *
      *              *-------------------------------------------------*
      *    move      "P?"                 to   s-ope                  .
      *    move      "pcge0500"           to   s-pro                  .
      *    call      "swd/mod/prg/obj/msegrt"
      *                                  using s                      .
      *    if        s-liv                not  = zero
      *              go to cod-mne-zca-foi-999.
      *    move      "pgm/cge/prg/obj/pcge0500"
      *                                   to   s-pat                  .
      *    call      "swd/mod/prg/obj/mfiltp"
      *                                  using s                      .
      *    call      s-pat                                            .
      *    cancel    s-pat                                            .
      *    move      "I+"                 to   w-cod-mne-zca-ope      .
           go to     cod-mne-zca-foi-999.
       cod-mne-zca-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-mne-zca-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pcge0510"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-zca-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/cge/prg/obj/pcge0510"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-mne-zca-ope      .
           go to     cod-mne-zca-foi-999.
       cod-mne-zca-foi-999.
           exit.
       cod-mne-zca-cll-000.
           call      w-cod-mne-zca-pth   using w-cod-mne-zca
                                               v
                                               s                      .
       cod-mne-zca-cll-999.
           exit.

