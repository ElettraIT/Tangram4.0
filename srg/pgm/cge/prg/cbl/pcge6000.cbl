      *                      *-----------------------------------------*
           if        w-rig-cod-cau-sgn (1)
                                          =    "-"
                     subtract  w-rig-imp-mov (1)
                                          from w-srp-sdo-amr
           else      add       w-rig-imp-mov (1)
                                          to   w-srp-sdo-amr          .
      *                      *-----------------------------------------*
      *                      * Aggiornamento valore iniziale           *
      *                      *-----------------------------------------*
           if        w-rig-cod-cau-sni (1)
                                          not  = "S"
                     go to rou-let-reg-880.
      *
           if        w-rig-cod-cau-sgn (1)
                                          =    "-"
                     subtract  w-rig-imp-mov (1)
                                          from w-srp-val-ini
           else      add       w-rig-imp-mov (1)
                                          to   w-srp-val-ini          .
       rou-let-reg-880.
      *                  *---------------------------------------------*
