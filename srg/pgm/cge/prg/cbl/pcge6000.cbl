      *              *-------------------------------------------------*
           if        w-srp-sgn-mov        =    "-"
                     add        w-srp-imp-mov
                                          to   w-srp-sdo-amr
           else      subtract   w-srp-imp-mov
                                          from w-srp-sdo-amr          .
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo , se necessario             *
      *              *-------------------------------------------------*
           if        w-cnt-cor-tip-agg    not  = "+"
                     go to pos-rig-cor-100.
           if        w-rig-sgn-mov (1)    =    "-"
                     subtract  w-rig-imp-mov (1)
                                          from w-srp-sdo-amr
           else      add       w-rig-imp-mov (1)
                                          to   w-srp-sdo-amr          .
       pos-rig-cor-100.
      *              *-------------------------------------------------*
      *              * Controaggiornamento valore iniziale             *
      *              *-------------------------------------------------*
           if        w-srp-val-sni        not  = "S"
                     go to pos-rig-cor-200.
           if        w-srp-sgn-mov        =    "-"
                     add        w-srp-imp-mov
                                          to   w-srp-val-ini
           else      subtract   w-srp-imp-mov
                                          from w-srp-val-ini          .
       pos-rig-cor-200.
