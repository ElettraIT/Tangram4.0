           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-det-ctl-ann-num      .
           add       1900                 to   w-det-ctl-ann-num      .
           move      w-det-ctl-ann-alf    to   rr-ann-stp             .
       acc-ann-stp-100.
