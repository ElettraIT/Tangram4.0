           move      w-sad-ann-ese        to   rf-mgs-ann-ese         .
           move      "C"                  to   rf-mgs-tip-rec         .
           move      w-sad-cod-cli        to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
