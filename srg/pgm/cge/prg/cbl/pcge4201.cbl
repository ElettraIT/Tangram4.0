      *    *-----------------------------------------------------------*
       dcc-con-cat-000.
           move      4                    to   w-dcc-num-rig          .
       dcc-con-cat-500.
           if        w-dcc-rig-cau
                    (w-dcc-num-rig)       =    spaces
                     subtract  1          from w-dcc-num-rig
                     if        w-dcc-num-rig
                                          >    zero
                               go to dcc-con-cat-500.
           if        w-dcc-com-rig        not  = spaces
                     add   1              to   w-dcc-num-rig
                     move  w-dcc-com-rig  to   w-dcc-rig-cau
                                              (w-dcc-num-rig)         .
       dcc-con-cat-999.
           exit.

