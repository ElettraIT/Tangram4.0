      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su archivio [cea]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PDCCSP    "         to   f-key                  .
           move      rr-cod-pdc           to   rf-cea-pdc-csp         .
           move      zero                 to   rf-cea-cod-csp         .
           move      "pgm/cge/fls/ioc/obj/iofcea"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cea                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [cea]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcea"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cea                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su sottoconto                          *
      *                  *---------------------------------------------*
           if        rr-cod-pdc           =    zero
                     go to stp-srt-inp-400.
           if        rf-cea-pdc-csp       not  = rr-cod-pdc
                     go to stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione movimenti cespite            *
      *                  *---------------------------------------------*
           perform   det-mov-csp-000      thru det-mov-csp-999        .
           if        d-mov-csp-exi-sts    not  = spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Test se cespite venduto                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-snx-ven           =    "N"
                     go to stp-srt-inp-422
           else if   rr-snx-ven           =    "S"
                     go to stp-srt-inp-424
           else if   rr-snx-ven           =    "E"
                     go to stp-srt-inp-426.
       stp-srt-inp-422.
      *                      *-----------------------------------------*
      *                      * Anche se cespite venduto                *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-440.
       stp-srt-inp-424.
      *                      *-----------------------------------------*
      *                      * Solo se cespite venduto                 *
      *                      *-----------------------------------------*
           if        d-mov-csp-dat-ven    >    zero
                     go to stp-srt-inp-440
           else      go to stp-srt-inp-200.
       stp-srt-inp-426.
      *                      *-----------------------------------------*
      *                      * Esclusione se cespite venduto           *
      *                      *-----------------------------------------*
           if        d-mov-csp-dat-ven    >    zero
                     go to stp-srt-inp-200
           else      go to stp-srt-inp-440.
       stp-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Test se cespite ammortizzato                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-snx-amm           =    "N"
                     go to stp-srt-inp-442
           else if   rr-snx-amm           =    "S"
                     go to stp-srt-inp-444
           else if   rr-snx-amm           =    "E"
                     go to stp-srt-inp-446.
       stp-srt-inp-442.
      *                      *-----------------------------------------*
      *                      * Anche se cespite ammortizzato           *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-460.
       stp-srt-inp-444.
      *                      *-----------------------------------------*
      *                      * Solo se cespite ammortizzato            *
      *                      *-----------------------------------------*
           if        d-mov-csp-val-res    =    zero
                     go to stp-srt-inp-460
           else      go to stp-srt-inp-200.
       stp-srt-inp-446.
      *                      *-----------------------------------------*
      *                      * Esclusione se cespite ammortizzato      *
      *                      *-----------------------------------------*
           if        d-mov-csp-val-res    =    zero
                     go to stp-srt-inp-200
           else      go to stp-srt-inp-460.
       stp-srt-inp-460.
      *                  *---------------------------------------------*
      *                  * Selezione su data acquisto                  *
      *                  *---------------------------------------------*
           if        d-mov-csp-dat-acq    >    rr-acq-max or
                     d-mov-csp-dat-acq    <    rr-acq-min
                     go to stp-srt-inp-200.
       stp-srt-inp-470.
      *                  *---------------------------------------------*
      *                  * Selezione su data vendita                   *
      *                  *---------------------------------------------*
           if        d-mov-csp-dat-ven    >    rr-ven-max or
                     d-mov-csp-dat-ven    <    rr-ven-min
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di sort                 *
      *                  *---------------------------------------------*
           move      rf-cea-pdc-csp       to   srt-cod-pdc            .
           move      d-mov-csp-dat-acq    to   srt-dat-acq            .
           move      rf-cea-cod-csp       to   srt-cod-csp            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di sort                   *
      *                  *---------------------------------------------*
           move      d-mov-csp-val-ini    to   srt-val-ini            .
           move      d-mov-csp-val-ind    to   srt-val-ind            .
           move      d-mov-csp-val-amm    to   srt-val-amm            .
           move      d-mov-csp-val-res    to   srt-val-res            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo a record [cea] successivo               *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

