      *    *===========================================================*
      *    * Accettazione campo selezione : Data pulizia               *
      *    *-----------------------------------------------------------*
       acc-dat-pul-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dat-pul-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
      *
           move      "Attenzione : eseguire il programma sotto la guida 
      -              "dell'assistenza a TANGRAM.    "
                                          to   v-nt1                  .
      *
           move      "             Gli archivi aggiornati NON vengono au
      -              "tomaticamente messi in linea. "
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      05                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      rr-dat-pul           to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-dat-pul-999.
       acc-dat-pul-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   rr-dat-pul             .
       acc-dat-pul-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data a zero non accettabile                 *
      *                  *---------------------------------------------*
           if        rr-dat-pul           not  = zero
                     go to acc-dat-pul-420.
           move      "Manca la data di pulizia dei movimenti !          
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-dat-pul-100.
       acc-dat-pul-420.
      *                  *---------------------------------------------*
      *                  * Controllo che si tratti di una data di fine *
      *                  * anno                                        *
      *                  *---------------------------------------------*
           move      rr-dat-pul           to   s-dat                  .
           if        s-gio                = 31 and
                     s-mes                = 12
                     go to acc-dat-pul-440.
           move      "Deve essere una data di fine anno !               
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-dat-pul-100.
       acc-dat-pul-440.
      *                  *---------------------------------------------*
      *                  * Confronto con la data massima impostabile   *
      *                  *---------------------------------------------*
           if        rr-dat-pul           not  > rr-dat-max
                     go to acc-dat-pul-600.
           move      "Pulizia non effettuabile a questa data !          
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-dat-pul-100.
       acc-dat-pul-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-pul-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-pul-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-pul-100.
       acc-dat-pul-999.
           exit.

