      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [ali]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ALIARCIVA "         to   f-key                  .
           move      rr-ann-fis           to   rf-ali-ann-fis         .
           move      rr-tip-arc           to   rf-ali-tip-arc         .
           move      zero                 to   rf-ali-cod-arc         .
           move      zero                 to   rf-ali-cod-iva         .
           move      spaces               to   rf-ali-ann-cop         .
           move      "pgm/cge/fls/ioc/obj/iofali"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ali                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ali]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofali"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ali                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ali-ann-fis       not  = rr-ann-fis or
                     rf-ali-tip-arc       not  = rr-tip-arc
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura archivio                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        rr-tip-arc           =    "C"
                     go to stp-srt-inp-220
           else if   rr-tip-arc           =    "F"
                     go to stp-srt-inp-240.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Lettura record [cli]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-ali-cod-arc       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-cli-rag-soc
                     move  spaces         to   rf-cli-rag-key         .
           go to     stp-srt-inp-260.
       stp-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Lettura record [fnt]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      rf-ali-cod-arc       to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-fnt-rag-soc
                     move  spaces         to   rf-fnt-rag-key         .
           go to     stp-srt-inp-260.
       stp-srt-inp-260.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Campi chiave                                *
      *                  *---------------------------------------------*
           if        rr-tip-arc           =    "C"
                     move  rf-cli-rag-key to   srt-rag-key
           else if   rr-tip-arc           =    "F"
                     move  rf-fnt-rag-key to   srt-rag-key            .
           move      rf-ali-cod-arc       to   srt-cod-arc            .
           move      rf-ali-cod-iva       to   srt-cod-iva            .
           if        rf-ali-ann-cop       =    "P"
                     move  01             to   srt-ann-cop
           else if   rf-ali-ann-cop       =    "C"
                     move  02             to   srt-ann-cop
           else      move  zero           to   srt-ann-cop            .
      *                  *---------------------------------------------*
      *                  * Campi dati                                  *
      *                  *---------------------------------------------*
           if        rr-tip-arc           =    "C"
                     move  rf-cli-rag-soc to   srt-rag-soc
           else if   rr-tip-arc           =    "F"
                     move  rf-fnt-rag-soc to   srt-rag-soc            .
           move      rf-ali-num-doc       to   srt-num-doc            .
           move      rf-ali-ibl-doc       to   srt-ibl-doc            .
           move      rf-ali-iva-doc       to   srt-imp-doc            .
           move      rf-ali-num-dog       to   srt-num-dog            .
           move      rf-ali-ibl-dog       to   srt-ibl-dog            .
           move      rf-ali-iva-dog       to   srt-imp-dog            .
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale [ali]            *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

