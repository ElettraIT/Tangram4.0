       acc-snx-aes-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-aes-lun    to   v-car                  .
           move      w-exp-snx-aes-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-snx-aes-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      21                   to   v-lin                  .
           move      32                   to   v-pos                  .
      *
           if        rr-snx-aes           =    "N"
                     move  01             to   v-num
           else if   rr-snx-aes           =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-snx-aes-999.
       acc-snx-aes-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "N"            to   rr-snx-aes
           else if   v-num                =    02
                     move  "S"            to   rr-snx-aes
           else      move  spaces         to   rr-snx-aes             .
       acc-snx-aes-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        rr-snx-aes           not  = "N" and
                     rr-snx-aes           not  = "S"
                     go to acc-snx-aes-100.
       acc-snx-aes-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-aes-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-snx-aes-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-snx-aes-100.
       acc-snx-aes-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su data minima e massima              *
      *              *-------------------------------------------------*
           if        rr-dat-fin           =    zero
                     go to tdo-ric-sel-200.
           if        rr-dat-fin           not  < rr-dat-ini
                     go to tdo-ric-sel-200.
           move      "La data massima non puo' essere inferiore alla dat
      -              "a minima !     "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su tipo record                        *
      *              *-------------------------------------------------*
           if        rr-tip-rec           =    "F" or
                     rr-tip-rec           =    "C"
                     go to tdo-ric-sel-300.
           move      "Manca il tipo record !                            
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo su codice minimo e massimo            *
      *              *-------------------------------------------------*
           if        rr-cod-max           =    zero
                     go to tdo-ric-sel-400.
           if        rr-cod-max           not  < rr-cod-min
                     go to tdo-ric-sel-400.
           move      "Il codice massimo non puo' essere inferiore al cod
      -              "ice minimo !   "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Controllo su codice Iva minimo e massimo        *
      *              *-------------------------------------------------*
           if        rr-iva-max           =    zero
                     go to tdo-ric-sel-800.
           if        rr-iva-max           not  < rr-iva-min
                     go to tdo-ric-sel-800.
           move      "Il codice Iva massimo non puo' essere inferiore al
      -              " codice minimo "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione messaggio                   *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Regolarizzazione data min - max                 *
      *              *-------------------------------------------------*
           if        rr-dat-fin           not  = zero
                     go to  reg-ric-sel-100.
           if        rr-dat-ini           =    zero
                     move   9999999       to   rr-dat-fin
           else      move   rr-dat-ini    to   rr-dat-fin             .
       reg-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Regolarizzazione codice min - max               *
      *              *-------------------------------------------------*
           if        rr-cod-max           not  = zero
                     go to reg-ric-sel-200.
           if        rr-cod-min           =    zero
                     move  9999999        to   rr-cod-max
           else      move  rr-cod-min     to   rr-cod-max             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Regolarizzazione codice Iva min - max           *
      *              *-------------------------------------------------*
           if        rr-iva-max           not  = zero
                     go to reg-ric-sel-300.
           if        rr-iva-min           =    zero
                     move  99999          to   rr-iva-max
           else      move  rr-iva-min     to   rr-iva-max             .
       reg-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Tipo data                                       *
      *              *-------------------------------------------------*
           if        rr-tip-dat           not  = "D"
                     move  "R"            to   rr-tip-dat             .
      *              *-------------------------------------------------*
      *              * Si/no anagrafica estesa                         *
      *              *-------------------------------------------------*
           if        rr-snx-aes           not  = "S"
                     move  "N"            to   rr-snx-aes             .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Preparazione parametri per selezione stampa               *
      *    *-----------------------------------------------------------*
       pre-prm-stp-000.
      *              *-------------------------------------------------*
      *              * Flags di tipo selezione                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sel      .
      *              *-------------------------------------------------*
      *              * Codice stampante                                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-stp      .
      *              *-------------------------------------------------*
      *              * Tipo di stampa                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sta      .
      *              *-------------------------------------------------*
      *              * Codice modulo                                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-mod      .
      *              *-------------------------------------------------*
      *              * Tipo modulo                                     *
      *              *   - L : Libero                                  *
      *              *   - T : Tipografico                             *
      *              *-------------------------------------------------*
           move      "L"                  to   w-cnt-stp-tip-mod      .
      *              *-------------------------------------------------*
      *              * Ampiezza linea di stampa in caratteri           *
      *              *-------------------------------------------------*
           move      132                  to   w-cnt-stp-amp-lin      .
      *              *-------------------------------------------------*
      *              * Top margin in linee                             *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-top-lin      .
      *              *-------------------------------------------------*
      *              * Numero linee di stampa minimo                   *
      *              *-------------------------------------------------*
           move      30                   to   w-cnt-stp-lin-min      .
      *              *-------------------------------------------------*
      *              * Bottom margin in linee                          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-bot-lin      .
      *              *-------------------------------------------------*
      *              * Ampiezza caratteri                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-amp-car      .
      *              *-------------------------------------------------*
      *              * Altezza interlinea                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-alt-int      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni future            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-esp-fut      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni speciali          *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-fnz-spc      .
       pre-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su archivio [mgi]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATPRT    "         to   f-key                  .
           move      rr-dat-ini           to   rf-mgi-dat-reg         .
           move      zero                 to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [mgi]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Se fine file                                *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Max su archivio [mgi]                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data registrazione                  *
      *                  *---------------------------------------------*
           if        rf-mgi-dat-reg       >    rr-dat-fin
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Sel su archivio [mgi]                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su tipo record                    *
      *                  *---------------------------------------------*
           if        rr-tip-rec           =    spaces
                     go to stp-srt-inp-410.
           if        rr-tip-rec           not  = rf-mgi-tip-rec
                     go to stp-srt-inp-200.
       stp-srt-inp-410.
      *                  *---------------------------------------------*
      *                  * Selezione su codice numerazione             *
      *                  *---------------------------------------------*
           if        rr-cod-num           =    "T "
                     go to stp-srt-inp-420.
           if        rr-cnu-cod           not  = rf-mgi-cod-num
                     go to stp-srt-inp-200.
       stp-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Selezione su codice archivio                *
      *                  *---------------------------------------------*
           if        rf-mgi-cod-arc       <    rr-cod-min or
                     rf-mgi-cod-arc       >    rr-cod-max
                     go to stp-srt-inp-200.
       stp-srt-inp-430.
      *                  *---------------------------------------------*
      *                  * Selezione su codice Iva                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ciclo di scansione castelletto Iva      *
      *                      *-----------------------------------------*
           move      zero                 to   w-stp-srt-inp-ctr      .
       stp-srt-inp-440.
           add       1                    to   w-stp-srt-inp-ctr      .
           if        w-stp-srt-inp-ctr    >    6
                     go to stp-srt-inp-800.
      *                      *-----------------------------------------*
      *                      * Selezione                               *
      *                      *-----------------------------------------*
           if        rf-mgi-cod-iva
                    (w-stp-srt-inp-ctr)   =    zero
                     go to stp-srt-inp-440.
           if        rf-mgi-cod-iva
                    (w-stp-srt-inp-ctr)   <    rr-iva-min or
                     rf-mgi-cod-iva
                    (w-stp-srt-inp-ctr)   >    rr-iva-max
                     go to stp-srt-inp-440.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave                                      *
      *                  *---------------------------------------------*
           move      rf-mgi-cod-iva
                    (w-stp-srt-inp-ctr)   to   srt-cod-iva            .
           move      rf-mgi-tip-iva       to   srt-tip-iva            .
           move      rf-mgi-tip-rec       to   srt-tip-rec            .
      *
           if        rr-tip-dat           =    "R"
                     move  rf-mgi-dat-reg to   srt-dat-key
           else      move  rf-mgi-dat-doc to   srt-dat-key            .
      *
           move      rf-mgi-num-doc       to   srt-num-key            .
      *                  *---------------------------------------------*
      *                  * Dati                                        *
      *                  *---------------------------------------------*
           move      rf-mgi-dat-doc       to   srt-dat-doc            .
           move      w-stp-srt-inp-ctr    to   srt-cst-ctr            .
           move      rf-mgi-cod-arc       to   srt-cod-arc            .
           move      rf-mgi-num-doc       to   srt-num-doc            .
           move      rf-mgi-cod-num       to   srt-cod-num            .
           move      rf-mgi-ibl-iva
                    (w-stp-srt-inp-ctr)   to   srt-ibl-iva            .
           move      rf-mgi-imp-iva
                    (w-stp-srt-inp-ctr)   to   srt-imp-iva            .
           move      rf-mgi-tot-doc       to   srt-tot-doc            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-750.
      *              *-------------------------------------------------*
      *              * Riciclo su castelletto Iva                      *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-440.
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo su Read Next [mgi]                      *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessuna registrazione entro i limiti assegnati !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
