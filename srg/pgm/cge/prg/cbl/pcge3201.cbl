      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *                                                           *
      *    * Operazioni preliminari                                    *
      *    *-----------------------------------------------------------*
       prn-str-ini-pre-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
       prn-str-ini-pre-010.
      *              *-------------------------------------------------*
      *              * Determinazione data del giorno precedente quel- *
      *              * lo della data iniziale                          *
      *              *-------------------------------------------------*
           move      rr-dat-min           to   s-dat                  .
           subtract  1                    from s-gio                  .
           if        s-gio                >    zero
                     go to  pre-str-ini-pre-120.
           move      31                   to   s-gio                  .
           subtract  1                    from s-mes                  .
           if        s-mes                >    zero
                     go to  pre-str-ini-pre-100.
           move      31                   to   s-gio                  .
           move      12                   to   s-mes                  .
           subtract  1                    from s-saa                  .
           go to     pre-str-ini-pre-120.
       pre-str-ini-pre-100.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to  pre-str-ini-pre-100.
       pre-str-ini-pre-120.
           move      s-dat                to   w-sad-dat-sad          .
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio relativi alla  *
      *              * data finale di stampa partitario                *
      *              *-------------------------------------------------*
           move      rr-dat-max           to   w-ese-cge-dtr          .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
           move      w-ese-cge-esa        to   w-sad-ese-att          .
      *              *-------------------------------------------------*
      *              * Determinazione mese e anno di esercizio relati- *
      *              * vi alla data del giorno precedente quello della *
      *              * data iniziale                                   *
      *              *-------------------------------------------------*
           move      w-sad-dat-sad        to   w-ese-cge-dtr          .
