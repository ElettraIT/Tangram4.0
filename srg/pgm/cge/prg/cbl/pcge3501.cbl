           if        rr-dat-bil
                    (w-car-inx-col)       =    zero
                     go to  car-tbl-cdb-050.
      *                  *---------------------------------------------*
      *                  * Determinazione mese e anno di esercizio     *
      *                  * relativo alla data bilancio                 *
      *                  *---------------------------------------------*
           move      rr-dat-bil
                    (w-car-inx-col)       to   w-ese-cge-dtr          .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
           move      w-ese-cge-esa        to   w-bil-ann-bil          .
           move      w-ese-cge-esm        to   w-bil-mes-bil          .
      *                  *---------------------------------------------*
      *                  * Determinazione anno precedente quello del   *
      *                  * bilancio infrannuale                        *
      *                  *---------------------------------------------*
           move      zero                 to   s-dat                  .
           move      w-bil-ann-bil        to   s-saa                  .
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-bil-ann-pre          .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record file [pdc]           *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                  *---------------------------------------------*
      *                  * Start su file [pdc] con chiave normalizzata *
      *                  *---------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     move   "#"           to   w-car-flg-exi
                     go to  car-tbl-cdb-999.
       car-tbl-cdb-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [pdc]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *                      *-----------------------------------------*
      *                      * Test se at end                          *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  car-tbl-cdb-200.
      *                      *-----------------------------------------*
      *                      * Selezione su codice sezione             *
      *                      *-----------------------------------------*
           if        rr-cod-sez           =    zero
                     go to  car-tbl-cdb-120.
           if        rr-cod-sez           not  = rf-pdc-cod-sez
                     go to  car-tbl-cdb-100.
       car-tbl-cdb-120.
      *                      *-----------------------------------------*
      *                      * Selezione su tipo conto : solo tipo "E" *
      *                      *-----------------------------------------*
           if        rf-pdc-tip-cnt       not  = "E"
                     go to  car-tbl-cdb-100.
      *                  *---------------------------------------------*
      *                  * Richiamo routine determinazione saldo alla  *
      *                  * data                                        *
      *                  *---------------------------------------------*
           perform   det-sdo-dat-000      thru det-sdo-dat-999        .
      *                  *---------------------------------------------*
      *                  * Se saldo bilancio zero si ricicla nella     *
      *                  * lettura                                     *
      *                  *---------------------------------------------*
           if        w-sad-sdo-dat        =    zero
                     go to  car-tbl-cdb-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cdb]                      *
      *                  *---------------------------------------------*
           if        w-sad-sdo-dat        >    zero
                     move  rf-pdc-tcb-dar to   w-let-arc-cdb-tip
                     move  rf-pdc-ccb-dar to   w-let-arc-cdb-cod
           else      move  rf-pdc-tcb-ave to   w-let-arc-cdb-tip
                     move  rf-pdc-ccb-ave to   w-let-arc-cdb-cod      .
           perform   let-arc-cdb-000      thru let-arc-cdb-999        .
           if        w-let-arc-cdb-flg    not  = spaces
                     move   "#"           to   w-car-flg-exi
                     go to  car-tbl-cdb-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione in tabella classificatori   *
      *                  *---------------------------------------------*
           move      w-let-arc-cdb-tip    to   w-buf-tbl-cla-tip      .
           move      w-let-arc-cdb-cod    to   w-buf-tbl-cla-cod      .
           move      w-let-arc-cdb-des    to   w-buf-tbl-cla-des      .
           move      w-let-arc-cdb-rcl    to   w-buf-tbl-cla-rcl      .
           move      w-sad-sdo-dat        to   w-buf-tbl-cla-sdo      .
           perform   buf-tbl-cla-000      thru buf-tbl-cla-999        .
      *                  *---------------------------------------------*
      *                  * Se errore su lettura [pdc]                  *
      *                  *---------------------------------------------*
           if        w-buf-tbl-cla-flg    not  = spaces
                     move   "#"           to   w-car-flg-exi
                     go to  car-tbl-cdb-300.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [pdc]                    *
      *                  *---------------------------------------------*
           go to     car-tbl-cdb-100.
       car-tbl-cdb-200.
      *                  *---------------------------------------------*
      *                  * Ordinamento tabella classificatori          *
      *                  *---------------------------------------------*
           perform   ord-tbl-cla-000      thru ord-tbl-cla-999        .
      *                  *---------------------------------------------*
      *                  * Elaborazioni su tabella classificatori      *
      *                  *---------------------------------------------*
           perform   ela-tbl-cla-000      thru ela-tbl-cla-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossima colonna                 *
      *                  *---------------------------------------------*
           go to     car-tbl-cdb-050.
       car-tbl-cdb-300.
      *              *-------------------------------------------------*
      *              * Chiusura file [pdc]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofpdc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdc                 .
      *              *-------------------------------------------------*
      *              * Chiusura file [mgs]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *              *-------------------------------------------------*
      *              * Chiusura file [cdb]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cdb                 .
      *              *-------------------------------------------------*
      *              * Chiusura file [rdb]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *              *-------------------------------------------------*
      *              * Chiusura file [mgr]                             *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
       car-tbl-cdb-999.
           exit.

      *    *===========================================================*
      *    * Routine di determinazione saldo alla data                 *
      *    *-----------------------------------------------------------*
       det-sdo-dat-000.
      *              *-------------------------------------------------*
      *              * Determinazione saldo ad inizio anno             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione se necessario lettura di una *
      *                  * o due schede saldi                          *
      *                  *                                             *
      *                  * - Se non e' mai stata eseguita una chiusura *
      *                  *   si leggono comunque due schede            *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio richiesto e' uguale o in-  *
      *                  *   feriore all'ultimo esercizio di chiusura  *
      *                  *   si legge una sola scheda                  *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio precedente quello della    *
      *                  *   data richiesta e' pari all'esercizio del- *
      *                  *   l'ultima chiusura si legge una sola sche- *
      *                  *   da                                        *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Si leggono due schede                     *
      *                  *---------------------------------------------*
           if        rn-dat-bil-ese-bil   =    zero
                     move  w-bil-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-bil-ann-bil        not  > rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else if   rn-dat-bil-flg-bil   not  = spaces
                     move  rn-dat-bil-ese-bil
                                          to   w-wrk-ann-ese
                     go to det-sdo-dat-010
           else if   w-bil-ann-pre        =    rn-dat-bil-ese-bil
                     go to det-sdo-dat-100
           else      move  w-bil-ann-pre  to   w-wrk-ann-ese
                     go to det-sdo-dat-010.
       det-sdo-dat-010.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio di chiusura        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se conto di tipo Economico : saldo ini- *
      *                      * ziale zero                              *
      *                      *-----------------------------------------*
           if        rf-pdc-tip-cnt       =    "E"
                     move   zero          to   w-sad-sdo-ini
                     go to  det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Se conto di tipo Patrimoniale : deter-  *
      *                      * minazione saldo finale esercizio di bi- *
      *                      * lancio                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione campi chiave           *
      *                          *-------------------------------------*
           move      w-wrk-ann-ese        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Determinazione saldo finale eserci- *
      *                          * zio di bilancio                     *
      *                          *-------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
           move      zero                 to   I                      .
       det-sdo-dat-020.
           add       1                    to   I                      .
           if        I                    >    12
                     go to  det-sdo-dat-040.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-ini          .
           go to     det-sdo-dat-020.
       det-sdo-dat-040.
           add       rf-mgs-dar-bil       to   w-sad-sdo-ini          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-ini          .
      *                          *-------------------------------------*
      *                          * Aggiornamento saldo bilancio        *
      *                          *-------------------------------------*
           add       w-sad-sdo-ini        to   w-bil-uop-pre          .
       det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Lettura [mgs] esercizio richiesto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Preparazione chiave per [mgs]       *
      *                          *-------------------------------------*
           move      w-bil-ann-bil        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                          *-------------------------------------*
      *                          * Lettura file [mgs]                  *
      *                          *-------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
           go to     det-sdo-dat-200.
       det-sdo-dat-100.
      *                  *---------------------------------------------*
      *                  * Lettura scheda esercizio richiesto          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record file [mgs]       *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Preparazione chiave per [mgs]           *
      *                      *-----------------------------------------*
           move      w-bil-ann-bil        to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      rf-pdc-cod-pdc       to   rf-mgs-cod-con         .
      *                      *-----------------------------------------*
      *                      * Lettura file [mgs]                      *
      *                      *-----------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Determinazione saldo inizio anno        *
      *                      *-----------------------------------------*
           move      rf-mgs-sdo-ini       to   w-sad-sdo-ini          .
       det-sdo-dat-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo alla data di partenza      *
      *              *-------------------------------------------------*
           move      w-sad-sdo-ini        to   w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per accumulo progressivi men-*
      *              * sili anno in corso fino a mese precedente a     *
      *              * quello indicato da data situazione              *
      *              *-------------------------------------------------*
           move      w-bil-mes-bil        to   I                      .
       det-sdo-dat-220.
           subtract  1                    from I                      .
           if        I                    =    zero
                     go to  det-sdo-dat-240.
           add       rf-mgs-dar-mes (I)   to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes (I)   from w-sad-sdo-dat          .
           go to     det-sdo-dat-220.
       det-sdo-dat-240.
      *              *-------------------------------------------------*
      *              * Controllo se giorno situazione e' fine mese     *
      *              *-------------------------------------------------*
           move      rr-dat-bil
                    (w-car-inx-col)       to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Se la data e' corretta vuol dire che il     *
      *                  * giorno situazione non e' a fine mese        *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to  det-sdo-dat-250.
      *                      *-----------------------------------------*
      *                      * Se fine mese si aggiungono i progressivi*
      *                      * del mese attuale                        *
      *                      *-----------------------------------------*
           add       rf-mgs-dar-mes
                     (w-bil-mes-bil)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-bil-mes-bil)      from w-sad-sdo-dat          .
       det-sdo-dat-245.
      *                      *-----------------------------------------*
      *                      * Si aggiorna il saldo con le rettifiche  *
      *                      * extracontabili desunte dal [mgs] stesso *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da aggiornare               *
      *                          *-------------------------------------*
           if        rr-snx-rec           =    02
                     go to det-sdo-dat-247.
      *                          *-------------------------------------*
      *                          * Aggiornamento                       *
      *                          *-------------------------------------*
           if        rf-mgs-dav-ret
                     (w-bil-mes-bil)      =    "A"
                     subtract rf-mgs-imp-ret
                              (w-bil-mes-bil)
                                          from w-sad-sdo-dat
           else      add      rf-mgs-imp-ret
                              (w-bil-mes-bil)
                                          to   w-sad-sdo-dat          .
       det-sdo-dat-247.
      *                      *-----------------------------------------*
      *                      * Se mese richiesto e' quello di chiusura *
      *                      * esercizio, si aggiungono i progressivi  *
      *                      * di bilancio                             *
      *                      *-----------------------------------------*
           if        w-bil-mes-bil        not  = w-ese-cge-mce
                     go to  det-sdo-dat-999.
           add       rf-mgs-dar-bil       to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-bil       from w-sad-sdo-dat          .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-sdo-dat-999.
       det-sdo-dat-250.
      *              *-------------------------------------------------*
      *              * Se data bilancio uguale a data attuale si ag-   *
      *              * giungono i progressivi del mese attuale         *
      *              *-------------------------------------------------*
           if        rr-dat-bil
                    (w-car-inx-col)       not  = w-wrk-dat-att
                     go to  det-sdo-dat-300.
           add       rf-mgs-dar-mes
                     (w-bil-mes-bil)      to   w-sad-sdo-dat          .
           subtract  rf-mgs-ave-mes
                     (w-bil-mes-bil)      from w-sad-sdo-dat          .
      *              *-------------------------------------------------*
      *              * Ad aggiornamento con rettifiche bilancio desunte*
      *              * da [rdb]                                        *
      *              *-------------------------------------------------*
           go to     det-sdo-dat-500.
       det-sdo-dat-300.
      *              *-------------------------------------------------*
      *              * Altrimenti si spazzola il file [mgr] per aggior-*
      *              * nare il saldo con i movimenti contabili fino al-*
      *              * la data richiesta                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record file [mgr]           *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Preparazione chiave per lettura file [mgr]  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      rf-pdc-cod-pdc       to   rf-mgr-cod-pdc         .
      *                      *-----------------------------------------*
      *                      * Data di registrazione                   *
      *                      *-----------------------------------------*
           move      01                   to   s-gio                  .
           move      w-bil-mes-bil        to   s-mes                  .
           move      w-bil-ann-bil        to   s-saa                  .
           move      s-dat                to   rf-mgr-dat-reg         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      zero                 to   rf-mgr-num-prt         .
      *                      *-----------------------------------------*
      *                      * Numero progressivo                      *
      *                      *-----------------------------------------*
           move      zero                 to   rf-mgr-num-prg         .
      *                  *---------------------------------------------*
      *                  * Start file [mgr] per chiave "PDCDAT"        *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PDCDAT"             to   f-key                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito start                     *
      *                      *-----------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-500.
       det-sdo-dat-400.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [mgr]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-500.
      *                  *---------------------------------------------*
      *                  * Test se superamento limiti massimi          *
      *                  *---------------------------------------------*
           if        rf-mgr-cod-pdc        not  = rf-pdc-cod-pdc or
                     rf-mgr-dat-reg        >    rr-dat-bil
                                               (w-car-inx-col)
                     go to  det-sdo-dat-500.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se movimento di bilancio si ricicla     *
      *                      *-----------------------------------------*
           if        rf-mgr-snx-mob        not  = "N"
                     go to  det-sdo-dat-400.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo alla data               *
      *                  *---------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-sad-sdo-dat
           else      add      rf-mgr-imp-mov
                                          to   w-sad-sdo-dat          .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [mgr]                    *
      *                  *---------------------------------------------*
           go to     det-sdo-dat-400.
       det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo con eventuali movimenti di  *
      *              * rettifica desunti dal file [rdb]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non sono state richieste le rettifiche   *
      *                  * extracontabili : nessuna azione             *
      *                  *---------------------------------------------*
           if        rr-snx-rec           =    02
                     go to det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Start file [rdb] per chiave "DATPDC"        *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATPDC"             to   f-key                  .
           move      rr-dat-bil
                    (w-car-inx-col)       to   rf-rdb-dat-reg         .
           move      rf-pdc-cod-pdc       to   rf-rdb-cod-pdc         .
           move      zero                 to   rf-rdb-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                      *-----------------------------------------*
      *                      * Test su esito start                     *
      *                      *-----------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
       det-sdo-dat-600.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [rdb]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-end-fil
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Test se superamento limiti massimi          *
      *                  *---------------------------------------------*
           if        rf-rdb-dat-reg        not  = rr-dat-bil
                                                 (w-car-inx-col) or
                     rf-rdb-cod-pdc        not  = rf-pdc-cod-pdc
                     go to  det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo alla data               *
      *                  *---------------------------------------------*
           if        rf-rdb-dar-ave       =    "A"
                     subtract rf-rdb-imp-mov
                                          from w-sad-sdo-dat
           else      add      rf-rdb-imp-mov
                                          to   w-sad-sdo-dat          .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [rdb]                    *
      *                  *---------------------------------------------*
           go to     det-sdo-dat-600.
       det-sdo-dat-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cdb]                         *
      *    *                                                           *
      *    * Input   : w-let-arc-cdb-tip = Tipo classificatore         *
      *    *           w-let-arc-cdb-cod = Codice classificatore       *
      *    *                                                           *
      *    * Output  : w-let-arc-cdb-flg = spaces; lettura OK          *
      *    *                               "#"     lettura errata      *
      *    *           w-let-arc-cdb-des = Descrizione classificatore  *
      *    *                               elementare                  *
      *    *-----------------------------------------------------------*
       let-arc-cdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cdb-flg      .
      *              *-------------------------------------------------*
      *              * Lettura classificatore                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCDB    "         to   f-key                  .
           move      w-let-arc-cdb-tip    to   rf-cdb-tip-cdb         .
           move      w-let-arc-cdb-cod    to   rf-cdb-cod-cdb         .
           move      "pgm/cge/fls/ioc/obj/iofcdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cdb                 .
      *                  *---------------------------------------------*
      *                  * Se lettura senza successo                   *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to  let-arc-cdb-100.
      *                      *-----------------------------------------*
      *                      * Scrittura messaggio di errore           *
      *                      *-----------------------------------------*
           perform   wrt-msg-001-000      thru wrt-msg-001-999        .
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-cdb-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-cdb-999.
       let-arc-cdb-100.
      *              *-------------------------------------------------*
      *              * Memorizzazione descrizione classificatore       *
      *              *-------------------------------------------------*
           move      rf-cdb-des-cdb       to   w-let-arc-cdb-des      .
      *              *-------------------------------------------------*
      *              * Memorizzazione codice di riclassificazione      *
      *              *-------------------------------------------------*
           move      rf-cdb-cod-rcl       to   w-let-arc-cdb-rcl      .
       let-arc-cdb-999.
           exit.

      *    *===========================================================*
      *    * Scrittura messaggi di errore tipo 1                       *
      *    *-----------------------------------------------------------*
       wrt-msg-001-000.
      *              *-------------------------------------------------*
      *              * Scrittura messaggio di errore                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing con appoggio a destra           *
      *                      *-----------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      rf-pdc-cod-pdc       to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-adx-000      thru edt-pdc-adx-999        .
           move      w-edt-cod-pdc-edt    to   w-msg-001-cod          .
      *                  *---------------------------------------------*
      *                  * Descrizione sottoconto                      *
      *                  *---------------------------------------------*
           move      rf-pdc-des-pdc       to   w-msg-001-des          .
      *                  *---------------------------------------------*
      *                  * 'Dare' o 'Avere'                            *
      *                  *---------------------------------------------*
           if        w-sad-sdo-dat        >    zero
                     move   "Dare"        to   w-msg-001-doa
           else      move   "Avere"       to   w-msg-001-doa          .
      *                  *---------------------------------------------*
      *                  * Scrittura                                   *
      *                  *---------------------------------------------*
           move      w-msg-001            to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       wrt-msg-001-999.
           exit.

      *    *===========================================================*
      *    * Scrittura messaggi di errore tipo 2                       *
      *    *-----------------------------------------------------------*
       wrt-msg-002-000.
      *              *-------------------------------------------------*
      *              * Scrittura messaggio di errore                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo classificatore                         *
      *                  *---------------------------------------------*
           move      w-let-arc-cdb-tip    to   w-msg-002-tip          .
      *                  *---------------------------------------------*
      *                  * Codice classificatore                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing con appoggio a sinistra         *
      *                      *-----------------------------------------*
           move      2                    to   w-edt-cod-pdc-liv      .
           move      w-let-arc-cdb-cod    to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
           move      w-edt-cod-pdc-edt    to   w-msg-002-cod          .
      *                  *---------------------------------------------*
      *                  * Scrittura                                   *
      *                  *---------------------------------------------*
           move      w-msg-002            to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       wrt-msg-002-999.
           exit.

      *    *===========================================================*
      *    * Bufferizzazione in tabella classificatori                 *
      *    *                                                           *
      *    * Input   : w-buf-tbl-cla-tip = Tipo classificatore         *
      *    *           w-buf-tbl-cla-cod = Codice classificatore       *
      *    *           w-buf-tbl-cla-des = Descrizione classificatore  *
      *    *           w-buf-tbl-cla-rcl = Codice di riclassificazione *
      *    *           w-buf-tbl-cla-sdo = Saldo alla data richiesta   *
      *    *                                                           *
      *    * Output  : w-buf-tbl-cla-flg = spaces; tutto OK            *
      *    *                               "#"     errore              *
      *    *-----------------------------------------------------------*
       buf-tbl-cla-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-tbl-cla-flg      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione classificatore in tabella       *
      *              *-------------------------------------------------*
           move      zero                 to   I                      .
       buf-tbl-cla-100.
           add       1                    to   I                      .
           if        I                    >    w-tbl-num-ele
                     go to  buf-tbl-cla-120.
           if        w-tbl-tip-cdb (I)    =    w-buf-tbl-cla-tip and
                     w-tbl-cod-rgp (I)    =    w-buf-tbl-cla-rgp and
                     w-tbl-cod-ele (I)    =    w-buf-tbl-cla-ele
                     go to  buf-tbl-cla-300.
           go to     buf-tbl-cla-100.
       buf-tbl-cla-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione nuovo classificatore        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Incremento numero elementi in tabella   *
      *                      *-----------------------------------------*
           add       1                    to   w-tbl-num-ele          .
           if        w-tbl-num-ele        >    w-tbl-max-ele
                     go to  buf-tbl-cla-900.
      *                      *-----------------------------------------*
      *                      * Gruppo di riclassificazione             *
      *                      *-----------------------------------------*
           if        w-buf-tbl-cla-rcl    =    01
                     move   1             to   w-tbl-gru-rcl (I)
           else if   w-buf-tbl-cla-rcl    =    02 or
                     w-buf-tbl-cla-rcl    =    03
                     move   2             to   w-tbl-gru-rcl (I)
           else if   w-buf-tbl-cla-rcl    =    04
                     move   3             to   w-tbl-gru-rcl (I)
           else if   w-buf-tbl-cla-rcl    =    05
                     move   4             to   w-tbl-gru-rcl (I)
           else      go to  buf-tbl-cla-800.
      *                      *-----------------------------------------*
      *                      * Sottogruppo di riclassificazione        *
      *                      *-----------------------------------------*
           if        w-tbl-gru-rcl (I)    =    1 or
                     w-tbl-gru-rcl (I)    =    3 or
                     w-tbl-gru-rcl (I)    =    4
                     move   0             to   w-tbl-sgr-rcl (I)
                     go to  buf-tbl-cla-200.
           if        w-buf-tbl-cla-rcl    =    02
                     move   2             to   w-tbl-sgr-rcl (I)
                     go to  buf-tbl-cla-200.
           if        w-buf-tbl-cla-tip    =    "C"
                     move   1             to   w-tbl-sgr-rcl (I)
           else      move   3             to   w-tbl-sgr-rcl (I)      .
       buf-tbl-cla-200.
      *                      *-----------------------------------------*
      *                      * Codice componente                       *
      *                      *-----------------------------------------*
           if        w-tbl-gru-rcl (I)    =    2 or
                     w-tbl-gru-rcl (I)    =    3 or
                     w-tbl-gru-rcl (I)    =    4
                     if     w-buf-tbl-cla-tip
                                          =    "C"
                            move   0      to   w-tbl-cod-cmp (I)
                     else   move   1      to   w-tbl-cod-cmp (I)
           else      if     w-buf-tbl-cla-tip
                                          =    "R"
                            move   0      to   w-tbl-cod-cmp (I)
                     else   move   1      to   w-tbl-cod-cmp (I)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione tipo classificatore     *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-tip    to   w-tbl-tip-cdb (I)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice raggruppamento   *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-rgp    to   w-tbl-cod-rgp (I)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice elemento         *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-ele    to   w-tbl-cod-ele (I)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione classificat.*
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-des    to   w-tbl-des-cdb (I)      .
      *                      *-----------------------------------------*
      *                      * Normalizzazione saldi classificatori    *
      *                      *-----------------------------------------*
           move      zero                 to   w-tbl-sdo-cdb (I, 1)   .
           move      zero                 to   w-tbl-sdo-cdb (I, 2)   .
           move      zero                 to   w-tbl-sdo-cdb (I, 3)   .
       buf-tbl-cla-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo classificatore          *
      *                  *---------------------------------------------*
           if        w-tbl-gru-rcl (I)    =    1
                     subtract w-buf-tbl-cla-sdo
                                          from w-tbl-sdo-cdb
                                              (I, w-car-inx-col)
           else      add      w-buf-tbl-cla-sdo
                                          to   w-tbl-sdo-cdb
                                              (I, w-car-inx-col)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     buf-tbl-cla-999.
       buf-tbl-cla-800.
      *              *-------------------------------------------------*
      *              * Se codice riclassificazione non corretto        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura messaggio di errore               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo classificatore                     *
      *                      *-----------------------------------------*
           move      w-buf-tbl-cla-tip    to   w-msg-003-tip          .
      *                      *-----------------------------------------*
      *                      * Codice classificatore                   *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "M"                  to   p-edm                  .
           move      "XX.XXX"             to   p-msk                  .
           move      w-buf-tbl-cla-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-msg-003-cod          .
      *                      *-----------------------------------------*
      *                      * Scrittura                               *
      *                      *-----------------------------------------*
           move      w-msg-003            to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Editing sottoconto                      *
      *                      *-----------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      rf-pdc-cod-pdc       to   w-edt-cod-pdc-cod      .
           move      spaces               to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *                      *-----------------------------------------*
      *                      * Scrittura                               *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Sottoconto : "
                                delimited by   size
                     w-edt-cod-pdc-edt
                                delimited by   spaces
                     " (conto economico)"
                                delimited by   size
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Flag di errore                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-buf-tbl-cla-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     buf-tbl-cla-999.
       buf-tbl-cla-900.
      *              *-------------------------------------------------*
      *              * Se superato il limite massimo elementi          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      spaces               to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "Il programma viene interrotto per superamento del 
      -              "limite massimo previsto in"
                                          to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "termini di numero classificatori di bilancio limit
      -              "e massimo previsto di"
                                          to   m-msg                  .
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Flag di errore                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-buf-tbl-cla-flg      .
       buf-tbl-cla-999.
           exit.

      *    *===========================================================*
      *    * Ordinamento tabella classificatori                        *
      *    *-----------------------------------------------------------*
       ord-tbl-cla-000.
      *              *-------------------------------------------------*
      *              * Test se almeno due codici da ordinare           *
      *              *-------------------------------------------------*
           if        w-tbl-num-ele        <    2
                     go to  ord-tbl-cla-999.
      *              *-------------------------------------------------*
      *              * Ciclo di ordinamento                            *
      *              *-------------------------------------------------*
           move      zero                 to   I                      .
       ord-tbl-cla-100.
           add       1                    to   I                      .
           if        I                    =    w-tbl-num-ele
                     go to  ord-tbl-cla-999.
           move      I                    to   J
                                               K                      .
           move      w-tbl-key-ord (I)    to   w-wrk-key-ord          .
       ord-tbl-cla-200.
           add       1                    to   J                      .
           if        J                    >    w-tbl-num-ele
                     go to  ord-tbl-cla-300.
           if        w-tbl-key-ord (J)    >    w-wrk-key-ord
                     go to  ord-tbl-cla-200.
           move      J                    to   K                      .
           move      w-tbl-key-ord (J)    to   w-wrk-key-ord          .
           go to     ord-tbl-cla-200.
       ord-tbl-cla-300.
           move      I                    to   L                      .          
           if        w-wrk-key-ord        >    w-tbl-key-ord (L)
                     go to  ord-tbl-cla-100.
           move      w-tbl-sng-ele (K)    to   w-tbl-sng-ele (600)    .
           move      w-tbl-sng-ele (L)    to   w-tbl-sng-ele (K)      .
           move      w-tbl-sng-ele (600)  to   w-tbl-sng-ele (L)      .
           go to     ord-tbl-cla-100.
       ord-tbl-cla-999.
           exit.

      *    *===========================================================*
      *    * Elaborazioni su tabella classificatori                    *
      *    *-----------------------------------------------------------*
       ela-tbl-cla-000.
      *              *-------------------------------------------------*
      *              * Determinazione totale vendite                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrk-tot-ven
                                              (w-car-inx-col)         .
           move      zero                 to   I                      .
       ela-tbl-cla-100.
           add       1                    to   I                      .
           if        I                    >    w-tbl-num-ele
                     go to  ela-tbl-cla-200.
           if        w-tbl-gru-rcl (I)    >    1
                     go to  ela-tbl-cla-200.
           add       w-tbl-sdo-cdb
                    (I, w-car-inx-col)    to   w-wrk-tot-ven 
                                              (w-car-inx-col)         .
           go to     ela-tbl-cla-100.
       ela-tbl-cla-200.
      *              *-------------------------------------------------*
      *              * Inizializzazione risultato progressivo          *
      *              *-------------------------------------------------*
           move      w-wrk-tot-ven
                    (w-car-inx-col)       to   w-wrk-ris-prg
                                              (w-car-inx-col)         .
       ela-tbl-cla-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-ese-cge-dtr        to   s-dat                  .
           if        w-ese-cge-mce        =    12         or
                     s-mes                >    w-ese-cge-mce
                     move  s-saa          to   w-ese-cge-esa
                     go to det-ese-cge-500.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-ese-cge-esa          .
       det-ese-cge-500.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-ese-cge-esm          .
           if        w-ese-cge-mce        =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-ese-cge-mce
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-ese-cge-mce
                     add   12             to   w-ese-cge-esm
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-ese-cge-esm          .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Routine di lettura sezione di bilancio                    *
      *    *-----------------------------------------------------------*
       rou-let-sez-000.
      *              *-------------------------------------------------*
      *              * [zsz]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzsz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsz                 .
      *              *-------------------------------------------------*
      *              * Lettura tabella [zsz]                           *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSEZ    "         to   f-key                  .
           move      rr-cod-sez           to   rf-zsz-cod-sez         .
           move      "pgm/cge/fls/ioc/obj/iofzsz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsz                 .
      *                  *---------------------------------------------*
      *                  * Test su esito della lettura                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move   all "."       to   rf-zsz-des-sez         .
      *              *-------------------------------------------------*
      *              * Bufferizzazione descrizione sezione             *
      *              *-------------------------------------------------*
           move      rf-zsz-des-sez       to   w-wrk-des-sez          .
      *              *-------------------------------------------------*
      *              * [zsz]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzsz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsz                 .
       rou-let-sez-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per allineamenti a destra o a sinistra oppure *
