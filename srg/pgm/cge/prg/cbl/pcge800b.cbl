      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-430.
      *                  *---------------------------------------------*
      *                  * Test se il titolo centrale deve essere ese- *
      *                  * guito a questa linea oppure e' gia' stato   *
      *                  * eseguito                                    *
      *                  *---------------------------------------------*
           if        w-int-rag-azi-ndc    >    22 or
                     w-int-via-azi-ndc    >    22 or
                     w-int-loc-azi-ndc    >    22
                     go to int-pag-sta-500
           else      go to int-pag-sta-700.
       int-pag-sta-500.
      *              *-------------------------------------------------*
      *              * Linea 5                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-600.
      *              *-------------------------------------------------*
      *              * Linea 6                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Titolo centrale                             *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
