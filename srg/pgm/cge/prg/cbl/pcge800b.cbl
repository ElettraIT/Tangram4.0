                     move  1              to   p-car
           else if   p-pag                <    100
                     move  2              to   p-car
           else if   p-pag                <    1000
                     move  3              to   p-car
           else if   p-pag                <    10000
                     move  4              to   p-car
           else      move  5              to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           add       5                    to   p-pos                  .
           move      p-pag                to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
