           move      w-tes-pmg-car (1)    to   l-mag-300-num-prt      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           move      w-tes-tmo-vdp-cac    to   l-mag-300-cod-cau      .
           move      w-tes-tmo-vdp-cmc    to   l-mag-300-cod-ctm      .
           move      w-tes-esz-dat (1)    to   l-mag-300-dat-doc      .
           move      w-tes-esz-num (1)    to   l-mag-300-num-doc      .
           move      w-tes-tmo-vdp-dsl    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           if        w-tes-esz-prd (1)    =    01
                     move  "N"            to   l-mag-300-tip-arc
                     move  zero           to   l-mag-300-cod-arc
                     move  spaces         to   l-mag-300-dpz-arc
           else      move  "F"            to   l-mag-300-tip-arc
                     move  w-tes-esz-cod (1)
                                          to   l-mag-300-cod-arc
                     move  w-tes-esz-dpz (1)
                                          to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mmg-car-900.
      *              *-------------------------------------------------*
      *              * Scrittura riga prodotto                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      w-tes-tip-mag (1)    to   l-mag-300-tip-mag      .
           move      w-tes-num-mag (1)    to   l-mag-300-num-mag      .
           move      w-tes-alf-mag (1)    to   l-mag-300-alf-mag      .
           move      w-tes-sgl-vrn (1)    to   l-mag-300-var-mag      .
           move      w-tes-umi-prd (1)    to   l-mag-300-udm-ana      .
           move      w-tes-umi-prd (1)    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      w-tes-qta-pdt (1)    to   l-mag-300-qta-mov      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    =    spaces
                     go to wrt-mmg-car-999.
      *              *-------------------------------------------------*
      *              * Se errore nella scrittura riga : cancellazione  *
      *              * della registrazione di magazzino per eliminare  *
      *              * la testata scritta                              *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-car (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       wrt-mmg-car-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile eseguire l'agg
      -              "iornamento di "     to   w-err-box-err-msg      .
           move      "             magazzino relativo al carico da produ
      -              "zione !        "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       wrt-mmg-car-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento di scarico componenti                 *
      *    *-----------------------------------------------------------*
       wrt-mmg-sca-000.
      *              *-------------------------------------------------*
      *              * Test se scrittura da eseguire                   *
      *              *-------------------------------------------------*
           if        w-tes-tmo-vdp-cas    =    zero
                     go to wrt-mmg-sca-999.
           if        w-tes-snx-dib (1)    not  = "S"
                     go to wrt-mmg-sca-999.
           if        w-tes-pmg-sca (1, 01)
                                          =    zero
                     go to wrt-mmg-sca-999.
       wrt-mmg-sca-100.
      *              *-------------------------------------------------*
      *              * Ciclo fino a 10 registrazioni di magazzino      *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrt-mmg-sca-cre      .
       wrt-mmg-sca-120.
           add       1                    to   w-wrt-mmg-sca-cre      .
           if        w-wrt-mmg-sca-cre    >    10
                     go to wrt-mmg-sca-950.
      *              *-------------------------------------------------*
      *              * Se registrazione successiva alla prima          *
      *              *-------------------------------------------------*
           if        w-wrt-mmg-sca-cre    =    1
                     go to wrt-mmg-sca-140.
      *                  *---------------------------------------------*
      *                  * Richiamo subroutine interna di prelievo di  *
      *                  * un nuovo numero protocollo di magazzino ed  *
      *                  * aggiornamento record [vpt]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Attribuzione numero protocollo di MAG   *
      *                      *-----------------------------------------*
           move      "NP"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
           move      l-mag-300-num-prt    to   w-tes-pmg-sca
                                              (1, w-wrt-mmg-sca-cre)  .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [vpt]              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ottenimento record [vpt]            *
      *                          *-------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT"             to   f-key                  .
           move      w-tes-num-prt        to   rf-vpt-num-prt         .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
           if        f-sts                not  = e-not-err
                     go to wrt-mmg-sca-140.
      *                          *-------------------------------------*
      *                          * Update record [vpt]                 *
      *                          *-------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
      *                          *-------------------------------------*
      *                          * Release record [vpt]                *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
       wrt-mmg-sca-140.
      *              *-------------------------------------------------*
      *              * Scrittura testata movimento di magazzino        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione testata                     *
      *                  *---------------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura testata                           *
      *                  *---------------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-sca
                    (1, w-wrt-mmg-sca-cre)
                                          to   l-mag-300-num-prt      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           move      w-tes-tmo-vdp-cas    to   l-mag-300-cod-cau      .
           move      w-tes-tmo-vdp-cms    to   l-mag-300-cod-ctm      .
           move      w-tes-esz-dat (1)    to   l-mag-300-dat-doc      .
           move      w-tes-esz-num (1)    to   l-mag-300-num-doc      .
           move      w-tes-tmo-vdp-dsl    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           if        w-tes-esz-prd (1)    =    01
                     move  "N"            to   l-mag-300-tip-arc
                     move  zero           to   l-mag-300-cod-arc
                     move  spaces         to   l-mag-300-dpz-arc
           else      move  "F"            to   l-mag-300-tip-arc
                     move  w-tes-esz-cod (1)
                                          to   l-mag-300-cod-arc
                     move  w-tes-esz-dpz (1)
                                          to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mmg-car-900.
       wrt-mmg-sca-200.
      *              *-------------------------------------------------*
      *              * Scrittura righe                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore righe scritte    *
      *                  *---------------------------------------------*
           move      zero                 to   w-wrt-mmg-sca-ctr      .
       wrt-mmg-sca-220.
      *                  *---------------------------------------------*
      *                  * Incremento contatore righe scritte          *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mmg-sca-ctr      .
      *                  *---------------------------------------------*
      *                  * Se oltre il numero righe ammesso per una    *
      *                  * registrazione : riciclo per registrazione   *
      *                  * successiva                                  *
      *                  *---------------------------------------------*
           if        w-wrt-mmg-sca-ctr    >    500
                     go to wrt-mmg-sca-120.
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero livelli distinta    *
      *                  *---------------------------------------------*
           move      1                    to   w-wrt-mmg-sca-nld      .
      *                  *---------------------------------------------*
      *                  * Salvataggio start per file [lgr]            *
      *                  *---------------------------------------------*
           move      w-tes-tip-mag (1)    to   w-sav-tpm-ass
                                              (w-wrt-mmg-sca-nld)     .
           move      w-tes-num-mag (1)    to   w-sav-nrm-ass
                                              (w-wrt-mmg-sca-nld)     .
           move      zero                 to   w-sav-num-prg
                                              (w-wrt-mmg-sca-nld)     .
           move      w-tes-qta-pdt (1)    to   w-sav-qta-ipg
                                              (w-wrt-mmg-sca-nld)     .
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di rilettura           *
      *                  *---------------------------------------------*
           move      spaces               to   w-wrt-mmg-sca-fdr      .
       wrt-mmg-sca-230.
      *                  *---------------------------------------------*
      *                  * Start su file [lgr]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TNMASS    "         to   f-key                  .
           move      w-sav-tpm-ass
                    (w-wrt-mmg-sca-nld)   to   rf-lgr-tpm-ass         .
           move      w-sav-nrm-ass
                    (w-wrt-mmg-sca-nld)   to   rf-lgr-nrm-ass         .
           move      w-sav-num-prg
                    (w-wrt-mmg-sca-nld)   to   rf-lgr-num-prg         .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-mmg-sca-600.
       wrt-mmg-sca-240.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale su file [lgr]           *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dtp/fls/ioc/obj/ioflgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgr                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end'                                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-mmg-sca-600.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-lgr-tpm-ass       not  = w-sav-tpm-ass
                                                (w-wrt-mmg-sca-nld) or
                     rf-lgr-nrm-ass       not  = w-sav-nrm-ass
                                                (w-wrt-mmg-sca-nld)
                     go to wrt-mmg-sca-600.
      *                  *---------------------------------------------*
      *                  * Test su flag di rilettura                   *
      *                  *---------------------------------------------*
           if        w-wrt-mmg-sca-fdr    not  = spaces
                     move  spaces         to   w-wrt-mmg-sca-fdr
                     go to wrt-mmg-sca-240.
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica di magazzino             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo magaz-  *
      *                      * zino                                    *
      *                      *-----------------------------------------*
           if        rf-lgr-tpm-cpt       =    01
                     go to wrt-mmg-sca-242
           else if   rf-lgr-tpm-cpt       =    02
                     go to wrt-mmg-sca-244
           else if   rf-lgr-tpm-cpt       =    03
                     go to wrt-mmg-sca-246
           else if   rf-lgr-tpm-cpt       =    99
                     go to wrt-mmg-sca-248.
       wrt-mmg-sca-242.
      *                          *-------------------------------------*
      *                          * Tipo magazzino : prodotti di vendita*
      *                          *-------------------------------------*
           move      rf-lgr-nrm-cpt       to   w-let-arc-dcp-cod      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           move      w-let-arc-dcp-alf    to   w-wrt-mmg-sca-wca      .
           move      w-let-arc-dcp-umi    to   w-wrt-mmg-sca-wum      .
           move      w-let-arc-dcp-deq    to   w-wrt-mmg-sca-wdq      .
           go to     wrt-mmg-sca-300.
       wrt-mmg-sca-244.
      *                          *-------------------------------------*
      *                          * Tipo magazzino : semilavorati       *
      *                          *-------------------------------------*
           move      rf-lgr-nrm-cpt       to   w-let-arc-dps-cod      .
           perform   let-arc-dps-000      thru let-arc-dps-999        .
           move      w-let-arc-dps-alf    to   w-wrt-mmg-sca-wca      .
           move      w-let-arc-dps-umi    to   w-wrt-mmg-sca-wum      .
           move      w-let-arc-dps-deq    to   w-wrt-mmg-sca-wdq      .
           go to     wrt-mmg-sca-300.
       wrt-mmg-sca-246.
      *                          *-------------------------------------*
      *                          * Tipo magazzino : materie prime      *
      *                          *-------------------------------------*
           move      rf-lgr-nrm-cpt       to   w-let-arc-dpm-cod      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
           move      w-let-arc-dpm-alf    to   w-wrt-mmg-sca-wca      .
           move      w-let-arc-dpm-umi    to   w-wrt-mmg-sca-wum      .
           move      w-let-arc-dpm-deq    to   w-wrt-mmg-sca-wdq      .
           go to     wrt-mmg-sca-300.
       wrt-mmg-sca-248.
      *                          *-------------------------------------*
      *                          * Tipo magazzino : sub-distinta vir-  *
      *                          *                  tuale              *
      *                          *-------------------------------------*
           move      rf-lgr-nrm-cpt       to   w-let-arc-lgv-cod      .
           perform   let-arc-lgv-000      thru let-arc-lgv-999        .
           move      w-let-arc-lgv-umi    to   w-wrt-mmg-sca-wum      .
           move      w-let-arc-lgv-deq    to   w-wrt-mmg-sca-wdq      .
           go to     wrt-mmg-sca-300.
       wrt-mmg-sca-300.
      *                  *---------------------------------------------*
      *                  * Determinazione quantita' di impiego         *
      *                  *                                             *
      *                  * - Quantita' di impiego, moltiplicatore      *
      *                  * - Quantita' di impiego, divisore            *
      *                  * - Quantita' prodotta                        *
      *                  *---------------------------------------------*
           move      rf-lgr-qta-ipm       to   w-wrt-mmg-sca-wqi      .
           divide    rf-lgr-qta-ipd       into w-wrt-mmg-sca-wqi      .
           multiply  w-sav-qta-ipg
                    (w-wrt-mmg-sca-nld)   by   w-wrt-mmg-sca-wqi      .
      *                  *---------------------------------------------*
      *                  * Test se scrittura di magazzino da eseguire  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo componente sub-distinta virtua- *
      *                      * le : no scrittura di magazzino          *
      *                      *-----------------------------------------*
           if        rf-lgr-tpm-cpt       =    99
                     go to wrt-mmg-sca-400.
      *                      *-----------------------------------------*
      *                      * Quantita' di impiego in work di comodo  *
      *                      * ridefinito                              *
      *                      *-----------------------------------------*
           move      w-wrt-mmg-sca-wqi    to   w-wrt-mmg-sca-wqm      .
      *                      *-----------------------------------------*
      *                      * Aggiustamento decimali quantita' per    *
      *                      * scrittura movimento                     *
      *                      *-----------------------------------------*
           if        w-wrt-mmg-sca-wdq    =    0
                     move  zero           to   w-wrt-mmg-sca-w1d
                     move  zero           to   w-wrt-mmg-sca-w2d
                     move  zero           to   w-wrt-mmg-sca-w3d
           else if   w-wrt-mmg-sca-wdq    =    1
                     move  zero           to   w-wrt-mmg-sca-w2d
                     move  zero           to   w-wrt-mmg-sca-w3d
           else if   w-wrt-mmg-sca-wdq    =    2
                     move  zero           to   w-wrt-mmg-sca-w3d      .
      *                      *-----------------------------------------*
      *                      * Se quantita' da scaricare a zero : no   *
      *                      * scrittura di magazzino                  *
      *                      *-----------------------------------------*
           if        w-wrt-mmg-sca-wqm    =    zero
                     go to wrt-mmg-sca-400.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo di e-   *
      *                      * splosione distinta base                 *
      *                      *-----------------------------------------*
           if        w-tes-tmo-vdp-ted    =    01
                     go to wrt-mmg-sca-310
           else if   w-tes-tmo-vdp-ted    =    02
                     go to wrt-mmg-sca-320
           else if   w-tes-tmo-vdp-ted    =    03
                     go to wrt-mmg-sca-330.
       wrt-mmg-sca-310.
      *                      *-----------------------------------------*
      *                      * Tipo esplosione distinta base : Ad un   *
      *                      * livello                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Scrittura di magazzino comunque da  *
      *                          * eseguire                            *
      *                          *-------------------------------------*
           go to     wrt-mmg-sca-350.
       wrt-mmg-sca-320.
      *                      *-----------------------------------------*
      *                      * Tipo esplosione distinta base : Scalare *
      *                      * totale                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Scrittura di magazzino solo se tipo *
      *                          * componente 'Materia Prima'          *
      *                          *-------------------------------------*
           if        rf-lgr-tpm-cpt       =    03
                     go to wrt-mmg-sca-350
           else      go to wrt-mmg-sca-400.
       wrt-mmg-sca-330.
      *                      *-----------------------------------------*
      *                      * Tipo esplosione distinta base : Scalare *
      *                      * fino ai semilavorati finali             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo     *
      *                          * componente                          *
      *                          *-------------------------------------*
           if        rf-lgr-tpm-cpt       =    01
                     go to wrt-mmg-sca-332
           else if   rf-lgr-tpm-cpt       =    02
                     go to wrt-mmg-sca-334
           else if   rf-lgr-tpm-cpt       =    03
                     go to wrt-mmg-sca-336.
       wrt-mmg-sca-332.
      *                          *-------------------------------------*
      *                          * Se tipo componente 'Prodotto di     *
      *                          * vendita'                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * No scrittura di magazzino       *
      *                              *---------------------------------*
           go to     wrt-mmg-sca-400.
       wrt-mmg-sca-334.
      *                          *-------------------------------------*
      *                          * Se tipo componente 'Semilavorato'   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se semilavorato intermedio      *
      *                              * scrittura di magazzino, altri-  *
      *                              * menti no                        *
      *                              *---------------------------------*
           if        w-let-arc-dps-tps    =    01
                     go to wrt-mmg-sca-350
           else      go to wrt-mmg-sca-400.
       wrt-mmg-sca-336.
      *                          *-------------------------------------*
      *                          * Se tipo componente 'Materia Prima'  *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Scrittura di magazzino          *
      *                              *---------------------------------*
           go to     wrt-mmg-sca-350.
       wrt-mmg-sca-350.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga movimento di magazzino *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      rf-lgr-tpm-cpt       to   l-mag-300-tip-mag      .
           move      rf-lgr-nrm-cpt       to   l-mag-300-num-mag      .
           move      w-wrt-mmg-sca-wca    to   l-mag-300-alf-mag      .
           move      spaces               to   l-mag-300-var-mag      .
           move      w-wrt-mmg-sca-wum    to   l-mag-300-udm-ana      .
           move      w-wrt-mmg-sca-wum    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      w-wrt-mmg-sca-wqm    to   l-mag-300-qta-mov      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mmg-sca-900.
       wrt-mmg-sca-400.
      *                  *---------------------------------------------*
      *                  * Test se il componente ha a sua volta una di-*
      *                  * stinta base                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [lgt]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TNMASS    "         to   f-key                  .
           move      rf-lgr-tpm-cpt       to   rf-lgt-tpm-ass         .
           move      rf-lgr-nrm-cpt       to   rf-lgt-nrm-ass         .
           move      "pgm/dtp/fls/ioc/obj/ioflgt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lgt                 .
      *                  *---------------------------------------------*
      *                  * Se il componente non ha a sua volta una di- *
      *                  * stinta base : riciclo su lettura [lgr]      *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-mmg-sca-240.
      *                  *---------------------------------------------*
      *                  * Se il componente ha a sua volta una distin- *
      *                  * ta base                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo di e-   *
      *                      * splosione distinta base                 *
      *                      *-----------------------------------------*
           if        w-tes-tmo-vdp-ted    =    01
                     go to wrt-mmg-sca-410
           else if   w-tes-tmo-vdp-ted    =    02
                     go to wrt-mmg-sca-420
           else if   w-tes-tmo-vdp-ted    =    03
                     go to wrt-mmg-sca-430.
       wrt-mmg-sca-410.
      *                      *-----------------------------------------*
      *                      * Tipo esplosione distinta base : Ad un   *
      *                      * livello                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Si prosegue nella esplosione solo   *
      *                          * se il prodotto in questione e' una  *
      *                          * subdistinta virtuale, altrimenti si *
      *                          * ricicla su lettura [lgr]            *
      *                          *-------------------------------------*
           if        rf-lgr-tpm-cpt       not  = 99
                     go to wrt-mmg-sca-240
           else      go to wrt-mmg-sca-450.
       wrt-mmg-sca-420.
      *                      *-----------------------------------------*
      *                      * Tipo esplosione distinta base : Scalare *
      *                      * totale                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Si prosegue nella esplosione        *
      *                          *-------------------------------------*
           go to     wrt-mmg-sca-450.
       wrt-mmg-sca-430.
      *                      *-----------------------------------------*
      *                      * Tipo esplosione distinta base : Scalare *
      *                      * fino ai semilavorati finali             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se tipo componente non e' un semi-  *
      *                          * lavorato : si prosegue nella esplo- *
      *                          * sione                               *
      *                          *-------------------------------------*
           if        rf-lgr-tpm-cpt       not  = 02
                     go to wrt-mmg-sca-450.
      *                          *-------------------------------------*
      *                          * Se e' un semilavorato finale si ri- *
      *                          * cicla su lettura [lgr]              *
      *                          *-------------------------------------*
           if        w-let-arc-dps-tps    =    01
                     go to wrt-mmg-sca-240
           else      go to wrt-mmg-sca-450.
       wrt-mmg-sca-450.
      *                      *-----------------------------------------*
      *                      * Salvataggio start del livello attuale   *
      *                      * su file [lgr]                           *
      *                      *-----------------------------------------*
           move      rf-lgr-tpm-ass       to   w-sav-tpm-ass
                                              (w-wrt-mmg-sca-nld)     .
           move      rf-lgr-nrm-ass       to   w-sav-nrm-ass
                                              (w-wrt-mmg-sca-nld)     .
           move      rf-lgr-num-prg       to   w-sav-num-prg
                                              (w-wrt-mmg-sca-nld)     .
      *                      *-----------------------------------------*
      *                      * Incremento numero livelli distinta      *
      *                      *-----------------------------------------*
           add       1                    to   w-wrt-mmg-sca-nld      .
      *                      *-----------------------------------------*
      *                      * Test se oltre il massimo consentito     *
      *                      *-----------------------------------------*
           if        w-wrt-mmg-sca-nld    >    15
                     move  15             to   w-wrt-mmg-sca-nld      .
      *                      *-----------------------------------------*
      *                      * Salvataggio start del nuovo livello     *
      *                      * su file [lgr]                           *
      *                      *-----------------------------------------*
           move      rf-lgr-tpm-cpt       to   w-sav-tpm-ass
                                              (w-wrt-mmg-sca-nld)     .
           move      rf-lgr-nrm-cpt       to   w-sav-nrm-ass
                                              (w-wrt-mmg-sca-nld)     .
           move      zero                 to   w-sav-num-prg
                                              (w-wrt-mmg-sca-nld)     .
           move      w-wrt-mmg-sca-wqi    to   w-sav-qta-ipg
                                              (w-wrt-mmg-sca-nld)     .
      *                      *-----------------------------------------*
      *                      * Riciclo su start su file [lgr]          *
      *                      *-----------------------------------------*
           go to     wrt-mmg-sca-230.
       wrt-mmg-sca-600.
      *                  *---------------------------------------------*
      *                  * Se fine lettura file [lgr]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se si e' al livello 1 : fine scrittura  *
      *                      *-----------------------------------------*
           if        w-wrt-mmg-sca-nld    =    1
                     go to wrt-mmg-sca-999.
      *                      *-----------------------------------------*
      *                      * Se si e' ad un livello maggiore di 1    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Decremento numero livelli distinta  *
      *                          *-------------------------------------*
           subtract  1                    from w-wrt-mmg-sca-nld      .
      *                          *-------------------------------------*
      *                          * Attivazione flag di rilettura per   *
      *                          * ripristino Start                    *
      *                          *-------------------------------------*
           move      "#"                  to   w-wrt-mmg-sca-fdr      .
      *                          *-------------------------------------*
      *                          * A Start su file [lgr]               *
      *                          *-------------------------------------*
           go to     wrt-mmg-sca-230.
       wrt-mmg-sca-800.
      *              *-------------------------------------------------*
      *              * Test su numero righe scritte all'interno della  *
      *              * registrazione                                   *
      *              *-------------------------------------------------*
           if        w-wrt-mmg-sca-ctr    not  = zero
                     go to wrt-mmg-sca-999.
      *              *-------------------------------------------------*
      *              * Se nessuna riga scritta : cancellazione della   *
      *              * registrazione di magazzino per eliminare la     *
      *              * testata scritta                                 *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-sca
                    (1, w-wrt-mmg-sca-cre)
                                          to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-mmg-sca-999.
       wrt-mmg-sca-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore in scrittura movimenti di    *
      *              * magazzino                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile eseguire l'agg
      -              "iornamento di "     to   w-err-box-err-msg      .
           move      "             magazzino relativo allo scarico compo
      -              "nenti da di-  "     to   w-err-box-err-m02      .
           move      "             stinta base !                        
      -              "              "     to   w-err-box-err-m03      .
           perform   box-msg-e03-000      thru box-msg-e03-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     wrt-mmg-sca-999.
       wrt-mmg-sca-950.
      *              *-------------------------------------------------*
      *              * Trattamento errore per esubero numero registra- *
      *              * zioni di magazzino                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile completare l'a
      -              "ggiornamento  "     to   w-err-box-err-msg      .
           move      "di magazzino relativo allo scarico componenti da d
      -              "istinta base  "     to   w-err-box-err-m02      .
           move      "per superamento del limite nel numero di registraz
      -              "ioni (10) !   "     to   w-err-box-err-m03      .
           perform   box-msg-e03-000      thru box-msg-e03-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     wrt-mmg-sca-999.
       wrt-mmg-sca-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento di scarico consumi manuali            *
      *    *-----------------------------------------------------------*
       wrt-mmg-cad-000.
      *              *-------------------------------------------------*
      *              * Test se scrittura da eseguire                   *
      *              *-------------------------------------------------*
           if        w-tes-tmo-vdp-sna    not  = "S"
                     go to wrt-mmg-cad-999.
           if        w-tes-tmo-vdp-caa    =    zero
                     go to wrt-mmg-cad-999.
           if        w-cat-rig-max        =    zero
                     go to wrt-mmg-cad-999.
           if        w-tes-pmg-cad (1)    =    zero
                     go to wrt-mmg-cad-999.
      *              *-------------------------------------------------*
      *              * Normalizzazione testata                         *
      *              *-------------------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Scrittura testata                               *
      *              *-------------------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-cad (1)    to   l-mag-300-num-prt      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           move      w-tes-tmo-vdp-caa    to   l-mag-300-cod-cau      .
           move      w-tes-tmo-vdp-cma    to   l-mag-300-cod-ctm      .
           move      w-tes-esz-dat (1)    to   l-mag-300-dat-doc      .
           move      w-tes-esz-num (1)    to   l-mag-300-num-doc      .
           move      w-tes-tmo-vdp-dsl    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           if        w-tes-esz-prd (1)    =    01
                     move  "N"            to   l-mag-300-tip-arc
                     move  zero           to   l-mag-300-cod-arc
                     move  spaces         to   l-mag-300-dpz-arc
           else      move  "F"            to   l-mag-300-tip-arc
                     move  w-tes-esz-cod (1)
                                          to   l-mag-300-cod-arc
                     move  w-tes-esz-dpz (1)
                                          to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mmg-cad-900.
      *              *-------------------------------------------------*
      *              * Scrittura righe                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore righe scritte    *
      *                  *---------------------------------------------*
           move      zero                 to   w-wrt-mmg-cad-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su catena movimenti                   *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       wrt-mmg-cad-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale catena movimenti        *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to wrt-mmg-cad-800.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * di lavoro                                   *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Se tipo riga a spazi : uscita               *
      *                  *---------------------------------------------*
           if        w-rig-tip-mag (1)    =    zero
                     go to wrt-mmg-cad-800.
      *                  *---------------------------------------------*
      *                  * Incremento contatore righe scritte          *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mmg-cad-ctr      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      w-rig-tip-mag (1)    to   l-mag-300-tip-mag      .
           move      w-rig-num-mag (1)    to   l-mag-300-num-mag      .
           move      w-rig-alf-mag (1)    to   l-mag-300-alf-mag      .
           move      w-rig-sgl-vrn (1)    to   l-mag-300-var-mag      .
           move      w-rig-umi-prd (1)    to   l-mag-300-udm-ana      .
           move      w-rig-umi-prd (1)    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      w-rig-qta-cns (1)    to   l-mag-300-qta-mov      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mmg-cad-900.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena movimenti         *
      *                  *---------------------------------------------*
           go to     wrt-mmg-cad-100.
       wrt-mmg-cad-800.
      *              *-------------------------------------------------*
      *              * Test su numero righe scritte                    *
      *              *-------------------------------------------------*
           if        w-wrt-mmg-cad-ctr    not  = zero
                     go to wrt-mmg-cad-999.
      *              *-------------------------------------------------*
      *              * Se nessuna riga scritta : cancellazione della   *
      *              * registrazione di magazzino per eliminare la     *
      *              * testata scritta                                 *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-cad (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-mmg-cad-999.
       wrt-mmg-cad-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile eseguire l'agg
      -              "iornamento di "     to   w-err-box-err-msg      .
           move      "             magazzino relativo agli scarichi cons
      -              "umi manuali ! "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       wrt-mmg-cad-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimenti di MAG                            *
      *    *-----------------------------------------------------------*
       del-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Movimento di carico magazzino                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        w-tes-pmg-car (2)    =    zero
                     go to del-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Esecuzione operazione                       *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-car (2)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-100.
      *              *-------------------------------------------------*
      *              * Movimenti di scarico componenti                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo per 10 numeri protocollo              *
      *                  *---------------------------------------------*
           move      zero                 to   w-del-mov-mag-ctr      .
       del-mov-mag-120.
           add       1                    to   w-del-mov-mag-ctr      .
           if        w-del-mov-mag-ctr    >    10
                     go to del-mov-mag-200.
      *                      *-----------------------------------------*
      *                      * Se protocollo non esistente : riciclo   *
      *                      *-----------------------------------------*
           if        w-tes-pmg-sca
                    (2, w-del-mov-mag-ctr)
                                          =    zero
                     go to del-mov-mag-120.
      *                      *-----------------------------------------*
      *                      * Esecuzione operazione                   *
      *                      *-----------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-sca
                    (2, w-del-mov-mag-ctr)
                                          to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     del-mov-mag-120.
       del-mov-mag-200.
      *              *-------------------------------------------------*
      *              * Movimento di carico magazzino                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        w-tes-pmg-cad (2)    =    zero
                     go to del-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Esecuzione operazione                       *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pmg-cad (2)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe          *
      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
