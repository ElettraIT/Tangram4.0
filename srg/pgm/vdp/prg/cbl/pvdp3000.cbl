                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
           if        f-sts                =    e-not-err
                     go to att-vdp-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-vdp-ndo-num-doc     .
           move      zero                 to   rn-vdp-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
           move      "RL"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
           go to     att-vdp-ndo-000.
       att-vdp-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori originali            *
      *                  *---------------------------------------------*
           move      rn-vdp-ndo-num-doc   to   w-att-vdp-ndo-nsv      .
           move      rn-vdp-ndo-dat-doc   to   w-att-vdp-ndo-dsv      .
      *                  *---------------------------------------------*
