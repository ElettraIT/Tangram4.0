      *                  * impostato                                   *
      *                  *---------------------------------------------*
           if        w-att-vdp-ndo-prg    =    zero
                     go to att-vdp-ndo-200
           else      go to att-vdp-ndo-300.
       att-vdp-ndo-200.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato a zero          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore record in comodo ridefinito      *
      *                      *-----------------------------------------*
           move      rn-vdp-ndo-num-doc   to   w-att-vdp-ndo-wnu      .
      *                      *-----------------------------------------*
      *                      * Incremento numero progressivo del comodo*
      *                      * ridefinito                              *
      *                      *-----------------------------------------*
           add       1                    to   w-att-vdp-ndo-wpr      .
           if        w-att-vdp-ndo-wpr    =    zero
                     move  1              to   w-att-vdp-ndo-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-vdp-ndo-saa    to   w-att-vdp-ndo-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-vdp-ndo-dpz    to   w-att-vdp-ndo-wdz      .
      *                      *-----------------------------------------*
      *                      * Movimento da comodo ridefinito a record *
      *                      *-----------------------------------------*
           move      w-att-vdp-ndo-wnu    to   rn-vdp-ndo-num-doc     .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-att-vdp-ndo-dat    to   rn-vdp-ndo-dat-doc     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
      *                      *-----------------------------------------*
