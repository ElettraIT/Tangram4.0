           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-num-lin      .
      *                      *-----------------------------------------*
      *                      * Se riga di tipo New : fine editing      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Editing Tipo codice di magazzino        *
      *                      *-----------------------------------------*
           if        w-rig-tip-mag (1)    =    01
                     move  "[P]"          to   w-lin-imm-tip-mag
           else if   w-rig-tip-mag (1)    =    02
                     move  "[S]"          to   w-lin-imm-tip-mag
           else if   w-rig-tip-mag (1)    =    03
                     move  "[M]"          to   w-lin-imm-tip-mag
           else      move  "[?]"          to   w-lin-imm-tip-mag      .
      *                      *-----------------------------------------*
      *                      * Editing Codice alfanumerico di magazzi- *
      *                      * no                                      *
      *                      *-----------------------------------------*
           move      w-rig-alf-mag (1)    to   w-lin-imm-alf-mag      .
      *                      *-----------------------------------------*
      *                      * Editing Descrizione per codice numerico *
      *                      * di magazzino                            *
      *                      *-----------------------------------------*
           move      w-rig-des-mag (1)    to   w-lin-imm-des-mag      .
      *                      *-----------------------------------------*
      *                      * Editing unita' di misura per produzione *
      *                      *-----------------------------------------*
           move      w-rig-umi-prd (1)    to   w-lin-imm-umi-prd      .
      *                      *-----------------------------------------*
      *                      * Editing quantita' consumata             *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           move      w-rig-qta-cns (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   w-lin-imm-qta-cns      .
       vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Parametri per visualizzazione           *
      *                      *-----------------------------------------*
           move      80                   to   v-car                  .
       vis-lin-cor-900.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione prima linea          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se una sola linea : uscita                      *
      *              *-------------------------------------------------*
           if        w-lin-num-lin-prc    =    1
                     go to vis-lin-cor-999.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione altre linee          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-wrk-ctr-003      .
       vis-lin-cor-925.
           add       1                    to   w-cnt-wrk-ctr-003      .
           if        w-cnt-wrk-ctr-003    >    w-lin-num-lin-prc
                     go to vis-lin-cor-999.
           add       1                    to   w-cnt-wrk-ctr-002      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin
                    (w-cnt-wrk-ctr-003)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-lin-cor-925.
       vis-lin-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate sia dall'area per la fin- *
      *              * catura che dall'area delle righe effettive      *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      18                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Titolo centrale                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "                                  C O N S U M I   
      -              "                              "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R Tipo     Codice                   Descrizione 
      -              "               Udm  Quantita' "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "--- ---- -------------- --------------------------
      -              "-------------- --- -----------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Trattini                                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "--------------------------------------------------
      -              "------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Tipo codice di    *
      *              *                               magazzino         *
      *              *-------------------------------------------------*
           perform   vis-tpm-rig-000      thru vis-tpm-rig-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Codice alfanume-  *
      *              *                               rico di magazzino *
      *              *-------------------------------------------------*
           perform   vis-cdm-rig-000      thru vis-cdm-rig-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Descrizione per   *
      *              *                               codice numerico   *
      *              *                               di magazzino      *
      *              *-------------------------------------------------*
           perform   vis-dsm-rig-000      thru vis-dsm-rig-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Unita' di misura  *
      *              *-------------------------------------------------*
           perform   vis-udm-rig-000      thru vis-udm-rig-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : Quantita' consu-  *
      *              *                               mata              *
      *              *-------------------------------------------------*
           perform   vis-qta-cns-000      thru vis-qta-cns-999        .
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga corpo espansa  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo codice di magazzino                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      23                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo codice magazzino :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Codice di magazzino                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      23                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice di magazzino   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura e quantita'                *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      23                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "U.d.m. e quantita'    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Tipo    *
      *    *                                    codice di magazzino    *
      *    *-----------------------------------------------------------*
       acc-tpm-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tpm-rig-010.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-tip-mag (1)    =    03
                     move  "M"            to   w-sav-tpm-rig
           else      move  spaces         to   w-sav-tpm-rig          .
       acc-tpm-rig-020.
      *                  *---------------------------------------------*
      *                  * Preparazione area di supporto per accetta-  *
      *                  * zione tipo codice di magazzino              *
      *                  *---------------------------------------------*
           move      w-sav-tpm-rig        to   w-acc-def-mag          .
       acc-tpm-rig-030.
      *                  *---------------------------------------------*
      *                  * Preparazione del valore di default          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore precedente non nullo : nessu- *
      *                      * na preparazione per il default          *
      *                      *-----------------------------------------*
           if        w-acc-def-mag        not  = spaces
                     go to acc-tpm-rig-040.
      *                      *-----------------------------------------*
      *                      * Preparazione default                    *
      *                      *-----------------------------------------*
           move      "M"                  to   w-acc-def-mag          .
       acc-tpm-rig-040.
      *                  *---------------------------------------------*
      *                  * Preparazione area w-exp per accettazione    *
      *                  * mediante pop-up dei soli tipi codice di     *
      *                  * magazzino ammessi                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se la lista dei tipi codice di magazzi- *
      *                      * no e' a Spaces : si accettano tutti i   *
      *                      * tipi codice di magazzino                *
      *                      *-----------------------------------------*
           if        w-tes-tmo-vdp-caa-ltm
                                          not  = spaces
                     go to acc-tpm-rig-044.
       acc-tpm-rig-042.
           move      w-exp-tpm-rig-tbl    to   w-exp-tpm-amm-num      .
           move      w-exp-tpm-rig-tbl    to   w-exp-tpm-amm-tbl      .
           move      w-exp-tpm-rig-ast    to   w-exp-tpm-amm-ass      .
           go to     acc-tpm-rig-080.
       acc-tpm-rig-044.
      *                      *-----------------------------------------*
      *                      * Altrimenti si prepara l'area con i soli *
      *                      * tipi codice di magazzino ammessi        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione iniziale            *
      *                          *-------------------------------------*
           move      spaces               to   w-exp-tpm-amm-ass      .
      *                          *-------------------------------------*
      *                          * Tipo codice di magazzino 'M' : se   *
      *                          * presente nella lista tipi codice    *
      *                          * di magazzino ammessi per la causa-  *
      *                          * le lo si inserisce nella lista, in  *
      *                          * caso contrario non lo si inserisce; *
      *                          * se pero' la gestione [dpm] non e'   *
      *                          * attiva, comunque non lo si inseri-  *
      *                          * sce                                 *
      *                          *-------------------------------------*
           if        w-prs-dpm-snx        not  = "S"
                     go to acc-tpm-rig-046.
           move      zero                 to   w-exp-tpm-amm-c01      .
           inspect   w-tes-tmo-vdp-caa-ltm
                                      tallying w-exp-tpm-amm-c01
                     for                  all  "M"                    .
           if        w-exp-tpm-amm-c01    >    zero
                     move  "M"            to   w-exp-tpm-amm-tcm (1)  .
       acc-tpm-rig-046.
      *                          *-------------------------------------*
      *                          * Se la lista cosi' determinata ri-   *
      *                          * sulta vuota si accettano tutti i    *
      *                          * tipi codice di magazzino            *
      *                          *-------------------------------------*
           if        w-exp-tpm-amm-ass    =    spaces
                     go to acc-tpm-rig-042.
       acc-tpm-rig-048.
      *                          *-------------------------------------*
      *                          * Compattamento della lista dei tipi  *
      *                          * codice di magazzino ammessi         *
      *                          *-------------------------------------*
       acc-tpm-rig-050.
      *                          *-------------------------------------*
      *                          * Preparazione del numero di elementi *
      *                          * in tabella tipi codice di magazzi-  *
      *                          * no ammessi                          *
      *                          *-------------------------------------*
           move      zero                 to   w-exp-tpm-amm-c01      .
           inspect   w-exp-tpm-amm-ass
                                      tallying w-exp-tpm-amm-c01
                     for                  all  spaces                 .
           move      01                   to   w-exp-tpm-amm-num      .
           subtract  w-exp-tpm-amm-c01    from w-exp-tpm-amm-num      .
       acc-tpm-rig-052.
      *                          *-------------------------------------*
      *                          * Preparazione delle descrizioni re-  *
      *                          * lative ai tipi codice di magazzino  *
      *                          * ammessi                             *
      *                          *-------------------------------------*
           move      zero                 to   w-exp-tpm-amm-c01      .
       acc-tpm-rig-054.
           add       1                    to   w-exp-tpm-amm-c01      .
           if        w-exp-tpm-amm-c01    >    01
                     go to acc-tpm-rig-080.
           move      zero                 to   w-exp-tpm-amm-i01      .
           inspect   w-exp-tpm-rig-ast
                                      tallying w-exp-tpm-amm-i01
                     for   characters   before
                                       initial w-exp-tpm-amm-tcm
                                              (w-exp-tpm-amm-c01)     .
           if        w-exp-tpm-amm-i01    =    w-exp-tpm-rig-num
                     move  spaces         to   w-exp-tpm-amm-ele
                                              (w-exp-tpm-amm-c01)
                     go to acc-tpm-rig-054.
           add       01                   to   w-exp-tpm-amm-i01      .
           move      w-exp-tpm-rig-ele
                    (w-exp-tpm-amm-i01)   to   w-exp-tpm-amm-ele
                                              (w-exp-tpm-amm-c01)     .
           go to     acc-tpm-rig-054.
       acc-tpm-rig-080.
      *                  *---------------------------------------------*
      *                  * Preparazione flag di ammissibilita' per il  *
      *                  * tasto Find                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non New : no                    *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     move  spaces         to   w-acc-fnd-mag
                     go to acc-tpm-rig-100.
      *                      *-----------------------------------------*
      *                      * Se esiste un default per il tipo codi-  *
      *                      * ce di magazzino, e questo non e' varia- *
      *                      * bile : no                               *
      *                      *-----------------------------------------*
           if        w-tes-tmo-vdp-caa-dtm
                                          =    "M" and
                     w-tes-tmo-vdp-caa-vtm
                                          =    "N"
                     move  spaces         to   w-acc-fnd-mag
                     go to acc-tpm-rig-100.
      *                      *-----------------------------------------*
      *                      * Se esiste un solo elemento nella tabel- *
      *                      * la di accettazione mediante pop-up : no *
      *                      *-----------------------------------------*
           if        w-exp-tpm-amm-num    not  > 1
                     move  spaces         to   w-acc-fnd-mag
                     go to acc-tpm-rig-100.
      *                      *-----------------------------------------*
      *                      * In tutti gli altri casi si ammette la   *
      *                      * possibilita' di Find                    *
      *                      *-----------------------------------------*
           move      "S"                  to   w-acc-fnd-mag          .
       acc-tpm-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore in formato normale          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-acc-def-mag        to   w-acc-tip-mag          .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      25                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : ammesso solo se determinato pre- *
      *                      *        cedentemente                     *
      *                      *-----------------------------------------*
           if        w-acc-fnd-mag        not  = spaces
                     move  "FIND"         to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-acc-tip-mag        to   v-alf                  .
       acc-tpm-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                      *-----------------------------------------*
      *                      * Valore impostato in campo di accetta-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      v-alf                to   w-acc-tip-mag          .
       acc-tpm-rig-205.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tpm-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tpm-rig-250.
       acc-tpm-rig-210.
      *                  *---------------------------------------------*
      *                  * Accettazione mediante pop-up                *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tpm-amm-lun    to   v-car                  .
           move      w-exp-tpm-amm-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tpm-amm-tbl    to   v-txt                  .
           move      19                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      zero                 to   w-exp-tpm-amm-c01      .
           inspect   w-exp-tpm-amm-ass
                                      tallying w-exp-tpm-amm-c01
                     for   characters   before
                                       initial w-acc-tip-mag          .
           if        w-exp-tpm-amm-c01    not  < w-exp-tpm-amm-num
                     move  zero           to   v-num
           else      move  w-exp-tpm-amm-c01
                                          to   v-num
                     add   1              to   v-num                  .
           if        w-acc-tip-mag        =    spaces
                     move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura function-key a Spaces             *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Se valore non accettabile : reimpostazione  *
      *                  * mediante pop-up                             *
      *                  *---------------------------------------------*
           if        v-num                >    w-exp-tpm-amm-num or
                     v-num                =    zero
                     go to acc-tpm-rig-210.
      *                  *---------------------------------------------*
      *                  * Corrispondente alfanumerico del valore im-  *
