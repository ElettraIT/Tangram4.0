      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to att-vdp-ndo-000.
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
      *                                  *-----------------------------*
      *                                  * Salvataggio nuovo valore    *
      *                                  *-----------------------------*
           move      rn-vdp-ndo-num-doc   to   w-att-vdp-ndo-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-vdp-ndo-999.
       att-vdp-ndo-600.
      *                              *---------------------------------*
      *                              * Se risposta negativa            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
      *                                  *-----------------------------*
      *                                  * Nessun nuovo valore         *
      *                                  *-----------------------------*
           move      zero                 to   w-att-vdp-ndo-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-vdp-ndo-999.
       att-vdp-ndo-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero documento versamento da pro- *
      *    * duzione                                                   *
      *    *-----------------------------------------------------------*
       rip-vdp-ndo-000.
      *              *-------------------------------------------------*
      *              * Se nessun nuovo numero documento : uscita       *
      *              *-------------------------------------------------*
           if        w-att-vdp-ndo-new    =    zero
                     go to rip-vdp-ndo-999.
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-vdp-ndo-dat    to   s-dat                  .
           move      s-saa                to   w-att-vdp-ndo-saa      .
           move      w-att-vdp-ndo-saa    to   rn-vdp-ndo-scl-ann     .
           move      w-att-vdp-ndo-dpz    to   rn-vdp-ndo-cod-dpz     .
           move      w-att-vdp-ndo-sgl    to   rn-vdp-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
           if        f-sts                =    e-not-err
                     go to rip-vdp-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-vdp-ndo-num-doc     .
           move      zero                 to   rn-vdp-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
           go to     rip-vdp-ndo-000.
       rip-vdp-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-vdp-ndo-num-doc   =    w-att-vdp-ndo-new
                     go to rip-vdp-ndo-200
           else      go to rip-vdp-ndo-400.
       rip-vdp-ndo-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento record              *
      *                      *-----------------------------------------*
           move      w-att-vdp-ndo-nsv    to   rn-vdp-ndo-num-doc     .
           move      w-att-vdp-ndo-dsv    to   rn-vdp-ndo-dat-doc     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-vdp-ndo-000.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-vdp-ndo-999.
       rip-vdp-ndo-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-vdp-ndo-num-doc   =    w-att-vdp-ndo-num
                     go to rip-vdp-ndo-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/vdp/num/ioc/obj/invdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-vdp-ndo             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box                             *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 1            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Un altro utente ha nel frattempo prelevato un nume
      -              "ro !        "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 2            *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione numero do- *
      *                                      * cumento editato         *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-vdp-ndo-new    to   w-att-vdp-ndo-wnu      .
           move      w-att-vdp-ndo-wpr    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Visualizzazione         *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Pertanto il numero  "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 3            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                                                  
      -              "         [ ]"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Video in On             *
      *                                      *-------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Accettazione carattere  *
      *                                      * di presa visione        *
      *                                      *-------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      17                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Ripristino immagine     *
      *                                      * video                   *
      *                                      *-------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rip-vdp-ndo-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se in modifica : cancellazione movimenti prece- *
      *              *                  denti                          *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to scr-mov-fil-050.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di MAG precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-mag-000      thru del-mov-mag-999        .
       scr-mov-fil-050.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete record [vpr]                             *
      *              *-------------------------------------------------*
           perform   del-rec-vpr-000      thru del-rec-vpr-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento file righe [vpr]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [vpr]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-vpr-000      thru wrt-rec-vpr-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-mag (2)    =    zero
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-cnt-var-tes-cor    not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [vpr]                       *
      *                          *-------------------------------------*
           perform   rew-rec-vpr-000      thru rew-rec-vpr-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Attribuzione numeri protocollo di MAG           *
      *              *-------------------------------------------------*
           perform   att-prt-mag-000      thru att-prt-mag-999        .
      *              *-------------------------------------------------*
      *              * Trattamento file testata [vpt]                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-800.
      *                      *-----------------------------------------*
      *                      * Write record [vpt]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-vpt-000      thru wrt-rec-vpt-999        .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [cdp] per Write    *
      *                      *-----------------------------------------*
           perform   agg-cdp-wrt-000      thru agg-cdp-wrt-999        .
           go to     scr-mov-fil-900.
       scr-mov-fil-800.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Rewrite record [vpt]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-vpt-000      thru rew-rec-vpt-999        .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [cdp] per Rewrite  *
      *                      *-----------------------------------------*
           perform   agg-cdp-rew-000      thru agg-cdp-rew-999        .
       scr-mov-fil-900.
      *              *-------------------------------------------------*
      *              * Scrittura movimenti di MAG                      *
      *              *-------------------------------------------------*
           perform   wrt-mov-mag-000      thru wrt-mov-mag-999        .
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Cancellazione righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a testata             *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-mov-fil-500.
       del-mov-fil-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale righe corpo             *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a testata                       *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to del-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Delete record file righe [vpr]              *
      *                  *---------------------------------------------*
           perform   del-rec-vpr-000      thru del-rec-vpr-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura riga corpo successiva     *
      *                  *---------------------------------------------*
           go to     del-mov-fil-100.
       del-mov-fil-500.
      *              *-------------------------------------------------*
      *              * Cancellazione testata file [vpt]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Delete record [vpt]                         *
      *                  *---------------------------------------------*
           perform   del-rec-vpt-000      thru del-rec-vpt-999        .
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [cdp] per Delete       *
      *                  *---------------------------------------------*
           perform   agg-cdp-del-000      thru agg-cdp-del-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione movimenti di MAG                  *
      *              *-------------------------------------------------*
           perform   del-mov-mag-000      thru del-mov-mag-999        .
       del-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record righe [vpr]                           *
      *    *-----------------------------------------------------------*
       cmp-rec-vpr-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/vdp/fls/ioc/obj/iofvpr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpr                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      w-tes-num-prt        to   rf-vpr-num-prt         .
           move      w-rig-num-prg (1)    to   rf-vpr-num-prg         .
           move      w-rig-tip-mag (1)    to   rf-vpr-tip-mag         .
           move      w-rig-num-mag (1)    to   rf-vpr-num-mag         .
           move      w-rig-alf-mag (1)    to   rf-vpr-alf-mag         .
           move      w-rig-sgl-vrn (1)    to   rf-vpr-sgl-vrn         .
           move      w-rig-umi-prd (1)    to   rf-vpr-umi-prd         .
           move      w-rig-dec-qta (1)    to   rf-vpr-dec-qta         .
           move      w-rig-qta-cns (1)    to   rf-vpr-qta-cns         .
           move      w-tes-tmo-vdp-dsl    to   rf-vpr-cod-dsl         .
           move      w-rig-snx-2qt (1)    to   rf-vpr-snx-2qt         .
           move      w-rig-dec-2qt (1)    to   rf-vpr-dec-2qt         .
           move      w-rig-qta-a02 (1)    to   rf-vpr-qta-a02         .
           move      w-rig-snx-3qt (1)    to   rf-vpr-snx-3qt         .
           move      w-rig-dec-3qt (1)    to   rf-vpr-dec-3qt         .
           move      w-rig-qta-a03 (1)    to   rf-vpr-qta-a03         .
           move      w-rig-flg-ela (1)    to   rf-vpr-flg-ela         .
           move      w-rig-flg-pul (1)    to   rf-vpr-flg-pul         .
           move      w-rig-alx-exp (1)    to   rf-vpr-alx-exp         .
       cmp-rec-vpr-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record righe [vpr]                              *
      *    *-----------------------------------------------------------*
       wrt-rec-vpr-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-vpr-000      thru cmp-rec-vpr-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
