      *                              *---------------------------------*
           if        v-key                =    "EXIT"
                     move  "#"            to   w-att-vdp-ndo-flg
                     go to att-vdp-ndo-600.
           if        w-exp-rat-ndo-sce    =    01
                     go to att-vdp-ndo-500
           else if   w-exp-rat-ndo-sce    =    02
                     go to att-vdp-ndo-600.
