      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo                 *
      *    *-----------------------------------------------------------*
       att-rda-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [rdaprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-rda-prt-ddo    to   s-dat                  .
           move      s-saa                to   w-att-rda-prt-saa      .
           move      w-att-rda-prt-saa    to   rn-rda-prt-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [rdaprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-rda-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-rda-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-rda-prt-000.
       att-rda-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-rda-prt-num-prt   to   w-att-rda-prt-num      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-rda-prt-prg      .
           if        w-att-rda-prt-prg    =    zero
                     move  1              to   w-att-rda-prt-prg      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-rda-prt-ddo    to   s-dat                  .
           move      s-saa                to   w-att-rda-prt-saa      .
           move      w-att-rda-prt-num    to   rn-rda-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-rda-prt-000.
       att-rda-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo                   *
      *    *-----------------------------------------------------------*
       rip-rda-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [rdaprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-rda-prt-ddo    to   s-dat                  .
           move      s-saa                to   w-att-rda-prt-saa      .
           move      w-att-rda-prt-saa    to   rn-rda-prt-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [rdaprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-rda-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-rda-prt-num-prt   not  = w-att-rda-prt-num
                     go to  rip-rda-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           subtract  1                    from w-att-rda-prt-prg      .
           if        w-att-rda-prt-prg    =    zero
                     move  zero           to   w-att-rda-prt-num      .
           move      w-att-rda-prt-num    to   rn-rda-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
       rip-rda-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
       rip-rda-prt-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Trattamento file [ram]                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
      *                      *-----------------------------------------*
      *                      * Write record [ram]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-ram-000      thru wrt-rec-ram-999        .
           go to     scr-mov-fil-999.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Rewrite record [ram]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-ram-000      thru rew-rec-ram-999        .
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Delete record [ram]                             *
      *              *-------------------------------------------------*
           perform   del-rec-ram-000      thru del-rec-ram-999        .
       del-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record [ram]                                 *
      *    *-----------------------------------------------------------*
       cmp-rec-ram-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/rda/fls/ioc/obj/iofram"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ram                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Campi chiave                                *
      *                  *---------------------------------------------*
           move      w-tes-num-prt        to   rf-ram-num-prt         .
      *                  *---------------------------------------------*
      *                  * Campi non chiave                            *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-ram-ide-dat         .
           move      s-ute                to   rf-ram-ide-ute         .
           move      s-fas                to   rf-ram-ide-fas         .
           move      w-tes-dat-reg        to   rf-ram-dat-reg         .
           move      w-tes-cod-tmo (1)    to   rf-ram-cod-tmo         .
           move      w-tes-dat-doc (1)    to   rf-ram-dat-doc         .
           move      w-tes-num-doc (1)    to   rf-ram-num-doc         .
           move      w-tes-cod-fnt (1)    to   rf-ram-cod-fnt         .
           move      w-tes-dpz-fnt (1)    to   rf-ram-dpz-fnt         .
           move      w-tes-snx-prf (1)    to   rf-ram-snx-prf         .
           move      w-tes-snx-tpv (1)    to   rf-ram-snx-tpv         .
           move      w-tes-cod-cau (1)    to   rf-ram-cod-cau         .
           move      w-tes-per-cau (1)    to   rf-ram-per-cau         .
           move      w-tes-pim-cau (1)    to   rf-ram-pim-cau         .
           move      w-tes-cod-trb (1)    to   rf-ram-cod-trb         .
           move      w-tes-per-trb (1)    to   rf-ram-per-trb         .
           move      w-tes-pim-trb (1)    to   rf-ram-pim-trb         .
           move      w-tes-cod-tcb (1)    to   rf-ram-cod-tcb         .
           move      w-tes-per-tcb (1)    to   rf-ram-per-tcb         .
           move      w-tes-pim-tcb (1)    to   rf-ram-pim-tcb         .
           move      w-tes-tot-ibl (1)    to   rf-ram-tot-ibl         .
           move      w-tes-tot-irt (1)    to   rf-ram-tot-irt         .
           move      w-tes-tot-rmb (1)    to   rf-ram-tot-rmb         .
           move      w-tes-tot-pvn (1)    to   rf-ram-tot-pvn         .
           move      w-tes-dat-pag (1)    to   rf-ram-dat-pag         .
           move      w-tes-tip-vrs (1)    to   rf-ram-tip-vrs         .
           move      w-tes-dat-vrs (1)    to   rf-ram-dat-vrs         .
           move      w-tes-num-vrs (1)    to   rf-ram-num-vrs         .
           move      w-tes-ann-mov (1)    to   rf-ram-ann-mov         .
           move      w-tes-flg-ela (1)    to   rf-ram-flg-ela         .
           move      w-tes-alx-exp (1)    to   rf-ram-alx-exp         .
       cmp-rec-ram-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [ram]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-ram-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-ram-000      thru cmp-rec-ram-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/rda/fls/ioc/obj/iofram"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ram                 .
       wrt-rec-ram-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record [ram]                                  *
      *    *-----------------------------------------------------------*
       rew-rec-ram-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-ram-000      thru cmp-rec-ram-999        .
      *              *-------------------------------------------------*
      *              * Forced put record                               *
      *              *-------------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/rda/fls/ioc/obj/iofram"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ram                 .
       rew-rec-ram-999.
           exit.

