      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione di un pop-up per il tipo riga      *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-rig-lun    to   v-car                  .
           move      w-exp-tip-rig-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      spaces               to   v-msk                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-exp-tip-rig-tbl    to   v-txt                  .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Valore in campo di destinazione                 *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "P"            to   w-fnd-tip-rig-tri
           else if   v-num                =    02
                     move  "PN"           to   w-fnd-tip-rig-tri
           else if   v-num                =    03
                     move  "M"            to   w-fnd-tip-rig-tri
           else if   v-num                =    04
                     move  "V"            to   w-fnd-tip-rig-tri
           else if   v-num                =    05
                     move  "C"            to   w-fnd-tip-rig-tri
           else if   v-num                =    06
                     move  "A"            to   w-fnd-tip-rig-tri
           else      move  spaces         to   w-fnd-tip-rig-tri      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fnd-tip-rig-999.
       fnd-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "pgm/bfo/prg/obj/pffo3001"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
      *              *-------------------------------------------------*
      *              * Estrazione di eventuale variabile di i.p.c.     *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "tip-rig"            to   s-var                  .
           move      "="                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  spaces         to   w-fnd-tip-rig-sel
                     move  s-alf          to   w-fnd-tip-rig-tri
           else      move  "#"            to   w-fnd-tip-rig-sel      .
       fnd-tip-rig-999.
           exit.

      *    *===========================================================*
