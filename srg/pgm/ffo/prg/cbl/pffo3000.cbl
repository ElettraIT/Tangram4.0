      *    *===========================================================*
      *    * Routine di attribuzione protocollo fatture fornitori      *
      *    *-----------------------------------------------------------*
       att-ffo-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [ffoprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-ffo-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-ffo-prt-saa      .
           move      w-att-ffo-prt-saa    to   rn-ffo-prt-scl-ann     .
           move      w-att-ffo-prt-dpz    to   rn-ffo-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [ffoprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-ffo-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-ffo-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-ffo-prt-000.
       att-ffo-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-ffo-prt-num-prt   to   w-att-ffo-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-ffo-prt-wpr      .
           if        w-att-ffo-prt-wpr    =    zero
                     move  1              to   w-att-ffo-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-ffo-prt-saa    to   w-att-ffo-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-ffo-prt-dpz    to   w-att-ffo-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-ffo-prt-wnu    to   rn-ffo-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-ffo-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-ffo-prt-num-prt   to   w-att-ffo-prt-num      .
       att-ffo-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino protocollo fatture fornitori        *
      *    *-----------------------------------------------------------*
       rip-ffo-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [ffoprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-ffo-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-ffo-prt-saa      .
           move      w-att-ffo-prt-saa    to   rn-ffo-prt-scl-ann     .
           move      w-att-ffo-prt-dpz    to   rn-ffo-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [ffoprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-ffo-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-ffo-prt-num-prt   not  = w-att-ffo-prt-num
                     go to  rip-ffo-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           move      w-att-ffo-prt-num    to   w-att-ffo-prt-wnu      .
           subtract  1                    from w-att-ffo-prt-wpr      .
           if        w-att-ffo-prt-wpr    =    zero
                     move  zero           to   w-att-ffo-prt-wnu      .
           move      w-att-ffo-prt-wnu    to   rn-ffo-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
       rip-ffo-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/ffo/num/ioc/obj/inffoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-ffo-prt             .
       rip-ffo-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo iva fornitori   *
      *    *-----------------------------------------------------------*
       att-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to att-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     att-prt-ivf-000.
       att-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore originale            *
      *                  *---------------------------------------------*
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-dec      .
      *                  *---------------------------------------------*
      *                  * Incremento numero protocollo                *
      *                  *---------------------------------------------*
           add       1                    to   rn-prt-ivf-num-prt     .
           if        rn-prt-ivf-num-prt   =    zero
                     move  1              to   rn-prt-ivf-num-prt     .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero protocollo           *
      *                  *---------------------------------------------*
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-prt      .
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-inc      .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                  *---------------------------------------------*
      *                  * Se errori ripete l'intera operazione        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-prt-ivf-000.
      *                  *---------------------------------------------*
      *                  * Unlock                                      *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       att-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di ratifica numero protocollo iva fornitori       *
      *    *-----------------------------------------------------------*
       rat-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Se il valore e' stato ratificato : uscita       *
      *              *-------------------------------------------------*
           if        w-num-prt-ivf-prt    =    w-num-prt-ivf-inc
                     go to rat-prt-ivf-999.
      *              *-------------------------------------------------*
      *              * Se il valore impostato e' inferiore al valore   *
      *              * originale si esegue il ripristino               *
      *              *-------------------------------------------------*
           if        w-num-prt-ivf-prt    >    w-num-prt-ivf-inc
                     go to rat-prt-ivf-200.
           perform   rip-prt-ivf-000      thru rip-prt-ivf-999        .
           move      spaces               to   w-num-prt-ivf-flg      .
           go to     rat-prt-ivf-999.
       rat-prt-ivf-200.
      *              *-------------------------------------------------*
      *              * Se il valore impostato e' superiore al valore   *
      *              * originale si chiede all'operatore se la numera- *
      *              * zione dovra' poi proseguire con il numero suc-  *
      *              * cessivo                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero progressivo editato     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-num-prt-ivf-prt    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Richiesta all'operatore                     *
      *                  *---------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      spaces               to   v-not                  .
           string    "La numerazione dovra' poi proseguire dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " (S/N) ?" delimited by   size
                                          into v-not                  .
           move      spaces               to   v-alf                  .
           move      "SN"                 to   v-msk                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Esame risposta                              *
      *                  *---------------------------------------------*
           if        v-alf                =    "S"
                     go to rat-prt-ivf-400
           else if   v-alf                =    "N"
                     go to rat-prt-ivf-999
           else      go to rat-prt-ivf-200.
       rat-prt-ivf-400.
      *                  *---------------------------------------------*
      *                  * Se risposta 'Si'                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento numerazione               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura numerazione                 *
      *                          *-------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to rat-prt-ivf-600.
      *                          *-------------------------------------*
      *                          * Se numerazione non esistente la si  *
      *                          * crea normalizzata a zero            *
      *                          *-------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rat-prt-ivf-400.
       rat-prt-ivf-600.
      *                          *-------------------------------------*
      *                          * Aggiornamento numerazione           *
      *                          *-------------------------------------*
           move      w-num-prt-ivf-prt    to   rn-prt-ivf-num-prt     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                not  = e-not-err
                     go to rat-prt-ivf-400.
       rat-prt-ivf-800.
      *                          *-------------------------------------*
      *                          * Unlock della numerazione            *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       rat-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo iva fornitori     *
      *    *-----------------------------------------------------------*
       rip-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to rip-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rip-prt-ivf-000.
       rip-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-prt-ivf-num-prt   =    w-num-prt-ivf-inc
                     go to rip-prt-ivf-200
           else      go to rip-prt-ivf-400.
       rip-prt-ivf-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento numerazione         *
      *                      *-----------------------------------------*
           move      w-num-prt-ivf-dec    to   rn-prt-ivf-num-prt     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-prt-ivf-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rip-prt-ivf-999.
       rip-prt-ivf-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-prt-ivf-num-prt   =    w-num-prt-ivf-prt
                     go to rip-prt-ivf-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Preparazione numero progressivo *
      *                              * editato                         *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-num-prt-ivf-inc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                              *---------------------------------*
      *                              * Messaggio all'operatore         *
      *                              *---------------------------------*
           move      "Attenzione: un altro utente ha nel frattempo prele
      -              "vato un numero."    to   w-err-box-err-msg      .
           string    "Pertanto il numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rip-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero registrazione fattura for- *
      *    * nitore                                                    *
      *    *-----------------------------------------------------------*
       att-sff-num-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numddp]                                  *
      *              *-------------------------------------------------*
           move      w-sff-num-scl-ann    to   rn-sff-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [sffnum]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sff-num-400.
       att-sff-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-sff-num-000.
       att-sff-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-sff-num-num-ftf   to   w-sff-num-num-ftf      .
           move      w-sff-num-r01-num    to   w-sff-num-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-sff-num-val-pre    to   w-sff-num-val-pos      .
           add       1                    to   w-sff-num-val-pos      .
           if        w-sff-num-val-pos    =    zero
                     move  1              to   w-sff-num-val-pos      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero registrazione completo  *
      *                  *---------------------------------------------*
           move      w-sff-num-scl-ann    to   w-sff-num-r01-saa      .
           move      w-sff-num-val-pos    to   w-sff-num-r01-num      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero registrazione          *
      *                  *---------------------------------------------*
           move      w-sff-num-num-ftf    to   rn-sff-num-num-ftf     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito dell'opera- *
      *                  * zione di update                             *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sff-num-600.
       att-sff-num-500.
      *                  *---------------------------------------------*
      *                  * Se errore in operazione di update           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-sff-num-000.
       att-sff-num-600.
      *                  *---------------------------------------------*
      *                  * Se nessun errore in operazione di update    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-sff-num-999.
       att-sff-num-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se in modifica : cancellazione movimenti prece- *
      *              *                  denti                          *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to scr-mov-fil-050.
      *                  *---------------------------------------------*
      *                  * Annullamento del movimento di contabilita'  *
      *                  * generale che era stato a suo tempo genera-  *
      *                  * to a fronte del movimento di registrazione  *
      *                  * fattura fornitore                           *
      *                  *---------------------------------------------*
           perform   del-mov-cge-000      thru del-mov-cge-999        .
      *                  *---------------------------------------------*
      *                  * Cancellazione movimenti di SCF precedenti   *
      *                  *---------------------------------------------*
           perform   del-mov-scf-000      thru del-mov-scf-999        .
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di MAG precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-mag-000      thru del-mov-mag-999        .
       scr-mov-fil-050.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [ffr]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-ffr-000      thru del-rec-ffr-999        .
      *              *-------------------------------------------------*
      *              * Delete [ffx]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-ffx-000      thru del-rec-ffx-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = w-tes-tip-arc (2) or
                     w-tes-cod-arc (1)    not  = w-tes-cod-arc (2) or
                     w-tes-dpz-arc (1)    not  = w-tes-dpz-arc (2) or
                     w-tes-dat-doc (1)    not  = w-tes-dat-doc (2) or
                     w-tes-num-doc (1)    not  = w-tes-num-doc (2) or
                     w-tes-cod-lng (1)    not  = w-tes-cod-lng (2) or
                     w-tes-sgl-vpf (1)    not  = w-tes-sgl-vpf (2) or
                     w-tes-dec-vpf (1)    not  = w-tes-dec-vpf (2) or
                     w-tes-tdc-vpf (1)    not  = w-tes-tdc-vpf (2) or
                     w-tes-cdc-vpf (1)    not  = w-tes-cdc-vpf (2)
                     move  "#"            to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento file righe [ffr]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [ffr]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-ffr-000      thru wrt-rec-ffr-999        .
      *                      *-----------------------------------------*
      *                      * Write record [ffx]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-ffx-000      thru wrt-rec-ffx-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig (2)    =    spaces
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-cnt-var-tes-cor    not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [ffr]                       *
      *                          *-------------------------------------*
           perform   rew-rec-ffr-000      thru rew-rec-ffr-999        .
      *                          *-------------------------------------*
      *                          * Rewrite [ffx]                       *
      *                          *-------------------------------------*
           perform   rew-rec-ffx-000      thru rew-rec-ffx-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Attribuzione protocolli per movimenti connessi  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Attribuzione primo protocollo di CGE e de-  *
      *                  * terminazione quanti di essi sono necessari  *
      *                  *---------------------------------------------*
           perform   det-prt-cge-000      thru det-prt-cge-999        .
