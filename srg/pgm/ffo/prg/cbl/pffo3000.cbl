      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-nok-reg-750.
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Prompts per pagina piede                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-ppx
                    (w-cnt-sts-imp-npp)   =    spaces
                     perform pmt-pie-reg-000
                                          thru pmt-pie-reg-999
                     move    "#"          to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati pagina piede           *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"      or
                     w-cnt-mfu-tip-fun    =    "V"      or
                     w-cnt-sts-imp-ppx
                    (w-cnt-sts-imp-npp)   not  = spaces or
                     w-cnt-sts-ing-ppx
                    (w-cnt-sts-imp-npp)   not  = spaces
                     if    w-cnt-sts-vis-ppx
                          (w-cnt-sts-imp-npp)
                                          =    spaces
                           perform vis-pie-reg-000
                                          thru vis-pie-reg-999
                           move    "#"    to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Flag di ingresso in pagina piede            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati piede                     *
      *                  *---------------------------------------------*
           perform   acc-pie-reg-000      thru acc-pie-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-pie    =    "S" or
                     w-cnt-tus-acc-pie    =    "X" or
                     w-cnt-tus-acc-pie    =    "E"
                     move  w-cnt-tus-acc-pie
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se spostamento di pagina                    *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-pie    =    "-"
                     go to acc-nok-reg-710
           else      go to acc-nok-reg-750.
       acc-nok-reg-710.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' 1 : ad ac-  *
      *                          * cettazione corpo                    *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    >    1
                     go to acc-nok-reg-720.
      *                              *---------------------------------*
      *                              * Nr riga corpo da accettare :    *
      *                              * max + 1                         *
      *                              *---------------------------------*
           move      w-cat-rig-max        to   w-cnt-cor-nrg-dac      .
           if        w-cat-rig-app        =    spaces
                     add   1              to   w-cnt-cor-nrg-dac      .
           go to     acc-nok-reg-400.
       acc-nok-reg-720.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina attuale a : no    *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-npp)     .
           move      spaces               to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-npp)     .
       acc-nok-reg-730.
      *                          *-------------------------------------*
      *                          * Decremento numero pagina attuale    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-sts-imp-npp      .
       acc-nok-reg-740.
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : decremento ulteriore, a me- *
      *                          *         no di non essere a pagina 1 *
      *                          *         caso in cui si va' ad ac-   *
      *                          *         cettazione corpo            *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-nok-reg-710.
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione piede       *
      *                          *-------------------------------------*
           go to     acc-nok-reg-700.
       acc-nok-reg-750.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina successiva      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio numero pagina attuale   *
      *                          *-------------------------------------*
           move      w-cnt-sts-imp-npp    to   w-cnt-sts-imp-spp      .
       acc-nok-reg-760.
      *                          *-------------------------------------*
      *                          * Status di impostazione dati della   *
      *                          * della pagina attuale a : si'        *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si pone lo status di impostazione   *
      *                          * dati generale piede a si'           *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    not  < w-cnt-sts-imp-mpp
                     move  "#"            to   w-cnt-sts-imp-pie      .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si va' a conferma impostazioni      *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    not  < w-cnt-sts-imp-mpp
                     move  w-cnt-sts-imp-spp
                                          to   w-cnt-sts-imp-npp
                     go to acc-nok-reg-800.
      *                          *-------------------------------------*
      *                          * Incremento numero pagina attuale    *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-sts-imp-npp      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : a re-incremento             *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-nok-reg-760.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina impostata a : no  *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-spp)     .
           move      spaces               to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-spp)     .
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione piede       *
      *                          *-------------------------------------*
           go to     acc-nok-reg-700.
       acc-nok-reg-800.
      *              *-------------------------------------------------*
      *              * Conferma impostazioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Se attualmente visualizzato il corpo 3 si   *
      *                  * esegue la visualizzazione dei prompts della *
      *                  * riga corpo 3 espansa                        *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-co3    =    spaces
                     go to acc-nok-reg-805.
           perform   pmt-rig-co3-000      thru pmt-rig-co3-999        .
       acc-nok-reg-805.
      *                  *---------------------------------------------*
      *                  * Cancellazione eventuali note operative      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-nok-reg-810.
      *                  *---------------------------------------------*
      *                  * Test se sola visualizzazione                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-nok-reg-820
           else      go to acc-nok-reg-830.
       acc-nok-reg-820.
      *                      *-----------------------------------------*
      *                      * Accettazione se sola visualizzazione    *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#VIS"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "E"                  to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "E"
                     move  "EXIT"         to   v-key                  .
           go to     acc-nok-reg-840.
       acc-nok-reg-830.
      *                      *-----------------------------------------*
      *                      * Accettazione se inserimento o modifica  *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#SAV"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "SNE"                to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "E"           to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key                  .
       acc-nok-reg-840.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to acc-nok-reg-850
           else if   v-key                =    "EXIT"
                     go to acc-nok-reg-860
           else if   v-key                =    "UP  "
                     go to acc-nok-reg-870
           else      go to acc-nok-reg-810.
       acc-nok-reg-850.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-tus-acc-nok      .
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    not  = spaces
                     go to acc-nok-reg-870.
           go to     acc-nok-reg-999.
       acc-nok-reg-860.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine di controllo per Exit        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se Exit non attivato : come 'Up'    *
      *                          *-------------------------------------*
           perform   exe-acc-cmp-exi-000  thru exe-acc-cmp-exi-999    .
           if        w-cnt-acc-flg-exi    not  = spaces
                     go to acc-nok-reg-870.
      *                          *-------------------------------------*
      *                          * Se Exit attivato                    *
      *                          *-------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-nok      .
           go to     acc-nok-reg-999.
       acc-nok-reg-870.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazione piede                   *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-nok-reg-740.
       acc-nok-reg-999.
           exit.

      *    *===========================================================*
      *    * Trattamento testata registrazione                         *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/pffo3000.tes"                   .

      *    *===========================================================*
      *    * Trattamento corpo registrazione                           *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/pffo3000.cor"                   .

      *    *===========================================================*
      *    * Trattamento testata 2 registrazione                       *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/pffo3000.te2"                   .

      *    *===========================================================*
      *    * Trattamento corpo 2 registrazione - contabilita'          *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/pffo3000.co2"                   .

      *    *===========================================================*
      *    * Trattamento corpo 3 registrazione - scadenze              *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/pffo3000.co3"                   .

      *    *===========================================================*
      *    * Trattamento piede registrazione                           *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/pffo3000.pie"                   .

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
      *              *-------------------------------------------------*
      *              * Test su tipo movimento                          *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf        not  = spaces
                     go to cnt-tdo-key-100.
           move      "Manca il tipo movimento !"
                                          to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-100.
      *              *-------------------------------------------------*
      *              * Test su data registrazione                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se mancante                            *
      *                  *---------------------------------------------*
           if        w-tes-dat-reg        not  = zero
                     go to cnt-tdo-key-150.
           move      "Manca la data registrazione !"
                                          to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-150.
      *                  *---------------------------------------------*
      *                  * Se numero protocollo a zero                 *
      *                  *---------------------------------------------*
           if        w-tes-num-prt        not  = zero
                     go to cnt-tdo-key-200.
      *                  *---------------------------------------------*
      *                  * Controllo data minima per scrittura movi-   *
      *                  * mento di magazzino                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-cam    =    zero
                     go to cnt-tdo-key-160.
      *                      *-----------------------------------------*
      *                      * Controllo                               *
      *                      *-----------------------------------------*
           if        w-tes-dat-reg        not  < w-gen-dtm-mag
                     go to cnt-tdo-key-160.
           move      "Data di registrazione non accettabile per moviment
      -              "o di magazzino "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-160.
      *                  *---------------------------------------------*
      *                  * Controllo data minima per aggiornamento     *
      *                  * contabile                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to cnt-tdo-key-200.
      *                      *-----------------------------------------*
      *                      * Controllo                               *
      *                      *-----------------------------------------*
           if        w-tes-dat-reg        not  < w-gen-dtm-cge
                     go to cnt-tdo-key-200.
           move      "Data di registrazione non accettabile per moviment
      -              "o contabile    "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-200.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       cnt-tdo-key-400.
      *              *-------------------------------------------------*
      *              * Dichiarazione di inizio ciclo evasione bolle    *
      *              * fornitori                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se gestione bolle fornitori attiva     *
      *                  *---------------------------------------------*
           if        w-prs-bfo-snx        not  = "S"
                     go to cnt-tdo-key-800.
      *                  *---------------------------------------------*
      *                  * Test se tipo movimento per la bolla lo pre- *
      *                  * vede                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-maf    not  = 02
                     go to cnt-tdo-key-800.
      *                  *---------------------------------------------*
      *                  * Esecuzione                                  *
      *                  *---------------------------------------------*
           move      "DI"                 to   l-eva-bfo-tip-ope      .
           move      "pgm/ffo/prg/obj/pffo300a"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-bfo
                                               w-prs
                                               w-tes
                                               w-te2
                                               w-rig
                                               w-cat-rig              .
       cnt-tdo-key-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     cnt-tdo-key-999.
       cnt-tdo-key-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
      *              *-------------------------------------------------*
      *              * Test                                            *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf        =    spaces and
                     w-tes-dat-reg        =    zero   and
                     w-tes-num-prt        =    zero
                     move  "#"            to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controlli per pagina testata nr. 1              *
      *              *-------------------------------------------------*
       cnt-tdo-nok-110.
      *                  *---------------------------------------------*
      *                  * Codice fornitore                            *
      *                  *---------------------------------------------*
       cnt-tdo-nok-120.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza fornitore                 *
      *                  *---------------------------------------------*
       cnt-tdo-nok-130.
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore non presente : errore         *
      *                      *-----------------------------------------*
           if        w-tes-dat-doc (1)    not  = zero
                     go to cnt-tdo-nok-140.
           move      "Manca la data documento                           
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-140.
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore non presente : errore         *
      *                      *-----------------------------------------*
           if        w-tes-num-doc (1)    not  = spaces
                     go to cnt-tdo-nok-150.
           move      "Manca il numero documento                         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-150.
      *              *-------------------------------------------------*
      *              * Controlli per pagina testata nr. 2              *
      *              *-------------------------------------------------*
       cnt-tdo-nok-160.
      *                  *---------------------------------------------*
      *                  * Inoltro pagamenti                           *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    not  = zero          and
                     w-tes-inl-pgt (1)    not  > w-exp-inl-pgt-num
                     go to cnt-tdo-nok-170.
           move      "Manca l'inoltro pagamenti al fornitore            
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-170.
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se campo da accettare              *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02 and
                     w-tes-cod-tmf-tpv    not  = 03
                     go to cnt-tdo-nok-180.
      *                      *-----------------------------------------*
      *                      * Se valore non presente : errore         *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = spaces
                     go to cnt-tdo-nok-180.
           move      "Manca la sigla valuta                             
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-180.
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se campo da accettare              *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02 and
                     w-tes-cod-tmf-tpv    not  = 03
                     go to cnt-tdo-nok-190.
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to cnt-tdo-nok-190.
      *                      *-----------------------------------------*
      *                      * Se valore non presente : errore         *
      *                      *-----------------------------------------*
           if        w-tes-cdc-vpf (1)    not  = zero
                     go to cnt-tdo-nok-190.
           move      "Manca il coefficiente di cambio                   
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-190.
      *                  *---------------------------------------------*
      *                  * Assoggettamento iva                         *
      *                  *---------------------------------------------*
       cnt-tdo-nok-200.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti                      *
      *                  *---------------------------------------------*
       cnt-tdo-nok-210.
      *                  *---------------------------------------------*
      *                  * Importo documento in valuta                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su impostazione righe del documen- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to cnt-tdo-nok-220.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to cnt-tdo-nok-220.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo prove-  *
      *                      * nienza documento                        *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
