       box-msg-es2-999.
           exit.

      *    *===========================================================*
      *    * Find su archivio [fft]                                    *
      *    *-----------------------------------------------------------*
       fnd-arc-fft-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-arc-fft-sel      .
       fnd-arc-fft-010.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se sono stati preparati i valori in input   *
      *                  * si procede come se ricerca gia' effettuata  *
      *                  *---------------------------------------------*
           if        w-fnd-arc-fft-tmf    not  = spaces or
                     w-fnd-arc-fft-dat    not  = zero   or
                     w-fnd-arc-fft-prt    not  = zero
                     go to fnd-arc-fft-080.
       fnd-arc-fft-030.
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pffo3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-arc-fft-sel
                     go to  fnd-arc-fft-999.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'snx-slc' per il  *
      *              * livello successivo per l'ammissibilita' del ta- *
      *              * sto Slct                                        *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-slc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "S"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per codice di- *
      *              * pendenza                                        *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-dpz"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-tes-cod-dpz        to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "pgm/ffo/prg/obj/pffo3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
       fnd-arc-fft-050.
      *              *-------------------------------------------------*
      *              * Estrazione di eventuali variabili di i.p.c. de- *
      *              * terminate da function-key "SLCT" durante l'in-  *
      *              * terrogazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo movimento                              *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "cod-tmf"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-arc-fft-sel
                     go to fnd-arc-fft-999.
           move      s-alf                to   w-fnd-arc-fft-tmf      .
      *                  *---------------------------------------------*
      *                  * Data registrazione                          *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "dat-reg"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-arc-fft-sel
                     go to fnd-arc-fft-999.
           move      s-dat                to   w-fnd-arc-fft-dat      .
      *                  *---------------------------------------------*
      *                  * Numero protocollo                           *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "num-prt"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-arc-fft-sel
                     go to fnd-arc-fft-999.
           move      s-num                to   w-fnd-arc-fft-prt      .
       fnd-arc-fft-080.
      *              *-------------------------------------------------*
      *              * Salvataggio valori chiave                       *
      *              *-------------------------------------------------*
           move      w-tes-val-key        to   w-sav-val-key          .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori estratti                 *
      *              *-------------------------------------------------*
           move      w-fnd-arc-fft-tmf    to   w-tes-cod-tmf          .
           move      w-fnd-arc-fft-dat    to   w-tes-dat-reg          .
           move      w-fnd-arc-fft-prt    to   w-tes-num-prt          .
       fnd-arc-fft-100.
      *              *-------------------------------------------------*
      *              * Determinazione campi derivati e effettuazione   *
      *              * controlli come se fossero stati impostati       *
      *              *-------------------------------------------------*
           perform   cnt-key-doc-000      thru cnt-key-doc-999        .
       fnd-arc-fft-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fnd-arc-fft-999.
       fnd-arc-fft-999.
           exit.
       
      *    *===========================================================*
      *    * Controllo dati in chiave a seguito FIND o PRSC            *
      *    *-----------------------------------------------------------*
       cnt-key-doc-000.
      *              *-------------------------------------------------*
      *              * Lettura archivio [yff]                          *
      *              *-------------------------------------------------*
           move      w-tes-cod-tmf        to   w-let-arc-yff-cod      .
           move      zero                 to   w-let-arc-yff-dpz      .
           perform   let-arc-yff-000      thru let-arc-yff-999        .
           move      w-let-arc-yff-des    to   w-tes-cod-tmf-des      .
      *              *-------------------------------------------------*
      *              * Se codice errato : uscita con errore            *
      *              *-------------------------------------------------*
           if        w-let-arc-yff-flg    not  = spaces
                     go to cnt-key-doc-900.
      *              *-------------------------------------------------*
      *              * Se a spaces : uscita con errore                 *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf        =    spaces
                     go to cnt-key-doc-900.
      *              *-------------------------------------------------*
      *              * Controllo tipo movimento per fattura fornitore  *
      *              *-------------------------------------------------*
           perform   ctl-cod-tmf-000      thru ctl-cod-tmf-999        .
      *              *-------------------------------------------------*
      *              * Se controllo non superato : uscita con errore   *
      *              *-------------------------------------------------*
           if        w-ctl-cod-tmf-flg    not  = spaces
                     go to cnt-key-doc-900.
      *              *-------------------------------------------------*
      *              * Completamento visualizzazione campi-chiave      *
      *              *-------------------------------------------------*
           perform   vis-cod-tmf-000      thru vis-cod-tmf-999        .
           perform   vis-cod-tmf-des-000  thru vis-cod-tmf-des-999    .
           perform   vis-dat-reg-000      thru vis-dat-reg-999        .
           perform   vis-num-prt-000      thru vis-num-prt-999        .
      *              *-------------------------------------------------*
      *              * Uscita con successo                             *
      *              *-------------------------------------------------*
           go to     cnt-key-doc-999.
       cnt-key-doc-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valori chiave salvati            *
      *                  *---------------------------------------------*
           move      w-sav-val-key        to   w-tes-val-key          .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-fnd-arc-fft-sel      .
       cnt-key-doc-999.
           exit.

      *    *===========================================================*
      *    * Find su tipi riga                                         *
      *    *-----------------------------------------------------------*
       fnd-tip-rig-000.
      *              *-------------------------------------------------*
