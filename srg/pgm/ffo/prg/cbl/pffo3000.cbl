      *    *===========================================================*
      *    * Accettazione campo chiave : Numero protocollo             *
      *    *-----------------------------------------------------------*
       acc-num-prt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione work per accettazione          *
      *                  *---------------------------------------------*
           move      w-tes-num-prt-saa    to   w-acc-num-prt-saa      .
           move      w-tes-num-prt-prg    to   w-acc-num-prt-prg      .
       acc-num-prt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      04                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-acc-num-prt-num    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
       acc-num-prt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-acc-num-prt-num      .
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Decomposizione work di accettazione         *
      *                  *---------------------------------------------*
           if        w-acc-num-prt-num    =    zero
                     go to acc-num-prt-300.
           move      w-acc-num-prt-saa    to   w-tes-num-prt-saa      .
           move      w-tes-cod-dpz        to   w-tes-num-prt-dpz      .
           move      w-acc-num-prt-prg    to   w-tes-num-prt-prg      .
       acc-num-prt-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-prt-400.
      *                  *---------------------------------------------*
      *                  * Find su archivio [fft]                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-fnd-arc-fft-tmf      .
           move      zero                 to   w-fnd-arc-fft-dat      .
           move      zero                 to   w-fnd-arc-fft-prt      .
           perform   fnd-arc-fft-000      thru fnd-arc-fft-999        .
           if        w-fnd-arc-fft-sel    not  = spaces
                     go to acc-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-num-prt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il protocollo e' diverso da zero : simu- *
      *                  * lazione della ricerca                       *
      *                  *---------------------------------------------*
           if        w-acc-num-prt-num    =    zero
                     go to acc-num-prt-600.
      *                  *---------------------------------------------*
      *                  * Lettura testata tramite protocollo          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-fft-num-prt         .
           move      "pgm/ffo/fls/ioc/obj/ioffft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fft                 .
      *                      *-----------------------------------------*
      *                      * Se registrazione non esistente : mes-   *
      *                      * saggio di errore                        *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to acc-num-prt-420.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Documento non esistente in archivio !             
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-num-prt-100.
       acc-num-prt-420.
      *                  *---------------------------------------------*
      *                  * Find precablato su archivio [fft]           *
      *                  *---------------------------------------------*
           move      rf-fft-cod-tmf       to   w-fnd-arc-fft-tmf      .
           move      rf-fft-dat-reg       to   w-fnd-arc-fft-dat      .
           move      rf-fft-num-prt       to   w-fnd-arc-fft-prt      .
           perform   fnd-arc-fft-000      thru fnd-arc-fft-999        .
           if        w-fnd-arc-fft-sel    not  = spaces
                     go to acc-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-num-prt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-prt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-num-prt-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-num-prt-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
       acc-num-prt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Numero protocollo          *
      *    *-----------------------------------------------------------*
       vis-num-prt-000.
      *              *-------------------------------------------------*
      *              * Composizione work per visualizzazione           *
      *              *-------------------------------------------------*
           move      w-tes-num-prt-saa    to   w-vis-num-prt-saa      .
           move      w-tes-num-prt-prg    to   w-vis-num-prt-prg      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      04                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-vis-num-prt-num    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-prt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Data registrazione            *
      *    *-----------------------------------------------------------*
       acc-dat-reg-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del valore di de-    *
      *                  * fault                                       *
      *                  *---------------------------------------------*
           if        w-tes-dat-reg        =    zero
                     move  w-def-dat-reg  to   w-tes-dat-reg          .
       acc-dat-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      04                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      w-tes-dat-reg        to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-dat-reg-999.
       acc-dat-reg-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dat-reg          .
       acc-dat-reg-250.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-dat-reg-300.
      *                  *---------------------------------------------*
      *                  * Find su archivio [fft]                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-fnd-arc-fft-tmf      .
           move      zero                 to   w-fnd-arc-fft-dat      .
           move      zero                 to   w-fnd-arc-fft-prt      .
           perform   fnd-arc-fft-000      thru fnd-arc-fft-999        .
           if        w-fnd-arc-fft-sel    not  = spaces
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-dat-reg-300.
      *              *-------------------------------------------------*
      *              * Se Previous screen                              *
      *              *-------------------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-dat-reg-400.
      *                  *---------------------------------------------*
      *                  * Preparazione dei parametri per la selezione *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-buf-doc-mvm-drc      .
           move      s-ute                to   w-buf-doc-mvm-ute      .
      *
           if        w-tes-dat-reg        not  = zero
                     move  w-tes-dat-reg  to   w-buf-doc-mvm-drc      .
      *                  *---------------------------------------------*
      *                  * Routine di ricerca                          *
      *                  *---------------------------------------------*
           perform   buf-doc-mvm-000      thru buf-doc-mvm-999        .
      *                      *-----------------------------------------*
      *                      * Test sul flag di uscita                 *
      *                      *-----------------------------------------*
           if        w-buf-doc-mvm-fds    not  = spaces
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Valori selezionati                          *
      *                  *---------------------------------------------*
           move      w-buf-doc-mvm-tds    to   w-tes-cod-tmf          .
           move      w-buf-doc-mvm-nds    to   w-tes-num-prt          .
           move      w-buf-doc-mvm-dds    to   w-tes-dat-reg          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione data registrazione e numero *
      *                  * protocollo selezionati                      *
      *                  *---------------------------------------------*
           perform   vis-cod-tmf-000      thru vis-cod-tmf-999        .
           perform   vis-num-prt-000      thru vis-num-prt-999        .
           perform   vis-dat-reg-000      thru vis-dat-reg-999        .
      *                  *---------------------------------------------*
      *                  * Test su valori estratti                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf        =    spaces   or
                     w-tes-dat-reg        =    zero     or
                     w-tes-num-prt        =    zero
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Find precablato su archivio [fft]           *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmf        to   w-fnd-arc-fft-tmf      .
           move      w-tes-dat-reg        to   w-fnd-arc-fft-dat      .
           move      w-tes-num-prt        to   w-fnd-arc-fft-prt      .
           perform   fnd-arc-fft-000      thru fnd-arc-fft-999        .
           if        w-fnd-arc-fft-sel    not  = spaces
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-dat-reg-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione, a meno   *
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-tes-dat-reg        not  = zero
                     go to acc-dat-reg-600.
           if        v-key                =    "UP  "
                     go to acc-dat-reg-600
           else      go to acc-dat-reg-100.
       acc-dat-reg-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-reg-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-dat-reg-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-dat-reg-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-dat-reg-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-dat-reg-999.
       acc-dat-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Data registrazione         *
      *    *-----------------------------------------------------------*
       vis-dat-reg-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      04                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-tes-dat-reg        to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Tipo movimento per fattura    *
      *    * fornitore                                                 *
      *    *-----------------------------------------------------------*
       acc-cod-tmf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf        not  = spaces
                     go to acc-cod-tmf-100.
      *                  *---------------------------------------------*
      *                  * Preparazione e visualizzazione default      *
      *                  *---------------------------------------------*
           move      w-def-cod-tmf        to   w-tes-cod-tmf          .
           move      w-def-cod-tmf-des    to   w-tes-cod-tmf-des      .
           perform   vis-cod-tmf-des-000  thru vis-cod-tmf-des-999    .
       acc-cod-tmf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-yff-ope      .
           move      w-tes-cod-tmf        to   w-cod-des-yff-cod      .
           move      05                   to   w-cod-des-yff-lin      .
           move      22                   to   w-cod-des-yff-pos      .
           move      05                   to   w-cod-des-yff-dln      .
           move      28                   to   w-cod-des-yff-dps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-yff-cll-000  thru cod-des-yff-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-yff-foi-000  thru cod-des-yff-foi-999    .
       acc-cod-tmf-110.
           perform   cod-des-yff-cll-000  thru cod-des-yff-cll-999    .
           if        w-cod-des-yff-ope    =    "F+"
                     go to acc-cod-tmf-115.
           if        w-cod-des-yff-ope    =    "AC"
                     go to acc-cod-tmf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-tmf-115.
           perform   cod-des-yff-foi-000  thru cod-des-yff-foi-999    .
           go to     acc-cod-tmf-110.
       acc-cod-tmf-120.
           move      w-cod-des-yff-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-tmf-999.
       acc-cod-tmf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-tmf          .
       acc-cod-tmf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmf        to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-cod-tmf-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [yff]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmf        to   w-let-arc-yff-cod      .
           move      zero                 to   w-let-arc-yff-dpz      .
           perform   let-arc-yff-000      thru let-arc-yff-999        .
           move      w-let-arc-yff-des    to   w-tes-cod-tmf-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-tmf-des-000  thru vis-cod-tmf-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-yff-flg    not  = spaces
                     go to acc-cod-tmf-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione, a meno *
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf        not  = spaces
                     go to acc-cod-tmf-405.
           if        v-key                =    "UP  "
                     go to acc-cod-tmf-405
           else      go to acc-cod-tmf-100.
       acc-cod-tmf-405.
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo               *
      *                  *---------------------------------------------*
           perform   ctl-cod-tmf-000      thru ctl-cod-tmf-999        .
      *                  *---------------------------------------------*
      *                  * Se controllo errato : reimpostazione        *
      *                  *---------------------------------------------*
           if        w-ctl-cod-tmf-flg    not  = spaces
                     go to acc-cod-tmf-100.
       acc-cod-tmf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-tmf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cod-tmf-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-tmf-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cod-tmf-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cod-tmf-999.
       acc-cod-tmf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : tipo movimento per la fat- *
      *    * tura fornitori                                            *
      *    *-----------------------------------------------------------*
       vis-cod-tmf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-tes-cod-tmf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-tmf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : descrizione tipo movimento *
      *    *-----------------------------------------------------------*
       vis-cod-tmf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-tes-cod-tmf-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-tmf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campi non chiave della registrazione         *
      *    *-----------------------------------------------------------*
       acc-nok-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-nok      .
      *              *-------------------------------------------------*
      *              * Visualizzazione tipo funzionamento              *
      *              *-------------------------------------------------*
           perform   vis-tip-fun-000      thru vis-tip-fun-999        .
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione se in modi- *
      *              * fica o visualizzazione, per testata, corpo, te- *
      *              * stata 2, corpo 2, corpo 3 e piede               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In inserimento bisogna vedere il contenuto  *
      *                  * delle personalizzazioni relative agli ag-   *
      *                  * giornamenti contabili ed alle scadenze for- *
      *                  * nitori                                      *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-nok-reg-100.
      *                  *---------------------------------------------*
      *                  * Test su Si/No aggiornamenti contabili da    *
      *                  * gestione fatture fornitori                  *
      *                  *---------------------------------------------*
           if        w-prs-snx-cge        not  = "S"
                     move  all "#"        to   w-cnt-sts-imp-pt2
                     move  all "#"        to   w-cnt-sts-ing-pt2
                     move  "#"            to   w-cnt-sts-imp-co2      .
      *                  *---------------------------------------------*
      *                  * Test su Si/No aggiornamento scadenze forni- *
      *                  * tori da gestione fatture fornitori          *
      *                  *---------------------------------------------*
           if        w-prs-snx-scf        not  = "S"
                     move  "#"            to   w-cnt-sts-imp-co3      .
      *                  *---------------------------------------------*
      *                  * Ad assestamento status di impostazione per  *
      *                  * piede                                       *
      *                  *---------------------------------------------*
           go to     acc-nok-reg-150.
       acc-nok-reg-100.
      *                  *---------------------------------------------*
      *                  * Se in modifica o in visualizzazione         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M" or
                     w-cnt-mfu-tip-fun    =    "V"
                     move  "#"            to   w-cnt-sts-imp-tes
                     move  all "#"        to   w-cnt-sts-imp-pte
                     move  all "#"        to   w-cnt-sts-ing-pte
                     move  "#"            to   w-cnt-sts-imp-cor
                     move  all "#"        to   w-cnt-sts-imp-pt2
                     move  all "#"        to   w-cnt-sts-ing-pt2
                     move  "#"            to   w-cnt-sts-imp-co2
                     move  "#"            to   w-cnt-sts-imp-co3
                     move  "#"            to   w-cnt-sts-imp-pie
                     move  all "#"        to   w-cnt-sts-imp-ppi
                     move  all "#"        to   w-cnt-sts-ing-ppi      .
       acc-nok-reg-150.
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione per piede   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-pie      .
       acc-nok-reg-200.
      *              *-------------------------------------------------*
      *              * Trattamento testata                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del numero di pagine che     *
      *                  * compongono la testata                       *
      *                  *---------------------------------------------*
           perform   dmp-tes-reg-000      thru dmp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione titolo programma            *
      *                  *---------------------------------------------*
           perform   vis-tit-pgm-000      thru vis-tit-pgm-999        .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-cor      
                                               w-cnt-sts-vis-cor      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo             *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rig      
                                               w-cnt-sts-vis-rig      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati testata 2              *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-te2
                                               w-cnt-sts-pmt-pt2
                                               w-cnt-sts-vis-te2
                                               w-cnt-sts-vis-pt2      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo 2                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-co2      
                                               w-cnt-sts-vis-co2      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo 2           *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rg2      
                                               w-cnt-sts-vis-rg2      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo 3                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-co3      
                                               w-cnt-sts-vis-co3      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo 3           *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rg3      
                                               w-cnt-sts-vis-rg3      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati piede                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-pie
                                               w-cnt-sts-pmt-ppi
                                               w-cnt-sts-vis-pie
                                               w-cnt-sts-vis-ppi      .
      *                  *---------------------------------------------*
      *                  * Prompts per campi chiave                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-key    =    spaces
                     perform pmt-key-reg-000
                                          thru pmt-key-reg-999
                     move    "#"          to   w-cnt-sts-pmt-key      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati campi chiave           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-key    =    spaces
                     perform vis-key-reg-000
                                          thru vis-key-reg-999
                     move    "#"          to   w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Prompts per pagina di testata               *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-ptx
                    (w-cnt-sts-imp-npt)   =    spaces
                     perform pmt-tes-reg-000
                                          thru pmt-tes-reg-999
                     move    "#"          to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati pagina testata         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"      or
                     w-cnt-mfu-tip-fun    =    "V"      or
                     w-cnt-sts-imp-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces or
                     w-cnt-sts-ing-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces
                     if    w-cnt-sts-vis-ptx
                          (w-cnt-sts-imp-npt)
                                          =    spaces
                           perform vis-tes-reg-000
                                          thru vis-tes-reg-999
                           move    "#"    to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Flag di ingresso in pagina di testata       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati testata                   *
      *                  *---------------------------------------------*
           perform   acc-tes-reg-000      thru acc-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "S" or
                     w-cnt-tus-acc-tes    =    "X" or
                     w-cnt-tus-acc-tes    =    "E"
                     move  w-cnt-tus-acc-tes
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se spostamento di pagina                    *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "-"
                     go to acc-nok-reg-225
           else      go to acc-nok-reg-250.
       acc-nok-reg-225.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' 1 si ignora *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  > 1
                     go to acc-nok-reg-200.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della chiave a : no            *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      .
           move      spaces               to   w-cnt-sts-vis-key      .
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina attuale a : no    *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
           move      spaces               to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
       acc-nok-reg-230.
      *                          *-------------------------------------*
      *                          * Decremento numero pagina attuale    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-sts-imp-npt      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : decremento ulteriore        *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces and
                     w-cnt-sts-imp-npt    >    1
                     go to acc-nok-reg-230.
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione testata     *
      *                          *-------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-250.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina successiva      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio numero pagina attuale   *
      *                          *-------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-nok-reg-260.
      *                          *-------------------------------------*
      *                          * Status di impostazione dati della   *
      *                          * della pagina attuale a : si'        *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si pone lo status di impostazione   *
      *                          * dati generale testata a si'         *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  "#"            to   w-cnt-sts-imp-tes      .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si va' ad accettazione corpo        *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-nok-reg-300.
      *                          *-------------------------------------*
      *                          * Incremento numero pagina attuale    *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : a re-incremento             *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-nok-reg-260.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della chiave a : no            *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      .
           move      spaces               to   w-cnt-sts-vis-key      .
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina impostata a : no  *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-svp)     .
           move      spaces               to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-svp)     .
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione testata     *
      *                          *-------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-300.
      *                  *---------------------------------------------*
      *                  * Numero riga corpo da accettare : 1          *
      *                  *---------------------------------------------*
           move       1                   to   w-cnt-cor-nrg-dac      .
       acc-nok-reg-400.
      *              *-------------------------------------------------*
      *              * Trattamento corpo                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se corpo da trattare                   *
      *                  *---------------------------------------------*
           perform   snp-cor-reg-000      thru snp-cor-reg-999        .
           if        w-cnt-sts-imp-snp    =    spaces
                     go to acc-nok-reg-420.
      *                  *---------------------------------------------*
      *                  * Se corpo da non trattare                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo uscita '-' da testata 2 : ad    *
      *                      * impostazione testata                    *
      *                      *-----------------------------------------*
           if        w-cnt-tus-acc-te2    =    "-"
                     move  spaces         to   w-cnt-tus-acc-te2
                     go to acc-nok-reg-200.
      *                      *-----------------------------------------*
      *                      * Altrimenti ad impostazione testata 2    *
      *                      *-----------------------------------------*
           go to     acc-nok-reg-500.
       acc-nok-reg-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione titolo programma            *
      *                  *---------------------------------------------*
           perform   vis-tit-pgm-000      thru vis-tit-pgm-999        .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati chiave                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      
                                               w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati testata                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-tes
                                               w-cnt-sts-pmt-pte
                                               w-cnt-sts-vis-tes
                                               w-cnt-sts-vis-pte      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati testata 2              *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-te2
                                               w-cnt-sts-pmt-pt2
                                               w-cnt-sts-vis-te2
                                               w-cnt-sts-vis-pt2      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo 2                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-co2      
                                               w-cnt-sts-vis-co2      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo 2           *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rg2      
                                               w-cnt-sts-vis-rg2      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo 3                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-co3      
                                               w-cnt-sts-vis-co3      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo 3           *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rg3      
                                               w-cnt-sts-vis-rg3      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati piede                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-pie
                                               w-cnt-sts-pmt-ppi
                                               w-cnt-sts-vis-pie
                                               w-cnt-sts-vis-ppi      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati corpo                     *
      *                  *---------------------------------------------*
           perform   acc-cor-reg-000      thru acc-cor-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
