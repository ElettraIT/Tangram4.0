           move      w-rg2-com-rig (1)    to   l-cge-300-com-rig      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      w-rg2-dat-rif (1)    to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      w-rg2-num-rif (1)    to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      w-rg2-dar-ave (1)    to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-rg2-imp-mov (1)    to   l-cge-300-imp-mov      .
      *                  *---------------------------------------------*
      *                  * Richiamo modulo scrittura CGE               *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per scrittura singola  *
      *                  * riga movimento di CGE                       *
      *                  *---------------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione tipo operazione per prossima   *
      *                  * riga movimento di CGE                       *
      *                  *---------------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossima riga                    *
      *                  *---------------------------------------------*
           go to     wrt-mov-cge-220.
       wrt-mov-cge-300.
      *              *-------------------------------------------------*
      *              * Scrittura movimenti per le scadenze             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero protocollo              *
      *                  *---------------------------------------------*
           move      w-pie-prt-mgd (1)    to   w-wrt-mov-cge-wnp      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero scadenza iniziale       *
      *                  *---------------------------------------------*
           move      w-pie-nps-scf (1)    to   w-wrt-mov-cge-wns      .
           subtract  1                    from w-wrt-mov-cge-wns      .
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 3 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg3-ope          .
           move      1                    to   w-cat-rg3-num          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to wrt-mov-cge-999.
       wrt-mov-cge-310.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg3-ope          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to wrt-mov-cge-999.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg3                              *
      *                  *---------------------------------------------*
           move      w-cat-rg3-buf        to   w-rg3                  .
      *                  *---------------------------------------------*
      *                  * Test se esistono causale di contabilita' e  *
      *                  * sottoconto per registrazione scadenza       *
      *                  *---------------------------------------------*
           if        w-rg3-cau-rsf (1)    =    zero or
                     w-rg3-stc-rsf (1)    =    zero
                     go to wrt-mov-cge-310.
      *                  *---------------------------------------------*
      *                  * Incremento numero protocollo di contabili-  *
      *                  * ta'                                         *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-cge-wnp      .
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenza fornitore        *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-cge-wns      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per scrittura testata  *
      *                  * e prima riga movimento di CGE               *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Valori per testata registrazione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WP"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data registrazione                      *
      *                      *-----------------------------------------*
           move      w-te2-dat-mgd (1)    to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      w-wrt-mov-cge-wnp    to   l-cge-300-num-prt      .
      *                      *-----------------------------------------*
      *                      * Causale                                 *
      *                      *-----------------------------------------*
           move      w-rg3-cau-rsf (1)    to   l-cge-300-cod-cau      .
      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "N"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-sca      .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc (1)    to   l-cge-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-wrt-mov-cge-wns    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   l-cge-300-num-doc      .
      *                  *---------------------------------------------*
      *                  * Valori per prima riga registrazione : Riga  *
      *                  * fornitore                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice piano dei conti                  *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc-cge (1)
                                          to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "F"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc (1)    to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Commento in riga                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-com-rig      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc (1)    to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      w-tes-num-doc (1)    to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "A"            to   l-cge-300-dar-ave
           else      move  "D"            to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-rg3-imp-scf (1)    to   l-cge-300-imp-mov      .
      *                  *---------------------------------------------*
      *                  * Richiamo modulo scrittura CGE               *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per scrittura singola  *
      *                  * riga movimento di CGE                       *
      *                  *---------------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga di contropartita al fornito- *
      *                  * re                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Codice piano dei conti                  *
      *                      *-----------------------------------------*
           move      w-rg3-stc-rsf (1)    to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Commento in riga                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-com-rig      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "D"            to   l-cge-300-dar-ave
           else      move  "A"            to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-rg3-imp-scf (1)    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Richiamo modulo scrittura CGE           *
      *                      *-----------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione catena scadenze    *
      *                      *-----------------------------------------*
           go to     wrt-mov-cge-310.
       wrt-mov-cge-999.
           exit.

      *    *===========================================================*
      *    * Annullamento del movimento di contabilita' generale che   *
      *    * che era stato a suo tempo generato a fronte del movimento *
      *    * di scadenze fornitori di registrazione fattura fornitore  *
      *    *-----------------------------------------------------------*
       del-mov-cge-000.
      *              *-------------------------------------------------*
      *              * Annullamento registrazione contabile fattura    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data registrazione o numero protocollo   *
      *                  * di CGE a zero : oltre                       *
      *                  *---------------------------------------------*
           if        w-te2-dat-mgd (2)    =    zero or
                     w-pie-prt-mgd (2)    =    zero
                     go to del-mov-cge-500.
      *                  *---------------------------------------------*
      *                  * Richiamo modulo per cancellazione movimento *
      *                  * di CGE                                      *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-te2-dat-mgd (2)    to   l-cge-300-dat-reg      .
           move      w-pie-prt-mgd (2)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       del-mov-cge-500.
      *              *-------------------------------------------------*
      *              * Annullamento registrazione contabile scadenze   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 3 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg3-ope          .
           move      1                    to   w-cat-rg3-num          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : uscita                *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to del-mov-cge-999.
       del-mov-cge-520.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg3-ope          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to del-mov-cge-999.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg3                              *
      *                  *---------------------------------------------*
           move      w-cat-rg3-buf        to   w-rg3                  .
      *                  *---------------------------------------------*
      *                  * Se data registrazione o numero protocollo   *
      *                  * di CGE a zero : a riciclo                   *
      *                  *---------------------------------------------*
           if        w-rg3-drc-rgs (2)    =    zero or
                     w-rg3-npc-rgs (2)    =    zero
                     go to del-mov-cge-580.
      *                  *---------------------------------------------*
      *                  * Richiamo modulo per cancellazione movimento *
      *                  * di CGE                                      *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-rg3-drc-rgs (2)    to   l-cge-300-dat-reg      .
           move      w-rg3-npc-rgs (2)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       del-mov-cge-580.
      *                  *---------------------------------------------*
      *                  * Riciclo per prossima cancellazione          *
      *                  *---------------------------------------------*
           go to     del-mov-cge-520.
       del-mov-cge-999.
           exit.

      *    *===========================================================*
      *    * Scrittura pareggiamento automatico acconti clienti o for- *
      *    * nitori                                                    *
      *    *-----------------------------------------------------------*
       wrt-pau-acf-000.
      *              *-------------------------------------------------*
      *              * Se nessun pareggiamento automatico effettuato : *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-co2-imp-pap (1)    =    spaces
                     go to wrt-pau-acf-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella partite           *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrt-pau-acf-ctr      .
       wrt-pau-acf-100.
           add       1                    to   w-wrt-pau-acf-ctr      .
           if        w-wrt-pau-acf-ctr    >    w-lpa-num-ele
                     go to wrt-pau-acf-999.
      *                  *---------------------------------------------*
      *                  * Se l'importo assegnato alla partita e' a    *
      *                  * zero : riciclo                              *
      *                  *---------------------------------------------*
           if        w-lpa-imp-ass
                    (w-wrt-pau-acf-ctr)   =    zero
                     go to wrt-pau-acf-100.
      *                  *---------------------------------------------*
      *                  * Se i riferimenti della partita sono uguali  *
      *                  * a quelli da forzare : riciclo               *
      *                  *---------------------------------------------*
           if        w-lpa-dat-rif
                    (w-wrt-pau-acf-ctr)   =    w-lpa-dri-doc and
                     w-lpa-num-rif
                    (w-wrt-pau-acf-ctr)   =    w-lpa-nri-doc
                     go to wrt-pau-acf-100.
      *                  *---------------------------------------------*
      *                  * Scansione delle righe di contabilita' rela- *
      *                  * tive alla partita in esame                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Start su file [mgr]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCRIF"             to   f-key                  .
           move      w-lpa-tip-arc        to   rf-mgr-tip-arc         .
           move      w-lpa-cod-arc        to   rf-mgr-cod-arc         .
           move      w-lpa-dat-rif
                    (w-wrt-pau-acf-ctr)   to   rf-mgr-dat-rif         .
           move      w-lpa-num-rif
                    (w-wrt-pau-acf-ctr)   to   rf-mgr-num-rif         .
           move      zero                 to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-pau-acf-300.
       wrt-pau-acf-200.
      *                      *-----------------------------------------*
      *                      * Ottenimento sequenziale record [mgr]    *
      *                      *-----------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'at end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-pau-acf-300.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-mgr-tip-arc       not  = w-lpa-tip-arc      or
                     rf-mgr-cod-arc       not  = w-lpa-cod-arc      or
                     rf-mgr-dat-rif       not  = w-lpa-dat-rif
                                                (w-wrt-pau-acf-ctr) or
                     rf-mgr-num-rif       not  = w-lpa-num-rif
                                                (w-wrt-pau-acf-ctr)
                     go to wrt-pau-acf-300.
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [mgr]              *
      *                      *-----------------------------------------*
           move      w-lpa-dri-doc        to   rf-mgr-dat-rif         .
           move      w-lpa-nri-doc        to   rf-mgr-num-rif         .
      *                      *-----------------------------------------*
      *                      * Update record [mgr]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Unlock record [mgr]                     *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su prossimo record [mgr]        *
      *                      *-----------------------------------------*
           go to     wrt-pau-acf-200.
       wrt-pau-acf-300.
      *              *-------------------------------------------------*
      *              * Unlock ultimo record [mgr]                      *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella partite            *
      *              *-------------------------------------------------*
           go to     wrt-pau-acf-100.
       wrt-pau-acf-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimenti di SCF                                *
      *    *-----------------------------------------------------------*
       wrt-mov-scf-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to wrt-mov-scf-900.
      *              *-------------------------------------------------*
      *              * Set del flag di registrazione contabile presen- *
      *              * te o assente                                    *
      *              *-------------------------------------------------*
           move      spaces               to   w-wrt-mov-scf-cge      .
      *                  *---------------------------------------------*
      *                  * Se si e' in modifica di una registrazione   *
      *                  * che non aveva generato nessun movimento     *
      *                  * contabile, non e' stato generato il movi-   *
      *                  * mento contabile e quindi non lo si deve ge- *
      *                  * nerare nemmeno per le relative scadenze     *
      *                  *---------------------------------------------*
           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-te2-dat-mgd (1)    =    zero or
                     w-pie-prt-mgd (1)    =    zero  )
                     move  "#"            to   w-wrt-mov-scf-cge      .
      *                  *---------------------------------------------*
      *                  * Se registrazione contabile da non eseguire, *
      *                  * set del flag                                *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     move  "#"            to   w-wrt-mov-scf-cge      .
       wrt-mov-scf-050.
      *              *-------------------------------------------------*
      *              * Trattamento record [sff]                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sff]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsff"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sff                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sff]                   *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sff-ide-dat         .
           move      s-ute                to   rf-sff-ide-ute         .
           move      s-fas                to   rf-sff-ide-fas         .
           move      w-tes-dat-reg        to   rf-sff-dtr-ftf         .
           move      w-pie-prt-scf (1)    to   rf-sff-num-ftf         .
           move      w-tes-cod-tmf-tdo    to   rf-sff-tip-ftf         .
           move      w-tes-cod-tmf-tpv    to   rf-sff-tpv-ftf         .
           move      w-tes-cod-arc (1)    to   rf-sff-cod-fnt         .
           move      w-tes-dpz-arc (1)    to   rf-sff-dpz-fnt         .
           move      w-tes-dat-doc (1)    to   rf-sff-ddo-ftf         .
           move      w-tes-num-doc (1)    to   rf-sff-ndo-ftf         .
           move      w-tes-sgl-vpf (1)    to   rf-sff-sgl-vlt         .
           move      w-tes-dec-vpf (1)    to   rf-sff-dec-vlt         .
           move      w-tes-tdc-vpf (1)    to   rf-sff-tdc-vlt         .
           move      w-tes-cdc-vpf (1)    to   rf-sff-cdc-ftf         .
           move      w-tes-iiv-doc (1)    to   rf-sff-iiv-ftf         .
           move      w-tes-imp-doc (1)    to   rf-sff-imp-ftf         .
