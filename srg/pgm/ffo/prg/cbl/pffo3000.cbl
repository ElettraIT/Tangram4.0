      *                      * Codice e descrizione forma di pagamento *
      *                      *-----------------------------------------*
           move      rf-dcf-cod-fop       to   w-tes-cod-fop (1)      .
           move      w-tes-cod-fop (1)    to   w-let-arc-yfp-cod      .
           perform   let-arc-yfp-000      thru let-arc-yfp-999        .
           move      w-let-arc-yfp-des    to   w-tes-cod-fop-des (1)  .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione categoria spese    *
      *                      * incasso                                 *
      *                      *-----------------------------------------*
           move      rf-dcf-add-spi       to   w-tes-add-spi (1)      .
           move      w-tes-add-spi (1)    to   w-let-arc-yin-cod      .
           move      00                   to   w-let-arc-yin-tpg      .
           perform   let-arc-yin-000      thru let-arc-yin-999        .
           move      w-let-arc-yin-des    to   w-tes-add-spi-des (1)  .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione categoria spese    *
      *                      * bollo                                   *
      *                      *-----------------------------------------*
           move      rf-dcf-add-spb       to   w-tes-add-spb (1)      .
           move      w-tes-add-spb (1)    to   w-let-arc-ybo-cod      .
           move      00                   to   w-let-arc-ybo-tpg      .
           perform   let-arc-ybo-000      thru let-arc-ybo-999        .
           move      w-let-arc-ybo-des    to   w-tes-add-spb-des (1)  .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca di appoggio per il  *
      *                      * documento                               *
      *                      *-----------------------------------------*
           move      rf-dcf-nos-ban       to   w-tes-nos-ban (1)      .
       det-vlt-dcf-100.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice e descrizione nostra banca di appog- *
      *                  * gio associati al fornitore                  *
      *                  *---------------------------------------------*
           move      rf-dcf-nos-ban       to   w-tes-nsb-aaf (1)      .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione nostra banca di appog- *
      *                  * gio per il documento                        *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione ABI del fornitore      *
      *                  *---------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-fnt (1)      .
           move      w-tes-abi-fnt (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-fnt-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione CAB del fornitore      *
      *                  *---------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-fnt (1)      .
           move      w-tes-abi-fnt (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-fnt (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-fnt-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c appoggio del fornitore                  *
      *                  *---------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-cca-fnt (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale del fornitore                   *
      *                  *---------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-fnt (1)      .
      *                  *---------------------------------------------*
      *                  * Modalita' di calcolo importo                *
      *                  *---------------------------------------------*
           move      rf-dcf-tip-mci       to   w-tes-tip-mci (1)      .
      *                  *---------------------------------------------*
      *                  * Id trasmittente SDI                         *
      *                  *---------------------------------------------*
           move      rf-dcf-num-fax       to   w-tes-cod-arc-ids (1)  .
      *                  *---------------------------------------------*
      *                  * Codici CIN                                  *
      *                  *---------------------------------------------*
           move      rf-dcf-cin-ita       to   w-tes-cod-arc-cin (1)  .
           move      rf-dcf-cin-eur       to   w-tes-cod-arc-ceu (1)  .
       det-vlt-dcf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuale sconto in chiusura             *
      *    *                                                           *
      *    * N.B.: La determinazione dello sconto in chiusura segue la *
      *    *       seguente scaletta di prevalenza:                    *
      *    *       - Quello contenuto direttamente in [dcf]            *
      *    *-----------------------------------------------------------*
       det-per-scc-000.
      *              *-------------------------------------------------*
      *              * Se percentuale di sconto in chiusura associata  *
      *              * al fornitore non e' a zero, questa prevale su   *
      *              * altre forme di determinazione                   *
      *              *-------------------------------------------------*
           if        w-tes-psc-aaf (1)    =    zero 
                     go to det-per-scc-100.
           move      w-tes-psc-aaf (1)    to   w-te2-per-scc (1)      .
           go to     det-per-scc-999.
       det-per-scc-100.
      *              *-------------------------------------------------*
      *              * A questo punto nessuno dei possibili tipi di de-*
      *              * terminazione si ' verificato, per cui non resta *
      *              * che uscire                                      *
      *              *-------------------------------------------------*
           go to     det-per-scc-999.
       det-per-scc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione funzionamento spese in fattura             *
      *    *-----------------------------------------------------------*
       det-fun-spe-000.
      *              *-------------------------------------------------*
      *              * Test su tipo funzionamento                      *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-fun-spe-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella personalizzazioni *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-fun-spe-ctr      .
       det-fun-spe-100.
           add       1                    to   w-det-fun-spe-ctr      .
           if        w-det-fun-spe-ctr    >    w-prs-spe-fat-nst
                     go to det-fun-spe-999.
      *              *-------------------------------------------------*
      *              * Preparazione indice per tabella                 *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-fun-spe-ctr)   to   w-det-fun-spe-inx      .
      *              *-------------------------------------------------*
      *              * Si/No addebito                                  *
      *              *-------------------------------------------------*
           if        rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    zero or
                     rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    01
                     move  0              to   w-te2-spe-snx
                                              (1, w-det-fun-spe-inx)
           else      move  1              to   w-te2-spe-snx
                                              (1, w-det-fun-spe-inx)  .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo funzionamento   *
      *              * derivato dalle personalizzazioni                *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    01
                     go to det-fun-spe-110
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    02
                     go to det-fun-spe-120
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    03
                     go to det-fun-spe-130
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    04
                     go to det-fun-spe-140
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    05
                     go to det-fun-spe-150.
       det-fun-spe-110.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : % fissa                    *
      *              *-------------------------------------------------*
           move      1                    to   w-te2-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-per
                    (w-det-fun-spe-ctr)   to   w-te2-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibl
                    (w-det-fun-spe-ctr)   to   w-te2-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibt
                    (w-det-fun-spe-ctr)   to   w-te2-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-120.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : % variabile                *
      *              *-------------------------------------------------*
           move      2                    to   w-te2-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      rf-dcf-per-spe
                    (w-det-fun-spe-inx)   to   w-te2-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibl
                    (w-det-fun-spe-ctr)   to   w-te2-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibt
                    (w-det-fun-spe-ctr)   to   w-te2-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-130.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : importo fisso              *
      *              *-------------------------------------------------*
           move      3                    to   w-te2-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      spaces               to   w-te2-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-imp
                    (w-det-fun-spe-ctr)   to   w-te2-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-140.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : importo variabile          *
      *              *-------------------------------------------------*
           move      4                    to   w-te2-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      spaces               to   w-te2-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-te2-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           move      rf-dcf-imp-spe
                    (w-det-fun-spe-inx)   to   w-te2-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-150.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : secondo [dcf]              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo funziona-   *
      *                  * mento espresso in [dcf]                     *
      *                  *---------------------------------------------*
           if        rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    03
                     go to det-fun-spe-151
           else if   rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    04
                     go to det-fun-spe-152.
       det-fun-spe-151.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento espresso in [dcf] : a %  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Come per tipo funzionamento espresso in *
      *                      * personalizzazioni : % variabile         *
      *                      *-----------------------------------------*
           go to     det-fun-spe-120.
       det-fun-spe-152.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento espresso in [dcf] : ad   *
      *                  * importo                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Come per tipo funzionamento espresso in *
      *                      * personalizzazioni : importo variabile   *
      *                      *-----------------------------------------*
           go to     det-fun-spe-140.
       det-fun-spe-200.
      *              *-------------------------------------------------*
      *              * Codice iva della spesa                          *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-civ
                    (w-det-fun-spe-ctr)   to   w-te2-spe-civ
                                              (1, w-det-fun-spe-inx)  .
      *              *-------------------------------------------------*
      *              * Contropartita della spesa                       *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-ccp
                    (w-det-fun-spe-ctr)   to   w-te2-spe-ccp
                                              (1, w-det-fun-spe-inx)  .
       det-fun-spe-300.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella personalizzazioni  *
      *              *-------------------------------------------------*
           go to     det-fun-spe-100.
       det-fun-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da inoltro pagamento*
      *    *-----------------------------------------------------------*
       det-vlt-ipg-000.
      *              *-------------------------------------------------*
      *              * Se dipendenza non esistente                     *
      *              *-------------------------------------------------*
           if        w-tes-dpz-arc (1)    not  = spaces
                     go to det-vlt-ipg-500.
       det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-fnt (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-fnt-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-fnt (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-fnt-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-fnt (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-fnt (1)    to   w-tes-ccp-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-500.
      *              *-------------------------------------------------*
      *              * Se dipendenza esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inoltro pagamento alla sede o alla sede  *
      *                  * legale : valori derivati da [dcf] principale*
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    01 or
                     w-tes-inl-pgt (1)    =    02
                     go to det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-dpz (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-dpz-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-dpz (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-dpz-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-dpz (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-dpz (1)    to   w-tes-ccp-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione se presenti dipendenze per il fornitore    *
      *    * commerciale                                               *
      *    *-----------------------------------------------------------*
       det-snd-dcf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esito                   *
      *              *-------------------------------------------------*
           move      "N"                  to   w-det-snd-dcf-snx      .
      *              *-------------------------------------------------*
      *              * Normalizzazione codice dipendenza unica         *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-snd-dcf-dpz      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-snd-dcf-ctr      .
      *              *-------------------------------------------------*
      *              * Start su file [dcf]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-det-snd-dcf-fnt    to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Se Start errata : uscita con flag a 'no'        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snd-dcf-999.
       det-snd-dcf-100.
      *              *-------------------------------------------------*
      *              * Next su [dcf]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Se 'at end' : a test finale                     *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snd-dcf-800.
      *              *-------------------------------------------------*
      *              * Max su [dcf], se non superato : a test finale   *
      *              *-------------------------------------------------*
           if        rf-dcf-cod-fnt       not  = w-det-snd-dcf-fnt
                     go to det-snd-dcf-800.
       det-snd-dcf-200.
      *              *-------------------------------------------------*
      *              * Test sul codice dipendenza                      *
      *              *-------------------------------------------------*
           if        rf-dcf-dpz-fnt       =    spaces
                     go to det-snd-dcf-100.
       det-snd-dcf-300.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-snd-dcf-ctr      .
       det-snd-dcf-300.
      *              *-------------------------------------------------*
      *              * Bufferizzazione del primo codice dipendenza     *
      *              *-------------------------------------------------*
           if        w-det-snd-dcf-ctr    >    1
                     go to det-snd-dcf-500.
           move      rf-dcf-dpz-fnt       to   w-det-snd-dcf-dpz      .
       det-snd-dcf-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record [dcf] successivo               *
      *              *-------------------------------------------------*
           go to     det-snd-dcf-100.
       det-snd-dcf-800.
      *              *-------------------------------------------------*
      *              * Determinazione finale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se durante la ricerca e' stato trovato un   *
      *                  * numero di dipendenze superiore a zero si    *
      *                  * esce con il flag di presenza a 'S'          *
      *                  *---------------------------------------------*
           if        w-det-snd-dcf-ctr    >    zero
                     go to det-snd-dcf-900
           else      go to det-snd-dcf-999.
       det-snd-dcf-900.
      *              *-------------------------------------------------*
      *              * Uscita per dipendenze trovate                   *
      *              *-------------------------------------------------*
           move      "S"                  to   w-det-snd-dcf-snx      .
       det-snd-dcf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da record [dcf]     *
      *    * relativo alla dipendenza del fornitore                    *
      *    *-----------------------------------------------------------*
       det-vlt-dcd-000.
      *              *-------------------------------------------------*
      *              * Se codice dipendenza a spazi : uscita           *
      *              *-------------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     go to det-vlt-dcd-999.
      *              *-------------------------------------------------*
      *              * Codice e descrizione ABI dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * Codice e descrizione CAB dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-dpz (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * C/c bancario della dipendenza                   *
      *              *-------------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-cca-dpz (1)      .
      *              *-------------------------------------------------*
      *              * C/c postale della dipendenza                    *
      *              *-------------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-dpz (1)      .
       det-vlt-dcd-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata dipendenti dalla forma di   *
      *    * pagamento                                                 *
      *    *-----------------------------------------------------------*
       det-vlt-yfp-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre solo in tipo funzionamento : *
      *              * 'inserimento'                                   *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-vlt-yfp-050.
       det-vlt-yfp-050.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione sconto pagamento associato  *
      *                  * alla forma di pagamento                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * alle impostazioni dei campi relativi ai pa- *
      *                  * pagamenti                                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-app-pgf (1)      .
           move      spaces               to   w-tes-snx-spm (1)      .
           move      spaces               to   w-tes-snx-qaf (1)      .
           move      spaces               to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata associati al-*
      *                  * la forma pagamento                          *
      *                  *---------------------------------------------*
           perform   nor-cpg-ass-000      thru nor-cpg-ass-999        .
      *                  *---------------------------------------------*
      *                  * Se forma di pagamento a zero : uscita       *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to det-vlt-yfp-999.
      *                  *---------------------------------------------*
      *                  * Sconto pagamento associato alla forma di    *
      *                  * pagamento                                   *
      *                  *---------------------------------------------*
           move      rf-yfp-sco-fat       to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Ciclo per tre codici pagamento possibili    *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vlt-yfp-ctr      .
       det-vlt-yfp-100.
           add       1                    to   w-det-vlt-yfp-ctr      .
           if        w-det-vlt-yfp-ctr    >    3
                     go to det-vlt-yfp-999.
           if        rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   =    zero
                     go to det-vlt-yfp-100.
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [yfp]  *
      *                      *-----------------------------------------*
           move      rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   to   w-tes-cod-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   to   w-tes-tip-amm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-per-toi
                    (w-det-vlt-yfp-ctr)   to   w-tes-per-toi
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   to   w-tes-dim-act
                                              (1, w-det-vlt-yfp-ctr)  .
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [zpg]  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record [zpg]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zpg]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODPAG"             to   f-key                  .
           move      w-tes-cod-pag
                    (1, w-det-vlt-yfp-ctr)
                                          to   rf-zpg-cod-pag         .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
           move      rf-zpg-tip-pag       to   w-tes-tip-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-num-sca       to   w-tes-num-sca
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dec-prs       to   w-tes-dec-prs
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dap-mes       to   w-tes-dap-mes
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dap-gio       to   w-tes-dap-gio
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-ggg-int       to   w-tes-ggg-int
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-tip-scm       to   w-tes-tip-scm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-gio-scm       to   w-tes-gio-scm
                                              (1, w-det-vlt-yfp-ctr)  .
       det-vlt-yfp-200.
      *                  *---------------------------------------------*
      *                  * Valori testata di appoggio alle successive  *
      *                  * impostazioni                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo appoggio per pagamento             *
      *                      *-----------------------------------------*
           if        w-tes-app-pgf (1)    not  = zero
                     go to det-vlt-yfp-220.
           if        rf-zpg-tip-pag       =    02 or
                     rf-zpg-tip-pag       =    03 or
                     rf-zpg-tip-pag       =    04 or
                     rf-zpg-tip-pag       =    05 or
                     rf-zpg-tip-pag       =    06 or
                     rf-zpg-tip-pag       =    09 or
                     rf-zpg-tip-pag       =    10 or
                     rf-zpg-tip-pag       =    11
                     move  01             to   w-tes-app-pgf (1)
           else if  (rf-zpg-tip-pag       =    07  ) and
                    (w-tes-cod-tmf-tpv    =    01 or
                     w-tes-cod-tmf-tpv    =    04  )
                     move  02             to   w-tes-app-pgf (1)
           else if   rf-zpg-tip-pag       =    08
                     move  03             to   w-tes-app-pgf (1)
           else if  (rf-zpg-tip-pag       =    07  ) and
                    (w-tes-cod-tmf-tpv    =    02 or
                     w-tes-cod-tmf-tpv    =    03  )
                     move  04             to   w-tes-app-pgf (1)      .
       det-vlt-yfp-220.
      *                      *-----------------------------------------*
      *                      * Si/no data scadenza pagamento manuale   *
      *                      *-----------------------------------------*
           if        rf-zpg-dec-prs       =    01
                     move  "S"            to   w-tes-snx-spm (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione quota a forfait      *
      *                      *-----------------------------------------*
           if        rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    06 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    07 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    08 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    09
                     move  "S"            to   w-tes-snx-qaf (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione acconto              *
      *                      *-----------------------------------------*
           if        rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   =    02
                     move  "S"            to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-yfp-100.
       det-vlt-yfp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata relativi alle spese incasso *
      *    *-----------------------------------------------------------*
       det-vlt-yin-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella spese incasso           *
      *              *-------------------------------------------------*
           perform   nor-tbl-spi-000      thru nor-tbl-spi-999        .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-yin-c01      .
           move      zero                 to   w-det-vlt-yin-c02      .
           move      zero                 to   w-det-vlt-yin-c03      .
      *              *-------------------------------------------------*
      *              * Se codice spesa incasso non esistente : uscita  *
      *              *-------------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to det-vlt-yin-900.
      *              *-------------------------------------------------*
      *              * Ciclo per tre codici pagamento possibili        *
      *              *-------------------------------------------------*
       det-vlt-yin-100.
           add       1                    to   w-det-vlt-yin-c01      .
           if        w-det-vlt-yin-c01    >    3
                     go to det-vlt-yin-900.
           if        w-tes-cod-pag
                    (1, w-det-vlt-yin-c01)
                                          =    zero
                     go to det-vlt-yin-100.
      *              *-------------------------------------------------*
      *              * Ciclo su elementi tabella gia' presenti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-yin-c02      .
       det-vlt-yin-200.
           add       1                    to   w-det-vlt-yin-c02      .
           if        w-det-vlt-yin-c02    >    w-det-vlt-yin-c03
                     go to det-vlt-yin-300.
           if        w-tes-tpg-spi
                    (1, w-det-vlt-yin-c02)
                                          =    w-tes-tip-pag
                                              (1, w-det-vlt-yin-c01)
                     go to det-vlt-yin-100.
       det-vlt-yin-300.
      *                  *---------------------------------------------*
      *                  * Lettura record [yin]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPI    "         to   f-key                  .
           move      w-tes-add-spi (1)    to   rf-yin-cod-spi         .
           move      w-tes-tip-pag
                    (1, w-det-vlt-yin-c01)
                                          to   rf-yin-tip-pag         .
           move      "pgm/dcf/fls/ioc/obj/iofyin"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yin                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vlt-yin-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi in tabella    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vlt-yin-c03      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori                      *
      *                  *---------------------------------------------*
           move      rf-yin-tip-pag       to   w-tes-tpg-spi
                                              (1, w-det-vlt-yin-c03)  .
           move      rf-yin-tfu-spi       to   w-tes-tfu-spi
                                              (1, w-det-vlt-yin-c03)  .
           move      rf-yin-amm-spi       to   w-tes-amm-spi
                                              (1, w-det-vlt-yin-c03)  .
           move      rf-yin-per-spi       to   w-tes-per-spi
                                              (1, w-det-vlt-yin-c03)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-yin-100.
       det-vlt-yin-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero elementi in tabella spe- *
      *              * se incasso                                      *
      *              *-------------------------------------------------*
           move      w-det-vlt-yin-c03    to   w-tes-eit-spi (1)      .
       det-vlt-yin-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata relativi alle spese bollo   *
      *    *-----------------------------------------------------------*
       det-vlt-ybo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella spese bollo             *
      *              *-------------------------------------------------*
           perform   nor-tbl-spb-000      thru nor-tbl-spb-999        .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-ybo-c01      .
           move      zero                 to   w-det-vlt-ybo-c02      .
           move      zero                 to   w-det-vlt-ybo-c03      .
      *              *-------------------------------------------------*
      *              * Se codice spesa bollo non esistente : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-add-spb (1)    =    spaces
                     go to det-vlt-ybo-900.
      *              *-------------------------------------------------*
      *              * Ciclo per tre codici pagamento possibili        *
      *              *-------------------------------------------------*
       det-vlt-ybo-100.
           add       1                    to   w-det-vlt-ybo-c01      .
           if        w-det-vlt-ybo-c01    >    3
                     go to det-vlt-ybo-900.
           if        w-tes-cod-pag
                    (1, w-det-vlt-ybo-c01)
                                          =    zero
                     go to det-vlt-ybo-100.
      *              *-------------------------------------------------*
      *              * Ciclo su elementi tabella gia' presenti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-ybo-c02      .
       det-vlt-ybo-200.
           add       1                    to   w-det-vlt-ybo-c02      .
           if        w-det-vlt-ybo-c02    >    w-det-vlt-ybo-c03
                     go to det-vlt-ybo-300.
           if        w-tes-tpg-spb
                    (1, w-det-vlt-ybo-c02)
                                          =    w-tes-tip-pag
                                              (1, w-det-vlt-ybo-c01)
                     go to det-vlt-ybo-100.
       det-vlt-ybo-300.
      *                  *---------------------------------------------*
      *                  * Lettura record [ybo]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPB    "         to   f-key                  .
           move      w-tes-add-spb (1)    to   rf-ybo-cod-spb         .
           move      w-tes-tip-pag
                    (1, w-det-vlt-ybo-c01)
                                          to   rf-ybo-tip-pag         .
           move      "pgm/dcf/fls/ioc/obj/iofybo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ybo                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vlt-ybo-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi in tabella    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vlt-ybo-c03      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori                      *
      *                  *---------------------------------------------*
           move      rf-ybo-tip-pag       to   w-tes-tpg-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-tau-spb       to   w-tes-tau-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-per-spb       to   w-tes-per-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      zero                 to   w-det-vlt-ybo-c04      .
       det-vlt-ybo-320.
           add       1                    to   w-det-vlt-ybo-c04      .
           if        w-det-vlt-ybo-c04    >    10
                     go to det-vlt-ybo-340.
           move      rf-ybo-tbe-scg
                    (w-det-vlt-ybo-c04)   to   w-tes-tbe-scg
                                              (1,
                                               w-det-vlt-ybo-c03,
                                               w-det-vlt-ybo-c04)     .
           move      rf-ybo-tbe-asc
                    (w-det-vlt-ybo-c04)   to   w-tes-tbe-asc
                                              (1,
                                               w-det-vlt-ybo-c03,
                                               w-det-vlt-ybo-c04)     .
           move      rf-ybo-tbe-psc
                    (w-det-vlt-ybo-c04)   to   w-tes-tbe-psc
                                              (1,
                                               w-det-vlt-ybo-c03,
                                               w-det-vlt-ybo-c04)     .
           go to     det-vlt-ybo-320.
       det-vlt-ybo-340.
           move      rf-ybo-tet-spb       to   w-tes-tet-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-min-spb       to   w-tes-min-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-max-spb       to   w-tes-max-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-tar-spb       to   w-tes-tar-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-var-spb       to   w-tes-var-spb
                                              (1, w-det-vlt-ybo-c03)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-ybo-100.
       det-vlt-ybo-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero elementi in tabella spe- *
      *              * se incasso                                      *
      *              *-------------------------------------------------*
           move      w-det-vlt-ybo-c03    to   w-tes-eit-spb (1)      .
       det-vlt-ybo-999.
           exit.

      *    *===========================================================*
      *    * Determinazione flag di estensione alla descrizione        *
      *    *-----------------------------------------------------------*
       det-des-ext-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe occupate            *
      *              *-------------------------------------------------*
           move      11                   to   w-det-des-ext-ctr      .
       det-des-ext-100.
           subtract  1                    from w-det-des-ext-ctr      .
           if        w-det-des-ext-ctr    =    zero
                     go to det-des-ext-200.
           if        w-rig-der-rig
                    (1, w-det-des-ext-ctr)
                                          =    spaces
                     go to det-des-ext-100.
       det-des-ext-200.
      *              *-------------------------------------------------*
      *              * Se numero righe non superiore a 1               *
      *              *-------------------------------------------------*
           if        w-det-des-ext-ctr    not  > 1
                     move  0              to   w-rig-des-ext (1)
                     go to det-des-ext-999.
      *              *-------------------------------------------------*
      *              * Se numero righe maggiore di 1                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se descrizione impostata diversa da descri- *
      *                  * zione prodotto originale                    *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = w-rig-des-por (1)
                     move  1              to   w-rig-des-ext (1)
                     go to det-des-ext-999.
      *                  *---------------------------------------------*
      *                  * Se descrizione impostata uguale a descri-   *
      *                  * zione prodotto                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A seconda che esista o meno un formato  *
      *                      * di acquisizione                         *
      *                      *-----------------------------------------*
           if        w-rig-snx-dep (1)    =    "S"
                     move  3              to   w-rig-des-ext (1)
           else      move  2              to   w-rig-des-ext (1)      .
       det-des-ext-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo di acquisto                         *
      *    *-----------------------------------------------------------*
       det-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Solo se riga di tipo 'new'                      *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to det-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di prezzo associato al forni-  *
      *              * tore/prodotto                                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-rig-per-scr-ffp (1)  .
       det-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione link-area                      *
      *                  *---------------------------------------------*
           move      "PA"                 to   d-prz-acq-tip-ope      .
           move      w-tes-cod-arc (1)    to   d-prz-acq-cod-fnt      .
           move      w-rig-tip-mag (1)    to   d-prz-acq-tip-mag      .
           move      w-rig-num-mag (1)    to   d-prz-acq-num-mag      .
           move      w-rig-fda-pif (1)    to   d-prz-acq-fda-pif      .
           move      w-let-arc-dcp-plb    to   d-prz-acq-prz-lsb      .
           move      w-let-arc-dcp-dlb    to   d-prz-acq-dec-vlb      .
           move      w-rig-dec-prz (1)    to   d-prz-acq-dec-prz      .
           move      w-det-prz-qta-att    to   d-prz-acq-qta-rif      .
      *
           if        w-tes-dat-doc (1)    =    zero
                     move  w-tes-dat-reg  to   d-prz-acq-dat-rfp
           else      move  w-tes-dat-doc (1)
                                          to   d-prz-acq-dat-rfp      .
      *                  *---------------------------------------------*
      *                  * Richiamo del sottoprogramma                 *
      *                  *---------------------------------------------*
           perform   det-prz-acq-cll-000  thru det-prz-acq-cll-999    .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori determinati           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo di acquisto                      *
      *                      *-----------------------------------------*
           move      d-prz-acq-prz-acq    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto                   *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-det (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-prz-acq-psr-det (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-prz-acq-psr-det (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-prz-acq-psr-det (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-prz-acq-psr-det (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Segnale di percentuali sconto determi-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-snx    to   w-rig-per-scr-ffp (1)  .
       det-prz-acq-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prz-acq-999.
       det-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Determinazione coefficiente di cambio effettivo per lega- *
      *    * me valutario                                              *
      *    *-----------------------------------------------------------*
       det-cdc-vpl-000.
      *              *-------------------------------------------------*
      *              * Controllo esistenza parametri                   *
      *              *-------------------------------------------------*
           if        w-rig-prz-acq (1)    =    zero   or
                     w-rig-sgl-vpl (1)    =    spaces or
                     w-rig-prz-vpl (1)    =    zero   or
                     w-rig-ccr-vpl (1)    =    zero
                     go to det-cdc-vpl-999.
           if        w-rig-plm-vpl (1)    =    zero and
                     w-rig-tlm-vpl (1)    not  = spaces
                     go to det-cdc-vpl-999.
           if       (w-rig-plm-vpl (1)    not  = zero  ) and
                    (w-rig-tlm-vpl (1)    not  = "T" and
                     w-rig-tlm-vpl (1)    not  = "F" and
                     w-rig-tlm-vpl (1)    not  = "M"   )
                     go to det-cdc-vpl-999.
      *              *-------------------------------------------------*
      *              * Coefficiente di cambio effettivo pari a quello  *
      *              * di riferimento                                  *
      *              *-------------------------------------------------*
           move      w-rig-ccr-vpl (1)    to   w-rig-cdc-vpl (1)      .
      *              *-------------------------------------------------*
      *              * Se prezzo di riferimento pari a prezzo effetti- *
      *              * vo : uscita                                     *
      *              *-------------------------------------------------*
           if        w-rig-prz-acq (1)    =    w-rig-prz-vpl (1)
                     go to det-cdc-vpl-999.
      *              *-------------------------------------------------*
      *              * Determinazione valore scostamento rispetto al   *
      *              * cambio di riferimento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che esista o meno la   *
      *                  * percentuale di tolleranza                   *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    =    zero
                     go to det-cdc-vpl-052
           else      go to det-cdc-vpl-054.
       det-cdc-vpl-052.
      *                  *---------------------------------------------*
      *                  * Se percentuale di tolleranza a zero         *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-cdc-vpl-wps      .
           go to     det-cdc-vpl-060.
       det-cdc-vpl-054.
      *                  *---------------------------------------------*
      *                  * Se percentuale di tolleranza esistente      *
      *                  *---------------------------------------------*
           multiply  w-rig-plm-vpl (1)    by   w-rig-ccr-vpl (1)
                                        giving w-det-cdc-vpl-wps      .
           divide    100                  into w-det-cdc-vpl-wps      .
           go to     det-cdc-vpl-060.
       det-cdc-vpl-060.
      *              *-------------------------------------------------*
      *              * Determinazione cambio per confronto             *
      *              *-------------------------------------------------*
           if        w-rig-prz-acq (1)    >    w-rig-prz-vpl (1)
                     add      w-det-cdc-vpl-wps
                                          to   w-rig-ccr-vpl (1)
                                        giving w-det-cdc-vpl-wpc
           else      subtract w-det-cdc-vpl-wps
                                          from w-rig-ccr-vpl (1)
                                        giving w-det-cdc-vpl-wpc      .
       det-cdc-vpl-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo limitazione     *
      *              *-------------------------------------------------*
           if        w-rig-tlm-vpl (1)    =    "T"
                     go to det-cdc-vpl-200
           else if   w-rig-tlm-vpl (1)    =    "F"
                     go to det-cdc-vpl-400
           else if   w-rig-tlm-vpl (1)    =    "M"
                     go to det-cdc-vpl-600.
       det-cdc-vpl-200.
      *              *=================================================*
      *              * Tipo limitazione : Tolleranza                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di cambio   *
      *                  *---------------------------------------------*
           if        w-rig-tdc-vpl (1)    =    "/"
                     go to det-cdc-vpl-220
           else      go to det-cdc-vpl-240.
       det-cdc-vpl-220.
      *                  *---------------------------------------------*
      *                  * Se divisore                                 *
      *                  *---------------------------------------------*
           multiply  w-rig-prz-acq (1)    by   w-rig-ccr-vpl (1)
                                        giving w-det-cdc-vpl-wpz      .
           divide    w-rig-prz-vpl (1)    into w-det-cdc-vpl-wpz
                                               rounded                .
           move      w-det-cdc-vpl-wpz    to   w-rig-cdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cdc-vpl-999.
       det-cdc-vpl-240.
      *                  *---------------------------------------------*
      *                  * Se moltiplicatore                           *
      *                  *---------------------------------------------*
           divide    w-rig-ccr-vpl (1)    into w-rig-prz-acq (1)
                                        giving w-det-cdc-vpl-wpz      .
           divide    w-det-cdc-vpl-wpz    into w-rig-prz-vpl (1)
                                        giving w-rig-cdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cdc-vpl-999.
       det-cdc-vpl-400.
      *              *=================================================*
      *              * Tipo limitazione : Franchigia                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di cambio   *
      *                  *---------------------------------------------*
           if        w-rig-tdc-vpl (1)    =    "/"
                     go to det-cdc-vpl-420
           else      go to det-cdc-vpl-440.
       det-cdc-vpl-420.
      *                  *---------------------------------------------*
      *                  * Se divisore                                 *
      *                  *---------------------------------------------*
           multiply  w-rig-prz-acq (1)    by   w-det-cdc-vpl-wpc
                                        giving w-det-cdc-vpl-wpz      .
           divide    w-rig-prz-vpl (1)    into w-det-cdc-vpl-wpz
                                               rounded                .
           move      w-det-cdc-vpl-wpz    to   w-rig-cdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cdc-vpl-999.
       det-cdc-vpl-440.
      *                  *---------------------------------------------*
      *                  * Se moltiplicatore                           *
      *                  *---------------------------------------------*
           divide    w-det-cdc-vpl-wpc    into w-rig-prz-acq (1)
                                        giving w-det-cdc-vpl-wpz      .
           divide    w-det-cdc-vpl-wpz    into w-rig-prz-vpl (1)
                                        giving w-rig-cdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-cdc-vpl-999.
       det-cdc-vpl-600.
      *              *=================================================*
      *              * Tipo limitazione : Tetto massimo                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Come per tipo limitazione : Tolleranza      *
      *                  *---------------------------------------------*
           go to     det-cdc-vpl-200.
       det-cdc-vpl-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuali di sconto in riga              *
      *    *-----------------------------------------------------------*
       det-per-scr-000.
      *              *-------------------------------------------------*
      *              * Solo se riga di tipo 'new'                      *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to det-per-scr-999.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento sconti in riga 001           *
      *              *-------------------------------------------------*
           perform   det-psr-001-000      thru det-psr-001-999        .
           go to     det-per-scr-999.
       det-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuali di sconto in riga tipo 001     *
      *    *                                                           *
      *    * N.B.: La determinazione degli sconti in riga segue la se- *
      *    *       guente scaletta di prevalenza:                      *
      *    *       - Quelli diretti dall'incrocio Fornitore/Prodotto   *
      *    *         contenuti nel record [aaq]                        *
      *    *       - Quelli contenuti direttamente in [dcf]            *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-psr-001-000.
      *              *-------------------------------------------------*
      *              * Se gli sconti sono associati alla combinazione  *
      *              * fornitore/prodotto, questi sono gia' stati memo-*
      *              * rizzati e quindi si esce                        *
      *              *-------------------------------------------------*
           if        w-rig-per-scr-ffp (1)
                                          not  = spaces
                     go to det-psr-001-999.
       det-psr-001-200.
      *              *-------------------------------------------------*
      *              * Test se sconti diretti da record [dcf]          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se percentuali di sconto in riga associate  *
      *                  * al fornitore sono tutte a zero : oltre      *
      *                  *---------------------------------------------*
           if        w-tes-psr-aaf (1, 1) =    zero and
                     w-tes-psr-aaf (1, 2) =    zero and
                     w-tes-psr-aaf (1, 3) =    zero and
                     w-tes-psr-aaf (1, 4) =    zero and
                     w-tes-psr-aaf (1, 5) =    zero
                     go to det-psr-001-700.
      *                  *---------------------------------------------*
      *                  * Altrimenti si memorizzano                   *
      *                  *---------------------------------------------*
           move      w-tes-psr-aaf (1, 1) to   w-rig-per-scr (1, 1)   .
           move      w-tes-psr-aaf (1, 2) to   w-rig-per-scr (1, 2)   .
           move      w-tes-psr-aaf (1, 3) to   w-rig-per-scr (1, 3)   .
           move      w-tes-psr-aaf (1, 4) to   w-rig-per-scr (1, 4)   .
           move      w-tes-psr-aaf (1, 5) to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-psr-001-999.
       det-psr-001-700.
      *              *-------------------------------------------------*
      *              * A questo punto nessuno dei possibili tipi di de-*
      *              * terminazione si ' verificato, per cui non resta *
      *              * che normalizzare le percentuali di sconto in ri-*
      *              * ga ed uscire                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
           go to     det-psr-001-999.
       det-psr-001-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' secondaria per l'acquisto        *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/wdetqts0.wks"                   .

      *    *===========================================================*
      *    * Determinazione importo in riga                            *
      *    *-----------------------------------------------------------*
       det-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per la determinazione    *
      *              *-------------------------------------------------*
           move      "IR"                 to   d-imp-acq-tip-ope      .
           move      w-rig-qta-fda (1)    to   d-imp-acq-qta-acq      .
           move      w-rig-prz-acq (1)    to   d-imp-acq-prz-uni      .
           move      w-rig-dec-prz (1)    to   d-imp-acq-dec-prz      .
           move      w-rig-per-scr (1, 1) to   d-imp-acq-per-scr (1)  .
           move      w-rig-per-scr (1, 2) to   d-imp-acq-per-scr (2)  .
           move      w-rig-per-scr (1, 3) to   d-imp-acq-per-scr (3)  .
           move      w-rig-per-scr (1, 4) to   d-imp-acq-per-scr (4)  .
           move      w-rig-per-scr (1, 5) to   d-imp-acq-per-scr (5)  .
           move      w-tes-tip-mci (1)    to   d-imp-acq-tip-clc      .
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           perform   det-imp-acq-cll-000  thru det-imp-acq-cll-999    .
      *              *-------------------------------------------------*
      *              * In campo di uscita                              *
      *              *-------------------------------------------------*
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
       det-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali da righe corpo prima del trattamen- *
      *    * to testata 2                                              *
      *    *-----------------------------------------------------------*
       det-tot-rig-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione totalizzatori per tipo prodotto *
      *              *-------------------------------------------------*
           perform   nor-tot-rig-000      thru nor-tot-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione totali di riepilogo documento   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valori parziali                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-trd-tot-lor          .
           move      zero                 to   w-trd-tot-nsc          .
           move      zero                 to   w-trd-tot-nsf          .
           move      zero                 to   w-trd-tot-net          .
           move      zero                 to   w-trd-tot-spe          .
           move      zero                 to   w-trd-tot-ibl          .
           move      zero                 to   w-trd-tot-imp          .
           move      zero                 to   w-trd-tot-doc          .
      *                  *---------------------------------------------*
      *                  * Castelletto iva                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-trd-iva-ele          .
           move      zero                 to   w-det-tot-rig-ctr      .
       det-tot-rig-020.
           add       1                    to   w-det-tot-rig-ctr      .
           if        w-det-tot-rig-ctr    >    12
                     go to det-tot-rig-040.
           move      zero                 to   w-trd-iva-cod
                                              (w-det-tot-rig-ctr)     .
           move      zero                 to   w-trd-iva-ibl
                                              (w-det-tot-rig-ctr)     .
           go to     det-tot-rig-020.
       det-tot-rig-040.
      *                  *---------------------------------------------*
      *                  * Castelletto contropartite                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-trd-ctp-ele          .
           move      zero                 to   w-det-tot-rig-ctr      .
       det-tot-rig-060.
           add       1                    to   w-det-tot-rig-ctr      .
           if        w-det-tot-rig-ctr    >    20
                     go to det-tot-rig-080.
           move      zero                 to   w-trd-ctp-cod
                                              (w-det-tot-rig-ctr)     .
           move      zero                 to   w-trd-ctp-imp
                                              (w-det-tot-rig-ctr)     .
           go to     det-tot-rig-060.
       det-tot-rig-080.
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : uscita                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento totalizzatori per tipo prodotto   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga P o PN                         *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to det-tot-rig-120.
           if        w-rig-tip-pro (1)    =    01
                     add  w-rig-imp-rig (1)
                                          to   w-te2-tot-rig (1, 01)
           else if   w-rig-tip-pro (1)    =    02
                     add  w-rig-imp-rig (1)
                                          to   w-te2-tot-rig (1, 02)
           else if   w-rig-tip-pro (1)    =    03
                     add  w-rig-imp-rig (1)
                                          to   w-te2-tot-rig (1, 03)
           else if   w-rig-tip-pro (1)    =    09
                     add  w-rig-imp-rig (1)
                                          to   w-te2-tot-rig (1, 09)  .
           go to     det-tot-rig-180.
       det-tot-rig-120.
      *                  *---------------------------------------------*
      *                  * Se tipo riga M o V                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to det-tot-rig-140.
           add       w-rig-imp-rig (1)    to   w-te2-tot-rig (1, 01)  .
           go to     det-tot-rig-180.
       det-tot-rig-140.
      *                  *---------------------------------------------*
      *                  * Se tipo riga A                              *
      *                  *---------------------------------------------*
           add       w-rig-imp-rig (1)    to   w-trd-tot-rta          .
       det-tot-rig-180.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-rig-civ-rig (1)    to   w-agg-cst-iva-coi      .
           move      w-rig-imp-rig (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-rig-ctp-rig (1)    to   w-agg-cst-ctp-cod      .
           move      w-rig-imp-rig (1)    to   w-agg-cst-ctp-imp      .
           move      w-rig-civ-rig (1)    to   w-agg-cst-ctp-civ      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione righe                      *
      *              *-------------------------------------------------*
           go to     det-tot-rig-100.
       det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Determinazione totale lordo                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-trd-tot-lor          .
           add       w-te2-tot-rig (1, 01)
                                          to   w-trd-tot-lor          .
           add       w-te2-tot-rig (1, 02)
                                          to   w-trd-tot-lor          .
           add       w-te2-tot-rig (1, 03)
                                          to   w-trd-tot-lor          .
           add       w-te2-tot-rig (1, 09)
                                          to   w-trd-tot-lor          .
      *              *-------------------------------------------------*
      *              * Salvataggio castelletto iva                     *
      *              *-------------------------------------------------*
           move      w-trd-iva-cst        to   w-trd-sav-csi          .
      *              *-------------------------------------------------*
      *              * Salvataggio castelletto contropartite           *
      *              *-------------------------------------------------*
           move      w-trd-ctp-cst        to   w-trd-sav-csc          .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       det-tot-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione codici iva per testata 2                   *
      *    *-----------------------------------------------------------*
       det-civ-te2-000.
      *              *-------------------------------------------------*
      *              * Se documento estero                             *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 03
                     go to det-civ-te2-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione aliquote iva                *
      *                  *---------------------------------------------*
           move      zero                 to   w-te2-civ-scc (1)      .
           move      zero                 to   w-te2-civ-scp (1)      .
           move      zero                 to   w-det-civ-te2-ctr      .
       det-civ-te2-010.
           add       1                    to   w-det-civ-te2-ctr      .
           if        w-det-civ-te2-ctr    >    w-prs-spe-fat-nst
                     go to det-civ-te2-020.
           move      w-prs-spe-fat-npt
                    (w-det-civ-te2-ctr)   to   w-det-civ-te2-inx      .
           move      zero                 to   w-te2-spe-civ
                                              (1, w-det-civ-te2-inx)  .
           go to     det-civ-te2-010.
       det-civ-te2-020.
           move      zero                 to   w-te2-civ-spi (1)      .
           move      zero                 to   w-te2-civ-spb (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-civ-te2-999.
       det-civ-te2-100.
      *              *-------------------------------------------------*
      *              * Se fornitore soggetto iva : uscita              *
      *              *-------------------------------------------------*
           if        w-tes-ass-iva (1)    =    zero
                     go to det-civ-te2-999.
      *                  *---------------------------------------------*
      *                  * Codice iva sconto in chiusura               *
      *                  *---------------------------------------------*
           move      w-te2-civ-scc (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-te2-civ-scc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva sconto pagamento                 *
      *                  *---------------------------------------------*
           move      w-te2-civ-scp (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-te2-civ-scp (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva spese in fattura                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-civ-te2-ctr      .
       det-civ-te2-110.
           add       1                    to   w-det-civ-te2-ctr      .
           if        w-det-civ-te2-ctr    >    w-prs-spe-fat-nst
                     go to det-civ-te2-120.
           move      w-prs-spe-fat-npt
                    (w-det-civ-te2-ctr)   to   w-det-civ-te2-inx      .
      *
           move      w-te2-spe-civ
                    (1, w-det-civ-te2-inx)
                                          to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-te2-spe-civ
                                              (1, w-det-civ-te2-inx)  .
           go to     det-civ-te2-110.
       det-civ-te2-120.
      *                  *---------------------------------------------*
      *                  * Codice iva spese incasso                    *
      *                  *---------------------------------------------*
           move      w-te2-civ-spi (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-te2-civ-spi (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva spese bollo                      *
      *                  *---------------------------------------------*
           move      w-te2-civ-spb (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-te2-civ-spb (1)      .
       det-civ-te2-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali riepilogo documento                 *
      *    *-----------------------------------------------------------*
       det-tri-doc-000.
      *              *-------------------------------------------------*
      *              * Ripristino castelletto iva da totali righe      *
      *              *-------------------------------------------------*
           move      w-trd-sav-csi        to   w-trd-iva-cst          .
      *              *-------------------------------------------------*
      *              * Ripristino castelletto contropartite da totali  *
      *              * righe                                           *
      *              *-------------------------------------------------*
           move      w-trd-sav-csc        to   w-trd-ctp-cst          .
      *              *-------------------------------------------------*
      *              * Determinazione totale sconto in chiusura        *
      *              *-------------------------------------------------*
           perform   det-tot-scc-000      thru det-tot-scc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale al netto dello sconto in  *
      *              * chiusura                                        *
      *              *-------------------------------------------------*
           perform   det-tot-nsc-000      thru det-tot-nsc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione importi spese                    *
      *              *-------------------------------------------------*
           perform   det-imp-spe-000      thru det-imp-spe-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale al netto delle spese in   *
      *              * fattura                                         *
      *              *-------------------------------------------------*
           perform   det-tot-nsf-000      thru det-tot-nsf-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale sconto pagamento          *
      *              *-------------------------------------------------*
           perform   det-tot-scp-000      thru det-tot-scp-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale netto                     *
      *              *-------------------------------------------------*
           perform   det-tot-net-000      thru det-tot-net-999        .
      *              *-------------------------------------------------*
      *              * Determinazione di:                              *
      *              * - totale imponibile                             *
      *              * - totale imposta                                *
      *              * - totale documento                              *
      *              * - castelletto scadenze                          *
      *              * prima del calcolo spese incasso e spese bollo   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale imponibile            *
      *                  *---------------------------------------------*
           perform   det-tot-ibl-000      thru det-tot-ibl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale imposta               *
      *                  *---------------------------------------------*
           perform   det-tot-imp-000      thru det-tot-imp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione scadenze del documento       *
      *                  *---------------------------------------------*
           perform   det-sca-doc-000      thru det-sca-doc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione spese incasso                    *
      *              *-------------------------------------------------*
           perform   det-tot-spi-000      thru det-tot-spi-999        .
      *              *-------------------------------------------------*
      *              * Determinazione di:                              *
      *              * - totale imponibile                             *
      *              * - totale imposta                                *
      *              * - totale documento                              *
      *              * - castelletto scadenze                          *
      *              * prima del calcolo spese bollo                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale imponibile            *
      *                  *---------------------------------------------*
           perform   det-tot-ibl-000      thru det-tot-ibl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale imposta               *
      *                  *---------------------------------------------*
           perform   det-tot-imp-000      thru det-tot-imp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione scadenze del documento       *
      *                  *---------------------------------------------*
           perform   det-sca-doc-000      thru det-sca-doc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione spese bollo                      *
      *              *-------------------------------------------------*
           perform   det-tot-spb-000      thru det-tot-spb-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale spese                     *
      *              *-------------------------------------------------*
           perform   det-tot-spe-000      thru det-tot-spe-999        .
      *              *-------------------------------------------------*
      *              * Determinazione di:                              *
      *              * - totale imponibile                             *
      *              * - totale imposta                                *
      *              * - totale documento                              *
      *              * dopo la determinazione di spese incasso e bollo *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale imponibile            *
      *                  *---------------------------------------------*
           perform   det-tot-ibl-000      thru det-tot-ibl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale imposta               *
      *                  *---------------------------------------------*
           perform   det-tot-imp-000      thru det-tot-imp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-tri-doc-999.
       det-tri-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto in chiusura                  *
      *    *-----------------------------------------------------------*
       det-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-te2-tot-scc (1)    =    zero and
                     w-te2-per-scc (1)    =    zero
                     go to det-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to in chiusura e' stato impostato manualmente   *
      *              *-------------------------------------------------*
           if        w-te2-per-scc (1)    =    zero
                     go to det-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-te2-per-scc (1)    by   w-trd-tot-lor
                                        giving w-te2-tot-scc (1)      .
           divide    100                  into w-te2-tot-scc (1)
                                       rounded                        .
       det-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-iva-tip      .
           move      w-te2-civ-scc (1)    to   w-agg-cst-iva-coi      .
           move      w-te2-tot-scc (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-ctp-tip      .
           move      w-te2-ccp-scc (1)    to   w-agg-cst-ctp-cod      .
           move      w-te2-tot-scc (1)    to   w-agg-cst-ctp-imp      .
           move      w-te2-civ-scc (1)    to   w-agg-cst-ctp-civ      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto dello sconto in chiusura   *
      *    *-----------------------------------------------------------*
       det-tot-nsc-000.
           subtract  w-te2-tot-scc (1)    from w-trd-tot-lor
                                        giving w-trd-tot-nsc          .
       det-tot-nsc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo spese in fattura                   *
      *    *-----------------------------------------------------------*
       det-imp-spe-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-spe-c01      .
       det-imp-spe-050.
           add       1                    to   w-det-imp-spe-c01      .
           if        w-det-imp-spe-c01    >    w-prs-spe-fat-nst
                     go to det-imp-spe-999.
      *              *-------------------------------------------------*
      *              * Determinazione indice per la spesa              *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-imp-spe-c01)   to   w-det-imp-spe-inx      .
      *              *-------------------------------------------------*
      *              * Se spesa da non addebitare : riciclo            *
      *              *-------------------------------------------------*
           if        w-te2-spe-snx
                    (1, w-det-imp-spe-inx)
                                          =    0
                     go to det-imp-spe-050.
      *              *-------------------------------------------------*
      *              * Se percentuale a zero : ad aggiornamenti        *
      *              *-------------------------------------------------*
           if        w-te2-spe-per
                    (1, w-det-imp-spe-inx)
                                          =    zero
                     go to det-imp-spe-500.
       det-imp-spe-100.
      *              *-------------------------------------------------*
      *              * Se modalita' di addebito a percentuale          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione imponibile per la spesa     *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-spe-ibl      .
      *                  *---------------------------------------------*
      *                  * Determinazione imponibile per la spesa      *
      *                  *---------------------------------------------*
           if        w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    01
                     move w-trd-tot-lor   to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    02
                     move w-trd-tot-nsc   to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    03
                     go to det-imp-spe-220
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    11
                     move w-te2-tot-rig (1, 1)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    12
                     move w-te2-tot-rig (1, 2)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    13
                     move w-te2-tot-rig (1, 3)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    14
                     move w-te2-tot-rig (1, 4)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    15
                     move w-te2-tot-rig (1, 5)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    16
                     move w-te2-tot-rig (1, 6)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    17
                     move w-te2-tot-rig (1, 7)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    18
                     move w-te2-tot-rig (1, 8)
                                          to   w-det-imp-spe-ibl
           else if   w-te2-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    19
                     move w-te2-tot-rig (1, 9)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-250.
       det-imp-spe-220.
      *                      *-----------------------------------------*
      *                      * Se risulta da una combinazione di tota- *
      *                      * li                                      *
      *                      *-----------------------------------------*
           move      w-te2-spe-ibt
                    (1, w-det-imp-spe-inx)
                                          to   w-det-imp-spe-ibt      .
           move      zero                 to   w-det-imp-spe-c02      .
       det-imp-spe-225.
           add       1                    to   w-det-imp-spe-c02      .
           if        w-det-imp-spe-c02    >    9
                     go to det-imp-spe-250.
           if        w-det-imp-spe-ibx
                    (w-det-imp-spe-c02)   not  = "S"
                     go to det-imp-spe-225.
           add       w-te2-tot-rig
                    (1, w-det-imp-spe-c02)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-225.
       det-imp-spe-250.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  w-te2-spe-per
                    (1, w-det-imp-spe-inx)
                                          by   w-det-imp-spe-ibl
                                        giving w-te2-spe-imp
                                              (1, w-det-imp-spe-inx)  .
           divide    100                  into w-te2-spe-imp
                                              (1, w-det-imp-spe-inx)
                                                            rounded   .
       det-imp-spe-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-te2-spe-civ
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-iva-coi      .
           move      w-te2-spe-imp
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-te2-spe-ccp
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-ctp-cod      .
           move      w-te2-spe-imp
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-ctp-imp      .
           move      w-te2-spe-civ
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-ctp-civ      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella                    *
      *              *-------------------------------------------------*
           go to     det-imp-spe-050.
       det-imp-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto delle spese in fattura     *
      *    *-----------------------------------------------------------*
       det-tot-nsf-000.
      *              *-------------------------------------------------*
      *              * Azzeramento work per accumulo spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-was      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-ctr      .
       det-tot-nsf-100.
           add       1                    to   w-det-tot-nsf-ctr      .
           if        w-det-tot-nsf-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-nsf-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-nsf-ctr)   to   w-det-tot-nsf-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-te2-spe-snx
                    (1, w-det-tot-nsf-inx)
                                          =    0
                     go to det-tot-nsf-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-te2-spe-imp
                    (1, w-det-tot-nsf-inx)
                                          to   w-det-tot-nsf-was      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-nsf-100.
       det-tot-nsf-200.
      *              *-------------------------------------------------*
      *              * Determinazione valore                           *
      *              *-------------------------------------------------*
           move      w-trd-tot-nsc        to    w-trd-tot-nsf         .
           add       w-det-tot-nsf-was    to    w-trd-tot-nsf         .
       det-tot-nsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto pagamento                    *
      *    *-----------------------------------------------------------*
       det-tot-scp-000.
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-te2-tot-scp (1)    =    zero and
                     w-te2-per-scp (1)    =    zero
                     go to det-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to pagamento e' stato impostato manualmente nel *
      *              * piede                                           *
      *              *-------------------------------------------------*
           if        w-te2-per-scp (1)    =    zero
                     go to det-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-te2-per-scp (1)    by   w-trd-tot-nsf
                                        giving w-te2-tot-scp (1)      .
           divide    100                  into w-te2-tot-scp (1)
                                       rounded                        .
       det-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-iva-tip      .
           move      w-te2-civ-scp (1)    to   w-agg-cst-iva-coi      .
           move      w-te2-tot-scp (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-ctp-tip      .
           move      w-te2-ccp-scp (1)    to   w-agg-cst-ctp-cod      .
           move      w-te2-tot-scp (1)    to   w-agg-cst-ctp-imp      .
           move      w-te2-civ-scp (1)    to   w-agg-cst-ctp-civ      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale netto                               *
      *    *-----------------------------------------------------------*
       det-tot-net-000.
           subtract  w-te2-tot-scc (1)    from w-trd-tot-lor
                                        giving w-trd-tot-net          .
           subtract  w-te2-tot-scp (1)    from w-trd-tot-net          .
       det-tot-net-999.
           exit.

      *    *===========================================================*
      *    * Determinazione spese incasso                              *
      *    *-----------------------------------------------------------*
       det-tot-spi-000.
      *              *-------------------------------------------------*
      *              * Se importo spesa incasso modificato in imposta- *
      *              * zione : oltre                                   *
      *              *-------------------------------------------------*
           if        w-te2-fdm-spi (1)    not  = spaces
                     go to det-tot-spi-500.
      *              *-------------------------------------------------*
      *              * Se codice spesa incasso non esistente : uscita  *
      *              *-------------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to det-tot-spi-999.
      *              *-------------------------------------------------*
      *              * Se valuta del documento non e' quella di base : *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = c-sgl
                     go to det-tot-spi-999.
      *              *-------------------------------------------------*
      *              * Azzeramento accumulatore spese incasso          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spi-wpa      .
      *              *-------------------------------------------------*
      *              * Ciclo su tabella scadenze                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spi-c01      .
       det-tot-spi-100.
           add       1                    to   w-det-tot-spi-c01      .
           if        w-det-tot-spi-c01    >    w-trd-scd-ele
                     go to det-tot-spi-400.
      *                  *---------------------------------------------*
      *                  * Test se esistono spese incasso per il tipo  *
      *                  * scadenza in esame                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Scansione tabella spese incasso         *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spi-c02      .
       det-tot-spi-200.
           add       1                    to   w-det-tot-spi-c02      .
           if        w-det-tot-spi-c02    >    w-tes-eit-spi (1)
                     go to det-tot-spi-100.
      *                      *-----------------------------------------*
      *                      * Se tipo pagamento non corrisponde a     *
      *                      * quello della scadenza in esame : rici-  *
      *                      * clo su prossima scadenza                *
      *                      *-----------------------------------------*
           if        w-tes-tpg-spi
                    (1, w-det-tot-spi-c02)
                                          not  = w-trd-scd-tip
                                                (w-det-tot-spi-c01)
                     go to det-tot-spi-200.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo funzio- *
      *                      * namento spesa incasso                   *
      *                      *-----------------------------------------*
           if        w-tes-tfu-spi
                    (1, w-det-tot-spi-c02)
                                          =    01
                     go to det-tot-spi-220
           else if   w-tes-tfu-spi
                    (1, w-det-tot-spi-c02)
                                          =    02
                     go to det-tot-spi-240.
       det-tot-spi-220.
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : automatico         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento accumulatore importo  *
      *                          * spese incasso                       *
      *                          *-------------------------------------*
           add       w-tes-amm-spi
                    (1, w-det-tot-spi-c02)
                                          to   w-det-tot-spi-wpa      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spi-100.
       det-tot-spi-240.
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : manuale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spi-100.
       det-tot-spi-400.
      *              *-------------------------------------------------*
      *              * Memorizzazione totale spese incasso             *
      *              *-------------------------------------------------*
           move      w-det-tot-spi-wpa    to   w-te2-tot-spi (1)      .
       det-tot-spi-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-te2-civ-spi (1)    to   w-agg-cst-iva-coi      .
           move      w-te2-tot-spi (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-te2-ccp-spi (1)    to   w-agg-cst-ctp-cod      .
           move      w-te2-tot-spi (1)    to   w-agg-cst-ctp-imp      .
           move      w-te2-civ-spi (1)    to   w-agg-cst-ctp-civ      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-spi-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale spese bollo                         *
      *    *-----------------------------------------------------------*
       det-tot-spb-000.
      *              *-------------------------------------------------*
      *              * Se importo spesa incasso modificato in imposta- *
      *              * zione : oltre                                   *
      *              *-------------------------------------------------*
           if        w-te2-fdm-spb (1)    not  = spaces
                     go to det-tot-spb-500.
      *              *-------------------------------------------------*
      *              * Se codice spesa bollo non esistente : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-add-spb (1)    =    spaces
                     go to det-tot-spb-999.
      *              *-------------------------------------------------*
      *              * Se valuta del documento non e' quella di base : *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = c-sgl
                     go to det-tot-spb-999.
      *              *-------------------------------------------------*
      *              * Azzeramento accumulatore spese bollo            *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spb-wpa      .
      *              *-------------------------------------------------*
      *              * Ciclo su tabella scadenze                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spb-c01      .
       det-tot-spb-100.
           add       1                    to   w-det-tot-spb-c01      .
           if        w-det-tot-spb-c01    >    w-trd-scd-ele
                     go to det-tot-spb-450.
      *                  *---------------------------------------------*
      *                  * Test se esistono spese bollo per il tipo    *
      *                  * scadenza in esame                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Scansione tabella spese bollo           *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spb-c02      .
       det-tot-spb-200.
           add       1                    to   w-det-tot-spb-c02      .
           if        w-det-tot-spb-c02    >    w-tes-eit-spb (1)
                     go to det-tot-spb-100.
      *                      *-----------------------------------------*
      *                      * Se tipo pagamento non corrisponde a     *
      *                      * quello della scadenza in esame : riciclo*
      *                      *-----------------------------------------*
           if        w-tes-tpg-spb
                    (1, w-det-tot-spb-c02)
                                          not  = w-trd-scd-tip
                                                (w-det-tot-spb-c01)
                     go to det-tot-spb-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per importo spesa      *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tot-spb-wis      .
      *                  *---------------------------------------------*
      *                  * Se importo scadenza non e' maggiore del     *
      *                  * tetto di esenzione : riciclo su prossima    *
      *                  * scadenza                                    *
      *                  *---------------------------------------------*
           if        w-trd-scd-imp
                    (w-det-tot-spb-c01)   not  > w-tes-tet-spb
                                                (1, w-det-tot-spb-c02)
                     go to det-tot-spb-100.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo automatismo *
      *                  * spesa bollo                                 *
      *                  *---------------------------------------------*
           if        w-tes-tau-spb
                    (1, w-det-tot-spb-c02)
                                          =    01
                     go to det-tot-spb-220
           else if   w-tes-tau-spb
                    (1, w-det-tot-spb-c02)
                                          =    02
                     go to det-tot-spb-240
           else if   w-tes-tau-spb
                    (1, w-det-tot-spb-c02)
                                          =    03
                     go to det-tot-spb-260.
       det-tot-spb-220.
      *                  *---------------------------------------------*
      *                  * Tipo automatismo : in percentuale sul tota- *
      *                  * le scadenza                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione importo spesa            *
      *                      *-----------------------------------------*
           multiply  w-tes-per-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-trd-scd-imp
                                              (w-det-tot-spb-c01)
                                        giving w-det-tot-spb-s13      .
           divide    100                  into w-det-tot-spb-s13
                                        giving w-det-tot-spb-wis
                                                         rounded      .
      *                      *-----------------------------------------*
      *                      * A trattamento arrotondamento            *
      *                      *-----------------------------------------*
           go to     det-tot-spb-300.
       det-tot-spb-240.
      *                  *---------------------------------------------*
      *                  * Tipo automatismo : a scaglioni              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ciclo per 10 scaglioni                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spb-c03      .
       det-tot-spb-242.
           add       1                    to   w-det-tot-spb-c03      .
           if        w-det-tot-spb-c03    >    10
                     go to det-tot-spb-244.
           if        w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   =    zero
                     go to det-tot-spb-242.
           if        w-trd-scd-imp
                    (w-det-tot-spb-c01)   >    w-tes-tbe-scg
                                              (                1,
                                               w-det-tot-spb-c02,
                                               w-det-tot-spb-c03)
                     go to det-tot-spb-242.
           move      w-tes-tbe-asc
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   to   w-det-tot-spb-wis      .
       det-tot-spb-244.
      *                      *-----------------------------------------*
      *                      * A trattamento arrotondamento            *
      *                      *-----------------------------------------*
           go to     det-tot-spb-300.
       det-tot-spb-260.
      *                  *---------------------------------------------*
      *                  * Tipo automatismo : a scaglioni in percentua-*
      *                  *                    le                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione work per progressivo   *
      *                      * imponibile                              *
      *                      *-----------------------------------------*
           move      w-trd-scd-imp
                    (w-det-tot-spb-c01)   to   w-det-tot-spb-wpi      .
      *                      *-----------------------------------------*
      *                      * Ciclo per 10 scaglioni                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spb-c03      .
       det-tot-spb-262.
           add       1                    to   w-det-tot-spb-c03      .
           if        w-det-tot-spb-c03    >    10
                     go to det-tot-spb-270.
           if        w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   =    zero
                     go to det-tot-spb-262.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che l'importo sca- *
      *                      * glione sia maggiore o meno dell'importo *
      *                      * scadenza                                *
      *                      *-----------------------------------------*
           if        w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   >    w-trd-scd-imp
                                              (w-det-tot-spb-c01)
                     go to det-tot-spb-270
           else      go to det-tot-spb-264.
       det-tot-spb-264.
      *                      *-----------------------------------------*
      *                      * Se l'importo scaglione e' minore o u-   *
      *                      * guale dell'importo scadenza             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Calcolo quota spesa bollo relativa  *
      *                          * allo scaglione                      *
      *                          *-------------------------------------*
           multiply  w-tes-tbe-psc
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)
                                          by   w-tes-tbe-scg
                                              (                1,
                                               w-det-tot-spb-c02,
                                               w-det-tot-spb-c03)
                                        giving w-det-tot-spb-s13      .
           divide    100                  into w-det-tot-spb-s13
                                        giving w-det-tot-spb-wss
                                                         rounded      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo spesa         *
      *                          *-------------------------------------*
           add       w-det-tot-spb-wss    to   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * Aggiornamento progressivo imponibile*
      *                          *-------------------------------------*
           subtract  w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   from w-det-tot-spb-wpi      .
      *                          *-------------------------------------*
      *                          * Riciclo su prossimo scaglione       *
      *                          *-------------------------------------*
           go to     det-tot-spb-262.
       det-tot-spb-270.
      *                      *-----------------------------------------*
      *                      * Se l'importo scaglione e' superiore al- *
      *                      * l'importo scadenza                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Calcolo quota spesa bollo relativa  *
      *                          * al residuo, cioe' il progressivo im-*
      *                          * ponibile sin qui determinato        *
      *                          *-------------------------------------*
           multiply  w-tes-tbe-psc
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)
                                          by   w-det-tot-spb-wpi
                                        giving w-det-tot-spb-s13      .
           divide    100                  into w-det-tot-spb-s13
                                        giving w-det-tot-spb-wss
                                                         rounded      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo spesa         *
      *                          *-------------------------------------*
           add       w-det-tot-spb-wss    to   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A trattamento arrotondamento        *
      *                          *-------------------------------------*
           go to     det-tot-spb-300.
       det-tot-spb-300.
      *                  *---------------------------------------------*
      *                  * Trattamento arrotondamento                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se esiste un valore minimo per la spesa *
      *                      *-----------------------------------------*
           if        w-tes-min-spb
                    (1, w-det-tot-spb-c02)
                                          =    zero
                     go to det-tot-spb-302.
      *                      *-----------------------------------------*
      *                      * Se l'importo spesa sin qui determinato  *
      *                      * e' inferiore al minimo valore, si forza *
      *                      * il valore minimo                        *
      *                      *-----------------------------------------*
           if        w-det-tot-spb-wis    <    w-tes-min-spb
                                              (1, w-det-tot-spb-c02)
                     move  w-tes-min-spb
                          (1, w-det-tot-spb-c02)
                                          to   w-det-tot-spb-wis      .
       det-tot-spb-302.
      *                      *-----------------------------------------*
      *                      * Se esiste un valore massimo per la spesa*
      *                      *-----------------------------------------*
           if        w-tes-max-spb
                    (1, w-det-tot-spb-c02)
                                          =    zero
                     go to det-tot-spb-304.
      *                      *-----------------------------------------*
      *                      * Se l'importo spesa sin qui determinato  *
      *                      * e' superiore al massimo valore, si forza*
      *                      * il valore massimo                       *
      *                      *-----------------------------------------*
           if        w-det-tot-spb-wis    >    w-tes-max-spb
                                              (1, w-det-tot-spb-c02)
                     move  w-tes-max-spb
                          (1, w-det-tot-spb-c02)
                                          to   w-det-tot-spb-wis      .
       det-tot-spb-304.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo arroton-*
      *                      * damento                                 *
      *                      *-----------------------------------------*
           go to     det-tot-spb-310
                     det-tot-spb-320
                     det-tot-spb-330
                     det-tot-spb-340
                                depending on   w-tes-tar-spb
                                              (1, w-det-tot-spb-c02)  .
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : nessuno           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scadenze       *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-310.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : al valore superio-*
      *                      *                       re                *
      *                      *-----------------------------------------*
           if        w-det-tot-spb-wis    >    zero
                     add      w-tes-var-spb
                             (1, w-det-tot-spb-c02)
                                          to   w-det-tot-spb-wis
                     subtract 1           from w-det-tot-spb-wis
           else      subtract w-tes-var-spb
                             (1, w-det-tot-spb-c02)
                                          from w-det-tot-spb-wis
                     add      1           to   w-det-tot-spb-wis      .
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-320.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : al valore inferio-*
      *                      *                       re                *
      *                      *-----------------------------------------*
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-330.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : commerciale       *
      *                      *-----------------------------------------*
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis
                                                         rounded      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-340.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : statale           *
      *                      *-----------------------------------------*
           divide    2                    into w-tes-var-spb
                                              (1, w-det-tot-spb-c02)
                                        giving w-det-tot-spb-wpc
                                                          rounded     .
           if        w-det-tot-spb-wis    >    zero
                     add      w-det-tot-spb-wpc
                                          to   w-det-tot-spb-wis
                     subtract 1           from w-det-tot-spb-wis
           else      subtract w-det-tot-spb-wpc
                                          from w-det-tot-spb-wis
                     add      1           to   w-det-tot-spb-wis      .
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-400.
      *                  *---------------------------------------------*
      *                  * Aggiornamento accumulatore spese bollo      *
      *                  *---------------------------------------------*
           add       w-det-tot-spb-wis    to   w-det-tot-spb-wpa      .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossima scadenza                *
      *                  *---------------------------------------------*
           go to     det-tot-spb-100.
       det-tot-spb-450.
      *              *-------------------------------------------------*
      *              * Memorizzazione totale spese bollo calcolate     *
      *              *-------------------------------------------------*
           move      w-det-tot-spb-wpa    to   w-te2-tot-spb (1)      .
       det-tot-spb-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-te2-civ-spb (1)    to   w-agg-cst-iva-coi      .
           move      w-te2-tot-spb (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-te2-ccp-spb (1)    to   w-agg-cst-ctp-cod      .
           move      w-te2-tot-spb (1)    to   w-agg-cst-ctp-imp      .
           move      w-te2-civ-spb (1)    to   w-agg-cst-ctp-civ      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-spb-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale spese                               *
      *    *-----------------------------------------------------------*
       det-tot-spe-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-trd-tot-spe          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spe-ctr      .
       det-tot-spe-100.
           add       1                    to   w-det-tot-spe-ctr      .
           if        w-det-tot-spe-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-spe-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-spe-ctr)   to   w-det-tot-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-te2-spe-snx
                    (1, w-det-tot-spe-inx)
                                          =    0
                     go to det-tot-spe-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-te2-spe-imp
                    (1, w-det-tot-spe-inx)
                                          to   w-trd-tot-spe          .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-spe-100.
       det-tot-spe-200.
      *              *-------------------------------------------------*
      *              * Spese incasso                                   *
      *              *-------------------------------------------------*
           add       w-te2-tot-spi (1)    to   w-trd-tot-spe          .
      *              *-------------------------------------------------*
      *              * Spese bollo                                     *
      *              *-------------------------------------------------*
           add       w-te2-tot-spb (1)    to   w-trd-tot-spe          .
       det-tot-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale imponibile                          *
      *    *-----------------------------------------------------------*
       det-tot-ibl-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-trd-tot-ibl          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-ibl-ctr      .
       det-tot-ibl-100.
           add       1                    to   w-det-tot-ibl-ctr      .
           if        w-det-tot-ibl-ctr    >    6
                     go to det-tot-ibl-999.
           add       w-trd-iva-ibl
                    (w-det-tot-ibl-ctr)   to   w-trd-tot-ibl          .
           go to     det-tot-ibl-100.
       det-tot-ibl-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale imposta                             *
      *    *-----------------------------------------------------------*
       det-tot-imp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-trd-tot-imp          .
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    02 or
                     w-tes-cod-tmf-tpv    =    03
                     go to det-tot-imp-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-imp-ctr      .
       det-tot-imp-100.
           add       1                    to   w-det-tot-imp-ctr      .
           if        w-det-tot-imp-ctr    >    6
                     go to det-tot-imp-999.
      *                  *---------------------------------------------*
      *                  * Se aliquota normale o indeducibile : calco- *
      *                  * lo                                          *
      *                  *---------------------------------------------*
           move      "DI"                 to   d-imp-iva-tip-ope      .
           move      w-trd-iva-ibl
                    (w-det-tot-imp-ctr)   to   d-imp-iva-ibl-iva      .
           move      w-trd-iva-cod
                    (w-det-tot-imp-ctr)   to   d-imp-iva-cod-iva      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
      *                  *---------------------------------------------*
      *                  * Aggiornamento accumulatore                  *
      *                  *---------------------------------------------*
           add       d-imp-iva-ims-iva    to   w-trd-tot-imp          .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-imp-100.
       det-tot-imp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
           add       w-trd-tot-ibl
                     w-trd-tot-imp      giving w-trd-tot-doc          .
       det-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione scadenze per il documento                  *
      *    *-----------------------------------------------------------*
       det-sca-doc-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri in input                 *
      *              *-------------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-clc-tbl-scd-fdp      .
           move      w-tes-dat-reg        to   w-clc-tbl-scd-ddo      .
           move      w-trd-tot-ibl        to   w-clc-tbl-scd-ibl      .
           move      w-trd-tot-imp        to   w-clc-tbl-scd-iva      .
           move      w-tes-pag-qaf (1)    to   w-clc-tbl-scd-qaf      .
           move      w-tes-pag-act (1)    to   w-clc-tbl-scd-acc      .
           move      w-tes-pag-dsm (1)    to   w-clc-tbl-scd-ddp      .
           move      zero                 to   w-det-sca-doc-ctr      .
       det-sca-doc-100.
           add       1                    to   w-det-sca-doc-ctr      .
           if        w-det-sca-doc-ctr    >    3
                     go to det-sca-doc-120.
           move      w-tes-cod-pag
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-cdp
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-tip-amm
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-tam
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-per-toi
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-pti
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dim-act
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dda
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-tip-pag
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-tpg
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-num-sca
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-nsp
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dec-prs
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dps
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dap-mes
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dpm
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dap-gio
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dpg
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-ggg-int
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-gdi
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-tip-scm
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-tsm
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-gio-scm
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-gfs
                                              (w-det-sca-doc-ctr)     .
           move      zero                 to   w-clc-tbl-scd-ccp
                                              (w-det-sca-doc-ctr)     .
           go to     det-sca-doc-100.
       det-sca-doc-120.
      *                  *---------------------------------------------*
      *                  * Tipo esclusione mesi : forzato a 01, nessun *
      *                  * mese escluso                                *
      *                  *---------------------------------------------*
           move      01                   to   w-clc-tbl-scd-esm      .
      *                  *---------------------------------------------*
      *                  * Valori di esclusione : normalizzati a zero  *
      *                  *---------------------------------------------*
           move      zero                 to   w-clc-tbl-scd-alt      .
           move      zero                 to   w-clc-tbl-scd-e01      .
           move      zero                 to   w-clc-tbl-scd-e02      .
       det-sca-doc-200.
      *              *-------------------------------------------------*
      *              * Richiamo routine di calcolo                     *
      *              *-------------------------------------------------*
           perform   clc-tbl-scd-000      thru clc-tbl-scd-999        .
       det-sca-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da work locale a work piede           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sca-doc-ctr      .
       det-sca-doc-310.
           add       1                    to   w-det-sca-doc-ctr      .
           if        w-det-sca-doc-ctr    >    w-clc-tbl-scd-nts
                     go to det-sca-doc-320.
           move      w-clc-tbl-scd-tds
                    (w-det-sca-doc-ctr)   to   w-trd-scd-tip
                                              (w-det-sca-doc-ctr)     .
           move      w-clc-tbl-scd-dds
                    (w-det-sca-doc-ctr)   to   w-trd-scd-dat
                                              (w-det-sca-doc-ctr)     .
           move      w-clc-tbl-scd-ccs
                    (w-det-sca-doc-ctr)   to   w-trd-scd-cau
                                              (w-det-sca-doc-ctr)     .
           move      w-clc-tbl-scd-ids
                    (w-det-sca-doc-ctr)   to   w-trd-scd-imp
                                              (w-det-sca-doc-ctr)     .
           go to     det-sca-doc-310.
       det-sca-doc-320.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero totale scadenze          *
      *              *-------------------------------------------------*
           move      w-clc-tbl-scd-nts    to   w-trd-scd-ele          .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-sca-doc-999.
       det-sca-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione tipo operazione, causale e sottoconto con- *
      *    * tabile per registrazione scadenza fornitore               *
      *    *-----------------------------------------------------------*
       det-tcs-rsf-000.
      *              *-------------------------------------------------*
      *              * Determinazione codice tipo operazione di regi-  *
      *              * strazione scadenza fornitore                    *
      *              *-------------------------------------------------*
           if        w-rg3-tip-scf (1)    =    01
                     move  1101           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    02
                     move  1102           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    03
                     move  1103           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    04
                     move  1104           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    05
                     move  1105           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    06
                     move  1106           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    07
                     if       w-rg3-tvl-scf (1)
                                          =    01
                              move  1107  to   w-det-tcs-rsf-top
                     else if  w-rg3-tvl-scf (1)
                                          =    02
                              move  1127  to   w-det-tcs-rsf-top
                     else     move  zero  to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    08
                     move  1108           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    09
                     move  1109           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    10
                     move  1110           to   w-det-tcs-rsf-top
           else if   w-rg3-tip-scf (1)    =    11
                     move  1111           to   w-det-tcs-rsf-top
           else      move  zero           to   w-det-tcs-rsf-top      .
      *              *-------------------------------------------------*
      *              * Lettura archivio [yop]                          *
      *              *-------------------------------------------------*
           move      w-det-tcs-rsf-top    to   w-let-arc-yop-cod      .
           perform   let-arc-yop-000      thru let-arc-yop-999        .
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice tipo operazione di regi- *
      *              * strazione scadenza fornitore                    *
      *              *-------------------------------------------------*
           move      w-det-tcs-rsf-top    to   w-rg3-top-rsf (1)      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice causale contabile per    *
      *              * registrazione scadenza fornitore                *
      *              *-------------------------------------------------*
           move      w-let-arc-yop-cau    to   w-rg3-cau-rsf (1)      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice sottoconto contabile per *
      *              * registrazione scadenza fornitore                *
      *              *-------------------------------------------------*
           move      w-let-arc-yop-stc    to   w-rg3-stc-rsf (1)      .
       det-tcs-rsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione saldo righe movimento contabile relative   *
      *    * al fornitore                                              *
      *    *-----------------------------------------------------------*
       det-sdo-rmf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione iniziale                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-co3-sdo-rmf (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione righe movimento contabile    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 2 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg2-ope          .
           move      1                    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to det-sdo-rmf-999.
       det-sdo-rmf-100.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to det-sdo-rmf-999.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg2                              *
      *                  *---------------------------------------------*
           move      w-cat-rg2-buf        to   w-rg2                  .
      *                  *---------------------------------------------*
      *                  * Test su tipo e codice conto                 *
      *                  *---------------------------------------------*
           if        w-rg2-tip-con (1)    not  = "F"            or
                     w-rg2-cod-con (1)    not  = w-tes-cod-arc (1)
                     go to det-sdo-rmf-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo fornitore               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo docu-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     go to det-sdo-rmf-120
           else      go to det-sdo-rmf-140.
       det-sdo-rmf-120.
      *                      *-----------------------------------------*
      *                      * Se nota di accredito                    *
      *                      *-----------------------------------------*
           if        w-rg2-dar-ave (1)    =    "A"
                     subtract w-rg2-imp-mov (1)
                                          from w-co3-sdo-rmf (1)
           else      add      w-rg2-imp-mov (1)
                                          to   w-co3-sdo-rmf (1)      .
           go to     det-sdo-rmf-200.
       det-sdo-rmf-140.
      *                      *-----------------------------------------*
      *                      * Se fattura, nota di addebito o bolla    *
      *                      * doganale                                *
      *                      *-----------------------------------------*
           if        w-rg2-dar-ave (1)    =    "D"
                     subtract w-rg2-imp-mov (1)
                                          from w-co3-sdo-rmf (1)
           else      add      w-rg2-imp-mov (1)
                                          to   w-co3-sdo-rmf (1)      .
           go to     det-sdo-rmf-200.
       det-sdo-rmf-200.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena                   *
      *                  *---------------------------------------------*
           go to     det-sdo-rmf-100.
       det-sdo-rmf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione primo protocollo di CGE e quanti di essi   *
      *    * sono necessari                                            *
      *    *-----------------------------------------------------------*
       det-prt-cge-000.
      *              *-------------------------------------------------*
      *              * Se si e' in modifica di una registrazione che   *
      *              * non aveva generato nessun movimento contabile,  *
      *              * non si generera' il movimento contabile e quin- *
      *              * di non si deve prelevare alcun numero protocol- *
      *              * lo                                              *
      *              *-------------------------------------------------*
           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-te2-dat-mgd (1)    =    zero or
                     w-pie-prt-mgd (1)    =    zero  )
                     go to det-prt-cge-999.
      *              *-------------------------------------------------*
      *              * Se registrazione contabile da non eseguire : u- *
      *              * scita                                           *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to det-prt-cge-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero protocollo necessari    *
      *              *-------------------------------------------------*
           move      1                    to   w-det-prt-cge-npn      .
      *              *-------------------------------------------------*
      *              * Determinazione numeri protocollo necessari      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 3 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg3-ope          .
           move      1                    to   w-cat-rg3-num          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to det-prt-cge-200.
       det-prt-cge-100.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg3-ope          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to det-prt-cge-200.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg3                              *
      *                  *---------------------------------------------*
           move      w-cat-rg3-buf        to   w-rg3                  .
      *                  *---------------------------------------------*
      *                  * Test se esistono causale di contabilita' e  *
      *                  * sottoconto per registrazione scadenza       *
      *                  *---------------------------------------------*
           if        w-rg3-cau-rsf (1)    =    zero or
                     w-rg3-stc-rsf (1)    =    zero
                     go to det-prt-cge-100.
      *                  *---------------------------------------------*
      *                  * Incremento numero protocolli necessari      *
      *                  *---------------------------------------------*
           add       1                    to   w-det-prt-cge-npn      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena                   *
      *                  *---------------------------------------------*
           go to     det-prt-cge-100.
       det-prt-cge-200.
      *              *-------------------------------------------------*
      *              * Prelievo numeri protocollo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record                      *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                  *---------------------------------------------*
      *                  * Lettura tabella numerazioni [prtcge]        *
      *                  *---------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      w-te2-dat-mgd (1)    to   s-dat                  .
           move      s-saa                to   rn-prt-cge-saa-dtr     .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-prt-cge-300.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     det-prt-cge-200.
       det-prt-cge-300.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Movimento da record a work              *
      *                      *-----------------------------------------*
           move      rn-prt-cge-num-prt   to   w-det-prt-cge-wnp      .
       det-prt-cge-310.
      *                      *-----------------------------------------*
      *                      * Salvataggio numero protocollo           *
      *                      *-----------------------------------------*
           move      w-det-prt-cge-wnp    to   w-det-prt-cge-snp      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       w-det-prt-cge-npn    to   w-det-prt-cge-wnp      .
           if        w-det-prt-cge-wnp    >    9999999
                     move  zero           to   w-det-prt-cge-wnp
                     go to det-prt-cge-310.
      *                      *-----------------------------------------*
      *                      * Movimento da work a record              *
      *                      *-----------------------------------------*
           move      w-det-prt-cge-wnp    to   rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-cge-200.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *              *-------------------------------------------------*
      *              * Determinazione primo protocollo da utilizzare   *
      *              *-------------------------------------------------*
           move      w-det-prt-cge-snp    to   w-pie-prt-mgd (1)      .
           add       1                    to   w-pie-prt-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Determinazione numeri di protocollo da utiliz-  *
      *              * zare                                            *
      *              *-------------------------------------------------*
           move      w-det-prt-cge-npn    to   w-pie-nrg-mgd (1)      .
       det-prt-cge-999.
           exit.

      *    *===========================================================*
      *    * Determinazione primo numero scadenza e quanti di essi     *
      *    * sono necessari                                            *
      *    *-----------------------------------------------------------*
       det-num-rsf-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero scadenze necessari        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-num-rsf-npn      .
           move      zero                 to   w-det-num-rsf-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 3 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg3-ope          .
           move      1                    to   w-cat-rg3-num          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to det-num-rsf-100.
       det-num-rsf-050.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg3-ope          .
           perform   cll-sub-ct3-000      thru cll-sub-ct3-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg3-exs        not  = spaces
                     go to det-num-rsf-100.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg3                              *
      *                  *---------------------------------------------*
           move      w-cat-rg3-buf        to   w-rg3                  .
      *                  *---------------------------------------------*
      *                  * Test se esiste il tipo operazione per regi- *
      *                  * strazione scadenza fornitore                *
      *                  *---------------------------------------------*
           if        w-rg3-top-rsf (1)    =    zero
                     go to det-num-rsf-050.
      *                  *---------------------------------------------*
      *                  * Incremento numero protocolli necessari      *
      *                  *---------------------------------------------*
           add       1                    to   w-det-num-rsf-npn      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena                   *
      *                  *---------------------------------------------*
           go to     det-num-rsf-050.
       det-num-rsf-100.
      *              *-------------------------------------------------*
      *              * Prelievo numeri protocollo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record                      *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                  *---------------------------------------------*
      *                  * Lettura tabella numerazioni [sfsnum]        *
      *                  *---------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   rn-sfs-num-scl-ann     .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-num-rsf-200.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   rn-sfs-num-num-scf     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     det-num-rsf-100.
       det-num-rsf-200.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Movimento da record a work              *
      *                      *-----------------------------------------*
           move      rn-sfs-num-num-scf   to   w-det-num-rsf-wns      .
           move      w-det-num-rsf-wnp    to   w-det-num-rsf-wap      .
       det-num-rsf-210.
      *                      *-----------------------------------------*
      *                      * Salvataggio numero scadenza             *
      *                      *-----------------------------------------*
           move      w-det-num-rsf-wns    to   w-det-num-rsf-sns      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero progressivo        *
      *                      *-----------------------------------------*
           add       w-det-num-rsf-npn    to   w-det-num-rsf-wap      .
           if        w-det-num-rsf-wap    >    99999999
                     move  zero           to   w-det-num-rsf-wap
                     go to det-num-rsf-210.
      *                      *-----------------------------------------*
      *                      * Movimento da work a record              *
      *                      *-----------------------------------------*
           move      w-det-num-rsf-wap    to   w-det-num-rsf-wnp      .
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   w-det-num-rsf-wsa      .
           move      w-det-num-rsf-wns    to   rn-sfs-num-num-scf     .
