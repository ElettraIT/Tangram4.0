           if        w-pie-nps-scf (2)    =    zero
                     go to del-mov-scf-800.
      *              *-------------------------------------------------*
      *              * Ciclo per tutti i movimenti registrati a parti- *
      *              * re dal numero scadenza iniziale                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero scadenza iniziale     *
      *                  * meno 1                                      *
      *                  *---------------------------------------------*
           move      w-pie-nps-scf (2)    to   w-del-mov-scf-nsi      .
           subtract  1                    from w-del-mov-scf-nsi      .
      *                  *---------------------------------------------*
      *                  * Determinazione numero scadenza finale       *
      *                  *---------------------------------------------*
           move      w-del-mov-scf-nsi    to   w-del-mov-scf-nsf      .
           add       w-pie-ctr-scf (2)    to   w-del-mov-scf-nsf      .
       del-mov-scf-100.
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenza                  *
      *                  *---------------------------------------------*
           add       1                    to   w-del-mov-scf-nsi      .
      *                  *---------------------------------------------*
      *                  * Test se oltrepassato il massimo             *
      *                  *---------------------------------------------*
           if        w-del-mov-scf-nsi    >    w-del-mov-scf-nsf
                     go to del-mov-scf-800.
      *                  *---------------------------------------------*
      *                  * Composizione chiave primaria                *
      *                  *---------------------------------------------*
           move      w-del-mov-scf-nsi    to   rf-sfs-num-scf         .
      *                  *---------------------------------------------*
      *                  * Delete record [sfs]                         *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
       del-mov-scf-600.
      *                  *---------------------------------------------*
      *                  * Riciclo per prossima cancellazione          *
      *                  *---------------------------------------------*
           go to     del-mov-scf-100.
       del-mov-scf-800.
      *              *-------------------------------------------------*
      *              * Cancellazione record [sfx]                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione chiave primaria record [sfx]   *
      *                  *---------------------------------------------*
           move      w-pie-prt-scf (2)    to   rf-sfx-num-prt         .
      *                  *---------------------------------------------*
      *                  * Delete record [sff]                         *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfx                 .
       del-mov-scf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     del-mov-scf-999.
       del-mov-scf-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimenti di MAG                                *
      *    *-----------------------------------------------------------*
       wrt-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Se causale di magazzino a zero : uscita         *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-cam    =    zero
                     go to wrt-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Normalizzazione testata                         *
      *              *-------------------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Scrittura testata                               *
      *              *-------------------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-pie-prt-mag (1)    to   l-mag-300-num-prt      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           move      w-tes-cod-tmf-cam    to   l-mag-300-cod-cau      .
           move      w-tes-dat-doc (1)    to   l-mag-300-dat-doc      .
           move      w-tes-num-doc (1)    to   l-mag-300-num-doc      .
           move      w-tes-cod-tmf-dsl    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           move      w-tes-tip-arc (1)    to   l-mag-300-tip-arc      .
           move      w-tes-cod-arc (1)    to   l-mag-300-cod-arc      .
           move      w-tes-dpz-arc (1)    to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Scrittura righe                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore righe scritte    *
      *                  *---------------------------------------------*
           move      zero                 to   w-wrt-mov-mag-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su catena movimenti                   *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale catena movimenti        *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to wrt-mov-mag-800.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * di lavoro                                   *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Se tipo riga a spazi : uscita               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to wrt-mov-mag-800.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo riga                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to wrt-mov-mag-100.
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo prodotto                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-pro (1)    not  = 01
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Selezione su flag di scrittura movimenti di *
      *                  * magazzino                                   *
      *                  *---------------------------------------------*
           if        w-rig-snx-mag (1)    not  = "S"
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore righe scritte          *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-mag-ctr      .
      *                  *---------------------------------------------*
      *                  * Determinazione valore movimento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento in work di comodo           *
      *                      *-----------------------------------------*
           move      w-rig-imp-rig (1)    to   w-wrt-mov-mag-wvm      .
      *                      *-----------------------------------------*
      *                      * Eventuale abbattimento con sconto in    *
      *                      * chiusura e sconto pagamento di testata  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione totale sconti       *
      *                          *-------------------------------------*
           move      zero                 to   w-wrt-mov-mag-tsc      .
      *                          *-------------------------------------*
      *                          * Se contropartita sconto in chiusura *
      *                          * a zero : bufferizzazione importo    *
      *                          * sconto in chiusura                  *
      *                          *-------------------------------------*
           if        w-te2-ccp-scc (1)    =    zero
                     add   w-te2-tot-scc (1)
                                          to   w-wrt-mov-mag-tsc      .
      *                          *-------------------------------------*
      *                          * Se contropartita sconto pagamento   *
      *                          * a zero : bufferizzazione importo    *
      *                          * sconto pagamento                    *
      *                          *-------------------------------------*
           if        w-te2-ccp-scp (1)    =    zero
                     add   w-te2-tot-scp (1)
                                          to   w-wrt-mov-mag-tsc      .
      *                          *-------------------------------------*
      *                          * Se totale sconti a zero : oltre     *
      *                          *-------------------------------------*
           if        w-wrt-mov-mag-tsc    =    zero
                     go to wrt-mov-mag-120.
      *                          *-------------------------------------*
      *                          * Determinazione totale lordo         *
      *                          *-------------------------------------*
           move      zero                 to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 1) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 2) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 3) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 4) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 5) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 6) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 7) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 8) to   w-wrt-mov-mag-tlo      .
           add       w-te2-tot-rig (1, 9) to   w-wrt-mov-mag-tlo      .
      *                          *-------------------------------------*
      *                          * Abbattimento importo in riga        *
      *                          *-------------------------------------*
           multiply  w-wrt-mov-mag-tsc    by   w-wrt-mov-mag-wvm
                                        giving w-wrt-mov-mag-s17      .
           divide    w-wrt-mov-mag-tlo    into w-wrt-mov-mag-s17
                                        giving w-wrt-mov-mag-s11
                                               rounded                .
           subtract  w-wrt-mov-mag-s11    from w-wrt-mov-mag-wvm      .
       wrt-mov-mag-120.
      *                      *-----------------------------------------*
      *                      * Conversione in valuta base              *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-wrt-mov-mag-wvm    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-wrt-mov-mag-wvm      .
      *                  *---------------------------------------------*
      *                  * Determinazione costo unitario movimento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa      *
      *                      * all'espressione dei costi unitari in    *
      *                      * unita' di misura diversa                *
      *                      *-----------------------------------------*
           if        w-prs-arg-mag-ecu    =    "N"
                     go to wrt-mov-mag-220.
      *                      *-----------------------------------------*
      *                      * Questo punto andrebbe perfezionato per  *
      *                      * confronto tra il tipo di trasformazione *
      *                      * unita' di misura e i coefficienti       *
      *                      *                                         *
      *                      * ___ MIGLIORARE !!! ___                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test solo per 1000                  *
      *                          *-------------------------------------*
           if        w-prs-arg-mag-ecu    not  = "K"
                     go to wrt-mov-mag-220.
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           divide    w-rig-qta-fda (1)    into w-wrt-mov-mag-wvm
                                        giving w-wrt-mov-mag-wcu
                                               rounded                .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     wrt-mov-mag-250.
       wrt-mov-mag-220.
      *                      *-----------------------------------------*
      *                      * Normale trattamento                     *
      *                      *-----------------------------------------*
           divide    w-rig-qta-acq (1)    into w-wrt-mov-mag-wvm
                                        giving w-wrt-mov-mag-wcu
                                               rounded                .
       wrt-mov-mag-250.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      w-rig-tip-mag (1)    to   l-mag-300-tip-mag      .
           move      w-rig-num-mag (1)    to   l-mag-300-num-mag      .
           move      w-rig-alf-mag (1)    to   l-mag-300-alf-mag      .
           move      w-rig-sgl-vrn (1)    to   l-mag-300-var-mag      .
           move      w-rig-umi-acq (1)    to   l-mag-300-udm-ana      .
           move      w-rig-umi-acq (1)    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      zero                 to   l-mag-300-qta-mov      .
           move      zero                 to   l-mag-300-cun-mov      .
           move      w-wrt-mov-mag-wvm    to   l-mag-300-val-mov      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena movimenti         *
      *                  *---------------------------------------------*
           go to     wrt-mov-mag-100.
       wrt-mov-mag-800.
      *              *-------------------------------------------------*
      *              * Test su numero righe scritte                    *
      *              *-------------------------------------------------*
           if        w-wrt-mov-mag-ctr    not  = zero
                     go to wrt-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Se nessuna riga scritta : cancellazione della   *
      *              * registrazione di magazzino per eliminare la     *
      *              * testata scritta                                 *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-pie-prt-mag (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-mov-mag-999.
       wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : aggiornamenti di magazzino non esegui
      -              "ti !  "             to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       wrt-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimento di MAG                            *
      *    *-----------------------------------------------------------*
       del-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Test se necessario                              *
      *              *-------------------------------------------------*
           if        w-pie-prt-mag (2)    =    zero
                     go to del-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Esecuzione operazione                           *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-pie-prt-mag (2)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento movimenti di magazzino di carico connessi   *
      *    * alle bolle fornitore                                      *
      *    *-----------------------------------------------------------*
       agg-mag-bfo-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        w-prs-snx-mag        not  = "S"
                     go to agg-mag-bfo-999.
           if        w-prs-bfo-snx        not  = "S"
                     go to agg-mag-bfo-999.
           if        w-tes-cod-tmf-maf    not  = 02
                     go to agg-mag-bfo-999.
      *              *-------------------------------------------------*
      *              * Esecuzione                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo modulo trattamento bolle fornito-  *
      *                  * ri con funzione 'AM'                        *
      *                  *---------------------------------------------*
           move      "AM"                 to   l-eva-bfo-tip-ope      .
           move      "pgm/ffo/prg/obj/pffo300a"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-bfo
                                               w-prs
                                               w-tes
                                               w-te2
                                               w-rig
                                               w-cat-rig              .
       agg-mag-bfo-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe          *
      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe, con     *
      *    * presa visione 'S'                                         *
      *    *-----------------------------------------------------------*
       box-msg-es2-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      66                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-es2-200.
      *              *-------------------------------------------------*
      *              * Normalizzazione function key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Accettazione per presa visione                  *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Test su carattere accettato                 *
      *                  *---------------------------------------------*
           if        v-alf                not  = "S" and
                     v-alf                not  = "s"
