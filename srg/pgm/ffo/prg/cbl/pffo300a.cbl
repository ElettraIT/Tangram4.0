                     go to acc-cdc-vpl-900.
           if        w-vpl-ctr-002        >    6
                     go to acc-cdc-vpl-900.
           if        w-vpl-cdc-vpl
                    (w-vpl-ctr-002)       =    zero
                     go to acc-cdc-vpl-100.
           go to     acc-cdc-vpl-820.
       acc-cdc-vpl-900.
      *                  *---------------------------------------------*
