           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      67                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      08                   to   v-pos                  .
           move      " --------+------------------+---------------------
      -              "--+------------- "  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
