           move      "BD"                 to   v-edm                  .
           add       12
                     w-vpl-ctr-001    giving   v-lin                  .
           move      38                   to   v-pos                  .
           move      w-vpl-cdc-rif
                    (w-vpl-ctr-001)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
