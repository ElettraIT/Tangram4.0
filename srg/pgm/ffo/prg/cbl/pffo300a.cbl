      *              * dice di magazzino oppure no                     *
      *              *-------------------------------------------------*
           if       (w-buf-rig-bfo-wtp    =    "P" or
                     w-buf-rig-bfo-wtp    =    "M" or
                     w-buf-rig-bfo-wtp    =    "V"  ) and
                     w-buf-rig-bfo-wtf    =    spaces
                     go to cpz-des-rgs-200.
       cpz-des-rgs-100.
