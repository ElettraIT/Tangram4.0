      *    *===========================================================*
      *    * Aggiornamento valori movimenti di magazzino generati a    *
      *    * suo tempo dalle bolle fornitori                           *
      *    *-----------------------------------------------------------*
       agg-mag-bfo-000.
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Se zero elementi nel buffer protocolli bolle    *
      *              * fornitori trattate, si ricostruisce tale buf-   *
      *              * fer, rileggendo la catena righe                 *
      *              *-------------------------------------------------*
           if        w-pbf-num-ele        not  = zero
                     go to agg-mag-bfo-080.
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : oltre                 *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to agg-mag-bfo-080.
       agg-mag-bfo-020.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale righe corpo             *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : oltre                           *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to agg-mag-bfo-080.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Test se riga fattura a fronte bolla         *
      *                  *---------------------------------------------*
           if        w-rig-bfo-prt (1)    =    zero
                     go to agg-mag-bfo-020.
      *                  *---------------------------------------------*
      *                  * Test se protocollo bolla gia' memorizzato   *
      *                  *---------------------------------------------*
           move      zero                 to   w-pbf-ctr-001          .
       agg-mag-bfo-040.
           add       1                    to   w-pbf-ctr-001          .
           if        w-pbf-ctr-001        >    w-pbf-num-ele
                     go to agg-mag-bfo-060.
           if        w-rig-bfo-prt (1)    =    w-pbf-num-prt
                                              (w-pbf-ctr-001)
                     go to agg-mag-bfo-020.
           go to     agg-mag-bfo-040.
       agg-mag-bfo-060.
           if        w-pbf-num-ele        <    w-pbf-max-ele
                     add   1              to   w-pbf-num-ele          .
           move      w-rig-bfo-prt (1)    to   w-pbf-num-prt
                                              (w-pbf-num-ele)         .
           go to     agg-mag-bfo-020.
       agg-mag-bfo-080.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer protocolli bolle for- *
      *              * nitori trattate                                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-pbf-ctr-001          .
       agg-mag-bfo-100.
           add       1                    to   w-pbf-ctr-001          .
           if        w-pbf-ctr-001        >    w-pbf-num-ele
                     go to agg-mag-bfo-999.
      *                  *---------------------------------------------*
      *                  * Lettura record [bft]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-pbf-num-prt
                    (w-pbf-ctr-001)       to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : riciclo             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-mag-bfo-100.
      *                  *---------------------------------------------*
      *                  * Se non e' stato generato alcun movimento di *
      *                  * magazzino a fronte della bolla : riciclo    *
      *                  *---------------------------------------------*
           if        rf-bft-prt-mag       =    zero
                     go to agg-mag-bfo-100.
       agg-mag-bfo-120.
      *                  *---------------------------------------------*
      *                  * Controllo tipo movimento bolla fornitore    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo movimento non esistente : ri-   *
      *                      * ciclo                                   *
      *                      *-----------------------------------------*
           if        rf-bft-cod-tmb       =    spaces
                     go to agg-mag-bfo-100.
      *                      *-----------------------------------------*
      *                      * Lettura record [ybf] principale         *
      *                      *-----------------------------------------*
           move      rf-bft-cod-tmb       to   w-let-arc-ybf-cod      .
           move      zero                 to   w-let-arc-ybf-dpz      .
           perform   let-arc-ybf-000      thru let-arc-ybf-999        .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : riciclo         *
      *                      *-----------------------------------------*
           if        w-let-arc-ybf-flg    not  = spaces
                     go to agg-mag-bfo-100.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione causale di magazzino    *
      *                      *-----------------------------------------*
           move      w-let-arc-ybf-cam    to   w-agg-mag-bfo-cam      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice conto merce      *
      *                      *-----------------------------------------*
           move      w-let-arc-ybf-ctm    to   w-agg-mag-bfo-ctm      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice dislocazione di  *
      *                      * default                                 *
      *                      *-----------------------------------------*
           move      w-let-arc-ybf-dsl    to   w-agg-mag-bfo-ddd      .
      *                      *-----------------------------------------*
      *                      * Lettura record [ybf] della dipendenza   *
      *                      *-----------------------------------------*
           move      rf-bft-cod-tmb       to   w-let-arc-ybf-cod      .
           move      rf-bft-cod-dpz       to   w-let-arc-ybf-dpz      .
           perform   let-arc-ybf-000      thru let-arc-ybf-999        .
      *                      *-----------------------------------------*
      *                      * Se record esistente si bufferizza il    *
      *                      * codice dislocazione in esso contenuto,  *
      *                      * altrimenti si bufferizza quello di de-  *
      *                      * fault                                   *
      *                      *                                         *
      *                      * ___ DA SISTEMARE ___ dipendenza ???     *
      *                      *-----------------------------------------*
______*    if        w-let-arc-ybf-flg    =    spaces
______*              move  w-let-arc-ybf-dsl
______*                                   to   w-agg-mag-bfo-dsl
______*    else      move  w-agg-mag-bfo-ddd
______*                                   to   w-agg-mag-bfo-dsl      .
      
           move      w-agg-mag-bfo-ddd    to   w-agg-mag-bfo-dsl      .
       agg-mag-bfo-140.
      *                  *---------------------------------------------*
      *                  * Controllo causale di magazzino              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se causale di magazzino non esisten-    *
      *                      * te : riciclo                            *
      *                      *-----------------------------------------*
           if        w-agg-mag-bfo-cam    =    zero
                     go to agg-mag-bfo-100.
      *                      *-----------------------------------------*
      *                      * Lettura record [zmc]                    *
      *                      *-----------------------------------------*
           move      w-agg-mag-bfo-cam    to   w-let-arc-zmc-cod      .
           perform   let-arc-zmc-000      thru let-arc-zmc-999        .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : riciclo         *
      *                      *-----------------------------------------*
           if        w-let-arc-zmc-flg    not  = spaces
                     go to agg-mag-bfo-100.
      *                      *-----------------------------------------*
      *                      * Se tipo trattamento valore della cau-   *
      *                      * sale non per impostazione diretta : ri- *
      *                      * ciclo                                   *
      *                      *-----------------------------------------*
           if        w-let-arc-zmc-trv    not  = "I"
                     go to agg-mag-bfo-100.
      *                      *-----------------------------------------*
      *                      * Se causale non di carico : riciclo      *
      *                      *-----------------------------------------*
           if        w-let-arc-zmc-tip    not  = 01
                     go to agg-mag-bfo-100.
       agg-mag-bfo-160.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di magazzino pre-   *
      *                  * cedente                                     *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      rf-bft-dat-reg       to   l-mag-300-dat-reg      .
           move      rf-bft-prt-mag       to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       agg-mag-bfo-200.
      *                  *---------------------------------------------*
      *                  * Scrittura testata nuovo movimento di magaz- *
      *                  * zino                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione testata                 *
      *                      *-----------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Scrittura testata                       *
      *                      *-----------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      rf-bft-dat-reg       to   l-mag-300-dat-reg      .
           move      rf-bft-prt-mag       to   l-mag-300-num-prt      .
           move      rf-bft-cod-dpz       to   l-mag-300-cod-dpz      .
           move      w-agg-mag-bfo-cam    to   l-mag-300-cod-cau      .
           move      w-agg-mag-bfo-ctm    to   l-mag-300-cod-ctm      .
           move      rf-bft-dat-doc       to   l-mag-300-dat-doc      .
           move      rf-bft-num-doc       to   l-mag-300-num-doc      .
           move      w-agg-mag-bfo-dsl    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           move      rf-bft-tip-arc       to   l-mag-300-tip-arc      .
           move      rf-bft-cod-arc       to   l-mag-300-cod-arc      .
           move      rf-bft-dpz-arc       to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to agg-mag-bfo-600.
       agg-mag-bfo-300.
      *                  *---------------------------------------------*
      *                  * Scrittura righe nuovo movimento di magazzi- *
      *                  * no                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione contatore righe scrit- *
      *                      * te                                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-mag-bfo-ctr      .
      *                      *-----------------------------------------*
      *                      * Start su file [bfr]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bft-num-prt       to   rf-bfr-num-prt         .
           move      zero                 to   rf-bfr-num-prg         .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-mag-bfo-500.
       agg-mag-bfo-320.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale record [bfr]        *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                          *-------------------------------------*
      *                          * Test se 'At End'                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-mag-bfo-500.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-bfr-num-prt       not  = rf-bft-num-prt
                     go to agg-mag-bfo-500.
      *                      *-----------------------------------------*
      *                      * Selezioni sul record                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Selezione su tipo riga              *
      *                          *-------------------------------------*
           move      rf-bfr-tip-rig       to   w-agg-mag-bfo-tri      .
