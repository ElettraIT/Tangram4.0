           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-sdc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo saldaconto : Quantita' fatturata       *
      *    *-----------------------------------------------------------*
       acc-qta-ffo-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-brb-tip-rig
                    (w-sdc-ctr-rig)       =    "A" or
                     w-brb-tip-rig
                    (w-sdc-ctr-rig)       =    "C"
                     go to acc-qta-ffo-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-brb-qta-ffo
                    (w-sdc-ctr-rig)       to   w-sav-qta-ffo          .
           move      w-brb-flg-fzs
                    (w-sdc-ctr-rig)       to   w-sav-flg-fzs          .
       acc-qta-ffo-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-brb-dec-qta
                    (w-sdc-ctr-rig)       to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      54                   to   v-pos                  .
           if        w-sdc-ctr-rig        >    1      
                     move   "UP  "        to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-sdc-npg-dat        <    w-sdc-npg-max
                     move   "NXSC"        to   v-pfk (06)             .
           if        w-sdc-npg-dat        >    1
                     move   "PRSC"        to   v-pfk (07)             .
           if        w-sdc-ctr-rig        <    w-brb-num-ele
                     move   "TAB "        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
           move      "SLCT"               to   v-pfk (10)             .
           move      "[1] "               to   v-pfk (14)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-brb-qta-ffo
                    (w-sdc-ctr-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     go to acc-qta-ffo-999.
       acc-qta-ffo-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-brb-qta-ffo
                                              (w-sdc-ctr-rig)         .
       acc-qta-ffo-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' fra segno quantita'*
      *                  * in fattura e segno quantita' in bolla       *
      *                  *---------------------------------------------*
           if        w-brb-qta-bfo
                    (w-sdc-ctr-rig)       >    zero and
                     w-brb-qta-ffo
                    (w-sdc-ctr-rig)       <    zero
                     go to acc-qta-ffo-100
           else if   w-brb-qta-bfo
                    (w-sdc-ctr-rig)       <    zero and
                     w-brb-qta-ffo
                    (w-sdc-ctr-rig)       >    zero
                     go to acc-qta-ffo-100.
      *                  *---------------------------------------------*
      *                  * Se Pf1 : controllo che il valore impostato  *
      *                  * non sia zero                                *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-qta-ffo-420.
           if        w-brb-qta-ffo
                    (w-sdc-ctr-rig)       =    zero
                     go to acc-qta-ffo-100.
       acc-qta-ffo-420.
      *                  *---------------------------------------------*
      *                  * Se Slct : controllo che il valore impostato *
      *                  * sia uguale al precedente                    *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-qta-ffo-600.
           if        w-brb-qta-ffo
                    (w-sdc-ctr-rig)       not  = w-sav-qta-ffo
                     move   w-sav-qta-ffo to   w-brb-qta-ffo
                                              (w-sdc-ctr-rig)
                     go to  acc-qta-ffo-100.
       acc-qta-ffo-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Quantita' in bolla e quantita' in fattura   *
      *                  * in work di comodo senza segno               *
      *                  *---------------------------------------------*
           move      w-brb-qta-bfo
                    (w-sdc-ctr-rig)       to   w-qss-qta-bfo          .
           move      w-brb-qta-ffo
                    (w-sdc-ctr-rig)       to   w-qss-qta-ffo          .
      *                  *---------------------------------------------*
      *                  * Se Slct                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to  acc-qta-ffo-620.
      *                      *-----------------------------------------*
      *                      * Se valore gia' presente                 *
      *                      *-----------------------------------------*
           if        w-brb-qta-ffo
                    (w-sdc-ctr-rig)       =    zero
                     go to acc-qta-ffo-610.
      *                          *-------------------------------------*
      *                          * Quantita' in fattura                *
      *                          *-------------------------------------*
           move      zero                 to   w-brb-qta-ffo
                                              (w-sdc-ctr-rig)         .
           move      zero                 to   w-qss-qta-ffo          .
      *                          *-------------------------------------*
      *                          * Flag di saldo forzato               *
      *                          *-------------------------------------*
           move      spaces               to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-700.
       acc-qta-ffo-610.
      *                      *-----------------------------------------*
      *                      * Se valore non presente                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' in fattura                *
      *                          *-------------------------------------*
           move      w-brb-qta-bfo
                    (w-sdc-ctr-rig)       to   w-brb-qta-ffo
                                              (w-sdc-ctr-rig)         .
           move      w-brb-qta-bfo
                    (w-sdc-ctr-rig)       to   w-qss-qta-ffo          .
      *                          *-------------------------------------*
      *                          * Flag di saldo forzato               *
      *                          *-------------------------------------*
           move      spaces               to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-700.
       acc-qta-ffo-620.
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to  acc-qta-ffo-640.
      *                      *-----------------------------------------*
      *                      * Flag di saldo forzato                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se quantita' in fattura maggiore o  *
      *                          * uguale a quella in bolla : spaces   *
      *                          *-------------------------------------*
           if        w-qss-qta-ffo        <    w-qss-qta-bfo
                     go to  acc-qta-ffo-630.
           move      spaces               to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-700.
       acc-qta-ffo-630.
      *                          *-------------------------------------*
      *                          * Altrimenti : si inverte il valore   *
      *                          * attuale del flag                    *
      *                          *-------------------------------------*
           if        w-brb-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     move  "S"            to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)
           else      move  spaces         to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-700.
       acc-qta-ffo-640.
      *                  *---------------------------------------------*
      *                  * Se Return o altri tasti funzione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di saldo forzato                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se valore impostato pari al prece-  *
      *                          * dente : nessuna variazione          *
      *                          *-------------------------------------*
           if        w-brb-qta-ffo
                    (w-sdc-ctr-rig)        not  = w-sav-qta-ffo
                     go to  acc-qta-ffo-650.
           go to     acc-qta-ffo-700.
       acc-qta-ffo-650.
      *                          *-------------------------------------*
      *                          * Se valore impostato diverso dal     *
      *                          * precedente                          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in fattura maggio- *
      *                              * re o uguale a quella in bolla : *
      *                              * spaces                          *
      *                              *---------------------------------*
           if        w-qss-qta-ffo        <    w-qss-qta-bfo
                     go to  acc-qta-ffo-655.
           move      spaces               to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-700.
       acc-qta-ffo-655.
      *                              *---------------------------------*
      *                              * Altrimenti : valore inalterato  *
      *                              *---------------------------------*
           go to     acc-qta-ffo-700.
       acc-qta-ffo-700.
      *                  *---------------------------------------------*
      *                  * Trattamento altri valori riga               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag indicatore di residuo              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato a 'S'      *
      *                          *-------------------------------------*
           if        w-brb-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     go to acc-qta-ffo-710.
           move      spaces               to   w-brb-flg-idr
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-720.
       acc-qta-ffo-710.
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato diverso da *
      *                          * 'S'                                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in fattura maggio- *
      *                              * re o uguale a quella in bolla : *
      *                              * spaces                          *
      *                              *---------------------------------*
           if        w-qss-qta-ffo        <    w-qss-qta-bfo
                     go to  acc-qta-ffo-715.
           move      spaces               to   w-brb-flg-idr
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-720.
       acc-qta-ffo-715.
      *                              *---------------------------------*
      *                              * Altrimenti : il valore viene    *
      *                              * forzato a '<'                   *
      *                              *---------------------------------*
           move      "<"                  to   w-brb-flg-idr
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-720.
       acc-qta-ffo-720.
      *                      *-----------------------------------------*
      *                      * Flag indicatore di saldo                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato a 'S'      *
      *                          *-------------------------------------*
           if        w-brb-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     go to acc-qta-ffo-730.
           move      "S"                  to   w-brb-flg-ids
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-740.
       acc-qta-ffo-730.
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato diverso da *
      *                          * 'S'                                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in fattura minore  *
      *                              * o uguale a quella in bolla :    *
      *                              * viene forzato il valore spaces  *
      *                              *---------------------------------*
           if        w-qss-qta-ffo        >    w-qss-qta-bfo
                     go to  acc-qta-ffo-735.
           move      spaces               to   w-brb-flg-ids
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-740.
       acc-qta-ffo-735.
      *                              *---------------------------------*
      *                              * Altrimenti : il valore viene    *
      *                              * forzato a "+"                   *
      *                              *---------------------------------*
           move      "+"                  to   w-brb-flg-ids
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-740.
       acc-qta-ffo-740.
      *                      *-----------------------------------------*
      *                      * Quantita' residua                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato a 'S'      *
      *                          *-------------------------------------*
           if        w-brb-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     go to acc-qta-ffo-750.
           move      zero                 to   w-brb-qta-res
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-760.
       acc-qta-ffo-750.
      *                          *-------------------------------------*
      *                          * Se flag di saldo forzato diverso da *
      *                          * 'S'                                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se quantita' in fattura maggio- *
      *                              * re o uguale a quella in bolla : *
      *                              * spaces                          *
      *                              *---------------------------------*
           if        w-qss-qta-ffo        <    w-qss-qta-bfo
                     go to  acc-qta-ffo-755.
           move      zero                 to   w-brb-qta-res
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-760.
       acc-qta-ffo-755.
      *                              *---------------------------------*
      *                              * Altrimenti : il valore e' pari  *
      *                              * alla differenza tra quantita'   *
      *                              * in bolla e quantita' in fattura *
      *                              *---------------------------------*
           subtract  w-brb-qta-ffo
                    (w-sdc-ctr-rig)       from w-brb-qta-bfo
                                              (w-sdc-ctr-rig)
                                        giving w-brb-qta-res
                                              (w-sdc-ctr-rig)         .
           go to     acc-qta-ffo-760.
       acc-qta-ffo-760.
      *                  *---------------------------------------------*
      *                  * Visualizzazione valori riga                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Quantita' in fattura                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-brb-qta-ffo
                    (w-sdc-ctr-rig)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Flag indicatore di residuo              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-brb-flg-idr
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Flag indicatore di saldo                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-brb-flg-ids
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Quantita' residua                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing quantita'                   *
      *                          *-------------------------------------*
           move      "ED"                 to   w-edt-qta-inc-ope      .
           move      w-brb-qta-res
                    (w-sdc-ctr-rig)       to   w-edt-qta-inc-qta      .
           move      w-brb-dec-qta
                    (w-sdc-ctr-rig)       to   w-edt-qta-inc-dec      .
           move      "S"                  to   w-edt-qta-inc-sgn      .
           move      11                   to   w-edt-qta-inc-car      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      70                   to   v-pos                  .
           move      w-edt-qta-inc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-qta-ffo-800.
       acc-qta-ffo-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo saldaconto : Si/No Addebito o Commento *
      *    *-----------------------------------------------------------*
       acc-snx-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-brb-tip-rig
                    (w-sdc-ctr-rig)       not  = "A" and
                     w-brb-tip-rig
                    (w-sdc-ctr-rig)       not  = "C"
                     go to acc-snx-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-brb-snx-aoc
                    (w-sdc-ctr-rig)       to   w-sav-snx-aoc          .
           move      w-brb-flg-fzs
                    (w-sdc-ctr-rig)       to   w-sav-flg-fzs          .
      *                  *---------------------------------------------*
      *                  * Default a 'Si'                              *
      *                  *---------------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       =    spaces
                     move  "S"            to   w-brb-snx-aoc
                                              (w-sdc-ctr-rig)         .
       acc-snx-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      59                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
           if        w-sdc-ctr-rig        >    1      
                     move   "UP  "        to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-sdc-npg-dat        <    w-sdc-npg-max
                     move   "NXSC"        to   v-pfk (06)             .
           if        w-sdc-npg-dat        >    1
                     move   "PRSC"        to   v-pfk (07)             .
           if        w-sdc-ctr-rig        <    w-brb-num-ele
                     move   "TAB "        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
       acc-snx-aoc-150.
           move      "SLCT"               to   v-pfk (10)             .
           move      "[1] "               to   v-pfk (14)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-brb-snx-aoc
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     go to acc-snx-aoc-999.
       acc-snx-aoc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-brb-snx-aoc
                                              (w-sdc-ctr-rig)         .
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to  acc-snx-aoc-300.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       not  = w-sav-snx-aoc
                     move   w-sav-snx-aoc to   w-brb-snx-aoc
                                              (w-sdc-ctr-rig)
                     go to  acc-snx-aoc-100.
      *                  *---------------------------------------------*
      *                  * Se valore presente lo si abblenca, altri-   *
      *                  * menti lo si forza a 'S'                     *
      *                  *---------------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       not  = spaces
                     move  spaces         to   w-brb-snx-aoc
                                              (w-sdc-ctr-rig)
           else      move  "S"            to   w-brb-snx-aoc
                                              (w-sdc-ctr-rig)         .
       acc-snx-aoc-300.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to  acc-snx-aoc-400.
      *                  *---------------------------------------------*
      *                  * Flag di saldo forzato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se indicatore a 'S' : spaces            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se quantita' in fattura maggiore o  *
      *                          * uguale a quella in bolla : spaces   *
      *                          *-------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)        not  = "S"
                     go to  acc-snx-aoc-330.
           move      "-"                   to   w-brb-flg-fzs
                                               (w-sdc-ctr-rig)        .
           go to     acc-snx-aoc-400.
       acc-snx-aoc-330.
      *                          *-------------------------------------*
      *                          * Altrimenti : si inverte il valore   *
      *                          * attuale del flag                    *
      *                          *-------------------------------------*
           if        w-brb-flg-fzs
                    (w-sdc-ctr-rig)       =    spaces
                     move  "S"            to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)
           else      move  "-"            to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
           go to     acc-snx-aoc-400.
       acc-snx-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       not  = "S" and
                     w-brb-snx-aoc
                    (w-sdc-ctr-rig)       not  = "N" and
                     w-brb-snx-aoc
                    (w-sdc-ctr-rig)       not  = spaces
                     go to acc-snx-aoc-100.
       acc-snx-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore                      *
      *                  *---------------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       =    "N"
                     move  spaces         to   w-brb-snx-aoc
                                              (w-sdc-ctr-rig)         .
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di forzatura a saldo   *
      *                  *---------------------------------------------*
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       not  = spaces
                     move  spaces         to   w-brb-flg-fzs
                                              (w-sdc-ctr-rig)         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione Si/No addebito o commento   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      59                   to   v-pos                  .
           if        w-brb-snx-aoc
                    (w-sdc-ctr-rig)       =    "S"
                     move  "Si"           to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Flag indicatore di forzatura a saldo        *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-brb-flg-fzs
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-snx-aoc-800.
       acc-snx-aoc-999.
           exit.

      *    *===========================================================*
      *    * Caricamento righe in catena                               *
      *    *-----------------------------------------------------------*
       car-rig-cat-000.
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer righe bolla           *
      *              *-------------------------------------------------*
           move      zero                 to   w-crc-wrk-ctr          .
       car-rig-cat-100.
           add       1                    to   w-crc-wrk-ctr          .
           if        w-crc-wrk-ctr        >    w-brb-num-ele
                     go to car-rig-cat-800.
      *                  *---------------------------------------------*
      *                  * Selezione su righe bolla nel buffer         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo riga    *
      *                      *-----------------------------------------*
           if        w-brb-tip-rig
                    (w-crc-wrk-ctr)       =    "A" or
                     w-brb-tip-rig
                    (w-crc-wrk-ctr)       =    "C"
                     go to car-rig-cat-110
           else      go to car-rig-cat-120.
       car-rig-cat-110.
      *                      *-----------------------------------------*
      *                      * Se riga di Addebito o Commento          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se si/no da riportare          *
      *                          *-------------------------------------*
           if        w-brb-snx-aoc
                    (w-crc-wrk-ctr)       not  = "S"
                     go to car-rig-cat-115.
      *                          *-------------------------------------*
      *                          * Ad append                           *
      *                          *-------------------------------------*
           go to     car-rig-cat-150.
       car-rig-cat-115.
      *                          *-------------------------------------*
      *                          * Test se forzatura saldo             *
      *                          *-------------------------------------*
           if        w-brb-flg-fzs
                    (w-crc-wrk-ctr)       =    spaces
                     go to car-rig-cat-100.
      *                          *-------------------------------------*
      *                          * Update riga bolla                   *
      *                          *-------------------------------------*
           perform   car-rig-cat-urb-000  thru car-rig-cat-urb-999    .
      *                          *-------------------------------------*
      *                          * A riciclo                           *
      *                          *-------------------------------------*
           go to     car-rig-cat-100.
       car-rig-cat-120.
      *                      *-----------------------------------------*
      *                      * Se altro tipo riga                      *
      *                      *-----------------------------------------*
           if        w-brb-qta-ffo
                    (w-crc-wrk-ctr)       =    zero
                     go to car-rig-cat-100.
           go to     car-rig-cat-150.
       car-rig-cat-150.
      *                  *---------------------------------------------*
      *                  * Append in catena                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Append non possibile : uscita con    *
      *                      * errore                                  *
      *                      *-----------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to  car-rig-cat-900.
      *                      *-----------------------------------------*
      *                      * Append                                  *
      *                      *-----------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-rig-cat-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [bfr]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [bfr]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-gen-prt-bfo        to   rf-bfr-num-prt         .
           move      w-brb-num-prg
                    (w-crc-wrk-ctr)       to   rf-bfr-num-prg         .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
       car-rig-cat-300.
      *                  *---------------------------------------------*
      *                  * Composizione riga                           *
      *                  *---------------------------------------------*
       car-rig-cat-400.
      *                      *-----------------------------------------*
      *                      * Valori contenuti direttamente in re-    *
      *                      * cord [bfr]                              *
      *                      *-----------------------------------------*
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
           move      rf-bfr-bld-flb       to   w-rig-bld-flb (1)      .
           move      rf-bfr-bld-tpb       to   w-rig-bld-tpb (1)      .
           move      rf-bfr-bld-rgb       to   w-rig-bld-rgb (1)      .
           move      rf-bfr-tip-rig       to   w-rig-tip-rig (1)      .
           perform   dec-tip-rig-000      thru dec-tip-rig-999        .
           move      rf-bfr-tip-mag       to   w-rig-tip-mag (1)      .
           move      rf-bfr-num-mag       to   w-rig-num-mag (1)      .
           move      rf-bfr-alf-mag       to   w-rig-alf-mag (1)      .
           move      rf-bfr-sgl-vrn       to   w-rig-sgl-vrn (1)      .
           move      rf-bfr-fda-pif       to   w-rig-fda-pif (1)      .
           move      rf-bfr-cop-sfn       to   w-rig-cop-sfn (1)      .
           move      rf-bfr-snx-tum       to   w-rig-snx-tum (1)      .
           move      rf-bfr-umf-tum       to   w-rig-umf-tum (1)      .
           move      rf-bfr-nde-tum       to   w-rig-nde-tum (1)      .
           move      rf-bfr-cmo-tum       to   w-rig-cmo-tum (1)      .
           move      rf-bfr-cdi-tum       to   w-rig-cdi-tum (1)      .
           move      rf-bfr-des-ext       to   w-rig-des-ext (1)      .
           move      rf-bfr-des-rig       to   w-rig-des-rig (1)      .
