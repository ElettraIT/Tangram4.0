      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-cd3-600.
      *                      *-----------------------------------------*
      *                      * Sottoconto iva a debito su acquisti     *
      *                      * intracomunitari                         *
      *                      *-----------------------------------------*
           move      w-ref-iva-dai        to   w-rg2-cod-con (1)      .
           move      w-ref-iva-dai-des    to   w-rg2-des-con (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-cd3-900.
       car-cat-rmc-cd3-600.
      *                  *---------------------------------------------*
      *                  * Se bolla doganale                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo operazione                 *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-cd3-900.
      *                      *-----------------------------------------*
      *                      * Sottoconto fornitore                    *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc (1)    to   w-rg2-cod-con (1)      .
           move      w-tes-cod-arc-rag (1)
                                          to   w-rg2-des-con (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-cd3-900.
       car-cat-rmc-cd3-900.
      *              *-------------------------------------------------*
