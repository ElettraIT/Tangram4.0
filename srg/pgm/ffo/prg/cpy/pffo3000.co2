      *    *                                                           *
      *    * Subroutine di trattamento Tipo conto                      *
      *    *                                                           *
      *    * Riga contabile 2                                          *
      *    *-----------------------------------------------------------*
       car-cat-rmc-tc2-000.
      *              *-------------------------------------------------*
      *              * Se documento Italia                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-tc2-200.
      *                  *---------------------------------------------*
      *                  * Tipo conto : 'G'                            *
      *                  *---------------------------------------------*
           move      "G"                  to   w-rg2-tip-con (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-tc2-900.
       car-cat-rmc-tc2-200.
      *              *-------------------------------------------------*
      *              * Se documento CEE o Reverse Charge               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01 and
                     w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-tc2-400.
           if        w-tes-cod-tmf-tpv    =    01   and
                     w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-tc2-400.
      *                  *---------------------------------------------*
      *                  * Tipo conto : 'G'                            *
      *                  *---------------------------------------------*
           move      "G"                  to   w-rg2-tip-con (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-tc2-900.
       car-cat-rmc-tc2-400.
      *              *-------------------------------------------------*
      *              * Se bolla doganale                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-tc2-900.
      *                  *---------------------------------------------*
      *                  * Se imposta presente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-te2-tot-imp (1)    =    zero           or
                     w-te2-tot-imp (1)    =    w-te2-tot-ind (1)
                     go to car-cat-rmc-tc2-700.
      *                      *-----------------------------------------*
      *                      * Tipo conto : 'G'                        *
      *                      *-----------------------------------------*
           move      "G"                  to   w-rg2-tip-con (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-tc2-900.
       car-cat-rmc-tc2-700.
      *                  *---------------------------------------------*
      *                  * Se imposta non presente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo conto : 'F'                        *
      *                      *-----------------------------------------*
           move      "F"                  to   w-rg2-tip-con (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-tc2-900.
       car-cat-rmc-tc2-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-rmc-tc2-999.
       car-cat-rmc-tc2-999.
           exit.

