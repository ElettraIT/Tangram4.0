      *              *-------------------------------------------------*
           go to     car-cat-rmc-cd3-999.
       car-cat-rmc-cd3-999.
           exit.

      *    *===========================================================*
      *    * Caricamento catena righe movimento di contabilita'        *
      *    *                                                           *
      *    * Subroutine di trattamento Flag di Dare/Avere e importo    *
      *    *                                                           *
      *    * Riga contabile 1                                          *
      *    *-----------------------------------------------------------*
       car-cat-rmc-fd1-000.
      *              *-------------------------------------------------*
      *              * Se documento Italia                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01 or
                     w-tes-cod-tmf-rfp    not  = spaces
                     go to car-cat-rmc-fd1-200.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "D"            to   w-rg2-dar-ave (1)
           else      move  "A"            to   w-rg2-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * Importo movimento: Totale castelletto iva   *
      *                  *---------------------------------------------*
           move      w-te2-tot-doc (1)    to   w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd1-900.
       car-cat-rmc-fd1-200.
      *              *-------------------------------------------------*
      *              * Se documento CEE o Reverse Charge               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01 and
                     w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-fd1-400.
           if        w-tes-cod-tmf-tpv    =    01   and
                     w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-fd1-400.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "D"            to   w-rg2-dar-ave (1)
           else      move  "A"            to   w-rg2-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * Importo movimento: Totale imponibile        *
      *                  *---------------------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd1-900.
       car-cat-rmc-fd1-400.
      *              *-------------------------------------------------*
      *              * Se documento Estero                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 03
                     go to car-cat-rmc-fd1-600.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "D"            to   w-rg2-dar-ave (1)
           else      move  "A"            to   w-rg2-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * Importo movimento: Totale fattura fornitore *
      *                  *---------------------------------------------*
           move      w-tes-imp-doc (1)    to   w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd1-900.
       car-cat-rmc-fd1-600.
      *              *-------------------------------------------------*
      *              * Se bolla doganale                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-fd1-900.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           move      "A"                  to   w-rg2-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * Importo movimento: Totale castelletto iva   *
      *                  *---------------------------------------------*
           move      w-te2-tot-doc (1)    to   w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd1-900.
       car-cat-rmc-fd1-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-rmc-fd1-999.
       car-cat-rmc-fd1-999.
           exit.

      *    *===========================================================*
