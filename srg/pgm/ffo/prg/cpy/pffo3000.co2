                     w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-fd2-700.
      *                      *-----------------------------------------*
      *                      * Flag di Dare/Avere                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
      *                      *-----------------------------------------*
      *                      * Importo movimento: Totale imposta       *
      *                      *                    deducibile           *
      *                      *-----------------------------------------*
           subtract  w-te2-tot-ind (1)    from w-te2-tot-imp (1)
                                        giving w-rg2-imp-mov (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-fd2-900.
       car-cat-rmc-fd2-700.
      *                  *---------------------------------------------*
      *                  * Se bolla doganale                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-fd2-900.
      *                      *-----------------------------------------*
      *                      * Flag di Dare/Avere                      *
      *                      *-----------------------------------------*
           move      "D"                  to   w-rg2-dar-ave (1)      .
      *                      *-----------------------------------------*
      *                      * Importo movimento: Totale imposta       *
      *                      *                    deducibile           *
      *                      *-----------------------------------------*
           subtract  w-te2-tot-ind (1)    from w-te2-tot-imp (1)
                                        giving w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd2-900.
       car-cat-rmc-fd2-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-rmc-fd2-999.
       car-cat-rmc-fd2-999.
           exit.

      *    *===========================================================*
      *    * Caricamento catena righe movimento di contabilita'        *
      *    *                                                           *
      *    * Subroutine di trattamento Flag di Dare/Avere e importo    *
      *    *                                                           *
      *    * Riga contabile 3                                          *
      *    *-----------------------------------------------------------*
       car-cat-rmc-fd3-000.
      *              *-------------------------------------------------*
      *              * Se documento CEE o Reverse Charge               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01 and
                     w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-fd3-400.
           if        w-tes-cod-tmf-tpv    =    01   and
                     w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-fd3-400.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "D"            to   w-rg2-dar-ave (1)
           else      move  "A"            to   w-rg2-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * Importo movimento: Totale imposta deducib.  *
      *                  *---------------------------------------------*
           subtract  w-te2-tot-ind (1)    from w-te2-tot-imp (1)
                                        giving w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd3-900.
       car-cat-rmc-fd3-400.
      *              *-------------------------------------------------*
      *              * Se bolla doganale                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-fd3-900.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           move      "D"                  to   w-rg2-dar-ave (1)
      *                  *---------------------------------------------*
      *                  * Importo movimento: Totale imponibile +      *
      *                  *                    imposta non deducibile   *
      *                  *---------------------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
           add       w-te2-tot-ind (1)    to   w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-fd3-900.
       car-cat-rmc-fd3-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-rmc-fd3-999.
       car-cat-rmc-fd3-999.
           exit.

      *    *===========================================================*
      *    * Caricamento catena righe movimento di contabilita'        *
      *    *                                                           *
      *    * Subroutine di trattamento Contropartite contabili         *
      *    *                                                           *
      *    * Se no impostazione righe del documento                    *
      *    *-----------------------------------------------------------*
       car-cat-rmc-cpc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione riga                            *
      *              *-------------------------------------------------*
           perform   nor-nok-rg2-000      thru nor-nok-rg2-999        .
       car-cat-rmc-cpc-100.
      *              *-------------------------------------------------*
      *              * Composizione riga                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo conto                                  *
      *                  *---------------------------------------------*
           move      "G"                  to   w-rg2-tip-con (1)      .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione conto                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Nota di accredito                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-tdo    not  = 03
                     go to car-cat-rmc-cpc-200.
      *                          *-------------------------------------*
      *                          * Sottoconto Resi su Acquisti         *
      *                          *-------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     move  w-tes-ctp-acq (1)
                                          to   w-rg2-cod-con (1)
                     move  w-tes-ctp-acq-des (1)
                                          to   w-rg2-des-con (1)
           else      move  w-ref-res-acq  to   w-rg2-cod-con (1)
                     move  w-ref-res-acq-des
                                          to   w-rg2-des-con (1)      .
      *                          *-------------------------------------*
      *                          * A commento                          *
      *                          *-------------------------------------*
           go to     car-cat-rmc-cpc-300.
       car-cat-rmc-cpc-200.
      *                      *-----------------------------------------*
      *                      * Se Fattura o Nota di addebito           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Sottoconto Acquisti                 *
      *                          *-------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     move  w-tes-ctp-acq (1)
                                          to   w-rg2-cod-con (1)
                     move  w-tes-ctp-acq-des (1)
                                          to   w-rg2-des-con (1)
           else      move  w-ref-stc-acq  to   w-rg2-cod-con (1)
                     move  w-ref-stc-acq-des
                                          to   w-rg2-des-con (1)      .
      *                          *-------------------------------------*
      *                          * A commento                          *
      *                          *-------------------------------------*
           go to     car-cat-rmc-cpc-300.
       car-cat-rmc-cpc-300.
      *                  *---------------------------------------------*
      *                  * Commento in riga                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
            if       w-prs-rsf-icr        =    "S"
                     move  w-tes-cod-arc-rag (1)
                                          to   w-rg2-com-rig (1)      .
       car-cat-rmc-cpc-400.
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere e importo                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di Dare/Avere                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
      *                      *-----------------------------------------*
      *                      * Importo                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se non esiste imposta deducibile    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        w-te2-tot-imp (1)    not  = zero          and
                     w-te2-tot-imp (1)    not  = w-te2-tot-ind (1)
                     go to car-cat-rmc-cpc-600.
      *                              *---------------------------------*
      *                              * Se documento Italia             *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-cpc-430.
           if        w-tes-cod-tmf-rfp    =    "R"
                     go to car-cat-rmc-cpc-420.
      *                              *---------------------------------*
      *                              * Totale documento                *
      *                              *---------------------------------*
           move      w-te2-tot-doc (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-420.
      *                              *---------------------------------*
      *                              * Se documento Reverse Charge     *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-cpc-430.
           if        w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-cpc-430.
      *                              *---------------------------------*
      *                              * Totale imponibile               *
      *                              *---------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-430.
      *                              *---------------------------------*
      *                              * Se documento CEE                *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-cpc-440.
      *                              *---------------------------------*
      *                              * Totale imponibile               *
      *                              *---------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-440.
      *                              *---------------------------------*
      *                              * Se documento Estero             *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 03
                     go to car-cat-rmc-cpc-900.
      *                              *---------------------------------*
      *                              * Importo documento               *
      *                              *---------------------------------*
           move      w-tes-imp-doc (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-600.
      *                          *-------------------------------------*
      *                          * Se esiste imposta deducibile        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se documento Italia             *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-cpc-630.
           if        w-tes-cod-tmf-rfp    =    "R"
                     go to car-cat-rmc-cpc-620.
      *                              *---------------------------------*
      *                              * Totale imponibile + imposta non *
      *                              * deducibile                      *
      *                              *---------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
           add       w-te2-tot-ind (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-620.
      *                              *---------------------------------*
      *                              * Se documento Reverse Charge     *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-cpc-630.
           if        w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-cpc-630.
      *                              *---------------------------------*
      *                              * Totale imponibile               *
      *                              *---------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-630.
      *                              *---------------------------------*
      *                              * Se documento CEE                *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-cpc-900.
      *                              *---------------------------------*
      *                              * Totale imponibile               *
      *                              *---------------------------------*
           move      w-te2-tot-ibl (1)    to   w-rg2-imp-mov (1)      .
      *                              *---------------------------------*
      *                              * Ad uscita                       *
      *                              *---------------------------------*
           go to     car-cat-rmc-cpc-900.
       car-cat-rmc-cpc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-rmc-cpc-999.
       car-cat-rmc-cpc-999.
           exit.



