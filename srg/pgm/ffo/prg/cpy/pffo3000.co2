           exit.

      *    *===========================================================*
      *    * Caricamento catena righe movimento di contabilita'        *
      *    *                                                           *
      *    * Subroutine di trattamento Codice e descrizione conto      *
      *    *                                                           *
      *    * Riga contabile 2                                          *
      *    *-----------------------------------------------------------*
       car-cat-rmc-cd2-000.
      *              *-------------------------------------------------*
      *              * Se non esiste imposta deducibile                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-te2-tot-imp (1)    not  = zero          and
                     w-te2-tot-imp (1)    not  = w-te2-tot-ind (1)
                     go to car-cat-rmc-cd2-500.
       car-cat-rmc-cd2-300.
      *                  *---------------------------------------------*
      *                  * Se bolla doganale                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo operazione                 *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-cd2-400.
      *                      *-----------------------------------------*
      *                      * Sottoconto Fornitore                    *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc (1)    to   w-rg2-cod-con (1)      .
           move      w-tes-cod-arc-rag (1)
                                          to   w-rg2-des-con (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-cd2-900.
       car-cat-rmc-cd2-400.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-cd2-900.
       car-cat-rmc-cd2-500.
      *              *-------------------------------------------------*
      *              * Se esiste imposta deducibile                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se documento Italia                         *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-cd2-600.
      *                  *---------------------------------------------*
      *                  * Sottoconto iva acquisti                     *
      *                  *---------------------------------------------*
           move      w-ref-iva-acq        to   w-rg2-cod-con (1)      .
           move      w-ref-iva-acq-des    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-cd2-900.
       car-cat-rmc-cd2-600.
      *                  *---------------------------------------------*
      *                  * Se documento in Reverse Charge              *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-cd2-700.
           if        w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-cd2-700.
      *                  *---------------------------------------------*
      *                  * Sottoconto iva a credito su acquisti in     *
      *                  * Reverse Charge                              *
      *                  *---------------------------------------------*
           move      w-ref-iva-car        to   w-rg2-cod-con (1)      .
           move      w-ref-iva-car-des    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-cd2-900.
       car-cat-rmc-cd2-700.
      *                  *---------------------------------------------*
      *                  * Se documento CEE                            *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-cd2-800.
      *                  *---------------------------------------------*
      *                  * Sottoconto iva a credito su acquisti su     *
      *                  * su acquisti intracomunitari                 *
      *                  *---------------------------------------------*
           move      w-ref-iva-cai        to   w-rg2-cod-con (1)      .
           move      w-ref-iva-cai-des    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-cd2-900.
       car-cat-rmc-cd2-800.
      *                  *---------------------------------------------*
      *                  * Se bolla doganale                           *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-cd2-900.
      *                  *---------------------------------------------*
      *                  * Sottoconto iva acquisti                     *
      *                  *---------------------------------------------*
           move      w-ref-iva-acq        to   w-rg2-cod-con (1)      .
           move      w-ref-iva-acq-des    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-cd2-900.
       car-cat-rmc-cd2-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-cat-rmc-cd2-999.
       car-cat-rmc-cd2-999.
           exit.

