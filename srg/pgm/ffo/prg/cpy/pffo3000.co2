      *    *===========================================================*
      *    * TRATTAMENTO RIGHE DI PRIMANOTA                            *
      *    *===========================================================*
      *    *===========================================================*
      *    * Determinazione si/no corpo 2 da trattare                  *
      *    *-----------------------------------------------------------*
       snp-co2-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *              *-------------------------------------------------*
      *              * Test se registrazione contabile da eseguire     *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-ccg    not  = zero
                     go to snp-co2-reg-999.
      *                  *---------------------------------------------*
      *                  * Flag di uscita a No                         *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Aggiustamento status impostazioni corpo 2   *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-co2      .
       snp-co2-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione corpo 2 a partire dalla riga con numero      *
      *    * d'ordine : w-cnt-co2-nrg-dac                              *
      *    *-----------------------------------------------------------*
       acc-co2-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-co2      .
      *              *-------------------------------------------------*
      *              * Caricamento catena movimenti di contabilita'    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non da effettuare : oltre                *
      *                  *---------------------------------------------*
           if        w-co2-fdc-rmc (1)    not  = spaces
                     go to acc-co2-reg-010.
      *                  *---------------------------------------------*
      *                  * Richiamo routine                            *
      *                  *---------------------------------------------*
           perform   car-cat-rmc-000      thru car-cat-rmc-999        .
      *                  *---------------------------------------------*
      *                  * Numero riga da accettare : max + 1          *
      *                  *---------------------------------------------*
           move      w-cat-rg2-max        to   w-cnt-co2-nrg-dac      .
           add       1                    to   w-cnt-co2-nrg-dac      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento flag di caricamento righe mo- *
      *                  * vimento contabile                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-co2-fdc-rmc (1)      .
       acc-co2-reg-010.
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-co2-nrg-dac    not  > w-cat-rg2-max
                     go to acc-co2-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append non pos-  *
      *              * sibile si esce con status di uscita "+"         *
      *              *-------------------------------------------------*
           if        w-cat-rg2-app        not  = spaces
                     move  "+"            to   w-cnt-tus-acc-co2
                     go to acc-co2-reg-990.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append possibile *
      *              * si esegue l'operazione di Append                *
      *              *-------------------------------------------------*
           move      w-cat-rg2-max        to   w-cnt-co2-nrg-dac      .
           add       1                    to   w-cnt-co2-nrg-dac      .
           move      "AP"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
       acc-co2-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-co2    =    spaces
                     perform pmt-co2-reg-000
                                          thru pmt-co2-reg-999
                     move    "#"          to   w-cnt-sts-pmt-co2      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrp-dav      .
           add       w-ln2-num-lin-vis    to   w-cnt-co2-nrp-dav      .
           subtract  1                    from w-cnt-co2-nrp-dav      .
           divide    w-ln2-num-lin-vis    into w-cnt-co2-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-co2    =    spaces           or
                     w-cnt-co2-nrp-vis    not  = w-cnt-co2-nrp-dav
                     perform vis-co2-reg-000
                                          thru vis-co2-reg-999
                     move    "#"          to   w-cnt-sts-vis-co2
                     move    w-cnt-co2-nrp-dav
                                          to   w-cnt-co2-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           move      w-cat-rg2-buf        to   w-rg2                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-050.
           perform   nor-nok-rg2-000      thru nor-nok-rg2-999        .
           move      w-rg2-val-aep (1)    to   w-rg2-val-aep (2)      .
       acc-co2-reg-050.
      *              *-------------------------------------------------*
      *              * Routine pre-accettazione riga corpo             *
      *              *-------------------------------------------------*
           perform   pre-rig-co2-000      thru pre-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga d'accettazione *
      *              *-------------------------------------------------*
           perform   pmt-rig-co2-000      thru pmt-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati per riga di accettazione   *
      *              *-------------------------------------------------*
           perform   vis-rig-co2-000      thru vis-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Flag di status impostazione corpo               *
      *              *-------------------------------------------------*
           if        w-cat-rg2-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-co2
           else      move  "#"            to   w-cnt-sts-imp-co2      .
           if        w-cat-rg2-max        =    1        and
                     w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move  spaces         to   w-cnt-sts-imp-co2      .
      *              *-------------------------------------------------*
      *              * Flag di status impostione riga attuale          *
      *              *-------------------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     move  "#"            to   w-cnt-sts-imp-rg2
           else      move  spaces         to   w-cnt-sts-imp-rg2      .
      *              *-------------------------------------------------*
      *              * Indicatore linea in corso di trattamento        *
      *              *-------------------------------------------------*
           move      "I"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da riga corpo       *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rg2      .
       acc-co2-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : primo campo riga corpo  *
      *                  *---------------------------------------------*
           move      "C"                  to   w-cnt-mfu-tip-imp      .
      *                  *---------------------------------------------*
      *                  * Accettazione tipo conto                     *
      *                  *---------------------------------------------*
           perform   acc-tip-con-000      thru acc-tip-con-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-925.
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : altri campi riga corpo  *
      *                  *---------------------------------------------*
           move      "R"                  to   w-cnt-mfu-tip-imp      .
       acc-co2-reg-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Accettazione codice conto                   *
      *                  *---------------------------------------------*
           perform   acc-cod-con-000      thru acc-cod-con-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
       acc-co2-reg-300.
      *                  *---------------------------------------------*
      *                  * Accettazione commento in riga               *
      *                  *---------------------------------------------*
           perform   acc-com-rig-000      thru acc-com-rig-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-200.
       acc-co2-reg-400.
      *                  *---------------------------------------------*
      *                  * Accettazione data riferimento               *
      *                  *---------------------------------------------*
           perform   acc-dat-rif-000      thru acc-dat-rif-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-300.
       acc-co2-reg-500.
      *                  *---------------------------------------------*
      *                  * Accettazione numero riferimento             *
      *                  *---------------------------------------------*
           perform   acc-num-rif-000      thru acc-num-rif-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-400.
       acc-co2-reg-600.
      *                  *---------------------------------------------*
      *                  * Accettazione importo movimento              *
      *                  *---------------------------------------------*
           perform   acc-imp-mov-000      thru acc-imp-mov-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-500.
       acc-co2-reg-800.
      *              *-------------------------------------------------*
      *              * Controllo finale su riga impostata              *
      *              *-------------------------------------------------*
           perform   cnt-tdo-rg2-000      thru cnt-tdo-rg2-999        .
           if        w-cnt-tdo-rg2-flg    not  = spaces
                     move  spaces         to   w-cnt-tdo-rg2-flg
                     move  "UP  "         to   v-key
                     go to acc-co2-reg-200.
       acc-co2-reg-900.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa da interno riga  *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rg2    =    spaces or
                     w-cnt-tus-acc-rg2    =    "S"
                     go to acc-co2-reg-905
           else if   w-cnt-tus-acc-rg2    =    "R"
                     go to acc-co2-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Exit da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga New funzionamento come per Remv *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to acc-co2-reg-915.
      *                      *-----------------------------------------*
      *                      * Se riga non New                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione numero riga         *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
           go to     acc-co2-reg-000.
       acc-co2-reg-905.
      *                  *---------------------------------------------*
      *                  * Se Do da interno riga                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record di tipo New attribuzione del  *
      *                      * numero progressivo per la riga          *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-907.
           perform   prg-rig-co2-000      thru prg-rig-co2-999        .
       acc-co2-reg-907.
      *                      *-----------------------------------------*
      *                      * Routine post-accettazione riga          *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-co2-tip-agg      .
           perform   pos-rig-co2-000      thru pos-rig-co2-999        .
      *                      *-----------------------------------------*
      *                      * Update riga in catena movimenti         *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           move      w-rg2                to   w-cat-rg2-buf          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione linea corpo             *
      *                      *-----------------------------------------*
           move      "R"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                      *-----------------------------------------*
      *                      * Incremento del numero d'ordine della    *
      *                      * riga da accettare                       *
      *                      *-----------------------------------------*
           add       1                    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Remv da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non new : routine post-accetta- *
      *                      * zione riga                              *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to acc-co2-reg-915.
           move      "-"                  to   w-cnt-co2-tip-agg      .
           perform   pos-rig-co2-000      thru pos-rig-co2-999        .
       acc-co2-reg-915.
      *                      *-----------------------------------------*
      *                      * Visualizzazione numero riga a spaces se *
      *                      * si e' in Append                         *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move    "S"          to   w-cnt-co2-tvi-rig
                     move    w-cnt-co2-nrg-dac
                                          to   w-cnt-co2-nrg-dav
                     perform vis-lin-co2-000
                                          thru vis-lin-co2-999        .
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente  visualizzata *
      *                      * a zero per forzare la rivisualizzazione *
      *                      * a meno che non si sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                      *-----------------------------------------*
      *                      * Rimozione record dalla catena           *
      *                      *-----------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                      *-----------------------------------------*
      *                      * Segnale di almeno una modifica          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-acc-flg-aum      .
           go to     acc-co2-reg-000.
       acc-co2-reg-925.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa dal primo campo  *
      *              * di impostazione della riga                      *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rg2    =    "U"
                     go to acc-co2-reg-935
           else if   w-cnt-tus-acc-rg2    =    "D"
                     go to acc-co2-reg-940
           else if   w-cnt-tus-acc-rg2    =    "S"
                     go to acc-co2-reg-945
           else if   w-cnt-tus-acc-rg2    =    "X"
                     go to acc-co2-reg-950
           else if   w-cnt-tus-acc-rg2    =    "I"
                     go to acc-co2-reg-955
           else if   w-cnt-tus-acc-rg2    =    "R"
                     go to acc-co2-reg-960
           else if   w-cnt-tus-acc-rg2    =    "T"
                     go to acc-co2-reg-965
           else if   w-cnt-tus-acc-rg2    =    "B"
                     go to acc-co2-reg-970
           else if   w-cnt-tus-acc-rg2    =    "N"
                     go to acc-co2-reg-975
           else if   w-cnt-tus-acc-rg2    =    "P"
                     go to acc-co2-reg-980
           else if   w-cnt-tus-acc-rg2    =    "."
                     go to acc-co2-reg-985.
       acc-co2-reg-930.
      *                  *---------------------------------------------*
      *                  * Se Exit da primo campo di impostazione riga *
      *                  *---------------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-co2      .
           go to     acc-co2-reg-990.
       acc-co2-reg-935.
      *                  *---------------------------------------------*
      *                  * Se Up da primo campo di impostazione riga   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-936.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces se si e' in Append           *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move    "S"          to   w-cnt-co2-tvi-rig
                     move    w-cnt-co2-nrg-dac
                                          to   w-cnt-co2-nrg-dav
                     perform vis-lin-co2-000
                                          thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione,  a meno che non si sia  *
      *                          * in Append                           *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           go to     acc-co2-reg-937.
       acc-co2-reg-936.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
       acc-co2-reg-937.
      *                          *-------------------------------------*
      *                          * Se si e' sulla riga numero 1        *
      *                          *-------------------------------------*
           if        w-cnt-co2-nrg-dac    =    1
                     move  "-"            to   w-cnt-tus-acc-co2
                     go to acc-co2-reg-990.
      *                          *-------------------------------------*
      *                          * Se non si e' sulla riga numero 1    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-940.
      *                  *---------------------------------------------*
      *                  * Se Down da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-941.
      *                          *-------------------------------------*
      *                          * Se si e' in Append si prepara il    *
      *                          * tipo uscita "+" e si visualizza il  *
      *                          * numero riga a spaces                *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move    "+"          to   w-cnt-tus-acc-co2
                     move    "S"          to   w-cnt-co2-tvi-rig
                     move    w-cnt-co2-nrg-dac
                                          to   w-cnt-co2-nrg-dav
                     perform vis-lin-co2-000
                                          thru vis-lin-co2-999
      *                          *-------------------------------------*
      *                          * Altrimenti si prepara il numero pa- *
      *                          * gina attualmente visualizzata a ze- *
      *                          * ro per forzare la rivisualizzazione *
      *                          *-------------------------------------*
           else      move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                          *-------------------------------------*
      *                          * Se si era in Append : uscita        *
      *                          *-------------------------------------*
           if        w-cnt-tus-acc-co2    =    "+"
                     go to acc-co2-reg-990
      *                          *-------------------------------------*
      *                          * Altrimenti : riciclo                *
      *                          *-------------------------------------*
           else      go to acc-co2-reg-000.
       acc-co2-reg-941.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Incremento del numero riga          *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-945.
      *                  *---------------------------------------------*
      *                  * Se Do da primo campo di impostazione riga   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-946.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
       acc-co2-reg-946.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
           move      "S"                  to   w-cnt-tus-acc-co2      .
           go to     acc-co2-reg-990.
       acc-co2-reg-950.
      *                  *---------------------------------------------*
      *                  * Se Delt da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-951.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
       acc-co2-reg-951.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
           move      "X"                  to   w-cnt-tus-acc-co2      .
           go to     acc-co2-reg-990.
       acc-co2-reg-955.
      *                  *---------------------------------------------*
      *                  * Se Insr da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inserimento record nella catena         *
      *                      *-----------------------------------------*
           move      "IN"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente  visualizzata *
      *                      * a zero per forzare la rivisualizzazione *
      *                      *-----------------------------------------*
           move      zero                 to   w-cnt-co2-nrp-vis      .
           go to     acc-co2-reg-000.
       acc-co2-reg-960.
      *                  *---------------------------------------------*
      *                  * Se Remv da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non new : routine post-accetta- *
      *                      * zione riga                              *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to acc-co2-reg-962.
           move      "-"                  to   w-cnt-co2-tip-agg      .
           perform   pos-rig-co2-000      thru pos-rig-co2-999        .
       acc-co2-reg-962.
      *                      *-----------------------------------------*
      *                      * Se in Append : visualizzazione del nu-  *
      *                      * mero riga a spaces                      *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move    "S"          to   w-cnt-co2-tvi-rig
                     move    w-cnt-co2-nrg-dac
                                          to   w-cnt-co2-nrg-dav
                     perform vis-lin-co2-000
                                          thru vis-lin-co2-999
      *                      *-----------------------------------------*
      *                      * Altrimenti si prepara il numero pagina  *
      *                      * attualmente visualizzata a zero per     *
      *                      * forzare la rivisualizzazione            *
      *                      *-----------------------------------------*
           else      move  zero           to   w-cnt-co2-nrp-vis      .
      *                      *-----------------------------------------*
      *                      * Rimozione record dalla catena           *
      *                      *-----------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                      *-----------------------------------------*
      *                      * Segnale di almeno una modifica          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-acc-flg-aum      .
           go to     acc-co2-reg-000.
       acc-co2-reg-965.
      *                  *---------------------------------------------*
      *                  * Se Tab da primo campo di impostazione riga  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-966.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione a meno che non si sia in *
      *                          * Append                              *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           go to     acc-co2-reg-967.
       acc-co2-reg-966.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
       acc-co2-reg-967.
      *                          *-------------------------------------*
      *                          * Ad accettazione max + 1             *
      *                          *-------------------------------------*
           move      w-cat-rg2-max        to   w-cnt-co2-nrg-dac      .
           if        w-cat-rg2-app        =    spaces
                     add   1              to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-970.
      *                  *---------------------------------------------*
      *                  * Se Back da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-971.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione a meno che non si sia in *
      *                          * Append                              *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           move      1                    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-971.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
           move      1                    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-975.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-976.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione a meno che non si sia in *
      *                          * Append                              *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           go to     acc-co2-reg-977.
       acc-co2-reg-976.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
       acc-co2-reg-977.
      *                          *-------------------------------------*
      *                          * Se si era nell'ultima riga, ed essa *
      *                          * era in Append : tipo uscita "+" e   *
      *                          * si esce                             *
      *                          *-------------------------------------*
           if        w-cnt-co2-nrg-dac    >    w-cat-rg2-max
                     move    "+"          to   w-cnt-tus-acc-co2
                     go to acc-co2-reg-990.
      *                          *-------------------------------------*
      *                          * Determinazione numero d'ordine del- *
      *                          * la prima riga appartenente alla pa- *
      *                          * gina (max + 1)                      *
      *                          *-------------------------------------*
           move      w-cat-rg2-max        to   w-cnt-wrk-ctr-001      .
           add       w-ln2-num-lin-vis    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-ln2-num-lin-vis    into w-cnt-wrk-ctr-001      .
           multiply  w-ln2-num-lin-vis    by   w-cnt-wrk-ctr-001      .
           add       1                    to   w-cnt-wrk-ctr-001      .
      *                          *-------------------------------------*
      *                          * Determinazione numero d'ordine del- *
      *                          * la prima riga appartenente alla pa- *
      *                          * gina (attuale + 1)                  *
      *                          *-------------------------------------*
           move      w-cnt-co2-nrg-dac    to   w-cnt-wrk-ctr-002      .
           add       w-ln2-num-lin-vis    to   w-cnt-wrk-ctr-002      .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           divide    w-ln2-num-lin-vis    into w-cnt-wrk-ctr-002      .
           multiply  w-ln2-num-lin-vis    by   w-cnt-wrk-ctr-002      .
           add       1                    to   w-cnt-wrk-ctr-002      .
      *                          *-------------------------------------*
      *                          * Se la prossima pagina e' sicuramen- *
      *                          * te prima dell'ultima                *
      *                          *-------------------------------------*
           if        w-cnt-wrk-ctr-002    <    w-cnt-wrk-ctr-001
                     move  w-cnt-wrk-ctr-002
                                          to   w-cnt-co2-nrg-dac
                     go to acc-co2-reg-000.
      *                          *-------------------------------------*
      *                          * Se si e' sull'ultima pagina la qua- *
      *                          * le e' pero' completamente piena     *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cat-rg2-max        =    w-cnt-wrk-ctr-001
                     move  w-cnt-wrk-ctr-002
                                          to   w-cnt-co2-nrg-dac
                     go to acc-co2-reg-000.
      *                          *-------------------------------------*
      *                          * Se si supera l'ultima pagina        *
      *                          *-------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-co2      .
           go to     acc-co2-reg-990.
       acc-co2-reg-980.
      *                  *---------------------------------------------*
      *                  * Se Prsc da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-981.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione a meno che non si sia in *
      *                          * Append                              *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           go to     acc-co2-reg-982.
       acc-co2-reg-981.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
       acc-co2-reg-982.
      *                          *-------------------------------------*
      *                          * Se si e' sulla prima pagina         *
      *                          *-------------------------------------*
           if        w-cnt-co2-nrg-dac    not  > w-ln2-num-lin-vis
                     move  "-"            to   w-cnt-tus-acc-co2
                     go to acc-co2-reg-990.
      *                          *-------------------------------------*
      *                          * Se non si e' sulla prima pagina     *
      *                          *-------------------------------------*
           subtract  w-ln2-num-lin-vis    from w-cnt-co2-nrg-dac      .
           subtract  1                    from w-cnt-co2-nrg-dac      .
           divide    w-ln2-num-lin-vis    into w-cnt-co2-nrg-dac      .
           multiply  w-ln2-num-lin-vis    by   w-cnt-co2-nrg-dac      .
           add       1                    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-985.
      *                  *---------------------------------------------*
      *                  * Se Slct da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-986.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione a meno che non si sia in *
      *                          * Append                              *
      *                          *-------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                          *-------------------------------------*
      *                          * Se il numero riga di destinazione   *
      *                          * risulta oltre il numero d'ordine    *
      *                          * attuale si sottrae 1 al numero ri-  *
      *                          * ga di destinazione                  *
      *                          *-------------------------------------*
           if        w-cnt-slc-num-rig    >    w-cnt-co2-nrg-dac
                     subtract  1          from w-cnt-slc-num-rig      .
           go to     acc-co2-reg-987.
       acc-co2-reg-986.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
       acc-co2-reg-987.
      *                          *-------------------------------------*
      *                          * Ad accettazione nr riga selezionato *
      *                          *-------------------------------------*
           move      w-cnt-slc-num-rig    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-990.
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione corpo       *
      *              *-------------------------------------------------*
           if        w-cat-rg2-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-co2
           else      move  "#"            to   w-cnt-sts-imp-co2      .
       acc-co2-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione pagina corpo numero : w-cnt-co2-nrp-dav   *
      *    *-----------------------------------------------------------*
       vis-co2-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      06                   to   v-lin                  .
           move      12                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-co2-reg-150.
      *              *-------------------------------------------------*
      *              * Determinazione numero d'ordine del primo numero *
      *              * riga da visualizzare                            *
      *              *-------------------------------------------------*
           move      w-cnt-co2-nrp-dav    to   w-cnt-wrk-ctr-008      .
           multiply  w-ln2-num-lin-vis    by   w-cnt-wrk-ctr-008      .
           add       1                    to   w-cnt-wrk-ctr-008      .
           subtract  w-ln2-num-lin-vis    from w-cnt-wrk-ctr-008      .
      *              *-------------------------------------------------*
      *              * Determinazione numero d'ordine dell'ultimo nu-  *
      *              * mero riga da visualizzare                       *
      *              *-------------------------------------------------*
           move      w-cnt-wrk-ctr-008    to   w-cnt-wrk-ctr-009      .
           add       w-ln2-num-lin-vis    to   w-cnt-wrk-ctr-009      .
           subtract  1                    from w-cnt-wrk-ctr-009      .
      *              *-------------------------------------------------*
      *              * Operazione di Start su catena movimenti         *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rg2-ope          .
           move      w-cnt-wrk-ctr-008    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se start errata : fine visualizzazione      *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to  vis-co2-reg-999.
       vis-co2-reg-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : fine visualizzazione      *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to  vis-co2-reg-999.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rg2-buf        to   w-rg2                  .
      *              *-------------------------------------------------*
      *              * Riga singolo movimento                          *
      *              *-------------------------------------------------*
           move      "R"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-wrk-ctr-008    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *              *-------------------------------------------------*
      *              * Incremento numero riga da visualizzare          *
      *              *-------------------------------------------------*
           add       1                    to   w-cnt-wrk-ctr-008      .
      *              *-------------------------------------------------*
      *              * Test se oltre ultima riga da visualizzare       *
      *              *-------------------------------------------------*
           if        w-cnt-wrk-ctr-008    not  > w-cnt-wrk-ctr-009
                     go to vis-co2-reg-200.
       vis-co2-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione linea corpo numero : w-cnt-co2-nrg-dav    *
      *    *-----------------------------------------------------------*
       vis-lin-co2-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-co2-nrg-dav    to   w-cnt-wrk-ctr-001      .
           add       w-ln2-num-lin-vis    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-ln2-num-lin-vis    into w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           multiply  w-ln2-num-lin-vis    by   w-cnt-wrk-ctr-001      .
           subtract  w-cnt-wrk-ctr-001    from w-cnt-co2-nrg-dav
                                        giving w-cnt-wrk-ctr-002      .
           add       w-ln2-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
           subtract  1                    from w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Test su tipo visualizzazione riga               *
      *              *-------------------------------------------------*
           if        w-cnt-co2-tvi-rig    =    "I"
                     go to vis-lin-co2-100
           else if   w-cnt-co2-tvi-rig    =    "S"
                     go to vis-lin-co2-200
           else if   w-cnt-co2-tvi-rig    =    "N"
                     go to vis-lin-co2-300
           else      go to vis-lin-co2-400.
       vis-lin-co2-100.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione indicatore linea         *
      *                  *---------------------------------------------*
           move      "==>"                to   w-ln2-imm-num-lin      .
           move      03                   to   v-car                  .
           go to     vis-lin-co2-900.
       vis-lin-co2-200.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione numero linea a spaces    *
      *                  *---------------------------------------------*
           move      spaces               to   w-ln2-imm-num-lin      .
           move      03                   to   v-car                  .
           go to     vis-lin-co2-900.
       vis-lin-co2-300.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione numero d'ordine riga     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-cat-rg2-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-ln2-imm-num-lin      .
           go to     vis-lin-co2-900.
       vis-lin-co2-400.
      *                  *---------------------------------------------*
      *                  * Se visualizzazione riga intera              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga in append : uscita              *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     go to  vis-lin-co2-999.
      *                      *-----------------------------------------*
      *                      * Abblencamento immagine linea di corpo   *
      *                      *-----------------------------------------*
           move      spaces               to   w-ln2-imm              .
      *                      *-----------------------------------------*
      *                      * Editing Numero d'ordine riga            *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-cat-rg2-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-ln2-imm-num-lin      .
      *                      *-----------------------------------------*
      *                      * Se riga di tipo New : fine editing      *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to vis-lin-co2-800.
       vis-lin-co2-600.
      *                      *-----------------------------------------*
      *                      * Descrizione conto                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo     *
      *                          * conto                               *
      *                          *-------------------------------------*
           if        w-rg2-tip-con (1)    =    "G"
                     go to vis-lin-co2-620
           else if   w-rg2-tip-con (1)    =    "C"
                     go to vis-lin-co2-640
           else if   w-rg2-tip-con (1)    =    "F"
                     go to vis-lin-co2-660.
       vis-lin-co2-620.
      *                          *-------------------------------------*
      *                          * Tipo 'G'                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing con appoggio a sinistra *
      *                              *---------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rg2-cod-con (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *                              *---------------------------------*
      *                              * Assemblaggio con descrizione    *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-edt-cod-pdc-edt    to   w-all-str-cat (1)      .
           move      w-rg2-des-con (1)    to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                              *---------------------------------*
      *                              * In campo di destinazione        *
      *                              *---------------------------------*
           move      w-all-str-alf        to   w-ln2-imm-des-con      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     vis-lin-co2-700.
       vis-lin-co2-640.
      *                          *-------------------------------------*
      *                          * Tipo 'C'                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing codice Cliente          *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-rg2-cod-arc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Assemblaggio con descrizione    *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "C/"                 to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      w-rg2-des-con (1)    to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                              *---------------------------------*
      *                              * In campo di destinazione        *
      *                              *---------------------------------*
           move      w-all-str-alf        to   w-ln2-imm-des-con      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     vis-lin-co2-700.
       vis-lin-co2-660.
      *                          *-------------------------------------*
      *                          * Tipo 'F'                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing codice Fornitore        *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-rg2-cod-arc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Assemblaggio con descrizione    *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "F/"                 to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      w-rg2-des-con (1)    to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                              *---------------------------------*
      *                              * In campo di destinazione        *
      *                              *---------------------------------*
           move      w-all-str-alf        to   w-ln2-imm-des-con      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     vis-lin-co2-700.
       vis-lin-co2-700.
      *                      *-----------------------------------------*
      *                      * Editing importo Dare o Avere            *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           move      w-rg2-imp-mov (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        w-rg2-dar-ave (1)    =    "A"
                     move  v-edt          to   w-ln2-imm-imp-ave
           else      move  v-edt          to   w-ln2-imm-imp-dar      .
       vis-lin-co2-800.
      *                      *-----------------------------------------*
      *                      * Parametri per visualizzazione           *
      *                      *-----------------------------------------*
           move      80                   to   v-car                  .
       vis-lin-co2-900.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione                      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-ln2-imm            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-lin-co2-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo 2             *
      *    *-----------------------------------------------------------*
       pmt-co2-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      15                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R             Descrizione conto                 
      -              "      Dare           Avere    "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---  ----------------------------------------     
      -              " -------------- --------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sopralineatura per saldo movimento          *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      33                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      48                   to   v-pos                  .
           move      "---------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * 'Saldo movimento :'                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "Saldo movimento :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Saldo righe movimento contabile             *
      *                  *---------------------------------------------*
           perform   vis-sdo-rmc-000      thru vis-sdo-rmc-999        .
      *                  *---------------------------------------------*
      *                  * Linea di trattini                           *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-co2-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo 2 di accettazione in w-rg2     *
      *    *-----------------------------------------------------------*
       vis-rig-co2-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to vis-rig-co2-999.
      *              *-------------------------------------------------*
      *              * Tipo conto                                      *
      *              *-------------------------------------------------*
           perform   vis-tip-con-000      thru vis-tip-con-999        .
      *              *-------------------------------------------------*
      *              * Codice conto                                    *
      *              *-------------------------------------------------*
           perform   vis-cod-con-000      thru vis-cod-con-999        .
      *              *-------------------------------------------------*
      *              * Descrizione conto                               *
      *              *-------------------------------------------------*
           perform   vis-des-con-000      thru vis-des-con-999        .
      *              *-------------------------------------------------*
      *              * Commento in riga                                *
      *              *-------------------------------------------------*
           perform   vis-com-rig-000      thru vis-com-rig-999        .
      *              *-------------------------------------------------*
      *              * Data riferimento                                *
      *              *-------------------------------------------------*
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
      *              *-------------------------------------------------*
      *              * Numero riferimento                              *
      *              *-------------------------------------------------*
           perform   vis-num-rif-000      thru vis-num-rif-999        .
      *              *-------------------------------------------------*
      *              * Importo movimento                               *
      *              *-------------------------------------------------*
           perform   vis-imp-mov-000      thru vis-imp-mov-999        .
       vis-rig-co2-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga di accettazione corpo 2  *
      *    *-----------------------------------------------------------*
       pmt-rig-co2-000.
           move      "EL"                 to   v-ope                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo conto :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Conto      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Commento   :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Data rif.  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Num. rif.  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      29                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "     Dare           Avere    "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      29                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      52                   to   v-pos                  .
           move      "-------------- --------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      38                   to   v-pos                  .
           move      "Importo :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rig-co2-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo conto                           *
      *    *-----------------------------------------------------------*
       acc-tip-con-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rg2-tip-con (1)    to   w-sav-tip-con          .
       acc-tip-con-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-con        to   w-rg2-tip-con (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      14                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-co2    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces and
                     w-cat-rg2-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-co2-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rg2-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rg2-tip-con (1)    to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Rivisitazione dei tasti funzione ammes- *
      *                      * si in funzione del numero riga          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 1 si disa-  *
      *                          * bilitano Insr e Remv                *
      *                          *-------------------------------------*
           if        w-cat-rg2-cur        =    1
                     move  spaces         to   v-pfk (04)
                     move  spaces         to   v-pfk (06)             .
       acc-tip-con-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-con-400.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-con-300
           else      go to acc-tip-con-350.
       acc-tip-con-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-con-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-con-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-con-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-con-310.
       acc-tip-con-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rg2-max
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-co2-nrg-dac
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rg2      .
           go to     acc-tip-con-999.
       acc-tip-con-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-con-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-tip-con-999
                     else    move  spaces to   w-cnt-tus-acc-rg2
                             go to acc-tip-con-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-con-999.
       acc-tip-con-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga non new                             *
      *                  *---------------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-tip-con-450.
      *                  *---------------------------------------------*
      *                  * Se si e' in riga numero 1                   *
      *                  *---------------------------------------------*
           if        w-cat-rg2-cur        not  = 1
                     go to acc-tip-con-450.
      *                      *-----------------------------------------*
      *                      * Il valore attuale deve essere uguale al *
      *                      * valore salvato                          *
      *                      *-----------------------------------------*
           if        v-alf                =    w-sav-tip-con
                     go to acc-tip-con-450
           else      go to acc-tip-con-100.
       acc-tip-con-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        v-alf                =    spaces
                     if    w-cat-rg2-new  not  = spaces and
                           w-cat-rg2-lst  not  = spaces and
                           w-cnt-sts-imp-co2
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rg2
                           go to acc-tip-con-999
                     else  go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Se non e' uno dei tipi conto previsti si    *
      *                  * tratta come per il tasto Slct               *
      *                  *---------------------------------------------*
           if        v-alf                not  = "G  " and
                     v-alf                not  = "C  " and
                     v-alf                not  = "F  "
                     go to acc-tip-con-300.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rg2-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-con-100.
      *                  *---------------------------------------------*
      *                  * Valore impostato in campo di destinazione   *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rg2-tip-con (1)      .
       acc-tip-con-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-con-800.
       acc-tip-con-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo conto                        *
      *    *-----------------------------------------------------------*
       vis-tip-con-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-rg2-tip-con (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-con-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice conto                         *
      *    *-----------------------------------------------------------*
       acc-cod-con-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo conto           *
      *              *-------------------------------------------------*
           if        w-rg2-tip-con (1)    =    "G"
                     perform acc-con-gen-000
                                          thru acc-con-gen-999
           else if   w-rg2-tip-con (1)    =    "C"
                     perform acc-con-cli-000
                                          thru acc-con-cli-999
           else if   w-rg2-tip-con (1)    =    "F"
                     perform acc-con-fnt-000
                                          thru acc-con-fnt-999        .
       acc-cod-con-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice conto di generale             *
      *    *-----------------------------------------------------------*
       acc-con-gen-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-sav-cod-con          .
       acc-con-gen-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rg2-cod-con (1)    to   w-cod-mne-pdc-cod      .
           move      17                   to   w-cod-mne-pdc-lin      .
           move      14                   to   w-cod-mne-pdc-pos      .
           move      17                   to   w-cod-mne-pdc-dln      .
           move      25                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-con-gen-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-con-gen-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-con-gen-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-con-gen-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-con-gen-110.
       acc-con-gen-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-con-gen-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-con-gen-999.
       acc-con-gen-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rg2-cod-con (1)      .
       acc-con-gen-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [pdc]                      *
      *                  *---------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-con-000      thru vis-des-con-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-con-gen-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rg2-cod-con (1)    =    zero
                     go to acc-con-gen-100.
       acc-con-gen-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo archivio                               *
      *                  *---------------------------------------------*
           move      spaces               to   w-rg2-tip-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice archivio                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-rg2-cod-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-rg2-cod-pdc (1)      .
       acc-con-gen-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-con-gen-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-con-gen-100.
       acc-con-gen-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice conto clienti                 *
      *    *-----------------------------------------------------------*
       acc-con-cli-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-sav-cod-con          .
       acc-con-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cli-ope      .
           move      w-rg2-cod-con (1)    to   w-cod-mne-cli-cod      .
           move      17                   to   w-cod-mne-cli-lin      .
           move      14                   to   w-cod-mne-cli-pos      .
           move      17                   to   w-cod-mne-cli-rln      .
           move      25                   to   w-cod-mne-cli-rps      .
           move      zero                 to   w-cod-mne-cli-vln      .
           move      zero                 to   w-cod-mne-cli-vps      .
           move      zero                 to   w-cod-mne-cli-lln      .
           move      zero                 to   w-cod-mne-cli-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
       acc-con-cli-110.
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           if        w-cod-mne-cli-ope    =    "F+"
                     go to acc-con-cli-115.
           if        w-cod-mne-cli-ope    =    "AC"
                     go to acc-con-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-con-cli-115.
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
           go to     acc-con-cli-110.
       acc-con-cli-120.
           move      w-cod-mne-cli-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-con-cli-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-con-cli-999.
       acc-con-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rg2-cod-con (1)      .
       acc-con-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cli]                      *
      *                  *---------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-con-000      thru vis-des-con-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces
                     go to acc-con-cli-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rg2-cod-con (1)    =    zero
                     go to acc-con-cli-100.
       acc-con-cli-500.
      *                  *---------------------------------------------*
      *                  * Controllo sottoconto contabile associato    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore a zero                        *
      *                      *-----------------------------------------*
           if        w-let-arc-cli-cge    not  = zero
                     go to acc-con-cli-520.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Sottoconto contabile associato al cliente a zero !
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-con-cli-100.
       acc-con-cli-520.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdc]                  *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-cge    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           if        w-let-arc-pdc-flg    =    spaces
                     go to acc-con-cli-600.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Sottoconto contabile associato al cliente non esis
      -              "tente !        "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-con-cli-100.
       acc-con-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo archivio                               *
      *                  *---------------------------------------------*
           move      w-rg2-tip-con (1)    to   w-rg2-tip-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice archivio                             *
      *                  *---------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-rg2-cod-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
           move      w-let-arc-cli-cge    to   w-rg2-cod-pdc (1)      .
       acc-con-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-con-cli-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-con-cli-100.
       acc-con-cli-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice conto fornitori               *
      *    *-----------------------------------------------------------*
       acc-con-fnt-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-sav-cod-con          .
       acc-con-fnt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-fnt-ope      .
           move      w-rg2-cod-con (1)    to   w-cod-mne-fnt-cod      .
           move      17                   to   w-cod-mne-fnt-lin      .
           move      14                   to   w-cod-mne-fnt-pos      .
           move      17                   to   w-cod-mne-fnt-rln      .
           move      25                   to   w-cod-mne-fnt-rps      .
           move      zero                 to   w-cod-mne-fnt-vln      .
           move      zero                 to   w-cod-mne-fnt-vps      .
           move      zero                 to   w-cod-mne-fnt-lln      .
           move      zero                 to   w-cod-mne-fnt-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-fnt-foi-000  thru cod-mne-fnt-foi-999    .
       acc-con-fnt-110.
           perform   cod-mne-fnt-cll-000  thru cod-mne-fnt-cll-999    .
           if        w-cod-mne-fnt-ope    =    "F+"
                     go to acc-con-fnt-115.
           if        w-cod-mne-fnt-ope    =    "AC"
                     go to acc-con-fnt-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-con-fnt-115.
           perform   cod-mne-fnt-foi-000  thru cod-mne-fnt-foi-999    .
           go to     acc-con-fnt-110.
       acc-con-fnt-120.
           move      w-cod-mne-fnt-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-con-fnt-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-con-fnt-999.
       acc-con-fnt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rg2-cod-con (1)      .
       acc-con-fnt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se in riga nr. 1                            *
      *                  *---------------------------------------------*
           if        w-cat-rg2-cur        not  = 1
                     go to acc-con-fnt-420.
      *                      *-----------------------------------------*
      *                      * Se valore variato : ripristino valore   *
      *                      * precedente e reimpostazione             *
      *                      *-----------------------------------------*
           if        w-rg2-cod-con (1)    not  = w-sav-cod-con
                     move  w-sav-cod-con  to   w-rg2-cod-con (1)
                     go to acc-con-fnt-100.
       acc-con-fnt-420.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [fnt]                      *
      *                  *---------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
           move      w-let-arc-fnt-rag    to   w-rg2-des-con (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-con-000      thru vis-des-con-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-flg    not  = spaces
                     go to acc-con-fnt-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rg2-cod-con (1)    =    zero
                     go to acc-con-fnt-100.
       acc-con-fnt-500.
      *                  *---------------------------------------------*
      *                  * Controllo sottoconto contabile associato    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore a zero                        *
      *                      *-----------------------------------------*
           if        w-let-arc-fnt-cge    not  = zero
                     go to acc-con-fnt-520.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Sottoconto contabile associato al fornitore a zero
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-con-fnt-100.
       acc-con-fnt-520.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdc]                  *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-cge    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           if        w-let-arc-pdc-flg    =    spaces
                     go to acc-con-fnt-600.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Sottoconto contabile associato al fornitore non es
      -              "istente !      "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-con-fnt-100.
       acc-con-fnt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo archivio                               *
      *                  *---------------------------------------------*
           move      w-rg2-tip-con (1)    to   w-rg2-tip-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice archivio                             *
      *                  *---------------------------------------------*
           move      w-rg2-cod-con (1)    to   w-rg2-cod-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice sottoconto                           *
      *                  *---------------------------------------------*
           move      w-let-arc-fnt-cge    to   w-rg2-cod-pdc (1)      .
       acc-con-fnt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-con-fnt-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-con-fnt-100.
       acc-con-fnt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice conto                      *
      *    *-----------------------------------------------------------*
       vis-cod-con-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo conto           *
      *              *-------------------------------------------------*
           if        w-rg2-tip-con (1)    =    "G"
                     perform vis-con-gen-000
                                          thru vis-con-gen-999
           else if   w-rg2-tip-con (1)    =    "C"
                     perform vis-con-cli-000
                                          thru vis-con-cli-999
           else if   w-rg2-tip-con (1)    =    "F"
                     perform vis-con-fnt-000
                                          thru vis-con-fnt-999        .
       vis-cod-con-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice conto di generale          *
      *    *-----------------------------------------------------------*
       vis-con-gen-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rg2-cod-con (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-con-gen-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice conto cliente              *
      *    *-----------------------------------------------------------*
       vis-con-cli-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      17                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-rg2-cod-con (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-con-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice conto fornitore            *
      *    *-----------------------------------------------------------*
       vis-con-fnt-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      17                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-rg2-cod-con (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-con-fnt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione conto                 *
      *    *-----------------------------------------------------------*
       vis-des-con-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      w-rg2-des-con (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-con-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Commento in riga                     *
      *    *-----------------------------------------------------------*
       acc-com-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione valore di default    *
      *                  * per ragione sociale fornitore               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore gia' presente : no prepara-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-rg2-com-rig (1)    not  = spaces
                     go to acc-com-rig-100.
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo consente   *
      *                      *-----------------------------------------*
            if       w-prs-rsf-icr        not  = "S"
                     go to acc-com-rig-100.
      *                      *-----------------------------------------*
      *                      * Test se riga 'New'                      *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-com-rig-100.
      *                      *-----------------------------------------*
      *                      * Test se tipo conto 'G'                  *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    not  = "G"
                     go to acc-com-rig-100.
      *                      *-----------------------------------------*
      *                      * Preparazione valore                     *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc-rag (1)
                                          to   w-rg2-com-rig (1)      .
       acc-com-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           move      w-rg2-com-rig (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-com-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-com-rig-999.
       acc-com-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rg2-com-rig (1)      .
       acc-com-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-com-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-com-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-com-rig-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-com-rig-100.
       acc-com-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Commento in riga                  *
      *    *-----------------------------------------------------------*
       vis-com-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-rg2-com-rig (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-com-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data riferimento                     *
      *    *-----------------------------------------------------------*
       acc-dat-rif-000.
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
           if        w-rg2-tip-con (1)    not  = "C" and
                     w-rg2-tip-con (1)    not  = "F"
                     go to acc-dat-rif-999.
       acc-dat-rif-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      20                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           move      w-rg2-dat-rif (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-dat-rif-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-dat-rif-999.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rg2-dat-rif (1)      .
       acc-dat-rif-200.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-dat-rif-300.
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rg2-tip-con (1)    =    "C"
                     go to acc-dat-rif-225
           else if   w-rg2-tip-con (1)    =    "F"
                     go to acc-dat-rif-250.
       acc-dat-rif-225.
      *                  *---------------------------------------------*
      *                  * Se conto clienti                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Find su riferimenti clienti             *
      *                      *-----------------------------------------*
           move      w-rg2-cod-con (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
      *                      *-----------------------------------------*
      *                      * Se nessuna selezione : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-dat-rif-100.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori selezionati      *
      *                      *-----------------------------------------*
           move      w-fnd-rif-cli-dat    to   w-rg2-dat-rif (1)      .
           move      w-fnd-rif-cli-num    to   w-rg2-num-rif (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori selezionati      *
      *                      *-----------------------------------------*
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
      *                      *-----------------------------------------*
      *                      * A controllo valore                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-dat-rif-400.
       acc-dat-rif-250.
      *                  *---------------------------------------------*
      *                  * Se conto fornitori                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Find su riferimenti fornitori           *
      *                      *-----------------------------------------*
           move      w-rg2-cod-con (1)    to   w-fnd-rif-fnt-cod      .
           perform   fnd-rif-fnt-000      thru fnd-rif-fnt-999        .
      *                      *-----------------------------------------*
      *                      * Se nessuna selezione : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-fnd-rif-fnt-sel    not  = spaces
                     go to acc-dat-rif-100.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori selezionati      *
      *                      *-----------------------------------------*
           move      w-fnd-rif-fnt-dat    to   w-rg2-dat-rif (1)      .
           move      w-fnd-rif-fnt-num    to   w-rg2-num-rif (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori selezionati      *
      *                      *-----------------------------------------*
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
      *                      *-----------------------------------------*
      *                      * A controllo valore                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-dat-rif-400.
       acc-dat-rif-300.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-dat-rif-400.
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rg2-tip-con (1)    =    "C"
                     go to acc-dat-rif-325
           else if   w-rg2-tip-con (1)    =    "F"
                     go to acc-dat-rif-350.
       acc-dat-rif-325.
      *                  *---------------------------------------------*
      *                  * Se conto clienti                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se funzione di pareggiamento automati-  *
      *                      * co partite gia' utilizzata : a reimpo-  *
      *                      * stazione                                *
      *                      *-----------------------------------------*
           if        w-co2-imp-pap (1)    not  = spaces
                     go to acc-dat-rif-100.
      *                      *-----------------------------------------*
      *                      * Se non si e' sulla prima riga : a reim- *
      *                      * postazione                              *
      *                      *-----------------------------------------*
           if        w-cat-rg2-cur        not  = 1
                     go to acc-dat-rif-100.
      *                      *-----------------------------------------*
      *                      * Richiamo funzione di pareggiamento au-  *
      *                      * tomatico partite clienti                *
      *                      *-----------------------------------------*
           move      spaces               to   w-lpa-exi-sts          .
           perform   ins-pap-cli-000      thru ins-pap-cli-999        .
      *                      *-----------------------------------------*
      *                      * Assestamento flag di impostazione pa-   *
      *                      * reggiamento automatico partite clienti  *
      *                      *-----------------------------------------*
           if        w-lpa-exi-sts        not  = spaces
                     move  "#"            to   w-co2-imp-pap (1)      .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-dat-rif-100.
       acc-dat-rif-350.
      *                  *---------------------------------------------*
      *                  * Se conto fornitori                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se funzione di pareggiamento automati-  *
      *                      * co partite gia' utilizzata : a reimpo-  *
      *                      * stazione                                *
      *                      *-----------------------------------------*
           if        w-co2-imp-pap (1)    not  = spaces
                     go to acc-dat-rif-100.
      *                      *-----------------------------------------*
      *                      * Se non si e' sulla prima riga : a reim- *
      *                      * postazione                              *
      *                      *-----------------------------------------*
           if        w-cat-rg2-cur        not  = 1
                     go to acc-dat-rif-100.
      *                      *-----------------------------------------*
      *                      * Richiamo funzione di pareggiamento au-  *
      *                      * tomatico partite fornitori              *
      *                      *-----------------------------------------*
           move      spaces               to   w-lpa-exi-sts          .
           perform   ins-pap-fnt-000      thru ins-pap-fnt-999        .
      *                      *-----------------------------------------*
      *                      * Assestamento flag di impostazione pa-   *
      *                      * reggiamento automatico partite forni-   *
      *                      * tori                                    *
      *                      *-----------------------------------------*
           if        w-lpa-exi-sts        not  = spaces
                     move  "#"            to   w-co2-imp-pap (1)      .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-dat-rif-100.
       acc-dat-rif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dat-rif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento numero riferimento              *
      *                  *---------------------------------------------*
           if        w-rg2-dat-rif (1)    not  = zero
                     go to acc-dat-rif-800.
           if        w-rg2-num-rif (1)    =    spaces
                     go to acc-dat-rif-800.
           move      spaces               to   w-rg2-num-rif (1)      .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
       acc-dat-rif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-dat-rif-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-dat-rif-100.
       acc-dat-rif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data riferimento                  *
      *    *-----------------------------------------------------------*
       vis-dat-rif-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rg2-tip-con (1)    not  = "C" and
                     w-rg2-tip-con (1)    not  = "F"
                     go to vis-dat-rif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      20                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-rg2-dat-rif (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-rif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero riferimento                   *
      *    *-----------------------------------------------------------*
       acc-num-rif-000.
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
           if        w-rg2-tip-con (1)    not  = "C" and
                     w-rg2-tip-con (1)    not  = "F"
                     go to acc-num-rif-999.
           if        w-rg2-dat-rif (1)    =    zero
                     go to acc-num-rif-999.
       acc-num-rif-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           move      w-rg2-num-rif (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-num-rif-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-num-rif-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rg2-num-rif (1)      .
       acc-num-rif-200.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-rif-400.
      *                  *---------------------------------------------*
      *                  * Test su tipo conto                          *
      *                  *---------------------------------------------*
           if        w-rg2-tip-con (1)    =    "C"
                     go to acc-num-rif-225
           else if   w-rg2-tip-con (1)    =    "F"
                     go to acc-num-rif-250
           else      go to acc-num-rif-100.
       acc-num-rif-225.
      *                  *---------------------------------------------*
      *                  * Se conto clienti                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Find su riferimenti clienti             *
      *                      *-----------------------------------------*
           move      w-rg2-cod-con (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
      *                      *-----------------------------------------*
      *                      * Se nessuna selezione : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-num-rif-100.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori selezionati      *
      *                      *-----------------------------------------*
           move      w-fnd-rif-cli-dat    to   w-rg2-dat-rif (1)      .
           move      w-fnd-rif-cli-num    to   w-rg2-num-rif (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori selezionati      *
      *                      *-----------------------------------------*
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
      *                      *-----------------------------------------*
      *                      * A controllo valore                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-num-rif-400.
       acc-num-rif-250.
      *                  *---------------------------------------------*
      *                  * Se conto fornitori                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Find su riferimenti fornitori           *
      *                      *-----------------------------------------*
           move      w-rg2-cod-con (1)    to   w-fnd-rif-fnt-cod      .
           perform   fnd-rif-fnt-000      thru fnd-rif-fnt-999        .
      *                      *-----------------------------------------*
      *                      * Se nessuna selezione : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-fnd-rif-fnt-sel    not  = spaces
                     go to acc-num-rif-100.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori selezionati      *
      *                      *-----------------------------------------*
           move      w-fnd-rif-fnt-dat    to   w-rg2-dat-rif (1)      .
           move      w-fnd-rif-fnt-num    to   w-rg2-num-rif (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori selezionati      *
      *                      *-----------------------------------------*
           perform   vis-dat-rif-000      thru vis-dat-rif-999        .
           perform   vis-num-rif-000      thru vis-num-rif-999        .
      *                      *-----------------------------------------*
      *                      * A controllo valore                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-num-rif-400.
       acc-num-rif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rg2-num-rif (1)    not  = spaces
                     go to acc-num-rif-600.
           if        v-key                =    "UP  "
                     go to acc-num-rif-600
           else      go to acc-num-rif-100.
       acc-num-rif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-rif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-num-rif-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-num-rif-100.
       acc-num-rif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero riferimento                *
      *    *-----------------------------------------------------------*
       vis-num-rif-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rg2-tip-con (1)    not  = "C" and
                     w-rg2-tip-con (1)    not  = "F"
                     go to vis-num-rif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      w-rg2-num-rif (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-rif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Importo movimento                    *
      *    *-----------------------------------------------------------*
       acc-imp-mov-000.
      *              *-------------------------------------------------*
      *              * Preparazione default di Dare o Avere e Importo  *
      *              * movimento                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valori attuali gia' presenti : nessuna   *
      *                  * azione                                      *
      *                  *---------------------------------------------*
           if        w-rg2-dar-ave (1)    not  = spaces and
                     w-rg2-imp-mov (1)    not  = zero
                     go to acc-imp-mov-100.
      *                      *-----------------------------------------*
      *                      * Preparazione del dare/avere in funzio-  *
      *                      * ne del saldo registrazione              *
      *                      *-----------------------------------------*
           if        w-rg2-dar-ave (1)    not  = spaces
                     go to acc-imp-mov-075.
           if        w-co2-sdo-rmc (1)    >    zero
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
       acc-imp-mov-075.
      *                      *-----------------------------------------*
      *                      * Importo : valore assoluto del saldo     *
      *                      * registrazione                           *
      *                      *-----------------------------------------*
           if        w-rg2-imp-mov (1)    not  = zero
                     go to acc-imp-mov-100.
           if       (w-co2-sdo-rmc (1)    >    zero and
                     w-rg2-dar-ave (1)    =    "D"    ) or
                    (w-co2-sdo-rmc (1)    <    zero and
                     w-rg2-dar-ave (1)    =    "A"    )
                     go to acc-imp-mov-100.
           move      w-co2-sdo-rmc (1)    to   w-rg2-imp-mov (1)      .
           if        w-rg2-imp-mov (1)    <    zero
                     multiply   -1        by   w-rg2-imp-mov (1)      .
       acc-imp-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
           if        w-rg2-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
           move      "GB"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rg2    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
           if        w-cat-rg2-cur        not  = 1
                     move  "TAB "         to   v-pfk (10)             .
           move      w-rg2-imp-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-imp-mov-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-imp-mov-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rg2-imp-mov (1)      .
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "TAB "
                     go to acc-imp-mov-400.
      *                  *---------------------------------------------*
      *                  * Salvataggio importo movimento precedente    *
      *                  *---------------------------------------------*
           move      w-rg2-imp-mov (1)    to   w-sav-imp-mov          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo movimento a zero    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rg2-imp-mov (1)      .
           perform   vis-imp-mov-000      thru vis-imp-mov-999        .
      *                  *---------------------------------------------*
      *                  * Ripristino importo movimento precedente     *
      *                  *---------------------------------------------*
           move      w-sav-imp-mov        to   w-rg2-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Inversione del segnale di Dare o Avere      *
      *                  *---------------------------------------------*
           if        w-rg2-dar-ave (1)    =    "A"
                     move  "D"            to   w-rg2-dar-ave (1)
           else      move  "A"            to   w-rg2-dar-ave (1)      .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-imp-mov-100.
       acc-imp-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-imp-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rg2-000
                                          thru cnt-tdo-rg2-999
                     if      w-cnt-tdo-rg2-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-imp-mov-999
                     else    move  spaces to   w-cnt-tdo-rg2-flg
                             go to acc-imp-mov-100.
       acc-imp-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo movimento                 *
      *    *-----------------------------------------------------------*
       vis-imp-mov-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
           if        w-rg2-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
           move      "GB"                 to   v-edm                  .
           move      w-rg2-imp-mov (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-mov-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Saldo righe movimento contabile   *
      *    *-----------------------------------------------------------*
       vis-sdo-rmc-000.
           move      spaces               to   w-ln2-imm-imp-mov      .
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-co2-sdo-rmc (1)    to   v-num                  .
           if        v-num                <    zero
                     multiply  -1         by   v-num                  .
           move      "G"                  to   v-edm                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        w-co2-sdo-rmc (1)    <    zero
                     move  v-edt          to   w-ln2-imm-imp-ave
           else      move  v-edt          to   w-ln2-imm-imp-dar      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      33                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      48                   to   v-pos                  .
           move      w-ln2-imm-imp-mov    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdo-rmc-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do riga corpo             *
      *    *-----------------------------------------------------------*
       cnt-tdo-rg2-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rg2-flg      .
       cnt-tdo-rg2-100.
      *              *-------------------------------------------------*
      *              * Controlli                                       *
      *              *-------------------------------------------------*
       cnt-tdo-rg2-120.
      *                  *---------------------------------------------*
      *                  * Tipo conto                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore non ammesso : errore          *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    =    "C" or
                     w-rg2-tip-con (1)    =    "F" or
                     w-rg2-tip-con (1)    =    "G"
                     go to cnt-tdo-rg2-140.
           move      "Tipo conto non ammesso                            
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-140.
      *                  *---------------------------------------------*
      *                  * Codice conto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore non ammesso : errore          *
      *                      *-----------------------------------------*
           if        w-rg2-cod-con (1)    not  = zero
                     go to cnt-tdo-rg2-160.
           move      "Manca il codice conto                             
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-160.
      *                  *---------------------------------------------*
      *                  * Commento in riga                            *
      *                  *---------------------------------------------*
       cnt-tdo-rg2-180.
      *                  *---------------------------------------------*
      *                  * Data e numero riferimento                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se campo da accettare              *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    not  = "C" and
                     w-rg2-tip-con (1)    not  = "F"
                     go to cnt-tdo-rg2-200.
      *                      *-----------------------------------------*
      *                      * Se valore non ammesso : errore          *
      *                      *-----------------------------------------*
           if        w-rg2-dat-rif (1)    =    zero   and
                     w-rg2-num-rif (1)    =    spaces
                     go to cnt-tdo-rg2-200.
           if        w-rg2-dat-rif (1)    not  = zero   and
                     w-rg2-num-rif (1)    not  = spaces
                     go to cnt-tdo-rg2-200.
           move      "Non e' ammessa una data riferimento senza numero r
      -              "iferimento     "    to   w-err-box-err-msg      .
           move      "o viceversa                                       
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     cnt-tdo-rg2-950.
       cnt-tdo-rg2-200.
      *                  *---------------------------------------------*
      *                  * Importo movimento                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore non ammesso : errore          *
      *                      *-----------------------------------------*
           if        w-rg2-imp-mov (1)    not  = zero
                     go to cnt-tdo-rg2-220.
           move      "Manca l'importo movimento                         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-220.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
       cnt-tdo-rg2-600.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rg2-999.
       cnt-tdo-rg2-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       cnt-tdo-rg2-950.
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rg2-flg      .
       cnt-tdo-rg2-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo 2                *
      *    *-----------------------------------------------------------*
       pre-rig-co2-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valori riga pre-accettazione        *
      *              *-------------------------------------------------*
           move      w-rg2-imp-mov (1)    to   w-srp-imp-mov          .
           move      w-rg2-dar-ave (1)    to   w-srp-dar-ave          .
       pre-rig-co2-999.
           exit.

      *    *===========================================================*
      *    * Attribuzione del numero progressivo per la riga 2 New     *
      *    *-----------------------------------------------------------*
       prg-rig-co2-000.
      *              *-------------------------------------------------*
      *              * Prelevamento da area di controllo catena        *
      *              *-------------------------------------------------*
           move      w-cat-rg2-prg        to   w-rg2-num-prg (1)      .
       prg-rig-co2-999.
           exit.

      *    *===========================================================*
      *    * Append riga in catena e update                            *
      *    *-----------------------------------------------------------*
       app-upd-rig-000.
      *              *-------------------------------------------------*
      *              * Append in catena                                *
      *              *-------------------------------------------------*
           move      "AP"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento del numero progressivo            *
      *              *-------------------------------------------------*
           perform   prg-rig-co2-000      thru prg-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Update catena                                   *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rg2-ope          .
           move      w-cat-rg2-max        to   w-cat-rg2-num          .
           move      w-rg2                to   w-cat-rg2-buf          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento totale righe movimento contabile  *
      *              *-------------------------------------------------*
           if        w-rg2-dar-ave (1)    =    "A"
                     subtract w-rg2-imp-mov (1)
                                          from w-co2-sdo-rmc (1)
           else      add      w-rg2-imp-mov (1)
                                          to   w-co2-sdo-rmc (1)      .
       app-upd-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     app-upd-rig-999.
       app-upd-rig-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo 2                     *
      *    *-----------------------------------------------------------*
       pos-rig-co2-000.
      *              *-------------------------------------------------*
      *              * Controaggiornamento                             *
      *              *-------------------------------------------------*
           if        w-srp-dar-ave        =    "A"
                     add        w-srp-imp-mov
                                          to   w-co2-sdo-rmc (1)
           else      subtract   w-srp-imp-mov
                                          from w-co2-sdo-rmc (1)      .
      *              *-------------------------------------------------*
      *              * Aggiornamento, se necessario                    *
      *              *-------------------------------------------------*
           if        w-cnt-co2-tip-agg    not  = "+"
                     go to pos-rig-co2-100.
           if        w-rg2-dar-ave (1)    =    "A"
                     subtract  w-rg2-imp-mov (1)
                                          from w-co2-sdo-rmc (1)
           else      add        w-rg2-imp-mov (1)
                                          to   w-co2-sdo-rmc (1)      .
       pos-rig-co2-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione saldo righe movimento contabile *
      *              *-------------------------------------------------*
           perform   vis-sdo-rmc-000      thru vis-sdo-rmc-999        .
       pos-rig-co2-200.
      *              *-------------------------------------------------*
      *              * Determinazione data e numero riferimento per pa-*
      *              * reggiamento automatico acconti                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se funzione non utilizzata : oltre          *
      *                  *---------------------------------------------*
           if        w-co2-imp-pap (1)    =    spaces
                     go to pos-rig-co2-300.
      *                  *---------------------------------------------*
      *                  * Se non si e' in riga 1 : oltre              *
      *                  *---------------------------------------------*
           if        w-cat-rg2-cur        not  = 1
                     go to pos-rig-co2-300.
      *                  *---------------------------------------------*
      *                  * Data riferimento                            *
      *                  *---------------------------------------------*
           if        w-rg2-dat-rif (1)    not  = zero
                     move  w-rg2-dat-rif (1)
                                          to   w-lpa-dri-doc
                     go to pos-rig-co2-220.
           move      w-tes-dat-doc (1)    to   w-lpa-dri-doc          .
       pos-rig-co2-220.
      *                  *---------------------------------------------*
      *                  * Numero riferimento                          *
      *                  *---------------------------------------------*
           if        w-rg2-num-rif (1)    not  = spaces
                     move  w-rg2-num-rif (1)
                                          to   w-lpa-nri-doc
                     go to pos-rig-co2-300.
           move      w-tes-num-doc (1)    to   w-lpa-nri-doc          .
       pos-rig-co2-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pos-rig-co2-999.
       pos-rig-co2-999.
           exit.

      *    *===========================================================*
      *    * Caricamento catena righe movimento di contabilita'        *
      *    *-----------------------------------------------------------*
       car-cat-rmc-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione saldo righe movimento di con-  *
      *              * tabilita'                                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-co2-sdo-rmc (1)      .
      *              *-------------------------------------------------*
      *              * Se tipo documento attualmente non riconosciu-   *
      *              * to : uscita                                     *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tdo    not  = 01 and
                     w-tes-cod-tmf-tdo    not  = 02 and
                     w-tes-cod-tmf-tdo    not  = 03
                     go to car-cat-rmc-999.
      *              *-------------------------------------------------*
      *              * Se tipo provenienza attualmente non riconosciu- *
      *              * to : uscita                                     *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01 and
                     w-tes-cod-tmf-tpv    not  = 02 and
                     w-tes-cod-tmf-tpv    not  = 03 and
                     w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-999.
       car-cat-rmc-100.
      *              *=================================================*
      *              * Ciclo per righe fornitore e iva                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-cat-rmc-ctr      .
       car-cat-rmc-120.
           add       1                    to   w-car-cat-rmc-ctr      .
           if        w-car-cat-rmc-ctr    >    3
                     go to car-cat-rmc-700.
      *                  *---------------------------------------------*
      *                  * Test se riga da preparare                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga 2                               *
      *                      *-----------------------------------------*
           if        w-car-cat-rmc-ctr    not  = 2
                     go to car-cat-rmc-130.
      *                          *-------------------------------------*
      *                          * Se documento Italia, o CEE          *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01 and
                     w-tes-cod-tmf-tpv    not  = 02
                     go to car-cat-rmc-122.
      *                              *---------------------------------*
      *                              * Se non esiste imposta deducibi- *
      *                              * le : a trattamento controparti- *
      *                              * te                              *
      *                              *---------------------------------*
           if        w-te2-tot-imp (1)    =    zero           or
                     w-te2-tot-imp (1)    =    w-te2-tot-ind (1)
                     go to car-cat-rmc-700.
      *                              *---------------------------------*
      *                              * A trattamento riga 2            *
      *                              *---------------------------------*
           go to     car-cat-rmc-160.
       car-cat-rmc-122.
      *                          *-------------------------------------*
      *                          * Se documento Estero                 *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 03
                     go to car-cat-rmc-124.
      *                              *---------------------------------*
      *                              * A trattamento contropartite     *
      *                              *---------------------------------*
           go to     car-cat-rmc-700.
       car-cat-rmc-124.
      *                      *-----------------------------------------*
      *                      * A trattamento riga 2                    *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-160.
       car-cat-rmc-130.
      *                      *-----------------------------------------*
      *                      * Se riga 3                               *
      *                      *-----------------------------------------*
           if        w-car-cat-rmc-ctr    not  = 3
                     go to car-cat-rmc-160.
      *                          *-------------------------------------*
      *                          * Se documento Italia                 *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to car-cat-rmc-131.
      *                          *-------------------------------------*
      *                          * Se documento Reverse Charge         *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-rfp    not  = "R"
                     go to car-cat-rmc-700
           else      go to car-cat-rmc-132.
       car-cat-rmc-131.
      *                          *-------------------------------------*
      *                          * Se Bolla doganale                   *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 04
                     go to car-cat-rmc-132.
      *                              *---------------------------------*
      *                              * Se non esiste imposta deducibi- *
      *                              * le : a trattamento controparti- *
      *                              * te                              *
      *                              *---------------------------------*
           if        w-te2-tot-imp (1)    =    zero           or
                     w-te2-tot-imp (1)    =    w-te2-tot-ind (1)
                     go to car-cat-rmc-700.
       car-cat-rmc-132.
      *                      *-----------------------------------------*
      *                      * A trattamento riga 3                    *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-160.
       car-cat-rmc-160.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rg2-000      thru nor-nok-rg2-999        .
      *                  *---------------------------------------------*
      *                  * Composizione riga                           *
      *                  *---------------------------------------------*
       car-cat-rmc-200.
      *                      *=========================================*
      *                      * Tipo conto                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del numero   *
      *                          * riga                                *
      *                          *-------------------------------------*
           go to     car-cat-rmc-210
                     car-cat-rmc-220
                     car-cat-rmc-230
                     depending            on   w-car-cat-rmc-ctr      .
       car-cat-rmc-210.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 1           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-tc1-000  thru car-cat-rmc-tc1-999    .
      *                              *---------------------------------*
      *                              * A trattamento codice e descri-  *
      *                              * zione conto                     *
      *                              *---------------------------------*
           go to     car-cat-rmc-300.
       car-cat-rmc-220.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 2           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-tc2-000  thru car-cat-rmc-tc2-999    .
      *                              *---------------------------------*
      *                              * A trattamento codice e descri-  *
      *                              * zione conto                     *
      *                              *---------------------------------*
           go to     car-cat-rmc-300.
       car-cat-rmc-230.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 3           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-tc3-000  thru car-cat-rmc-tc3-999    .
      *                              *---------------------------------*
      *                              * A trattamento codice e descri-  *
      *                              * zione conto                     *
      *                              *---------------------------------*
           go to     car-cat-rmc-300.
       car-cat-rmc-300.
      *                      *=========================================*
      *                      * Codice e descrizione conto              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del numero   *
      *                          * riga                                *
      *                          *-------------------------------------*
           go to     car-cat-rmc-310
                     car-cat-rmc-320
                     car-cat-rmc-330
                     depending            on   w-car-cat-rmc-ctr      .
       car-cat-rmc-310.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 1           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-cd1-000  thru car-cat-rmc-cd1-999    .
      *                              *---------------------------------*
      *                              * A trattamento commento          *
      *                              *---------------------------------*
           go to     car-cat-rmc-400.
       car-cat-rmc-320.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 2           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-cd2-000  thru car-cat-rmc-cd2-999    .
      *                              *---------------------------------*
      *                              * A trattamento commento          *
      *                              *---------------------------------*
           go to     car-cat-rmc-400.
       car-cat-rmc-330.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 3           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-cd3-000  thru car-cat-rmc-cd3-999    .
      *                              *---------------------------------*
      *                              * A trattamento commento          *
      *                              *---------------------------------*
           go to     car-cat-rmc-400.
       car-cat-rmc-400.
      *                      *=========================================*
      *                      * Commento in riga                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Per tutti i tipi documento : spazi  *
      *                          *-------------------------------------*
           move      spaces               to   w-rg2-com-rig (1)      .
      *                          *-------------------------------------*
      *                          * A trattamento flag di Dare/Avere    *
      *                          *-------------------------------------*
           go to     car-cat-rmc-500.
       car-cat-rmc-500.
      *                      *=========================================*
      *                      * Flag di Dare/Avere e importo in riga    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del numero   *
      *                          * riga                                *
      *                          *-------------------------------------*
           go to     car-cat-rmc-510
                     car-cat-rmc-520
                     car-cat-rmc-530
                     depending            on   w-car-cat-rmc-ctr      .
       car-cat-rmc-510.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 1           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-fd1-000  thru car-cat-rmc-fd1-999    .
      *                              *---------------------------------*
      *                              * A test finali                   *
      *                              *---------------------------------*
           go to     car-cat-rmc-600.
       car-cat-rmc-520.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 2           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-fd2-000  thru car-cat-rmc-fd2-999    .
      *                              *---------------------------------*
      *                              * A test finali                   *
      *                              *---------------------------------*
           go to     car-cat-rmc-600.
       car-cat-rmc-530.
      *                          *-------------------------------------*
      *                          * Se si e' in riga numero 3           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Subroutine                      *
      *                              *---------------------------------*
           perform   car-cat-rmc-fd3-000  thru car-cat-rmc-fd3-999    .
      *                              *---------------------------------*
      *                              * A test finali                   *
      *                              *---------------------------------*
           go to     car-cat-rmc-600.
       car-cat-rmc-600.
      *                      *=========================================*
      *                      * Se gli elementi della riga fin qui pre- *
      *                      * parati non sono corretti : uscita       *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    =   spaces or
                     w-rg2-cod-con (1)    =   zero   or
                     w-rg2-dar-ave (1)    =   spaces or
                     w-rg2-imp-mov (1)    =   zero
                     go to car-cat-rmc-999.
      *                      *-----------------------------------------*
      *                      * Aggiustamento Dare/Avere e importo in   *
      *                      * caso di importo negativo                *
      *                      *-----------------------------------------*
           if        w-rg2-imp-mov (1)    >    zero
                     go to car-cat-rmc-620.
           multiply  -1                   by   w-rg2-imp-mov (1)      .
           if        w-rg2-dar-ave (1)    =    "D"
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
       car-cat-rmc-620.
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    =    "G"
                     move  spaces         to   w-rg2-tip-arc (1)
           else      move  w-rg2-tip-con (1)
                                          to   w-rg2-tip-arc (1)      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    =    "G"
                     move  zero           to   w-rg2-cod-arc (1)
           else      move  w-rg2-cod-con (1)
                                          to   w-rg2-cod-arc (1)      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    =    "G"
                     move  w-rg2-cod-con (1)
                                          to   w-rg2-cod-pdc (1)
           else if   w-rg2-tip-con (1)    =    "F" and
                     w-car-cat-rmc-ctr    =    1
                     move  w-tes-cod-arc-cge (1)
                                          to   w-rg2-cod-pdc (1)      .
      *                  *---------------------------------------------*
      *                  * Append in catena e update                   *
      *                  *---------------------------------------------*
           perform   app-upd-rig-000      thru app-upd-rig-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-cat-rmc-120.
       car-cat-rmc-700.
      *              *=================================================*
      *              * Contropartite contabili                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'impostazione ri-  *
      *                  * ghe del documento                           *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to car-cat-rmc-800.
      *                  *---------------------------------------------*
      *                  * Se no impostazione righe del documento      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine                              *
      *                      *-----------------------------------------*
           perform   car-cat-rmc-cpc-000  thru car-cat-rmc-cpc-999    .
       car-cat-rmc-750.
      *                      *=========================================*
      *                      * Se gli elementi della riga fin qui      *
      *                      * preparati non sono corretti : uscita    *
      *                      *-----------------------------------------*
           if        w-rg2-tip-con (1)    =   spaces or
                     w-rg2-cod-con (1)    =   zero   or
                     w-rg2-dar-ave (1)    =   spaces or
                     w-rg2-imp-mov (1)    =   zero
                     go to car-cat-rmc-999.
      *                          *-------------------------------------*
      *                          * Aggiustamento Dare/Avere e importo  *
      *                          * in caso di importo negativo         *
      *                          *-------------------------------------*
           if        w-rg2-imp-mov (1)    >    zero
                     go to car-cat-rmc-770.
           multiply  -1                   by   w-rg2-imp-mov (1)      .
           if        w-rg2-dar-ave (1)    =    "D"
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
       car-cat-rmc-770.
      *                          *-------------------------------------*
      *                          * Codice sottoconto                   *
      *                          *-------------------------------------*
           move      w-rg2-cod-con (1)    to   w-rg2-cod-pdc (1)      .
      *                      *-----------------------------------------*
      *                      * Append in catena e update               *
      *                      *-----------------------------------------*
           perform   app-upd-rig-000      thru app-upd-rig-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-999.
       car-cat-rmc-800.
      *                  *=============================================*
      *                  * Se si impostazione righe del documento      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione castelletto controparti- *
      *                      * te                                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione totale controparti- *
      *                          * te                                  *
      *                          *-------------------------------------*
           move      zero                 to   w-car-cat-rmc-tcp      .
      *                          *-------------------------------------*
      *                          * Ciclo di scansione su castelletto   *
      *                          * contropartite per totali di riepi-  *
      *                          * logo documento                      *
      *                          *-------------------------------------*
           move      zero                 to   w-car-cat-rmc-ctr      .
       car-cat-rmc-802.
           add       1                    to   w-car-cat-rmc-ctr      .
           if        w-car-cat-rmc-ctr    >    w-trd-ctp-ele
                     go to car-cat-rmc-810.
      *                              *---------------------------------*
      *                              * Codice contropartita            *
      *                              *---------------------------------*
           move      w-trd-ctp-cod
                    (w-car-cat-rmc-ctr)   to   w-car-cat-rmc-cod
                                              (w-car-cat-rmc-ctr)     .
      *                              *---------------------------------*
      *                              * Importo contropartita in valuta *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Test se da trattare         *
      *                                  *-----------------------------*
           if        w-tes-sgl-vpf (1)   =    c-sgl
                     go to car-cat-rmc-804.
      *                                  *-----------------------------*
      *                                  * Bufferizzazione             *
      *                                  *-----------------------------*
           move      w-trd-ctp-imp
                    (w-car-cat-rmc-ctr)   to   w-car-cat-rmc-iiv
                                              (w-car-cat-rmc-ctr)     .
       car-cat-rmc-804.
      *                              *---------------------------------*
      *                              * Importo in valuta base          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Se documento in valuta      *
      *                                  *-----------------------------*
           if        w-tes-sgl-vpf (1)   =    c-sgl
                     go to car-cat-rmc-806.
      *                                      *-------------------------*
      *                                      * Conversione importo in  *
      *                                      * valuta base             *
      *                                      *-------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-trd-ctp-imp
                    (w-car-cat-rmc-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-car-cat-rmc-imp
                                              (w-car-cat-rmc-ctr)     .
      *                                      *-------------------------*
      *                                      * Oltre                   *
      *                                      *-------------------------*
           go to     car-cat-rmc-808.
       car-cat-rmc-806.
      *                                  *-----------------------------*
      *                                  * Se documento in valuta base *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Bufferizzazione         *
      *                                      *-------------------------*
           move      w-trd-ctp-imp
                    (w-car-cat-rmc-ctr)   to   w-car-cat-rmc-imp
                                              (w-car-cat-rmc-ctr)     .
      *                                      *-------------------------*
      *                                      * Oltre                   *
      *                                      *-------------------------*
           go to     car-cat-rmc-808.
       car-cat-rmc-808.
      *                              *---------------------------------*
      *                              * Aggiornamento totale contropar- *
      *                              * tite                            *
      *                              *---------------------------------*
           add       w-car-cat-rmc-imp
                    (w-car-cat-rmc-ctr)   to   w-car-cat-rmc-tcp      .
      *                              *---------------------------------*
      *                              * Riciclo su scansione            *
      *                              *---------------------------------*
           go to     car-cat-rmc-802.
       car-cat-rmc-810.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero elementi         *
      *                      *-----------------------------------------*
           move      w-trd-ctp-ele        to   w-car-cat-rmc-ele      .
      *                      *-----------------------------------------*
      *                      * Se documento estero si salta il succes- *
      *                      * sivo aggiustamento                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03
                     go to car-cat-rmc-815.
      *                      *-----------------------------------------*
      *                      * Determinazione totale contropartite da  *
      *                      * castelletto iva                         *
      *                      *-----------------------------------------*
           move      w-te2-tot-ibl (1)    to   w-car-cat-rmc-tci      .
           add       w-te2-tot-ind (1)    to   w-car-cat-rmc-tci      .
      *                      *-----------------------------------------*
      *                      * Aggiustamento della prima contropartita *
      *                      * nel caso che il totale contropartite    *
      *                      * del castelletto non sia uguale al tota- *
      *                      * le contropartite da castelletto iva     *
      *                      *-----------------------------------------*
           if        w-car-cat-rmc-tci    =    w-car-cat-rmc-tcp
                     go to car-cat-rmc-815.
           subtract  w-car-cat-rmc-tcp    from w-car-cat-rmc-tci
                                        giving w-car-cat-rmc-s11
           add       w-car-cat-rmc-s11    to   w-car-cat-rmc-imp (1)  .
       car-cat-rmc-815.
      *                      *-----------------------------------------*
      *                      * Ciclo su castelletto contropartite      *
      *                      *-----------------------------------------*
           move      zero                 to   w-car-cat-rmc-ctr      .
       car-cat-rmc-820.
           add       1                    to   w-car-cat-rmc-ctr      .
           if        w-car-cat-rmc-ctr    >    w-car-cat-rmc-ele
                     go to car-cat-rmc-999.
      *                      *-----------------------------------------*
      *                      * Normalizzazione riga                    *
      *                      *-----------------------------------------*
           perform   nor-nok-rg2-000      thru nor-nok-rg2-999        .
      *                      *-----------------------------------------*
      *                      * Composizione riga                       *
      *                      *-----------------------------------------*
       car-cat-rmc-830.
      *                          *-------------------------------------*
      *                          * Tipo conto                          *
      *                          *-------------------------------------*
           move      "G"                  to   w-rg2-tip-con (1)      .
       car-cat-rmc-840.
      *                          *-------------------------------------*
      *                          * Codice e descrizione conto          *
      *                          *-------------------------------------*
           move      w-car-cat-rmc-cod
                    (w-car-cat-rmc-ctr)   to   w-rg2-cod-con (1)      .
           move      w-rg2-cod-con (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rg2-des-con (1)      .
       car-cat-rmc-850.
      *                          *-------------------------------------*
      *                          * Commento in riga                    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test su personalizzazione       *
      *                              *---------------------------------*
            if       w-prs-rsf-icr        =    "S"
                     move  w-tes-cod-arc-rag (1)
                                          to   w-rg2-com-rig (1)      .
       car-cat-rmc-860.
      *                          *-------------------------------------*
      *                          * Flag di Dare/Avere e importo        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Flag di Dare/Avere              *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tdo    =    03
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
      *                              *---------------------------------*
      *                              * Importo                         *
      *                              *---------------------------------*
           move      w-car-cat-rmc-imp
                    (w-car-cat-rmc-ctr)   to   w-rg2-imp-mov (1)      .
       car-cat-rmc-870.
      *                          *-------------------------------------*
      *                          * Se gli elementi della riga fin qui  *
      *                          * preparati non sono corretti : usci- *
      *                          * ta                                  *
      *                          *-------------------------------------*
           if        w-rg2-tip-con (1)    =   spaces or
                     w-rg2-cod-con (1)    =   zero   or
                     w-rg2-dar-ave (1)    =   spaces or
                     w-rg2-imp-mov (1)    =   zero
                     go to car-cat-rmc-999.
      *                          *-------------------------------------*
      *                          * Aggiustamento Dare/Avere e importo  *
      *                          * in caso di importo negativo         *
      *                          *-------------------------------------*
           if        w-rg2-imp-mov (1)    >    zero
                     go to car-cat-rmc-880.
           multiply  -1                   by   w-rg2-imp-mov (1)      .
           if        w-rg2-dar-ave (1)    =    "D"
                     move  "A"            to   w-rg2-dar-ave (1)
           else      move  "D"            to   w-rg2-dar-ave (1)      .
       car-cat-rmc-880.
      *                          *-------------------------------------*
      *                          * Codice sottoconto                   *
      *                          *-------------------------------------*
           move      w-rg2-cod-con (1)    to   w-rg2-cod-pdc (1)      .
      *                      *-----------------------------------------*
      *                      * Append in catena e update               *
      *                      *-----------------------------------------*
           perform   app-upd-rig-000      thru app-upd-rig-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione castelletto con-   *
      *                      * tropartite                              *
      *                      *-----------------------------------------*
           go to     car-cat-rmc-820.
       car-cat-rmc-999.
           exit.

      *    *===========================================================*
      *    * Caricamento catena righe movimento di contabilita'        *
      *    *                                                           *
      *    * Subroutine di trattamento Tipo conto                      *
      *    *                                                           *
      *    * Riga contabile 1                                          *
      *    *-----------------------------------------------------------*
       car-cat-rmc-tc1-000.
      *              *-------------------------------------------------*
