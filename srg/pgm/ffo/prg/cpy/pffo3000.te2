      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-civ-scp-100.
       acc-civ-scp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-civ-scp (1)    =    w-sav-civ-scp
                     go to acc-civ-scp-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-civ-scp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-civ-scp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-civ-scp-100.
       acc-civ-scp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Codice iva sconto pa-   *
      *    * gamento                                                   *
      *    *-----------------------------------------------------------*
       vis-civ-scp-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-te2-tot-scp (1)    =    zero
                     go to vis-civ-scp-999.
       vis-civ-scp-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-te2-civ-scp (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      08                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-scp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Si/No addebito spesa in    *
      *    * funzione di w-acc-iep-spe-ctr                             *
      *    *-----------------------------------------------------------*
       acc-spe-snx-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-snx-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-snx          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-spe-snx-400.
       acc-spe-snx-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-spe-snx-lun    to   v-car                  .
           move      w-exp-spe-snx-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      "NS#"                to   v-msk                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      w-exp-spe-snx-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-te2-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     move  1              to   v-num
           else if   w-te2-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    1
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-spe-snx-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-spe-snx-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  0              to   w-te2-spe-snx
                                              (1, w-acc-iep-spe-inx)
           else if   v-num                =    2
                     move  1              to   w-te2-spe-snx
                                              (1, w-acc-iep-spe-inx)
           else      move  zero           to   w-te2-spe-snx
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-snx-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-snx-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-snx
                     go to acc-spe-snx-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-snx-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-spe-snx-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-snx-100.
       acc-spe-snx-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Si/No addebito spese    *
      *    *-----------------------------------------------------------*
       vis-spe-snx-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-snx-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-snx-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-spe-snx-lun    to   v-car                  .
           move      w-exp-spe-snx-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      w-exp-spe-snx-tbl    to   v-txt                  .
           if        w-te2-spe-snx
                    (1, w-vis-iep-spe-inx)
                                          =    0
                     move  1              to   v-num
           else if   w-te2-spe-snx
                    (1, w-vis-iep-spe-inx)
                                          =    1
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-snx-100.
       vis-spe-snx-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Importo spesa in funzione  *
      *    * di w-acc-iep-spe-ctr                                      *
      *    *-----------------------------------------------------------*
       acc-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero spese personalizzate a zero : *
      *                      * il campo non e' da accettare            *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-imp-999.
      *                      *-----------------------------------------*
      *                      * Se spesa da non addebitare : no         *
      *                      *-----------------------------------------*
           if        w-te2-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     go to acc-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-imp          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-spe-imp-400.
       acc-spe-imp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-te2-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-spe-imp
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-imp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-imp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-imp
                     go to acc-spe-imp-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione percentuale spesa       *
      *                      *-----------------------------------------*
           move      zero                 to   w-te2-spe-per
                                              (1, w-acc-iep-spe-inx)  .
      *                      *-----------------------------------------*
      *                      * Trattamento codice iva spesa            *
      *                      *-----------------------------------------*
           if        w-te2-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          =    zero
                     move  zero           to   w-te2-spe-civ
                                              (1, w-acc-iep-spe-inx)  .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-imp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-spe-imp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-imp-100.
       acc-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : Importi spese          *
      *    *-----------------------------------------------------------*
       vis-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-imp-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      31                   to   v-pos                  .
           move      w-te2-spe-imp
                    (1, w-vis-iep-spe-inx)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-imp-100.
       vis-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Codice iva spesa in fun-   *
      *    * zione di w-acc-iep-spe-ctr                                *
      *    *-----------------------------------------------------------*
       acc-spe-civ-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero spese personalizzate a zero : *
      *                      * il campo non e' da accettare            *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-civ-999.
      *                      *-----------------------------------------*
      *                      * Se spesa da non addebitare : no         *
      *                      *-----------------------------------------*
           if        w-te2-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     go to acc-spe-civ-999.
      *                      *-----------------------------------------*
      *                      * Se importo spesa a zero : no            *
      *                      *-----------------------------------------*
           if        w-te2-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          =    zero
                     go to acc-spe-civ-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-spe-civ
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-civ          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-spe-civ-400.
       acc-spe-civ-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-te2-spe-civ
                    (1, w-acc-iep-spe-inx)
                                          to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           add       09
                     w-acc-iep-spe-ctr  giving w-cod-mne-zci-lin      .
           move      44                   to   w-cod-mne-zci-pos      .
           move      zero                 to   w-cod-mne-zci-dln      .
           move      zero                 to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-spe-civ-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-spe-civ-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-spe-civ-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-spe-civ-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-spe-civ-110.
       acc-spe-civ-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-spe-civ-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-spe-civ-999.
       acc-spe-civ-200.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-spe-civ
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-civ-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-te2-spe-civ
                    (1, w-acc-iep-spe-inx)
                                          to   d-imp-iva-cod-iva      .
           move      spaces               to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Se controllo non superato                   *
      *                  *---------------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-spe-civ-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-spe-civ-100.
       acc-spe-civ-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-spe-civ
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-civ
                     go to acc-spe-civ-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-civ-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-spe-civ-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-civ-100.
       acc-spe-civ-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Codice iva spesa in     *
      *    * funzione di w-acc-iep-spe-ctr                             *
      *    *-----------------------------------------------------------*
       vis-spe-civ-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-civ-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-civ-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Editing preliminare                         *
      *                  *---------------------------------------------*
           move      w-te2-spe-civ
                    (1, w-vis-iep-spe-inx)
                                          to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-te2-spe-snx           
                    (1, w-vis-iep-spe-inx)
                                          =    0
                     go to vis-spe-civ-100.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      44                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-civ-100.
       vis-spe-civ-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Spese incasso              *
      *    *-----------------------------------------------------------*
       acc-tot-spi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-tot-spi (1)    to   w-sav-tot-spi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-tot-spi-400.
       acc-tot-spi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-te2-tot-spi (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-tot-spi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-tot-spi-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-tot-spi (1)      .
       acc-tot-spi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-spi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-tot-spi (1)    =    w-sav-tot-spi
                     go to acc-tot-spi-800.
      *                      *-----------------------------------------*
      *                      * Attivazione flag di modifica importo    *
      *                      * spese incasso                           *
      *                      *-----------------------------------------*
           move      "#"                  to   w-te2-fdm-spi (1)      .
      *                      *-----------------------------------------*
      *                      * Trattamento codice iva spese incasso    *
      *                      *-----------------------------------------*
           if        w-te2-tot-spi (1)    =    zero
                     move  zero           to   w-te2-civ-spi (1)      .
      *                      *-----------------------------------------*
      *                      * Se totale spese incasso diverso da zero *
      *                      * e codice addebito spese incasso di te-  *
      *                      * stata a spaces : si bufferizzano il co- *
      *                      * dice iva e contropartita della referen- *
      *                      * za                                      *
      *                      *-----------------------------------------*
           if        w-te2-tot-spi (1)    not  = zero and
                     w-tes-add-spi (1)    =    spaces
                     move  w-ref-spe-inc-civ
                                          to   w-te2-civ-spi (1)
                     move  w-ref-spe-inc-ccp
                                          to   w-te2-ccp-spi (1)
                     perform vis-civ-spi-000
                                          thru vis-civ-spi-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-spi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-tot-spi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-spi-100.
       acc-tot-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Spese incasso           *
      *    *-----------------------------------------------------------*
       vis-tot-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      w-te2-tot-spi (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-spi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Codice iva spese incasso   *
      *    *-----------------------------------------------------------*
       acc-civ-spi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-te2-tot-spi (1)    =    zero
                     go to acc-civ-spi-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-civ-spi (1)    to   w-sav-civ-spi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-civ-spi-400.
       acc-civ-spi-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-te2-civ-spi (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      19                   to   w-cod-mne-zci-lin      .
           move      44                   to   w-cod-mne-zci-pos      .
           move      zero                 to   w-cod-mne-zci-dln      .
           move      zero                 to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-civ-spi-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-civ-spi-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-civ-spi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-civ-spi-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-civ-spi-110.
       acc-civ-spi-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-civ-spi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-civ-spi-999.
       acc-civ-spi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-civ-spi (1)      .
       acc-civ-spi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-te2-civ-spi (1)    to   d-imp-iva-cod-iva      .
           move      spaces               to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Se controllo non superato                   *
      *                  *---------------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-civ-spi-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-civ-spi-100.
       acc-civ-spi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-civ-spi (1)    =    w-sav-civ-spi
                     go to acc-civ-spi-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-civ-spi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-civ-spi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-civ-spi-100.
       acc-civ-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Codice iva spese incas- *
      *    * so                                                        *
      *    *-----------------------------------------------------------*
       vis-civ-spi-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-te2-civ-spi (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-spi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Spese bollo                *
      *    *-----------------------------------------------------------*
       acc-tot-spb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-tot-spb (1)    to   w-sav-tot-spb          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-tot-spb-400.
       acc-tot-spb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-te2-tot-spb (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-tot-spb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-tot-spb-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-tot-spb (1)      .
       acc-tot-spb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-spb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-tot-spb (1)    =    w-sav-tot-spb
                     go to acc-tot-spb-800.
      *                      *-----------------------------------------*
      *                      * Attivazione flag di modifica importo    *
      *                      * spese bollo                             *
      *                      *-----------------------------------------*
           move      "#"                  to   w-te2-fdm-spb (1)      .
      *                      *-----------------------------------------*
      *                      * Trattamento codice iva spese bollo      *
      *                      *-----------------------------------------*
           if        w-te2-tot-spb (1)    =    zero
                     move  zero           to   w-te2-civ-spb (1)      .
      *                      *-----------------------------------------*
      *                      * Se totale spese bollo diverso da zero   *
      *                      * e codice addebito spese bollo di te-    *
      *                      * stata a spaces : si bufferizzano il co- *
      *                      * dice iva e contropartita della referen- *
      *                      * za                                      *
      *                      *-----------------------------------------*
           if        w-te2-tot-spb (1)    not  = zero and
                     w-tes-add-spb (1)    =    spaces
                     move  w-ref-spe-bol-civ
                                          to   w-te2-civ-spb (1)
                     move  w-ref-spe-bol-ccp
                                          to   w-te2-ccp-spb (1)
                     perform vis-civ-spb-000
                                          thru vis-civ-spb-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-spb-800.
      *              *-------------------------------------------------*
