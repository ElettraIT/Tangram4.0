           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-tot-spb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-spb-100.
       acc-tot-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Spese bollo             *
      *    *-----------------------------------------------------------*
       vis-tot-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      w-te2-tot-spb (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-spb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata 2 : Codice iva spese bollo     *
      *    *-----------------------------------------------------------*
       acc-civ-spb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-te2-tot-spb (1)    =    zero
                     go to acc-civ-spb-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-civ-spb (1)    to   w-sav-civ-spb          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-civ-spb-400.
       acc-civ-spb-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-te2-civ-spb (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      20                   to   w-cod-mne-zci-lin      .
           move      44                   to   w-cod-mne-zci-pos      .
           move      zero                 to   w-cod-mne-zci-dln      .
           move      zero                 to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-civ-spb-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-civ-spb-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-civ-spb-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-civ-spb-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-civ-spb-110.
       acc-civ-spb-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-civ-spb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-civ-spb-999.
       acc-civ-spb-200.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-civ-spb (1)      .
       acc-civ-spb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-te2-civ-spb (1)    to   d-imp-iva-cod-iva      .
           move      spaces               to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Se controllo non superato                   *
      *                  *---------------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-civ-spb-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-civ-spb-100.
       acc-civ-spb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-te2-civ-spb (1)    =    w-sav-civ-spb
                     go to acc-civ-spb-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione pagina testata 2      *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-te2-reg-000      thru vis-te2-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-civ-spb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-civ-spb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-civ-spb-100.
       acc-civ-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Codice iva spese bollo  *
      *    *-----------------------------------------------------------*
       vis-civ-spb-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-te2-civ-spb (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata 2 : Riepilogo totali        *
      *    *-----------------------------------------------------------*
       vis-rie-tot-000.
      *              *-------------------------------------------------*
      *              * Totale lordo                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-trd-tot-lor        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale netto                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-trd-tot-net        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale spese                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-trd-tot-spe        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale imponibile                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      13                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-trd-tot-ibl        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale imposta                                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      15                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-trd-tot-imp        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale documento                                *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-trd-tot-doc        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to vis-rie-tot-999.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-trd-tot-doc        to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-cvs-vlt-avb        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Descrizione causale contabile        *
      *    *-----------------------------------------------------------*
       acc-des-cau-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-te2-des-cau (1)    not  = spaces
                     go to acc-des-cau-100.
           move      w-tes-cod-tmf-ccg    to   w-let-arc-zcc-cod      .
           perform   let-arc-zcc-000      thru let-arc-zcc-999        .
           move      w-let-arc-zcc-des    to   w-te2-des-cau (1)      .
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-des-cau-400.
       acc-des-cau-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-ldt                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-te2-des-cau (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-des-cau-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-des-cau-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-te2-des-cau (1)      .
       acc-des-cau-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-des-cau-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale default per Regime fiscale        *
      *                  *---------------------------------------------*
           if        w-te2-flg-rfp (1)    not  = spaces
                     go to acc-des-cau-800.
           if        w-tes-cod-tmf-rfp    not  = "R"
                     go to acc-des-cau-800.
           move      w-tes-cod-tmf-rfp    to   w-te2-flg-rfp (1)      .
           perform   vis-flg-rfp-000      thru vis-flg-rfp-999        .
       acc-des-cau-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-des-cau-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-des-cau-100.
       acc-des-cau-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione causale contabile     *
      *    *-----------------------------------------------------------*
       vis-des-cau-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-ldt                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-te2-des-cau (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-des-cau-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data registrazione contabile         *
      *    *-----------------------------------------------------------*
       acc-dat-mgd-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-dat-mgd (1)    to   w-sav-dat-mgd          .
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-te2-dat-mgd (1)    =    zero
                     move  w-def-dat-mgd  to   w-te2-dat-mgd (1)
                     perform vis-dat-mgd-000
                                          thru vis-dat-mgd-999        .
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-dat-mgd-400.
       acc-dat-mgd-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo in Inserimento                         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-dat-mgd-120.
      *                  *---------------------------------------------*
      *                  * Editing data registrazione                  *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-tes-dat-reg        to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   w-all-str-cat (02)     .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "Data registrazione impostata :"
                                          to   w-all-str-cat (01)     .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Nota 1                                      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      w-all-str-alf        to   v-nt1                  .
           move      spaces               to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-dat-mgd-120.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-te2-dat-mgd (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative attuali            *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-dat-mgd-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-dat-mgd-999.
       acc-dat-mgd-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-te2-dat-mgd (1)      .
       acc-dat-mgd-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-te2-dat-mgd (1)    not  = zero
                     go to acc-dat-mgd-450.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-te2
                     go to acc-dat-mgd-600
           else      go to acc-dat-mgd-100.
       acc-dat-mgd-450.
      *                  *---------------------------------------------*
      *                  * In Inserimento la data registrazione deve   *
      *                  * essere superiore alla data registrazione    *
      *                  * minima per la contabilita' generale         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-dat-mgd-600.
           if        w-te2-dat-mgd (1)    not  < w-gen-dtm-cge
                     go to acc-dat-mgd-600.
           move      "Data di registrazione inferiore al minimo consenti
      -              "to             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-dat-mgd-100.
       acc-dat-mgd-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-mgd-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-dat-mgd-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-mgd-100.
       acc-dat-mgd-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data registrazione contabile      *
      *    *-----------------------------------------------------------*
       vis-dat-mgd-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-te2-dat-mgd (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-mgd-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero giornale iva                  *
      *    *-----------------------------------------------------------*
       acc-ngi-iva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 
                     go to acc-ngi-iva-999.
           if        w-prs-mul-gia-snx    not  = "S"
                     go to acc-ngi-iva-999.
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-te2-ngi-iva (1)    =    zero
                     move  w-tes-cod-tmf-giv
                                          to   w-te2-ngi-iva (1)
                     perform vis-ngi-iva-000
                                          thru vis-ngi-iva-999        .
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-ngi-iva-400.
       acc-ngi-iva-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      07                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-te2-ngi-iva (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-ngi-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-ngi-iva-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-ngi-iva (1)      .
       acc-ngi-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul valore massimo                     *
      *                  *---------------------------------------------*
           if        w-te2-ngi-iva (1)    >    w-prs-mul-gia-max
                     go to acc-ngi-iva-100.
       acc-ngi-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ngi-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-ngi-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ngi-iva-100.
       acc-ngi-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero giornale iva               *
      *    *-----------------------------------------------------------*
       vis-ngi-iva-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 
                     go to vis-ngi-iva-999.
           if        w-prs-mul-gia-snx    not  = "S"
                     go to vis-ngi-iva-999.
       vis-ngi-iva-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      07                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-te2-ngi-iva (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-ngi-iva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Regime fiscale                       *
      *    *-----------------------------------------------------------*
       acc-flg-rfp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to acc-flg-rfp-999.
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-flg-rfp-400.
      *                  *---------------------------------------------*
      *                  * Eventuale default                           *
      *                  *---------------------------------------------*
           if        w-te2-flg-rfp (1)    not  = spaces
                     go to acc-flg-rfp-100.
           move      w-tes-cod-tmf-rfp    to   w-te2-flg-rfp (1)      .
       acc-flg-rfp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-rfp-lun    to   v-car                  .
           move      w-exp-flg-rfp-num    to   v-ldt                  .
           move      "ORE#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-flg-rfp-tbl    to   v-txt                  .
      *
           if        w-te2-flg-rfp (1)    =    spaces
                     move  01             to   v-num
           else if   w-te2-flg-rfp (1)    =    "N"
                     move  01             to   v-num
           else if   w-te2-flg-rfp (1)    =    "R"
                     move  02             to   v-num
           else if   w-te2-flg-rfp (1)    =    "E"
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-flg-rfp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-flg-rfp-999.
       acc-flg-rfp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  spaces         to   w-te2-flg-rfp (1)
           else if   v-num                =    02
                     move  "R"            to   w-te2-flg-rfp (1)
           else if   v-num                =    03
                     move  "E"            to   w-te2-flg-rfp (1)
           else      move  spaces         to   w-te2-flg-rfp (1)      .
       acc-flg-rfp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-flg-rfp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-flg-rfp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-flg-rfp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-flg-rfp-100.
       acc-flg-rfp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Regime fiscale                    *
      *    *-----------------------------------------------------------*
       vis-flg-rfp-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 01
                     go to vis-flg-rfp-999.
       vis-flg-rfp-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-rfp-lun    to   v-car                  .
           move      w-exp-flg-rfp-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-flg-rfp-tbl    to   v-txt                  .
      *
           if        w-te2-flg-rfp (1)    =    spaces
                     move  01             to   v-num
           else if   w-te2-flg-rfp (1)    =    "N"
                     move  01             to   v-num
           else if   w-te2-flg-rfp (1)    =    "R"
                     move  02             to   v-num
           else if   w-te2-flg-rfp (1)    =    "E"
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-rfp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero protocollo iva                *
      *    *-----------------------------------------------------------*
       acc-npt-iva-000.
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 
                     go to acc-npt-iva-999.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-te2-npt-iva (1)    to   w-sav-npt-iva          .
       acc-npt-iva-050.
      *              *-------------------------------------------------*
      *              * Preparazione valore di default                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non numerazione semiautomatica : nessun  *
      *                  * default                                     *
      *                  *---------------------------------------------*
           if        w-prs-pif-aut        not  = "S"
                     go to acc-npt-iva-080.
      *                  *---------------------------------------------*
      *                  * Se non in inserimento : nessun default      *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-npt-iva-080.
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso da zero : nessun  *
      *                  * default                                     *
      *                  *---------------------------------------------*
           if        w-te2-npt-iva (1)    not  = zero
                     go to acc-npt-iva-080.
      *                  *---------------------------------------------*
      *                  * Attribuzione nuovo protocollo iva fornitori *
      *                  *---------------------------------------------*
           move      w-te2-dat-mgd (1)    to   w-num-prt-ivf-dat      .
           move      w-te2-ngi-iva (1)    to   w-num-prt-ivf-ngi      .
           perform   att-prt-ivf-000      thru att-prt-ivf-999        .
           move      w-num-prt-ivf-prt    to   w-te2-npt-iva (1)      .
           move      "#"                  to   w-num-prt-ivf-flg      .
           perform   vis-npt-iva-000      thru vis-npt-iva-999        .
       acc-npt-iva-080.
      *              *-------------------------------------------------*
      *              * Se Next Screen da campi precedenti              *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-npt-iva-400.
       acc-npt-iva-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-te2-npt-iva (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-npt-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-npt-iva-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-te2-npt-iva (1)      .
       acc-npt-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-te2-npt-iva (1)    not  = zero
                     go to acc-npt-iva-500.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-te2
                     go to acc-npt-iva-600
           else      go to acc-npt-iva-100.
       acc-npt-iva-500.
      *                  *---------------------------------------------*
      *                  * Controllo di congruenza numerazione iva     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Up : oltre                           *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-npt-iva-600.
      *                      *-----------------------------------------*
      *                      * Richiamo routine di controllo           *
      *                      *-----------------------------------------*
           perform   rou-cdn-mgi-000      thru rou-cdn-mgi-999        .
           if        l-cge-300-exi-sts    =    spaces
                     go to acc-npt-iva-600.
      *                      *-----------------------------------------*
      *                      * Se errore                               *
      *                      *-----------------------------------------*
           perform   rou-cdn-mgi-msg-000  thru rou-cdn-mgi-msg-999    .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-npt-iva-100.
       acc-npt-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se precedentemente era stata eseguita  *
      *                  * una attribuzione di numero progressivo      *
      *                  *---------------------------------------------*
           if        w-num-prt-ivf-flg    =    spaces
                     go to acc-npt-iva-800.
      *                      *-----------------------------------------*
      *                      * Se Up : ripristino numero protocollo    *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     perform rip-prt-ivf-000
                                          thru rip-prt-ivf-999
                     move    spaces       to   w-num-prt-ivf-flg
                     move    zero         to   w-te2-npt-iva (1)
                     perform vis-npt-iva-000
                                          thru vis-npt-iva-999
      *                      *-----------------------------------------*
      *                      * Altrimenti : ratifica numero protocollo *
      *                      *-----------------------------------------*
           else      move    w-te2-npt-iva (1)
                                          to   w-num-prt-ivf-prt
                     perform rat-prt-ivf-000
                                          thru rat-prt-ivf-999        .
       acc-npt-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-te2
                             go to acc-npt-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-npt-iva-100.
       acc-npt-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero protocollo iva             *
      *    *-----------------------------------------------------------*
       vis-npt-iva-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 
                     go to vis-npt-iva-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-te2-npt-iva (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-npt-iva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Castelletto iva                      *
      *    *-----------------------------------------------------------*
       acc-cst-iva-000.
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 
                     go to acc-cst-iva-999.
      *              *-------------------------------------------------*
      *              * Se Next Screen da campi precedenti              *
      *              *-------------------------------------------------*
           if        v-key                not  = "NXSC"
                     go to acc-cst-iva-010.
      *                  *---------------------------------------------*
      *                  * Controllo castelletto iva                   *
      *                  *---------------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        =    spaces
                     go to acc-cst-iva-999.
       acc-cst-iva-010.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore 1..6                 *
      *              *-------------------------------------------------*
           move      1                    to   w-cst-ctr-rig          .
       acc-cst-iva-020.
      *              *-------------------------------------------------*
      *              * Codice iva                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-te2-iva-cod 
                    (1, w-cst-ctr-rig)    to   w-sav-iva-cod          .
       acc-cst-iva-040.
      *                  *---------------------------------------------*
      *                  * Accettazione                                *
      *                  *---------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
      *                      *-----------------------------------------*
      *                      * Ridefinizione codice Iva per accetta-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      w-te2-iva-cod 
                    (1, w-cst-ctr-rig)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
      *
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      v-lin                to   w-cod-mne-zci-lin      .
      *
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  22             to   w-cod-mne-zci-pos
           else      move  03             to   w-cod-mne-zci-pos      .
           move      zero                 to   w-cod-mne-zci-dln      .
           move      zero                 to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
      *                      *-----------------------------------------*
      *                      * Tasti funzione                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione numero riga + 1      *
      *                          *-------------------------------------*
           add       1
                     w-cst-ctr-rig      giving w-cst-cts-rig          .
      *                          *-------------------------------------*
      *                          * Up   : sempre ammesso               *
      *                          *-------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                          *-------------------------------------*
      *                          * Down : sempre ammesso               *
      *                          *-------------------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *                          *-------------------------------------*
      *                          * Find : sempre ammesso               *
      *                          *-------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                          *-------------------------------------*
      *                          * Insr : sempre ammesso, a meno che   *
      *                          *        non si sia in una riga new   *
      *                          *        oppure manchi spazio per     *
      *                          *        l'inserimento                *
      *                          *-------------------------------------*
           if        w-te2-iva-cod (1, 6) not  = zero
                     go to acc-cst-iva-060.
           if        w-cst-ctr-rig        =    6
                     go to acc-cst-iva-060.
           if        w-sav-iva-cod        =    zero
                     go to acc-cst-iva-060.
           move      "INSR"               to   v-pfk (04)             .
       acc-cst-iva-060.
      *                          *-------------------------------------*
      *                          * Do   : sempre ammesso, purche' sia  *
      *                          *        concesso dallo status delle  *
      *                          *        impostazioni                 *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                          *-------------------------------------*
      *                          * Remv : sempre ammesso               *
      *                          *-------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                          *-------------------------------------*
      *                          * Back : sempre ammesso, a meno che   *
      *                          *        si sia gia' sulla prima riga *
      *                          *-------------------------------------*
           if        w-cst-ctr-rig        not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                          *-------------------------------------*
      *                          * Tab  : sempre ammesso               *
      *                          *-------------------------------------*
           move      "TAB "               to   v-pfk (10)             .
       acc-cst-iva-061.
      *                      *-----------------------------------------*
      *                      * Accettazione vera e propria             *
      *                      *-----------------------------------------*
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           move      "N"                  to   w-cod-mne-zci-edm
                                              (20 : 01)               .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-cst-iva-062.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-cst-iva-064.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-cst-iva-066.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cst-iva-064.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-cst-iva-062.
       acc-cst-iva-066.
      *                      *-----------------------------------------*
      *                      * Editing valore impostato                *
      *                      *-----------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
       acc-cst-iva-070.
      *                  *---------------------------------------------*
      *                  * Se Return                                   *
      *                  *---------------------------------------------*
           if        v-key                =    spaces
                     go to acc-cst-iva-300.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-cst-iva-999.
      *                  *---------------------------------------------*
      *                  * Se Delt                                     *
      *                  *---------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-cst-iva-999.
      *                  *---------------------------------------------*
      *                  * Se premuto un altro tasto funzione non deve *
      *                  * essere avvenuta variazione del campo        *
      *                  *---------------------------------------------*
           if        v-num                not  = w-sav-iva-cod
                     go to acc-cst-iva-020.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-cst-iva-080.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Se su riga > 1 : a riga precedente      *
      *                      *-----------------------------------------*
           if        w-cst-ctr-rig        >    1
                     subtract  1          from w-cst-ctr-rig
                     go to     acc-cst-iva-020.
      *                      *-----------------------------------------*
      *                      * Se su riga 1 : uscita, a meno che non   *
      *                      * si sia in variazione e il castelletto   *
      *                      * non sia a posto                         *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    =    spaces
                     move  "UP  "         to   v-key
                     go to acc-cst-iva-999.
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        =    spaces
                     move  "UP  "         to   v-key
                     go to acc-cst-iva-999.
           go to     acc-cst-iva-040.
       acc-cst-iva-080.
      *                  *---------------------------------------------*
      *                  * Se Down                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "DOWN"
                     go to acc-cst-iva-140.
       acc-cst-iva-100.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Se il codice iva precedentemente salva- *
      *                      * to era a zero                           *
      *                      *-----------------------------------------*
           if        w-sav-iva-cod        not  = zero
                     go to acc-cst-iva-120.
      *                          *-------------------------------------*
      *                          * Se anche dopo il compattamento ci   *
      *                          * si trova su di un codice iva a ze-  *
      *                          * ro : a impostazione totale docum.   *
      *                          *-------------------------------------*
           if        w-te2-iva-cod
                    (1, w-cst-ctr-rig)    =    zero
                     go to acc-cst-iva-600.
      *                          *-------------------------------------*
      *                          * Altrimenti si ricicla sulla stessa  *
      *                          * riga, in pratica sulla successiva   *
      *                          *-------------------------------------*
           go to     acc-cst-iva-020.
       acc-cst-iva-120.
      *                      *-----------------------------------------*
      *                      * Se il codice iva precedentemente salva- *
      *                      * to era diverso da zero                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se si e' all'ultima riga : a impo-  *
      *                          * stazione totale documento           *
      *                          *-------------------------------------*
           if        w-cst-ctr-rig        =    6
                     go to acc-cst-iva-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti : a riga successiva          *
      *                      *-----------------------------------------*
           add       1                    to   w-cst-ctr-rig          .
           go to     acc-cst-iva-020.
       acc-cst-iva-140.
      *                  *---------------------------------------------*
      *                  * Se Find                                     *
      *                  *---------------------------------------------*
       acc-cst-iva-160.
      *                  *---------------------------------------------*
      *                  * Se Insr                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-cst-iva-180.
      *                      *-----------------------------------------*
      *                      * Inserimento riga in castelletto         *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-820      thru acc-cst-iva-829        .
      *                      *-----------------------------------------*
      *                      * Riciclo sulla stessa riga               *
      *                      *-----------------------------------------*
           go to     acc-cst-iva-020.
       acc-cst-iva-180.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cst-iva-200.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-040.
      *                      *-----------------------------------------*
      *                      * Controllo globali                       *
      *                      *-----------------------------------------*
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
      *                      *-----------------------------------------*
      *                      * Test su esito controllo                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se positivo : uscita                *
      *                          *-------------------------------------*
           if        w-cnt-tdo-nok-flg    =    spaces
                     move  "S"            to   w-cnt-tus-acc-te2
                     go to acc-cst-iva-999.
      *                          *-------------------------------------*
      *                          * Altrimenti si torna alla reimposta- *
      *                          * zione della stessa riga             *
      *                          *-------------------------------------*
           go to     acc-cst-iva-040.
       acc-cst-iva-200.
      *                  *---------------------------------------------*
      *                  * Se Remv                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "REMV"
                     go to acc-cst-iva-220.
       acc-cst-iva-210.
      *                      *-----------------------------------------*
      *                      * Compattamento non controllato           *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-810      thru acc-cst-iva-819        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione della stessa riga        *
      *                      *-----------------------------------------*
           go to     acc-cst-iva-020.
       acc-cst-iva-220.
      *                  *---------------------------------------------*
      *                  * Se Nxsc                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "NXSC"
                     go to acc-cst-iva-230.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-040.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-te2      .
           go to     acc-cst-iva-999.
       acc-cst-iva-230.
      *                  *---------------------------------------------*
      *                  * Se Prsc                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-cst-iva-240.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-040.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           move      "-"                  to   w-cnt-tus-acc-te2      .
           go to     acc-cst-iva-999.
       acc-cst-iva-240.
      *                  *---------------------------------------------*
      *                  * Se Back                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "BACK"
                     go to acc-cst-iva-260.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Ad impostazione della prima riga        *
      *                      *-----------------------------------------*
           move      1                    to   w-cst-ctr-rig          .
           go to     acc-cst-iva-020.
       acc-cst-iva-260.
      *                  *---------------------------------------------*
      *                  * Se Tab                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "TAB "
                     go to acc-cst-iva-340.
      *                      *-----------------------------------------*
      *                      * Compattamento controllato               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-800      thru acc-cst-iva-809        .
      *                      *-----------------------------------------*
      *                      * Se il codice iva precedentemente salva- *
      *                      * to era a zero                           *
      *                      *-----------------------------------------*
           if        w-sav-iva-cod        not  = zero
                     go to acc-cst-iva-280.
      *                          *-------------------------------------*
      *                          * Se anche dopo il compattamento ci   *
      *                          * si trova su di un codice iva a ze-  *
      *                          * ro : a impostazione totale docum.   *
      *                          *-------------------------------------*
           if        w-te2-iva-cod
                    (1, w-cst-ctr-rig)    =    zero
                     go to acc-cst-iva-600.
       acc-cst-iva-280.
      *                      *-----------------------------------------*
      *                      * Se il codice iva precedentemente salva- *
      *                      * to era diverso da zero ci si posiziona  *
      *                      * dopo l'ultima riga                      *
      *                      *-----------------------------------------*
           add       1                    to   w-cst-ctr-rig          .
      *                          *-------------------------------------*
      *                          * Se sono presenti tutte le righe si  *
      *                          * va' al totale documento             *
      *                          *-------------------------------------*
           if        w-cst-ctr-rig        >    6
                     go to acc-cst-iva-600.
      *                          *-------------------------------------*
      *                          * Se la riga e' vuota si va ad impo-  *
      *                          * starla                              *
      *                          *-------------------------------------*
           if        w-te2-iva-cod
                    (1, w-cst-ctr-rig)    =    zero
                     go to acc-cst-iva-020.
      *                          *-------------------------------------*
      *                          * Altrimenti si ricicla per trovare   *
      *                          * una riga vuota                      *
      *                          *-------------------------------------*
           go to     acc-cst-iva-280.
       acc-cst-iva-300.
      *                  *---------------------------------------------*
      *                  * Se Return                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Memorizzazione valore impostato         *
      *                      *-----------------------------------------*
           move      v-num                to   w-te2-iva-cod
                                              (1, w-cst-ctr-rig)      .
      *                      *-----------------------------------------*
      *                      * Se campo vuoto : come Down              *
      *                      *-----------------------------------------*
           if        v-num                =    zero
                     go to acc-cst-iva-100.
      *                  *---------------------------------------------*
      *                  * Controllo impostazione                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo codice iva                    *
      *                      *-----------------------------------------*
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   d-imp-iva-cod-iva      .
           move      spaces               to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                          *-------------------------------------*
      *                          * Se errore : messaggio e reimposta-  *
      *                          * zione previo ripristino valore pre- *
      *                          * cedentemente salvato                *
      *                          *-------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     move  d-imp-iva-msg-exi
                                          to   w-cst-des-iva
                     go to acc-cst-iva-320.
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      w-sav-iva-cod        to   w-te2-iva-cod
                                              (1, w-cst-ctr-rig)      .
           go to     acc-cst-iva-020.
       acc-cst-iva-320.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo di codice *
      *                      * iva impostato                           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ridefinizione codice iva            *
      *                          *-------------------------------------*
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   w-edt-iva-cod          .
      *                          *-------------------------------------*
      *                          * Se imponibile                       *
      *                          *-------------------------------------*
           if        w-edt-iva-cod-003    =    zero
                     go to acc-cst-iva-340.
      *                          *-------------------------------------*
      *                          * Se codice esenzione                 *
      *                          *-------------------------------------*
           if        w-edt-iva-cod-003    =    3 or
                     w-edt-iva-cod-003    =    4 or
                     w-edt-iva-cod-003    =    5 or
                     w-edt-iva-cod-003    =    6
                     go to acc-cst-iva-460.
      *                          *-------------------------------------*
      *                          * Se non detraibile                   *
      *                          *-------------------------------------*
           if        w-edt-iva-cod-003    =    7
                     go to acc-cst-iva-340.
      *                          *-------------------------------------*
      *                          * Se omaggio                          *
      *                          *-------------------------------------*
           if        w-edt-iva-cod-003    =    9
                     go to acc-cst-iva-520.
       acc-cst-iva-340.
      *                      *-----------------------------------------*
      *                      * Se codice iva 001..099                  *
      *                      *               701..799                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Accettazione imponibile in valuta   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test se da accettare            *
      *                              *---------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to acc-cst-iva-350.
      *                              *---------------------------------*
      *                              * Accettazione                    *
      *                              *---------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      13                   to   v-pos                  .
      *                              *---------------------------------*
      *                              * Tasti funzione                  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Determinazione nr riga + 1  *
      *                                  *-----------------------------*
           add       1
                     w-cst-ctr-rig      giving w-cst-cts-rig          .
      *                                  *-----------------------------*
      *                                  * Down : sempre ammesso       *
      *                                  *-----------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *                                  *-----------------------------*
      *                                  * Remv : sempre ammesso       *
      *                                  *-----------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                                  *-----------------------------*
      *                                  * Valore di accettazione      *
      *                                  *-----------------------------*
           move      w-te2-iva-ibv 
                    (1, w-cst-ctr-rig)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                          *-------------------------------------*
      *                          * Se Exit o Remv                      *
      *                          *-------------------------------------*
           if        v-key                =    "EXIT" or
                     v-key                =    "REMV"
                     go to acc-cst-iva-210.
      *                          *-------------------------------------*
      *                          * Se Delt                             *
      *                          *-------------------------------------*
           if        v-key                =    "DELT"
                     go to acc-cst-iva-340.
      *                          *-------------------------------------*
      *                          * Se Next Screen                      *
      *                          *-------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cst-iva-340.
      *                          *-------------------------------------*
      *                          * Se Previous Screen                  *
      *                          *-------------------------------------*
           if        v-key                =    "PRSC"
                     go to acc-cst-iva-340.
      *                          *-------------------------------------*
      *                          * Se Return o Down                    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Valore impostato in campo di    *
      *                              * destinazione                    *
      *                              *---------------------------------*
           move      v-num                to   w-te2-iva-ibv
                                              (1, w-cst-ctr-rig)      .
      *                              *---------------------------------*
      *                              * Imponibile a zero non ammesso   *
      *                              *---------------------------------*
           if        w-te2-iva-ibv
                    (1, w-cst-ctr-rig)    =    zero
                     go to acc-cst-iva-340.
      *                              *---------------------------------*
      *                              * Determinazione imponibile in    *
      *                              * valuta base                     *
      *                              *---------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-te2-iva-ibv
                    (1, w-cst-ctr-rig)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-te2-iva-ibl
                                              (1, w-cst-ctr-rig)      .
      *                              *---------------------------------*
      *                              * Visualizzazione imponibile in   *
      *                              * valuta base                     *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      32                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Visualizzazione totale riga     *
      *                              *---------------------------------*
           perform   acc-cst-iva-840      thru acc-cst-iva-849        .
      *                              *---------------------------------*
      *                              * Determinazione totali castell.  *
      *                              *---------------------------------*
           perform   acc-cst-iva-830      thru acc-cst-iva-839        .
      *                              *---------------------------------*
      *                              * Visualizzazione tot. imponibile *
      *                              *---------------------------------*
           perform   acc-cst-iva-870      thru acc-cst-iva-879        .
      *                              *---------------------------------*
      *                              * Visualizzazione tot. documento  *
      *                              *---------------------------------*
           perform   acc-cst-iva-890      thru acc-cst-iva-899        .
       acc-cst-iva-350.
      *                          *-------------------------------------*
      *                          * Accettazione imponibile in valuta   *
      *                          * base                                *
      *                          *-------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      32                   to   v-pos                  .
      *                              *---------------------------------*
      *                              * Tasti funzione                  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Determinazione nr riga + 1  *
      *                                  *-----------------------------*
           add       1
                     w-cst-ctr-rig      giving w-cst-cts-rig          .
      *                                  *-----------------------------*
      *                                  * Up   : Ammesso solo se ac-  *
      *                                  *        cettazione castel-   *
      *                                  *        letto in valuta      *
      *                                  *-----------------------------*
           if        w-tes-sgl-vpf (1)    not  = c-sgl
                     move  "UP  "         to   v-pfk (01)             .
      *                                  *-----------------------------*
      *                                  * Down : sempre ammesso       *
      *                                  *-----------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *                                  *-----------------------------*
      *                                  * Remv : sempre ammesso       *
      *                                  *-----------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                                  *-----------------------------*
      *                                  * Valore di accettazione      *
      *                                  *-----------------------------*
           move      w-te2-iva-ibl 
                    (1, w-cst-ctr-rig)    to   v-num                  .
      *                                  *-----------------------------*
      *                                  * Richiamo sub. accettazione  *
      *                                  *-----------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                          *-------------------------------------*
      *                          * Se Exit o Remv                      *
      *                          *-------------------------------------*
           if        v-key                =    "EXIT" or
                     v-key                =    "REMV"
                     go to acc-cst-iva-210.
      *                          *-------------------------------------*
      *                          * Se Delt                             *
      *                          *-------------------------------------*
           if        v-key                =    "DELT"
                     go to acc-cst-iva-350.
      *                          *-------------------------------------*
      *                          * Se Next Screen                      *
      *                          *-------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cst-iva-350.
      *                          *-------------------------------------*
      *                          * Se Previous Screen                  *
      *                          *-------------------------------------*
           if        v-key                =    "PRSC"
                     go to acc-cst-iva-350.
      *                          *-------------------------------------*
      *                          * Se Up                               *
      *                          *-------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-cst-iva-340.
      *                          *-------------------------------------*
      *                          * Se Return o Down                    *
      *                          *-------------------------------------*
