           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
      *                      *-----------------------------------------*
      *                      * Tasti funzione                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Up   : sempre ammesso               *
      *                          *-------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                          *-------------------------------------*
      *                          * Down : sempre ammesso               *
      *                          *-------------------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *                          *-------------------------------------*
      *                          * Do   : sempre ammesso, purche' sia  *
      *                          *        concesso dallo status delle  *
      *                          *        impostazioni                 *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-te2-tot-doc (1)    to   v-num                  .
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *                      *-----------------------------------------*
      *                      * Valore in campo destinazione            *
      *                      *-----------------------------------------*
           move      v-num                to   w-te2-tot-doc (1)      .
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-te2
                     go to acc-cst-iva-999.
      *                  *---------------------------------------------*
      *                  * Se Delt                                     *
      *                  *---------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-te2
                     go to acc-cst-iva-999.
      *                  *---------------------------------------------*
      *                  * Se premuto un altro tasto funzione non deve *
      *                  * essere avvenuta variazione del campo        *
      *                  *---------------------------------------------*
           if        w-te2-tot-doc (1)    not  = w-sav-tot-doc
                     go to acc-cst-iva-620.
      *                  *---------------------------------------------*
      *                  * Se Return                                   *
      *                  *---------------------------------------------*
           if        v-key                =    spaces
                     go to acc-cst-iva-700.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-cst-iva-660.
      *                      *-----------------------------------------*
      *                      * Allineamento all'ultima riga non vuota  *
      *                      * oppure alla prima riga                  *
      *                      *-----------------------------------------*
           move      6                    to   w-cst-ctr-rig          .
       acc-cst-iva-640.
           if        w-te2-iva-cod
                    (1, w-cst-ctr-rig)    =    zero
                     if    w-cst-ctr-rig  >    1
                           subtract  1    from w-cst-ctr-rig
                           go to     acc-cst-iva-640.
           go to     acc-cst-iva-020.
       acc-cst-iva-660.
      *                  *---------------------------------------------*
      *                  * Totale documento a zero non ammesso         *
      *                  *---------------------------------------------*
           if        w-te2-tot-doc (1)    =    zero
                     go to acc-cst-iva-620.
      *                  *---------------------------------------------*
      *                  * Se Down : come per Return                   *
      *                  *---------------------------------------------*
           if        v-key                =    "DOWN"
                     move  spaces         to   v-key
                     go to acc-cst-iva-700.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cst-iva-680.
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-620.
      *                      *-----------------------------------------*
      *                      * Controllo globali                       *
      *                      *-----------------------------------------*
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
      *                      *-----------------------------------------*
      *                      * Test su esito controllo                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se positivo : uscita                *
      *                          *-------------------------------------*
           if        w-cnt-tdo-nok-flg    =    spaces
                     move  "S"            to   w-cnt-tus-acc-te2
                     go to acc-cst-iva-999.
      *                          *-------------------------------------*
      *                          * Altrimenti si torna alla reimposta- *
      *                          * zione del totale documento          *
      *                          *-------------------------------------*
           go to     acc-cst-iva-620.
       acc-cst-iva-680.
      *                  *---------------------------------------------*
      *                  * Se Nxsc                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "NXSC"
                     go to acc-cst-iva-690.
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-620.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-te2      .
           go to     acc-cst-iva-999.
       acc-cst-iva-690.
      *                  *---------------------------------------------*
      *                  * Se Prsc                                     *
      *                  *---------------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-cst-iva-700.
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-620.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           move      "-"                  to   w-cnt-tus-acc-te2      .
           go to     acc-cst-iva-999.
       acc-cst-iva-700.
      *                  *---------------------------------------------*
      *                  * Se Return                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo castelletto iva               *
      *                      *-----------------------------------------*
           perform   acc-cst-iva-980      thru acc-cst-iva-989        .
           if        w-cst-flg-exi        not  = spaces
                     go to acc-cst-iva-620.
           move      spaces               to   v-key                  .
           go to     acc-cst-iva-999.
       acc-cst-iva-800.
      *              *-------------------------------------------------*
      *              * Subroutine interna di compattamento controllato *
      *              * castelletto : solo se il codice iva e' a zero   *
      *              *-------------------------------------------------*
           if        w-te2-iva-cod
                    (1, w-cst-ctr-rig)    not  = zero
                     go to acc-cst-iva-809.
           if        w-cst-ctr-rig        =    6
                     go to acc-cst-iva-809.
           if        w-te2-iva-cod
                    (1, w-cst-cts-rig)    =    zero
                     go to acc-cst-iva-809.
           perform   acc-cst-iva-810      thru acc-cst-iva-819        .
       acc-cst-iva-809.
           exit.
       acc-cst-iva-810.
      *              *-------------------------------------------------*
      *              * Subroutine interna di compattamento righe del   *
      *              * castelletto escludendo la riga w-cst-ctr-rig    *
      *              * con rideterminazione e rivisualizzazione totali *
      *              *-------------------------------------------------*
           move      w-cst-ctr-rig        to   w-cst-ctx-rig          .
           add       1
                     w-cst-ctx-rig    giving   w-cst-cty-rig          .
       acc-cst-iva-811.
           if        w-cst-ctx-rig        =    6
                     move  zero           to   w-te2-iva-ibv (1, 6)
                     move  zero           to   w-te2-iva-ibl (1, 6)
                     move  zero           to   w-te2-iva-cod (1, 6)
                     move  zero           to   w-te2-iva-imp (1, 6)
                     go to acc-cst-iva-812.
           move      w-te2-iva-rig
                    (1, w-cst-cty-rig)    to   w-te2-iva-rig
                                              (1, w-cst-ctx-rig)      .
           add       1                    to   w-cst-ctx-rig          .
           add       1                    to   w-cst-cty-rig          .
           go to     acc-cst-iva-811.
       acc-cst-iva-812.
           move      w-cst-ctr-rig        to   w-cst-ctx-rig          .
           add       12                   to   w-cst-ctx-rig          .
           add       1
                     w-cst-ctx-rig    giving   w-cst-cty-rig          .
       acc-cst-iva-813.
           if        w-cst-ctx-rig        =    18
                     go to acc-cst-iva-814.
           move      "FL"                 to   v-ope                  .
           move      w-cst-cty-rig        to   v-lin                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      w-cst-ctx-rig        to   v-lin                  .
           move      01                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           if        v-alf                =    spaces
                     go to acc-cst-iva-815.
           add       1                    to   w-cst-ctx-rig          .
           add       1                    to   w-cst-cty-rig          .
           go to     acc-cst-iva-813.
       acc-cst-iva-814.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       acc-cst-iva-815.
            perform  acc-cst-iva-830      thru acc-cst-iva-839        .
            perform  acc-cst-iva-860      thru acc-cst-iva-869        .
       acc-cst-iva-819.
           exit.
       acc-cst-iva-820.
      *              *-------------------------------------------------*
      *              * Subroutine interna di inserimento della riga    *
      *              * numero w-cst-ctr-rig nel castelletto iva        *
      *              *-------------------------------------------------*
           move      5                    to   w-cst-cty-rig          .
       acc-cst-iva-821.
           if        w-te2-iva-cod
                    (1, w-cst-cty-rig)    =    zero
                     subtract  1          from w-cst-cty-rig
                     go to     acc-cst-iva-821.
           move      w-cst-cty-rig        to   w-cst-ctx-rig          .
           add       1                    to   w-cst-cty-rig          .
       acc-cst-iva-822.
           move      w-te2-iva-rig
                    (1, w-cst-ctx-rig)    to   w-te2-iva-rig
                                              (1, w-cst-cty-rig)      .
           if        w-cst-ctx-rig        not  = w-cst-ctr-rig
                     subtract  1          from w-cst-ctx-rig
                     subtract  1          from w-cst-cty-rig
                     go to acc-cst-iva-822.
           move      zero                 to   w-te2-iva-ibl
                                              (1, w-cst-ctr-rig)      .
           move      zero                 to   w-te2-iva-cod
                                              (1, w-cst-ctr-rig)      .
           move      zero                 to   w-te2-iva-imp
                                              (1, w-cst-ctr-rig)      .
           move      5                    to   w-cst-cty-rig          .
       acc-cst-iva-823.
           if        w-cst-cty-rig        =    w-cst-ctr-rig
                     go to     acc-cst-iva-824.
           if        w-te2-iva-cod
                    (1, w-cst-cty-rig)    =    zero
                     subtract  1          from w-cst-cty-rig
                     go to     acc-cst-iva-823.
       acc-cst-iva-824.
           move      w-cst-cty-rig        to   w-cst-ctx-rig          .
           add       1                    to   w-cst-cty-rig          .
       acc-cst-iva-825.
           move      "FL"                 to   v-ope                  .
           add       12
                     w-cst-ctx-rig      giving v-lin                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       12
                     w-cst-cty-rig      giving v-lin                  .
           move      01                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           if        w-cst-ctx-rig        not  = w-cst-ctr-rig
                     subtract  1          from w-cst-ctx-rig
                     subtract  1          from w-cst-cty-rig
                     go to acc-cst-iva-825.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      01                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       acc-cst-iva-829.
           exit.
       acc-cst-iva-830.
      *              *-------------------------------------------------*
      *              * Subroutine interna di determinazione totali per *
      *              * castelletto iva                                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-te2-tot-ibv (1)      .
           move      zero                 to   w-te2-tot-ibl (1)      .
           move      zero                 to   w-te2-tot-imp (1)      .
           move      zero                 to   w-te2-tot-ind (1)      .
           move      zero                 to   w-cst-ctx-rig          .
       acc-cst-iva-831.
           add       1                    to   w-cst-ctx-rig          .
           if        w-cst-ctx-rig        >    6
                     go to acc-cst-iva-832.
           if        w-te2-iva-cod
                    (1, w-cst-ctx-rig)    =    zero
                     go to acc-cst-iva-831.
           add       w-te2-iva-ibv
                    (1, w-cst-ctx-rig)    to   w-te2-tot-ibv (1)      .
           add       w-te2-iva-ibl
                    (1, w-cst-ctx-rig)    to   w-te2-tot-ibl (1)      .
           add       w-te2-iva-imp
                    (1, w-cst-ctx-rig)    to   w-te2-tot-imp (1)      .
      *
           move      w-te2-iva-cod
                    (1, w-cst-ctx-rig)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    7
                     add   w-te2-iva-ibl
                          (1, w-cst-ctx-rig)
                                          to   w-te2-tot-ind (1)      .
           go to     acc-cst-iva-831.
       acc-cst-iva-832.
           add       w-te2-tot-ibl (1)
                     w-te2-tot-imp (1)  giving w-te2-tot-doc (1)      .
       acc-cst-iva-839.
           exit.
       acc-cst-iva-840.
      *              *-------------------------------------------------*
      *              * Subroutine interna di visualizzazione totale    *
      *              * riga castelletto nr w-cst-ctr-rig               *
      *              *-------------------------------------------------*
           perform   acc-cst-iva-850      thru acc-cst-iva-859        .
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      66                   to   v-pos                  .
           move      w-cst-tot-rig        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cst-iva-849.
           exit.
       acc-cst-iva-850.
      *              *-------------------------------------------------*
      *              * Subroutine interna di determinazione totale ri- *
      *              * ga castelletto w-cst-ctr-rig in w-cst-tot-rig   *
      *              *-------------------------------------------------*
           add       w-te2-iva-ibl
                    (1, w-cst-ctr-rig)
                     w-te2-iva-imp
                    (1, w-cst-ctr-rig)  giving w-cst-tot-rig          .
       acc-cst-iva-859.
           exit.
       acc-cst-iva-860.
      *              *-------------------------------------------------*
      *              * Subroutine interna di visualizzazione totali    *
      *              * castelletto iva                                 *
      *              *-------------------------------------------------*
           perform   acc-cst-iva-870      thru acc-cst-iva-879        .
           perform   acc-cst-iva-880      thru acc-cst-iva-889        .
           perform   acc-cst-iva-890      thru acc-cst-iva-899        .
       acc-cst-iva-869.
           exit.
       acc-cst-iva-870.
      *              *-------------------------------------------------*
      *              * Subroutine interna di visualizzazione del tota- *
      *              * le imponibile sia in valuta che non             *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to acc-cst-iva-875.
      *                  *---------------------------------------------*
      *                  * Imponibile in valuta                        *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      13                   to   v-pos                  .
           move      w-te2-tot-ibv (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cst-iva-875.
      *                  *---------------------------------------------*
      *                  * Imponibile in valuta base                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-te2-tot-ibl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cst-iva-879.
           exit.
       acc-cst-iva-880.
      *              *-------------------------------------------------*
      *              * Subroutine interna di visualizzazione del tota- *
      *              * le imposta                                      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      49                   to   v-pos                  .
           move      w-te2-tot-imp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cst-iva-889.
           exit.
       acc-cst-iva-890.
      *              *-------------------------------------------------*
      *              * Subroutine interna di visualizzazione del tota- *
      *              * le documento                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-te2-tot-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cst-iva-899.
           exit.
       acc-cst-iva-910.
      *              *-------------------------------------------------*
      *              * Subroutine interna di determinazione imposta a  *
      *              * fronte imponibile per riga w-cst-ctr-rig        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione                                *
      *                  *---------------------------------------------*
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   w-cst-cod-iva          .
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      "DI"                 to   d-imp-iva-tip-ope      .
           move      w-te2-iva-ibl 
                    (1, w-cst-ctr-rig)    to   d-imp-iva-ibl-iva      .
           move      w-cst-cod-iva        to   d-imp-iva-cod-iva      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
           move      d-imp-iva-ims-iva    to   w-te2-iva-imp
                                              (1, w-cst-ctr-rig)      .
       acc-cst-iva-919.
           exit.
       acc-cst-iva-920.
      *              *-------------------------------------------------*
      *              * Subroutine interna di scorporo imponibile e im- *
      *              * posta per riga w-cst-ctr-rig da w-cst-tot-rig   *
      *              *-------------------------------------------------*
           move      "SI"                 to   d-imp-iva-tip-ope      .
      *
           move      w-cst-tot-rig        to   d-imp-iva-ibl-iva      .
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   d-imp-iva-cod-iva      .
      *
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
      *
           move      d-imp-iva-ibl-iva    to   w-te2-iva-ibl 
                                              (1, w-cst-ctr-rig)      .
           move      d-imp-iva-ims-iva    to   w-te2-iva-imp 
                                              (1, w-cst-ctr-rig)      .
       acc-cst-iva-929.
           exit.
       acc-cst-iva-980.
      *              *-------------------------------------------------*
      *              * Subroutine interna di esecuzione operazioni per *
      *              * fine impostazione castelletto iva               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione status di uscita            *
      *                  *---------------------------------------------*
           move      spaces               to   w-cst-flg-exi          .
      *                  *---------------------------------------------*
      *                  * Controllo che almeno una riga sia presente  *
      *                  *---------------------------------------------*
           if        w-te2-iva-cod (1, 1) =    zero
                     move  "#"            to   w-cst-flg-exi
                     go to acc-cst-iva-989.
      *                  *---------------------------------------------*
      *                  * Controllo che il totale documento sia di-   *
      *                  * verso da zero                               *
      *                  *---------------------------------------------*
           if        w-te2-tot-doc (1)    =    zero
                     move  "#"            to   w-cst-flg-exi
                     go to acc-cst-iva-989.
      *                  *---------------------------------------------*
      *                  * Determinazione del totale imposta non dedu- *
      *                  * cibile                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-te2-tot-ind (1)      .
           move      zero                 to   w-cst-ctz-rig          .
       acc-cst-iva-984.
           add       1                    to   w-cst-ctz-rig          .
           if        w-cst-ctz-rig        >    6
                     go to acc-cst-iva-986.
      *
           move      w-te2-iva-cod
                    (1, w-cst-ctz-rig)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    7
                     add   w-te2-iva-imp
                          (1, w-cst-ctz-rig)
                                          to   w-te2-tot-ind (1)      .
      *
           go to     acc-cst-iva-984.
       acc-cst-iva-986.
       acc-cst-iva-989.
           exit.
       acc-cst-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Castelletto iva                   *
      *    *-----------------------------------------------------------*
       vis-cst-iva-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 
                     go to vis-cst-iva-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore 1..6                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-cst-ctr-rig          .
      *              *-------------------------------------------------*
      *              * Ciclo 1..6                                      *
      *              *-------------------------------------------------*
       vis-cst-iva-100.
           add       1                    to   w-cst-ctr-rig          .
           if        w-cst-ctr-rig        >    6
                     go to  vis-cst-iva-400.
           if        w-te2-iva-cod 
                    (1, w-cst-ctr-rig)    =    zero and
                     w-te2-iva-ibl 
                    (1, w-cst-ctr-rig)    =    zero and
                     w-te2-iva-imp 
                    (1, w-cst-ctr-rig)    =    zero
                     go to  vis-cst-iva-400.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
      *
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
      *
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  22             to   v-pos
           else      move  03             to   v-pos                  .
      *
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Imponibile in valuta                    *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to vis-cst-iva-120.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      13                   to   v-pos                  .
           move      w-te2-iva-ibv
                    (1, w-cst-ctr-rig)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cst-iva-120.
      *                      *-----------------------------------------*
      *                      * Imponibile in valuta base               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      32                   to   v-pos                  .
           move      w-te2-iva-ibl
                    (1, w-cst-ctr-rig)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Imposta o esenzione                     *
      *                      *-----------------------------------------*
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   w-edt-iva-cod          .
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to  vis-cst-iva-200.
      *                      *-----------------------------------------*
      *                      * Caso imposta                            *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      49                   to   v-pos                  .
           move      w-te2-iva-imp
                    (1, w-cst-ctr-rig)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-cst-iva-300.
       vis-cst-iva-200.
      *                      *-----------------------------------------*
      *                      * Caso esenzione                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura tabella codici iva          *
      *                          *-------------------------------------*
           move      w-te2-iva-cod
                    (1, w-cst-ctr-rig)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione descr. esenzione    *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      49                   to   v-pos                  .
           move      w-let-arc-zci-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cst-iva-300.
      *                      *-----------------------------------------*
      *                      * Totale riga                             *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           add       12
                     w-cst-ctr-rig      giving v-lin                  .
           move      "GB"                 to   v-edm                  .
           move      66                   to   v-pos                  .
           add       w-te2-iva-ibl
                    (1, w-cst-ctr-rig)
                     w-te2-iva-imp
                    (1, w-cst-ctr-rig)  giving v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riciclo a riga castelletto successiva   *
      *                      *-----------------------------------------*
           go to     vis-cst-iva-100.
       vis-cst-iva-400.
      *                  *---------------------------------------------*
      *                  * Visualizzazione riga totali                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Totale imponibile in valuta             *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to vis-cst-iva-420.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      13                   to   v-pos                  .
           move      w-te2-tot-ibv (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cst-iva-420.
      *                      *-----------------------------------------*
      *                      * Totale imponibile                       *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-te2-tot-ibl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Totale imposta                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      49                   to   v-pos                  .
           move      w-te2-tot-imp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Totale documento                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-te2-tot-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cst-iva-999.
           exit.
