           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-imp-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data riferimento di CGE      *
      *    *-----------------------------------------------------------*
       acc-dri-mgd-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    01
                     go to acc-dri-mgd-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-dri-mgd-400.
       acc-dri-mgd-080.
      *                  *---------------------------------------------*
      *                  * Eventuale default                           *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    "R"  and
                     w-tes-dri-mgd (1)    =    zero
                     move  w-tes-dat-doc (1)
                                          to   w-tes-dri-mgd (1)      .
       acc-dri-mgd-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dri-mgd (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dri-mgd-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dri-mgd-999.
       acc-dri-mgd-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dri-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-dri-mgd-400.
      *                  *---------------------------------------------*
      *                  * Find su riferimenti cliente                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-fnd-rif-fnt-cod      .
           perform   fnd-rif-fnt-000      thru fnd-rif-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-rif-fnt-sel    not  = spaces
                     go to acc-dri-mgd-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           move      w-fnd-rif-fnt-dat    to   w-tes-dri-mgd (1)      .
           move      w-fnd-rif-fnt-num    to   w-tes-nri-mgd (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           perform   vis-dri-mgd-000      thru vis-dri-mgd-999        .
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-dri-mgd-400.
       acc-dri-mgd-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dri-mgd-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data riferimento a zero si forza spaces  *
      *                  * il numero riferimento                       *
      *                  *---------------------------------------------*
           if        w-tes-dri-mgd (1)    not  = zero
                     go to acc-dri-mgd-800.
           if        w-tes-nri-mgd (1)    =    spaces
                     go to acc-dri-mgd-800.
           move      spaces               to   w-tes-nri-mgd (1)      .
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
       acc-dri-mgd-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dri-mgd-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dri-mgd-100.
       acc-dri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data riferimento di CGE           *
      *    *-----------------------------------------------------------*
       vis-dri-mgd-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    01
                     go to vis-dri-mgd-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dri-mgd (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero riferimento di CGE            *
      *    *-----------------------------------------------------------*
       acc-nri-mgd-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    01
                     go to acc-nri-mgd-999.
           if        w-tes-dri-mgd (1)    =    zero
                     go to acc-nri-mgd-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-nri-mgd-400.
       acc-nri-mgd-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo in Inserimento                         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-nri-mgd-120.
      *                  *---------------------------------------------*
      *                  * Solo se fattura Reverse Charge              *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-rfp    not  = "R"
                     go to acc-nri-mgd-120.
      *                  *---------------------------------------------*
      *                  * Nota 1                                      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "Indicare l'idSDI ricevuto con la consegna del docu
      -              "mento elettronico del Fornitore"
                                          to   v-nt1                  .
           move      spaces               to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-nri-mgd-120.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nri-mgd (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative attuali            *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nri-mgd-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nri-mgd-999.
       acc-nri-mgd-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nri-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-nri-mgd-400.
      *                  *---------------------------------------------*
      *                  * Find su riferimenti cliente                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-fnd-rif-fnt-cod      .
           perform   fnd-rif-fnt-000      thru fnd-rif-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-rif-fnt-sel    not  = spaces
                     go to acc-nri-mgd-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           move      w-fnd-rif-fnt-dat    to   w-tes-dri-mgd (1)      .
           move      w-fnd-rif-fnt-num    to   w-tes-nri-mgd (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-nri-mgd-400.
       acc-nri-mgd-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-nri-mgd (1)    not  = spaces
                     go to acc-nri-mgd-600.
           if        v-key                =    "UP  "
                     go to acc-nri-mgd-600
           else      go to acc-nri-mgd-100.
       acc-nri-mgd-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nri-mgd-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nri-mgd-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nri-mgd-100.
       acc-nri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data riferimento di CGE           *
      *    *-----------------------------------------------------------*
       vis-nri-mgd-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tdo    =    01
                     go to vis-nri-mgd-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nri-mgd (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice forma di pagamento    *
      *    *-----------------------------------------------------------*
       acc-cod-fop-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio percentuale di sconto pagamento *
      *                  * associata alla forma di pagamento           *
      *                  *---------------------------------------------*
           move      w-tes-scp-aap (1)    to   w-sav-scp-aap          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cod-fop-400.
       acc-cod-fop-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-yfp-ope      .
           move      w-tes-cod-fop (1)    to   w-cod-mne-yfp-cod      .
           move      05                   to   w-cod-mne-yfp-lin      .
           move      30                   to   w-cod-mne-yfp-pos      .
           move      05                   to   w-cod-mne-yfp-dln      .
           move      41                   to   w-cod-mne-yfp-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-yfp-cll-000  thru cod-mne-yfp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-yfp-foi-000  thru cod-mne-yfp-foi-999    .
       acc-cod-fop-110.
           perform   cod-mne-yfp-cll-000  thru cod-mne-yfp-cll-999    .
           if        w-cod-mne-yfp-ope    =    "F+"
                     go to acc-cod-fop-115.
           if        w-cod-mne-yfp-ope    =    "AC"
                     go to acc-cod-fop-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fop-115.
           perform   cod-mne-yfp-foi-000  thru cod-mne-yfp-foi-999    .
           go to     acc-cod-fop-110.
       acc-cod-fop-120.
           move      w-cod-mne-yfp-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
       acc-cod-fop-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-fop (1)      .
       acc-cod-fop-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [yfp]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-let-arc-yfp-cod      .
           perform   let-arc-yfp-000      thru let-arc-yfp-999        .
           move      w-let-arc-yfp-des    to   w-tes-cod-fop-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-fop-des-000  thru vis-cod-fop-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-yfp-flg    not  = spaces
                     go to acc-cod-fop-100.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [yfp]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-yfp-000      thru det-vlt-yfp-999        .
       acc-cod-fop-550.
      *                  *---------------------------------------------*
      *                  * Controlli su forma di pagamento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazioni riguardanti   *
      *                      * 'scf'                                   *
      *                      *-----------------------------------------*
           if        w-prs-snx-scf        not  = "S"
                     go to acc-cod-fop-600.
      *                      *-----------------------------------------*
      *                      * Controllo che se documento estero, i    *
      *                      * tipi pagamento siano Bonifici           *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02 and
                     w-tes-cod-tmf-tpv    not  = 03
                     go to acc-cod-fop-600.
           if        w-tes-tip-pag (1, 1) not  = zero and
                     w-tes-tip-pag (1, 1) not  = 07
                     go to acc-cod-fop-560.
           if        w-tes-tip-pag (1, 2) not  = zero and
                     w-tes-tip-pag (1, 2) not  = 07
                     go to acc-cod-fop-560.
           if        w-tes-tip-pag (1, 3) not  = zero and
                     w-tes-tip-pag (1, 3) not  = 07
                     go to acc-cod-fop-560.
           go to     acc-cod-fop-600.
       acc-cod-fop-560.
           move      "Per documenti Esteri o CEE sono ammessi solo forme
      -              " di pagamento  "    to   w-err-box-err-msg      .
           move      "contenenti codici pagamento definiti di tipo Bonif
      -              "ico Bancario.  "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     acc-cod-fop-100.
       acc-cod-fop-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione sconto pagamento            *
      *                  *---------------------------------------------*
           perform   vis-scp-aap-000      thru vis-scp-aap-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento % sconto pagamento per piede    *
      *                  *                                             *
      *                  * - Se w-tes-scp-aap # 0                      *
      *                  *   - Se w-te2-per-scp = 0 => bufferizzazione *
      *                  *   - Se w-te2-per-scp # 0                    *
      *                  *     - Se w-te2-per-scp = w-sav-scp-aap =>   *
      *                  *       => bufferizzazione                    *
      *                  *     - Se w-te2-per-scp # w-sav-scp-aap =>   *
      *                  *       => nessuna azione                     *
      *                  * - Se w-tes-scp-aap = 0                      *
      *                  *   - Se w-te2-per-scp = 0 => nessuna azione  *
      *                  *   - Se w-te2-per-scp # 0 => nessuna azione  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se % sconto pagamento associata alla    *
      *                      * forma di pagamento a zero : oltre       *
      *                      *-----------------------------------------*
           if        w-tes-scp-aap (1)    =    zero
                     go to acc-cod-fop-602.
      *                      *-----------------------------------------*
      *                      * Se % sconto pagamento per piede a zero, *
      *                      * bufferizzazione % sconto pagamento as-  *
      *                      * sociata alla forma di pagamento in %    *
      *                      * sconto pagamento per piede e oltre      *
      *                      *-----------------------------------------*
           if        w-te2-per-scp (1)    =    zero
                     move  w-tes-scp-aap (1)
                                          to   w-te2-per-scp (1)
                     go to acc-cod-fop-602.
      *                      *-----------------------------------------*
      *                      * Se % sconto pagamento per piede diverso *
      *                      * da zero                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se % per piede pari alla % associa- *
      *                          * ta alla forma di pagamento prece-   *
      *                          * dentemente salvata, aggiornamento   *
      *                          *-------------------------------------*
           if        w-sav-scp-aap        =    w-te2-per-scp (1)
                     move  w-tes-scp-aap (1)
                                          to   w-te2-per-scp (1)      .
       acc-cod-fop-602.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostra banca             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-app-pgf (1)    not  = 01
                     go to acc-cod-fop-604.
           if        w-tes-nos-ban (1)    not  = spaces
                     go to acc-cod-fop-608.
      *                          *-------------------------------------*
      *                          * Memorizzazione valore associato al  *
      *                          * fornitore                           *
      *                          *-------------------------------------*
           move      w-tes-nsb-aaf (1)    to   w-tes-nos-ban (1)      .
      *                          *-------------------------------------*
      *                          * Lettura archivio [cbp]              *
      *                          *-------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           go to     acc-cod-fop-608.
       acc-cod-fop-604.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ban (1)    =    spaces
                     go to acc-cod-fop-608.
           move      spaces               to   w-tes-nos-ban (1)      .
           move      spaces               to   w-tes-nos-ban-des (1)  .
           go to     acc-cod-fop-608.
       acc-cod-fop-608.
      *                  *---------------------------------------------*
      *                  * Trattamento codici ABI, CAB e c/c bancario  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to acc-cod-fop-610.
           if        w-tes-cod-abi (1)    not  = zero
                     go to acc-cod-fop-620.
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                          *-------------------------------------*
      *                          * Lettura archivio [axi]              *
      *                          *-------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
      *                          *-------------------------------------*
      *                          * Lettura archivio [axs]              *
      *                          *-------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
           go to     acc-cod-fop-620.
       acc-cod-fop-610.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-fop-620.
           move      zero                 to   w-tes-cod-abi (1)      .
           move      spaces               to   w-tes-cod-abi-den (1)  .
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
           move      spaces               to   w-tes-ccc-app (1)      .
           go to     acc-cod-fop-620.
       acc-cod-fop-620.
      *                  *---------------------------------------------*
      *                  * Trattamento c/c postale fornitore           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-app-pgf (1)    not  = 03
                     go to acc-cod-fop-625.
           if        w-tes-ccp-app (1)    not  = spaces
                     go to acc-cod-fop-630.
           move      w-tes-ccp-fnt (1)    to   w-tes-ccp-app (1)      .
           go to     acc-cod-fop-630.
       acc-cod-fop-625.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-ccp-app (1)    =    spaces
                     go to acc-cod-fop-630.
           move      spaces               to   w-tes-ccp-app (1)      .
           go to     acc-cod-fop-630.
       acc-cod-fop-630.
      *                  *---------------------------------------------*
      *                  * Trattamento codice banca estera fornitore   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-app-pgf (1)    not  = 04
                     go to acc-cod-fop-635.
      *                          *-------------------------------------*
      *                          * Nessun default                      *
      *                          *-------------------------------------*
           go to     acc-cod-fop-640.
       acc-cod-fop-635.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-bef (1)    =    zero
                     go to acc-cod-fop-640.
           move      zero                 to   w-tes-cod-bef (1)      .
           move      spaces               to   w-tes-cod-bef-des (1)  .
           move      spaces               to   w-tes-cod-bef-fil (1)  .
           move      spaces               to   w-tes-cod-bef-ccc (1)  .
           go to     acc-cod-fop-640.
       acc-cod-fop-640.
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione valori per appoggio pa-   *
      *                  * gamento                                     *
      *                  *---------------------------------------------*
           perform   vis-app-pgf-000      thru vis-app-pgf-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento data scadenza pagamento manuale *
      *                  *---------------------------------------------*
           if        w-tes-snx-spm (1)    =    spaces and
                     w-tes-pag-dsm (1)    not  = zero
                     move  zero           to   w-tes-pag-dsm (1)
                     perform vis-pag-dsm-000
                                          thru vis-pag-dsm-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento quota a forfait                 *
      *                  *---------------------------------------------*
           if        w-tes-snx-qaf (1)    =    spaces and
                     w-tes-pag-qaf (1)    not  = zero
                     move  zero           to   w-tes-pag-qaf (1)
                     perform vis-pag-qaf-000
                                          thru vis-pag-qaf-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento acconto                         *
      *                  *---------------------------------------------*
           if        w-tes-snx-act (1)    =    spaces and
                     w-tes-pag-act (1)    not  = zero
                     move  zero           to   w-tes-pag-act (1)
                     perform vis-pag-act-000
                                          thru vis-pag-act-999        .
       acc-cod-fop-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fop-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fop-100.
       acc-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice forma di pagamento *
      *    *-----------------------------------------------------------*
       vis-cod-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-fop (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione forma di pa-  *
      *    * gamento                                                   *
      *    *-----------------------------------------------------------*
       vis-cod-fop-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-fop-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-fop-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Appoggio per pagamenti a fornito- *
      *    *                         re                                *
      *    *-----------------------------------------------------------*
       vis-app-pgf-000.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           perform   pmt-app-pgf-000      thru pmt-app-pgf-999        .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo appoggio paga-  *
      *              * mento                                           *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    =    01
                     go to vis-app-pgf-100
           else if   w-tes-app-pgf (1)    =    02
                     go to vis-app-pgf-200
           else if   w-tes-app-pgf (1)    =    03
                     go to vis-app-pgf-300
           else if   w-tes-app-pgf (1)    =    04
                     go to vis-app-pgf-400
           else      go to vis-app-pgf-999.
       vis-app-pgf-100.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 01, ns. banca di   *
      *              * appoggio                                        *
      *              *-------------------------------------------------*
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     vis-app-pgf-999.
       vis-app-pgf-200.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 02, codice ABI,    *
      *              * CAB e C/C fornitore                             *
      *              *-------------------------------------------------*
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-cod-abi-den-000  thru vis-cod-abi-den-999    .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-cod-cab-den-000  thru vis-cod-cab-den-999    .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
           go to     vis-app-pgf-999.
       vis-app-pgf-300.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 03, c/c postale    *
      *              *-------------------------------------------------*
           perform   vis-ccp-app-000      thru vis-ccp-app-999        .
           go to     vis-app-pgf-999.
       vis-app-pgf-400.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 04, codice banca   *
      *              * estera fornitore                                *
      *              *-------------------------------------------------*
           perform   vis-cod-bef-000      thru vis-cod-bef-999        .
           perform   vis-cod-bef-des-000  thru vis-cod-bef-des-999    .
           perform   vis-cod-bef-fil-000  thru vis-cod-bef-fil-999    .
           perform   vis-cod-bef-ccc-000  thru vis-cod-bef-ccc-999    .
           go to     vis-app-pgf-999.
       vis-app-pgf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : % sconto pagamento        *
      *    *-----------------------------------------------------------*
       vis-scp-aap-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BD"                to   v-edm                  .
           move      w-tes-scp-aap (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-scp-aap-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostra banca          *
      *    *-----------------------------------------------------------*
       acc-nos-ban-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 01
                     go to acc-nos-ban-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-nos-ban-400.
       acc-nos-ban-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      02                   to   w-cod-des-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-cod-des-cbp-cod      .
           move      09                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      09                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-nos-ban-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-nos-ban-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-nos-ban-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-nos-ban-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-nos-ban-110.
       acc-nos-ban-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
       acc-nos-ban-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nos-ban (1)      .
       acc-nos-ban-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-nos-ban-100.
       acc-nos-ban-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nos-ban-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nos-ban-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nos-ban-100.
       acc-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostra banca       *
      *    *-----------------------------------------------------------*
       vis-nos-ban-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 01
                     go to vis-nos-ban-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nos-ban (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice nostra banca, descrizione  *
      *    *-----------------------------------------------------------*
       vis-nos-ban-des-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 01
                     go to vis-nos-ban-des-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-nos-ban-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice ABI banca d'appoggio  *
      *    *-----------------------------------------------------------*
       acc-cod-abi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to acc-cod-abi-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-sav-cod-abi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cod-abi-400.
       acc-cod-abi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-abi-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-abi-cod      .
           move      08                   to   w-cod-mne-abi-lin      .
           move      30                   to   w-cod-mne-abi-pos      .
           move      08                   to   w-cod-mne-abi-dln      .
           move      41                   to   w-cod-mne-abi-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
       acc-cod-abi-110.
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           if        w-cod-mne-abi-ope    =    "F+"
                     go to acc-cod-abi-115.
           if        w-cod-mne-abi-ope    =    "AC"
                     go to acc-cod-abi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-abi-115.
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
           go to     acc-cod-abi-110.
       acc-cod-abi-120.
           move      w-cod-mne-abi-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
       acc-cod-abi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-abi (1)      .
       acc-cod-abi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica istituti                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-cod-abi-den-000  thru vis-cod-abi-den-999    .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita da lettura           *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to acc-cod-abi-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazioni riguardanti   *
      *                      * 'scf'                                   *
      *                      *-----------------------------------------*
           if        w-prs-snx-scf        not  = "S"
                     go to acc-cod-abi-600.
      *                      *-----------------------------------------*
      *                      * Test se a zero                          *
      *                      *-----------------------------------------*
           if        w-tes-cod-abi (1)    not  = zero
                     go to acc-cod-abi-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-cod-abi-600
           else      go to acc-cod-abi-100.
       acc-cod-abi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se variato codice ABI                       *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    w-sav-cod-abi
                     go to acc-cod-abi-800.
           if        w-tes-cod-cab (1)    =    zero
                     go to acc-cod-abi-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-cod-cab-den-000  thru vis-cod-cab-den-999    .
      *                      *-----------------------------------------*
      *                      * Normalizzazione C/C bancario            *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-ccc-app (1)      .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
       acc-cod-abi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-abi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-abi-100.
       acc-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice ABI banca          *
      *    *-----------------------------------------------------------*
       vis-cod-abi-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to vis-cod-abi-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-abi (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione banca       *
      *    *-----------------------------------------------------------*
       vis-cod-abi-den-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to vis-cod-abi-den-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-abi-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-abi-den-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice CAB                   *
      *    *-----------------------------------------------------------*
       acc-cod-cab-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to acc-cod-cab-999.
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-cab-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cod-cab-400.
       acc-cod-cab-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cab-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-cab-abi      .
           move      w-tes-cod-cab (1)    to   w-cod-mne-cab-cab      .
           move      09                   to   w-cod-mne-cab-lin      .
           move      30                   to   w-cod-mne-cab-pos      .
           move      09                   to   w-cod-mne-cab-dln      .
           move      41                   to   w-cod-mne-cab-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
       acc-cod-cab-110.
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           if        w-cod-mne-cab-ope    =    "F+"
                     go to acc-cod-cab-115.
           if        w-cod-mne-cab-ope    =    "AC"
                     go to acc-cod-cab-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cab-115.
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
           go to     acc-cod-cab-110.
       acc-cod-cab-120.
           move      w-cod-mne-cab-cab    to   v-num                  .
       acc-cod-cab-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
       acc-cod-cab-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cab (1)      .
       acc-cod-cab-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-cab-den-000  thru vis-cod-cab-den-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-cod-cab-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-cab (1)    not  = zero
                     go to acc-cod-cab-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-cod-cab-600
           else      go to acc-cod-cab-100.
       acc-cod-cab-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cab-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cab-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cab-100.
       acc-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice CAB                *
      *    *-----------------------------------------------------------*
       vis-cod-cab-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to vis-cod-cab-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cab (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione sportello   *
      *    *-----------------------------------------------------------*
       vis-cod-cab-den-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to vis-cod-cab-den-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cab-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cab-den-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Conto corrente del fornitore *
      *    *-----------------------------------------------------------*
       acc-ccc-app-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 02
                     go to acc-ccc-app-999.
           if        w-tes-cod-abi (1)    =    zero or
                     w-tes-cod-cab (1)    =    zero
                     go to acc-ccc-app-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-ccc-app-400.
       acc-ccc-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ccc-app (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
       acc-ccc-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ccc-app (1)      .
       acc-ccc-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice a spaces : reimpostazione, a meno *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-ccc-app (1)    not  = spaces
                     go to acc-ccc-app-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-ccc-app-600
           else      go to acc-ccc-app-100.
       acc-ccc-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccc-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ccc-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ccc-app-100.
       acc-ccc-app-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Conto corrente fornitore  *
      *    *-----------------------------------------------------------*
       vis-ccc-app-000.
      *              *-------------------------------------------------*
