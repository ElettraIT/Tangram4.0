      *    *===========================================================*
      *    * Prompt per : Appoggio pagamento al fornitore              *
      *    *-----------------------------------------------------------*
       pmt-app-pgf-000.
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Abblencamento linee interessate                 *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      10                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo appoggio paga-  *
      *              * mento                                           *
      *              *-------------------------------------------------*
           if        w-tes-app-pgf (1)    =    01
                     go to pmt-app-pgf-100
           else if   w-tes-app-pgf (1)    =    02
                     go to pmt-app-pgf-200
           else if   w-tes-app-pgf (1)    =    03
                     go to pmt-app-pgf-300
           else if   w-tes-app-pgf (1)    =    04
                     go to pmt-app-pgf-400
           else      go to pmt-app-pgf-900.
       pmt-app-pgf-100.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 01, ns. banca di   *
      *              * appoggio                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ns. banca di appoggio      :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     pmt-app-pgf-900.
       pmt-app-pgf-200.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 02, codice ABI,    *
      *              * CAB e C/C fornitore                             *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Cod. ABI banca per bonifici:"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Cod. CAB sportello         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Conto corrente             :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     pmt-app-pgf-900.
       pmt-app-pgf-300.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 03, c/c postale    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Conto corrente postale     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     pmt-app-pgf-900.
       pmt-app-pgf-400.
      *              *-------------------------------------------------*
      *              * Se tipo appoggio pagamento : 04, codice banca   *
      *              * estera fornitore                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to pmt-app-pgf-900.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Banca d'appoggio estera    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     pmt-app-pgf-900.
       pmt-app-pgf-900.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-app-pgf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Tipo addebito spese incasso      *
      *    *-----------------------------------------------------------*
       pmt-add-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo addebito spese incasso:"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Si/No addebito spese bollo       *
      *    *-----------------------------------------------------------*
       pmt-add-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo addebito spese bollo  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Data scadenza pagamento          *
      *    *-----------------------------------------------------------*
       pmt-pag-dsm-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Data scadenza pagamento    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Ammontare quota a forfait        *
      *    *-----------------------------------------------------------*
       pmt-pag-qaf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ammontare quota a forfait  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-pag-qaf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Ammontare acconto                *
      *    *-----------------------------------------------------------*
       pmt-pag-act-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ammontare acconto          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-pag-act-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vpg-100.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vpg-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vpg-100.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata e accet-  *
      *                  * tazione presa visione                       *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vpg-200.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-arc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "F"
                     perform acc-cod-fnt-000
                                          thru acc-cod-fnt-999        .
       acc-cod-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice fornitore             *
      *    *-----------------------------------------------------------*
       acc-cod-fnt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-fnt-100.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-sav-cod-arc          .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcf-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-dcf-cod      .
           move      08                   to   w-cod-mne-dcf-lin      .
           move      27                   to   w-cod-mne-dcf-pos      .
           move      08                   to   w-cod-mne-dcf-rln      .
           move      41                   to   w-cod-mne-dcf-rps      .
           move      09                   to   w-cod-mne-dcf-vln      .
           move      41                   to   w-cod-mne-dcf-vps      .
           move      10                   to   w-cod-mne-dcf-lln      .
           move      41                   to   w-cod-mne-dcf-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
       acc-cod-fnt-110.
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           if        w-cod-mne-dcf-ope    =    "F+"
                     go to acc-cod-fnt-115.
           if        w-cod-mne-dcf-ope    =    "AC"
                     go to acc-cod-fnt-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fnt-115.
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
           go to     acc-cod-fnt-110.
       acc-cod-fnt-120.
           move      w-cod-mne-dcf-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fnt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fnt-999.
       acc-cod-fnt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-fnt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-fnt-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [fnt]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione ragione sociale, indirizzo,  *
      *                  * localita', e sottoconto associato da ana-   *
      *                  * grafica contabile                           *
      *                  *---------------------------------------------*
           move      w-let-arc-fnt-rag    to   w-tes-cod-arc-rag (1)  .
           move      w-let-arc-fnt-via    to   w-tes-cod-arc-via (1)  .
           move      w-let-arc-fnt-loc    to   w-tes-cod-arc-loc (1)  .
           move      w-let-arc-fnt-naz    to   w-tes-cod-arc-naz (1)  .
           move      w-let-arc-fnt-piv    to   w-tes-cod-arc-piv (1)  .
           move      w-let-arc-fnt-cfi    to   w-tes-cod-arc-cfi (1)  .
           move      w-let-arc-fnt-cge    to   w-tes-cod-arc-cge (1)  .
           move      w-let-arc-fnt-ass    to   w-tes-ass-iva (1)      .
       acc-cod-fnt-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
       acc-cod-fnt-430.
      *                  *---------------------------------------------*
      *                  * Se fornitore non esistente                  *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-flg    =    spaces
                     go to acc-cod-fnt-440.
       acc-cod-fnt-432.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione di-   *
      *                      * pendenza del fornitore                  *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-dpz-arc-rag (1)
                                          =    spaces and
                     w-tes-dpz-arc-via (1)
                                          =    spaces and
                     w-tes-dpz-arc-loc (1)
                                          =    spaces
                     go to acc-cod-fnt-434.
           move      spaces               to   w-tes-dpz-arc (1)      .
           move      spaces               to   w-tes-dpz-arc-rag (1)  .
           move      spaces               to   w-tes-dpz-arc-via (1)  .
           move      spaces               to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
       acc-cod-fnt-434.
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-fnt-100.
       acc-cod-fnt-440.
      *                  *---------------------------------------------*
      *                  * Se codice a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    not  = zero
                     go to acc-cod-fnt-450.
       acc-cod-fnt-442.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione di-   *
      *                      * pendenza del fornitore                  *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-dpz-arc-rag (1)
                                          =    spaces and
                     w-tes-dpz-arc-via (1)
                                          =    spaces and
                     w-tes-dpz-arc-loc (1)
                                          =    spaces
                     go to acc-cod-fnt-444.
           move      spaces               to   w-tes-dpz-arc (1)      .
           move      spaces               to   w-tes-dpz-arc-rag (1)  .
           move      spaces               to   w-tes-dpz-arc-via (1)  .
           move      spaces               to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
       acc-cod-fnt-444.
      *                      *-----------------------------------------*
      *                      * A reimpostazione, a meno che non si sia *
      *                      * in tasto Up                             *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-cod-fnt-600
           else      go to acc-cod-fnt-100.
       acc-cod-fnt-450.
      *                  *---------------------------------------------*
      *                  * Se codice diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del confronto con  *
      *                      * il valore precedente                    *
      *                      *-----------------------------------------*
           if        w-tes-cod-arc (1)    =    w-sav-cod-arc
                     go to acc-cod-fnt-455
           else      go to acc-cod-fnt-480.
       acc-cod-fnt-455.
      *                      *-----------------------------------------*
      *                      * Se valore impostato pari al valore pre- *
      *                      * cedente                                 *
      *                      *-----------------------------------------*
       acc-cod-fnt-457.
      *                          *-------------------------------------*
      *                          * Lettura anagrafica commerciale del  *
      *                          * fornitore principale                *
      *                          *-------------------------------------*
           move      "C"                  to   w-let-arc-dcf-tle      .
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-cod      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                          *-------------------------------------*
      *                          * Deviazione a seconda dell'esito     *
      *                          * della lettura                       *
      *                          *-------------------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-cod-fnt-467.
       acc-cod-fnt-459.
      *                          *-------------------------------------*
      *                          * Se anagrafica commerciale del for-  *
      *                          * nitore principale non esistente     *
      *                          *-------------------------------------*
       acc-cod-fnt-461.
      *                              *---------------------------------*
      *                              * Normalizzazione e visualizza-   *
      *                              * zione dei dati relativi alla    *
      *                              * dipendenza                      *
      *                              *---------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-dpz-arc-rag (1)
                                          =    spaces and
                     w-tes-dpz-arc-via (1)
                                          =    spaces and
                     w-tes-dpz-arc-loc (1)
                                          =    spaces
                     go to acc-cod-fnt-463.
           move      spaces               to   w-tes-dpz-arc (1)      .
           move      spaces               to   w-tes-dpz-arc-rag (1)  .
           move      spaces               to   w-tes-dpz-arc-via (1)  .
           move      spaces               to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
       acc-cod-fnt-463.
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "Manca l'anagrafica commerciale per il fornitore   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cod-fnt-465.
      *                              *---------------------------------*
      *                              * A reimpostazione                *
      *                              *---------------------------------*
           go to     acc-cod-fnt-100.
       acc-cod-fnt-467.
      *                          *-------------------------------------*
      *                          * Se anagrafica commerciale del for-  *
      *                          * nitore principale esistente         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Memorizzazione valori letti da  *
      *                              * anagrafica commerciale fornitore*
      *                              * principale in dati per la di-   *
      *                              * pendenza                        *
      *                              *---------------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
      *                              *---------------------------------*
      *                              * Deviazione a seconda se il co-  *
      *                              * dice dipendenza e' a spaces op- *
      *                              * pure diverso da spaces          *
      *                              *---------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     go to acc-cod-fnt-469
           else      go to acc-cod-fnt-471.
       acc-cod-fnt-469.
      *                              *---------------------------------*
      *                              * Se codice dipendenza a spaces   *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Visualizzazione valori re-  *
      *                                  * lativi alla dipendenza      *
      *                                  *-----------------------------*
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                                  *-----------------------------*
      *                                  * A ulteriori controlli       *
      *                                  *-----------------------------*
           go to     acc-cod-fnt-500.
       acc-cod-fnt-471.
      *                              *---------------------------------*
      *                              * Se codice dipendenza diverso da *
      *                              * spaces                          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Lettura anagrafica commer-  *
      *                                  * ciale della dipendenza      *
      *                                  *-----------------------------*
           move      "D"                  to   w-let-arc-dcf-tle      .
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-cod      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                                  *-----------------------------*
      *                                  * Deviazione a seconda del-   *
      *                                  * l'esito della lettura       *
      *                                  *-----------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-cod-fnt-473
           else      go to acc-cod-fnt-475.
       acc-cod-fnt-473.
      *                                  *-----------------------------*
      *                                  * Se anagrafica commerciale   *
      *                                  * della dipendenza esistente  *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Memorizzazione valori   *
      *                                      * letti da anagrafica     *
      *                                      * commerciale della di-   *
      *                                      * pendenza                *
      *                                      *-------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
      *                                      *-------------------------*
      *                                      * Visualizzazione valori  *
      *                                      * relativi alla dipenden- *
      *                                      * za                      *
      *                                      *-------------------------*
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                                      *-------------------------*
      *                                      * A ulteriori controlli   *
      *                                      *-------------------------*
           go to     acc-cod-fnt-500.
       acc-cod-fnt-475.
      *                                  *-----------------------------*
      *                                  * Se anagrafica commerciale   *
      *                                  * della dipendenza non esi-   *
      *                                  * stente                      *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Memorizzazione valori   *
      *                                      * letti da anagrafica     *
      *                                      * commerciale della di-   *
      *                                      * pendenza                *
      *                                      *-------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
      *                                      *-------------------------*
      *                                      * Visualizzazione valori  *
      *                                      * relativi alla dipenden- *
      *                                      * za                      *
      *                                      *-------------------------*
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                                      *-------------------------*
      *                                      * Messaggio di errore     *
      *                                      *-------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Manca l'anagrafica commerciale per la dipendenza "
                                delimited by   size
                     "'"        delimited by   size
                     w-tes-dpz-arc (1)
                                delimited by spaces
                     "'"        delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                                      *-------------------------*
      *                                      * A reimpostazione        *
      *                                      *-------------------------*
           go to     acc-cod-fnt-100.
       acc-cod-fnt-480.
      *                      *-----------------------------------------*
      *                      * Se valore impostato diverso dal valore  *
      *                      * precedente                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se modificabile                *
      *                          *-------------------------------------*
           if        w-tes-fda-pt1 (1)    =    spaces
                     go to acc-cod-fnt-482.
      *                          *-------------------------------------*
      *                          * Box di avvertimento                 *
      *                          *-------------------------------------*
           perform   acc-cod-fnt-mod-000  thru acc-cod-fnt-mod-999    .
      *                          *-------------------------------------*
      *                          * Test su scelta                      *
      *                          *-------------------------------------*
           if        w-exp-arc-mod-sce    =    01
                     go to acc-cod-fnt-100.
       acc-cod-fnt-482.
      *                              *---------------------------------*
      *                              * Normalizzazione e visualizza-   *
      *                              * zione dei dati relativi alla    *
      *                              * dipendenza                      *
      *                              *---------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-dpz-arc-rag (1)
                                          =    spaces and
                     w-tes-dpz-arc-via (1)
                                          =    spaces and
                     w-tes-dpz-arc-loc (1)
                                          =    spaces
                     go to acc-cod-fnt-484.
           move      spaces               to   w-tes-dpz-arc (1)      .
           move      spaces               to   w-tes-dpz-arc-rag (1)  .
           move      spaces               to   w-tes-dpz-arc-via (1)  .
           move      spaces               to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
       acc-cod-fnt-484.
      *                              *---------------------------------*
      *                              * Test che, se sono richiesti ag- *
      *                              * giornamenti contabili, il sot-  *
      *                              * toconto associato al fornitore  *
      *                              * sia diverso da zero. Solo se    *
      *                              * non si e' in Visualizzazione    *
      *                              *---------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-cod-fnt-486.
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-cod-fnt-486.
           if        w-tes-cod-arc-cge (1)
                                          not  = zero
                     go to acc-cod-fnt-486.
           move      "Manca il sottoconto contabile associato al fornito
      -              "re !           "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      zero                 to   w-tes-cod-arc (1)      .
           move      spaces               to   v-key                  .
           go to     acc-cod-fnt-400.
       acc-cod-fnt-486.
      *                              *---------------------------------*
      *                              * Riaggancio                      *
      *                              *---------------------------------*
           go to     acc-cod-fnt-457.
       acc-cod-fnt-500.
      *                  *---------------------------------------------*
      *                  * Lettura tabella [codiva]                    *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
       acc-cod-fnt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ri-lettura anagrafica commerciale del       *
      *                  * fornitore principale                        *
      *                  *---------------------------------------------*
           move      "C"                  to   w-let-arc-dcf-tle      .
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-cod      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Subroutine per note su fornitore            *
      *                  *---------------------------------------------*
           perform   cod-mne-dcf-not-000  thru cod-mne-dcf-not-999    .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [dcf] principale                     *
      *                  *---------------------------------------------*
           perform   det-vlt-dcf-000      thru det-vlt-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * dipendenti dalla forma di pagamento         *
      *                  *---------------------------------------------*
           perform   det-vlt-yfp-000      thru det-vlt-yfp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione funzionamento spese          *
      *                  *---------------------------------------------*
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione se presenti dipendenze per   *
      *                  * il fornitore in corso di trattamento        *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-det-snd-dcf-fnt      .
           perform   det-snd-dcf-000      thru det-snd-dcf-999        .
       acc-cod-fnt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fnt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fnt-100.
       acc-cod-fnt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice fornitore                     *
      *    *                                                           *
      *    * Routine di avviso per cambio codice fornitore             *
      *    *-----------------------------------------------------------*
       acc-cod-fnt-mod-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       acc-cod-fnt-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica del codice fornitore non comporta alcu
      -              "na variazione "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "nelle condizioni gia' presenti nel documento !    
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-arc-mod-sce      .
       acc-cod-fnt-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-arc-mod-lun    to   v-car                  .
           move      w-exp-arc-mod-num    to   v-ldt                  .
           move      "AP#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-arc-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-arc-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-cod-fnt-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02
                     go to acc-cod-fnt-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-arc-mod-sce      .
       acc-cod-fnt-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-fnt-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-fnt-mod-999.
       acc-cod-fnt-mod-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice archivio           *
      *    *-----------------------------------------------------------*
       vis-cod-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-arc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione archivio      *
      *    *-----------------------------------------------------------*
       vis-cod-arc-des-000.
      *              *-------------------------------------------------*
      *              * Ragione sociale                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Indirizzo                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Localita'                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-des-600.
      *              *-------------------------------------------------*
      *              * Partita Iva                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Pulizia preliminare                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Test se archivio estero                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-naz (1)
                                          =    "IT " or
                     w-tes-cod-arc-naz (1)
                                          =    spaces
                     go to vis-cod-arc-des-640.
       vis-cod-arc-des-620.
      *                  *---------------------------------------------*
      *                  * Archivio estero                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      w-tes-cod-arc-cfi (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cod-arc-des-999.
       vis-cod-arc-des-640.
      *                  *---------------------------------------------*
      *                  * Archivio Italia                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      w-tes-cod-arc-piv (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Dipendenza archivio          *
      *    *-----------------------------------------------------------*
       acc-dpz-arc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dpz-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "F"
                     perform acc-dpz-fnt-000
                                          thru acc-dpz-fnt-999
           else      go to acc-dpz-arc-999.
       acc-dpz-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dpz-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice dipendenza fornitore          *
      *    *-----------------------------------------------------------*
       acc-dpz-fnt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    =    zero
                     go to acc-dpz-fnt-999.
           if        w-det-snd-dcf-snx    =    "N"
                     go to acc-dpz-fnt-999.
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-dpz-fnt-400.
       acc-dpz-fnt-100.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-sav-dpz-arc          .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcf-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dcf-fnt      .
           move      w-tes-dpz-arc (1)    to   w-cod-cod-dcf-cod      .
           move      14                   to   w-cod-cod-dcf-lin      .
           move      27                   to   w-cod-cod-dcf-pos      .
           move      14                   to   w-cod-cod-dcf-rln      .
           move      41                   to   w-cod-cod-dcf-rps      .
           move      15                   to   w-cod-cod-dcf-vln      .
           move      41                   to   w-cod-cod-dcf-vps      .
           move      16                   to   w-cod-cod-dcf-lln      .
           move      41                   to   w-cod-cod-dcf-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcf-cll-000  thru cod-cod-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcf-foi-000  thru cod-cod-dcf-foi-999    .
       acc-dpz-fnt-110.
           perform   cod-cod-dcf-cll-000  thru cod-cod-dcf-cll-999    .
           if        w-cod-cod-dcf-ope    =    "F+"
                     go to acc-dpz-fnt-115.
           if        w-cod-cod-dcf-ope    =    "AC"
                     go to acc-dpz-fnt-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-fnt-115.
           perform   cod-cod-dcf-foi-000  thru cod-cod-dcf-foi-999    .
           go to     acc-dpz-fnt-110.
       acc-dpz-fnt-120.
           move      w-cod-cod-dcf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-fnt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-fnt-999.
       acc-dpz-fnt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-arc (1)      .
       acc-dpz-fnt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dpz-fnt-410.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se codice sipendenza   *
      *                  * a spaces oppure no                          *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     go to acc-dpz-fnt-420
           else      go to acc-dpz-fnt-440.
       acc-dpz-fnt-420.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica commerciale del for- *
      *                      * nitore principale                       *
      *                      *-----------------------------------------*
           move      "C"                  to   w-let-arc-dcf-tle      .
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-cod      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valori letti da anagra-  *
      *                      * fica commerciale fornitore principale   *
      *                      * in dati per la dipendenza               *
      *                      *-----------------------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori relativi alla    *
      *                      * dipendenza                              *
      *                      *-----------------------------------------*
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito della   *
      *                      * lettura                                 *
      *                      *-----------------------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-dpz-fnt-425
           else      go to acc-dpz-fnt-430.
       acc-dpz-fnt-425.
      *                      *-----------------------------------------*
      *                      * Se anagrafica commerciale del fornitore *
      *                      * principale esistente                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A dipendenze dall'impostazione      *
      *                          *-------------------------------------*
           go to     acc-dpz-fnt-600.
       acc-dpz-fnt-430.
      *                      *-----------------------------------------*
      *                      * Se anagrafica commerciale del fornitore *
      *                      * principale non esistente                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Manca l'anagrafica commerciale per il fornitore   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-dpz-fnt-100.
       acc-dpz-fnt-440.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza diverso da spaces      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica commerciale per la   *
      *                      * dipendenza                              *
      *                      *-----------------------------------------*
           move      "D"                  to   w-let-arc-dcf-tle      .
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-cod      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valori letti da anagra-  *
      *                      * fica commerciale della dipendenza in    *
      *                      * dati per la dipendenza                  *
      *                      *-----------------------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori relativi alla    *
      *                      * dipendenza                              *
      *                      *-----------------------------------------*
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito della   *
      *                      * lettura                                 *
      *                      *-----------------------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-dpz-fnt-445
           else      go to acc-dpz-fnt-450.
       acc-dpz-fnt-445.
      *                      *-----------------------------------------*
      *                      * Se anagrafica commerciale della dipen-  *
      *                      * denza esistente                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A dipendenze dall'impostazione      *
      *                          *-------------------------------------*
           go to     acc-dpz-fnt-600.
       acc-dpz-fnt-450.
      *                      *-----------------------------------------*
      *                      * Se anagrafica commerciale della dipen-  *
      *                      * denza non esistente                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Manca l'anagrafica commerciale per la dipendenza "
                                delimited by   size
                     "'"        delimited by   size
                     w-tes-dpz-arc (1)
                                delimited by spaces
                     "'"        delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-dpz-fnt-100.
       acc-dpz-fnt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine per note su dipendenza fornitore *
      *                  *---------------------------------------------*
           perform   cod-cod-dcf-not-000  thru cod-cod-dcf-not-999    .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    w-sav-dpz-arc
                     go to acc-dpz-fnt-800.
      *                      *-----------------------------------------*
      *                      * Rilettura anagrafica commerciale per la *
      *                      * dipendenza                              *
      *                      *-----------------------------------------*
           move      "D"                  to   w-let-arc-dcf-tle      .
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-cod      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcf]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-dpz-fnt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-fnt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-fnt-100.
       acc-dpz-fnt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza archivio       *
      *    *-----------------------------------------------------------*
       vis-dpz-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-dpz-arc (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    *-----------------------------------------------------------*
       vis-dpz-arc-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-arc-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no documento 'xml'                *
      *    *-----------------------------------------------------------*
       acc-snx-sdi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-flg-xml (1)    to    w-sav-flg-xml         .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-snx-sdi-400.
      *                  *---------------------------------------------*
      *                  * Eventuale default                           *
      *                  *---------------------------------------------*
           if        w-tes-flg-xml (1)    not  = spaces
                     go to acc-snx-sdi-100.
      *                  *---------------------------------------------*
      *                  * Test su codice nazione                      *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-naz    =    "IT "
                     move  "S"            to   w-tes-flg-xml (1)
           else      move  "N"            to   w-tes-flg-xml (1)      .
       acc-snx-sdi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-xml-lun    to   v-car                  .
           move      w-exp-flg-xml-num    to   v-ldt                  .
           move      "SN#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-flg-xml-tbl    to   v-txt                  .
      *
           if        w-tes-flg-xml (1)    =    spaces
                     move  01             to   v-num
           else if   w-tes-flg-xml (1)    =    "S"
                     move  01             to   v-num
           else if   w-tes-flg-xml (1)    =    "N"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-snx-sdi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-snx-sdi-999.
       acc-snx-sdi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "S"            to   w-tes-flg-xml (1)
           else if   v-num                =    02
                     move  "N"            to   w-tes-flg-xml (1)
           else      move  spaces         to   w-tes-flg-xml (1)      .
       acc-snx-sdi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-sdi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente per il campo  *
      *                  * successivo                                  *
      *                  *---------------------------------------------*
           move      w-tes-fil-sdi (1)    to    w-sav-fil-xml         .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-flg-xml (1)    =    w-sav-flg-xml
                     go to acc-snx-sdi-800.
      *                  *---------------------------------------------*
      *                  * Se 'N'                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-flg-xml (1)    =    "S"
                     go to acc-snx-sdi-620.
      *                      *-----------------------------------------*
      *                      * Normalizzazione nome file 'xml'         *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-fil-sdi (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione nome file 'xml'         *
      *                      *-----------------------------------------*
           perform   vis-fil-sdi-000      thru vis-fil-sdi-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-snx-sdi-800.
       acc-snx-sdi-620.
      *                  *---------------------------------------------*
      *                  * Se 'S'                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se esiste il nome file 'xml'       *
      *                      *-----------------------------------------*
           if        w-tes-fil-sdi (1)    not  = spaces
                     go to acc-snx-sdi-800.
      *                      *-----------------------------------------*
      *                      * ATTUALMENTE INIBITO                     *
      *                      *-----------------------------------------*
           go to     acc-snx-sdi-800.
      *                      *-----------------------------------------*
      *                      * Assemblaggio                            *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      "IT"                 to   w-all-str-cat (01)     .
      *
           if        w-tes-cod-arc-ids (1)
                                          not  = spaces
                     move  w-tes-cod-arc-ids (1)
                                          to   w-all-str-cat (02)
           else      move  w-tes-cod-arc-cfi (1)
                                          to   w-all-str-cat (02)     .
      *
           move      "_"                  to   w-all-str-cat (03)     .
           move      "....."              to   w-all-str-cat (04)     .
      *
           if        v-key                =    "[1] "
                     move  ".xml"         to   w-all-str-cat (05)
           else      move  ".xml.p7m"     to   w-all-str-cat (05)     .
      *
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                      *-----------------------------------------*
      *                      * Nome file 'xml' assemblato              *
      *                      *-----------------------------------------*
           move      w-all-str-alf        to   w-tes-fil-sdi (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione nome file 'xml'         *
      *                      *-----------------------------------------*
           perform   vis-fil-sdi-000      thru vis-fil-sdi-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-snx-sdi-800.
       acc-snx-sdi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-sdi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-sdi-100.
       acc-snx-sdi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Si/no documento 'xml'             *
      *    *-----------------------------------------------------------*
       vis-snx-sdi-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-xml-lun    to   v-car                  .
           move      w-exp-flg-xml-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-flg-xml-tbl    to   v-txt                  .
      *
           if        w-tes-flg-xml (1)    =    spaces
                     move  01             to   v-num
           else if   w-tes-flg-xml (1)    =    "S"
                     move  01             to   v-num
           else if   w-tes-flg-xml (1)    =    "N"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-sdi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Nome file xml                        *
      *    *-----------------------------------------------------------*
       acc-fil-sdi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-flg-xml (1)    not  = "N"
                     go to acc-fil-sdi-050.
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-fil-sdi (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-fil-sdi-000      thru vis-fil-sdi-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-fil-sdi-999.
       acc-fil-sdi-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-fil-sdi (1)    to   w-sav-fil-sdi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-fil-sdi-400.
       acc-fil-sdi-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo in Inserimento                         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-fil-sdi-120.
      *                  *---------------------------------------------*
      *                  * Solo se valore a spazi                      *
      *                  *---------------------------------------------*
           if        w-tes-fil-sdi (1)    not  = spaces
                     go to acc-fil-sdi-120.
      *                  *---------------------------------------------*
      *                  * Nota 1                                      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "Numero documento seguito da RICERCA per trovare il
      -              " documento caricato"
                                          to   v-nt1                  .
           move      spaces               to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-fil-sdi-120.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *
           move      w-tes-fil-sdi (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative attuali            *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fil-sdi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fil-sdi-999.
       acc-fil-sdi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-fil-sdi (1)      .
       acc-fil-sdi-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-fil-sdi-400.
      *                  *---------------------------------------------*
      *                  * Find su archivio [xft]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-fnd-arc-xft-fnt      .
           move      w-tes-fil-sdi (1)    to   w-fnd-arc-xft-doc      .
           perform   fnd-arc-xft-000      thru fnd-arc-xft-999        .
           move      w-fnd-arc-xft-xml    to   w-tes-fil-sdi (1)      .
           perform   vis-fil-sdi-000      thru vis-fil-sdi-999        .
       acc-fil-sdi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-fil-sdi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-fil-sdi (1)    =    w-sav-fil-sdi
                     go to acc-fil-sdi-800.
      *                  *---------------------------------------------*
      *                  * Lettura documento 'xml'                     *
      *                  *---------------------------------------------*
           perform   acc-fil-sdi-let-000  thru acc-fil-sdi-let-999    .
       acc-fil-sdi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fil-sdi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fil-sdi-100.
       acc-fil-sdi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Nome file xml                     *
      *    *-----------------------------------------------------------*
       vis-fil-sdi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-fil-sdi (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fil-sdi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Nome file documento elettronico      *
      *    *                                                           *
      *    * Subroutine di lettura documento 'xml'                     *
      *    *-----------------------------------------------------------*
       acc-fil-sdi-let-000.
      *              *-------------------------------------------------*
      *              * Chiamata modulo                                 *
      *              *-------------------------------------------------*
           move      "RX"                 to   m-xml-for-tip-ope      .
           move      w-tes-fil-sdi (1)    to   m-xml-for-nom-xml      .
           perform   mdl-xml-for-cll-000  thru mdl-xml-for-cll-999    .
       acc-fil-sdi-let-100.
      *              *-------------------------------------------------*
      *              * Test se inserimento                             *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-fil-sdi-let-900.
      *              *-------------------------------------------------*
      *              * Test su nome file                               *
      *              *-------------------------------------------------*
           if        w-tes-fil-sdi (1)    =    spaces
                     go to acc-fil-sdi-let-900.
       acc-fil-sdi-let-200.
      *              *-------------------------------------------------*
      *              * Dati di testata                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data documento del fornitore                *
      *                  *---------------------------------------------*
           if        w-tes-dat-doc (1)    =    zero
                     move m-xml-for-dat-doc
                                          to   w-tes-dat-doc (1)      .
      *                  *---------------------------------------------*
      *                  * Numero documento del fornitore              *
      *                  *---------------------------------------------*
           if        w-tes-num-doc (1)    =    spaces
                     move m-xml-for-num-doc
                                          to   w-tes-num-doc (1)      .
      *                  *---------------------------------------------*
      *                  * Importo documento del fornitore             *
      *                  *---------------------------------------------*
           if        w-tes-imp-doc (1)    =    zero
                     move m-xml-for-imp-doc
                                          to   w-tes-imp-doc (1)      .
       acc-fil-sdi-let-400.
      *              *-------------------------------------------------*
      *              * Dati righe                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * ___ DA IMPLEMENTARE ___                     *
      *                  *---------------------------------------------*
       acc-fil-sdi-let-600.
      *              *-------------------------------------------------*
      *              * Dati pagamento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo per max 9 elementi                    *
      *                  *---------------------------------------------*
           move      zero                 to   w-trd-scx-ele          .
           move      zero                 to   w-all-str-i01          .
       acc-fil-sdi-let-620.
           add       1                    to   w-all-str-i01          .
           if        w-all-str-i01        >    9
                     go to acc-fil-sdi-let-800.
      *                  *---------------------------------------------*
      *                  * Se elemento vuoto: uscita                   *
      *                  *---------------------------------------------*
           if        m-xml-for-mod-pag
                    (w-all-str-i01)       =    spaces
                     go to acc-fil-sdi-let-800.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione                             *
      *                  *---------------------------------------------*
           move      w-all-str-i01        to   w-trd-scx-ele          .
           move      m-xml-for-mod-pag
                    (w-all-str-i01)       to   w-trd-scx-mod
                                              (w-all-str-i01)         .
           move      m-xml-for-imp-pag
                    (w-all-str-i01)       to   w-trd-scx-imp
                                              (w-all-str-i01)         .
           move      m-xml-for-dat-scd
                    (w-all-str-i01)       to   w-trd-scx-dat
                                              (w-all-str-i01)         .
           move      m-xml-for-cod-abi
                    (w-all-str-i01)       to   w-trd-scx-abi
                                              (w-all-str-i01)         .
           move      m-xml-for-cod-cab
                    (w-all-str-i01)       to   w-trd-scx-cab
                                              (w-all-str-i01)         .
           move      m-xml-for-cod-ibn
                    (w-all-str-i01)       to   w-trd-scx-ibn
                                              (w-all-str-i01)         .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     acc-fil-sdi-let-620.
       acc-fil-sdi-let-800.
      *              *-------------------------------------------------*
      *              * Dati Iva                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Castelletto Iva                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-cst-ctr-rig          .
       acc-fil-sdi-let-820.
           add       1                    to   w-cst-ctr-rig          .
           if        w-cst-ctr-rig        >    6
                     go to acc-fil-sdi-let-900.
      *                  *---------------------------------------------*
      *                  * Codice Iva                                  *
      *                  *---------------------------------------------*
           if        w-te2-iva-cod
                    (1, w-cst-ctr-rig)    =    zero
                     move  m-xml-for-iva-cod
                          (w-cst-ctr-rig) to   w-te2-iva-cod
                                              (1, w-cst-ctr-rig)      .
      *                  *---------------------------------------------*
      *                  * Imponibile Iva                              *
      *                  *---------------------------------------------*
           if        w-te2-iva-ibl
                    (1, w-cst-ctr-rig)    =    zero
                     move  m-xml-for-iva-ibl
                          (w-cst-ctr-rig) to   w-te2-iva-ibl
                                              (1, w-cst-ctr-rig)      .
      *                  *---------------------------------------------*
      *                  * Imposta Iva                                 *
      *                  *---------------------------------------------*
           if        w-te2-iva-imp
                    (1, w-cst-ctr-rig)    =    zero
                     move  m-xml-for-iva-imp
                          (w-cst-ctr-rig) to   w-te2-iva-imp
                                              (1, w-cst-ctr-rig)      .
       acc-fil-sdi-let-880.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     acc-fil-sdi-let-820.
       acc-fil-sdi-let-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-fil-sdi-let-999.
       acc-fil-sdi-let-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data documento del fornitore *
      *    *-----------------------------------------------------------*
       acc-dat-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dat-doc (1)    to   w-sav-dat-doc          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-dat-doc-400.
       acc-dat-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      20                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-dat-doc (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dat-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dat-doc-999.
       acc-dat-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dat-doc (1)      .
       acc-dat-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dat-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento numero documento                *
      *                  *---------------------------------------------*
           if        w-tes-dat-doc (1)    =    zero and
                     w-tes-num-doc (1)    not  = spaces
                     move  spaces         to   w-tes-num-doc (1)
                     perform vis-num-doc-000
                                          thru vis-num-doc-999        .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dat-doc (1)    =    w-sav-dat-doc
                     go to acc-dat-doc-800.
      *                      *-----------------------------------------*
      *                      * Determinazione coefficiente di cambio   *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc (1)    to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
       acc-dat-doc-620.
      *                      *-----------------------------------------*
      *                      * Trattamento importo fattura fornitore   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da trattare                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test su impostazione righe del  *
      *                              * documento                       *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to acc-dat-doc-630.
      *                              *---------------------------------*
      *                              * Deviazione in funzione del tipo *
      *                              * provenienza                     *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
                     go to acc-dat-doc-621
           else if   w-tes-cod-tmf-tpv    =    02
                     go to acc-dat-doc-622
           else if   w-tes-cod-tmf-tpv    =    03
                     go to acc-dat-doc-623
           else if   w-tes-cod-tmf-tpv    =    04
                     go to acc-dat-doc-624.
       acc-dat-doc-621.
      *                              *---------------------------------*
      *                              * Se documento Italia             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-dat-doc-628.
           go to     acc-dat-doc-630.
       acc-dat-doc-622.
      *                              *---------------------------------*
      *                              * Se documento CEE                *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-dat-doc-628.
           go to     acc-dat-doc-630.
       acc-dat-doc-623.
      *                              *---------------------------------*
      *                              * Se documento Estero             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Si accetta sempre           *
      *                                  *-----------------------------*
           go to     acc-dat-doc-628.
       acc-dat-doc-624.
      *                              *---------------------------------*
      *                              * Se bolla doganale               *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-dat-doc-628.
           go to     acc-dat-doc-630.
       acc-dat-doc-628.
      *                              *---------------------------------*
      *                              * Test su sigla valuta            *
      *                              *---------------------------------*
            if       w-tes-sgl-vpf (1)    =    c-sgl
                     go to acc-dat-doc-630.
      *                              *---------------------------------*
      *                              * Test se importo in valuta anco- *
      *                              * ra a zero                       *
      *                              *---------------------------------*
           if        w-tes-iiv-doc (1)    =    zero
                     go to acc-dat-doc-630.
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-tes-iiv-doc (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-tes-imp-doc (1)      .
       acc-dat-doc-630.
       acc-dat-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dat-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-doc-100.
       acc-dat-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data documento del forni- *
      *    * tore                                                      *
      *    *-----------------------------------------------------------*
       vis-dat-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      20                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-dat-doc (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Numero documento del forni-  *
      *    * tore                                                      *
      *    *-----------------------------------------------------------*
       acc-num-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-num-doc-400.
       acc-num-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-num-doc (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-num-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-num-doc-999.
       acc-num-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-num-doc (1)      .
       acc-num-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore nullo non ammesso, a meno che non si *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        w-tes-num-doc (1)    not  = spaces
                     go to acc-num-doc-500.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-num-doc-600
           else      go to acc-num-doc-100.
       acc-num-doc-500.
      *                  *---------------------------------------------*
      *                  * Controllo se numero documento gia' inserito *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se aggiornamenti contabili da      *
      *                      * eseguire                                *
      *                      *-----------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-cge        not  = "S"
                     go to acc-num-doc-600.
      *                      *-----------------------------------------*
      *                      * Operazione di controllo su 'cge'        *
      *                      *-----------------------------------------*
           move      "CN"                 to   l-cge-300-tip-ope      .
           move      "F"                  to   l-cge-300-tip-arc      .
           move      w-tes-cod-arc (1)    to   l-cge-300-cod-arc      .
           move      w-tes-dat-doc (1)    to   l-cge-300-dat-doc      .
           move      w-tes-num-doc (1)    to   l-cge-300-num-doc      .
           move      w-pie-prt-mgd (1)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        l-cge-300-exi-sts    =    spaces
                     go to acc-num-doc-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : il documento sembra gia' inserito con
      -              " questi estremi"    to   w-err-box-err-msg      .
           move      "                                 [digitare 'S' per
      -              " presa visione]"    to   w-err-box-err-m02      .
           perform   box-msg-es2-000      thru box-msg-es2-999        .
       acc-num-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento data documento                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero documento non esistente, vuol *
      *                      * dire che siamo in Up e quindi oltre     *
      *                      *-----------------------------------------*
           if        w-tes-num-doc (1)    =    spaces
                     go to acc-num-doc-800.
      *                      *-----------------------------------------*
      *                      * Se data documento esistente : oltre     *
      *                      *-----------------------------------------*
           if        w-tes-dat-doc (1)    not  = zero
                     go to acc-num-doc-800.
      *                      *-----------------------------------------*
      *                      * Forzatura della data di registrazione   *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   w-tes-dat-doc (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione data documento          *
      *                      *-----------------------------------------*
           perform   vis-dat-doc-000      thru vis-dat-doc-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione coefficiente di cambio   *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc (1)    to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
       acc-num-doc-620.
      *                      *-----------------------------------------*
      *                      * Trattamento importo fattura fornitore   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da trattare                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test su impostazione righe del  *
      *                              * documento                       *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to acc-num-doc-630.
      *                              *---------------------------------*
      *                              * Deviazione in funzione del tipo *
      *                              * provenienza                     *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
                     go to acc-num-doc-621
           else if   w-tes-cod-tmf-tpv    =    02
                     go to acc-num-doc-622
           else if   w-tes-cod-tmf-tpv    =    03
                     go to acc-num-doc-623
           else if   w-tes-cod-tmf-tpv    =    04
                     go to acc-num-doc-624.
       acc-num-doc-621.
      *                              *---------------------------------*
      *                              * Se documento Italia             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-num-doc-628.
           go to     acc-num-doc-630.
       acc-num-doc-622.
      *                              *---------------------------------*
      *                              * Se documento CEE                *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-num-doc-628.
           go to     acc-num-doc-630.
       acc-num-doc-623.
      *                              *---------------------------------*
      *                              * Se documento Estero             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Si accetta sempre           *
      *                                  *-----------------------------*
           go to     acc-num-doc-628.
       acc-num-doc-624.
      *                              *---------------------------------*
      *                              * Se bolla doganale               *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-num-doc-628.
           go to     acc-num-doc-630.
       acc-num-doc-628.
      *                              *---------------------------------*
      *                              * Test su sigla valuta            *
      *                              *---------------------------------*
            if       w-tes-sgl-vpf (1)    =    c-sgl
                     go to acc-num-doc-630.
      *                              *---------------------------------*
      *                              * Test se importo in valuta anco- *
      *                              * ra a zero                       *
      *                              *---------------------------------*
           if        w-tes-iiv-doc (1)    =    zero
                     go to acc-num-doc-630.
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-tes-iiv-doc (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-tes-imp-doc (1)      .
       acc-num-doc-630.
       acc-num-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-num-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-num-doc-100.
       acc-num-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Numero documento del for- *
      *    * nitore                                                    *
      *    *-----------------------------------------------------------*
       vis-num-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-num-doc (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Protocollo di contabilita'        *
      *    *-----------------------------------------------------------*
       vis-prt-cge-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo funzionamento                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to vis-prt-cge-900.
      *                  *---------------------------------------------*
      *                  * Test su personalizzazioni                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-cge        not  = "S"
                     go to vis-prt-cge-900.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-pie-prt-mgd (1)    =    zero
                     go to vis-prt-cge-900.
       vis-prt-cge-100.
      *              *-------------------------------------------------*
      *              * Preparazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test di esistenza                           *
      *                  *---------------------------------------------*
           move      "TM"                 to   l-cge-300-tip-ope      .
           move      w-te2-dat-mgd (1)    to   l-cge-300-dat-reg      .
           move      w-pie-prt-mgd (1)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Editing protocollo di contabilita'          *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-pie-prt-mgd (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      v-edt                to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
      *                  * Editing data di registrazione               *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-te2-dat-mgd (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      v-edt                to   w-all-str-cat (4)      .
      *                  *---------------------------------------------*
      *                  * Concatenamento                              *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      "(Reg."              to   w-all-str-cat (1)      .
           move      "del"                to   w-all-str-cat (3)      .
      *
           if        l-cge-300-exi-sts    =    spaces
                     move  ")"
                                          to   w-all-str-cat (5)
           else if   l-cge-300-exi-sts    =    "?"
                     move  "non trovata)"
                                          to   w-all-str-cat (5)
           else      move  "non modific.)"
                                          to   w-all-str-cat (5)      .
      *
           perform   all-str-csb-000      thru all-str-csb-999        .
       vis-prt-cge-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prt-cge-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-prt-cge-999.
       vis-prt-cge-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Inoltro pagamenti            *
      *    *-----------------------------------------------------------*
       acc-inl-pgt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-inl-pgt (1)    to    w-sav-inl-pgt         .
      *                  *---------------------------------------------*
      *                  * Se dipendenza fornitore non esistente, mo-  *
      *                  * difica nr. elementi del pop-up di accetta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     move 02              to   w-exp-inl-pgt-num
           else      move 03              to   w-exp-inl-pgt-num      .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    zero
                     move  02             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-inl-pgt-400.
       acc-inl-pgt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      "SLD#"               to   v-msk                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
       acc-inl-pgt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-inl-pgt (1)      .
       acc-inl-pgt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    not  = zero
                     go to acc-inl-pgt-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-inl-pgt-600
           else      go to acc-inl-pgt-100.
       acc-inl-pgt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    w-sav-inl-pgt
                     go to acc-inl-pgt-800.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-inl-pgt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-inl-pgt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-inl-pgt-100.
       acc-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Inoltro pagamenti         *
      *    *-----------------------------------------------------------*
       vis-inl-pgt-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Sigla valuta                 *
      *    *-----------------------------------------------------------*
       acc-sgl-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo provenienza documento      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    not  = 02 and
                     w-tes-cod-tmf-tpv    not  = 03
                     go to acc-sgl-vpf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)       to   w-sav-sgl-vpf       .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-sgl-vpf-400.
       acc-sgl-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-tes-sgl-vpf (1)    to   w-cod-cod-zvl-cod      .
           move      08                   to   w-cod-cod-zvl-lin      .
           move      30                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpf-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpf-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpf-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpf-110.
       acc-sgl-vpf-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
       acc-sgl-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-sgl-vpf (1)      .
       acc-sgl-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-des    to   w-tes-sgl-vpf-des (1)  .
           move      w-let-arc-zvl-dec    to   w-tes-dec-vpf (1)      .
           move      w-let-arc-zvl-tdc    to   w-tes-tdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione valuta          *
      *                  *---------------------------------------------*
           perform   vis-sgl-vpf-des-000  thru vis-sgl-vpf-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Valore a Spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = spaces
                     go to acc-sgl-vpf-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-sgl-vpf-600
           else      go to acc-sgl-vpf-100.
       acc-sgl-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    w-sav-sgl-vpf
                     go to acc-sgl-vpf-800.
      *                      *-----------------------------------------*
      *                      * Trattamento coefficiente di cambio      *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc (1)    to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
           perform   vis-cdc-vpf-000      thru vis-cdc-vpf-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione               *
      *                      *-----------------------------------------*
           if        w-coe-cmb-vlt-cdc    =    zero
                     move  1              to   w-coe-cmb-vlt-cdc      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento coefficiente di cambio    *
      *                      *-----------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione coefficiente di cambio  *
      *                      *-----------------------------------------*
           perform   vis-cdc-vpf-000      thru vis-cdc-vpf-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dei prezzi in riga  *
      *                      * in caso di variazione valuta            *
      *                      *-----------------------------------------*
           perform   rcl-vlt-prz-000      thru rcl-vlt-prz-999        .
      *                      *-----------------------------------------*
      *                      * Test sulla scelta dell'operatore        *
      *                      *-----------------------------------------*
           if        w-exp-rcl-vlt-sce    =    01
                     go to acc-sgl-vpf-100.
      *                      *-----------------------------------------*
      *                      * Attivazione segnale di conversione da   *
      *                      * effettuare                              *
      *                      *-----------------------------------------*
           move      "#"                  to   w-sav-sgl-var          .
       acc-sgl-vpf-610.
      *                      *-----------------------------------------*
      *                      * Trattamento importo in valuta           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da trattare                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test su impostazione righe del  *
      *                              * documento                       *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to acc-sgl-vpf-630.
      *                              *---------------------------------*
      *                              * Deviazione in funzione del tipo *
      *                              * provenienza                     *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
                     go to acc-sgl-vpf-611
           else if   w-tes-cod-tmf-tpv    =    02
                     go to acc-sgl-vpf-612
           else if   w-tes-cod-tmf-tpv    =    03
                     go to acc-sgl-vpf-613
           else if   w-tes-cod-tmf-tpv    =    04
                     go to acc-sgl-vpf-614.
       acc-sgl-vpf-611.
      *                              *---------------------------------*
      *                              * Se documento Italia             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Non si accetta mai          *
      *                                  *-----------------------------*
           go to     acc-sgl-vpf-620.
       acc-sgl-vpf-612.
      *                              *---------------------------------*
      *                              * Se documento CEE                *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-sgl-vpf-618.
           go to     acc-sgl-vpf-620.
       acc-sgl-vpf-613.
      *                              *---------------------------------*
      *                              * Se documento Estero             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Si accetta sempre           *
      *                                  *-----------------------------*
           go to     acc-sgl-vpf-618.
       acc-sgl-vpf-614.
      *                              *---------------------------------*
      *                              * Se bolla doganale               *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Non si accetta mai          *
      *                                  *-----------------------------*
           go to     acc-sgl-vpf-620.
       acc-sgl-vpf-618.
      *                          *-------------------------------------*
      *                          * Normalizzazione e visualizzazione   *
      *                          *-------------------------------------*
           if        w-tes-iiv-doc (1)    =    zero
                     go to acc-sgl-vpf-620.
           move      zero                 to   w-tes-iiv-doc (1)      .
           perform   vis-iiv-doc-000      thru vis-iiv-doc-999        .
       acc-sgl-vpf-620.
      *                      *-----------------------------------------*
      *                      * Trattamento importo fattura fornitore   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da trattare                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione in funzione del tipo *
      *                              * operazione                      *
      *                              *---------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
                     go to acc-sgl-vpf-621
           else if   w-tes-cod-tmf-tpv    =    02
                     go to acc-sgl-vpf-622
           else if   w-tes-cod-tmf-tpv    =    03
                     go to acc-sgl-vpf-623
           else if   w-tes-cod-tmf-tpv    =    04
                     go to acc-sgl-vpf-624.
       acc-sgl-vpf-621.
      *                              *---------------------------------*
      *                              * Se documento Italia             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-sgl-vpf-628.
           go to     acc-sgl-vpf-630.
       acc-sgl-vpf-622.
      *                              *---------------------------------*
      *                              * Se documento CEE                *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-sgl-vpf-628.
           go to     acc-sgl-vpf-630.
       acc-sgl-vpf-623.
      *                              *---------------------------------*
      *                              * Se documento Estero             *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Si accetta sempre           *
      *                                  *-----------------------------*
           go to     acc-sgl-vpf-628.
       acc-sgl-vpf-624.
      *                              *---------------------------------*
      *                              * Se bolla doganale               *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Solo se aggiornamenti con-  *
      *                                  * tabili da non eseguire      *
      *                                  *-----------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-sgl-vpf-628.
           go to     acc-sgl-vpf-630.
       acc-sgl-vpf-628.
      *                          *-------------------------------------*
      *                          * Normalizzazione e visualizzazione   *
      *                          *-------------------------------------*
           if        w-tes-imp-doc (1)    not  = zero
                     go to acc-sgl-vpf-630.
           move      zero                 to   w-tes-imp-doc (1)
           perform   vis-imp-doc-000      thru vis-imp-doc-999        .
       acc-sgl-vpf-630.
       acc-sgl-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sgl-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sgl-vpf-100.
       acc-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sigla valuta              *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione sigla valuta  *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-sgl-vpf-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Coefficiente di cambio       *
      *    *-----------------------------------------------------------*
       acc-cdc-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to acc-cdc-vpf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cdc-vpf (1)       to   w-sav-cdc-vpf       .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cdc-vpf-400.
       acc-cdc-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc (1)    to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           if        w-tes-cdc-vpf (1)    =    zero
                     move  "S"            to   w-coe-cmb-vlt-snd
           else      move  "N"            to   w-coe-cmb-vlt-snd      .
           move      w-tes-cdc-vpf (1)    to   w-coe-cmb-vlt-cdc      .
           move      08                   to   w-coe-cmb-vlt-lin      .
           move      60                   to   w-coe-cmb-vlt-pos      .
           move      08                   to   w-coe-cmb-vlt-dln      .
           move      73                   to   w-coe-cmb-vlt-dps      .
           move      "<GBD"               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-cdc-vpf-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-cdc-vpf-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-cdc-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cdc-vpf-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-cdc-vpf-110.
       acc-cdc-vpf-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-cdc-vpf-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cdc-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cdc-vpf-999.
       acc-cdc-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cdc-vpf (1)      .
       acc-cdc-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-cdc-vpf (1)    not  = zero
                     go to acc-cdc-vpf-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-cdc-vpf-600
           else      go to acc-cdc-vpf-100.
       acc-cdc-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-cdc-vpf (1)    =    w-sav-cdc-vpf
                     go to acc-cdc-vpf-800.
      *                  *---------------------------------------------*
      *                  * Determinazione importo documento            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-cdc-vpf-800.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-tes-iiv-doc (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-tes-imp-doc (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-doc-000      thru vis-imp-doc-999        .
       acc-cdc-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cdc-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cdc-vpf-100.
       acc-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Coefficiente di cambio    *
      *    *-----------------------------------------------------------*
       vis-cdc-vpf-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = c-sgl
                     go to vis-cdc-vpf-100.
           if        w-tes-cod-tmf-tpv    not  = 02 and
                     w-tes-cod-tmf-tpv    not  = 03
                     go to vis-cdc-vpf-999.
       vis-cdc-vpf-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<GBD"               to   v-edm                  .
           move      08                   to   v-lin                  .
           move      60                   to   v-pos                  .
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  zero           to   v-num
           else      move  w-tes-cdc-vpf (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Assoggettamento iva          *
      *    *-----------------------------------------------------------*
       acc-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo provenienza documento      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    =    03 or
                     w-tes-cod-tmf-tpv    =    04
                     go to acc-ass-iva-999.
      *                      *-----------------------------------------*
      *                      * Test su flag di accettazione pagina     *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-ass-iva-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-ass-iva-400.
       acc-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      10                   to   w-cod-mne-zci-lin      .
           move      30                   to   w-cod-mne-zci-pos      .
           move      10                   to   w-cod-mne-zci-dln      .
           move      37                   to   w-cod-mne-zci-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-ass-iva-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-ass-iva-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-ass-iva-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ass-iva-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-ass-iva-110.
       acc-ass-iva-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
       acc-ass-iva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ass-iva (1)      .
       acc-ass-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-des-000  thru vis-ass-iva-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zci-flg    not  = spaces
                     go to acc-ass-iva-100.
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
      *
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     go to acc-ass-iva-100.
       acc-ass-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ass-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ass-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ass-iva-100.
       acc-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice di esenzione IVA   *
      *    *-----------------------------------------------------------*
       vis-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione assoggetta-   *
      *    * mento IVA                                                 *
      *    *-----------------------------------------------------------*
       vis-ass-iva-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-ass-iva-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Contropartita acquisti       *
      *    *-----------------------------------------------------------*
       acc-ctp-acq-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo provenienza documento      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    =    04
                     go to acc-ctp-acq-999.
      *                      *-----------------------------------------*
      *                      * Test se registrazione contabile da ese- *
      *                      * guire                                   *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-ctp-acq-999.
      *                      *-----------------------------------------*
      *                      * Test su flag di accettazione pagina     *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-ctp-acq-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-ctp-acq-400.
       acc-ctp-acq-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-tes-ctp-acq (1)    to   w-cod-mne-pdc-cod      .
           move      12                   to   w-cod-mne-pdc-lin      .
           move      30                   to   w-cod-mne-pdc-pos      .
           move      12                   to   w-cod-mne-pdc-dln      .
           move      41                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-acq-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-acq-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-acq-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-acq-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-acq-110.
       acc-ctp-acq-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-acq-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-acq-999.
       acc-ctp-acq-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ctp-acq (1)      .
       acc-ctp-acq-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-tes-ctp-acq (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-acq-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-acq-des-000  thru vis-ctp-acq-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-acq-100.
       acc-ctp-acq-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctp-acq-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ctp-acq-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ctp-acq-100.
       acc-ctp-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sottoconto contabile      *
      *    *-----------------------------------------------------------*
       vis-ctp-acq-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    04
                     go to vis-ctp-acq-999.
           if        w-tes-cod-tmf-ccg    =    zero
                     go to vis-ctp-acq-999.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-tes-ctp-acq (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita acquisti    *
      *    * per testata                                               *
      *    *-----------------------------------------------------------*
       vis-ctp-acq-des-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    04
                     go to vis-ctp-acq-des-999.
           if        w-tes-cod-tmf-ccg    =    zero
                     go to vis-ctp-acq-des-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-ctp-acq-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-acq-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Importo documento in valuta          *
      *    *-----------------------------------------------------------*
       acc-iiv-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su impostazione righe del documen- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to acc-iiv-doc-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to acc-iiv-doc-999.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo prove-  *
      *                      * nienza documento                        *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
                     go to acc-iiv-doc-010
           else if   w-tes-cod-tmf-tpv    =    02
                     go to acc-iiv-doc-020
           else if   w-tes-cod-tmf-tpv    =    03
                     go to acc-iiv-doc-030
           else if   w-tes-cod-tmf-tpv    =    04
                     go to acc-iiv-doc-040.
       acc-iiv-doc-010.
      *                      *-----------------------------------------*
      *                      * Se documento Italia                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Non si accetta mai                  *
      *                          *-------------------------------------*
           go to     acc-iiv-doc-999.
       acc-iiv-doc-020.
      *                      *-----------------------------------------*
      *                      * Se documento CEE                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Solo se aggiornamenti contabili da  *
      *                          * non eseguire                        *
      *                          *-------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to acc-iiv-doc-050.
           go to     acc-iiv-doc-999.
       acc-iiv-doc-030.
      *                      *-----------------------------------------*
      *                      * Se documento Estero                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Si accetta sempre                   *
      *                          *-------------------------------------*
           go to     acc-iiv-doc-050.
       acc-iiv-doc-040.
      *                      *-----------------------------------------*
      *                      * Se bolla doganale                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Non si accetta mai                  *
      *                          *-------------------------------------*
           go to     acc-iiv-doc-999.
       acc-iiv-doc-050.
      *                      *-----------------------------------------*
      *                      * Test su flag di accettazione pagina     *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-iiv-doc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-iiv-doc (1)    to   w-sav-iiv-doc          .
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-iiv-doc-400.
       acc-iiv-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *
           move      w-tes-iiv-doc (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-iiv-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-iiv-doc-999.
       acc-iiv-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-iiv-doc (1)      .
       acc-iiv-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-iiv-doc (1)    not  = zero
                     go to acc-iiv-doc-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-iiv-doc-600
           else      go to acc-iiv-doc-100.
       acc-iiv-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-iiv-doc (1)    =    w-sav-iiv-doc
                     go to acc-iiv-doc-800.
      *                  *---------------------------------------------*
      *                  * Determinazione importo documento            *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-tes-iiv-doc (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-tes-imp-doc (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo documento           *
      *                  *---------------------------------------------*
           perform   vis-imp-doc-000      thru vis-imp-doc-999        .
       acc-iiv-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-iiv-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-iiv-doc-100.
       acc-iiv-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo documento in valuta       *
      *    *-----------------------------------------------------------*
       vis-iiv-doc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su impostazione righe del documento    *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-ird    =    "S"
                     go to vis-iiv-doc-999.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo provenienza *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmf-tpv    =    01
                     go to vis-iiv-doc-010
           else if   w-tes-cod-tmf-tpv    =    02
                     go to vis-iiv-doc-020
           else if   w-tes-cod-tmf-tpv    =    03
                     go to vis-iiv-doc-030
           else if   w-tes-cod-tmf-tpv    =    04
                     go to vis-iiv-doc-040.
       vis-iiv-doc-010.
      *                  *---------------------------------------------*
      *                  * Se documento Italia                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non si visualizza mai                   *
      *                      *-----------------------------------------*
           go to     vis-iiv-doc-999.
       vis-iiv-doc-020.
      *                  *---------------------------------------------*
      *                  * Se documento CEE                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se aggiornamenti contabili da non  *
      *                      * eseguire                                *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmf-ccg    =    zero
                     go to vis-iiv-doc-050.
           go to     vis-iiv-doc-999.
       vis-iiv-doc-030.
      *                  *---------------------------------------------*
      *                  * Se documento Estero                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si visualizza sempre                    *
      *                      *-----------------------------------------*
           go to     vis-iiv-doc-050.
       vis-iiv-doc-040.
      *                  *---------------------------------------------*
      *                  * Se bolla doganale                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non si visualizza mai                   *
      *                      *-----------------------------------------*
           go to     vis-iiv-doc-999.
       vis-iiv-doc-050.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-iiv-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-iiv-doc-999.
           exit.

