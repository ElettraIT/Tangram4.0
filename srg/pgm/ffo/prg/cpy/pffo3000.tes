      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ccp-app (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccp-app-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice banca estera per fattura for- *
      *    *                      nitore                               *
      *    *-----------------------------------------------------------*
       acc-cod-bef-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to acc-cod-bef-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-app-pgf (1)    not  = 04
                     go to acc-cod-bef-999.
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-cod-bef-400.
       acc-cod-bef-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-bef-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-bef-dcf      .
           move      w-tes-dpz-arc (1)    to   w-cod-mne-bef-dpz      .
           move      w-tes-cod-bef (1)    to   w-cod-mne-bef-cod      .
           move      08                   to   w-cod-mne-bef-lin      .
           move      30                   to   w-cod-mne-bef-pos      .
           move      08                   to   w-cod-mne-bef-dln      .
           move      41                   to   w-cod-mne-bef-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-bef-cll-000  thru cod-mne-bef-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-bef-foi-000  thru cod-mne-bef-foi-999    .
       acc-cod-bef-110.
           perform   cod-mne-bef-cll-000  thru cod-mne-bef-cll-999    .
           if        w-cod-mne-bef-ope    =    "F+"
                     go to acc-cod-bef-115.
           if        w-cod-mne-bef-ope    =    "AC"
                     go to acc-cod-bef-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-bef-115.
           perform   cod-mne-bef-foi-000  thru cod-mne-bef-foi-999    .
           go to     acc-cod-bef-110.
       acc-cod-bef-120.
           move      w-cod-mne-bef-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-bef-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-bef-999.
       acc-cod-bef-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-bef (1)      .
       acc-cod-bef-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [bef]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-bef-fnt      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-bef-dpz      .
           move      w-tes-cod-bef (1)    to   w-let-arc-bef-cod      .
           perform   let-arc-bef-000      thru let-arc-bef-999        .
           move      w-let-arc-bef-des    to   w-tes-cod-bef-des (1)  .
           move      w-let-arc-bef-fil    to   w-tes-cod-bef-fil (1)  .
           move      w-let-arc-bef-ccc    to   w-tes-cod-bef-ccc (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati banca estera           *
      *                  *---------------------------------------------*
           perform   vis-cod-bef-des-000  thru vis-cod-bef-des-999    .
           perform   vis-cod-bef-fil-000  thru vis-cod-bef-fil-999    .
           perform   vis-cod-bef-ccc-000  thru vis-cod-bef-ccc-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-bef-flg    not  = spaces
                     go to acc-cod-bef-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-bef (1)    not  = zero
                     go to acc-cod-bef-600.
           if        v-key                =    "UP  "
                     move  spaces         to   w-cnt-sts-imp-tes
                     go to acc-cod-bef-600
           else      go to acc-cod-bef-100.
       acc-cod-bef-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-bef-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-bef-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-bef-100.
       acc-cod-bef-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice banca estera per fattura   *
      *    *                         fornitore                         *
      *    *-----------------------------------------------------------*
       vis-cod-bef-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to vis-cod-bef-999.
           if        w-tes-app-pgf (1)    not  = 04
                     go to vis-cod-bef-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-bef (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bef-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione banca estera          *
      *    *-----------------------------------------------------------*
       vis-cod-bef-des-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to vis-cod-bef-des-999.
           if        w-tes-app-pgf (1)    not  = 04
                     go to vis-cod-bef-des-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-bef-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bef-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Filiale banca estera              *
      *    *-----------------------------------------------------------*
       vis-cod-bef-fil-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to vis-cod-bef-fil-999.
           if        w-tes-app-pgf (1)    not  = 04
                     go to vis-cod-bef-fil-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-bef-fil (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bef-fil-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : C/C banca estera                  *
      *    *-----------------------------------------------------------*
       vis-cod-bef-ccc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx        not  = "S" or
                     w-prs-snx-scf        not  = "S"
                     go to vis-cod-bef-ccc-999.
           if        w-tes-app-pgf (1)    not  = 04
                     go to vis-cod-bef-ccc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-bef-ccc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bef-ccc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : addebito spese incasso       *
      *    *-----------------------------------------------------------*
       acc-add-spi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-add-spi-400.
       acc-add-spi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-yin-ope      .
           move      w-tes-add-spi (1)    to   w-cod-cod-yin-cod      .
           move      13                   to   w-cod-cod-yin-lin      .
           move      30                   to   w-cod-cod-yin-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-cod-spi-cll-000  thru cod-cod-spi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-spi-foi-000  thru cod-cod-spi-foi-999    .
       acc-add-spi-110.
           perform   cod-cod-spi-cll-000  thru cod-cod-spi-cll-999    .
           if        w-cod-cod-yin-ope    =    "F+"
                     go to acc-add-spi-115.
           if        w-cod-cod-yin-ope    =    "AC"
                     go to acc-add-spi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spi-115.
           perform   cod-cod-spi-foi-000  thru cod-cod-spi-foi-999    .
           go to     acc-add-spi-110.
       acc-add-spi-120.
           move      w-cod-cod-yin-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spi-999.
       acc-add-spi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-add-spi (1)      .
       acc-add-spi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-add-spi (1)    to   w-let-arc-yin-cod      .
           move      00                   to   w-let-arc-yin-tpg      .
           perform   let-arc-yin-000      thru let-arc-yin-999        .
           move      w-let-arc-yin-des    to   w-tes-add-spi-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-add-spi-des-000  thru vis-add-spi-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-yin-flg    not  = spaces
                     go to acc-add-spi-100.
       acc-add-spi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva spese incasso    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se pagina totali di riepilogo do-  *
      *                      * cumento ancora da impostare             *
      *                      *-----------------------------------------*
           if        w-te2-fda-pt1 (1)    not  = spaces
                     go to acc-add-spi-610.
           move      w-let-arc-yin-coi    to   w-te2-civ-spi (1)      .
       acc-add-spi-610.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione contropartita spese incasso *
      *                  *---------------------------------------------*
           move      w-let-arc-yin-ccp    to   w-te2-ccp-spi (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [yin]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-yin-000      thru det-vlt-yin-999        .
       acc-add-spi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-add-spi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-add-spi-100.
       acc-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Addebito spese incasso    *
      *    *-----------------------------------------------------------*
       vis-add-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-add-spi (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descriz. spese incasso    *
      *    *-----------------------------------------------------------*
       vis-add-spi-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-add-spi-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spi-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : addebito spese bollo         *
      *    *-----------------------------------------------------------*
       acc-add-spb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-add-spb-400.
       acc-add-spb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-ybo-ope      .
           move      w-tes-add-spb (1)    to   w-cod-cod-ybo-cod      .
           move      15                   to   w-cod-cod-ybo-lin      .
           move      30                   to   w-cod-cod-ybo-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-cod-spb-cll-000  thru cod-cod-spb-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-spb-foi-000  thru cod-cod-spb-foi-999    .
       acc-add-spb-110.
           perform   cod-cod-spb-cll-000  thru cod-cod-spb-cll-999    .
           if        w-cod-cod-ybo-ope    =    "F+"
                     go to acc-add-spb-115.
           if        w-cod-cod-ybo-ope    =    "AC"
                     go to acc-add-spb-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spb-115.
           perform   cod-cod-spb-foi-000  thru cod-cod-spb-foi-999    .
           go to     acc-add-spb-110.
       acc-add-spb-120.
           move      w-cod-cod-ybo-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spb-999.
       acc-add-spb-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-add-spb (1)      .
       acc-add-spb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-add-spb (1)    to   w-let-arc-ybo-cod      .
           move      00                   to   w-let-arc-ybo-tpg      .
           perform   let-arc-ybo-000      thru let-arc-ybo-999        .
           move      w-let-arc-ybo-des    to   w-tes-add-spb-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-add-spb-des-000  thru vis-add-spb-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-ybo-flg    not  = spaces
                     go to acc-add-spb-100.
       acc-add-spb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva spese bollo      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se pagina totali di riepilogo do-  *
      *                      * cumento ancora da impostare             *
      *                      *-----------------------------------------*
           if        w-te2-fda-pt1 (1)    not  = spaces
                     go to acc-add-spb-610.
           move      w-let-arc-ybo-coi    to   w-te2-civ-spb (1)      .
       acc-add-spb-610.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione contropartita spese bollo   *
      *                  *---------------------------------------------*
           move      w-let-arc-ybo-ccp    to   w-te2-ccp-spb (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [ybo]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-ybo-000      thru det-vlt-ybo-999        .
       acc-add-spb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-add-spb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-add-spb-100.
       acc-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Addebito spese bollo      *
      *    *-----------------------------------------------------------*
       vis-add-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-add-spb (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descriz. spese bollo      *
      *    *-----------------------------------------------------------*
       vis-add-spb-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-add-spb-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spb-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data scadenza pagamento      *
      *    *-----------------------------------------------------------*
       acc-pag-dsm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-spm (1)    =    spaces
                     go to acc-pag-dsm-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pag-dsm-400.
       acc-pag-dsm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      ">"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-dsm (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-dsm-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-dsm-999.
       acc-pag-dsm-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-pag-dsm (1)      .
       acc-pag-dsm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se inferiore a data documento          *
      *                  *---------------------------------------------*
           if        w-tes-pag-dsm (1)    <    w-tes-dat-reg
                     go to acc-pag-dsm-100.
       acc-pag-dsm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pag-dsm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-dsm-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-dsm-100.
       acc-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data scadenza pagamento   *
      *    *-----------------------------------------------------------*
       vis-pag-dsm-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-pag-dsm (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Importo quota a forfait per pagamen- *
      *    *                      to                                   *
      *    *-----------------------------------------------------------*
       acc-pag-qaf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-qaf (1)    =    spaces
                     go to acc-pag-qaf-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pag-qaf-400.
       acc-pag-qaf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-qaf (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-qaf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-qaf-999.
       acc-pag-qaf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pag-qaf (1)      .
       acc-pag-qaf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pag-qaf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pag-qaf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-qaf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-qaf-100.
       acc-pag-qaf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo quota a forfait per paga- *
      *    *                         mento                             *
      *    *-----------------------------------------------------------*
       vis-pag-qaf-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      w-tes-pag-qaf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-qaf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Importo acconto per pagamento        *
      *    *-----------------------------------------------------------*
       acc-pag-act-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-act (1)    =    spaces
                     go to acc-pag-act-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti    *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pag-act-400.
       acc-pag-act-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-act (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-act-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-act-999.
       acc-pag-act-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pag-act (1)      .
       acc-pag-act-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pag-act-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pag-act-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-act-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-act-100.
       acc-pag-act-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo acconto per pagamento     *
      *    *-----------------------------------------------------------*
       vis-pag-act-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      w-tes-pag-act (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-act-999.
           exit.
