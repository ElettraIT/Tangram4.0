           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "--------------------- ------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-600.
       pmt-cor-reg-390.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 13              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "    Codice       Codice del fornitore   "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "-------------- -------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-600.
       pmt-cor-reg-400.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 14              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "      Codice        Codice del fornitore"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "------------------ ---------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-600.
       pmt-cor-reg-600.
      *              *-------------------------------------------------*
      *              * Quantita' e prezzo                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      21                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      " Quantita'   Prezzo  "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      21                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      "---------- ----------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-700.
      *              *-------------------------------------------------*
      *              * Importo                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "   Importo   "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "-------------"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-800.
      *              *-------------------------------------------------*
      *              * Trattini di chiusura                            *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : tipo riga         *
      *              *-------------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : codice addebito o *
      *              *                               commento          *
      *              *-------------------------------------------------*
           perform   vis-cod-aoc-000      thru vis-cod-aoc-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : codice prodotto   *
      *              *-------------------------------------------------*
           perform   vis-cod-pro-000      thru vis-cod-pro-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : formato di acqui- *
      *              * sizione                                         *
      *              *-------------------------------------------------*
           perform   vis-fda-pif-000      thru vis-fda-pif-999        .
      *              *-------------------------------------------------*
      *              * Codice prodotto secondo fornitore               *
      *              *-------------------------------------------------*
           perform   vis-cop-sfn-000      thru vis-cop-sfn-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : descrizione       *
      *              *-------------------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : quantita' prima-  *
      *              * ria                                             *
      *              *-------------------------------------------------*
           perform   vis-qta-pri-000      thru vis-qta-pri-999        .
      *              *-------------------------------------------------*
      *              * Quantita' secondaria                            *
      *              *-------------------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
      *              *-------------------------------------------------*
      *              * Unita' di misura                                *
      *              *-------------------------------------------------*
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *              *-------------------------------------------------*
      *              * Prezzo                                          *
      *              *-------------------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *              *-------------------------------------------------*
      *              * Numero lotto                                    *
      *              *-------------------------------------------------*
           perform   vis-lot-sgl-000      thru vis-lot-sgl-999        .
      *              *-------------------------------------------------*
      *              * Data lotto                                      *
      *              *-------------------------------------------------*
           perform   vis-lot-dat-000      thru vis-lot-dat-999        .
      *              *-------------------------------------------------*
      *              * Sigla valuta per il legame valutario            *
      *              *-------------------------------------------------*
           perform   vis-sgl-vpl-000      thru vis-sgl-vpl-999        .
      *              *-------------------------------------------------*
      *              * Coefficiente di cambio di riferimento per il    *
      *              * legame valutario                                *
      *              *-------------------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
      *              *-------------------------------------------------*
      *              * Coefficiente di cambio effettivo per il legame  *
      *              * valutario                                       *
      *              *-------------------------------------------------*
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
      *              *-------------------------------------------------*
      *              * Percentuale di limitazione per legame valutario *
      *              *-------------------------------------------------*
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
      *              *-------------------------------------------------*
      *              * Tipo di limitazione per legame valutario        *
      *              *-------------------------------------------------*
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *              *-------------------------------------------------*
      *              * % sconto in riga                                *
      *              *-------------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *              *-------------------------------------------------*
      *              * Importo in riga                                 *
      *              *-------------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Codice iva                                      *
      *              *-------------------------------------------------*
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *              *-------------------------------------------------*
      *              * Contropartita                                   *
      *              *-------------------------------------------------*
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga corpo espansa  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo riga         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Codice prodotto                             *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
      *                  *---------------------------------------------*
      *                  * Formato di acquisizione                     *
      *                  *---------------------------------------------*
           perform   pmt-fda-pif-000      thru pmt-fda-pif-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione                                 *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Descrizione       :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Quantita'                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Quantita'         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Prezzo                                      *
      *                  *---------------------------------------------*
           perform   pmt-prz-acq-000      thru pmt-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Numero lotto                                *
      *                  *---------------------------------------------*
           perform   pmt-lot-sgl-000      thru pmt-lot-sgl-999        .
      *                  *---------------------------------------------*
      *                  * Data lotto                                  *
      *                  *---------------------------------------------*
           perform   pmt-lot-dat-000      thru pmt-lot-dat-999        .
      *                  *---------------------------------------------*
      *                  * Legame valutario                            *
      *                  *---------------------------------------------*
           perform   pmt-leg-val-000      thru pmt-leg-val-999        .
      *                  *---------------------------------------------*
      *                  * % sconto                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "% sconto          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Importo                                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      "Importo :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice iva        :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Contropartita                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Contropartita     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per note in righe docu- *
      *              * mento                                           *
      *              *-------------------------------------------------*
           move      "PM"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Codice prodotto                                           *
      *    *-----------------------------------------------------------*
       pmt-cod-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  "Codice addebito   :"
                                          to   v-alf
           else if   w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento   :"
                                          to   v-alf
           else      move  "Codice prodotto   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Formato di acquisizione per il fornitore                  *
      *    *-----------------------------------------------------------*
       pmt-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to pmt-fda-pif-999.
           if        w-prs-snx-fda        =    "N"
                     go to pmt-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "Formato :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per prezzo d'acquisto             *
      *    *-----------------------------------------------------------*
       pmt-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Preparazione literal                            *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    not  = "P"
                     move  "Prezzo            :"
                                          to   v-alf
                     go to pmt-prz-acq-100.
           if        w-rig-umf-tum (1)    =    spaces
                     move  "Prezzo            :"
                                          to   v-alf
                     go to pmt-prz-acq-100.
           move      spaces               to   v-alf                  .
           string    "Prezzo/"
                                delimited by   size
                     w-rig-umf-tum (1)
                                delimited by   size
                     "        :"
                                delimited by   size
                                          into v-alf                  .
       pmt-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione literal                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : sigla lotto                      *
      *    *-----------------------------------------------------------*
       pmt-lot-sgl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to pmt-lot-sgl-999.
       pmt-lot-sgl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "Lotto   :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-lot-sgl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : data lotto                       *
      *    *-----------------------------------------------------------*
       pmt-lot-dat-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to pmt-lot-dat-999.
       pmt-lot-dat-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "del:"               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-lot-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       pmt-leg-val-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to pmt-leg-val-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to pmt-leg-val-999.
           if        w-cat-rig-new        not  = spaces
                     go to pmt-leg-val-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      47                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      "Legame:                               +/-      "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-leg-val-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : tipo    *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       acc-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-rig-025.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del default          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    not  = spaces
                     go to acc-tip-rig-050.
           if        w-tes-cod-tmf-dtr    not  = spaces
                     if    w-tes-cod-tmf-dtr
                                          =    "-----"
                           move  spaces   to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050
                     else  move  w-tes-cod-tmf-dtr
                                          to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050.
       acc-tip-rig-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig (1)    to   w-sav-tip-rig          .
       acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-rig        to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-te2    not  = spaces and
                     w-cnt-sts-imp-co2    not  = spaces and
                     w-cnt-sts-imp-co3    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Pf4  : ammesso solo se gestione bolle   *
      *                      *        fornitori attiva e il tipo movi- *
      *                      *        mento per la bolla lo consente   *
      *                      *        e si e' in un record New         *
      *                      *-----------------------------------------*
           if       (w-prs-bfo-snx        =    "S" and
                     w-tes-cod-tmf-maf    =    02    ) and
                     w-cat-rig-new        not  = spaces
                     move  "[4] "         to   v-pfk (17)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   v-alf                  .
       acc-tip-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-rig-210.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-rig-250.
      *                  *---------------------------------------------*
      *                  * Test se ricerca per prodotto                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : find su tipi riga       *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-tip-rig-220.
           if        v-alf                =    spaces
                     go to acc-tip-rig-220.
           move      v-alf                to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    = spaces
                     go to acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su righe per codice prodotto           *
      *                  *---------------------------------------------*
           move      v-alf                to   w-fnd-mag-rig-alf      .
           move      w-cat-rig-cur        to   w-fnd-mag-rig-cur      .
           perform   fnd-mag-rig-000      thru fnd-mag-rig-999        .
           if        w-fnd-mag-rig-num    =    zero
                     go to acc-tip-rig-100.
           move      w-fnd-mag-rig-num    to   w-cnt-slc-rap-num      .
           go to     acc-tip-rig-320.
       acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su tipi riga                           *
      *                  *---------------------------------------------*
           perform   fnd-tip-rig-000      thru fnd-tip-rig-999        .
           if        w-fnd-tip-rig-sel    not  = spaces
                     go to acc-tip-rig-100.
           move      w-fnd-tip-rig-tri    to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo riga                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-rig-425.
       acc-tip-rig-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-rig-300
           else      go to acc-tip-rig-350.
       acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-rig-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-rig-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-rig-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-rig-310.
       acc-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-rig-999.
       acc-tip-rig-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-rig-999
                     else    move  spaces to   w-cnt-tus-acc-rig
                             go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "4"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
       acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-tip-rig (1)      .
       acc-tip-rig-425.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo tipo riga impostato           *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    not  = spaces
                     go to acc-tip-rig-100.
       acc-tip-rig-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-rig-999
                     else  go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-rig-100.
       acc-tip-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo magazzino               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     move  01             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     move  03             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     move  04             to   w-rig-tip-mag (1)
           else      move  zero           to   w-rig-tip-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura codice iva              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto 'P', 'M' o 'V'   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to acc-tip-rig-620.
           if        w-tes-ass-iva (1)    =    zero
                     go to acc-tip-rig-620.
           move      w-tes-ass-iva (1)    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-tes-ass-iva-des (1)
                                          to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-tip-rig-620.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura contropartita acquisti  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto 'P', 'M' o 'V'   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to acc-tip-rig-700.
           if        w-tes-ctp-acq (1)    =    zero
                     go to acc-tip-rig-700.
           move      w-tes-ctp-acq (1)    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-tes-ctp-acq-des (1)
                                          to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-tip-rig-700.
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt per codice prodotto  *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
       acc-tip-rig-800.
       acc-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo riga                         *
      *    *-----------------------------------------------------------*
       vis-tip-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Ricerca riga da codice di magazzino                       *
      *    *-----------------------------------------------------------*
       fnd-mag-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-fnd-mag-rig-num      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      w-fnd-mag-rig-cur    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to fnd-mag-rig-100.
       fnd-mag-rig-200.
      *              *-------------------------------------------------*
      *              * Confronto con il numero riga in corso di trat-  *
      *              * tamento                                         *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-cur    =    w-cat-rig-cur
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Confronto con il codice alfanumerico contenuto  *
      *              * nella riga                                      *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-alf    not  = w-rig-alf-mag (1)
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Riga trovata in campo do comodo                 *
      *              *-------------------------------------------------*
           move      w-cat-rig-cur        to   w-fnd-mag-rig-num      .
       fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       fnd-mag-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice addebito o commen- *
      *    *                                 to                        *
      *    *-----------------------------------------------------------*
       acc-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-cod-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig-cac (1)
                                          to   w-sav-cod-aoc          .
       acc-cod-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zac-ope      .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-cod-mne-zac-tip
           else      move  02             to   w-cod-mne-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-cod-mne-zac-cod      .
           move      15                   to   w-cod-mne-zac-lin      .
           move      21                   to   w-cod-mne-zac-pos      .
           move      16                   to   w-cod-mne-zac-dln      .
           move      21                   to   w-cod-mne-zac-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "<B"                 to   v-edm                  .
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
       acc-cod-aoc-110.
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           if        w-cod-mne-zac-ope    =    "F+"
                     go to acc-cod-aoc-115.
           if        w-cod-mne-zac-ope    =    "AC"
                     go to acc-cod-aoc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aoc-115.
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
           go to     acc-cod-aoc-110.
       acc-cod-aoc-120.
           move      w-cod-mne-zac-cod    to   v-num                  .
       acc-cod-aoc-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-tip-rig-cac (1)  .
       acc-cod-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zac]                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-let-arc-zac-tip
           else      move  02             to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato                            *
      *                  *---------------------------------------------*
           if        w-let-arc-zac-flg    =    spaces
                     go to acc-cod-aoc-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento non esistente !"
                                          to   w-err-box-err-msg
           else      move  "Codice addebito non esistente !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-aoc-100.
       acc-cod-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    w-sav-cod-aoc
                     go to acc-cod-aoc-800.
      *                  *---------------------------------------------*
      *                  * Descrizione addebito o commento             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-cod-aoc-800.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-civ    to   w-edt-iva-cod          .
      *
           if        w-tes-ass-iva (1)    not  = zero
                     if    w-edt-iva-cod-003
                                          =    zero
                           move  w-tes-ass-iva (1)
                                          to   w-rig-civ-rig (1)
                     else  move  w-let-arc-zac-civ
                                          to   w-rig-civ-rig (1)
           else      move  w-let-arc-zac-civ
                                          to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-aoc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-aoc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-aoc-100.
       acc-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Codice addebito o com- *
      *    *                                    mento                  *
      *    *-----------------------------------------------------------*
       vis-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to vis-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto           *
      *    *-----------------------------------------------------------*
       acc-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-cod-pro-999.
      *                      *-----------------------------------------*
      *                      * Test se campo gia' accettato            *
      *                      *-----------------------------------------*
           if        w-rig-num-mag (1)    not  = zero
                     go to acc-cod-pro-999.
       acc-cod-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     perform   acc-cod-dcp-000
                                          thru acc-cod-dcp-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     perform   acc-cod-dpm-000
                                          thru acc-cod-dpm-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     perform   acc-cod-mtv-000
                                          thru acc-cod-mtv-999        .
       acc-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto                   *
      *    *-----------------------------------------------------------*
       vis-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cod-pro-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-alf-mag (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-dcp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      w-rig-num-mag (1)    to   w-cod-cod-dcp-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-dcp-alf      .
           move      15                   to   w-cod-cod-dcp-lin      .
           move      21                   to   w-cod-cod-dcp-pos      .
           move      16                   to   w-cod-cod-dcp-dln      .
           move      21                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dcp-400.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dcp-cod      .
           move      w-tes-cod-lng (1)    to   w-let-arc-dcp-lng      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-dcp-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto prodo
      -              "tto !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-100.
       acc-cod-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-610.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dcp]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dcp] in descrizione per documento      *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-dcp-610.
      *                  *---------------------------------------------*
      *                  * Tipo prodotto                               *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-tpr    to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si/No aggiornamento di magazzino            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-rig-snx-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-dcp-620.
      *                  *---------------------------------------------*
      *                  * Prezzo di listino base                      *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-dlb    to   w-rig-num-mag-dlb (1)  .
           move      w-let-arc-dcp-plb    to   w-rig-num-mag-plb (1)  .
       acc-cod-dcp-630.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-dcp-640.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-dcp-640.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dcp-660.
      *                      *-----------------------------------------*
      *                      * Se codice iva contenuto in [aaq] questo *
      *                      * prevale, altrimenti e' quello contenuto *
      *                      * in [dcp]                                *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-civ    not  = zero
                     move  w-let-arc-aaq-civ
                                          to   w-rig-civ-rig (1)
           else      move  w-let-arc-dcp-civ
                                          to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-dcp-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-dcp-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-dcp-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-760.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dcp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dcp-100.
       acc-cod-dcp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dpm]     *
      *    *-----------------------------------------------------------*
       acc-cod-dpm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-dpm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaq-ope      .
           move      "A"                  to   w-cod-cod-aaq-tac      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaq-tco      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaq-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaq-alf      .
           move      15                   to   w-cod-cod-aaq-lin      .
           move      21                   to   w-cod-cod-aaq-pos      .
           move      16                   to   w-cod-cod-aaq-dln      .
           move      21                   to   w-cod-cod-aaq-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
       acc-cod-dpm-110.
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           if        w-cod-cod-aaq-ope    =    "F+"
                     go to acc-cod-dpm-115.
           if        w-cod-cod-aaq-ope    =    "AC"
                     go to acc-cod-dpm-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dpm-115.
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
           go to     acc-cod-dpm-110.
       acc-cod-dpm-120.
           move      w-cod-cod-aaq-alf    to   v-alf                  .
           move      w-cod-cod-aaq-num    to   v-num                  .
       acc-cod-dpm-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dpm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dpm]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dpm-cod      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dpm-flg    not  = spaces
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-dpm-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-dpm-100.
       acc-cod-dpm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dpm]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione ad uso in-   *
      *                      * terno                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Tipo prodotto : forzato a Merce             *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si/No aggiornamento di magazzino            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-rig-snx-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-dpm-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-dpm-620.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dpm-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-dpm-640.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-dpm-640.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dpm-660.
           move      w-let-arc-aaq-civ    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-dpm-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-dpm-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-dpm-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dpm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dpm-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dpm-100.
       acc-cod-dpm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [mtv]     *
      *    *-----------------------------------------------------------*
       acc-cod-mtv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-mtv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaq-ope      .
           move      "A"                  to   w-cod-cod-aaq-tac      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaq-tco      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaq-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaq-alf      .
           move      15                   to   w-cod-cod-aaq-lin      .
           move      21                   to   w-cod-cod-aaq-pos      .
           move      16                   to   w-cod-cod-aaq-dln      .
           move      21                   to   w-cod-cod-aaq-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
       acc-cod-mtv-110.
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           if        w-cod-cod-aaq-ope    =    "F+"
                     go to acc-cod-mtv-115.
           if        w-cod-cod-aaq-ope    =    "AC"
                     go to acc-cod-mtv-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-mtv-115.
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
           go to     acc-cod-mtv-110.
       acc-cod-mtv-120.
           move      w-cod-cod-aaq-alf    to   v-alf                  .
           move      w-cod-cod-aaq-num    to   v-num                  .
       acc-cod-mtv-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-mtv-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-mtv-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-mtv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [mtv]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-mtv-cod      .
           perform   let-arc-mtv-000      thru let-arc-mtv-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-mtv-flg    not  = spaces
                     go to acc-cod-mtv-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-mtv-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-mtv-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-mtv-100.
       acc-cod-mtv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [mtv]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-mtv-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione ad uso in-   *
      *                      * terno                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-mtv-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Tipo prodotto : forzato a Merce             *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si/No aggiornamento di magazzino            *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-snm    to   w-rig-snx-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-mtv-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-mtv-620.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-mtv-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-mtv-640.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-mtv-640.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-mtv-660.
           move      w-let-arc-aaq-civ    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-mtv-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-mtv-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-mtv-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-mtv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-mtv-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-mtv-100.
       acc-cod-mtv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Unita' di misura                  *
      *    *-----------------------------------------------------------*
       vis-umi-acq-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      15                   to   v-pos                  .
           if        w-rig-snx-tum (1)    not  = "S"
                     move  w-rig-umi-acq (1)
                                          to   v-alf
           else      move  w-rig-umf-tum (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-umi-acq-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di acquisizione   *
      *    *-----------------------------------------------------------*
       acc-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-fda        =    "N"
                     go to acc-fda-pif-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo archivio diverso da 'F' : usci- *
      *                      * ta                                      *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to acc-fda-pif-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-fda-pif-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo funzionamento              *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-fda-pif-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-fda-pif (1)    to   w-sav-fda-pif          .
       acc-fda-pif-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaf-ope      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaf-nrm      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaf-afm      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-aaf-dcf      .
           move      w-rig-fda-pif (1)    to   w-cod-cod-aaf-fda      .
           move      15                   to   w-cod-cod-aaf-lin      .
           move      47                   to   w-cod-cod-aaf-pos      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-aaf-cll-000  thru cod-cod-aaf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaf-foi-000  thru cod-cod-aaf-foi-999    .
       acc-fda-pif-110.
           perform   cod-cod-aaf-cll-000  thru cod-cod-aaf-cll-999    .
           if        w-cod-cod-aaf-ope    =    "F+"
                     go to acc-fda-pif-115.
           if        w-cod-cod-aaf-ope    =    "AC"
                     go to acc-fda-pif-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fda-pif-115.
           perform   cod-cod-aaf-foi-000  thru cod-cod-aaf-foi-999    .
           go to     acc-fda-pif-110.
       acc-fda-pif-120.
           move      w-cod-cod-aaf-fda    to   v-alf                  .
       acc-fda-pif-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-fda-pif (1)      .
       acc-fda-pif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaf]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-flg    =    spaces
                     go to acc-fda-pif-600.
           if        w-rig-fda-pif (1)    =    spaces
                     go to acc-fda-pif-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Formato di acquisizione non esistente !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-fda-pif-100.
       acc-fda-pif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-fda-pif (1)    =    w-sav-fda-pif
                     go to acc-fda-pif-800.
      *                  *---------------------------------------------*
      *                  * Richiamo subroutine                         *
      *                  *---------------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-fda-pif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-fda-pif-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-fda-pif-100.
       acc-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di acquisizione   *
      *    *                                                           *
      *    * Subroutine per dipendenze dall'impostazione               *
      *    *-----------------------------------------------------------*
       acc-fda-pif-ddi-000.
       acc-fda-pif-ddi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione si/no esistenza di un forma- *
      *                  * to di acquisizione                          *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-flg    =    spaces
                     move  "S"            to   w-rig-snx-fda (1)
           else      move  "N"            to   w-rig-snx-fda (1)      .
           if        w-let-arc-aaf-des    =    spaces
                     move  "N"            to   w-rig-snx-dep (1)
           else      move  "S"            to   w-rig-snx-dep (1)      .
      *                  *---------------------------------------------*
      *                  * Valori da bufferizzare se formato di acqui- *
      *                  * sizione esistente                           *
      *                  *---------------------------------------------*
           if        w-rig-snx-fda (1)    =    "N"
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Codice prodotto secondo il fornitore        *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-csf    to   w-rig-cop-sfn (1)      .
           perform   vis-cop-sfn-000      thru vis-cop-sfn-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto secondo il fornitore   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se diversa da spaces               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-des    =    spaces
                     go to acc-fda-pif-ddi-605.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-des    to   w-rig-des-por (1)      .
           move      w-let-arc-aaf-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-fda-pif-ddi-605.
      *                  *---------------------------------------------*
      *                  * Parametri associati all'unita' di misura    *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-snu    to   w-rig-snx-tum (1)      .
           move      w-let-arc-aaf-umf    to   w-rig-umf-tum (1)      .
           move      w-let-arc-aaf-ndu    to   w-rig-nde-tum (1)      .
           move      w-let-arc-aaf-cmu    to   w-rig-cmo-tum (1)      .
           move      w-let-arc-aaf-cdu    to   w-rig-cdi-tum (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione unita' di misura            *
      *                  *---------------------------------------------*
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione prompt prezzo di acquisto *
      *                  *---------------------------------------------*
           perform   pmt-prz-acq-000      thru pmt-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni                                   *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaf-dcv    not  = w-tes-dec-vpf (1)
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo d'acquisto           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-ndp    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione work-area                  *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-tpa    to   w-det-prz-acq-tpa      .
           move      w-let-arc-aaf-tap    to   w-det-prz-acq-tap      .
           move      zero                 to   w-acc-fda-pif-c01      .
       acc-fda-pif-ddi-610.
           add       1                    to   w-acc-fda-pif-c01      .
           if        w-acc-fda-pif-c01    >    6
                     go to acc-fda-pif-ddi-620.
           move      w-let-arc-aaf-qtp
                    (w-acc-fda-pif-c01)   to   w-det-prz-acq-qtp
                                              (w-acc-fda-pif-c01)     .
           move      w-let-arc-aaf-pzp
                    (w-acc-fda-pif-c01)   to   w-det-prz-acq-pzp
                                              (w-acc-fda-pif-c01)     .
           move      w-let-arc-aaf-csp
                    (w-acc-fda-pif-c01)   to   w-det-prz-acq-csp
                                              (w-acc-fda-pif-c01)     .
           move      zero                 to   w-acc-fda-pif-c02      .
       acc-fda-pif-ddi-612.
           add       1                    to   w-acc-fda-pif-c02      .
           if        w-acc-fda-pif-c02    >    5
                     go to acc-fda-pif-ddi-614.
           move      w-let-arc-aaf-psp
                    (w-acc-fda-pif-c01,
                     w-acc-fda-pif-c02)
                                          to   w-det-prz-acq-psp
                                              (w-acc-fda-pif-c01
                                               w-acc-fda-pif-c02)     .
           go to     acc-fda-pif-ddi-612.
       acc-fda-pif-ddi-614.
           go to     acc-fda-pif-ddi-610.
       acc-fda-pif-ddi-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-prz-qta-pre      .
           move      zero                 to   w-det-prz-qta-att      .
           perform   det-prz-acq-000      thru det-prz-acq-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Parametri associati al legame valutario     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-fda-pif-ddi-680.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-fda-pif-ddi-680.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione e visualizzazione       *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-lvv    to   w-rig-sgl-vpl (1)      .
           move      w-let-arc-aaf-lvd    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-aaf-lvt    to   w-rig-tdc-vpl (1)      .
           move      w-let-arc-aaf-lvc    to   w-rig-ccr-vpl (1)      .
           move      w-let-arc-aaf-lvp    to   w-rig-plm-vpl (1)      .
           move      "F"                  to   w-rig-tlm-vpl (1)      .
           perform   vis-sgl-vpl-000      thru vis-sgl-vpl-999        .
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
       acc-fda-pif-ddi-680.
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-fda-pif-ddi-800.
       acc-fda-pif-ddi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Formato di acquisizione           *
      *    *-----------------------------------------------------------*
       vis-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to vis-fda-pif-999.
           if        w-prs-snx-fda        =    "N"
                     go to vis-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-rig-fda-pif (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto secondo fornitore *
      *    *-----------------------------------------------------------*
       vis-cop-sfn-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to vis-cop-sfn-999.
           if        w-rig-cop-sfn (1)    =    spaces
                     go to vis-cop-sfn-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "[F]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-rig-cop-sfn (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cop-sfn-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Descrizione in riga       *
      *    *-----------------------------------------------------------*
       acc-des-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-des-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-des-rig (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-rig-des-rig (1)      .
       acc-des-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spazi ammesso solo per tipi riga   *
      *                  * 'C', a meno che non si sia in Up            *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = spaces
                     go to acc-des-rig-600.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-des-rig-600.
           if        v-key                =    "UP  "
                     go to acc-des-rig-600
           else      go to acc-des-rig-100.
       acc-des-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-des-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-des-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-des-rig-100.
       acc-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione in riga               *
      *    *-----------------------------------------------------------*
       vis-des-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-des-rig (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' primaria        *
      *    *-----------------------------------------------------------*
       acc-qta-pri-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-pri-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   w-sav-qta-psx
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx          .
       acc-qta-pri-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   v-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   v-num
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-fda (1)
                                          to   v-num                  .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-pri-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-pri-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  v-num          to   w-rig-qta-acq (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  v-num          to   w-rig-qta-fda (1)
           else      move  v-num          to   w-rig-qta-fda (1)      .
      *              *-------------------------------------------------*
      *              * Valore impostato in comodo per confronti        *
      *              *-------------------------------------------------*
           move      v-num                to   w-sav-qta-cfr          .
       acc-qta-pri-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-pri-425.
      *                  *---------------------------------------------*
      *                  * Quantita' a zero non ammessa, a meno che    *
      *                  * non si sia in Up                            *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        not  = zero
                     go to acc-qta-pri-450.
           if        v-key                not  = "UP  "
                     go to acc-qta-pri-100.
       acc-qta-pri-450.
      *                  *---------------------------------------------*
      *                  * Fine controlli                              *
      *                  *---------------------------------------------*
           go to     acc-qta-pri-600.
       acc-qta-pri-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento quantita' secondaria            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore inalterato rispetto al valore *
      *                      * precedente : nessuna azione             *
      *                      *-----------------------------------------*
           if        w-sav-qta-cfr        =    w-sav-qta-psx
                     go to acc-qta-pri-605.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' secondaria     *
      *                      *-----------------------------------------*
           move      w-sav-qta-cfr        to   w-det-qta-sec-qim      .
           move      w-rig-dec-qta (1)    to   w-det-qta-sec-dgm      .
           move      w-rig-snx-tum (1)    to   w-det-qta-sec-snu      .
           move      w-rig-umf-tum (1)    to   w-det-qta-sec-umf      .
           move      w-rig-nde-tum (1)    to   w-det-qta-sec-ndu      .
           move      w-rig-cmo-tum (1)    to   w-det-qta-sec-cmu      .
           move      w-rig-cdi-tum (1)    to   w-det-qta-sec-cdu      .
           perform   det-qta-sec-000      thru det-qta-sec-999        .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-det-qta-sec-qts
                                          to   w-rig-qta-fda (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-det-qta-sec-qts
                                          to   w-rig-qta-acq (1)
           else      move  w-det-qta-sec-qts
                                          to   w-rig-qta-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione quantita' secondaria    *
      *                      *-----------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
       acc-qta-pri-605.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni, tranne che quella dell'importo   *
      *                  * in riga                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1)
                     go to acc-qta-pri-700.
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione work-area                  *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-tpa    to   w-det-prz-acq-tpa      .
           move      w-let-arc-aaf-tap    to   w-det-prz-acq-tap      .
           move      zero                 to   w-acc-qta-psx-c01      .
       acc-qta-pri-610.
           add       1                    to   w-acc-qta-psx-c01      .
           if        w-acc-qta-psx-c01    >    6
                     go to acc-qta-pri-620.
           move      w-let-arc-aaf-qtp
                    (w-acc-qta-psx-c01)   to   w-det-prz-acq-qtp
                                              (w-acc-qta-psx-c01)     .
           move      w-let-arc-aaf-pzp
                    (w-acc-qta-psx-c01)   to   w-det-prz-acq-pzp
                                              (w-acc-qta-psx-c01)     .
           move      w-let-arc-aaf-csp
                    (w-acc-qta-psx-c01)   to   w-det-prz-acq-csp
                                              (w-acc-qta-psx-c01)     .
           move      zero                 to   w-acc-qta-psx-c02      .
       acc-qta-pri-612.
           add       1                    to   w-acc-qta-psx-c02      .
           if        w-acc-qta-psx-c02    >    5
                     go to acc-qta-pri-614.
           move      w-let-arc-aaf-psp
                    (w-acc-qta-psx-c01,
                     w-acc-qta-psx-c02)
                                          to   w-det-prz-acq-psp
                                              (w-acc-qta-psx-c01
                                               w-acc-qta-psx-c02)     .
           go to     acc-qta-pri-612.
       acc-qta-pri-614.
           go to     acc-qta-pri-610.
       acc-qta-pri-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-sav-qta-psx        to   w-det-prz-qta-pre      .
           move      w-sav-qta-cfr        to   w-det-prz-qta-att      .
           perform   det-prz-acq-000      thru det-prz-acq-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-qta-pri-640.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-qta-pri-700.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore attuale come precedente e im- *
      *                      * porto in riga diverso da zero : oltre   *
      *                      *-----------------------------------------*
           if        w-sav-qta-cfr        =    w-sav-qta-psx and
                     w-rig-imp-rig (1)    not  = zero
                     go to acc-qta-pri-800.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-pri-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-pri-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-pri-100.
       acc-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' primaria                *
      *    *-----------------------------------------------------------*
       vis-qta-pri-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   v-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   v-num
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-fda (1)
                                          to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' secondaria      *
      *    *-----------------------------------------------------------*
       acc-qta-sec-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-qta-sec-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to acc-qta-sec-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-sec-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"  and
                     w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-qta-sec-999.
      *                      *-----------------------------------------*
      *                      * Test su trasformazione unita' di misura *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    not  = "S" and
                     w-rig-snx-tum (1)    not  = "P"
                     go to acc-qta-sec-999.
       acc-qta-sec-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-acq (1)
                                          to   w-sav-qta-psx          .
       acc-qta-sec-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-umf-tum (1)
                                          to   w-sav-umi-sec
           else      move  w-rig-umi-acq (1)
                                          to   w-sav-umi-sec          .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "("
                                delimited by   size
                     w-sav-umi-sec
                                delimited by   size
                     "             )"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-acq (1)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-sec-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-sec-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  v-num          to   w-rig-qta-fda (1)
           else      move  v-num          to   w-rig-qta-acq (1)      .
      *              *-------------------------------------------------*
      *              * Valore impostato in comodo per confronti        *
      *              *-------------------------------------------------*
           move      v-num                to   w-sav-qta-cfr          .
      *              *-------------------------------------------------*
      *              * Visualizzazione quantita' secondaria            *
      *              *-------------------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
       acc-qta-sec-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-sec-425.
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        not  = zero
                     go to acc-qta-sec-450.
           if        v-key                not  = "UP  "
                     go to acc-qta-sec-100.
       acc-qta-sec-450.
      *                  *---------------------------------------------*
      *                  * Fine controlli                              *
      *                  *---------------------------------------------*
           go to     acc-qta-sec-600.
       acc-qta-sec-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-sec-625.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente e importo *
      *                  * in riga diverso da zero : oltre             *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     if    w-rig-qta-fda (1)
                                          =    w-sav-qta-psx and
                           w-rig-imp-rig (1)
                                          not  = zero
                           go to acc-qta-sec-800
                     else  go to acc-qta-sec-630
           else      if    w-rig-qta-acq (1)
                                          =    w-sav-qta-psx and
                           w-rig-imp-rig (1)
                                          not  = zero
                           go to acc-qta-sec-800
                     else  go to acc-qta-sec-630.
       acc-qta-sec-630.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-sec-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-sec-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-sec-100.
       acc-qta-sec-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' secondaria              *
      *    *-----------------------------------------------------------*
       vis-qta-sec-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    not  = "S" and
                     w-rig-snx-tum (1)    not  = "P"
                     go to vis-qta-sec-999.
       vis-qta-sec-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
       vis-qta-sec-200.
      *                  *---------------------------------------------*
      *                  * Preparazione valore numerico da editare     *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-cfr
           else      move  w-rig-qta-acq (1)
                                          to   w-sav-qta-cfr          .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore da editare  *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        =    zero
                     go to vis-qta-sec-300
           else      go to vis-qta-sec-400.
       vis-qta-sec-300.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione a spaces                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-sec-999.
       vis-qta-sec-400.
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      w-sav-qta-cfr        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione unita' di misura           *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-umf-tum (1)
                                          to   w-sav-umi-sec
           else      move  w-rig-umi-acq (1)
                                          to   w-sav-umi-sec          .
      *                      *-----------------------------------------*
      *                      * Composizione area editata completa      *
      *                      *-----------------------------------------*
           move      spaces               to   v-alf                  .
           string    "("
                                delimited by   size
                     w-sav-umi-sec
                                delimited by   size
                     " "
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into v-alf                  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      37                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-sec-999.
       vis-qta-sec-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo di acquisto        *
      *    *-----------------------------------------------------------*
       acc-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-acq-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo di acquisto                      *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-sav-prz-acq          .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto in riga           *
      *                      *-----------------------------------------*
           move      w-rig-per-scr (1, 1) to   w-sav-per-scr (1)      .
           move      w-rig-per-scr (1, 2) to   w-sav-per-scr (2)      .
           move      w-rig-per-scr (1, 3) to   w-sav-per-scr (3)      .
           move      w-rig-per-scr (1, 4) to   w-sav-per-scr (4)      .
           move      w-rig-per-scr (1, 5) to   w-sav-per-scr (5)      .
       acc-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-prz-acq (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-acq (1)      .
       acc-prz-acq-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-prz-acq-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-prz-acq-610.
      *                      *-----------------------------------------*
      *                      * Se percentuali di sconto gia' tutte a   *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-acq-610.
      *                      *-----------------------------------------*
      *                      * Trattamento percentuali di sconto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-prz-acq-610.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-acq-620.
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio per legame valutario *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-cdc-vpl-000      thru det-cdc-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
       acc-prz-acq-640.
      *                  *---------------------------------------------*
      *                  * Se valori attuali come precedenti e importo *
      *                  * in riga diverso da zero : oltre             *
      *                  *---------------------------------------------*
           if        w-rig-prz-acq (1)    =    w-sav-prz-acq     and
                     w-rig-per-scr (1, 1) =    w-sav-per-scr (1) and
                     w-rig-per-scr (1, 2) =    w-sav-per-scr (2) and
                     w-rig-per-scr (1, 3) =    w-sav-per-scr (3) and
                     w-rig-per-scr (1, 4) =    w-sav-per-scr (4) and
                     w-rig-per-scr (1, 5) =    w-sav-per-scr (5) and
                     w-rig-imp-rig (1)    not  = zero
                     go to acc-prz-acq-800.
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-acq-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-acq-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-acq-100.
       acc-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Prezzo di acquisto                *
      *    *-----------------------------------------------------------*
       vis-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      w-rig-prz-acq (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      v-edt                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Sigla lotto                          *
      *    *-----------------------------------------------------------*
       acc-lot-sgl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to acc-lot-sgl-999.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M"
                     go to acc-lot-sgl-999.
       acc-lot-sgl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-lot-sgl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-lot-sgl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-lot-sgl-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-lot-sgl (1)      .
       acc-lot-sgl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-lot-sgl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-lot-sgl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-lot-sgl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-lot-sgl-100.
       acc-lot-sgl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla lotto                       *
      *    *-----------------------------------------------------------*
       vis-lot-sgl-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to vis-lot-sgl-999.
       vis-lot-sgl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-rig-lot-sgl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-lot-sgl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data lotto                           *
      *    *-----------------------------------------------------------*
       acc-lot-dat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to acc-lot-dat-999.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M"
                     go to acc-lot-dat-999.
       acc-lot-dat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      18                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-lot-dat (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-lot-dat-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-lot-dat-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-lot-dat (1)      .
       acc-lot-dat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-lot-dat-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-lot-dat-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-lot-dat-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-lot-dat-100.
       acc-lot-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data lotto (sigla variante)       *
      *    *-----------------------------------------------------------*
       vis-lot-dat-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to vis-lot-dat-999.
       vis-lot-dat-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-rig-lot-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-lot-dat-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per legame   *
      *    * valutario                                                 *
      *    *-----------------------------------------------------------*
       acc-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa al   *
      *                      * legame valutario                        *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-sgl-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Se riga 'New' : no  accettazione        *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Se valore attuale a spaces : no  accet- *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-sgl-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-sav-sgl-vpl          .
       acc-sgl-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpl (1)    to   w-cod-cod-zvl-cod      .
           move      18                   to   w-cod-cod-zvl-lin      .
           move      42                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpl-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpl-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpl-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpl-110.
       acc-sgl-vpl-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
       acc-sgl-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpl (1)      .
       acc-sgl-vpl-400.
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpl-100.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per fatturazione                            *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-tes-sgl-vpf (1)
                     go to acc-sgl-vpl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per fatturazione del documento 
      -              "!              "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-500.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta per legame valutario uguale *
      *                  * a sigla vauta base : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    c-sgl
                     go to acc-sgl-vpl-100.
       acc-sgl-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    w-sav-sgl-vpl
                     go to acc-sgl-vpl-800.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che il valore sia esi- *
      *                  * stente o no                                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-sgl-vpl-620
           else      go to acc-sgl-vpl-640.
       acc-sgl-vpl-620.
      *                  *---------------------------------------------*
      *                  * Se valore non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori connessi         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-dec-vpl (1)      .
           move      spaces               to   w-rig-tdc-vpl (1)      .
           move      zero                 to   w-rig-prz-vpl (1)      .
           move      zero                 to   w-rig-cdc-vpl (1)      .
           move      zero                 to   w-rig-ccr-vpl (1)      .
           move      zero                 to   w-rig-plm-vpl (1)      .
           move      spaces               to   w-rig-tlm-vpl (1)      .
           move      spaces               to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori connessi         *
      *                      *-----------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-800.
       acc-sgl-vpl-640.
      *                  *---------------------------------------------*
      *                  * Se valore esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori connessi         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Coefficiente di cambio di riferi-   *
      *                          * mento                               *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-ccr-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio effettivo                       *
      *                          *-------------------------------------*
           perform   det-cdc-vpl-000      thru det-cdc-vpl-999        .
      *                          *-------------------------------------*
      *                          * Tipo di limitazione                 *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-tlm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Momento di applicazione cambio      *
      *                          *-------------------------------------*
           move      "F"                  to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori connessi         *
      *                      *-----------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-800.
       acc-sgl-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpl-100.
       acc-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Sigla valuta per *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       vis-sgl-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      w-rig-sgl-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Coefficiente di cambio    *
      *    * di riferimento per legame valutario                       *
      *    *-----------------------------------------------------------*
       acc-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-ccr-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-ccr-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-ccr-vpl (1)    to   w-sav-ccr-vpl          .
       acc-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           if        w-tes-dat-doc (1)    not  = zero
                     move  w-tes-dat-doc (1)
                                          to   w-coe-cmb-vlt-drc
           else      move  w-tes-dat-reg  to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           move      "N"                  to   w-coe-cmb-vlt-snd      .
           move      w-rig-ccr-vpl (1)    to   w-coe-cmb-vlt-cdc      .
           move      18                   to   w-coe-cmb-vlt-lin      .
           move      46                   to   w-coe-cmb-vlt-pos      .
           move      zero                 to   w-coe-cmb-vlt-dln      .
           move      zero                 to   w-coe-cmb-vlt-dps      .
           move      "BD"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-ccr-vpl-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-ccr-vpl-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-ccr-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ccr-vpl-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-ccr-vpl-110.
       acc-ccr-vpl-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-ccr-vpl-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
       acc-ccr-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ccr-vpl (1)      .
       acc-ccr-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore zero non ammesso a meno che non si   *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    not  = zero
                     go to acc-ccr-vpl-600.
           if        v-key                =    "UP  "
                     go to acc-ccr-vpl-600
           else      go to acc-ccr-vpl-100.
       acc-ccr-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    =    w-sav-ccr-vpl
                     go to acc-ccr-vpl-800.
      *                  *---------------------------------------------*
      *                  * Determinazione coefficiente di cambio ef-   *
      *                  * fettivo per legame valutario                *
      *                  *---------------------------------------------*
           perform   det-cdc-vpl-000      thru det-cdc-vpl-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione coefficiente di cambio ef-  *
      *                  * fettivo per legame valutario                *
      *                  *---------------------------------------------*
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
       acc-ccr-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ccr-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ccr-vpl-100.
       acc-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Coefficiente di  *
      *    * cambio di riferimento per legame valutario                *
      *    *-----------------------------------------------------------*
       vis-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      w-rig-ccr-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Coefficiente di  *
      *    * cambio effettivo per legame valutario                     *
      *    *-----------------------------------------------------------*
       vis-cdc-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-cdc-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-rig-cdc-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cdc-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuale di limitazio- *
      *    * ne per legame valutario                                   *
      *    *-----------------------------------------------------------*
       acc-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-plm-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-plm-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-plm-vpl (1)    to   w-sav-plm-vpl          .
       acc-plm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
       acc-plm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-plm-vpl (1)      .
       acc-plm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-plm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    =    w-sav-plm-vpl
                     go to acc-plm-vpl-800.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    not  = zero
                     go to acc-plm-vpl-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione tipo di limitazione per le- *
      *                  * game valutario                              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     move  spaces         to   w-rig-tlm-vpl (1)
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione coefficiente di cambio ef-   *
      *                  * fettivo per legame valutario                *
      *                  *---------------------------------------------*
           perform   det-cdc-vpl-000      thru det-cdc-vpl-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione coefficiente di cambio ef-  *
      *                  * fettivo per legame valutario                *
      *                  *---------------------------------------------*
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
       acc-plm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-plm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-plm-vpl-100.
       acc-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Percentuale di   *
      *    * limitazione per legame valutario                          *
      *    *-----------------------------------------------------------*
       vis-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Tipo di limitazione per   *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       acc-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-tlm-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame         *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su percentuale di limitazione per  *
      *                      * legame                                  *
      *                      *-----------------------------------------*
           if        w-rig-plm-vpl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-sav-tlm-vpl          .
       acc-tlm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
       acc-tlm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tlm-vpl-400.
      *                  *---------------------------------------------*
      *                  * Find per note operative                     *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-fnd-tlm-vpl-tlm      .
           perform   fnd-tlm-vpl-000      thru fnd-tlm-vpl-999        .
           move      w-fnd-tlm-vpl-tlm    to   w-rig-tlm-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tlm-vpl-100.
       acc-tlm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     go to acc-tlm-vpl-500.
           if        v-key                =    "UP  "
                     go to acc-tlm-vpl-600
           else      go to acc-tlm-vpl-100.
       acc-tlm-vpl-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = "T" and
                     w-rig-tlm-vpl (1)    not  = "F" and
                     w-rig-tlm-vpl (1)    not  = "M"
                     go to acc-tlm-vpl-100.
       acc-tlm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    =    w-sav-tlm-vpl
                     go to acc-tlm-vpl-800.
      *                  *---------------------------------------------*
      *                  * Determinazione coefficiente di cambio ef-   *
      *                  * fettivo per legame valutario                *
      *                  *---------------------------------------------*
           perform   det-cdc-vpl-000      thru det-cdc-vpl-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione coefficiente di cambio ef-  *
      *                  * fettivo per legame valutario                *
      *                  *---------------------------------------------*
           perform   vis-cdc-vpl-000      thru vis-cdc-vpl-999        .
       acc-tlm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tlm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-tlm-vpl-100.
       acc-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Tipo di limita-  *
      *    * zione per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuali sconto in riga*
      *    *-----------------------------------------------------------*
       acc-per-scr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-per-scr-ctr      .
       acc-per-scr-100.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   w-sav-per-scr
                                              (w-acc-per-scr-ctr)     .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           if        w-acc-per-scr-ctr    >    5
                     subtract  5          from v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
       acc-per-scr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-per-scr
                                              (1, w-acc-per-scr-ctr)  .
       acc-per-scr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente e importo *
      *                  * in riga diverso da zero : oltre             *
      *                  *---------------------------------------------*
           if        w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          =    w-sav-per-scr
                                              (w-acc-per-scr-ctr) and
                     w-rig-imp-rig (1)    not  = zero
                     go to acc-per-scr-610.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-per-scr-605.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-per-scr-610.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione dell'impostazione        *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-scr-650
           else if   v-key                =    "DOWN"
                     go to acc-per-scr-700
           else if   v-key                =    "TAB "
                     go to acc-per-scr-710
           else if   v-key                =    "DO  "
                     go to acc-per-scr-800
           else      go to acc-per-scr-700.
       acc-per-scr-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr    =    1
                     go to acc-per-scr-999.
           subtract  1                    from w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-700.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-710.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr        =    05
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-per-scr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-per-scr-100.
       acc-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di sconto in riga     *
      *    *-----------------------------------------------------------*
       vis-per-scr-000.
           move      zero                 to   w-acc-per-scr-ctr      .
       vis-per-scr-200.
           add       1                    to   w-acc-per-scr-ctr      .
           if        w-acc-per-scr-ctr    >    5
                     go to vis-per-scr-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      w-rig-per-scr 
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-per-scr-200.
       vis-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Importo in riga           *
      *    *-----------------------------------------------------------*
       acc-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-imp-rig-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-imp-rig (1)    to   w-sav-imp-rig          .
       acc-imp-rig-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "[F1] per confermare un eventuale importo diverso d
      -              "a quello calcolato" to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-imp-rig (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione eventuali note operative          *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-rig (1)      .
       acc-imp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione a meno    *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    not  = zero
                     go to acc-imp-rig-500.
           if        v-key                =    "UP  "
                     go to acc-imp-rig-600
           else      go to acc-imp-rig-100.
       acc-imp-rig-500.
      *                  *---------------------------------------------*
      *                  * Test su segno valore impostato              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-imp-rig-600.
      *                      *-----------------------------------------*
      *                      * Controllo che il segno del valore impo- *
      *                      * stato sia pari al segno del valore sal- *
      *                      * vato                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se valore salvato a zero : oltre    *
      *                          *-------------------------------------*
           if        w-sav-imp-rig        =    zero
                     go to acc-imp-rig-600.
      *                          *-------------------------------------*
      *                          * Controllo                           *
      *                          *-------------------------------------*
           if       (w-rig-imp-rig (1)    >    zero and
                     w-sav-imp-rig        >    zero   ) or
                    (w-rig-imp-rig (1)    <    zero and
                     w-sav-imp-rig        <    zero   )
                     go to acc-imp-rig-600
           else      go to acc-imp-rig-100.
       acc-imp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    =    w-sav-imp-rig
                     go to acc-imp-rig-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo sconto in riga                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se PF1                             *
      *                      *-----------------------------------------*
           if        v-key                =    "[1] "
                     go to acc-imp-rig-800.
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"  or
                     w-rig-qta-fda (1)    =    zero or
                     w-rig-prz-acq (1)    =    zero or
                     w-rig-imp-rig (1)    =    zero
                     go to acc-imp-rig-800.
      *                      *-----------------------------------------*
      *                      * Ricalcolo secondo la seguente formula : *
      *                      *                                         *
      *                      *                    I                    *
      *                      *        S = 100 - ----- x 100            *
      *                      *                  Q x P                  *
      *                      *                                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione (quantita' x prezzo) *
      *                          *-------------------------------------*
           multiply  w-rig-qta-fda (1)    by   w-rig-prz-acq (1)
                                        giving w-acc-imp-rig-qxp      .
           if        w-rig-dec-prz (1)    =    1
                     divide  10           into w-acc-imp-rig-qxp
           else if   w-rig-dec-prz (1)    =    2
                     divide  100          into w-acc-imp-rig-qxp      .
      *                          *-------------------------------------*
      *                          * Se valore inferiore a importo in    *
      *                          * riga : ripristino valore preceden-  *
      *                          * temente salvato e reimpostazione    *
      *                          *-------------------------------------*
           if        w-rig-imp-rig (1)    >    w-acc-imp-rig-qxp
                     move  w-sav-imp-rig  to   w-rig-imp-rig (1) 
                     go to acc-imp-rig-100.
      *                          *-------------------------------------*
      *                          * Se valore pari all'importo in riga  *
      *                          * percentuale di sconto a zero e ol-  *
      *                          * tre                                 *
      *                          *-------------------------------------*
           if        w-rig-imp-rig (1)    =    w-acc-imp-rig-qxp
                     move  zero           to   w-acc-imp-rig-psc
                     go to acc-imp-rig-620.
      *                          *-------------------------------------*
      *                          * Altrimenti, continuazione calcolo   *
      *                          *-------------------------------------*
           multiply  100                  by   w-rig-imp-rig (1)
                                        giving w-acc-imp-rig-s13      .
           divide    w-acc-imp-rig-qxp    into w-acc-imp-rig-s13
                                        giving w-acc-imp-rig-2v1
                                               rounded                .
           move      100                  to   w-acc-imp-rig-psc      .
           subtract  w-acc-imp-rig-2v1    from w-acc-imp-rig-psc      .
       acc-imp-rig-620.
      *                          *-------------------------------------*
      *                          * Bufferizzazione nuove % di sconto   *
      *                          *-------------------------------------*
           move      w-acc-imp-rig-psc    to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                          *-------------------------------------*
      *                          * Visualizzazione nuove % di sconto   *
      *                          *-------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-imp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-rig-100.
       acc-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo in riga                   *
      *    *-----------------------------------------------------------*
       vis-imp-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice iva                *
      *    *-----------------------------------------------------------*
       acc-civ-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-civ-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-civ-rig-100.
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-civ-rig-999.
       acc-civ-rig-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-rig-civ-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      20                   to   w-cod-mne-zci-lin      .
           move      21                   to   w-cod-mne-zci-pos      .
           move      20                   to   w-cod-mne-zci-dln      .
           move      32                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-civ-rig-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-civ-rig-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-civ-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-civ-rig-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-civ-rig-110.
       acc-civ-rig-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-civ-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-civ-rig-999.
       acc-civ-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-civ-rig (1)      .
       acc-civ-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-rig-civ-rig (1)    to   d-imp-iva-cod-iva      .
      *
           move      w-tes-cod-tmf-ccg    to   w-let-arc-zcc-cod      .
           perform   let-arc-zcc-000      thru let-arc-zcc-999        .
      *
           move      w-let-arc-zcc-tmi    to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                      *-----------------------------------------*
      *                      * Se errato : messaggio di errore         *
      *                      *-----------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     move  d-imp-iva-msg-exi
                                          to   w-rig-civ-rig-des (1)
                     go to acc-civ-rig-500.
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-civ-rig-100.
       acc-civ-rig-500.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero : reimpostazione a meno*
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-rig-civ-rig (1)    not  = zero
                     go to acc-civ-rig-600.
           if        v-key                =    "UP  "
                     go to acc-civ-rig-600
           else      go to acc-civ-rig-100.
       acc-civ-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-civ-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-civ-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-civ-rig-100.
       acc-civ-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice iva                *
      *    *-----------------------------------------------------------*
       vis-civ-rig-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-rig-civ-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione codice IVA    *
      *    *-----------------------------------------------------------*
       vis-civ-rig-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-civ-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice contropartita      *
      *    *-----------------------------------------------------------*
       acc-ctp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ctp-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ctp-rig-100.
       acc-ctp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rig-ctp-rig (1)    to   w-cod-mne-pdc-cod      .
           move      21                   to   w-cod-mne-pdc-lin      .
           move      21                   to   w-cod-mne-pdc-pos      .
           move      21                   to   w-cod-mne-pdc-dln      .
           move      32                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-rig-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-rig-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-rig-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-rig-110.
       acc-ctp-rig-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ctp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ctp-rig-999.
       acc-ctp-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ctp-rig (1)      .
       acc-ctp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-rig-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-ctp-rig (1)    =    zero
                     go to acc-ctp-rig-100.
      *                  *---------------------------------------------*
      *                  * Se impostata contropartita in testata       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-ctp-acq (1)    =    zero
                     go to acc-ctp-rig-600.
      *                      *-----------------------------------------*
      *                      * Confronto con contropartita impostata   *
      *                      *-----------------------------------------*
           if        w-rig-ctp-rig (1)    =    w-tes-ctp-acq (1)
                     go to acc-ctp-rig-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Attenzione: contropartita diversa da quella impost
      -              "ata per il doc."    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-ctp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ctp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ctp-rig-100.
       acc-ctp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita acquisti in *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       vis-ctp-rig-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rig-ctp-rig (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione contropartita *
      *    * acquisti in riga                                          *
      *    *-----------------------------------------------------------*
       vis-ctp-rig-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-ctp-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Presa visione per riga espansa       *
      *    *-----------------------------------------------------------*
       acc-pre-vre-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-pre-vre-050.
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      77                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-pre-vre-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      21                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "SLCT"               to   v-pfk (11)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-pre-vre-200.
      *              *-------------------------------------------------*
      *              * Pulizia prompt                                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      77                   to   v-pos                  .
           move      "   "                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-pre-vre-300.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-pre-vre-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-pre-vre-999.
       acc-pre-vre-400.
      *              *-------------------------------------------------*
      *              * Se Select                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-pre-vre-800.
      *                  *---------------------------------------------*
      *                  * Subroutine di espansione                    *
      *                  *---------------------------------------------*
           perform   esp-rig-cor-000      thru esp-rig-cor-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-pre-vre-050.
       acc-pre-vre-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-pre-vre-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-pre-vre-100.
       acc-pre-vre-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do riga corpo             *
      *    *-----------------------------------------------------------*
       cnt-tdo-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-100.
      *              *-------------------------------------------------*
      *              * Richiamo routine di controllo impostazioni su   *
      *              * riga corpo                                      *
      *              *-------------------------------------------------*
           perform   ctl-imp-rig-000      thru ctl-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di errori ri-   *
      *              * scontrati                                       *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-ele    =    zero
                     go to cnt-tdo-rig-120
           else      go to cnt-tdo-rig-140.
       cnt-tdo-rig-120.
      *              *-------------------------------------------------*
      *              * Se zero errori riscontrati                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * A normalizzazioni                           *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-200.
       cnt-tdo-rig-140.
      *              *-------------------------------------------------*
      *              * Se riscontrati errori                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer                   *
      *                  *---------------------------------------------*
           move      zero                 to    w-ctl-imp-rig-ctr     .
       cnt-tdo-rig-142.
           add       1                    to    w-ctl-imp-rig-ctr     .
      *                      *-----------------------------------------*
      *                      * Se fine scansione e non sono stati tro- *
      *                      * vati errori Bloccanti : a normalizza-   *
      *                      * zioni                                   *
      *                      *-----------------------------------------*
           if        w-ctl-imp-rig-ctr    >     w-ctl-imp-rig-ele
                     go to cnt-tdo-rig-200.
      *                      *-----------------------------------------*
      *                      * Emissione messaggio                     *
      *                      *-----------------------------------------*
           move      w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)   to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo errore    *
      *                      *-----------------------------------------*
           if        w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "B"
                     go to cnt-tdo-rig-144
           else if   w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "N"
                     go to cnt-tdo-rig-146.
       cnt-tdo-rig-144.
      *                      *-----------------------------------------*
      *                      * Se tipo errore : Bloccante              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A uscita con errore                 *
      *                          *-------------------------------------*
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-146.
      *                      *-----------------------------------------*
      *                      * Se tipo errore : Non bloccante          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo su scansione buffer         *
      *                          *-------------------------------------*
           go to     cnt-tdo-rig-142.
       cnt-tdo-rig-200.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione flag di estensione alla de-  *
      *                  * scrizione prodotto                          *
      *                  *---------------------------------------------*
           perform   det-des-ext-000      thru det-des-ext-999        .
      *                  *---------------------------------------------*
      *                  * Aggiornamento comodi di visualizzazione     *
      *                  *---------------------------------------------*
           move      "AG"                 to   w-edt-qta-inc-ope      .
           move      w-rig-qta-acq (1)    to   w-edt-qta-inc-qta      .
           move      w-rig-dec-qta (1)    to   w-edt-qta-inc-dec      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
           move      w-edt-qta-inc-din    to   w-tes-dec-qta          .
       cnt-tdo-rig-300.
      *              *-------------------------------------------------*
      *              * Uscita con esito positivo                       *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-999.
           exit.

      *    *===========================================================*
      *    * Controllo impostazioni su riga corpo                      *
      *    *-----------------------------------------------------------*
       ctl-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero elementi nel buffer er- *
      *              * rori                                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-imp-rig-ele      .
       ctl-imp-rig-010.
      *              *-------------------------------------------------*
      *              * Test su codice prodotto                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-020.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    not  = zero
                     go to ctl-imp-rig-020.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca il codice prodotto                       "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-020.
      *              *-------------------------------------------------*
      *              * Test su descrizione in riga                     *
      *              *-------------------------------------------------*
       ctl-imp-rig-040.
      *              *-------------------------------------------------*
      *              * Test su quantita' di acquisto                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-060.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-rig-qta-fda (1)    not  = zero and
                     w-rig-qta-acq (1)    not  = zero
                     go to ctl-imp-rig-060.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca la quantita'                             "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-060.
      *              *-------------------------------------------------*
      *              * Test su prezzo di acquisto                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-080.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-rig-prz-acq (1)    not  = zero
                     go to ctl-imp-rig-080.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca il prezzo di acquisto                    "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : a seconda se aggiornamenti    *
      *                  *               contabili da eseguire         *
      *                  *---------------------------------------------*
           if        w-prs-snx-cge        not  = "S"
                     move  "N"            to   w-ctl-imp-rig-ter
           else      move  "B"            to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-080.
      *              *-------------------------------------------------*
      *              * Test su coefficiente di cambio per legame valu- *
      *              * tario                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to ctl-imp-rig-100.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to ctl-imp-rig-100.
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to ctl-imp-rig-100.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    not  = zero
                     go to ctl-imp-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Cambio di riferimento per legame indeterminato "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore bloccante                       *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-100.
      *              *-------------------------------------------------*
      *              * Controllo tipo di limitazione per legame valu-  *
      *              * tario                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione per legame    *
      *                      * valutario                               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to ctl-imp-rig-120.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to ctl-imp-rig-120.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-120.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to ctl-imp-rig-120.
      *                      *-----------------------------------------*
      *                      * Test su percentuale di limitazione per  *
      *                      * legame valutario                        *
      *                      *-----------------------------------------*
           if        w-rig-plm-vpl (1)    =    zero
                     go to ctl-imp-rig-120.
      *                  *---------------------------------------------*
      *                  * Test se valore a spaces                     *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     go to ctl-imp-rig-120.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Tipo di tolleranza per legame indeterminata    "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore bloccante                       *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-120.
      *              *-------------------------------------------------*
      *              * Test su importo in riga                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to ctl-imp-rig-140.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    not  = zero
                     go to ctl-imp-rig-140.
      *                  *---------------------------------------------*
      *                  * Se il tipo riga non e' 'A' e o il prezzo o  *
      *                  * la quantita' sono a zero non viene emesso   *
      *                  * il messaggio                                *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-122.
           if       (w-rig-qta-fda (1)    =    zero and
                     w-rig-qta-acq (1)    =    zero   ) or
                     w-rig-prz-acq (1)    =    zero
                     go to ctl-imp-rig-140.
       ctl-imp-rig-122.
           move      "Manca l'importo                                "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-140.
      *              *-------------------------------------------------*
      *              * Test su codice iva                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to ctl-imp-rig-160.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-civ-rig (1)    not  = zero
                     go to ctl-imp-rig-160.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca il codice iva                            "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-160.
      *              *-------------------------------------------------*
      *              * Test su contropartita                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to ctl-imp-rig-180.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-ctp-rig (1)    not  = zero
                     go to ctl-imp-rig-180.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca la contropartita                         "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-180.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-imp-rig-999.
       ctl-imp-rig-900.
      *              *=================================================*
      *              * Subroutine interna per bufferizzazione tipo e   *
      *              * messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero elementi                  *
      *                  *---------------------------------------------*
           if        w-ctl-imp-rig-ele    <    w-ctl-imp-rig-max
                     add   1              to   w-ctl-imp-rig-ele      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione elemento                    *
      *                  *---------------------------------------------*
           move      w-ctl-imp-rig-ter    to   w-ctl-imp-rig-bte
                                              (w-ctl-imp-rig-ele)     .
           move      w-ctl-imp-rig-msg    to   w-ctl-imp-rig-bmg
                                              (w-ctl-imp-rig-ele)     .
       ctl-imp-rig-909.
           exit.
       ctl-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo                  *
      *    *-----------------------------------------------------------*
       pre-rig-cor-000.
       pre-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Attribuzione del numero progressivo per la riga New       *
      *    *-----------------------------------------------------------*
       prg-rig-cor-000.
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
       prg-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo                       *
      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
       pos-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di trattamento tasto 'Select' riga corpo       *
      *    *-----------------------------------------------------------*
       esp-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Costruzione box di Expand                       *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      22                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       esp-rig-cor-050.
      *              *-------------------------------------------------*
      *              * Salvataggi preliminari                          *
      *              *-------------------------------------------------*
           move      w-rig-bfo-tip (1)    to   w-sav-bfo-tip          .
           move      w-rig-bfo-prt (1)    to   w-sav-bfo-prt          .
           move      w-rig-bfo-dat (1)    to   w-sav-bfo-dat          .
           move      w-rig-bfo-ndo (1)    to   w-sav-bfo-ndo          .
           move      w-rig-bfo-ddo (1)    to   w-sav-bfo-ddo          .
       esp-rig-cor-100.
      *              *-------------------------------------------------*
      *              * Prompts per Expand                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Titolo                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      78                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      02                   to   v-pos                  .
           move      "                   Riferimenti documento di entrat
      -              "a merce                     "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Tipo documento di riferimento               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Bolla           :"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Protocollo documento di riferimento         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      29                   to   v-pos                  .
           move      "Numero :"           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Data registrazione documento di riferimento *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      50                   to   v-pos                  .
           move      "Data :"             to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      29                   to   v-pos                  .
           move      "Doc.   :"           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      50                   to   v-pos                  .
           move      "Data :"             to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Presa visione                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      77                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       esp-rig-cor-200.
      *              *-------------------------------------------------*
      *              * Visualizzazione dati per expand                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo documento di riferimento               *
      *                  *---------------------------------------------*
           perform   vis-bfo-tip-000      thru vis-bfo-tip-999        .
      *                  *---------------------------------------------*
      *                  * Protocollo documento di riferimento         *
      *                  *---------------------------------------------*
           perform   vis-bfo-prt-000      thru vis-bfo-prt-999        .
      *                  *---------------------------------------------*
      *                  * Data registrazione documento di riferimento *
      *                  *---------------------------------------------*
           perform   vis-bfo-dat-000      thru vis-bfo-dat-999        .
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           perform   vis-bfo-ndo-000      thru vis-bfo-ndo-999        .
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           perform   vis-bfo-ddo-000      thru vis-bfo-ddo-999        .
       esp-rig-cor-300.
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       esp-rig-cor-400.
      *              *-------------------------------------------------*
      *              * Accettazione dati per expand                    *
      *              *-------------------------------------------------*
       esp-rig-cor-410.
      *                  *---------------------------------------------*
      *                  * Tipo documento di riferimento               *
      *                  *---------------------------------------------*
           perform   acc-bfo-tip-000      thru acc-bfo-tip-999        .
      *                      *-----------------------------------------*
      *                      * Se 'Exit'                               *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     go to esp-rig-cor-880.
      *                      *-----------------------------------------*
      *                      * Se 'Do'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  "
                     go to esp-rig-cor-900.
       esp-rig-cor-420.
      *                  *---------------------------------------------*
      *                  * Protocollo documento di riferimento         *
      *                  *---------------------------------------------*
           perform   acc-bfo-prt-000      thru acc-bfo-prt-999        .
      *                      *-----------------------------------------*
      *                      * Se 'Exit'                               *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     go to esp-rig-cor-880.
      *                      *-----------------------------------------*
      *                      * Se 'Do'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  "
                     go to esp-rig-cor-900.
      *                      *-----------------------------------------*
      *                      * Se 'Up'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to esp-rig-cor-410.
       esp-rig-cor-430.
      *                  *---------------------------------------------*
      *                  * Data registrazione documento di riferimento *
      *                  *---------------------------------------------*
           perform   acc-bfo-dat-000      thru acc-bfo-dat-999        .
      *                      *-----------------------------------------*
      *                      * Se 'Exit'                               *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     go to esp-rig-cor-880.
      *                      *-----------------------------------------*
      *                      * Se 'Do'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  "
                     go to esp-rig-cor-900.
      *                      *-----------------------------------------*
      *                      * Se 'Up'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to esp-rig-cor-420.
       esp-rig-cor-440.
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           perform   acc-bfo-ndo-000      thru acc-bfo-ndo-999        .
      *                      *-----------------------------------------*
      *                      * Se 'Exit'                               *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     go to esp-rig-cor-880.
      *                      *-----------------------------------------*
      *                      * Se 'Do'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  "
                     go to esp-rig-cor-900.
      *                      *-----------------------------------------*
      *                      * Se 'Up'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to esp-rig-cor-430.
       esp-rig-cor-450.
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           perform   acc-bfo-ddo-000      thru acc-bfo-ddo-999        .
      *                      *-----------------------------------------*
      *                      * Se 'Exit'                               *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     go to esp-rig-cor-880.
      *                      *-----------------------------------------*
      *                      * Se 'Do'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DO  "
                     go to esp-rig-cor-900.
      *                      *-----------------------------------------*
      *                      * Se 'Up'                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to esp-rig-cor-440.
       esp-rig-cor-800.
      *              *-------------------------------------------------*
      *              * Accettazione di un carattere per presa visione  *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "SLCT"               to   v-pfk (11)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       esp-rig-cor-820.
      *              *-------------------------------------------------*
      *              * Tasti funzione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se 'Up'                                     *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to esp-rig-cor-400.
      *                  *---------------------------------------------*
      *                  * Se 'Exit'                                   *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     go to esp-rig-cor-880.
      *                  *---------------------------------------------*
      *                  * Se 'Do'                                     *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to esp-rig-cor-900.
      *                  *---------------------------------------------*
      *                  * Ad accettazione carattere presa visione     *
      *                  *---------------------------------------------*
           go to     esp-rig-cor-800.
       esp-rig-cor-880.
      *              *-------------------------------------------------*
      *              * Ripristino dati salvati                         *
      *              *-------------------------------------------------*
           move      w-sav-bfo-tip        to   w-rig-bfo-tip (1)      .
           move      w-sav-bfo-prt        to   w-rig-bfo-prt (1)      .
           move      w-sav-bfo-dat        to   w-rig-bfo-dat (1)      .
           move      w-sav-bfo-ndo        to   w-rig-bfo-ndo (1)      .
           move      w-sav-bfo-ddo        to   w-rig-bfo-ddo (1)      .
       esp-rig-cor-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     esp-rig-cor-999.
       esp-rig-cor-999.
           exit.
           
      *    *===========================================================*
      *    * Accettazione campo : Tipo documento di riferimento        *
      *    *-----------------------------------------------------------*
       acc-bfo-tip-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-bfo-tip-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-rig-bfo-tip (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-bfo-tip-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-bfo-tip (1)      .
       acc-bfo-tip-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo documento di riferimento     *
      *    *-----------------------------------------------------------*
       vis-bfo-tip-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-bfo-tip (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-bfo-tip-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero protocollo documento di rif.  *
      *    *-----------------------------------------------------------*
       acc-bfo-prt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione work per accettazione          *
      *                  *---------------------------------------------*
           move      w-rig-bfo-prt (1)
                                   (01 : 03)
                                          to   w-acc-num-prt-saa      .
           move      w-rig-bfo-prt (1)
                                   (06 : 06)
                                          to   w-acc-num-prt-prg      .
       acc-bfo-prt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      38                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-acc-num-prt-num    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-bfo-prt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Decomposizione work di accettazione         *
      *                  *---------------------------------------------*
           if        w-acc-num-prt-prg    =    zero
                     move  zero           to   w-rig-bfo-prt (1)
                     go to acc-bfo-prt-999.
           move      w-acc-num-prt-saa    to   w-rig-bfo-prt (1)
                                                             (01 : 03).
           move      w-tes-cod-dpz        to   w-rig-bfo-prt (1)
                                                             (03 : 02).
           move      w-acc-num-prt-prg    to   w-rig-bfo-prt (1)
                                                             (06 : 06).
       acc-bfo-prt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero protocollo documento rif.  *
      *    *-----------------------------------------------------------*
       vis-bfo-prt-000.
      *              *-------------------------------------------------*
      *              * Composizione work per visualizzazione           *
      *              *-------------------------------------------------*
           move      w-rig-bfo-prt (1)
                                   (01 : 03)
                                          to   w-vis-num-prt-saa      .
           move      w-rig-bfo-prt (1)
                                   (06 : 06)
                                          to   w-vis-num-prt-prg      .
       vis-bfo-prt-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      38                   to   v-pos                  .
           move      w-vis-num-prt-num    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-bfo-prt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data registrazione documento di rif. *
      *    *-----------------------------------------------------------*
       acc-bfo-dat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-bfo-dat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      57                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-rig-bfo-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-bfo-dat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-dat                to   w-rig-bfo-dat (1)      .
       acc-bfo-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data registrazione documento rif. *
      *    *-----------------------------------------------------------*
       vis-bfo-dat-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      57                   to   v-pos                  .
           move      w-rig-bfo-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-bfo-dat-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero documento di riferimento      *
      *    *-----------------------------------------------------------*
       acc-bfo-ndo-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-bfo-ndo-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      38                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-rig-bfo-ndo (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-bfo-ndo-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-bfo-ndo (1)      .
       acc-bfo-ndo-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero documento di riferimento   *
      *    *-----------------------------------------------------------*
       vis-bfo-ndo-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      38                   to   v-pos                  .
           move      w-rig-bfo-ndo (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-bfo-ndo-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data documento di riferimento        *
      *    *-----------------------------------------------------------*
       acc-bfo-ddo-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-bfo-ddo-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      57                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-rig-bfo-ddo (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-bfo-ddo-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-dat                to   w-rig-bfo-ddo (1)      .
       acc-bfo-ddo-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data documento di riferimento     *
      *    *-----------------------------------------------------------*
       vis-bfo-ddo-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      57                   to   v-pos                  .
           move      w-rig-bfo-ddo (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-bfo-ddo-999.
           exit.
