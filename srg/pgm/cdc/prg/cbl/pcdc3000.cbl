           move      w-exp-tip-sel-lun    to   v-car                  .
           move      w-exp-tip-sel-num    to   v-ldt                  .
           move      "DGT#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-sel-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-tip-sel        to   v-num                  .
