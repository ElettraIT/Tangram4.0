      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Esecuzione sort in ordine ascendente oppure     *
      *              *  discendente                                    *
      *              *-------------------------------------------------*
           if        w-cnt-exe-rou-srt    =    "<"
                     go to exe-rou-srt-140
           else      go to exe-rou-srt-120.
       exe-rou-srt-120.
      *              *-------------------------------------------------*
      *              * Se ordine ascendente                            *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-140.
      *              *-------------------------------------------------*
      *              * Se ordine discendente                           *
      *              *-------------------------------------------------*
           sort      srt                  on   descending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-rou-srt-999.
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       int-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su [oft] per fornitore                    *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      rr-dpz-inu           to   rf-oft-cod-dpz         .
           move      "F"                  to   rf-oft-tip-arc         .
           move      rr-cod-fnt           to   rf-oft-cod-arc         .
           move      rr-dem-min           to   rf-oft-dat-doc         .
           move      zero                 to   rf-oft-num-doc         .
           move      zero                 to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [oft]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su dipendenza e archivio               *
      *                  *---------------------------------------------*
           if        rf-oft-cod-dpz       not  = rr-dpz-inu or
                     rf-oft-tip-arc       not  = "F"        or
                     rf-oft-cod-arc       not  = rr-cod-fnt
                     go to int-srt-inp-900.
       int-srt-inp-310.
      *                  *---------------------------------------------*
      *                  * Test su data emissione min e max            *
      *                  *---------------------------------------------*
           if        rr-dem-max           =    zero
                     go to int-srt-inp-320
           else      go to int-srt-inp-340.
       int-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se data emissione max a zero                *
      *                  *---------------------------------------------*
           if        rr-dem-min           =    zero
                     go to int-srt-inp-400.
           if        rf-oft-dat-doc       >    rr-dem-min
                     go to int-srt-inp-900.
           go to     int-srt-inp-400.
       int-srt-inp-340.
      *                  *---------------------------------------------*
      *                  * Se data emissione massima non zero          *
      *                  *---------------------------------------------*
           if        rf-oft-dat-doc       >    rr-dem-max
                     go to int-srt-inp-900.
           go to     int-srt-inp-400.
       int-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su ordini aperti                  *
      *                  *---------------------------------------------*
           if        rr-sts-orf           =    01
                     go to int-srt-inp-410.
           if        rr-sts-orf           not  = 04 and
                     rf-oft-flg-och       not  = spaces
                     go to int-srt-inp-200.
       int-srt-inp-410.
      *                  *---------------------------------------------*
      *                  * Selezione su codice dipendenza fornitore    *
      *                  *---------------------------------------------*
           if        rr-dpz-fnt           =    "*   "
                     go to int-srt-inp-420.
           if        rf-oft-dpz-arc       not  = rr-dpz-fnt
                     go to int-srt-inp-200.
       int-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Determinazione status dell'ordine           *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-sts-orf-tip-ope      .
           perform   det-sts-orf-cll-000  thru det-sts-orf-cll-999    .
       int-srt-inp-430.
      *                  *---------------------------------------------*
      *                  * Selezione su status dell'ordine             *
      *                  *---------------------------------------------*
           if        rr-sts-orf           =    01
                     go to int-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione delle richieste      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-sts-orf           =    02
                     go to int-srt-inp-432
           else if   rr-sts-orf           =    03
                     go to int-srt-inp-434
           else if   rr-sts-orf           =    04
                     go to int-srt-inp-436.
       int-srt-inp-432.
      *                      *-----------------------------------------*
      *                      * Se solo ordini inevasi                  *
      *                      *-----------------------------------------*
           if        d-sts-orf-sts-ord    =    02  or
                     d-sts-orf-sts-ord    =    04
                     go to int-srt-inp-440
           else      go to int-srt-inp-200.
       int-srt-inp-434.
      *                      *-----------------------------------------*
      *                      * Se solo ordini evasi                    *
      *                      *-----------------------------------------*
           if        d-sts-orf-sts-ord    =    02  or
                     d-sts-orf-sts-ord    =    03
                     go to int-srt-inp-440
           else      go to int-srt-inp-200.
       int-srt-inp-436.
      *                      *-----------------------------------------*
      *                      * Se solo ordini chiusi                   *
      *                      *-----------------------------------------*
           if        d-sts-orf-sts-ord    =    01
                     go to int-srt-inp-440
           else      go to int-srt-inp-200.
       int-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Selezione su data ordine fornitore          *
      *                  *---------------------------------------------*
           if        rr-cof-dat           =    zero
                     go to int-srt-inp-450.
           if        rf-oft-cof-dat       not  = rr-cof-dat
                     go to int-srt-inp-200.
       int-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Selezione su numero ordine fornitore        *
      *                  *---------------------------------------------*
           if        rr-cof-num           =    spaces
                     go to int-srt-inp-500.
           if        rf-oft-cof-num       not  = rr-cof-num
                     go to int-srt-inp-200.
       int-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Determinazione totale documento                 *
      *              *-------------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
       int-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
           perform   int-srt-inp-key-000  thru int-srt-inp-key-999    .
       int-srt-inp-650.
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      rf-oft-num-prt       to   srt-num-prt            .
      *                      *-----------------------------------------*
      *                      * Imponibile documento                    *
      *                      *-----------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-doc            .
      *                      *-----------------------------------------*
      *                      * Status ordine                           *
      *                      *-----------------------------------------*
           move      d-sts-orf-sts-ord    to   srt-sts-ord            .
      *                      *-----------------------------------------*
      *                      * Annotazioni                             *
      *                      *-----------------------------------------*
           if        d-sts-orf-sts-ord    =    01
                     move  "Chiuso                   "
                                          to   srt-sts-lit
           else if   d-sts-orf-sts-ord    =    02
                     move  "Evaso parzialmente       "
                                          to   srt-sts-lit
           else if   d-sts-orf-sts-ord    =    03
                     move  "Evaso                    "
                                          to   srt-sts-lit
           else if   d-sts-orf-sts-ord    =    04
                     move  "Inevaso                  "
                                          to   srt-sts-lit            .
       int-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       int-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     int-srt-inp-200.
       int-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-999.
       int-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per preparazione chiavi di sort                *
      *    *-----------------------------------------------------------*
       int-srt-inp-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      spaces               to   srt-tip-key            .
           move      zero                 to   srt-ntp-key            .
           move      zero                 to   srt-num-key            .
           move      zero                 to   srt-dat-key            .
           move      zero                 to   srt-ndt-key            .
           move      spaces               to   srt-dpz-arc            .
           move      zero                 to   srt-tot-key            .
           move      zero                 to   srt-cns-key            .
           move      spaces               to   srt-ann-key            .
       int-srt-inp-key-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di ordinamento  *
      *              *-------------------------------------------------*
           go to     int-srt-inp-key-100
                     int-srt-inp-key-200
                     int-srt-inp-key-300
                     int-srt-inp-key-400
                     int-srt-inp-key-500
                     int-srt-inp-key-600
                     int-srt-inp-key-700
                     depending            on   w-cnt-exe-rou-sro      .
       int-srt-inp-key-100.
      *              *-------------------------------------------------*
      *              * 1. per tipo documento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-oft-tmo-orf       to   srt-tip-key            .
           move      rf-oft-num-doc
                    (06 : 06)             to   srt-ntp-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-200.
      *              *-------------------------------------------------*
      *              * 2. per numero ordine                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-oft-num-doc
                    (06 : 06)             to   srt-num-key            .
           move      rf-oft-dpz-arc       to   srt-dpz-arc            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-300.
      *              *-------------------------------------------------*
      *              * 3. per data documento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-oft-dat-doc       to   srt-dat-key            .
           move      rf-oft-num-doc
                    (06 : 06)             to   srt-ndt-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-400.
      *              *-------------------------------------------------*
      *              * 4. per dipendenza archivio                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-oft-dpz-arc       to   srt-dpz-arc            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-500.
      *              *-------------------------------------------------*
      *              * 5. per totale documento                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-600.
      *              *-------------------------------------------------*
      *              * 6. per data consegna                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-oft-dat-cns       to   srt-cns-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-700.
      *              *-------------------------------------------------*
      *              * 7. per annotazioni                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           if        d-sts-orf-sts-ord    =    01
                     move  "Chiuso                   "
                                          to   srt-ann-key
           else if   d-sts-orf-sts-ord    =    02
                     move  "Evaso parzialmente       "
                                          to   srt-ann-key
           else if   d-sts-orf-sts-ord    =    03
                     move  "Evaso                    "
                                          to   srt-ann-key
           else if   d-sts-orf-sts-ord    =    04
                     move  "Inevaso                  "
                                          to   srt-ann-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-key-999.
       int-srt-inp-key-999.
           exit.

      *    *===========================================================*
      *    * Accettazione richieste di selezione                       *
      *    *-----------------------------------------------------------*
       acc-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-acc-ric-sel      .
      *              *-------------------------------------------------*
      *              * Normalizzazione status impostazione             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-ric      .
      *              *-------------------------------------------------*
      *              * Normalizzazione status visualizzazione prompts  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ric      .
      *              *-------------------------------------------------*
      *              * Normalizzazione status visualizzazione dati     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-vis-ric      .
      *              *-------------------------------------------------*
      *              * Normalizzazione parametri di selezione          *
      *              *-------------------------------------------------*
           perform   nor-ric-sel-000      thru nor-ric-sel-999        .
