                     go to acc-tmo-orf-def-400
           else if   w-ref-cod-tmo-trt    =    "O"
                     go to acc-tmo-orf-def-500
           else      go to acc-tmo-orf-def-900.
       acc-tmo-orf-def-200.
      *              *-------------------------------------------------*
