           move      "NUMPRT    "         to   f-key                  .
           move      w-slc-num-oft-bpt (1)
                                          to   rf-oft-num-prt         .
           move      "pgm/orf/fls/ioc/obj/iofoft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
           if        f-sts                not  = e-not-err
