      *              * Deviazione a seconda della presenza o meno del- *
      *              * la variabile di i.p.c. per il codice prodotto   *
      *              *-------------------------------------------------*
           if        w-ipc-cod-pro-snx    =    "N"
                     go to pre-tip-fun-500.
       pre-tip-fun-100.
      *              *-------------------------------------------------*
      *              * Se variabile esistente                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : come per non esistente   *
      *                  *---------------------------------------------*
           if        w-ipc-cod-pro-val    =    zero
                     go to pre-tip-fun-500.
      *                  *---------------------------------------------*
      *                  * Preparazione work-area richieste            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice prodotto numerico                *
      *                      *-----------------------------------------*
           move      w-ipc-cod-pro-val    to   rr-cod-pro             .
      *                      *-----------------------------------------*
      *                      * Lettura record [dcp]                    *
      *                      *-----------------------------------------*
           move      rr-cod-pro           to   w-let-arc-dcp-num      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to pre-tip-fun-500.
      *                      *-----------------------------------------*
      *                      * Codice prodotto alfanumerico            *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-alf    to   rr-alf-pro             .
      *                      *-----------------------------------------*
      *                      * Descrizione prodotto                    *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   rr-cod-pro-des         .
      *                      *-----------------------------------------*
      *                      * Data emissione minima                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se esiste una variabile di i.p.c. e *
      *                          * questa non e' zero : data emissione *
      *                          * minima pari al valore letto         *
      *                          *-------------------------------------*
           if        w-ipc-dem-min-snx    =    "S" and
                     w-ipc-dem-min-val    not  = zero
                     move  w-ipc-dem-min-val
                                          to   rr-dem-min
                     go to pre-tip-fun-120.
      *                          *-------------------------------------*
      *                          * Altrimenti : data emissione minima  *
      *                          * a zero                              *
      *                          *-------------------------------------*
           move      zero                 to   rr-dem-min             .
       pre-tip-fun-120.
      *                      *-----------------------------------------*
      *                      * Data emissione massima                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se esiste una variabile di i.p.c. e *
      *                          * questa non e' zero : data emissione *
      *                          * massima pari al valore letto        *
      *                          *-------------------------------------*
           if        w-ipc-dem-max-snx    =    "S" and
                     w-ipc-dem-max-val    not  = zero
                     move  w-ipc-dem-max-val
                                          to   rr-dem-max
                     go to pre-tip-fun-140.
      *                          *-------------------------------------*
      *                          * Altrimenti : data emissione massima *
      *                          * a zero                              *
      *                          *-------------------------------------*
           move      zero                 to   rr-dem-max             .
       pre-tip-fun-140.
      *                      *-----------------------------------------*
      *                      * Status ordini fornitori                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se esiste una variabile di i.p.c. e *
      *                          * questa non e' zero : status ordini  *
      *                          * fornitori pari al valore letto      *
      *                          *-------------------------------------*
           if        w-ipc-sts-orf-snx    =    "S" and
                     w-ipc-sts-orf-val    not  = zero
                     move  w-ipc-sts-orf-val
                                          to   rr-sts-orf
                     go to pre-tip-fun-200.
      *                          *-------------------------------------*
      *                          * Altrimenti : status ordini fornito- *
      *                          * ri normalizzato a 01                *
      *                          *-------------------------------------*
           move      01                   to   rr-sts-orf             .
       pre-tip-fun-200.
      *                  *---------------------------------------------*
      *                  * Preparazione tipo funzionamento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si/No richieste ad utente : No          *
      *                      *-----------------------------------------*
           move      "N"                  to   w-cnt-fun-snx-ric      .
      *                      *-----------------------------------------*
      *                      * Si/No funzionamento ciclico : No        *
      *                      *-----------------------------------------*
           move      "N"                  to   w-cnt-fun-snx-cic      .
      *                      *-----------------------------------------*
      *                      * Si/No funzionamento automatico : Si     *
      *                      *-----------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-aut      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-tip-fun-999.
       pre-tip-fun-500.
      *              *-------------------------------------------------*
      *              * Se variabile non esistente                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Si/No richieste ad utente : Si              *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-ric      .
      *                  *---------------------------------------------*
      *                  * Si/No funzionamento ciclico : Si            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-cic      .
      *                  *---------------------------------------------*
      *                  * Si/No funzionamento automatico : No         *
      *                  *---------------------------------------------*
           move      "N"                  to   w-cnt-fun-snx-aut      .
       pre-tip-fun-999.
           exit.

