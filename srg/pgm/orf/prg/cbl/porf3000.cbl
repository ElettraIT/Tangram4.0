      *    *===========================================================*
      *    * Routine di ripristino numero documento ordini fornitori   *
      *    *-----------------------------------------------------------*
       rip-orf-ndo-000.
      *              *-------------------------------------------------*
      *              * Se nessun nuovo numero documento : uscita       *
      *              *-------------------------------------------------*
           if        w-att-orf-ndo-new    =    zero
                     go to rip-orf-ndo-999.
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-orf-ndo-dat    to   s-dat                  .
           move      s-saa                to   w-att-orf-ndo-saa      .
           move      w-att-orf-ndo-saa    to   rn-orf-ndo-scl-ann     .
           move      w-att-orf-ndo-dpz    to   rn-orf-ndo-cod-dpz     .
           move      w-att-orf-ndo-sgl    to   rn-orf-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-ndo             .
           if        f-sts                =    e-not-err
                     go to rip-orf-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-orf-ndo-num-doc     .
           move      zero                 to   rn-orf-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-ndo             .
           go to     rip-orf-ndo-000.
       rip-orf-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-orf-ndo-num-doc   =    w-att-orf-ndo-new
                     go to rip-orf-ndo-200
           else      go to rip-orf-ndo-400.
       rip-orf-ndo-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento record              *
      *                      *-----------------------------------------*
           move      w-att-orf-ndo-nsv    to   rn-orf-ndo-num-doc     .
           move      w-att-orf-ndo-dsv    to   rn-orf-ndo-dat-doc     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-ndo             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-orf-ndo-000.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-orf-ndo-999.
       rip-orf-ndo-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-orf-ndo-num-doc   =    w-att-orf-ndo-num
                     go to rip-orf-ndo-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
