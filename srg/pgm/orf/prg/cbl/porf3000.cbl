                     w-let-arc-ofx-prg    =    zero   or
                     w-let-arc-ofx-trc    =    zero
                     go to let-arc-ofx-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-let-arc-ofx-prt    to   rf-ofx-num-prt         .
           move      w-let-arc-ofx-prg    to   rf-ofx-num-prg         .
           move      w-let-arc-ofx-trc    to   rf-ofx-tip-rec         .
           move      "pgm/orf/fls/ioc/obj/iofofx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofx                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-ofx-400.
       let-arc-ofx-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-ofx-des-400       to   w-let-arc-ofx-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-ofx-999.
       let-arc-ofx-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-ofx-flg      .
           move      spaces               to   w-let-arc-ofx-des      .
           move      all   "."            to   w-let-arc-ofx-drg (1)  .
           go to     let-arc-ofx-999.
       let-arc-ofx-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ofx-des      .
       let-arc-ofx-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [ada]                         *
      *    *-----------------------------------------------------------*
           copy      "pgm/azi/prg/cpy/larcada0.lts"                   .

      *    *===========================================================*
      *    * Determinazione valori testata indotti da record [dcf]     *
      *    * principale                                                *
      *    *-----------------------------------------------------------*
       det-vlt-dcf-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre solo in tipo funzionamento : *
      *              * 'inserimento'                                   *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-vlt-dcf-100.
      *                  *---------------------------------------------*
      *                  * Valori                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice lingua per il documento          *
      *                      *-----------------------------------------*
           move      rf-dcf-cod-lng       to   w-tes-cod-lng (1)      .
           move      w-tes-cod-lng (1)    to   w-let-arc-zln-cod      .
           perform   let-arc-zln-000      thru let-arc-zln-999        .
           move      w-let-arc-zln-des    to   w-tes-cod-lng-des (1)  .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione contropartita agli *
      *                      * acquisti                                *
      *                      *-----------------------------------------*
           move      rf-dcf-ctp-acq       to   w-tes-ctp-acq (1)      .
           move      w-tes-ctp-acq (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-acq-des (1)  .
      *                      *-----------------------------------------*
      *                      * Inoltro documenti                       *
      *                      *-----------------------------------------*
           move      rf-dcf-inl-dcm       to   w-tes-inl-dcm (1)      .
      *                      *-----------------------------------------*
      *                      * Inoltro pagamenti                       *
      *                      *-----------------------------------------*
           move      rf-dcf-inl-pgt       to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-dcf-cod-vlt       to   w-tes-sgl-vpf (1)      .
           move      w-tes-sgl-vpf (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-des    to   w-tes-sgl-vpf-des (1)  .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto in riga associate *
      *                      * al fornitore                            *
      *                      *-----------------------------------------*
           move      rf-dcf-per-scr (1)   to   w-tes-psr-aaf (1, 1)   .
           move      rf-dcf-per-scr (2)   to   w-tes-psr-aaf (1, 2)   .
           move      rf-dcf-per-scr (3)   to   w-tes-psr-aaf (1, 3)   .
           move      rf-dcf-per-scr (4)   to   w-tes-psr-aaf (1, 4)   .
           move      rf-dcf-per-scr (5)   to   w-tes-psr-aaf (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Codice, descrizione e % sconto chiusura *
      *                      *-----------------------------------------*
           move      rf-dcf-per-scc       to   w-tes-psc-aaf (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione % sconto in chiususra    *
      *                      *-----------------------------------------*
           perform   det-per-scc-000      thru det-per-scc-999        .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione voci descrittive   *
      *                      *-----------------------------------------*
           move      rf-dcf-vde-cod (1)   to   w-tes-voc-des (1, 1)   .
           move      rf-dcf-vde-cod (2)   to   w-tes-voc-des (1, 2)   .
           move      rf-dcf-vde-cod (3)   to   w-tes-voc-des (1, 3)   .
           move      rf-dcf-vde-cod (4)   to   w-tes-voc-des (1, 4)   .
           move      rf-dcf-vde-cod (5)   to   w-tes-voc-des (1, 5)   .
           move      rf-dcf-vde-cod (6)   to   w-tes-voc-des (1, 6)   .
           move      zero                 to   w-det-vlt-dcf-ctr      .
       det-vlt-dcf-020.
           add       1                    to   w-det-vlt-dcf-ctr      .
           if        w-det-vlt-dcf-ctr    >    w-prs-vde-fat-nvt
                     go to det-vlt-dcf-040.
           move      w-prs-vde-fat-npt
                    (w-det-vlt-dcf-ctr)   to   w-det-vlt-dcf-inx      .
           move      w-det-vlt-dcf-inx    to   w-let-arc-yvf-num      .
           move      w-tes-voc-des
                    (1, w-det-vlt-dcf-inx)
                                          to   w-let-arc-yvf-cod      .
           perform   let-arc-yvf-000      thru let-arc-yvf-999        .
           move      w-let-arc-yvf-des    to   w-tes-voc-des-des
                                              (1, w-det-vlt-dcf-inx)  .
           go to     det-vlt-dcf-020.
       det-vlt-dcf-040.
      *                      *-----------------------------------------*
      *                      * Codice e descrizione forma di pagamento *
      *                      *-----------------------------------------*
           move      rf-dcf-cod-fop       to   w-tes-cod-fop (1)      .
           move      w-tes-cod-fop (1)    to   w-let-arc-yfp-cod      .
           perform   let-arc-yfp-000      thru let-arc-yfp-999        .
           move      w-let-arc-yfp-des    to   w-tes-cod-fop-des (1)  .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione categoria spese    *
      *                      * incasso                                 *
      *                      *-----------------------------------------*
           move      rf-dcf-add-spi       to   w-tes-add-spi (1)      .
           move      w-tes-add-spi (1)    to   w-let-arc-yin-cod      .
           move      00                   to   w-let-arc-yin-tpg      .
           perform   let-arc-yin-000      thru let-arc-yin-999        .
           move      w-let-arc-yin-des    to   w-tes-add-spi-des (1)  .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione categoria spese    *
      *                      * bollo                                   *
      *                      *-----------------------------------------*
           move      rf-dcf-add-spb       to   w-tes-add-spb (1)      .
           move      w-tes-add-spb (1)    to   w-let-arc-ybo-cod      .
           move      00                   to   w-let-arc-ybo-tpg      .
           perform   let-arc-ybo-000      thru let-arc-ybo-999        .
           move      w-let-arc-ybo-des    to   w-tes-add-spb-des (1)  .
       det-vlt-dcf-100.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice e descrizione nostra banca di appog- *
      *                  * gio associati al fornitore                  *
      *                  *---------------------------------------------*
           move      rf-dcf-nos-ban       to   w-tes-nsb-aaf (1)      .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione nostra banca di appog- *
      *                  * gio per il documento                        *
      *                  *---------------------------------------------*
           move      w-tes-nsb-aaf (1)    to   w-tes-nos-ban (1)      .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione ABI del fornitore      *
      *                  *---------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-fnt (1)      .
           move      w-tes-abi-fnt (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-fnt-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione CAB del fornitore      *
      *                  *---------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-fnt (1)      .
           move      w-tes-abi-fnt (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-fnt (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-fnt-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c appoggio del fornitore                  *
      *                  *---------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-cca-fnt (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale del fornitore                   *
      *                  *---------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-fnt (1)      .
      *                  *---------------------------------------------*
      *                  * Modalita' di calcolo importo                *
      *                  *---------------------------------------------*
           move      rf-dcf-tip-mci       to   w-tes-tip-mci (1)      .
       det-vlt-dcf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuale sconto in chiusura             *
      *    *                                                           *
      *    * N.B.: La determinazione dello sconto in chiusura segue la *
      *    *       seguente scaletta di prevalenza:                    *
      *    *       - Quello contenuto direttamente in [dcf]            *
      *    *       - Quelli contenuto nella categoria di sconto        *
      *    *-----------------------------------------------------------*
       det-per-scc-000.
      *              *-------------------------------------------------*
      *              * Se percentuale di sconto in chiusura associata  *
      *              * al fornitore non e' a zero, questa prevale su   *
      *              * altre forme di determinazione                   *
      *              *-------------------------------------------------*
           if        w-tes-psc-aaf (1)    =    zero 
                     go to det-per-scc-100.
           move      w-tes-psc-aaf (1)    to   w-pie-per-scc (1)      .
           go to     det-per-scc-999.
       det-per-scc-100.
      *              *-------------------------------------------------*
      *              * A questo punto nessuno dei possibili tipi di de-*
      *              * terminazione si ' verificato, per cui non resta *
      *              * che uscire                                      *
      *              *-------------------------------------------------*
           go to     det-per-scc-999.
       det-per-scc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione funzionamento spese in fattura             *
      *    *-----------------------------------------------------------*
       det-fun-spe-000.
      *              *-------------------------------------------------*
      *              * Test su tipo funzionamento                      *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-fun-spe-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella personalizzazioni *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-fun-spe-ctr      .
       det-fun-spe-100.
           add       1                    to   w-det-fun-spe-ctr      .
           if        w-det-fun-spe-ctr    >    w-prs-spe-fat-nst
                     go to det-fun-spe-999.
      *              *-------------------------------------------------*
      *              * Preparazione indice per tabella                 *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-fun-spe-ctr)   to   w-det-fun-spe-inx      .
      *              *-------------------------------------------------*
      *              * Si/No addebito                                  *
      *              *-------------------------------------------------*
           if        rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    zero or
                     rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    01
                     move  0              to   w-pie-spe-snx
                                              (1, w-det-fun-spe-inx)
           else      move  1              to   w-pie-spe-snx
                                              (1, w-det-fun-spe-inx)  .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo funzionamento   *
      *              * derivato dalle personalizzazioni                *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    01
                     go to det-fun-spe-110
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    02
                     go to det-fun-spe-120
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    03
                     go to det-fun-spe-130
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    04
                     go to det-fun-spe-140
           else if   w-prs-spe-fat-tfs
                    (w-det-fun-spe-ctr)   =    05
                     go to det-fun-spe-150.
       det-fun-spe-110.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : % fissa                    *
      *              *-------------------------------------------------*
           move      1                    to   w-pie-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-per
                    (w-det-fun-spe-ctr)   to   w-pie-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibl
                    (w-det-fun-spe-ctr)   to   w-pie-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibt
                    (w-det-fun-spe-ctr)   to   w-pie-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-120.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : % variabile                *
      *              *-------------------------------------------------*
           move      2                    to   w-pie-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      rf-dcf-per-spe
                    (w-det-fun-spe-inx)   to   w-pie-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibl
                    (w-det-fun-spe-ctr)   to   w-pie-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-ibt
                    (w-det-fun-spe-ctr)   to   w-pie-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-130.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : importo fisso              *
      *              *-------------------------------------------------*
           move      3                    to   w-pie-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      spaces               to   w-pie-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-imp
                    (w-det-fun-spe-ctr)   to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-140.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : importo variabile          *
      *              *-------------------------------------------------*
           move      4                    to   w-pie-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      spaces               to   w-pie-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           move      rf-dcf-imp-spe
                    (w-det-fun-spe-inx)   to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-150.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : secondo [dcf]              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo funziona-   *
      *                  * mento espresso in [dcf]                     *
      *                  *---------------------------------------------*
           if        rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    03
                     go to det-fun-spe-151
           else if   rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    04
                     go to det-fun-spe-152.
       det-fun-spe-151.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento espresso in [dcf] : a %  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Come per tipo funzionamento espresso in *
      *                      * personalizzazioni : % variabile         *
      *                      *-----------------------------------------*
           go to     det-fun-spe-120.
       det-fun-spe-152.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento espresso in [dcf] : ad   *
      *                  * importo                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Come per tipo funzionamento espresso in *
      *                      * personalizzazioni : importo variabile   *
      *                      *-----------------------------------------*
           go to     det-fun-spe-140.
       det-fun-spe-200.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella personalizzazioni  *
      *              *-------------------------------------------------*
           go to     det-fun-spe-100.
       det-fun-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da record [dcf]     *
      *    * relativo alla dipendenza del fornitore                    *
      *    *-----------------------------------------------------------*
       det-vlt-dcd-000.
      *              *-------------------------------------------------*
      *              * Se codice dipendenza a spazi : uscita           *
      *              *-------------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     go to det-vlt-dcd-999.
      *              *-------------------------------------------------*
      *              * Codice e descrizione ABI dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * Codice e descrizione CAB dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-dpz (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * C/c bancario della dipendenza                   *
      *              *-------------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-cca-dpz (1)      .
      *              *-------------------------------------------------*
      *              * C/c postale della dipendenza                    *
      *              *-------------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-dpz (1)      .
       det-vlt-dcd-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da inoltro pagamento*
      *    *-----------------------------------------------------------*
       det-vlt-ipg-000.
      *              *-------------------------------------------------*
      *              * Se dipendenza non esistente                     *
      *              *-------------------------------------------------*
           if        w-tes-dpz-arc (1)    not  = spaces
                     go to det-vlt-ipg-500.
       det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-fnt (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-fnt-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-fnt (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-fnt-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-fnt (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-fnt (1)    to   w-tes-ccp-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-500.
      *              *-------------------------------------------------*
      *              * Se dipendenza esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inoltro pagamento alla sede o alla sede  *
      *                  * legale : valori derivati da [dcf] principale*
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    01 or
                     w-tes-inl-pgt (1)    =    02
                     go to det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-dpz (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-dpz-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-dpz (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-dpz-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-dpz (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-dpz (1)    to   w-tes-ccp-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata dipendenti dalla forma di   *
      *    * pagamento                                                 *
      *    *-----------------------------------------------------------*
       det-vlt-yfp-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sconto pagamento associato alla forma di    *
      *                  * pagamento                                   *
      *                  *---------------------------------------------*
           move      w-let-arc-yfp-sap    to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * alle impostazioni dei campi relativi ai pa- *
      *                  * pagamenti                                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-snx-nsb (1)      .
           move      spaces               to   w-tes-snx-bnb (1)      .
           move      spaces               to   w-tes-snx-ccp (1)      .
           move      spaces               to   w-tes-snx-spm (1)      .
           move      spaces               to   w-tes-snx-qaf (1)      .
           move      spaces               to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Se forma di pagamento a zero : uscita       *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to det-vlt-yfp-999.
      *                  *---------------------------------------------*
      *                  * Ciclo per tre codici pagamento possibili    *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vlt-yfp-ctr      .
       det-vlt-yfp-100.
           add       1                    to   w-det-vlt-yfp-ctr      .
           if        w-det-vlt-yfp-ctr    >    3
                     go to det-vlt-yfp-400.
           if        rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   =    zero
                     go to det-vlt-yfp-100.
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [zpg]  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record [zpg]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zpg]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODPAG"             to   f-key                  .
           move      rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   to   rf-zpg-cod-pag         .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
       det-vlt-yfp-200.
      *                  *---------------------------------------------*
      *                  * Valori testata di appoggio alle successive  *
      *                  * impostazioni                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice nostra banca     *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    02 or
                     rf-zpg-tip-pag       =    03 or
                     rf-zpg-tip-pag       =    04 or
                     rf-zpg-tip-pag       =    05 or
                     rf-zpg-tip-pag       =    06 or
                     rf-zpg-tip-pag       =    09 or
                     rf-zpg-tip-pag       =    10 or
                     rf-zpg-tip-pag       =    11
                     move  "S"            to   w-tes-snx-nsb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice ABI, CAB e C/C/  *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    07
                     move  "S"            to   w-tes-snx-bnb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no richiesta C/C postale             *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    08
                     move  "S"            to   w-tes-snx-ccp (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no data scadenza pagamento manuale   *
      *                      *-----------------------------------------*
           if        rf-zpg-dec-prs       =    01
                     move  "S"            to   w-tes-snx-spm (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione quota a forfait      *
      *                      *-----------------------------------------*
           if        rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    06 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    07 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    08 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    09
                     move  "S"            to   w-tes-snx-qaf (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione acconto              *
      *                      *-----------------------------------------*
           if        rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   =    02
                     move  "S"            to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-yfp-100.
       det-vlt-yfp-400.
      *              *-------------------------------------------------*
      *              * Valori relativi alla determinazione effettuata  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostra banca             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-nsb (1)    not  = "S"
                     go to det-vlt-yfp-420.
           if        w-tes-nos-ban (1)    not  = spaces
                     go to det-vlt-yfp-900.
           move      w-tes-nsb-aaf (1)    to   w-tes-nos-ban (1)      .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-vlt-yfp-900.
       det-vlt-yfp-420.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ban (1)    =    spaces
                     go to det-vlt-yfp-900.
           move      spaces               to   w-tes-nos-ban (1)      .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-vlt-yfp-900.
       det-vlt-yfp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-vlt-yfp-999.
       det-vlt-yfp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione flag di estensione alla descrizione        *
      *    *-----------------------------------------------------------*
       det-des-ext-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe occupate            *
      *              *-------------------------------------------------*
           move      11                   to   w-det-des-ext-ctr      .
       det-des-ext-100.
           subtract  1                    from w-det-des-ext-ctr      .
           if        w-det-des-ext-ctr    =    zero
                     go to det-des-ext-200.
           if        w-rig-der-rig
                    (1, w-det-des-ext-ctr)
                                          =    spaces
                     go to det-des-ext-100.
       det-des-ext-200.
      *              *-------------------------------------------------*
      *              * Se numero righe non superiore a 1               *
      *              *-------------------------------------------------*
           if        w-det-des-ext-ctr    not  > 1
                     move  0              to   w-rig-des-ext (1)
                     go to det-des-ext-900.
       det-des-ext-300.
      *              *-------------------------------------------------*
      *              * Se numero righe maggiore di 1                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se descrizione impostata diversa da descri- *
      *                  * zione prodotto originale                    *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = w-rig-des-por (1)
                     move  1              to   w-rig-des-ext (1)
                     go to det-des-ext-900.
      *                  *---------------------------------------------*
      *                  * Se descrizione impostata uguale a descri-   *
      *                  * zione prodotto                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A seconda che esista o meno un formato  *
      *                      * di acquisizione                         *
      *                      *-----------------------------------------*
           if        w-rig-snx-dep (1)    =    "S"
                     move  3              to   w-rig-des-ext (1)
           else      move  2              to   w-rig-des-ext (1)      .
       det-des-ext-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-ext-999.
       det-des-ext-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo di acquisto                         *
      *    *-----------------------------------------------------------*
       det-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Solo se riga di tipo 'new'                      *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to det-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di prezzo associato al forni-  *
      *              * tore/prodotto                                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-rig-per-scr-ffp (1)  .
       det-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione link-area                      *
      *                  *---------------------------------------------*
           move      "PA"                 to   d-prz-acq-tip-ope      .
           move      w-tes-cod-arc (1)    to   d-prz-acq-cod-fnt      .
           move      w-rig-tip-mag (1)    to   d-prz-acq-tip-mag      .
           move      w-rig-num-mag (1)    to   d-prz-acq-num-mag      .
           move      w-rig-fda-pif (1)    to   d-prz-acq-fda-pif      .
           move      w-let-arc-dcp-plb    to   d-prz-acq-prz-lsb      .
           move      w-let-arc-dcp-dlb    to   d-prz-acq-dec-vlb      .
           move      w-rig-dec-prz (1)    to   d-prz-acq-dec-prz      .
      *                      *-----------------------------------------*
      *                      * Preparazione quantita'                  *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-ord (1)
                                          to   d-prz-acq-qta-rif
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   d-prz-acq-qta-rif
           else      move  w-rig-qta-ord (1)
                                          to   d-prz-acq-qta-rif      .
      *                      *-----------------------------------------*
      *                      * Come data di riferimento prezzo viene   *
      *                      * presa quella di conferma da parte del   *
      *                      * fornitore o, in sua assenza, quella del *
      *                      * documento                               *
      *                      *-----------------------------------------*
           if        w-tes-cof-dat (1)    =    zero
                     move  w-tes-dat-doc  to   d-prz-acq-dat-rfp
           else      move  w-tes-cof-dat (1)
                                          to   d-prz-acq-dat-rfp      .
      *                  *---------------------------------------------*
      *                  * Richiamo del sottoprogramma                 *
      *                  *---------------------------------------------*
           perform   det-prz-acq-cll-000  thru det-prz-acq-cll-999    .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori determinati           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo di acquisto                      *
      *                      *-----------------------------------------*
           move      d-prz-acq-prz-acq    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto                   *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-det (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-prz-acq-psr-det (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-prz-acq-psr-det (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-prz-acq-psr-det (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-prz-acq-psr-det (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Segnale di percentuali sconto determi-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-snx    to   w-rig-per-scr-ffp (1)  .
      *                      *-----------------------------------------*
      *                      * Data ultimo aggiornamento prezzo        *
      *                      *-----------------------------------------*
           move      d-prz-acq-dat-rfp    to   w-rig-prz-acq-dua (1)  .
       det-prz-acq-900.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-prz-acq-999.
       det-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuali di sconto in riga              *
      *    *-----------------------------------------------------------*
       det-per-scr-000.
      *              *-------------------------------------------------*
      *              * Solo se riga di tipo 'new'                      *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to det-per-scr-999.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento sconti in riga 001           *
      *              *-------------------------------------------------*
           perform   det-psr-001-000      thru det-psr-001-999        .
           go to     det-per-scr-999.
       det-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuali di sconto in riga tipo 001     *
      *    *                                                           *
      *    * N.B.: La determinazione degli sconti in riga segue la se- *
      *    *       guente scaletta di prevalenza:                      *
      *    *       - Quelli diretti dall'incrocio Fornitore/Prodotto   *
      *    *         contenuti nel record [aaq]                        *
      *    *       - Quelli contenuti direttamente in [dcf]            *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-psr-001-000.
      *              *-------------------------------------------------*
      *              * Se gli sconti sono associati alla combinazione  *
      *              * fornitore/prodotto, questi sono gia' stati memo-*
      *              * rizzati e quindi si esce                        *
      *              *-------------------------------------------------*
           if        w-rig-per-scr-ffp (1)
                                          not  = spaces
                     go to det-psr-001-999.
       det-psr-001-200.
      *              *-------------------------------------------------*
      *              * Test se sconti diretti da record [dcf]          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se percentuali di sconto in riga associate  *
      *                  * al fornitore sono tutte a zero : oltre      *
      *                  *---------------------------------------------*
           if        w-tes-psr-aaf (1, 1) =    zero and
                     w-tes-psr-aaf (1, 2) =    zero and
                     w-tes-psr-aaf (1, 3) =    zero and
                     w-tes-psr-aaf (1, 4) =    zero and
                     w-tes-psr-aaf (1, 5) =    zero
                     go to det-psr-001-700.
      *                  *---------------------------------------------*
      *                  * Altrimenti si memorizzano                   *
      *                  *---------------------------------------------*
           move      w-tes-psr-aaf (1, 1) to   w-rig-per-scr (1, 1)   .
           move      w-tes-psr-aaf (1, 2) to   w-rig-per-scr (1, 2)   .
           move      w-tes-psr-aaf (1, 3) to   w-rig-per-scr (1, 3)   .
           move      w-tes-psr-aaf (1, 4) to   w-rig-per-scr (1, 4)   .
           move      w-tes-psr-aaf (1, 5) to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-psr-001-999.
       det-psr-001-700.
      *              *-------------------------------------------------*
      *              * A questo punto nessuno dei possibili tipi di de-*
      *              * terminazione si ' verificato, per cui non resta *
      *              * che normalizzare le percentuali di sconto in ri-*
      *              * ga ed uscire                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
           go to     det-psr-001-999.
       det-psr-001-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' secondaria per l'acquisto        *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/wdetqts0.wks"                   .

      *    *===========================================================*
      *    * Determinazione importo in riga                            *
      *    *-----------------------------------------------------------*
       det-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per la determinazione    *
      *              *-------------------------------------------------*
           move      "IR"                 to   d-imp-acq-tip-ope      .
           move      w-rig-qta-fda (1)    to   d-imp-acq-qta-acq      .
           move      w-rig-prz-acq (1)    to   d-imp-acq-prz-uni      .
           move      w-rig-dec-prz (1)    to   d-imp-acq-dec-prz      .
           move      w-rig-per-scr (1, 1) to   d-imp-acq-per-scr (1)  .
           move      w-rig-per-scr (1, 2) to   d-imp-acq-per-scr (2)  .
           move      w-rig-per-scr (1, 3) to   d-imp-acq-per-scr (3)  .
           move      w-rig-per-scr (1, 4) to   d-imp-acq-per-scr (4)  .
           move      w-rig-per-scr (1, 5) to   d-imp-acq-per-scr (5)  .
           move      w-tes-tip-mci (1)    to   d-imp-acq-tip-clc      .
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           perform   det-imp-acq-cll-000  thru det-imp-acq-cll-999    .
      *              *-------------------------------------------------*
      *              * In campo di uscita                              *
      *              *-------------------------------------------------*
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
       det-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali da righe prima del trattamento piede*
      *    *-----------------------------------------------------------*
       det-tot-rig-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione totalizzatori per tipo prodotto *
      *              *-------------------------------------------------*
           perform   nor-tot-rig-000      thru nor-tot-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione comodo per totale volume        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vol-tot-tvr      .
      *              *-------------------------------------------------*
      *              * Normalizzazione totale volume                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-vol (1)      .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : uscita                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento totalizzatori per tipo prodotto   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga P o PN                         *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to det-tot-rig-120.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo prodotto    *
      *                  *---------------------------------------------*
           if        w-rig-tip-pro (1)    =    01
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 01)
           else if   w-rig-tip-pro (1)    =    02
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 02)
           else if   w-rig-tip-pro (1)    =    03
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 03)
           else if   w-rig-tip-pro (1)    =    09
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 09)  .
      *                  *---------------------------------------------*
      *                  * Eventuale aggiornamento importo 'ricevuto'  *
      *                  *---------------------------------------------*
           perform   det-imp-ric-000      thru det-imp-ric-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale determinazione volume             *
      *                  *---------------------------------------------*
           perform   det-vol-tot-000      thru det-vol-tot-999        .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     det-tot-rig-180.
       det-tot-rig-120.
      *                  *---------------------------------------------*
      *                  * Se tipo riga M o V                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to det-tot-rig-140.
           add       w-rig-imp-rig (1)    to   w-pie-tot-rig (1, 01)  .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     det-tot-rig-180.
       det-tot-rig-140.
      *                  *---------------------------------------------*
      *                  * Se tipo riga A                              *
      *                  *---------------------------------------------*
           add       w-rig-imp-rig (1)    to   w-pie-tot-rta (1)      .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     det-tot-rig-180.
       det-tot-rig-180.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione righe                      *
      *              *-------------------------------------------------*
           go to     det-tot-rig-100.
       det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Determinazione totale lordo                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 01)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 02)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 03)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 09)
                                          to   w-pie-tot-lor (1)      .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       det-tot-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo totale ricevuto                    *
      *    *-----------------------------------------------------------*
       det-imp-ric-000.
      *              *-------------------------------------------------*
      *              * Test se da determinare                          *
      *              *-------------------------------------------------*
           if        w-prs-tvn-rgd        not  = 11
                     go to det-imp-ric-999.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' secondaria eventuale   *
      *              *-------------------------------------------------*
           move      w-rig-qta-ric (1)    to   w-det-qta-sec-qim      .
           move      w-rig-dec-qta (1)    to   w-det-qta-sec-dgm      .
           move      w-rig-snx-tum (1)    to   w-det-qta-sec-snu      .
           move      w-rig-umf-tum (1)    to   w-det-qta-sec-umf      .
           move      w-rig-nde-tum (1)    to   w-det-qta-sec-ndu      .
           move      w-rig-cmo-tum (1)    to   w-det-qta-sec-cmu      .
           move      w-rig-cdi-tum (1)    to   w-det-qta-sec-cdu      .
           perform   det-qta-sec-000      thru det-qta-sec-999        .
      *              *-------------------------------------------------*
      *              * Preparazione parametri per la determinazione    *
      *              *-------------------------------------------------*
           move      "IR"                 to   d-imp-acq-tip-ope      .
           move      w-det-qta-sec-qts    to   d-imp-acq-qta-acq      .
           move      w-rig-prz-acq (1)    to   d-imp-acq-prz-uni      .
           move      w-rig-dec-prz (1)    to   d-imp-acq-dec-prz      .
           move      w-rig-per-scr (1, 1) to   d-imp-acq-per-scr (1)  .
           move      w-rig-per-scr (1, 2) to   d-imp-acq-per-scr (2)  .
           move      w-rig-per-scr (1, 3) to   d-imp-acq-per-scr (3)  .
           move      w-rig-per-scr (1, 4) to   d-imp-acq-per-scr (4)  .
           move      w-rig-per-scr (1, 5) to   d-imp-acq-per-scr (5)  .
           move      w-tes-tip-mci (1)    to   d-imp-acq-tip-clc      .
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           perform   det-imp-acq-cll-000  thru det-imp-acq-cll-999    .
      *              *-------------------------------------------------*
      *              * Aggiornamento totale ricevuto                   *
      *              *-------------------------------------------------*
           add       d-imp-acq-imp-rig    to   w-pie-tot-ric (1)      .
       det-imp-ric-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-imp-ric-999.
       det-imp-ric-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale volume                              *
      *    *-----------------------------------------------------------*
       det-vol-tot-000.
      *              *-------------------------------------------------*
      *              * Test se da determinare                          *
      *              *-------------------------------------------------*
           if        w-tes-tmo-orf-stv    not  = "S"
                     go to det-vol-tot-999.
       det-vol-tot-100.
      *              *-------------------------------------------------*
      *              * Determinazione del volume in riga               *
      *              *                                                 *
      *              * N.B.: Attualmente il calcolo avviene secondo la *
      *              *       formula :                                 *
      *              *                                                 *
      *              *       (VOLUME PRODOTTO :                        *
      *              *        QTA' PER CONFEZIONE) x QTA' ORDINATA     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica prodotto                 *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dcp-cod      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione confezione        *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-qcf    =    zero
                     move  1              to   w-let-arc-dcp-qcf      .
           divide    w-let-arc-dcp-qcf       into w-rig-qta-ord (1)
                                        giving w-det-vol-tot-tvr      .
           multiply  w-let-arc-dcp-vol    by   w-det-vol-tot-tvr      .
      *                  *---------------------------------------------*
      *                  * Incremento totale volume                    *
      *                  *---------------------------------------------*
           add       w-det-vol-tot-tvr    to   w-pie-tot-vol (1)      .
       det-vol-tot-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali riepilogo documento                 *
      *    *-----------------------------------------------------------*
       det-tri-doc-000.
      *              *-------------------------------------------------*
      *              * Determinazione totale sconto in chiusura        *
      *              *-------------------------------------------------*
           perform   det-tot-scc-000      thru det-tot-scc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale al netto dello sconto in  *
      *              * chiusura                                        *
      *              *-------------------------------------------------*
           perform   det-tot-nsc-000      thru det-tot-nsc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione importi spese                    *
      *              *-------------------------------------------------*
           perform   det-imp-spe-000      thru det-imp-spe-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale al netto delle spese in   *
      *              * fattura                                         *
      *              *-------------------------------------------------*
           perform   det-tot-nsf-000      thru det-tot-nsf-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale sconto pagamento          *
      *              *-------------------------------------------------*
           perform   det-tot-scp-000      thru det-tot-scp-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale netto                     *
      *              *-------------------------------------------------*
           perform   det-tot-net-000      thru det-tot-net-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale spese                     *
      *              *-------------------------------------------------*
           perform   det-tot-spe-000      thru det-tot-spe-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale documento                 *
      *              *-------------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
       det-tri-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto in chiusura                  *
      *    *-----------------------------------------------------------*
       det-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-tot-scc-flg      .
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-pie-tot-scc (1)    =    zero and
                     w-pie-per-scc (1)    =    zero
                     go to det-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to in chiusura e' stato impostato manualmente   *
      *              * nel piede                                       *
      *              *-------------------------------------------------*
           if        w-pie-per-scc (1)    =    zero
                     go to det-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-pie-per-scc (1)    by   w-pie-tot-lor (1)
                                        giving w-pie-tot-scc (1)      .
           divide    100                  into w-pie-tot-scc (1)
                                       rounded                        .
       det-tot-scc-100.
       det-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto dello sonto in chiusura    *
      *    *-----------------------------------------------------------*
       det-tot-nsc-000.
           subtract  w-pie-tot-scc (1)    from w-pie-tot-lor (1)
                                        giving w-pie-tot-nsc (1)      .
       det-tot-nsc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo spese in fattura                   *
      *    *-----------------------------------------------------------*
       det-imp-spe-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-imp-spe-flg      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-spe-c01      .
       det-imp-spe-050.
           add       1                    to   w-det-imp-spe-c01      .
           if        w-det-imp-spe-c01    >    w-prs-spe-fat-nst
                     go to det-imp-spe-999.
      *              *-------------------------------------------------*
      *              * Determinazione indice per la spesa              *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-imp-spe-c01)   to   w-det-imp-spe-inx      .
      *              *-------------------------------------------------*
      *              * Se spesa da non addebitare : riciclo            *
      *              *-------------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-imp-spe-inx)
                                          =    0
                     go to det-imp-spe-050.
      *              *-------------------------------------------------*
      *              * Se modalita' di addebito ad importo : ad aggior-*
      *              * namenti                                         *
      *              *-------------------------------------------------*
           if        w-pie-spe-mad
                    (1, w-det-imp-spe-inx)
                                          =    3 or
                     w-pie-spe-mad
                    (1, w-det-imp-spe-inx)
                                          =    4
                     go to det-imp-spe-500.
       det-imp-spe-100.
      *              *-------------------------------------------------*
      *              * Se modalita' di addebito a percentuale          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione imponibile per la spesa     *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-spe-ibl      .
      *                  *---------------------------------------------*
      *                  * Determinazione imponibile per la spesa      *
      *                  *---------------------------------------------*
           if        w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    01
                     move w-pie-tot-lor (1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    02
                     move w-pie-tot-nsc (1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    03
                     go to det-imp-spe-220
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    11
                     move w-pie-tot-rig (1, 1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    12
                     move w-pie-tot-rig (1, 2)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    13
                     move w-pie-tot-rig (1, 3)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    14
                     move w-pie-tot-rig (1, 4)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    15
                     move w-pie-tot-rig (1, 5)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    16
                     move w-pie-tot-rig (1, 6)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    17
                     move w-pie-tot-rig (1, 7)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    18
                     move w-pie-tot-rig (1, 8)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    19
                     move w-pie-tot-rig (1, 9)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-250.
       det-imp-spe-220.
      *                      *-----------------------------------------*
      *                      * Se risulta da una combinazione di tota- *
      *                      * li                                      *
      *                      *-----------------------------------------*
           move      w-pie-spe-ibt
                    (1, w-det-imp-spe-inx)
                                          to   w-det-imp-spe-ibt      .
           move      zero                 to   w-det-imp-spe-c02      .
       det-imp-spe-225.
           add       1                    to   w-det-imp-spe-c02      .
           if        w-det-imp-spe-c02    >    9
                     go to det-imp-spe-250.
           if        w-det-imp-spe-ibx
                    (w-det-imp-spe-c02)   not  = "S"
                     go to det-imp-spe-225.
           add       w-pie-tot-rig
                    (1, w-det-imp-spe-c02)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-225.
       det-imp-spe-250.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  w-pie-spe-per
                    (1, w-det-imp-spe-inx)
                                          by   w-det-imp-spe-ibl
                                        giving w-pie-spe-imp
                                              (1, w-det-imp-spe-inx)  .
           divide    100                  into w-pie-spe-imp
                                              (1, w-det-imp-spe-inx)
                                                            rounded   .
       det-imp-spe-500.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella                    *
      *              *-------------------------------------------------*
           go to     det-imp-spe-050.
       det-imp-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto delle spese in fattura     *
      *    *-----------------------------------------------------------*
       det-tot-nsf-000.
      *              *-------------------------------------------------*
      *              * Azzeramento work per accumulo spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-was      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-ctr      .
       det-tot-nsf-100.
           add       1                    to   w-det-tot-nsf-ctr      .
           if        w-det-tot-nsf-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-nsf-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-nsf-ctr)   to   w-det-tot-nsf-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-tot-nsf-inx)
                                          =    0
                     go to det-tot-nsf-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-pie-spe-imp
                    (1, w-det-tot-nsf-inx)
                                          to   w-det-tot-nsf-was      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-nsf-100.
       det-tot-nsf-200.
      *              *-------------------------------------------------*
      *              * Determinazione valore                           *
      *              *-------------------------------------------------*
           move      w-pie-tot-nsc (1)    to    w-pie-tot-nsf (1)     .
           add       w-det-tot-nsf-was    to    w-pie-tot-nsf (1)     .
       det-tot-nsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto pagamento                    *
      *    *-----------------------------------------------------------*
       det-tot-scp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-tot-scp-flg      .
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-pie-tot-scp (1)    =    zero and
                     w-pie-per-scp (1)    =    zero
                     go to det-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to pagamento e' stato impostato manualmente nel *
      *              * piede                                           *
      *              *-------------------------------------------------*
           if        w-pie-per-scp (1)    =    zero
                     go to det-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-pie-per-scp (1)    by   w-pie-tot-nsf (1)
                                        giving w-pie-tot-scp (1)      .
           divide    100                  into w-pie-tot-scp (1)
                                       rounded                        .
       det-tot-scp-100.
       det-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale netto                               *
      *    *-----------------------------------------------------------*
       det-tot-net-000.
           subtract  w-pie-tot-scc (1)    from w-pie-tot-lor (1)
                                        giving w-pie-tot-net (1)      .
           subtract  w-pie-tot-scp (1)    from w-pie-tot-net (1)      .
       det-tot-net-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale spese                               *
      *    *-----------------------------------------------------------*
       det-tot-spe-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-spe (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spe-ctr      .
       det-tot-spe-100.
           add       1                    to   w-det-tot-spe-ctr      .
           if        w-det-tot-spe-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-spe-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-spe-ctr)   to   w-det-tot-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-tot-spe-inx)
                                          =    0
                     go to det-tot-spe-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-pie-spe-imp
                    (1, w-det-tot-spe-inx)
                                          to   w-pie-tot-spe (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-spe-100.
       det-tot-spe-200.
       det-tot-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
           add       w-pie-tot-net (1)
                     w-pie-tot-spe (1)
                     w-pie-tot-rta (1)  giving w-pie-tot-doc (1)      .
       det-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Controllo tipo riga                                       *
      *    *-----------------------------------------------------------*
       ctl-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-tip-rig-flg      .
      *              *-------------------------------------------------*
      *              * Test che non ci siano blanks embedded           *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-tri    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Controllo se ci sono asterischi                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-tip-rig-inx      .
           inspect   w-ctl-tip-rig-tri
                                      tallying w-ctl-tip-rig-inx
                                          for  all "*"                .
      *               *------------------------------------------------*
      *               * Deviazione in funzione del numero di asterischi*
      *               * trovati                                        *
      *               *------------------------------------------------*
           if        w-ctl-tip-rig-inx    =    zero
                     go to ctl-tip-rig-200
           else if   w-ctl-tip-rig-inx    =    1
                     go to ctl-tip-rig-100
           else      go to ctl-tip-rig-900.
       ctl-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se c'e' un asterisco                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sostituzione con carattere spazio           *
      *                  *---------------------------------------------*
           inspect   w-ctl-tip-rig-tri
                                     replacing all "*" by   spaces    .
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-ctl-tip-rig-tri    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to ctl-tip-rig-900.
      *                  *---------------------------------------------*
      *                  * Segnale di presenza di asterisco            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-rig-tip-rig-ast (1)  .
      *                  ***********************************************
      *                  * Non essendo ancora attivata la gestione a   *
      *                  * blocchi, la presenza dell'asterisco viene   *
      *                  * considerata errore                          *
      *                  ***********************************************
           go to     ctl-tip-rig-900.
       ctl-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Test se valore ammesso                          *
      *              *-------------------------------------------------*
           if        w-ctl-tip-rig-tri    not  = "P    " and
                     w-ctl-tip-rig-tri    not  = "PN   " and
                     w-ctl-tip-rig-tri    not  = "M    " and
                     w-ctl-tip-rig-tri    not  = "V    " and
                     w-ctl-tip-rig-tri    not  = "C    " and
                     w-ctl-tip-rig-tri    not  = "A    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Se gestione materie prime non attiva : il tipo  *
      *              * riga non puo' essere 'M'                        *
      *              *-------------------------------------------------*
           if        w-prs-dpm-snx        not  = "S"   and
                     w-ctl-tip-rig-tri    =    "M    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Se gestione materiali vari non attiva : il tipo *
      *              * riga non puo' essere 'V'                        *
      *              *-------------------------------------------------*
           if        w-prs-mtv-snx        not  = "S"   and
                     w-ctl-tip-rig-tri    =    "V    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo riga                        *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (1)
                                          to   w-rig-tip-rig-tpr (1)  .
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo funzionamento               *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (2)
                                          to   w-rig-tip-rig-tfu (1)  .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-tip-rig-999.
       ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita con errore                               *
      *              *-------------------------------------------------*
           move      "#"                  to   w-ctl-tip-rig-flg      .
       ctl-tip-rig-999.
           exit.

