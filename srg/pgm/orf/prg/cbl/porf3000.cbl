      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo ordini fornitori*
      *    *-----------------------------------------------------------*
       att-orf-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [orfprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-orf-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-orf-prt-saa      .
           move      w-att-orf-prt-saa    to   rn-orf-prt-scl-ann     .
           move      w-att-orf-prt-dpz    to   rn-orf-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [orfprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-orf-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-orf-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-orf-prt-000.
       att-orf-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-orf-prt-num-prt   to   w-att-orf-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-orf-prt-wpr      .
           if        w-att-orf-prt-wpr    =    zero
                     move  1              to   w-att-orf-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-orf-prt-saa    to   w-att-orf-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-orf-prt-dpz    to   w-att-orf-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-orf-prt-wnu    to   rn-orf-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-orf-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-orf-prt-num-prt   to   w-att-orf-prt-num      .
       att-orf-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo ordini fornitori  *
      *    *-----------------------------------------------------------*
       rip-orf-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [orfprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-orf-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-orf-prt-saa      .
           move      w-att-orf-prt-saa    to   rn-orf-prt-scl-ann     .
           move      w-att-orf-prt-dpz    to   rn-orf-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [orfprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-orf-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-orf-prt-num-prt   not  = w-att-orf-prt-num
                     go to  rip-orf-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           move      w-att-orf-prt-num    to   w-att-orf-prt-wnu      .
           subtract  1                    from w-att-orf-prt-wpr      .
           if        w-att-orf-prt-wpr    =    zero
                     move  zero           to   w-att-orf-prt-wnu      .
           move      w-att-orf-prt-wnu    to   rn-orf-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfprt"
