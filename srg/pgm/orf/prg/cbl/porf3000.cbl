      *    *-----------------------------------------------------------*
       loa-dpz-ids-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare area w-exp-dpz-ids  *
      *              *-------------------------------------------------*
           move      zero                 to   w-exp-dpz-ids-num      .
           move      spaces               to   w-exp-dpz-ids-tbl      .
           move      zero                 to   w-exp-dpz-ids-c01      .
       loa-dpz-ids-010.
           add       1                    to   w-exp-dpz-ids-c01      .
           if        w-exp-dpz-ids-c01    >    w-exp-dpz-ids-max
                     go to loa-dpz-ids-100.
           move      zero                 to   w-exp-dpz-ids-cod
                                              (w-exp-dpz-ids-c01)     .
           move      spaces               to   w-exp-dpz-ids-des
                                              (w-exp-dpz-ids-c01)     .
           go to     loa-dpz-ids-010.
       loa-dpz-ids-100.
      *              *-------------------------------------------------*
      *              * Start su tabella dipendenze determinate         *
      *              *-------------------------------------------------*
           move      zero                 to   w-exp-dpz-ids-c01      .
       loa-dpz-ids-200.
           add       1                    to   w-exp-dpz-ids-c01      .
           if        w-exp-dpz-ids-c01    >    w-exp-dpz-ids-max
                     go to loa-dpz-ids-900.
           if        w-exp-dpz-ids-c01    >    w-dpz-ctr-dpz
                     go to loa-dpz-ids-900.
           if        w-exp-dpz-ids-c01    =    w-tes-cod-dpz
                     go to loa-dpz-ids-200.
           if        w-dpz-ele-den
                    (w-exp-dpz-ids-c01)   =    spaces
                     go to loa-dpz-ids-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazionde denominazione dipendenza       *
      *              *-------------------------------------------------*
