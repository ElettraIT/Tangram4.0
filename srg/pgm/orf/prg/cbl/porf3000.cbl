                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-ndo             .
           if        f-sts                =    e-not-err
                     go to att-orf-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-orf-ndo-num-doc     .
           move      zero                 to   rn-orf-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
