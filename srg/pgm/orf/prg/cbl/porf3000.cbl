           if        v-key                =    "EXIT"
                     go to att-orf-ndo-440.
           go to     att-orf-ndo-430.
       att-orf-ndo-440.
      *                              *---------------------------------*
      *                              * Ripristino immagine video       *
      *                              *---------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Esame risposta                  *
      *                              *---------------------------------*
           if        v-key                =    "EXIT"
                     move  "#"            to   w-att-orf-ndo-flg
                     go to att-orf-ndo-600.
           if        w-exp-rat-ndo-sce    =    01
                     go to att-orf-ndo-500
           else if   w-exp-rat-ndo-sce    =    02
                     go to att-orf-ndo-600.
       att-orf-ndo-500.
      *                              *---------------------------------*
      *                              * Se risposta positiva            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Aggiornamento numerazione   *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Numero                  *
      *                                      *-------------------------*
           move      w-att-orf-ndo-num    to   w-att-orf-ndo-wnu      .
           move      w-att-orf-ndo-saa    to   w-att-orf-ndo-wsa      .
           move      w-att-orf-ndo-dpz    to   w-att-orf-ndo-wdz      .
           move      w-att-orf-ndo-wnu    to   rn-orf-ndo-num-doc     .
      *                                      *-------------------------*
      *                                      * Data                    *
      *                                      *-------------------------*
           move      w-att-orf-ndo-dat    to   rn-orf-ndo-dat-doc     .
      *                                  *-----------------------------*
      *                                  * Update record               *
      *                                  *-----------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orf-ndo             .
      *                                  *-----------------------------*
      *                                  * Se errori ripete l'intera   *
      *                                  * operazione                  *
      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to att-orf-ndo-000.
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orf/num/ioc/obj/inorfndo"
                                          to   s-pat                  .
