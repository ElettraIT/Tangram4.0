      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice condizioni di   *
      *    * acquisto                                                  *
      *    *-----------------------------------------------------------*
       cod-mne-yca-opn-000.
           move      "pgm/orf/prg/obj/acmnyca0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-mne-yca-pth      .
           move      "OP"                 to   w-cod-mne-yca-ope      .
           perform   cod-mne-yca-cll-000  thru cod-mne-yca-cll-999    .
       cod-mne-yca-opn-999.
           exit.
       cod-mne-yca-cls-000.
           move      "CL"                 to   w-cod-mne-yca-ope      .
           perform   cod-mne-yca-cll-000  thru cod-mne-yca-cll-999    .
           move      "C?"                 to   w-cod-mne-yca-ope      .
           perform   cod-mne-yca-cll-000  thru cod-mne-yca-cll-999    .
           if        w-cod-mne-yca-ope    not  = spaces
                     go to cod-mne-yca-cls-999.
           cancel    w-cod-mne-yca-pth                                .
       cod-mne-yca-cls-999.
           exit.
       cod-mne-yca-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-mne-yca-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "porf0200"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-yca-foi-999.
           move      "pgm/orf/prg/obj/porf0200"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-mne-yca-ope      .
           go to     cod-mne-yca-foi-999.
       cod-mne-yca-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-mne-yca-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "porf0210"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-yca-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/orf/prg/obj/porf0210"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-mne-yca-ope      .
           go to     cod-mne-yca-foi-999.
       cod-mne-yca-foi-999.
           exit.
       cod-mne-yca-cll-000.
           call      w-cod-mne-yca-pth   using w-cod-mne-yca
                                               v
                                               s                      .
       cod-mne-yca-cll-999.
           exit.
