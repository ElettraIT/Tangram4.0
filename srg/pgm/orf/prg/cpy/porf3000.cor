           go to     vis-lin-cor-532.
       vis-lin-cor-528.
      *                          *-------------------------------------*
      *                          * Se il tipo riga indica che non si   *
      *                          * sta trattando un codice di magaz-   *
      *                          * zino                                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * A visualizzazione della sola    *
      *                              * intera descrizione              *
      *                              *---------------------------------*
           go to     vis-lin-cor-530.
       vis-lin-cor-530.
      *                              *---------------------------------*
      *                              * Visualizzazione della sola in-  *
      *                              * tera descrizione                *
      *                              *---------------------------------*
           move      w-rig-der-rig (1, 1) to   w-lin-imm-des-rig      .
       vis-lin-cor-532.
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     vis-lin-cor-550.
       vis-lin-cor-550.
      *                      *-----------------------------------------*
      *                      * Editing quantita' e prezzo              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo riga  *
      *                          *-------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-lin-cor-575
           else      go to vis-lin-cor-600.
       vis-lin-cor-575.
      *                          *-------------------------------------*
      *                          * Se tipo riga "A"                    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing dell'importo incolonna- *
      *                              * to con il prezzo                *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-imp-aoa      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     vis-lin-cor-650.
       vis-lin-cor-600.
      *                          *-------------------------------------*
      *                          * Se tipo riga diverso da "A"         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing quantita'               *
      *                              *---------------------------------*
           move      "ED"                 to   w-edt-qta-inc-ope      .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-ord (1)
                                          to   w-edt-qta-inc-qta
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-ord (1)
                                          to   w-edt-qta-inc-qta
           else      move  w-rig-qta-fda (1)
                                          to   w-edt-qta-inc-qta      .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   w-edt-qta-inc-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   w-edt-qta-inc-dec
           else      move  w-rig-dec-qta (1)
                                          to   w-edt-qta-inc-dec      .
      *
           move      "S"                  to   w-edt-qta-inc-sgn      .
           move      11                   to   w-edt-qta-inc-car      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
           move      w-edt-qta-inc-edt    to   w-lin-imm-qta-fda      .
      *                              *---------------------------------*
      *                              * Editing prezzo                  *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-rig-prz-acq (1)    >    9999999
                     move  09             to   v-car
           else      move  07             to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           if        w-rig-prz-acq (1)    >    9999999
                     move  "B"            to   v-edm
           else      move  "GB"           to   v-edm                  .
           move      w-rig-prz-acq (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-prz-acq      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     vis-lin-cor-650.
       vis-lin-cor-650.
      *                      *-----------------------------------------*
      *                      * Editing importo                         *
      *                      *-----------------------------------------*
       vis-lin-cor-652.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo riga  *
      *                          *-------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "P"  and
                     w-rig-tip-rig-tfu (1)
                                          =    spaces ) or
                     w-rig-tip-rig-tpr (1)
                                          =    "M"      or
                     w-rig-tip-rig-tpr (1)
                                          =    "V"
                     go to vis-lin-cor-654
           else      go to vis-lin-cor-660.
       vis-lin-cor-654.
      *                          *-------------------------------------*
      *                          * Se il tipo riga indica che si sta   *
      *                          * trattando un codice di magazzino    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione a seconda della per- *
      *                              * sonalizzazione di tipo esposi-  *
      *                              * zione importo                   *
      *                              *---------------------------------*
           if        w-prs-rig-scr-imp    =    "I"
                     go to vis-lin-cor-656
           else if   w-prs-rig-scr-imp    =    "C"
                     go to vis-lin-cor-658
           else if   w-prs-rig-scr-imp    =    "E"
                     go to vis-lin-cor-659
           else      go to vis-lin-cor-656.
       vis-lin-cor-656.
      *                              *---------------------------------*
      *                              * Se la personalizzazione indica  *
      *                              * l'esposizione dell'importo      *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Ad editing importo          *
      *                                  *-----------------------------*
           go to     vis-lin-cor-662.
       vis-lin-cor-658.
      *                              *---------------------------------*
      *                              * Se la personalizzazione indica  *
      *                              * l'esposizione della data di     *
      *                              * consegna                        *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing data di consegna    *
      *                                  *-----------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-rig-dcn-ric (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-imp-dtc      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-670.
       vis-lin-cor-659.
      *                              *---------------------------------*
      *                              * Se la personalizzazione indica  *
      *                              * l'esposizione della data di     *
      *                              * consegna richiesta e la data    *
      *                              * consegna prevista con i relati- *
      *                              * vi flags                        *
      *                              *                                 *
      *                              * N.B.: Le date sono nel formato  *
      *                              *       gg/mm                     *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing data di consegna    *
      *                                  * richiesta                   *
      *                                  *-----------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-rig-dcn-ric (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-imp-dcr      .
      *                                  *-----------------------------*
      *                                  * Flag di stampa data con-    *
      *                                  * segna richiesta             *
      *                                  *-----------------------------*
           move      w-rig-fds-dcr (1)    to   w-lin-imm-imp-fds      .
      *                                  *-----------------------------*
      *                                  * Editing data di consegna    *
      *                                  * prevista                    *
      *                                  *-----------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-rig-dcn-prv (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-imp-dcp      .
      *                                  *-----------------------------*
      *                                  * Flag di conferma data di    *
      *                                  * consegna prevista           *
      *                                  *-----------------------------*
           move      w-rig-flg-cnf (1)    to   w-lin-imm-imp-fcn      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-670.
       vis-lin-cor-660.
      *                          *-------------------------------------*
      *                          * Se il tipo riga indica che non si   *
      *                          * sta trattando un codice di magaz-   *
      *                          * zino                                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se il tipo riga e' "PN" : come  *
      *                              * per un codice di magazzino      *
      *                              *---------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to vis-lin-cor-654.
      *                              *---------------------------------*
      *                              * Se il tipo riga e' "A" : come   *
      *                              * per un codice di magazzino      *
      *                              *---------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-lin-cor-654.
      *                              *---------------------------------*
      *                              * Altrimenti : ad editing importo *
      *                              *---------------------------------*
           go to     vis-lin-cor-662.
       vis-lin-cor-662.
      *                          *-------------------------------------*
      *                          * Editing importo                     *
      *                          *-------------------------------------*
       vis-lin-cor-664.
      *                              *---------------------------------*
      *                              * Deviazione a seconda del tipo   *
      *                              * riga                            *
      *                              *---------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-lin-cor-666
           else      go to vis-lin-cor-668.
       vis-lin-cor-666.
      *                              *---------------------------------*
      *                              * Se tipo riga "A" : nessun edi-  *
      *                              * ting dell'importo, in quanto    *
      *                              * gia' eseguito nella colonna     *
      *                              * per il prezzo                   *
      *                              *---------------------------------*
           go to     vis-lin-cor-670.
       vis-lin-cor-668.
      *                              *---------------------------------*
      *                              * Se tipo riga diverso da "A" si  *
      *                              * edita l'importo                 *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           if        w-rig-imp-rig (1)    >    9999999999 or
                     w-rig-imp-rig (1)    <   -9999999999
                     if    w-tes-dec-vpf (1)
                                          =    0
                           move  13       to   v-car
                     else  move  12       to   v-car
           else      move  10             to   v-car                  .
           subtract  w-tes-dec-vpf (1)    from v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           if        w-rig-imp-rig (1)    >    9999999999 or
                     w-rig-imp-rig (1)    <   -9999999999
                     move  "B"            to   v-edm
           else      move  "GB"           to   v-edm                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           if        w-tes-dec-vpf (1)    =    1
                     divide 10            into v-num
           else if   w-tes-dec-vpf (1)    =    2
                     divide 100           into v-num
           else if   w-tes-dec-vpf (1)    =    3
                     divide 1000          into v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-imp-rig      .
       vis-lin-cor-670.
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     vis-lin-cor-800.
       vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Parametri per visualizzazione           *
      *                      *-----------------------------------------*
           move      80                   to   v-car                  .
       vis-lin-cor-900.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione prima linea          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se una sola linea : uscita                      *
      *              *-------------------------------------------------*
           if        w-lin-num-lin-prc    =    1
                     go to vis-lin-cor-999.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione altre linee          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-wrk-ctr-003      .
       vis-lin-cor-925.
           add       1                    to   w-cnt-wrk-ctr-003      .
           if        w-cnt-wrk-ctr-003    >    w-lin-num-lin-prc
                     go to vis-lin-cor-999.
           add       1                    to   w-cnt-wrk-ctr-002      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin
                    (w-cnt-wrk-ctr-003)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-lin-cor-925.
       vis-lin-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate sia dall'area per la fin- *
      *              * catura che dall'area delle righe effettive      *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      12                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-200.
      *              *-------------------------------------------------*
      *              * Numero riga                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
