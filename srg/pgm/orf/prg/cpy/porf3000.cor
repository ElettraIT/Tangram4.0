      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se fase di duplicazioone riga precedente : si   *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rig    =    "4"
                     go to vis-rig-cor-100.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
       vis-rig-cor-100.
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : tipo riga         *
      *              *-------------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
      *              *-------------------------------------------------*
      *              * Segnale di riga chiusa                          *
      *              *-------------------------------------------------*
           perform   vis-flg-rch-000      thru vis-flg-rch-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : codice addebito o *
      *              *                               commento          *
      *              *-------------------------------------------------*
           perform   vis-cod-aoc-000      thru vis-cod-aoc-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : codice prodotto   *
      *              *-------------------------------------------------*
           perform   vis-cod-pro-000      thru vis-cod-pro-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : formato di acqui- *
      *              * sizione                                         *
      *              *-------------------------------------------------*
           perform   vis-fda-pif-000      thru vis-fda-pif-999        .
      *              *-------------------------------------------------*
      *              * Codice prodotto secondo fornitore               *
      *              *-------------------------------------------------*
           perform   vis-cop-sfn-000      thru vis-cop-sfn-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : descrizione       *
      *              *-------------------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *              *-------------------------------------------------*
      *              * Codice prodotto per la casa produttrice         *
      *              *-------------------------------------------------*
           perform   vis-cdp-pdt-000      thru vis-cdp-pdt-999        .
      *              *-------------------------------------------------*
      *              * Campo di accettazione corpo : quantita' prima-  *
      *              * ria                                             *
      *              *-------------------------------------------------*
           perform   vis-qta-pri-000      thru vis-qta-pri-999        .
      *              *-------------------------------------------------*
      *              * Quantita' secondaria                            *
      *              *-------------------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
      *              *-------------------------------------------------*
      *              * Unita' di misura                                *
      *              *-------------------------------------------------*
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *              *-------------------------------------------------*
      *              * Flag non bloccante 1                            *
      *              *-------------------------------------------------*
           perform   vis-flg-xb1-000      thru vis-flg-xb1-999        .
      *              *-------------------------------------------------*
      *              * Flag non bloccante 2                            *
      *              *-------------------------------------------------*
           perform   vis-flg-xb2-000      thru vis-flg-xb2-999        .
      *              *-------------------------------------------------*
      *              * Flag non bloccante 3                            *
      *              *-------------------------------------------------*
           perform   vis-flg-xb3-000      thru vis-flg-xb3-999        .
      *              *-------------------------------------------------*
      *              * Prezzo                                          *
      *              *-------------------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *              *-------------------------------------------------*
      *              * Sigla valuta per il legame valutario            *
      *              *-------------------------------------------------*
           perform   vis-sgl-vpl-000      thru vis-sgl-vpl-999        .
      *              *-------------------------------------------------*
      *              * Coefficiente di cambio per legame valutario     *
      *              *-------------------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
      *              *-------------------------------------------------*
      *              * Percentuale di tolleranza per legame valutario  *
      *              *-------------------------------------------------*
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
      *              *-------------------------------------------------*
      *              * Tipo di limitazione per legame valutario        *
      *              *-------------------------------------------------*
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *              *-------------------------------------------------*
      *              * % sconto in riga                                *
      *              *-------------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *              *-------------------------------------------------*
      *              * Importo in riga                                 *
      *              *-------------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Data consegna richiesta                         *
      *              *-------------------------------------------------*
           perform   vis-dcn-ric-000      thru vis-dcn-ric-999        .
      *              *-------------------------------------------------*
      *              * Formato di stampa data consegna richiesta       *
      *              *-------------------------------------------------*
           perform   vis-fds-dcr-000      thru vis-fds-dcr-999        .
      *              *-------------------------------------------------*
      *              * Data consegna prevista                          *
      *              *-------------------------------------------------*
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
      *              *-------------------------------------------------*
      *              * Flag di conferma da fornitore                   *
      *              *-------------------------------------------------*
           perform   vis-flg-cnf-000      thru vis-flg-cnf-999        .
      *              *-------------------------------------------------*
      *              * Data consegna confermata                        *
      *              *-------------------------------------------------*
           perform   vis-dcn-cnf-000      thru vis-dcn-cnf-999        .
      *              *-------------------------------------------------*
      *              * Codice iva                                      *
      *              *-------------------------------------------------*
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *              *-------------------------------------------------*
      *              * Riferimento al listino                          *
      *              *-------------------------------------------------*
           perform   vis-rif-lst-000      thru vis-rif-lst-999        .
      *              *-------------------------------------------------*
      *              * Contropartita                                   *
      *              *-------------------------------------------------*
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga corpo espansa  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo riga         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Codice prodotto                             *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
      *                  *---------------------------------------------*
      *                  * Formato di acquisizione                     *
      *                  *---------------------------------------------*
           perform   pmt-fda-pif-000      thru pmt-fda-pif-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione                                 *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Descrizione       :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Quantita'                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Quantita'         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Flag non bloccante 1                        *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb1-000      thru pmt-flg-xb1-999        .
      *                  *---------------------------------------------*
      *                  * Flag non bloccante 2                        *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb2-000      thru pmt-flg-xb2-999        .
      *                  *---------------------------------------------*
      *                  * Flag non bloccante 3                        *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb3-000      thru pmt-flg-xb3-999        .
      *                  *---------------------------------------------*
      *                  * Prezzo                                      *
      *                  *---------------------------------------------*
           perform   pmt-prz-acq-000      thru pmt-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Legame valutario                            *
      *                  *---------------------------------------------*
           perform   pmt-leg-val-000      thru pmt-leg-val-999        .
      *                  *---------------------------------------------*
      *                  * % sconto                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "% sconto          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Importo                                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      "Importo :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Data consegna richiesta                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Consegna richiesta:"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Formato di stampa data consegna richiesta   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Prevista:"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Flag di conferma da fornitore               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Data consegna confermata                    *
      *                  *---------------------------------------------*
           perform   pmt-dcn-cnf-000      thru pmt-dcn-cnf-999        .
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice iva        :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Riferimento al listino                      *
      *                  *---------------------------------------------*
           perform   pmt-rif-lst-000      thru pmt-rif-lst-999        .
      *                  *---------------------------------------------*
      *                  * Contropartita                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Contropartita     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per note in righe docu- *
      *              * mento                                           *
      *              *-------------------------------------------------*
           move      "PM"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Codice prodotto                                           *
      *    *-----------------------------------------------------------*
       pmt-cod-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      01                   to   v-pos                  .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  "Codice addebito   :"
                                          to   v-alf
           else if   w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento   :"
                                          to   v-alf
           else      move  "Codice prodotto   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Formato di acquisizione                                   *
      *    *-----------------------------------------------------------*
       pmt-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-snx-fda        =    "N"
                     go to pmt-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "Formato :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Flag non bloccante 1                                      *
      *    *-----------------------------------------------------------*
       pmt-flg-xb1-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione prompts                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (1)
                                          =    spaces
                     go to pmt-flg-xb1-999.
       pmt-flg-xb1-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      57                   to   v-pos                  .
           if        w-rig-flg-nbx (1, 1) =    spaces
                     move  spaces         to   v-alf
           else      move  "( )"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-flg-xb1-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Flag non bloccante 2                                      *
      *    *-----------------------------------------------------------*
       pmt-flg-xb2-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione prompts                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (2)
                                          =    spaces
                     go to pmt-flg-xb2-999.
       pmt-flg-xb2-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      60                   to   v-pos                  .
           if        w-rig-flg-nbx (1, 2) =    spaces
                     move  spaces         to   v-alf
           else      move  "( )"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-flg-xb2-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Flag non bloccante 3                                      *
      *    *-----------------------------------------------------------*
       pmt-flg-xb3-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione prompts                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (3)
                                          =    spaces
                     go to pmt-flg-xb3-999.
       pmt-flg-xb3-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      63                   to   v-pos                  .
           if        w-rig-flg-nbx (1, 3) =    spaces
                     move  spaces         to   v-alf
           else      move  "( )"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-flg-xb3-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Data consegna confermata                *
      *    *-----------------------------------------------------------*
       pmt-dcn-cnf-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione prompts                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-dcn-cnf        not  = "S"
                     go to pmt-dcn-cnf-999.
       pmt-dcn-cnf-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      "Conf.:"             to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-dcn-cnf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per prezzo d'acquisto             *
      *    *-----------------------------------------------------------*
       pmt-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Preparazione literal                            *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    not  = "P"
                     move  "Prezzo            :"
                                          to   v-alf
                     go to pmt-prz-acq-100.
           if        w-rig-umf-tum (1)    =    spaces
                     move  "Prezzo            :"
                                          to   v-alf
                     go to pmt-prz-acq-100.
           move      spaces               to   v-alf                  .
           string    "Prezzo/"
                                delimited by   size
                     w-rig-umf-tum (1)
                                delimited by   size
                     "        :"
                                delimited by   size
                                          into v-alf                  .
       pmt-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione literal                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-prz-acq-200.
      *              *-------------------------------------------------*
      *              * Visualizzazione sigla valuta                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       pmt-leg-val-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to pmt-leg-val-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to pmt-leg-val-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Legame valutario:"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      "+/-"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-leg-val-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : riferimento al listino fornitore        *
      *    *-----------------------------------------------------------*
       pmt-rif-lst-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione prompts                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-rif-lst        =    "N"
                     go to pmt-rif-lst-999.
       pmt-rif-lst-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      "Rif.:"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rif-lst-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : tipo    *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       acc-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-rig-025.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del default          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    not  = spaces
                     go to acc-tip-rig-050.
           if        w-tes-tmo-orf-dtr    not  = spaces
                     if    w-tes-tmo-orf-dtr
                                          =    "-----"
                           move  spaces   to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050
                     else  move  w-tes-tmo-orf-dtr
                                          to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050.
           if        w-prs-dpm-snx        =    "S"
                     move  "M"            to   w-rig-tip-rig (1)
           else      move  "P"            to   w-rig-tip-rig (1)      .
       acc-tip-rig-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig (1)    to   w-sav-tip-rig          .
       acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-rig        to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Pf3  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend                             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  "[3] "         to   v-pfk (16)             .
      *                      *-----------------------------------------*
      *                      * Pf4  : ammesso solo se si e' su di un   *
      *                      *        record New, a meno che non si    *
      *                      *        sia sulla prima riga             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cnt-cor-nrg-dac    not  = 1
                     move  "[4] "         to   v-pfk (17)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   v-alf                  .
       acc-tip-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-rig-250.
      *                  *---------------------------------------------*
      *                  * Test se ricerca per prodotto                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : find su tipi riga       *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-tip-rig-220.
           if        v-alf                =    spaces
                     go to acc-tip-rig-220.
           move      v-alf                to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    = spaces
                     go to acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su righe per codice prodotto           *
      *                  *---------------------------------------------*
           move      v-alf                to   w-fnd-mag-rig-alf      .
           move      w-cat-rig-cur        to   w-fnd-mag-rig-cur      .
           perform   fnd-mag-rig-000      thru fnd-mag-rig-999        .
           if        w-fnd-mag-rig-num    =    zero
                     go to acc-tip-rig-100.
           move      w-fnd-mag-rig-num    to   w-cnt-slc-rap-num      .
           go to     acc-tip-rig-320.
       acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su tipi riga                           *
      *                  *---------------------------------------------*
           perform   fnd-tip-rig-000      thru fnd-tip-rig-999        .
           if        w-fnd-tip-rig-sel    not  = spaces
                     go to acc-tip-rig-100.
           move      w-fnd-tip-rig-tri    to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo riga                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-rig-425.
       acc-tip-rig-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-rig-300
           else      go to acc-tip-rig-350.
       acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-rig-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-rig-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-rig-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-rig-310.
       acc-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-rig-999.
       acc-tip-rig-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-rig-999
                     else    go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf3                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[3] "
                     move  "3"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "4"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
       acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-tip-rig (1)      .
       acc-tip-rig-425.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo tipo riga impostato           *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    not  = spaces
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-rig-999
                     else  go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-rig-100.
       acc-tip-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo magazzino               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     move  01             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     move  03             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     move  04             to   w-rig-tip-mag (1)
           else      move  zero           to   w-rig-tip-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura codice iva              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto 'P', 'M' o 'V'   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to acc-tip-rig-620.
           if        w-tes-ass-iva (1)    =    zero
                     go to acc-tip-rig-620.
           move      w-tes-ass-iva (1)    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-tes-ass-iva-des (1)
                                          to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-tip-rig-620.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura contropartita acquisti  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto 'P', 'M' o 'V'   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to acc-tip-rig-700.
           if        w-tes-ctp-acq (1)    =    zero
                     go to acc-tip-rig-700.
           move      w-tes-ctp-acq (1)    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-tes-ctp-acq-des (1)
                                          to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-tip-rig-700.
      *                  *---------------------------------------------*
      *                  * Preparazione e visualizzazione eventuale    *
      *                  * default per data consegna richiesta         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto diverso da C     *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-tip-rig-720.
           if        w-rig-dcn-ric (1)    not  = zero
                     go to acc-tip-rig-720.
           move      w-tes-dat-cns (1)    to   w-rig-dcn-ric (1)      .
           perform   vis-dcn-ric-000      thru vis-dcn-ric-999        .
       acc-tip-rig-720.
      *                  *---------------------------------------------*
      *                  * Preparazione e visualizzazione eventuale    *
      *                  * default per data consegna prevista          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto diverso da C     *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-tip-rig-740.
      *                      *-----------------------------------------*
      *                      * Solo se data a zero                     *
      *                      *-----------------------------------------*
           if        w-rig-dcn-prv (1)    not  = zero
                     go to acc-tip-rig-740.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-tdt-apv        not  = "N"
                     go to acc-tip-rig-740.
      *                      *-----------------------------------------*
      *                      * Trattamento data consegna prevista      *
      *                      *-----------------------------------------*
           perform   trt-dcn-prv-000      thru trt-dcn-prv-999        .
       acc-tip-rig-740.
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt per codice prodotto  *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
       acc-tip-rig-800.
       acc-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo riga                         *
      *    *-----------------------------------------------------------*
       vis-tip-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Segnale di riga chiusa            *
      *    *-----------------------------------------------------------*
       vis-flg-rch-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-flg-och (1)    not  = spaces
                     go to vis-flg-rch-999.
           if        w-rig-flg-rch (1)    =    spaces
                     go to vis-flg-rch-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      70                   to   v-pos                  .
           move      "RIGA CHIUSA"        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-rch-999.
           exit.

      *    *===========================================================*
      *    * Ricerca riga da codice di magazzino                       *
      *    *-----------------------------------------------------------*
       fnd-mag-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-fnd-mag-rig-num      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      w-fnd-mag-rig-cur    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to fnd-mag-rig-100.
       fnd-mag-rig-200.
      *              *-------------------------------------------------*
      *              * Confronto con il numero riga in corso di trat-  *
      *              * tamento                                         *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-cur    =    w-cat-rig-cur
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Confronto con il codice alfanumerico contenuto  *
      *              * nella riga                                      *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-alf    not  = w-rig-alf-mag (1)
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Riga trovata in campo do comodo                 *
      *              *-------------------------------------------------*
           move      w-cat-rig-cur        to   w-fnd-mag-rig-num      .
       fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       fnd-mag-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice addebito o commen- *
      *    *                                 to                        *
      *    *-----------------------------------------------------------*
       acc-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-cod-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig-cac (1)
                                          to   w-sav-cod-aoc          .
       acc-cod-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zac-ope      .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-cod-mne-zac-tip
           else      move  02             to   w-cod-mne-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-cod-mne-zac-cod      .
           move      14                   to   w-cod-mne-zac-lin      .
           move      21                   to   w-cod-mne-zac-pos      .
           move      16                   to   w-cod-mne-zac-dln      .
           move      21                   to   w-cod-mne-zac-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "<B"                 to   v-edm                  .
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
       acc-cod-aoc-110.
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           if        w-cod-mne-zac-ope    =    "F+"
                     go to acc-cod-aoc-115.
           if        w-cod-mne-zac-ope    =    "AC"
                     go to acc-cod-aoc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aoc-115.
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
           go to     acc-cod-aoc-110.
       acc-cod-aoc-120.
           move      w-cod-mne-zac-cod    to   v-num                  .
       acc-cod-aoc-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-tip-rig-cac (1)  .
       acc-cod-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zac]                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-let-arc-zac-tip
           else      move  02             to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato                            *
      *                  *---------------------------------------------*
           if        w-let-arc-zac-flg    =    spaces
                     go to acc-cod-aoc-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento non esistente !"
                                          to   w-err-box-err-msg
           else      move  "Codice addebito non esistente !"            
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-aoc-100.
       acc-cod-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    w-sav-cod-aoc
                     go to acc-cod-aoc-800.
      *                  *---------------------------------------------*
      *                  * Descrizione addebito o commento             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-cod-aoc-800.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-civ    to   w-edt-iva-cod          .
      *
           if        w-tes-ass-iva (1)    not  = zero
                     if    w-edt-iva-cod-003
                                          =    zero
                           move  w-tes-ass-iva (1)
                                          to   w-rig-civ-rig (1)
                     else  move  w-let-arc-zac-civ
                                          to   w-rig-civ-rig (1)
           else      move  w-let-arc-zac-civ
                                          to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           if        w-rig-civ-rig (1)    <    100
                     move  spaces         to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-aoc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-aoc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-aoc-100.
       acc-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Codice addebito o com- *
      *    *                                    mento                  *
      *    *-----------------------------------------------------------*
       vis-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to vis-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto           *
      *    *-----------------------------------------------------------*
       acc-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-cod-pro-999.
      *                      *-----------------------------------------*
      *                      * Test se campo gia' accettato            *
      *                      *-----------------------------------------*
           if        w-rig-num-mag (1)    not  = zero
                     go to acc-cod-pro-999.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     perform acc-cod-dcp-000
                                          thru acc-cod-dcp-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     perform acc-cod-dpm-000
                                          thru acc-cod-dpm-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     perform acc-cod-mtv-000
                                          thru acc-cod-mtv-999        .
       acc-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto                   *
      *    *-----------------------------------------------------------*
       vis-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cod-pro-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-alf-mag (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-dcp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      w-rig-num-mag (1)    to   w-cod-cod-dcp-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-dcp-alf      .
           move      14                   to   w-cod-cod-dcp-lin      .
           move      21                   to   w-cod-cod-dcp-pos      .
           move      15                   to   w-cod-cod-dcp-dln      .
           move      21                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "cod-pro"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dcp-cod      .
           move      w-tes-cod-lng (1)    to   w-let-arc-dcp-lng      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-dcp-450.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto prodo
      -              "tto !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-100.
       acc-cod-dcp-450.
      *                  *---------------------------------------------*
      *                  * Memorizzazione codice prodotto per la casa  *
      *                  * produttrice                                 *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-cdp    to   w-rig-cdp-pdt (1)      .
           perform   vis-cdp-pdt-000      thru vis-cdp-pdt-999        .
       acc-cod-dcp-460.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del prodotto     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se la personalizzazione lo esige   *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcp    =    "N"
                     go to acc-cod-dcp-500.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           move      w-tes-cod-arc (1)    to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se codice errato : oltre                *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces
                     go to acc-cod-dcp-500.
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-tus    =    01
                     go to acc-cod-dcp-500.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cod-dcp-bsp-000  thru acc-cod-dcp-bsp-999    .
      *                      *-----------------------------------------*
      *                      * Tipo di uscita a seconda della persona- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcp    =    "B"
                     go to acc-cod-dcp-100
           else      go to acc-cod-dcp-500.
       acc-cod-dcp-500.
      *                  *---------------------------------------------*
      *                  * Eventuale controllo su codice fornitore     *
      *                  * preferenziale                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-fnt-pfz        =    spaces
                     go to acc-cod-dcp-600.
      *                      *-----------------------------------------*
      *                      * Test di confronto                       *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-pfz    =    zero
                     go to acc-cod-dcp-600.
           if        w-tes-cod-arc (1)    =    w-let-arc-aaq-pfz
                     go to acc-cod-dcp-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing codice fornitore preferen-  *
      *                          * ziale                               *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-let-arc-aaq-pfz    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Lettura anagrafica fornitore prefe- *
      *                          * renziale                            *
      *                          *-------------------------------------*
           move      w-let-arc-aaq-pfz    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                          *-------------------------------------*
      *                          * Composizione messaggio              *
      *                          *-------------------------------------*
           move      65                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "Fornitore pref. :"  to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "-"                  to   w-all-str-cat (3)      .
           move      w-let-arc-fnt-rag    to   w-all-str-cat (4)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A dipendenze dall'impostazione          *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-600.
       acc-cod-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-610.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dcp] in descrizione originale          *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dcp] in descrizione per documento      *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-dcp-610.
      *                  *---------------------------------------------*
      *                  * Tipo prodotto                               *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-tpr    to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione riga in ordine             *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-epz    to   w-rig-epz-rgo (1)      .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-dcp-620.
      *                  *---------------------------------------------*
      *                  * Prezzo di listino base                      *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-dlb    to   w-rig-num-mag-dlb (1)  .
           move      w-let-arc-dcp-plb    to   w-rig-num-mag-plb (1)  .
       acc-cod-dcp-630.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-let-arc-dcp-des    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-dcp-645.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-dcp-640.
      *                  *---------------------------------------------*
      *                  * Lotto di acquisto                           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-lda    to   w-rig-num-mag-lda (1)  .
       acc-cod-dcp-645.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-cod-dcp-650.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dcp-660.
      *                      *-----------------------------------------*
      *                      * Se codice iva contenuto in [aaq] questo *
      *                      * prevale, altrimenti e' quello contenuto *
      *                      * in [dcp]                                *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-civ    not  = zero
                     move  w-let-arc-aaq-civ
                                          to   w-rig-civ-rig (1)
           else      move  w-let-arc-dcp-civ
                                          to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-dcp-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-dcp-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-dcp-680.
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-tdt-apv        =    "N"
                     go to acc-cod-dcp-690.
      *                      *-----------------------------------------*
      *                      * Trattamento data consegna prevista      *
      *                      *-----------------------------------------*
           perform   trt-dcn-prv-000      thru trt-dcn-prv-999        .
       acc-cod-dcp-690.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dcp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dcp-100.
       acc-cod-dcp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del prodotto, se diverso da 'normale'                     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-bsp-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il prodotto impostato si rileva la seguente co
      -              "ndizione :  "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-tus    =    11
                     move  "[Prodotto ad esaurimento]                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    21
                     move  "[Sostituito da ns. nuovo prodotto]          
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    51
                     move  "[Cessata commercializzazione]               
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    52
                     move  "[Cessata commercializzazione, ma sostituito 
      -                    "da ns. prodotto]  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    71
                     move  "[Obsoleto]                                  
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    72
                     move  "[Obsoleto, ma sostituito da ns. nuovo prodot
      -                    "to]               "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-dcp-pdx-tud    =    zero
                     go to acc-cod-dcp-bsp-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-dcp-pdx-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-dcp-pdx-tuc    =    zero
                     go to acc-cod-dcp-bsp-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il prodotto utilizzabile in alternativa e' il segu
      -              "ente :       "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice prodotto alternativo         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Lettura record [dcp]            *
      *                              *---------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-dcp-pdx-tuc    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-dcp-alf-pro
                     move  all "."        to   rf-dcp-des-pro         .
      *                              *---------------------------------*
      *                              * Visualizzazione codice prodotto *
      *                              *---------------------------------*

           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      rf-dcp-alf-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Visualizzazione descrizione     *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      rf-dcp-des-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Lettura record [dcp] di ripris- *
      *                              * tino                            *
      *                              *---------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-dcp-pdx-cod    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       acc-cod-dcp-bsp-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dpm]     *
      *    *-----------------------------------------------------------*
       acc-cod-dpm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-dpm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaq-ope      .
           move      "A"                  to   w-cod-cod-aaq-tac      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaq-tco      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaq-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaq-alf      .
           move      14                   to   w-cod-cod-aaq-lin      .
           move      21                   to   w-cod-cod-aaq-pos      .
           move      15                   to   w-cod-cod-aaq-dln      .
           move      21                   to   w-cod-cod-aaq-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
       acc-cod-dpm-110.
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           if        w-cod-cod-aaq-ope    =    "F+"
                     go to acc-cod-dpm-115.
           if        w-cod-cod-aaq-ope    =    "AC"
                     go to acc-cod-dpm-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dpm-115.
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
           go to     acc-cod-dpm-110.
       acc-cod-dpm-120.
           move      w-cod-cod-aaq-alf    to   v-alf                  .
           move      w-cod-cod-aaq-num    to   v-num                  .
       acc-cod-dpm-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "cod-pro"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dpm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dpm]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dpm-cod      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dpm-flg    not  = spaces
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-dpm-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-dpm-100.
       acc-cod-dpm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dpm]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione ad uso in-   *
      *                      * terno                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-dpm-610.
      *                  *---------------------------------------------*
      *                  * Tipo prodotto                               *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione riga in ordine             *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-epz    to   w-rig-epz-rgo (1)      .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dpm-620.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-dpm-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-dpm-620.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dpm-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-let-arc-dpm-des    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-dpm-645.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-dpm-640.
      *                  *---------------------------------------------*
      *                  * Lotto di acquisto                           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-lda    to   w-rig-num-mag-lda (1)  .
       acc-cod-dpm-645.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-cod-dpm-650.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dpm-660.
           move      w-let-arc-aaq-civ    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-dpm-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-dpm-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-dpm-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dpm-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dpm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dpm-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dpm-100.
       acc-cod-dpm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [mtv]     *
      *    *-----------------------------------------------------------*
       acc-cod-mtv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-mtv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaq-ope      .
           move      "A"                  to   w-cod-cod-aaq-tac      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaq-tco      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaq-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaq-alf      .
           move      14                   to   w-cod-cod-aaq-lin      .
           move      21                   to   w-cod-cod-aaq-pos      .
           move      15                   to   w-cod-cod-aaq-dln      .
           move      21                   to   w-cod-cod-aaq-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
       acc-cod-mtv-110.
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           if        w-cod-cod-aaq-ope    =    "F+"
                     go to acc-cod-mtv-115.
           if        w-cod-cod-aaq-ope    =    "AC"
                     go to acc-cod-mtv-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-mtv-115.
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
           go to     acc-cod-mtv-110.
       acc-cod-mtv-120.
           move      w-cod-cod-aaq-alf    to   v-alf                  .
           move      w-cod-cod-aaq-num    to   v-num                  .
       acc-cod-mtv-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-mtv-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-mtv-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "cod-pro"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-mtv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [mtv]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-mtv-cod      .
           perform   let-arc-mtv-000      thru let-arc-mtv-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-mtv-flg    not  = spaces
                     go to acc-cod-mtv-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-mtv-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-mtv-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-mtv-100.
       acc-cod-mtv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [mtv]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-mtv-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione ad uso in-   *
      *                      * terno                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-mtv-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-mtv-610.
      *                  *---------------------------------------------*
      *                  * Tipo prodotto                               *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Tipo esposizione riga in ordine             *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-epz    to   w-rig-epz-rgo (1)      .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-mtv-620.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-mtv-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-mtv-620.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-mtv-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-let-arc-mtv-des    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-mtv-645.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-mtv-640.
      *                  *---------------------------------------------*
      *                  * Lotto di acquisto                           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-lda    to   w-rig-num-mag-lda (1)  .
       acc-cod-mtv-645.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-cod-mtv-650.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-mtv-660.
           move      w-let-arc-aaq-civ    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-mtv-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-mtv-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-mtv-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-mtv-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-mtv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-mtv-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-mtv-100.
       acc-cod-mtv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Unita' di misura                  *
      *    *-----------------------------------------------------------*
       vis-umi-acq-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      15                   to   v-pos                  .
           if        w-rig-snx-tum (1)    not  = "S"
                     move  w-rig-umi-acq (1)
                                          to   v-alf
           else      move  w-rig-umf-tum (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-umi-acq-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di acquisizione   *
      *    *-----------------------------------------------------------*
       acc-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-fda        =    "N"
                     go to acc-fda-pif-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-fda-pif-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo funzionamento              *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-fda-pif-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-fda-pif (1)    to   w-sav-fda-pif          .
       acc-fda-pif-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaf-ope      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaf-nrm      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaf-afm      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-aaf-dcf      .
           move      w-rig-fda-pif (1)    to   w-cod-cod-aaf-fda      .
           move      14                   to   w-cod-cod-aaf-lin      .
           move      47                   to   w-cod-cod-aaf-pos      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-aaf-cll-000  thru cod-cod-aaf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaf-foi-000  thru cod-cod-aaf-foi-999    .
       acc-fda-pif-110.
           perform   cod-cod-aaf-cll-000  thru cod-cod-aaf-cll-999    .
           if        w-cod-cod-aaf-ope    =    "F+"
                     go to acc-fda-pif-115.
           if        w-cod-cod-aaf-ope    =    "AC"
                     go to acc-fda-pif-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fda-pif-115.
           perform   cod-cod-aaf-foi-000  thru cod-cod-aaf-foi-999    .
           go to     acc-fda-pif-110.
       acc-fda-pif-120.
           move      w-cod-cod-aaf-fda    to   v-alf                  .
       acc-fda-pif-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "fda-pif"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-fda-pif (1)      .
       acc-fda-pif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaf]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-rig-des-por (1)    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-flg    =    spaces
                     go to acc-fda-pif-600.
           if        w-rig-fda-pif (1)    =    spaces
                     go to acc-fda-pif-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Formato di acquisizione non esistente !           
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-fda-pif-100.
       acc-fda-pif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-fda-pif (1)    =    w-sav-fda-pif
                     go to acc-fda-pif-700.
      *                  *---------------------------------------------*
      *                  * Richiamo subroutine                         *
      *                  *---------------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
      *                  *---------------------------------------------*
      *                  * Lotto di acquisto                           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-lda    to   w-rig-num-mag-lda (1)  .
       acc-fda-pif-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-fda-pif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-fda-pif-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-fda-pif-100.
       acc-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di acquisizione   *
      *    *                                                           *
      *    * Subroutine per dipendenze dall'impostazione               *
      *    *-----------------------------------------------------------*
       acc-fda-pif-ddi-000.
       acc-fda-pif-ddi-200.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione si/no esistenza di un forma- *
      *                  * to di acquisizione                          *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-flg    =    spaces
                     move  "S"            to   w-rig-snx-fda (1)
           else      move  "N"            to   w-rig-snx-fda (1)      .
           if        w-let-arc-aaf-des    =    spaces
                     move  "N"            to   w-rig-snx-dep (1)
           else      move  "S"            to   w-rig-snx-dep (1)      .
      *                  *---------------------------------------------*
      *                  * Valori da bufferizzare se formato di acqui- *
      *                  * sizione esistente                           *
      *                  *---------------------------------------------*
           if        w-rig-snx-fda (1)    =    "N"
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Codice prodotto secondo il fornitore        *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-csf    to   w-rig-cop-sfn (1)      .
           perform   vis-cop-sfn-000      thru vis-cop-sfn-999        .
      *                  *---------------------------------------------*
      *                  * Codice prodotto per la casa produttrice     *
      *                  *---------------------------------------------*
           perform   vis-cdp-pdt-000      thru vis-cdp-pdt-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto secondo il fornitore   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se diversa da spaces               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-des    =    spaces
                     go to acc-fda-pif-ddi-300.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-des    to   w-rig-des-por (1)      .
           move      w-let-arc-aaf-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-fda-pif-ddi-300.
      *                  *---------------------------------------------*
      *                  * Eventuale default per riferimento listino   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se valore gia' inserito            *
      *                      *-----------------------------------------*
           if        w-rig-rif-lst (1)    not  = spaces
                     go to acc-fda-pif-ddi-400.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazioni               *
      *                      *                                         *
      *                      * N.B.: opzione da eliminare ___          *
      *                      *-----------------------------------------*
           if        w-prs-rif-lst        not  = "X"
                     go to acc-fda-pif-ddi-320.
      *                      *-----------------------------------------*
      *                      * Test se II riga descrizione presente    *
      *                      *-----------------------------------------*
           if        w-rig-der-rig (1, 2) =    spaces
                     go to acc-fda-pif-ddi-400.
      *                      *-----------------------------------------*
      *                      * Si estrae la porzione di descrizione    *
      *                      * dall'ottavo carattere in poi            *
      *                      *-----------------------------------------*
           move      w-rig-der-rig
                    (01 , 02)
                    (07 : 30)             to   w-rig-rif-lst (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione riferimento listino     *
      *                      *-----------------------------------------*
           perform   vis-rif-lst-000      thru vis-rif-lst-999        .
       acc-fda-pif-ddi-320.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazioni               *
      *                      *-----------------------------------------*
           if        w-prs-rif-lst        not  = "S"
                     go to acc-fda-pif-ddi-400.
      *                      *-----------------------------------------*
      *                      * Estrazione da record [aaf]              *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-rif    to   w-rig-rif-lst (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione riferimento listino     *
      *                      *-----------------------------------------*
           perform   vis-rif-lst-000      thru vis-rif-lst-999        .
       acc-fda-pif-ddi-400.
      *                  *---------------------------------------------*
      *                  * Parametri associati all'unita' di misura    *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-snu    to   w-rig-snx-tum (1)      .
           move      w-let-arc-aaf-umf    to   w-rig-umf-tum (1)      .
           move      w-let-arc-aaf-ndu    to   w-rig-nde-tum (1)      .
           move      w-let-arc-aaf-cmu    to   w-rig-cmo-tum (1)      .
           move      w-let-arc-aaf-cdu    to   w-rig-cdi-tum (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione unita' di misura            *
      *                  *---------------------------------------------*
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione prompt prezzo di acquisto *
      *                  *---------------------------------------------*
           perform   pmt-prz-acq-000      thru pmt-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni                                   *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaf-dcv    not  = w-tes-dec-vpf (1)
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo d'acquisto           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-ndp    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-prz-qta-pre      .
           move      zero                 to   w-det-prz-qta-att      .
           perform   det-prz-acq-000      thru det-prz-acq-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Parametri associati al legame valutario     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-fda-pif-ddi-680.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-fda-pif-ddi-680.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione e visualizzazione       *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-lvv    to   w-rig-sgl-vpl (1)      .
           move      w-let-arc-aaf-lvd    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-aaf-lvt    to   w-rig-tdc-vpl (1)      .
           move      w-let-arc-aaf-lvc    to   w-rig-ccr-vpl (1)      .
           move      w-let-arc-aaf-lvp    to   w-rig-plm-vpl (1)      .
           move      "F"                  to   w-rig-tlm-vpl (1)      .
           perform   vis-sgl-vpl-000      thru vis-sgl-vpl-999        .
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
       acc-fda-pif-ddi-680.
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-fda-pif-ddi-800.
       acc-fda-pif-ddi-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-fda-pif-ddi-999.
       acc-fda-pif-ddi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Formato di acquisizione           *
      *    *-----------------------------------------------------------*
       vis-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-fda        =    "N"
                     go to vis-fda-pif-999.
       vis-fda-pif-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-rig-fda-pif (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto secondo fornitore *
      *    *-----------------------------------------------------------*
       vis-cop-sfn-000.
      *              *-------------------------------------------------*
      *              * Se non esistente : uscita                       *
      *              *-------------------------------------------------*
           if        w-rig-cop-sfn (1)    =    spaces
                     go to vis-cop-sfn-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "[F]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Allineamento a destra                       *
      *                  *---------------------------------------------*
           move      w-rig-cop-sfn (1)    to   w-all-str-alf          .
           move      14                   to   w-all-str-lun          .
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cop-sfn-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto per la casa pro-  *
      *    *                         duttrice                          *
      *    *-----------------------------------------------------------*
       vis-cdp-pdt-000.
      *              *-------------------------------------------------*
      *              * Se non esistente : uscita                       *
      *              *-------------------------------------------------*
           if        w-rig-cdp-pdt (1)    =    spaces
                     go to vis-cdp-pdt-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "[P]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Allineamento a destra                       *
      *                  *---------------------------------------------*
           move      w-rig-cdp-pdt (1)    to   w-all-str-alf          .
           move      15                   to   w-all-str-lun          .
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cdp-pdt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Descrizione in riga       *
      *    *-----------------------------------------------------------*
       acc-des-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-des-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-des-rig (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "des-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-rig-des-rig (1)      .
       acc-des-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spazi ammesso solo per tipi riga   *
      *                  * 'C', a meno che non si sia in Up            *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = spaces
                     go to acc-des-rig-600.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-des-rig-600.
           if        v-key                =    "UP  "
                     go to acc-des-rig-600
           else      go to acc-des-rig-100.
       acc-des-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-des-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-des-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-des-rig-100.
       acc-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione in riga               *
      *    *-----------------------------------------------------------*
       vis-des-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-des-rig (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' primaria        *
      *    *-----------------------------------------------------------*
       acc-qta-pri-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-pri-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-ord (1)
                                          to   w-sav-qta-psx
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx          .
       acc-qta-pri-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   v-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-ord (1)
                                          to   v-num
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-fda (1)
                                          to   v-num                  .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-pri-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-pri-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "qta-pri"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  v-num          to   w-rig-qta-ord (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  v-num          to   w-rig-qta-fda (1)
           else      move  v-num          to   w-rig-qta-fda (1)      .
      *              *-------------------------------------------------*
      *              * Valore impostato in comodo per confronti        *
      *              *-------------------------------------------------*
           move      v-num                to   w-sav-qta-cfr          .
       acc-qta-pri-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        =    w-sav-qta-psx
                     go to acc-qta-pri-600.
      *                  *---------------------------------------------*
      *                  * Subroutine di trattamento lotto di acquisto *
      *                  *---------------------------------------------*
           perform   acc-qta-pri-lda-000  thru acc-qta-pri-lda-999    .
      *                      *-----------------------------------------*
      *                      * Test sul flag di uscita                 *
      *                      *-----------------------------------------*
           if        w-acc-qta-psx-flg    not  = spaces
                     go to acc-qta-pri-100.
       acc-qta-pri-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento quantita' secondaria            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore inalterato rispetto al valore *
      *                      * precedente : nessuna azione             *
      *                      *-----------------------------------------*
           if        w-sav-qta-cfr        =    w-sav-qta-psx
                     go to acc-qta-pri-605.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' secondaria     *
      *                      *-----------------------------------------*
           move      w-sav-qta-cfr        to   w-det-qta-sec-qim      .
           move      w-rig-dec-qta (1)    to   w-det-qta-sec-dgm      .
           move      w-rig-snx-tum (1)    to   w-det-qta-sec-snu      .
           move      w-rig-umf-tum (1)    to   w-det-qta-sec-umf      .
           move      w-rig-nde-tum (1)    to   w-det-qta-sec-ndu      .
           move      w-rig-cmo-tum (1)    to   w-det-qta-sec-cmu      .
           move      w-rig-cdi-tum (1)    to   w-det-qta-sec-cdu      .
           perform   det-qta-sec-000      thru det-qta-sec-999        .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-det-qta-sec-qts
                                          to   w-rig-qta-fda (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-det-qta-sec-qts
                                          to   w-rig-qta-ord (1)
           else      move  w-det-qta-sec-qts
                                          to   w-rig-qta-ord (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione quantita' secondaria    *
      *                      *-----------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
       acc-qta-pri-605.
      *                  *---------------------------------------------*
      *                  * Valori da determinare se formato di acqui-  *
      *                  * sizione esistente                           *
      *                  *---------------------------------------------*
           if        w-rig-snx-fda (1)    =    "N"
                     go to acc-qta-pri-660.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni, tranne che quella dell'importo   *
      *                  * in riga                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1)
                     go to acc-qta-pri-660.
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-sav-qta-psx        to   w-det-prz-qta-pre      .
           move      w-sav-qta-cfr        to   w-det-prz-qta-att      .
           perform   det-prz-acq-000      thru det-prz-acq-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-qta-pri-640.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-qta-pri-660.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-pri-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-qta-pri-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-pri-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-pri-100.
       acc-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' primaria        *
      *    *                                                           *
      *    * Subroutine per il controlli su lotto di acquisto          *
      *    *-----------------------------------------------------------*
       acc-qta-pri-lda-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-acc-qta-psx-flg      .
      *              *-------------------------------------------------*
      *              * Se lotto di acquisto a zero : uscita            *
      *              *-------------------------------------------------*
           if        w-rig-num-mag-lda (1)
                                          =    zero
                     go to acc-qta-pri-lda-800.
      *              *-------------------------------------------------*
      *              * Se quantita' ordinata a zero : uscita           *
      *              *-------------------------------------------------*
           if        w-sav-qta-cfr        =    zero
                     go to acc-qta-pri-lda-800.
      *              *-------------------------------------------------*
      *              * Se quantita' ordinata gia' impostata preceden-  *
      *              * temente : uscita                                *
      *              *-------------------------------------------------*
           if        w-sav-qta-psx        not  = zero
                     go to acc-qta-pri-lda-800.
       acc-qta-pri-lda-010.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della personalizzazione  *
      *              *-------------------------------------------------*
           if        w-prs-tdt-lda        =    "N"
                     go to acc-qta-pri-lda-100
           else if   w-prs-tdt-lda        =    "A"
                     go to acc-qta-pri-lda-200
           else if   w-prs-tdt-lda        =    "M"
                     go to acc-qta-pri-lda-300
           else if   w-prs-tdt-lda        =    "B"
                     go to acc-qta-pri-lda-300
           else if   w-prs-tdt-lda        =    "*"
                     go to acc-qta-pri-lda-400
           else      go to acc-qta-pri-lda-800.
       acc-qta-pri-lda-100.
      *              *-------------------------------------------------*
      *              * Se nessun trattamento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita per fine trattamento regolare     *
      *                  *---------------------------------------------*
           go to     acc-qta-pri-lda-800.
       acc-qta-pri-lda-200.
      *              *-------------------------------------------------*
      *              * Se arrotondamento                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale aggiustamento quantita' ordinata  *
      *                  * al lotto di acquisto superiore              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che quantita' ordinata sia    *
      *                      * multiplo del lotto di acquisto          *
      *                      *-----------------------------------------*
           divide    w-rig-num-mag-lda (1)
                                          into w-sav-qta-cfr
                                        giving w-acc-qta-psx-wpq
                                     remainder w-acc-qta-psx-wpr      .
           if        w-acc-qta-psx-r2a    not  = zero
                     go to acc-qta-pri-lda-220.
           if        w-rig-dec-qta (1)    =    zero
                     if    w-acc-qta-psx-r1b
                                          not  = zero or
                           w-acc-qta-psx-r2b
                                          not  = zero or
                           w-acc-qta-psx-r1c
                                          not  = zero or
                           w-acc-qta-psx-r2c
                                          not  = zero or
                           w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-pri-lda-220
                      else go to acc-qta-pri-lda-800.
           if        w-rig-dec-qta (1)    =    1
                     if    w-acc-qta-psx-r1c
                                          not  = zero or
                           w-acc-qta-psx-r2c
                                          not  = zero or
                           w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-pri-lda-220
                      else go to acc-qta-pri-lda-800.
           if        w-rig-dec-qta (1)    =    2
                     if    w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-pri-lda-220
                      else go to acc-qta-pri-lda-800.
           go to     acc-qta-pri-lda-800.
       acc-qta-pri-lda-220.
      *                      *-----------------------------------------*
      *                      * Aggiustamento quantita' ordinata        *
      *                      *-----------------------------------------*
           add       1                    to   w-acc-qta-psx-r1a      .
           multiply  w-rig-num-mag-lda (1)
                                          by   w-acc-qta-psx-r1a
                                        giving w-sav-qta-cfr          .
      *                      *-----------------------------------------*
      *                      * In campo di destinazione                *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-sav-qta-cfr  to   w-rig-qta-ord (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-sav-qta-cfr  to   w-rig-qta-fda (1)
           else      move  w-sav-qta-cfr  to   w-rig-qta-fda (1)      .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione quantita' ordinata    *
      *                      *-----------------------------------------*
           perform   vis-qta-pri-000      thru vis-qta-pri-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     acc-qta-pri-lda-800.
       acc-qta-pri-lda-300.
      *              *-------------------------------------------------*
      *              * Se messaggio di avviso                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra la quantita' ordinata e il    *
      *                  * lotto di acquisto                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che quantita' ordinata sia    *
      *                      * multiplo del lotto di acquisto          *
      *                      *-----------------------------------------*
           divide    w-rig-num-mag-lda (1)
                                          into w-sav-qta-cfr
                                        giving w-acc-qta-psx-wpq
                                     remainder w-acc-qta-psx-wpr      .
           if        w-acc-qta-psx-r2a    not  = zero
                     go to acc-qta-pri-lda-320.
           if        w-rig-dec-qta (1)    =    zero
                     if    w-acc-qta-psx-r1b
                                          not  = zero or
                           w-acc-qta-psx-r2b
                                          not  = zero or
                           w-acc-qta-psx-r1c
                                          not  = zero or
                           w-acc-qta-psx-r2c
                                          not  = zero or
                           w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-pri-lda-320
                      else go to acc-qta-pri-lda-800.
           if        w-rig-dec-qta (1)    =    1
                     if    w-acc-qta-psx-r1c
                                          not  = zero or
                           w-acc-qta-psx-r2c
                                          not  = zero or
                           w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-pri-lda-320
                      else go to acc-qta-pri-lda-800.
           if        w-rig-dec-qta (1)    =    2
                     if    w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-pri-lda-320
                      else go to acc-qta-pri-lda-800.
           go to     acc-qta-pri-lda-800.
       acc-qta-pri-lda-320.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing del lotto di acquisto           *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      w-rig-num-mag-lda (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione messaggio di avviso        *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Lotto di acquisto del prodotto : "
                                delimited by size
                     v-edt      delimited by spaces
                                          into w-err-box-err-msg      .
      *                  *---------------------------------------------*
      *                  * Ad uscita con emissione messaggio di avviso *
      *                  * ed eventuale blocco a seconda della perso-  *
      *                  * nalizzazione                                *
      *                  *---------------------------------------------*
           if        w-prs-tdt-lda        =    "M"
                     go to acc-qta-pri-lda-950
           else      go to acc-qta-pri-lda-900.
       acc-qta-pri-lda-400.
      *              *-------------------------------------------------*
      *              * Se moltiplicazione della quantita' per il lotto *
      *              * di acquisto                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione addizionale della quantita'    *
      *                  * da sottoporre a moltiplicazione             *
      *                  *---------------------------------------------*
           perform   acc-qta-add-000      thru acc-qta-add-999        .
      *                  *---------------------------------------------*
      *                  * In campo di destinazione                    *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-sav-qta-cfr  to   w-rig-qta-ord (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-sav-qta-cfr  to   w-rig-qta-fda (1)
           else      move  w-sav-qta-cfr  to   w-rig-qta-fda (1)      .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione quantita' in ordine       *
      *                  *---------------------------------------------*
           perform   vis-qta-pri-000      thru vis-qta-pri-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita per fine trattamento regolare     *
      *                  *---------------------------------------------*
           go to     acc-qta-pri-lda-800.
       acc-qta-pri-lda-800.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento regolare            *
      *              *-------------------------------------------------*
           go to     acc-qta-pri-lda-999.
       acc-qta-pri-lda-900.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento con messaggio e con *
      *              * blocco                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-acc-qta-psx-flg      .
      *                  *---------------------------------------------*
      *                  * Ad uscita per fine trattamento con messag-  *
      *                  * gio                                         *
      *                  *---------------------------------------------*
           go to     acc-qta-pri-lda-950.
       acc-qta-pri-lda-950.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento con messaggio       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-pri-lda-999.
       acc-qta-pri-lda-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' di vendita      *
      *    *                                 addizionale per moltipli- *
      *    *                                 cazione con lotto di ven- *
      *    *                                 dita                      *
      *    *-----------------------------------------------------------*
       acc-qta-add-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-qta-add-010.
      *                  *---------------------------------------------*
      *                  * Box di accettazione                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      15                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      17                   to   v-lto                  .
           move      68                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Prompt per quantita' addizionale        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Quantita' x lotto :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-qta-add-050.
      *                  *---------------------------------------------*
      *                  * Quantita' di vendita in quantita' addizio-  *
      *                  * nale                                        *
      *                  *---------------------------------------------*
           move      w-sav-qta-cfr        to   w-rig-qta-add (1)      .
      *                  *---------------------------------------------*
      *                  * Moltiplicazione                             *
      *                  *---------------------------------------------*
           multiply  w-rig-num-mag-lda (1)
                                          by   w-rig-qta-add (1)
                                        giving w-rig-qta-add (1)      .
       acc-qta-add-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-qta-add (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-add-900.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-add-900.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-add (1)      .
       acc-qta-add-200.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-qta-add-400.
           if        w-rig-qta-add (1)    =    zero
                     go to acc-qta-add-400.
      *                  *---------------------------------------------*
      *                  * Quantita' addizionale in quantita' in       *
      *                  * ordine                                      *
      *                  *---------------------------------------------*
           move      w-rig-qta-add (1)    to   w-sav-qta-cfr          .
       acc-qta-add-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-add-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-add-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-add-900
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-add-100.
       acc-qta-add-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-qta-add-999.
       acc-qta-add-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' primaria                *
      *    *-----------------------------------------------------------*
       vis-qta-pri-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   v-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-ord (1)
                                          to   v-num
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-fda (1)
                                          to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' secondaria      *
      *    *-----------------------------------------------------------*
       acc-qta-sec-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-sec-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"  and
                     w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-qta-sec-999.
           if        w-rig-snx-tum (1)    not  = "S" and
                     w-rig-snx-tum (1)    not  = "P"
                     go to acc-qta-sec-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-ord (1)
                                          to   w-sav-qta-psx          .
       acc-qta-sec-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-umf-tum (1)
                                          to   w-sav-umi-sec
           else      move  w-rig-umi-acq (1)
                                          to   w-sav-umi-sec          .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "("
                                delimited by   size
                     w-sav-umi-sec
                                delimited by   size
                     "             )"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-ord (1)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-sec-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-sec-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "qta-sec"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  v-num          to   w-rig-qta-fda (1)
           else      move  v-num          to   w-rig-qta-ord (1)      .
      *              *-------------------------------------------------*
      *              * Valore impostato in comodo per confronti        *
      *              *-------------------------------------------------*
           move      v-num                to   w-sav-qta-cfr          .
      *              *-------------------------------------------------*
      *              * Visualizzazione quantita' secondaria            *
      *              *-------------------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
       acc-qta-sec-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo con lotto di acquisto             *
      *                  *---------------------------------------------*
           perform   acc-qta-sec-cla-000  thru acc-qta-sec-cla-999    .
       acc-qta-sec-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-sec-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-qta-sec-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-sec-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-sec-100.
       acc-qta-sec-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' secondaria      *
      *    *                                                           *
      *    * Subroutine per il controlli su lotto di acquisto          *
      *    *-----------------------------------------------------------*
       acc-qta-sec-cla-000.
      *              *-------------------------------------------------*
      *              * Test se controllo da eseguire                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il controllo sul lotto di acquisto non   *
      *                  * deve essere eseguito sulla quantita' prima- *
      *                  * ria : ad uscita                             *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     go to acc-qta-sec-cla-900.
      *                  *---------------------------------------------*
      *                  * Se quantita' impostata a zero oppure se     *
      *                  * lotto di acquisto a zero : ad uscita        *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        =    zero or
                     w-rig-num-mag-lda (1)
                                          =    zero
                     go to acc-qta-sec-cla-900.
      *                  *---------------------------------------------*
      *                  * Se quantita' impostata inalterata rispetto  *
      *                  * al valore precedente : ad uscita            *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        =    w-sav-qta-psx
                     go to acc-qta-sec-cla-900.
       acc-qta-sec-cla-200.
      *              *-------------------------------------------------*
      *              * Controllo effettivo                             *
      *              *-------------------------------------------------*
           divide    w-rig-num-mag-lda (1)
                                          into w-sav-qta-cfr
                                        giving w-acc-qta-psx-wpq
                                     remainder w-acc-qta-psx-wpr      .
           if        w-acc-qta-psx-r2a    not  = zero
                     go to acc-qta-sec-cla-300.
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   w-acc-qta-psx-dec
           else      move  w-rig-dec-qta (1)
                                          to   w-acc-qta-psx-dec      .
           if        w-acc-qta-psx-dec    =    zero
                     if    w-acc-qta-psx-r1b
                                          not  = zero or
                           w-acc-qta-psx-r2b
                                          not  = zero or
                           w-acc-qta-psx-r1c
                                          not  = zero or
                           w-acc-qta-psx-r2c
                                          not  = zero or
                           w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-sec-cla-300
                      else go to acc-qta-sec-cla-900.
           if        w-acc-qta-psx-dec    =    1
                     if    w-acc-qta-psx-r1c
                                          not  = zero or
                           w-acc-qta-psx-r2c
                                          not  = zero or
                           w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-sec-cla-300
                      else go to acc-qta-sec-cla-900.
           if        w-acc-qta-psx-dec    =    2
                     if    w-acc-qta-psx-r1d
                                          not  = zero or
                           w-acc-qta-psx-r2d
                                          not  = zero
                           go to acc-qta-sec-cla-300
                      else go to acc-qta-sec-cla-900.
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     acc-qta-sec-cla-900.
       acc-qta-sec-cla-300.
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      w-rig-num-mag-lda (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione                            *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : il lotto di acquisto e' "
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     " !"
                                delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     acc-qta-sec-cla-900.
       acc-qta-sec-cla-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-qta-sec-cla-999.
       acc-qta-sec-cla-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' secondaria              *
      *    *-----------------------------------------------------------*
       vis-qta-sec-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    not  = "S" and
                     w-rig-snx-tum (1)    not  = "P"
                     go to vis-qta-sec-999.
       vis-qta-sec-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
       vis-qta-sec-200.
      *                  *---------------------------------------------*
      *                  * Preparazione valore numerico da editare     *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-cfr
           else      move  w-rig-qta-ord (1)
                                          to   w-sav-qta-cfr          .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore da editare  *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        =    zero
                     go to vis-qta-sec-300
           else      go to vis-qta-sec-400.
       vis-qta-sec-300.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione a spaces                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-sec-999.
       vis-qta-sec-400.
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      w-sav-qta-cfr        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione unita' di misura           *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-umf-tum (1)
                                          to   w-sav-umi-sec
           else      move  w-rig-umi-acq (1)
                                          to   w-sav-umi-sec          .
      *                      *-----------------------------------------*
      *                      * Composizione area editata completa      *
      *                      *-----------------------------------------*
           move      spaces               to   v-alf                  .
           string    "("
                                delimited by   size
                     w-sav-umi-sec
                                delimited by   size
                     " "
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into v-alf                  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      37                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-sec-999.
       vis-qta-sec-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag non bloccante 1      *
      *    *-----------------------------------------------------------*
       acc-flg-xb1-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (1)
                                          =    spaces
                     go to acc-flg-xb1-999.
       acc-flg-xb1-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      57                   to   v-pos                  .
           move      "( )"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-flg-nbx (1, 1) to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb1-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb1-999.
      *              *-------------------------------------------------*
      *              * Se Pf4 : come Down                              *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "DOWN"         to   v-key                  .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-nbx (1, 1)   .
       acc-flg-xb1-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-flg-xb1-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt                      *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb1-000      thru pmt-flg-xb1-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore                      *
      *                  *---------------------------------------------*
           perform   vis-flg-xb1-000      thru vis-flg-xb1-999        .
       acc-flg-xb1-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-flg-xb1-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-flg-xb1-100.
       acc-flg-xb1-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag non bloccante 1              *
      *    *-----------------------------------------------------------*
       vis-flg-xb1-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (1)
                                          =    spaces
                     go to vis-flg-xb1-999.
       vis-flg-xb1-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-rig-flg-nbx (1, 1) to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-xb1-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag non bloccante 2      *
      *    *-----------------------------------------------------------*
       acc-flg-xb2-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (2)
                                          =    spaces
                     go to acc-flg-xb2-999.
       acc-flg-xb2-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      "( )"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-flg-nbx (1, 2) to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb2-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb2-999.
      *              *-------------------------------------------------*
      *              * Se Pf4 : come Down                              *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "DOWN"         to   v-key                  .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-nbx (1, 2)   .
       acc-flg-xb2-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore diverso da spaces : conversione   *
      *                  * nel carattere '*'                           *
      *                  *---------------------------------------------*
           if        w-rig-flg-nbx (1, 2) =    spaces
                     go to acc-flg-xb2-600.
           if        w-rig-flg-nbx (1, 2) =    "*"
                     go to acc-flg-xb2-600.
           move      "*"                  to   w-rig-flg-nbx (1, 2)   .
           perform   vis-flg-xb2-000      thru vis-flg-xb2-999        .
       acc-flg-xb2-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt                      *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb2-000      thru pmt-flg-xb2-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore                      *
      *                  *---------------------------------------------*
           perform   vis-flg-xb2-000      thru vis-flg-xb2-999        .
       acc-flg-xb2-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-flg-xb2-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-flg-xb2-100.
       acc-flg-xb2-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag non bloccante 2              *
      *    *-----------------------------------------------------------*
       vis-flg-xb2-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (2)
                                          =    spaces
                     go to vis-flg-xb2-999.
       vis-flg-xb2-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      w-rig-flg-nbx (1, 2) to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-xb2-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag non bloccante 3      *
      *    *-----------------------------------------------------------*
       acc-flg-xb3-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (3)
                                          =    spaces
                     go to acc-flg-xb3-999.
       acc-flg-xb3-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "( )"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      64                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-flg-nbx (1, 3) to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb3-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb3-999.
      *              *-------------------------------------------------*
      *              * Se Pf4 : come Down                              *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "DOWN"         to   v-key                  .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-nbx (1, 3)   .
       acc-flg-xb3-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore diverso da spaces : conversione   *
      *                  * nel carattere '*'                           *
      *                  *---------------------------------------------*
           if        w-rig-flg-nbx (1, 3) =    spaces
                     go to acc-flg-xb3-600.
           if        w-rig-flg-nbx (1, 3) =    "*"
                     go to acc-flg-xb3-600.
           move      "*"                  to   w-rig-flg-nbx (1, 3)   .
           perform   vis-flg-xb3-000      thru vis-flg-xb3-999        .
       acc-flg-xb3-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt                      *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb3-000      thru pmt-flg-xb3-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore                      *
      *                  *---------------------------------------------*
           perform   vis-flg-xb3-000      thru vis-flg-xb3-999        .
       acc-flg-xb3-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-flg-xb3-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-flg-xb3-100.
       acc-flg-xb3-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag non bloccante 3              *
      *    *-----------------------------------------------------------*
       vis-flg-xb3-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (3)
                                          =    spaces
                     go to vis-flg-xb3-999.
       vis-flg-xb3-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      64                   to   v-pos                  .
           move      w-rig-flg-nbx (1, 3) to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-xb3-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo di acquisto        *
      *    *-----------------------------------------------------------*
       acc-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-acq-999.
       acc-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-prz-acq (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "prz-acq"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-acq (1)      .
       acc-prz-acq-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-prz-acq-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-prz-acq-610.
      *                      *-----------------------------------------*
      *                      * Se percentuali di sconto gia' tutte a   *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-acq-610.
      *                      *-----------------------------------------*
      *                      * Trattamento percentuali di sconto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-prz-acq-610.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-acq-620.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-acq-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-prz-acq-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-acq-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-acq-100.
       acc-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Prezzo di acquisto                *
      *    *-----------------------------------------------------------*
       vis-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      w-rig-prz-acq (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      v-edt                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per legame   *
      *    * valutario                                                 *
      *    *-----------------------------------------------------------*
       acc-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa al   *
      *                      * legame valutario                        *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-sgl-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-sgl-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-sav-sgl-vpl          .
       acc-sgl-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpl (1)    to   w-cod-cod-zvl-cod      .
           move      17                   to   w-cod-cod-zvl-lin      .
           move      54                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpl-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpl-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpl-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpl-110.
       acc-sgl-vpl-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "sgl-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-sgl-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpl (1)      .
       acc-sgl-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpl-100.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per fatturazione                            *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-tes-sgl-vpf (1)
                     go to acc-sgl-vpl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per fatturazione del documento 
      -              "!              "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-500.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta per legame valutario uguale *
      *                  * a sigla vauta base : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    c-sgl
                     go to acc-sgl-vpl-100.
       acc-sgl-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    w-sav-sgl-vpl
                     go to acc-sgl-vpl-800.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che il valore sia esi- *
      *                  * stente o no                                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-sgl-vpl-620
           else      go to acc-sgl-vpl-640.
       acc-sgl-vpl-620.
      *                  *---------------------------------------------*
      *                  * Se valore non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori connessi         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-dec-vpl (1)      .
           move      spaces               to   w-rig-tdc-vpl (1)      .
           move      zero                 to   w-rig-prz-vpl (1)      .
           move      zero                 to   w-rig-cdc-vpl (1)      .
           move      zero                 to   w-rig-ccr-vpl (1)      .
           move      zero                 to   w-rig-plm-vpl (1)      .
           move      spaces               to   w-rig-tlm-vpl (1)      .
           move      spaces               to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori connessi         *
      *                      *-----------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-700.
       acc-sgl-vpl-640.
      *                  *---------------------------------------------*
      *                  * Se valore esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori connessi         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Prezzo di riferimento               *
      *                          *-------------------------------------*
           move      w-rig-prz-acq (1)    to   w-rig-prz-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio                                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpl-642.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-642.
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio                              *
      *                          *-------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Tipo di limitazione                 *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-tlm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Momento di applicazione cambio      *
      *                          *-------------------------------------*
           move      "F"                  to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-700.
       acc-sgl-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-sgl-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpl-100.
       acc-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Sigla valuta per *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       vis-sgl-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-rig-sgl-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Coefficiente di cambio    *
      *    * per legame valutario                                      *
      *    *-----------------------------------------------------------*
       acc-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-ccr-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-ccr-vpl-999.
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-ccr-vpl-999.
       acc-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           move      "N"                  to   w-coe-cmb-vlt-snd      .
           move      w-rig-ccr-vpl (1)    to   w-coe-cmb-vlt-cdc      .
           move      17                   to   w-coe-cmb-vlt-lin      .
           move      58                   to   w-coe-cmb-vlt-pos      .
           move      zero                 to   w-coe-cmb-vlt-dln      .
           move      zero                 to   w-coe-cmb-vlt-dps      .
           move      "BD"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-ccr-vpl-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-ccr-vpl-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-ccr-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ccr-vpl-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-ccr-vpl-110.
       acc-ccr-vpl-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-ccr-vpl-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "ccr-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-ccr-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ccr-vpl (1)      .
       acc-ccr-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore zero non ammesso a meno che non si   *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    not  = zero
                     go to acc-ccr-vpl-600.
           if        v-key                =    "UP  "
                     go to acc-ccr-vpl-600
           else      go to acc-ccr-vpl-100.
       acc-ccr-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccr-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-ccr-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ccr-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ccr-vpl-100.
       acc-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Coefficiente di  *
      *    * cambio per legame valutario                               *
      *    *-----------------------------------------------------------*
       vis-ccr-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      17                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-rig-ccr-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuale di tolleranza *
      *    * per legame valutario                                      *
      *    *-----------------------------------------------------------*
       acc-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-plm-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-plm-vpl-999.
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-plm-vpl-999.
       acc-plm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "plm-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-plm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-plm-vpl (1)      .
       acc-plm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-plm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    not  = zero
                     go to acc-plm-vpl-700.
      *                  *---------------------------------------------*
      *                  * Normalizzazione tipo di limitazione per le- *
      *                  * game valutario                              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     move  spaces         to   w-rig-tlm-vpl (1)
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999        .
       acc-plm-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-plm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-plm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-plm-vpl-100.
       acc-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Percentuale di   *
      *    * tolleranza per legame valutario                           *
      *    *-----------------------------------------------------------*
       vis-plm-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Tipo di limitazione per   *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       acc-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-tlm-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-tlm-vpl-999.
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-tlm-vpl-999.
           if        w-rig-plm-vpl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    =    spaces
                     move  "T"            to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "tlm-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-tlm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tlm-vpl-400.
      *                  *---------------------------------------------*
      *                  * Find per note operative                     *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-fnd-tlm-vpl-tlm      .
           perform   fnd-tlm-vpl-000      thru fnd-tlm-vpl-999        .
           move      w-fnd-tlm-vpl-tlm    to   w-rig-tlm-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tlm-vpl-100.
       acc-tlm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     go to acc-tlm-vpl-500.
           if        v-key                =    "UP  "
                     go to acc-tlm-vpl-600
           else      go to acc-tlm-vpl-100.
       acc-tlm-vpl-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = "T" and
                     w-rig-tlm-vpl (1)    not  = "F" and
                     w-rig-tlm-vpl (1)    not  = "M"
                     go to acc-tlm-vpl-100.
       acc-tlm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tlm-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-tlm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tlm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-tlm-vpl-100.
       acc-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Tipo di limita-  *
      *    * zione per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-tlm-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuali sconto in riga*
      *    *-----------------------------------------------------------*
       acc-per-scr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-per-scr-999.
      *                      *-----------------------------------------*
      *                      * Test su apposita personalizzazione      *
      *                      *-----------------------------------------*
           if        w-prs-tac-psr        =    99
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-per-scr-ctr      .
       acc-per-scr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           if        w-acc-per-scr-ctr    >    5
                     subtract  5          from v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      "[1] "               to   v-pfk (14)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "per-scr"      to   w-dup-vri-pre-ncd
                     move  w-acc-per-scr-ctr
                                          to   w-dup-vri-pre-ctr
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999
                     move  "TAB "         to   v-key                  .
       acc-per-scr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-per-scr
                                              (1, w-acc-per-scr-ctr)  .
       acc-per-scr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-per-scr-605.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-per-scr-610.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione dell'impostazione        *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-scr-620
           else if   v-key                =    "DOWN"
                     go to acc-per-scr-630
           else if   v-key                =    "TAB "
                     go to acc-per-scr-700
           else if   v-key                =    "[1] "
                     go to acc-per-scr-640
           else if   v-key                =    "DO  "
                     go to acc-per-scr-800
           else      go to acc-per-scr-630.
       acc-per-scr-620.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr    =    1
                     go to acc-per-scr-999.
           subtract  1                    from w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-630.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-640.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento prezzo di acquisto            *
      *                  *---------------------------------------------*
           move      w-rig-prz-net (1)    to   w-rig-prz-acq (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Visualizzazione prezzo di acquisto          *
      *                  *---------------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Uscita come per Down                        *
      *                  *---------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-700.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr        =    05
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-per-scr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-per-scr-100.
       acc-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di sconto in riga     *
      *    *-----------------------------------------------------------*
       vis-per-scr-000.
           move      zero                 to   w-vis-per-scr-ctr      .
       vis-per-scr-200.
           add       1                    to   w-vis-per-scr-ctr      .
           if        w-vis-per-scr-ctr    >    5
                     go to vis-per-scr-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      w-vis-per-scr-ctr    to   v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      w-rig-per-scr 
                    (1, w-vis-per-scr-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-per-scr-200.
       vis-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Importo in riga           *
      *    *-----------------------------------------------------------*
       acc-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-imp-rig-999.
       acc-imp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-imp-rig (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "imp-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-rig (1)      .
       acc-imp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione a meno    *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    not  = zero
                     go to acc-imp-rig-600.
           if        v-key                =    "UP  "
                     go to acc-imp-rig-600
           else      go to acc-imp-rig-100.
       acc-imp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-rig-100.
       acc-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo in riga                   *
      *    *-----------------------------------------------------------*
       vis-imp-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Data consegna richiesta   *
      *    *-----------------------------------------------------------*
       acc-dcn-ric-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-dcn-ric-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-dcn-ric (1)    to   w-sav-dcn-ric          .
       acc-dcn-ric-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-dcn-ric (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-ric-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-ric-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "dcn-ric"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-dcn-ric (1)      .
       acc-dcn-ric-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-dcn-ric (1)    not  = zero
                     go to acc-dcn-ric-500.
      *                      *-----------------------------------------*
      *                      * Forzatura da data documento             *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   w-rig-dcn-ric (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-dcn-ric-000      thru vis-dcn-ric-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dcn-ric-600.
       acc-dcn-ric-500.
      *                  *---------------------------------------------*
      *                  * Se valore inferiore alla data documento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-dcn-ric (1)    not  < w-tes-dat-doc
                     go to acc-dcn-ric-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Data consegna richiesta inferiore alla data ordine
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dcn-ric-600.
       acc-dcn-ric-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-dcn-ric (1)    =    w-sav-dcn-ric
                     go to acc-dcn-ric-800.
      *                  *---------------------------------------------*
      *                  * Trattamento data consegna prevista          *
      *                  *---------------------------------------------*
           perform   trt-dcn-prv-000      thru trt-dcn-prv-999        .
       acc-dcn-ric-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-dcn-ric-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-dcn-ric-100.
       acc-dcn-ric-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna                     *
      *    *-----------------------------------------------------------*
       vis-dcn-ric-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-dcn-ric (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dcn-ric-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di stampa data    *
      *    * consegna richiesta                                        *
      *    *-----------------------------------------------------------*
       acc-fds-dcr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-fds-dcr-999.
       acc-fds-dcr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-fds-dcr (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-fds-dcr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-fds-dcr-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "fds-dcr"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-fds-dcr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-fds-dcr (1)      .
       acc-fds-dcr-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-fds-dcr-400.
      *                  *---------------------------------------------*
      *                  * Find per note operative                     *
      *                  *---------------------------------------------*
           move      w-rig-fds-dcr (1)    to   w-fnd-fds-dcr-fds      .
           perform   fnd-fds-dcr-000      thru fnd-fds-dcr-999        .
           move      w-fnd-fds-dcr-fds    to   w-rig-fds-dcr (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-fds-dcr-100.
       acc-fds-dcr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-fds-dcr (1)    not  = " " and
                     w-rig-fds-dcr (1)    not  = "N" and
                     w-rig-fds-dcr (1)    not  = "U" and
                     w-rig-fds-dcr (1)    not  = "A"
                     go to acc-fds-dcr-100.
       acc-fds-dcr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fds-dcr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-fds-dcr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-fds-dcr-100.
       acc-fds-dcr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Formato di stam- *
      *    * pa data consegna richiesta                                *
      *    *-----------------------------------------------------------*
       vis-fds-dcr-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      w-rig-fds-dcr (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fds-dcr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Data consegna prevista    *
      *    *-----------------------------------------------------------*
       acc-dcn-prv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-dcn-prv-999.
       acc-dcn-prv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-dcn-prv (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-prv-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-prv-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "dcn-prv"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-dcn-prv (1)      .
       acc-dcn-prv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-dcn-prv (1)    not  = zero
                     go to acc-dcn-prv-600.
      *                  *---------------------------------------------*
      *                  * Trattamento data consegna prevista          *
      *                  *---------------------------------------------*
           perform   trt-dcn-prv-000      thru trt-dcn-prv-999        .
       acc-dcn-prv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dcn-prv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-dcn-prv-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-dcn-prv-100.
       acc-dcn-prv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna prevista            *
      *    *-----------------------------------------------------------*
       vis-dcn-prv-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      46                   to   v-pos                  .
           move      w-rig-dcn-prv (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dcn-prv-999.
           exit.

      *    *===========================================================*
      *    * Trattamento data consegna prevista                        *
      *    *-----------------------------------------------------------*
       trt-dcn-prv-000.
      *              *-------------------------------------------------*
      *              * Test su valore personalizzazione                *
      *              *-------------------------------------------------*
           if        w-prs-tdt-apv        =    "N"
                     go to trt-dcn-prv-600
           else if   w-prs-tdt-apv        =    "M"
                     go to trt-dcn-prv-200
           else if   w-prs-tdt-apv        =    "F"
                     go to trt-dcn-prv-400.
       trt-dcn-prv-200.
      *              *-------------------------------------------------*
      *              * Se default da tempo medio di consegna           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su valore data documento               *
      *                  *---------------------------------------------*
           if        w-tes-dat-doc        =    zero
                     go to trt-dcn-prv-280.
      *                  *---------------------------------------------*
      *                  * Test su valore attuale data                 *
      *                  *---------------------------------------------*
           if        w-rig-dcn-ric (1)    not  = w-sav-dcn-ric
                     go to trt-dcn-prv-220.
           if        w-rig-dcn-prv (1)    not  = zero
                     go to trt-dcn-prv-280.
       trt-dcn-prv-220.
      *                  *---------------------------------------------*
      *                  * Test su valore tempo medio di consegna      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-apv    =    zero
                     go to trt-dcn-prv-280.
      *                  *---------------------------------------------*
      *                  * Determinazione data maggiorata del numero   *
      *                  * giorni di approvigionamento                 *
      *                  *---------------------------------------------*
           move      w-tes-dat-doc        to   w-det-dat-nrg-dtb      .
           move      w-let-arc-aaq-apv    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
      *                  *---------------------------------------------*
      *                  * Confronto con data richiesta                *
      *                  *---------------------------------------------*
           if        w-rig-dcn-ric (1)    >    w-det-dat-nrg-dti
                     move  w-rig-dcn-ric (1)
                                          to   w-rig-dcn-prv (1)
           else      move  w-det-dat-nrg-dti
                                          to   w-rig-dcn-prv (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione data determinata            *
      *                  *---------------------------------------------*
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento flag di conferma                *
      *                  *---------------------------------------------*
           move      spaces               to   w-rig-flg-cnf (1)      .
           perform   vis-flg-cnf-000      thru vis-flg-cnf-999        .
       trt-dcn-prv-280.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     trt-dcn-prv-900.
       trt-dcn-prv-400.
      *              *-------------------------------------------------*
      *              * Se default da tempo medio fornitore             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su valore data documento               *
      *                  *---------------------------------------------*
           if        w-tes-dat-doc        =    zero
                     go to trt-dcn-prv-480.
      *                  *---------------------------------------------*
      *                  * Test su valore attuale data                 *
      *                  *---------------------------------------------*
           if        w-rig-dcn-prv (1)    not  = zero
                     go to trt-dcn-prv-480.
      *                  *---------------------------------------------*
      *                  * Test su valore tempo medio di consegna      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-apv    =    zero
                     go to trt-dcn-prv-480.
      *                  *---------------------------------------------*
      *                  * Determinazione data maggiorata del numero   *
      *                  * giorni di approvigionamento                 *
      *                  *---------------------------------------------*
           move      w-tes-dat-doc        to   w-det-dat-nrg-dtb      .
           move      w-let-arc-aaf-apv    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
      *                  *---------------------------------------------*
      *                  * Confronto con data richiesta                *
      *                  *---------------------------------------------*
           if        w-rig-dcn-ric (1)    >    w-det-dat-nrg-dti
                     move  w-rig-dcn-ric (1)
                                          to   w-rig-dcn-prv (1)
           else      move  w-det-dat-nrg-dti
                                          to   w-rig-dcn-prv (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione data determinata            *
      *                  *---------------------------------------------*
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento flag di conferma                *
      *                  *---------------------------------------------*
           move      spaces               to   w-rig-flg-cnf (1)      .
           perform   vis-flg-cnf-000      thru vis-flg-cnf-999        .
       trt-dcn-prv-480.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     trt-dcn-prv-900.
       trt-dcn-prv-600.
      *              *-------------------------------------------------*
      *              * Trattamento normale                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data consegna prevista diversa da data   *
      *                  * consegna richiesta precedente: oltre        *
      *                  *---------------------------------------------*
______*    if        w-rig-dcn-prv (1)    not  = w-sav-dcn-ric
______*              go to trt-dcn-prv-680.
      *                  *---------------------------------------------*
      *                  * Trattamento data consegna prevista          *
      *                  *---------------------------------------------*
           move      w-rig-dcn-ric (1)    to   w-rig-dcn-prv (1)      .
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento flag di conferma                *
      *                  *---------------------------------------------*
           move      spaces               to   w-rig-flg-cnf (1)      .
           perform   vis-flg-cnf-000      thru vis-flg-cnf-999        .
       trt-dcn-prv-680.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     trt-dcn-prv-900.
       trt-dcn-prv-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     trt-dcn-prv-999.
       trt-dcn-prv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag di conferma          *
      *    *-----------------------------------------------------------*
       acc-flg-cnf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-flg-cnf-999.
       acc-flg-cnf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-flg-cnf (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-flg-cnf-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-cnf-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "flg-cnf"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-cnf (1)      .
       acc-flg-cnf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-flg-cnf (1)    =    spaces or
                     w-rig-flg-cnf (1)    =    "?"
                     go to acc-flg-cnf-600.
           if        w-rig-flg-cnf (1)    not  <  "0" and
                     w-rig-flg-cnf (1)    not  >  "9"
                     go to acc-flg-cnf-600.
           if        w-rig-flg-cnf (1)    not  <  "A" and
                     w-rig-flg-cnf (1)    not  >  "Z"
                     go to acc-flg-cnf-600
           else      go to acc-flg-cnf-100.
       acc-flg-cnf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-flg-cnf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-flg-cnf-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-flg-cnf-100.
       acc-flg-cnf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag di conferma                  *
      *    *-----------------------------------------------------------*
       vis-flg-cnf-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      w-rig-flg-cnf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-cnf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data consegna confermata             *
      *    *-----------------------------------------------------------*
       acc-dcn-cnf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-dcn-cnf        not  = "S"
                     go to acc-dcn-cnf-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-dcn-cnf-999.
       acc-dcn-cnf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-dcn-cnf (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-cnf-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-cnf-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "dcn-cnf"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-dcn-cnf (1)      .
       acc-dcn-cnf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dcn-cnf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dcn-cnf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-dcn-cnf-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-dcn-cnf-100.
       acc-dcn-cnf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna confermata          *
      *    *-----------------------------------------------------------*
       vis-dcn-cnf-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-dcn-cnf        not  = "S"
                     go to vis-dcn-cnf-999.
       vis-dcn-cnf-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-rig-dcn-cnf (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dcn-cnf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice iva                *
      *    *-----------------------------------------------------------*
       acc-civ-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-civ-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-civ-rig-100.
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-civ-rig-999.
       acc-civ-rig-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-rig-civ-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      20                   to   w-cod-mne-zci-lin      .
           move      21                   to   w-cod-mne-zci-pos      .
           move      20                   to   w-cod-mne-zci-dln      .
           move      32                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-civ-rig-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-civ-rig-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-civ-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-civ-rig-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-civ-rig-110.
       acc-civ-rig-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-civ-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-civ-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "civ-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-civ-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-civ-rig (1)      .
       acc-civ-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-rig-civ-rig (1)    to   d-imp-iva-cod-iva      .
           move      "5"                  to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                      *-----------------------------------------*
      *                      * Se errato : messaggio di errore         *
      *                      *-----------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-civ-rig-500.
      *                          *-------------------------------------*
      *                          * Messaggio di avviso                 *
      *                          *-------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-civ-rig-100.
       acc-civ-rig-500.
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      d-imp-iva-msg-exi    to   w-rig-civ-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero : reimpostazione a meno*
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-rig-civ-rig (1)    not  = zero
                     go to acc-civ-rig-600.
           if        v-key                =    "UP  "
                     go to acc-civ-rig-600
           else      go to acc-civ-rig-100.
       acc-civ-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-civ-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-civ-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-civ-rig-100.
       acc-civ-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice iva                *
      *    *-----------------------------------------------------------*
       vis-civ-rig-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-rig-civ-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione codice IVA    *
      *    *-----------------------------------------------------------*
       vis-civ-rig-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-civ-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Riferimento a listino fornitore            *
      *    *-----------------------------------------------------------*
       acc-rif-lst-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-rif-lst        =    "N"
                     go to acc-rif-lst-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-rif-lst-999.
       acc-rif-lst-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-rif-lst (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-rif-lst-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-rif-lst-999.
      *              *-------------------------------------------------*
      *              * Se Pf4 : come Down                              *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "rif-lst"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-rif-lst (1)      .
       acc-rif-lst-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-rif-lst-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-rif-lst-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-rif-lst-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-rif-lst-100.
       acc-rif-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Riferimento a listino fornitore   *
      *    *-----------------------------------------------------------*
       vis-rif-lst-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-rif-lst        =    "N"
                     go to vis-rif-lst-999.
       vis-rif-lst-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      w-rig-rif-lst (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rif-lst-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice contropartita      *
      *    *-----------------------------------------------------------*
       acc-ctp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ctp-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ctp-rig-100.
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-ctp-rig-999.
       acc-ctp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rig-ctp-rig (1)    to   w-cod-mne-pdc-cod      .
           move      21                   to   w-cod-mne-pdc-lin      .
           move      21                   to   w-cod-mne-pdc-pos      .
           move      21                   to   w-cod-mne-pdc-dln      .
           move      32                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-rig-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-rig-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-rig-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-rig-110.
       acc-ctp-rig-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ctp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ctp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "ctp-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-ctp-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ctp-rig (1)      .
       acc-ctp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-rig-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-ctp-rig (1)    =    zero
                     go to acc-ctp-rig-100.
       acc-ctp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ctp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ctp-rig-100.
       acc-ctp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita acquisti in *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       vis-ctp-rig-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rig-ctp-rig (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione contropartita *
      *    * acquisti in riga                                          *
      *    *-----------------------------------------------------------*
       vis-ctp-rig-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-ctp-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Duplicazione valore della riga precedente                 *
      *    *-----------------------------------------------------------*
       dup-vri-pre-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Se su prima riga di accettazione : uscita       *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    =    1
                     go to dup-vri-pre-999.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Lettura record catena precedente                *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           subtract  1                    from w-cnt-cor-nrg-dac
                                        giving w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
       dup-vri-pre-100.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore campo riga precedente in *
      *              * area v                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del nome campo da    *
      *                  * duplicare                                   *
      *                  *---------------------------------------------*
           if        w-dup-vri-pre-ncd    =    "cod-aoc"
                     move  w-rig-tip-rig-cac (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "cod-pro"
                     move  w-rig-alf-mag (1)
                                          to   v-alf
                     move  w-rig-num-mag (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "fda-pif"
                     move  w-rig-fda-pif (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "des-rig"
                     move  w-rig-des-rig (1)
                                          to   v-txt
      *
           else if   w-dup-vri-pre-ncd    =    "qta-pri"
                     if      w-rig-snx-tum (1)
                                          =    "P"
                             move  w-rig-qta-ord (1)
                                          to   v-num
                     else if w-rig-snx-tum (1)
                                          =    "S"
                             move  w-rig-qta-fda (1)
                                          to   v-num
                     else    move  w-rig-qta-fda (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "qta-sec"
                     if      w-rig-snx-tum (1)
                                          =    "P"
                             move  w-rig-qta-fda (1)
                                          to   v-num
                     else    move  w-rig-qta-ord (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "prz-acq"
                     move  w-rig-prz-acq (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpl"
                     move  w-rig-sgl-vpl (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "ccr-vpl"
                     move  w-rig-ccr-vpl (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "plm-vpl"
                     move  w-rig-plm-vpl (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "tlm-vpl"
                     move  w-rig-tlm-vpl (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "per-scr"
                     move  w-rig-per-scr
                    (1, w-dup-vri-pre-ctr)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "imp-rig"
                     move  w-rig-imp-rig (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-ric"
                     move  w-rig-dcn-ric (1)
                                          to   v-dat
      *
           else if   w-dup-vri-pre-ncd    =    "fds-dcr"
                     move  w-rig-fds-dcr (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-prv"
                     move  w-rig-dcn-prv (1)
                                          to   v-dat
      *
           else if   w-dup-vri-pre-ncd    =    "flg-cnf"
                     move  w-rig-flg-cnf (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "civ-rig"
                     move  w-rig-civ-rig (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "rif-lst"
                     move  w-rig-rif-lst (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "ctp-rig"
                     move  w-rig-ctp-rig (1)
                                          to   v-num
      *
           else      go to dup-vri-pre-150.
       dup-vri-pre-150.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       dup-vri-pre-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore campo riga attuale da    *
      *              * area v                                          *
      *              *-------------------------------------------------*
           if        w-dup-vri-pre-ncd    =    "cod-aoc"
                     move  v-num          to   w-rig-tip-rig-cac (1)
      *
           else if   w-dup-vri-pre-ncd    =    "cod-pro"
                     move  v-alf          to   w-rig-alf-mag (1)
                     move  v-num          to   w-rig-num-mag (1)
      *
           else if   w-dup-vri-pre-ncd    =    "fda-pif"
                     move  v-alf          to   w-rig-fda-pif (1)
      *
           else if   w-dup-vri-pre-ncd    =    "des-rig"
                     move  v-txt          to   w-rig-des-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "qta-pri"
                     if      w-rig-snx-tum (1)
                                          =    "P"
                             move  v-num  to   w-rig-qta-ord (1)
                     else if w-rig-snx-tum (1)
                                          =    "S"
                             move  v-num  to   w-rig-qta-fda (1)
                     else    move  v-num  to   w-rig-qta-fda (1)
      *
           else if   w-dup-vri-pre-ncd    =    "qta-sec"
                     if    w-rig-snx-tum (1)
                                          =    "P"
                           move  v-num    to   w-rig-qta-fda (1)
                     else  move  v-num    to   w-rig-qta-ord (1)
      *
           else if   w-dup-vri-pre-ncd    =    "prz-acq"
                     move  v-num          to   w-rig-prz-acq (1)
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpl"
                     move  v-alf          to   w-rig-sgl-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "ccr-vpl"
                     move  v-num          to   w-rig-ccr-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "plm-vpl"
                     move  v-num          to   w-rig-plm-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "tlm-vpl"
                     move  v-alf          to   w-rig-tlm-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "per-scr"
                     move  v-num          to   w-rig-per-scr
                                              (1, w-dup-vri-pre-ctr)
      *
           else if   w-dup-vri-pre-ncd    =    "imp-rig"
                     move  v-num          to   w-rig-imp-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-ric"
                     move  v-dat          to   w-rig-dcn-ric (1)
      *
           else if   w-dup-vri-pre-ncd    =    "fds-dcr"
                     move  v-alf          to   w-rig-fds-dcr (1)
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-prv"
                     move  v-dat          to   w-rig-dcn-prv (1)
      *
           else if   w-dup-vri-pre-ncd    =    "flg-cnf"
                     move  v-alf          to   w-rig-flg-cnf (1)
      *
           else if   w-dup-vri-pre-ncd    =    "civ-rig"
                     move  v-num          to   w-rig-civ-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "ctp-rig"
                     move  v-num          to   w-rig-ctp-rig (1)
      *
           else      go to dup-vri-pre-300.
       dup-vri-pre-300.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore campo attuale            *
      *              *-------------------------------------------------*
           if        w-dup-vri-pre-ncd    =    "cod-aoc"
                     perform vis-cod-aoc-000
                                          thru vis-cod-aoc-999
      *
           else if   w-dup-vri-pre-ncd    =    "cod-pro"
                     perform vis-cod-pro-000
                                          thru vis-cod-pro-999
      *
           else if   w-dup-vri-pre-ncd    =    "fda-pif"
                     perform vis-fda-pif-000
                                          thru vis-fda-pif-999
      *
           else if   w-dup-vri-pre-ncd    =    "des-rig"
                     perform vis-des-rig-000
                                          thru vis-des-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "qta-pri"
                     perform vis-qta-pri-000
                                          thru vis-qta-pri-999
      *
           else if   w-dup-vri-pre-ncd    =    "qta-sec"
                     perform vis-qta-sec-000
                                          thru vis-qta-sec-999
      *
           else if   w-dup-vri-pre-ncd    =    "prz-acq"
                     perform vis-prz-acq-000
                                          thru vis-prz-acq-999
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpl"
                     perform vis-sgl-vpl-000
                                          thru vis-sgl-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "ccr-vpl"
                     perform vis-ccr-vpl-000
                                          thru vis-ccr-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "plm-vpl"
                     perform vis-plm-vpl-000
                                          thru vis-plm-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "tlm-vpl"
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "per-scr"
                     perform vis-per-scr-000
                                          thru vis-per-scr-999
                     move  w-rig-per-scr
                    (1, w-dup-vri-pre-ctr)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "imp-rig"
                     perform vis-imp-rig-000
                                          thru vis-imp-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-ric"
                     perform vis-dcn-ric-000
                                          thru vis-dcn-ric-999
      *
           else if   w-dup-vri-pre-ncd    =    "fds-dcr"
                     perform vis-fds-dcr-000
                                          thru vis-fds-dcr-999
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-prv"
                     perform vis-dcn-prv-000
                                          thru vis-dcn-prv-999
      *
           else if   w-dup-vri-pre-ncd    =    "flg-cnf"
                     perform vis-flg-cnf-000
                                          thru vis-flg-cnf-999
      *
           else if   w-dup-vri-pre-ncd    =    "civ-rig"
                     perform vis-civ-rig-000
                                          thru vis-civ-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "ctp-rig"
                     perform vis-ctp-rig-000
                                          thru vis-ctp-rig-999
      *
           else      go to dup-vri-pre-400.
       dup-vri-pre-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     dup-vri-pre-999.
       dup-vri-pre-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per riga corpo *
      *    *-----------------------------------------------------------*
       acc-pre-vrc-000.
      *              *-------------------------------------------------*
      *              * Prompt per accettazione presa visione riga      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      21                   to   v-lin                  .
           move      79                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-pre-vrc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-pre-vrc-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-pre-vrc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-pre-vrc-000.
       acc-pre-vrc-999.
           exit.


