      *                                  *-----------------------------*
           move      w-rig-alf-mag (1)    to   w-lin-imm-cod-p13      .
      *                                  *-----------------------------*
      *                                  * Editing segnale codice for- *
      *                                  * nitore                      *
      *                                  *-----------------------------*
           move      "[F]"                to   w-lin-imm-pfp-p13      .
      *                                  *-----------------------------*
      *                                  * Editing codice secondo il   *
      *                                  * fornitore                   *
      *                                  *-----------------------------*
           move      w-rig-cop-sfn (1)    to   w-lin-imm-cdf-p13      .
      *                                  *-----------------------------*
      *                                  * Continuazione               *
      *                                  *-----------------------------*
           go to     vis-lin-cor-532.
       vis-lin-cor-526.
      *                              *---------------------------------*
      *                              * Se personalizzazione tipo : 14  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Editing parentesi sinistra  *
      *                                  *-----------------------------*
           move      "["                  to   w-lin-imm-pqs-p14      .
      *                                  *-----------------------------*
      *                                  * Editing tipo codice di ma-  *
      *                                  * gazzino                     *
      *                                  *-----------------------------*
           if        w-rig-tip-mag (1)    =    01
                     move  "P"            to   w-lin-imm-tco-p14
           else if   w-rig-tip-mag (1)    =    02
                     move  "S"            to   w-lin-imm-tco-p14
           else if   w-rig-tip-mag (1)    =    03
                     move  "M"            to   w-lin-imm-tco-p14
           else if   w-rig-tip-mag (1)    =    04
                     move  "V"            to   w-lin-imm-tco-p14
           else      move  "?"            to   w-lin-imm-tco-p14      .
      *                                  *-----------------------------*
      *                                  * Editing parentesi destra    *
      *                                  *-----------------------------*
           move      "]"                  to   w-lin-imm-pqd-p14      .
      *                                  *-----------------------------*
