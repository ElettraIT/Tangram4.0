      *    *===========================================================*
      *    * Routine pre-trattamento piede registrazione               *
      *    *-----------------------------------------------------------*
       pre-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Determinazione totali riga                      *
      *              *-------------------------------------------------*
           perform   det-tot-rig-000      thru det-tot-rig-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totali riepilogo documento       *
      *              *-------------------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
       pre-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione numero pagine che compongono il piede      *
      *    *-----------------------------------------------------------*
       dmp-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Il piede e' composto di nr. 1 pagina            *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-sts-imp-mpp      .
       dmp-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no pagina w-cnt-sts-imp-npp da trattare *
      *    *-----------------------------------------------------------*
       snp-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snx      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina piede  *
      *              *-------------------------------------------------*
           go to     snp-pie-reg-100
                     depending            on   w-cnt-sts-imp-npp      .
           go to     snp-pie-reg-999.
       snp-pie-reg-100.
      *              *-------------------------------------------------*
      *              * Pagina 1 : sempre accettata                     *
      *              *-------------------------------------------------*
           go to     snp-pie-reg-999.
       snp-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione piede registrazione                          *
      *    *-----------------------------------------------------------*
       acc-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-pie      .
      *              *-------------------------------------------------*
      *              * Normalizzazione func-key di impostazione        *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : piede                       *
      *              *-------------------------------------------------*
           move      "P"                  to   w-cnt-mfu-tip-imp      .
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     acc-pie-reg-100
                     depending            on   w-cnt-sts-imp-npp      .
           go to     acc-pie-reg-999.
       acc-pie-reg-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Abilitazione tasto Do                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-pie      .
      *                  *---------------------------------------------*
      *                  * Totale sconto in chiusura                   *
      *                  *---------------------------------------------*
           perform   acc-tot-scc-000      thru acc-tot-scc-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-pie
                     go to acc-pie-reg-999.
       acc-pie-reg-110.
      *                  *---------------------------------------------*
      *                  * Percentuale sconto in chiusura              *
      *                  *---------------------------------------------*
           perform   acc-per-scc-000      thru acc-per-scc-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-100.
       acc-pie-reg-120.
      *                  *---------------------------------------------*
      *                  * Totale sconto pagamento                     *
      *                  *---------------------------------------------*
           perform   acc-tot-scp-000      thru acc-tot-scp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-110.
           if        v-key                =    "DOWN"
                     go to acc-pie-reg-135.
       acc-pie-reg-130.
      *                  *---------------------------------------------*
      *                  * Percentuale sconto pagamento                *
      *                  *---------------------------------------------*
           perform   acc-per-scp-000      thru acc-per-scp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-120.
       acc-pie-reg-135.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella spese*
      *                  *---------------------------------------------*
           move      1                    to   w-acc-iep-spe-ctr      .
       acc-pie-reg-140.
      *                  *---------------------------------------------*
      *                  * Si/No addebito, importo e percentuale spesa *
      *                  *---------------------------------------------*
       acc-pie-reg-142.
      *                      *-----------------------------------------*
      *                      * Accettazione Si/No addebito             *
      *                      *-----------------------------------------*
           perform   acc-spe-snx-000      thru acc-spe-snx-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-pie-reg-144.
           subtract  1                    from w-acc-iep-spe-ctr      .
           if        w-acc-iep-spe-ctr    =    zero
                     go to acc-pie-reg-130
           else      go to acc-pie-reg-142.
       acc-pie-reg-144.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DOWN"
                     go to acc-pie-reg-148.
      *                      *-----------------------------------------*
      *                      * Accettazione importo spesa              *
      *                      *-----------------------------------------*
           perform   acc-spe-imp-000      thru acc-spe-imp-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-142.
       acc-pie-reg-146.
      *                      *-----------------------------------------*
      *                      * Accettazione percentuale spesa          *
      *                      *-----------------------------------------*
           perform   acc-spe-per-000      thru acc-spe-per-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-pie      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-pie      .
           if        w-cnt-tus-acc-pie    not  = spaces
                     go to acc-pie-reg-999.
           if        v-key                =    "UP  "
                     go to acc-pie-reg-144.
       acc-pie-reg-148.
      *                      *-----------------------------------------*
      *                      * Se Down o Return                        *
      *                      *-----------------------------------------*
           add       1                    to   w-acc-iep-spe-ctr      .
           if        w-acc-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to acc-pie-reg-149
           else      go to acc-pie-reg-142.
       acc-pie-reg-149.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella spese*
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-nst    to   w-acc-iep-spe-ctr      .
       acc-pie-reg-150.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-pie      .
           go to     acc-pie-reg-999.
       acc-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione piede registrazione                       *
      *    *-----------------------------------------------------------*
       vis-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     vis-pie-reg-100
                     depending            on   w-cnt-sts-imp-npp      .
           go to     vis-pie-reg-999.
       vis-pie-reg-100.
      *                  *---------------------------------------------*
      *                  * Totale sconto in chiusura                   *
      *                  *---------------------------------------------*
           perform   vis-tot-scc-000      thru vis-tot-scc-999        .
      *                  *---------------------------------------------*
      *                  * Percentuale sconto in chiusura              *
      *                  *---------------------------------------------*
           perform   vis-per-scc-000      thru vis-per-scc-999        .
      *                  *---------------------------------------------*
      *                  * Totale sconto pagamento                     *
      *                  *---------------------------------------------*
           perform   vis-tot-scp-000      thru vis-tot-scp-999        .
      *                  *---------------------------------------------*
      *                  * Percentuale sconto pagamento                *
      *                  *---------------------------------------------*
           perform   vis-per-scp-000      thru vis-per-scp-999        .
      *                  *---------------------------------------------*
      *                  * Si/No addebito spese                        *
      *                  *---------------------------------------------*
           perform   vis-spe-snx-000      thru vis-spe-snx-999        .
      *                  *---------------------------------------------*
      *                  * Importi spese                               *
      *                  *---------------------------------------------*
           perform   vis-spe-imp-000      thru vis-spe-imp-999        .
      *                  *---------------------------------------------*
      *                  * Percentuali spese                           *
      *                  *---------------------------------------------*
           perform   vis-spe-per-000      thru vis-spe-per-999        .
      *                  *---------------------------------------------*
      *                  * Volume totale                               *
      *                  *---------------------------------------------*
           perform   vis-vol-tot-000      thru vis-vol-tot-999        .
      *                  *---------------------------------------------*
      *                  * Riepilogo totali                            *
      *                  *---------------------------------------------*
           perform   vis-rie-tot-000      thru vis-rie-tot-999        .
           go to     vis-pie-reg-999.
       vis-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts piede                             *
      *    *-----------------------------------------------------------*
       pmt-pie-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     pmt-pie-reg-100
                     depending            on   w-cnt-sts-imp-npp      .
           go to     pmt-pie-reg-999.
       pmt-pie-reg-100.
      *                  *---------------------------------------------*
      *                  * Intestazione pagina totali                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "          Voce                   Importo     %    
      -              "|            Totali"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura fincatura                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "------------------------- ---------------- -----  
      -              "| ----------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Trattini verticali                      *
      *                      *-----------------------------------------*
           move      5                    to   I                      .
       pmt-pie-reg-210.
           add       1                    to   I                      .
           if        I                    >    21
                     go to pmt-pie-reg-220.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      I                    to   v-lin                  .
           move      51                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-pie-reg-210.
       pmt-pie-reg-220.
      *                  *---------------------------------------------*
      *                  * Sconto in chiusura                          *
      *                  *---------------------------------------------*
           perform   pmt-tot-scc-000      thru pmt-tot-scc-999        .
      *                  *---------------------------------------------*
      *                  * Sconto pagamento                            *
      *                  *---------------------------------------------*
           perform   pmt-tot-scp-000      thru pmt-tot-scp-999        .
      *                  *---------------------------------------------*
      *                  * Importi spese                               *
      *                  *---------------------------------------------*
           perform   pmt-spe-imp-000      thru pmt-spe-imp-999        .
      *                  *---------------------------------------------*
      *                  * Riepilogo totali                            *
      *                  *---------------------------------------------*
           perform   pmt-rie-tot-000      thru pmt-rie-tot-999        .
       pmt-pie-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per sconto in chiusura            *
      *    *-----------------------------------------------------------*
       pmt-tot-scc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      26                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Sconto incondizionato    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per sconto pagamento              *
      *    *-----------------------------------------------------------*
       pmt-tot-scp-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      26                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Sconto pagamento         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per importi spese                 *
      *    *-----------------------------------------------------------*
       pmt-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Se nessuna personalizzazione : uscita           *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to pmt-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-pmt-iep-spe-ctr      .
       pmt-spe-imp-100.
           add       1                    to   w-pmt-iep-spe-ctr      .
           if        w-pmt-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to pmt-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           add       09
                     w-pmt-iep-spe-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      w-prs-spe-fat-dve
                    (w-pmt-iep-spe-ctr)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       09
                     w-pmt-iep-spe-ctr  giving v-lin                  .
           move      26                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     pmt-spe-imp-100.
       pmt-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riepilogo totali              *
      *    *-----------------------------------------------------------*
       pmt-rie-tot-000.
      *              *-------------------------------------------------*
      *              * Totale lordo merce                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Lordo      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Totale netto merce                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Netto      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Totale spese                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Spese      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rie-tot-050.
      *              *-------------------------------------------------*
      *              * Totale inevaso                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-prs-tvn-rgd        not  = 11
                     go to pmt-rie-tot-060.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Inevaso    :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rie-tot-060.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che sia un documento in    *
      *              * valuta o no                                     *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to pmt-rie-tot-100
           else      go to pmt-rie-tot-200.
       pmt-rie-tot-100.
      *              *-------------------------------------------------*
      *              * Se documento non in valuta                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Totale     :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Valuta per fatturazione                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pmt-rie-tot-999.
       pmt-rie-tot-200.
      *              *-------------------------------------------------*
      *              * Se documento in valuta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Totale in valuta                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Totale "  delimited by   size
                     w-tes-sgl-vpf (1)
                                delimited by   size
                     " :"       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "       "  delimited by   size
                     c-sgl      delimited by   size
                     " :"       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-rie-tot-999.
       pmt-rie-tot-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Presa visione per pagina piede *
      *    *-----------------------------------------------------------*
       acc-pre-vpp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-pre-vpp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-pre-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-pre-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
