      *    *===========================================================*
      *    * Accettazione campo riga : Si/No addebito spesa in funzio- *
      *    * ne di w-acc-iep-spe-ctr                                   *
      *    *-----------------------------------------------------------*
       acc-spe-snx-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-snx-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-snx          .
       acc-spe-snx-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-spe-snx-lun    to   v-car                  .
           move      w-exp-spe-snx-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      w-exp-spe-snx-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     move  1              to   v-num
           else if   w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    1
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-spe-snx-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-spe-snx-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  0              to   w-pie-spe-snx
                                              (1, w-acc-iep-spe-inx)
           else if   v-num                =    2
                     move  1              to   w-pie-spe-snx
                                              (1, w-acc-iep-spe-inx)
           else      move  zero           to   w-pie-spe-snx
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-snx-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-snx-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-snx
                     go to acc-spe-snx-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-snx-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-spe-snx-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-snx-100.
       acc-spe-snx-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : Si/No addebito spese   *
      *    *-----------------------------------------------------------*
       vis-spe-snx-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-snx-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-snx-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-spe-snx-lun    to   v-car                  .
           move      w-exp-spe-snx-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      w-exp-spe-snx-tbl    to   v-txt                  .
           if        w-pie-spe-snx
                    (1, w-vis-iep-spe-inx)
                                          =    0
                     move  1              to   v-num
           else if   w-pie-spe-snx
                    (1, w-vis-iep-spe-inx)
                                          =    1
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-snx-100.
       vis-spe-snx-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga : Importo spesa in funzione di    *
      *    * w-acc-iep-spe-ctr                                         *
      *    *-----------------------------------------------------------*
       acc-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero spese personalizzate a zero : *
      *                      * il campo non e' da accettare            *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-imp-999.
      *                      *-----------------------------------------*
      *                      * Se spesa da non addebitare : no         *
      *                      *-----------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     go to acc-spe-imp-999.
      *                      *-----------------------------------------*
      *                      * Campo da accettare solo se spesa ad im- *
      *                      * porto variabile                         *
      *                      *-----------------------------------------*
           if        w-pie-spe-mad
                    (1, w-acc-iep-spe-inx)
                                          not  = 4
                     go to acc-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-imp          .
       acc-spe-imp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-spe-imp
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-imp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-imp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-imp
                     go to acc-spe-imp-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-imp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-spe-imp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-imp-100.
       acc-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : Importi spese          *
      *    *-----------------------------------------------------------*
       vis-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-imp-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      31                   to   v-pos                  .
           move      w-pie-spe-imp
                    (1, w-vis-iep-spe-inx)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-imp-100.
       vis-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga : % spesa in funzione di          *
      *    * w-acc-iep-spe-ctr                                         *
      *    *-----------------------------------------------------------*
       acc-spe-per-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero spese personalizzate a zero : *
      *                      * il campo non e' da accettare            *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-per-999.
      *                      *-----------------------------------------*
      *                      * Se spesa da non addebitare : no         *
      *                      *-----------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     go to acc-spe-per-999.
      *                      *-----------------------------------------*
      *                      * Campo da accettare solo se spesa a % va-*
      *                      * riabile                                 *
      *                      *-----------------------------------------*
           if        w-pie-spe-mad
                    (1, w-acc-iep-spe-inx)
                                          not  = 2
                     go to acc-spe-per-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-spe-per
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-per          .
       acc-spe-per-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      45                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-spe-per
                    (1, w-acc-iep-spe-inx)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-spe-per-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-spe-per-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-spe-per
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-per-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-per-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-spe-per
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-per
                     go to acc-spe-per-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-per-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-spe-per-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-per-100.
       acc-spe-per-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : % spese                *
      *    *-----------------------------------------------------------*
       vis-spe-per-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-per-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-per-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      45                   to   v-pos                  .
           move      w-pie-spe-per
                    (1, w-vis-iep-spe-inx)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-per-100.
       vis-spe-per-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Volume totale               *
      *    *-----------------------------------------------------------*
       vis-vol-tot-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tmo-orf-stv    not  = "S"
                     go to vis-vol-tot-999.
       vis-vol-tot-100.
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      26                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Volume (MC)              :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Valore                                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GBD"                to   v-edm                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-pie-tot-vol (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-vol-tot-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Riepilogo totali            *
      *    *-----------------------------------------------------------*
       vis-rie-tot-000.
      *              *-------------------------------------------------*
      *              * Totale lordo                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-lor (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale netto                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-net (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale spese                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-spe (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale documento                                *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      13                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-400.
      *              *-------------------------------------------------*
      *              * Totale inevaso                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-prs-tvn-rgd        not  = 11
                     go to vis-rie-tot-500.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-doc (1)    to   v-num                  .
           subtract  w-pie-tot-ric (1)    from v-num                  .
      *
           if        w-tes-flg-och (1)    not  = spaces
                     move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-500.
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to vis-rie-tot-900.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-pie-tot-doc (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      15                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-cvs-vlt-avb        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-rie-tot-999.
       vis-rie-tot-999.
           exit.

