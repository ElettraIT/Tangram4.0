      *    *===========================================================*
      *    * Visualizzazione prompt : Data scadenza pagamento          *
      *    *-----------------------------------------------------------*
       pmt-pag-dsm-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Data scadenza pagamento    :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Ammontare quota a forfait        *
      *    *-----------------------------------------------------------*
       pmt-pag-qaf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ammontare quota a forfait  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-pag-qaf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Ammontare acconto                *
      *    *-----------------------------------------------------------*
       pmt-pag-act-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ammontare acconto          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-pag-act-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-arc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-sav-cod-arc          .
       acc-cod-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcf-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-dcf-cod      .
           move      08                   to   w-cod-mne-dcf-lin      .
           move      27                   to   w-cod-mne-dcf-pos      .
           move      08                   to   w-cod-mne-dcf-rln      .
           move      41                   to   w-cod-mne-dcf-rps      .
           move      09                   to   w-cod-mne-dcf-vln      .
           move      41                   to   w-cod-mne-dcf-vps      .
           move      10                   to   w-cod-mne-dcf-lln      .
           move      41                   to   w-cod-mne-dcf-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
       acc-cod-arc-110.
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           if        w-cod-mne-dcf-ope    =    "F+"
                     go to acc-cod-arc-115.
           if        w-cod-mne-dcf-ope    =    "AC"
                     go to acc-cod-arc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-arc-115.
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
           go to     acc-cod-arc-110.
       acc-cod-arc-120.
           move      w-cod-mne-dcf-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-arc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-arc-999.
       acc-cod-arc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-arc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [fnt]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
           move      w-let-arc-fnt-rag    to   w-tes-cod-arc-rag (1)  .
           move      w-let-arc-fnt-via    to   w-tes-cod-arc-via (1)  .
           move      w-let-arc-fnt-loc    to   w-tes-cod-arc-loc (1)  .
           move      w-let-arc-fnt-naz    to   w-tes-cod-arc-naz (1)  .
           move      w-let-arc-fnt-piv    to   w-tes-cod-arc-piv (1)  .
           move      w-let-arc-fnt-cfi    to   w-tes-cod-arc-cfi (1)  .
           move      w-let-arc-fnt-stc    to   w-tes-cod-arc-stc (1)  .
           move      w-let-arc-fnt-ass    to   w-tes-ass-iva (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-arc-000      thru vis-des-arc-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-flg    not  = spaces or
                     w-tes-cod-arc (1)    =    zero
                     go to acc-cod-arc-100.
      *                  *---------------------------------------------*
      *                  * Test su codice sottoconto associato al      *
      *                  * fornitore                                   *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-stc (1)
                                          not  = zero
                     go to acc-cod-arc-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca il sottoconto contabile per il fornitore !  
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-arc-100.
       acc-cod-arc-420.
      *                  *---------------------------------------------*
      *                  * Lettura tabella [codiva]                    *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcf] principale             *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-fnt      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-cod-arc-500.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il fornitore ! 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-arc-100.
       acc-cod-arc-500.
      *                  *---------------------------------------------*
      *                  * Test su segnale di ordini bloccati          *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-cod-arc-520.
           if        w-let-arc-dcf-blo    not  = 02
                     go to acc-cod-arc-520.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : Fornitore con ordini bloccati !      
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A seconda della personalizzazione rela- *
      *                      * tiva alla modalita' di blocco del for-  *
      *                      * nitore si prosegue, oppure si esce si-  *
      *                      * mulando il tasto Exit                   *
      *                      *-----------------------------------------*
           if        w-prs-blo-fnt-t01    =    "B"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-arc-999
           else      go to acc-cod-arc-520.
       acc-cod-arc-520.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del fornitore    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcf-tus    =    01
                     go to acc-cod-arc-580.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cod-arc-bsc-000  thru acc-cod-arc-bsc-999    .
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     acc-cod-arc-100.
       acc-cod-arc-580.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su fornitore            *
      *                  *---------------------------------------------*
           perform   cod-mne-dcf-not-000  thru cod-mne-dcf-not-999    .
       acc-cod-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-sav-cod-arc        =    zero
                     go to acc-cod-arc-610.
           if        w-tes-cod-arc (1)    =    w-sav-cod-arc
                     go to acc-cod-arc-800.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           perform   acc-cod-arc-mod-000  thru acc-cod-arc-mod-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-arc-mod-sce    =    01
                     go to acc-cod-arc-100.
       acc-cod-arc-610.
      *                  *---------------------------------------------*
      *                  * Flag di accettazione codice archivio        *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-car (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [dcf] principale                     *
      *                  *---------------------------------------------*
           perform   det-vlt-dcf-000      thru det-vlt-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione funzionamento spese          *
      *                  *---------------------------------------------*
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-cod-arc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-arc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-arc-100.
       acc-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Routine di avviso per cambio codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-arc-mod-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       acc-cod-arc-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica del codice fornitore non comporta alcu
      -              "na variazione "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "nelle condizioni gia' presenti nell'ordine !      
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-arc-mod-sce      .
       acc-cod-arc-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-arc-mod-lun    to   v-car                  .
           move      w-exp-arc-mod-num    to   v-ldt                  .
           move      "AP#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-arc-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-arc-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-cod-arc-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02
                     go to acc-cod-arc-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-arc-mod-sce      .
       acc-cod-arc-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-arc-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-arc-mod-999.
       acc-cod-arc-mod-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del fornitore, se diverso da 'normale'                    *
      *    *-----------------------------------------------------------*
       acc-cod-arc-bsc-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-arc-bsc-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il fornitore impostato si rileva la seguente c
      -              "ondizione : "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcf-tus    =    11
                     move  "[Esauriti i rapporti commerciali]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    21
                     move  "[Sostituito da ns. nuovo fornitore]         
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    51
                     move  "[Cessata attivita']                         
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    52
                     move  "[Cessata attivita', ma sostituito da ns. nuo
      -                    "vo fornitore]     "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    61
                     move  "[In contenzioso]                            
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    62
                     move  "[In contenzioso, ma sostituito da ns. nuovo 
      -                    "fornitore]        "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    71
                     move  "[Fallito]                                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcf-tus    =    72
                     move  "[Fallito, ma sostituito da ns. nuovo fornito
      -                    "re]               "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcf-tud    =    zero
                     go to acc-cod-arc-bsc-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-arc-dcf-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-arc-bsc-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcf-tuc    =    zero
                     go to acc-cod-arc-bsc-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il fornitore utilizzabile in alternativa e' il seg
      -              "uente :     "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice fornitore alternativo        *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      w-let-arc-dcf-tuc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Lettura descrizione per fornitore   *
      *                          * alternativo                         *
      *                          *-------------------------------------*
           move      w-let-arc-dcf-tuc    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
           if        w-let-arc-fnt-flg    not  = spaces
                     move  all "."        to   v-alf
           else      move  w-let-arc-fnt-rag
                                          to   v-alf                  .
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      20                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-arc-bsc-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-arc-bsc-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-arc-bsc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice archivio           *
      *    *-----------------------------------------------------------*
       vis-cod-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-arc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione archivio      *
      *    *-----------------------------------------------------------*
       vis-des-arc-000.
      *              *-------------------------------------------------*
      *              * Ragione sociale                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Indirizzo                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Localita'                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-arc-600.
      *              *-------------------------------------------------*
      *              * Partita Iva                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           perform   pmt-prt-iva-000      thru pmt-prt-iva-999        .
      *                  *---------------------------------------------*
      *                  * Pulizia preliminare                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Test se fornitore estero                    *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-naz (1)
                                          =    "IT "
                     go to vis-des-arc-640.
       vis-des-arc-620.
      *                  *---------------------------------------------*
      *                  * Fornitore estero                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      w-tes-cod-arc-cfi (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-des-arc-999.
       vis-des-arc-640.
      *                  *---------------------------------------------*
      *                  * Fornitore Italia                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      w-tes-cod-arc-piv (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice dipendenza fornitore  *
      *    *-----------------------------------------------------------*
       acc-dpz-fnt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to acc-dpz-fnt-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-sav-dpz-fnt          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-fnt-400.
       acc-dpz-fnt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcf-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dcf-fnt      .
           move      w-tes-dpz-arc (1)    to   w-cod-cod-dcf-cod      .
           move      14                   to   w-cod-cod-dcf-lin      .
           move      27                   to   w-cod-cod-dcf-pos      .
           move      14                   to   w-cod-cod-dcf-rln      .
           move      41                   to   w-cod-cod-dcf-rps      .
           move      15                   to   w-cod-cod-dcf-vln      .
           move      41                   to   w-cod-cod-dcf-vps      .
           move      16                   to   w-cod-cod-dcf-lln      .
           move      41                   to   w-cod-cod-dcf-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcf-cll-000  thru cod-cod-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcf-foi-000  thru cod-cod-dcf-foi-999    .
       acc-dpz-fnt-110.
           perform   cod-cod-dcf-cll-000  thru cod-cod-dcf-cll-999    .
           if        w-cod-cod-dcf-ope    =    "F+"
                     go to acc-dpz-fnt-115.
           if        w-cod-cod-dcf-ope    =    "AC"
                     go to acc-dpz-fnt-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-fnt-115.
           perform   cod-cod-dcf-foi-000  thru cod-cod-dcf-foi-999    .
           go to     acc-dpz-fnt-110.
       acc-dpz-fnt-120.
           move      w-cod-cod-dcf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-fnt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-fnt-999.
       acc-dpz-fnt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-arc (1)      .
       acc-dpz-fnt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcf]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-fnt      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
           perform   vis-des-dpz-000      thru vis-des-dpz-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcf-flg    not  = spaces
                     go to acc-dpz-fnt-100.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su dipendenza fornitore *
      *                  *---------------------------------------------*
           perform   cod-cod-dcf-not-000  thru cod-cod-dcf-not-999    .
       acc-dpz-fnt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    w-sav-dpz-fnt
                     go to acc-dpz-fnt-800.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcf]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-dpz-fnt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-fnt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-fnt-100.
       acc-dpz-fnt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza del fornitore  *
      *    *-----------------------------------------------------------*
       vis-dpz-fnt-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-dpz-arc (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-fnt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    *-----------------------------------------------------------*
       vis-des-dpz-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-dpz-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo indirizzo di spedizione *
      *    *-----------------------------------------------------------*
       acc-tip-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tip-ids (1)    to   w-sav-tip-ids          .
      *                  *---------------------------------------------*
      *                  * Correttivo in funzione del numero di        *
      *                  * dipendenze                                  *
      *                  *---------------------------------------------*
           if        w-exp-dpz-ids-num    <    1
                     move   02            to   w-exp-tip-ids-num      .
      *                  *---------------------------------------------*
      *                  * Eventuale default                           *
      *                  *---------------------------------------------*
           if        w-exp-dpz-ids-num    <    1  and
                     w-tes-tip-ids (1)    =    zero
                     move   01            to   w-tes-tip-ids (1)      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-ids-400.
       acc-tip-ids-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ids-lun    to   v-car                  .
           move      w-exp-tip-ids-num    to   v-ldt                  .
           move      "EMD#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-tip-ids-tbl    to   v-txt                  .
           move      w-tes-tip-ids (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ids-999.
       acc-tip-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-ids (1)      .
       acc-tip-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    not  = zero
                     go to acc-tip-ids-600.
           if        v-key                =    "UP  "
                     go to acc-tip-ids-600
           else      go to acc-tip-ids-100.
       acc-tip-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    =    w-sav-tip-ids
                     go to acc-tip-ids-800.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo indirizzo   *
      *                  * di spedizione                               *
      *                  *---------------------------------------------*
           go to     acc-tip-ids-610
                     acc-tip-ids-620
                     acc-tip-ids-630
                     depending            on   w-tes-tip-ids (1)      .
       acc-tip-ids-610.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Emittente    *
      *                  *---------------------------------------------*
           move      w-tes-cod-dpz        to   w-let-arc-dpz-cod      .
           perform   let-arc-dpz-000      thru let-arc-dpz-999        .
           move      w-let-arc-dpz-rag    to   w-sav-rag-ids          .
           move      w-let-arc-dpz-via    to   w-sav-via-ids          .
           move      w-let-arc-dpz-loc    to   w-sav-loc-ids          .
           move      w-let-arc-dpz-rag    to   w-tes-rag-ids (1)      .
           move      w-let-arc-dpz-via    to   w-tes-via-ids (1)      .
           move      w-let-arc-dpz-loc    to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-620.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Manuale      *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-via-ids (1)      .
           move      spaces               to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-630.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Altra dip.   *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-via-ids (1)      .
           move      spaces               to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-650.
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati indirizzo di spedizione*
      *                  *---------------------------------------------*
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-tip-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-ids-100.
       acc-tip-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo indirizzo di spedi-  *
      *    *                                 zione                     *
      *    *-----------------------------------------------------------*
       vis-tip-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ids-lun    to   v-car                  .
           move      w-exp-tip-ids-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-tip-ids-tbl    to   v-txt                  .
           move      w-tes-tip-ids (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Dipendenza di spedizione             *
      *    *-----------------------------------------------------------*
       acc-dpz-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non esiste alcun codice dipendenza       *
      *                  * memorizzato : uscita                        *
      *                  *---------------------------------------------*
           if        w-exp-dpz-ids-num    <    1
                     go to acc-dpz-ids-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-rag-ids (1)    not  = spaces
                     go to acc-dpz-ids-999.
           if        w-tes-tip-ids (1)    not  = 3
                     go to acc-dpz-ids-999.
       acc-dpz-ids-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-dpz-ids-lun    to   v-car                  .
           move      w-exp-dpz-ids-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-exp-dpz-ids-tbl    to   v-txt                  .
           move      zero                 to   v-num                  .
           move      zero                 to   w-exp-dpz-ids-c01      .
       acc-dpz-ids-150.
           add       1                    to   w-exp-dpz-ids-c01      .
           if        w-exp-dpz-ids-c01    >    w-exp-dpz-ids-num
                     go to acc-dpz-ids-160.
           go to     acc-dpz-ids-150.
       acc-dpz-ids-160.
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-ids-999.
       acc-dpz-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-exp-dpz-ids-c01      .
       acc-dpz-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella dipendenze                  *
      *                  *---------------------------------------------*
           move      w-exp-dpz-ids-cod
                    (w-exp-dpz-ids-c01)   to   w-let-arc-dpz-cod      .
           perform   let-arc-dpz-000      thru let-arc-dpz-999        .
           move      w-let-arc-dpz-rag    to   w-sav-rag-ids          .
           move      w-let-arc-dpz-via    to   w-sav-via-ids          .
           move      w-let-arc-dpz-loc    to   w-sav-loc-ids          .
           move      w-let-arc-dpz-rag    to   w-tes-rag-ids (1)      .
           move      w-let-arc-dpz-via    to   w-tes-via-ids (1)      .
           move      w-let-arc-dpz-loc    to   w-tes-loc-ids (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione indirizzo di spedizione     *
      *                  *---------------------------------------------*
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
      *                  *---------------------------------------------*
      *                  * In campo di memorizzazione                  *
      *                  *---------------------------------------------*
           move      w-exp-dpz-ids-cod
                    (w-exp-dpz-ids-c01)   to   w-tes-dpz-ids (1)      .
       acc-dpz-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dpz-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-ids-100.
       acc-dpz-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Ragione sociale indirizzo di *
      *    *                              spedizione                   *
      *    *-----------------------------------------------------------*
       acc-rag-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-rag-ids-400.
       acc-rag-ids-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-rag-ids (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-rag-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-rag-ids-999.
       acc-rag-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-rag-ids (1)      .
       acc-rag-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-rag-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento indirizzo e localita'           *
      *                  *---------------------------------------------*
           if        w-tes-rag-ids (1)    not  = spaces
                     go to acc-rag-ids-800.
           move      spaces               to   w-tes-via-ids (1)      .
           move      spaces               to   w-tes-loc-ids (1)      .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-rag-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-rag-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-rag-ids-100.
       acc-rag-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Ragione sociale indirizzo *
      *    *                                 di spedizione             *
      *    *-----------------------------------------------------------*
       vis-rag-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-rag-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rag-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Via per indirizzo di spedi-  *
      *    *                              zione                        *
      *    *-----------------------------------------------------------*
       acc-via-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-rag-ids (1)    =    spaces
                     go to acc-via-ids-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-via-ids-400.
       acc-via-ids-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-ind-cec-geo-ope      .
           move      "IT "                to   w-ind-cec-geo-naz      .
           move      w-tes-via-ids (1)    to   w-ind-cec-geo-ind      .
           move      19                   to   w-ind-cec-geo-lin      .
           move      41                   to   w-ind-cec-geo-pos      .
           move      w-tes-loc-ids (1)    to   w-ind-cec-geo-cec      .
           move      zero                 to   w-ind-cec-geo-cmn      .
           move      spaces               to   w-ind-cec-geo-dco      .
           move      spaces               to   w-ind-cec-geo-prv      .
           move      zero                 to   w-ind-cec-geo-fzn      .
           move      spaces               to   w-ind-cec-geo-dfr      .
           move      zero                 to   w-ind-cec-geo-lct      .
           move      spaces               to   w-ind-cec-geo-dlo      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   ind-cec-geo-foi-000  thru ind-cec-geo-foi-999    .
       acc-via-ids-110.
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           if        w-ind-cec-geo-ope    =    "F+"
                     go to acc-via-ids-115.
           if        w-ind-cec-geo-ope    =    "AC"
                     go to acc-via-ids-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-via-ids-115.
           perform   ind-cec-geo-foi-000  thru ind-cec-geo-foi-999    .
           go to     acc-via-ids-110.
       acc-via-ids-120.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-via-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-via-ids-999.
       acc-via-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      w-ind-cec-geo-ind    to   w-tes-via-ids (1)      .
      *              *-------------------------------------------------*
      *              * Altri valori se automatismo eseguito            *
      *              *-------------------------------------------------*
           if        w-ind-cec-geo-aut    =    spaces
                     go to acc-via-ids-400.
      *                  *---------------------------------------------*
      *                  * Localita'                                   *
      *                  *---------------------------------------------*
           move      w-ind-cec-geo-cec    to   w-tes-loc-ids (1)      .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-via-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-via-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-via-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-via-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-via-ids-100.
       acc-via-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Via per indirizzo di spe- *
      *    *                                 dizione                   *
      *    *-----------------------------------------------------------*
       vis-via-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-via-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-via-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Localita' indirizzo di spe-  *
      *    *                              dizione                      *
      *    *-----------------------------------------------------------*
       acc-loc-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-rag-ids (1)    =    spaces
                     go to acc-loc-ids-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-loc-ids-400.
       acc-loc-ids-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cap-cit-geo-ope      .
           move      "IT "                to   w-cap-cit-geo-naz      .
           move      w-tes-loc-ids (1)    to   w-cap-cit-geo-cec      .
           move      20                   to   w-cap-cit-geo-lin      .
           move      41                   to   w-cap-cit-geo-pos      .
           move      zero                 to   w-cap-cit-geo-cmn      .
           move      spaces               to   w-cap-cit-geo-dco      .
           move      spaces               to   w-cap-cit-geo-prv      .
           move      zero                 to   w-cap-cit-geo-fzn      .
           move      spaces               to   w-cap-cit-geo-dfr      .
           move      zero                 to   w-cap-cit-geo-lct      .
           move      spaces               to   w-cap-cit-geo-dlo      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cap-cit-geo-cll-000  thru cap-cit-geo-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cap-cit-geo-foi-000  thru cap-cit-geo-foi-999    .
       acc-loc-ids-110.
           perform   cap-cit-geo-cll-000  thru cap-cit-geo-cll-999    .
           if        w-cap-cit-geo-ope    =    "F+"
                     go to acc-loc-ids-115.
           if        w-cap-cit-geo-ope    =    "AC"
                     go to acc-loc-ids-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-loc-ids-115.
           perform   cap-cit-geo-foi-000  thru cap-cit-geo-foi-999    .
           go to     acc-loc-ids-110.
       acc-loc-ids-120.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-loc-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-loc-ids-999.
       acc-loc-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      w-cap-cit-geo-cec    to   w-tes-loc-ids (1)      .
      *              *-------------------------------------------------*
      *              * Altri valori se automatismo eseguito            *
      *              *-------------------------------------------------*
           if        w-cap-cit-geo-aut    =    spaces
                     go to acc-loc-ids-400.
       acc-loc-ids-300.
      *                  *---------------------------------------------*
      *                  * Indirizzo, solo se l'elemento selezionato   *
      *                  * e' una localita'                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non si tratta di una localita' non   *
      *                      * si esegue alcun automatismo sull'indi-  *
      *                      * rizzo                                   *
      *                      *-----------------------------------------*
           if        w-cap-cit-geo-lct    =    zero
                     go to acc-loc-ids-350.
      *                      *-----------------------------------------*
      *                      * Concatenamento della localita' selezio- *
      *                      * nata con l'indirizzo precedente         *
      *                      *-----------------------------------------*
           move      "IL"                 to   w-ind-cec-geo-ope      .
           move      w-tes-via-ids (1)    to   w-ind-cec-geo-ind      .
           move      w-cap-cit-geo-dlo    to   w-ind-cec-geo-dlo      .
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           move      w-ind-cec-geo-ind    to   w-tes-via-ids (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione via concatenata         *
      *                      *-----------------------------------------*
           perform   vis-via-ids-000      thru vis-via-ids-999        .
       acc-loc-ids-350.
       acc-loc-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-loc-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-loc-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-loc-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-loc-ids-100.
       acc-loc-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Localita' indirizzo di    *
      *    *                                 spedizione                *
      *    *-----------------------------------------------------------*
       vis-loc-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-loc-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-loc-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data conferma da fornitore   *
      *    *-----------------------------------------------------------*
       acc-cof-dat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cof-dat-400.
       acc-cof-dat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-cof-dat (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cof-dat-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cof-dat-999.
       acc-cof-dat-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-cof-dat (1)      .
       acc-cof-dat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cof-dat-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cof-dat-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cof-dat-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cof-dat-100.
       acc-cof-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Data conferma da fornitore              *
      *    *-----------------------------------------------------------*
       vis-cof-dat-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cof-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cof-dat-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Num. conferma da fornitore   *
      *    *-----------------------------------------------------------*
       acc-cof-num-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cof-num-400.
       acc-cof-num-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-cof-num (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cof-num-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cof-num-999.
       acc-cof-num-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cof-num (1)      .
       acc-cof-num-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cof-num-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cof-num-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cof-num-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cof-num-100.
       acc-cof-num-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Num. conferma da fornitore              *
      *    *-----------------------------------------------------------*
       vis-cof-num-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cof-num (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cof-num-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Riferimenti conferma da for- *
      *    * nitore                                                    *
      *    *-----------------------------------------------------------*
       acc-cof-rif-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
