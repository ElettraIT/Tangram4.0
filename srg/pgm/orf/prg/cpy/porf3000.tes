      *    *===========================================================*
      *    * Accettazione campo testata : Sigla valuta per fatturazio- *
      *    * ne                                                        *
      *    *-----------------------------------------------------------*
       acc-sgl-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-sav-sgl-vpf          .
           move      w-tes-dec-vpf (1)    to   w-sav-dec-vpf          .
           move      w-tes-tdc-vpf (1)    to   w-sav-tdc-vpf          .
           move      w-tes-cdc-vpf (1)    to   w-sav-cdc-vpf          .
           move      spaces               to   w-sav-sgl-var          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-sgl-vpf-400.
      *                  *---------------------------------------------*
      *                  * Test di modificabilita' della valuta        *
      *                  * ___ test su righe con legame ___            *
      *                  *---------------------------------------------*
       acc-sgl-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-tes-sgl-vpf (1)    to   w-cod-cod-zvl-cod      .
           move      08                   to   w-cod-cod-zvl-lin      .
           move      30                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpf-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpf-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpf-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpf-110.
       acc-sgl-vpf-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
       acc-sgl-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-sgl-vpf (1)      .
       acc-sgl-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-des    to   w-tes-sgl-vpf-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione valuta          *
      *                  *---------------------------------------------*
           perform   vis-sgl-vpf-des-000  thru vis-sgl-vpf-des-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso                 *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero decimali             *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-dec    to   w-tes-dec-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo di cambio              *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-tes-tdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Se sigla valuta pari a quella base : forza- *
      *                  * tura cambio della valuta base               *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  c-dec          to   w-tes-cdc-vpf (1)      .
       acc-sgl-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo prezzi                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    w-sav-sgl-vpf
                     go to acc-sgl-vpf-800.
      *                      *-----------------------------------------*
      *                      * Determinazione coefficiente di cambio   *
      *                      * per la nuova valuta                     *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione               *
      *                      *-----------------------------------------*
           if        w-coe-cmb-vlt-cdc    =    zero
                     move  1              to   w-coe-cmb-vlt-cdc      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento coefficiente di cambio    *
      *                      *-----------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione coefficiente di cambio  *
      *                      *-----------------------------------------*
           perform   vis-cdc-vpf-000      thru vis-cdc-vpf-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dei prezzi in riga  *
      *                      * in caso di variazione valuta            *
      *                      *-----------------------------------------*
           perform   rcl-vlt-prz-000      thru rcl-vlt-prz-999        .
      *                      *-----------------------------------------*
      *                      * Test sulla scelta dell'operatore        *
      *                      *-----------------------------------------*
           if        w-exp-rcl-vlt-sce    =    01
                     go to acc-sgl-vpf-100.
      *                      *-----------------------------------------*
      *                      * Attivazione segnale di conversione da   *
      *                      * effettuare                              *
      *                      *-----------------------------------------*
           move      "#"                  to   w-sav-sgl-var          .
       acc-sgl-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sgl-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sgl-vpf-100.
       acc-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sigla valuta per fattura- *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione sigla valuta  *
      *    * per fatturazione                                          *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-sgl-vpf-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Coefficiente di cambio       *
      *    *-----------------------------------------------------------*
       acc-cdc-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cdc-vpf (1)    to   w-sav-cdc-vpf          .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  c-cdc          to   w-tes-cdc-vpf (1)
                     go to acc-cdc-vpf-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cdc-vpf-400.
       acc-cdc-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           if        w-tes-cdc-vpf (1)    =    zero
                     move  "S"            to   w-coe-cmb-vlt-snd
           else      move  "N"            to   w-coe-cmb-vlt-snd      .
           move      w-tes-cdc-vpf (1)    to   w-coe-cmb-vlt-cdc      .
           move      08                   to   w-coe-cmb-vlt-lin      .
           move      60                   to   w-coe-cmb-vlt-pos      .
           move      08                   to   w-coe-cmb-vlt-dln      .
           move      73                   to   w-coe-cmb-vlt-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-cdc-vpf-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-cdc-vpf-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-cdc-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cdc-vpf-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-cdc-vpf-110.
       acc-cdc-vpf-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-cdc-vpf-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cdc-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cdc-vpf-999.
       acc-cdc-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cdc-vpf (1)      .
       acc-cdc-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-cdc-vpf (1)    not  = zero
                     go to acc-cdc-vpf-600.
           if        v-key                =    "UP  "
                     go to acc-cdc-vpf-600
           else      go to acc-cdc-vpf-100.
       acc-cdc-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo prezzi                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-tes-cdc-vpf (1)    =    w-sav-cdc-vpf
                     go to acc-cdc-vpf-800.
           if        w-sav-sgl-var        =    spaces
                     go to acc-cdc-vpf-800.
      *                      *-----------------------------------------*
      *                      * Disattivazione segnale di conversione   *
      *                      * da effettuare                           *
      *                      *-----------------------------------------*
           move      spaces               to   w-sav-sgl-var          .
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dei prezzi in riga  *
      *                      * in caso di variazione valuta            *
      *                      *-----------------------------------------*
           perform   rcl-vlt-prz-cmb-000  thru rcl-vlt-prz-cmb-999    .
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Effettuato il ricalcolo delle righe ordine !      
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cdc-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cdc-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cdc-vpf-100.
       acc-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Coefficiente di cambio    *
      *    *-----------------------------------------------------------*
       vis-cdc-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      08                   to   v-lin                  .
           move      60                   to   v-pos                  .
           if        w-tes-cdc-vpf (1)    =    1
                     move  zero           to   v-num
           else      move  w-tes-cdc-vpf (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Codice lingua                 *
      *    *-----------------------------------------------------------*
       acc-cod-lng-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-lng (1)    to    w-sav-cod-lng         .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-lng-400.
       acc-cod-lng-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zln-ope      .
           move      w-tes-cod-lng (1)    to   w-cod-cod-zln-cod      .
           move      09                   to   w-cod-cod-zln-lin      .
           move      30                   to   w-cod-cod-zln-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zln-foi-000  thru cod-cod-zln-foi-999    .
       acc-cod-lng-110.
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           if        w-cod-cod-zln-ope    =    "F+"
                     go to acc-cod-lng-115.
           if        w-cod-cod-zln-ope    =    "AC"
                     go to acc-cod-lng-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-lng-115.
           perform   cod-cod-zln-foi-000  thru cod-cod-zln-foi-999    .
           go to     acc-cod-lng-110.
       acc-cod-lng-120.
           move      w-cod-cod-zln-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lng-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lng-999.
       acc-cod-lng-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-lng (1)      .
       acc-cod-lng-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [zln]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-lng (1)    to   w-let-arc-zln-cod      .
           perform   let-arc-zln-000      thru let-arc-zln-999        .
           move      w-let-arc-zln-des    to   w-tes-cod-lng-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-lng-000      thru vis-des-lng-999        .
      *                  *---------------------------------------------*
      *                  * Test sul flag                               *
      *                  *---------------------------------------------*
           if        w-let-arc-zln-flg    not  = spaces
                     go to acc-cod-lng-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-tes-cod-lng (1)    not  = spaces
                     go to acc-cod-lng-600.
           go to     acc-cod-lng-100.
       acc-cod-lng-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore variato                      *
      *                  *---------------------------------------------*
           if        w-tes-cod-lng (1)    =    w-sav-cod-lng
                     go to acc-cod-lng-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo descrizione prodotti del documen- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           perform   rcl-des-doc-000      thru rcl-des-doc-999        .
       acc-cod-lng-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-lng-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-lng-100.
       acc-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Codice lingua              *
      *    *-----------------------------------------------------------*
       vis-cod-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-lng (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione lingua        *
      *    *-----------------------------------------------------------*
       vis-des-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-lng-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-lng-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Assoggettamento iva          *
      *    *-----------------------------------------------------------*
       acc-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fda-aiv (1)    not  = spaces
                     go to acc-ass-iva-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ass-iva-400.
       acc-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      11                   to   w-cod-mne-zci-lin      .
           move      30                   to   w-cod-mne-zci-pos      .
           move      11                   to   w-cod-mne-zci-dln      .
           move      37                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-ass-iva-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-ass-iva-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-ass-iva-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ass-iva-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-ass-iva-110.
       acc-ass-iva-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
       acc-ass-iva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ass-iva (1)      .
       acc-ass-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-des-000  thru vis-ass-iva-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zci-flg    not  = spaces
                     go to acc-ass-iva-100.
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
      *
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     go to acc-ass-iva-100.
       acc-ass-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di accettazione assoggettamento iva    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-aiv (1)      .
       acc-ass-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ass-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ass-iva-100.
       acc-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice di esenzione IVA   *
      *    *-----------------------------------------------------------*
       vis-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione assoggetta-   *
      *    * mento IVA                                                 *
      *    *-----------------------------------------------------------*
       vis-ass-iva-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-ass-iva-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Contropartita acquisti in    *
      *    * testata                                                   *
      *    *-----------------------------------------------------------*
       acc-ctp-acq-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ctp-acq-400.
       acc-ctp-acq-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-tes-ctp-acq (1)    to   w-cod-mne-pdc-cod      .
           move      12                   to   w-cod-mne-pdc-lin      .
           move      30                   to   w-cod-mne-pdc-pos      .
           move      12                   to   w-cod-mne-pdc-dln      .
           move      41                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-acq-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-acq-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-acq-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-acq-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-acq-110.
       acc-ctp-acq-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-acq-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-acq-999.
       acc-ctp-acq-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ctp-acq (1)      .
       acc-ctp-acq-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-tes-ctp-acq (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-acq-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-acq-des-000  thru vis-ctp-acq-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-acq-100.
       acc-ctp-acq-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctp-acq-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ctp-acq-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ctp-acq-100.
       acc-ctp-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita acquisti in *
      *    * testata                                                   *
      *    *-----------------------------------------------------------*
       vis-ctp-acq-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-tes-ctp-acq (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione contropartita *
      *    * acquisti in testata                                       *
      *    *-----------------------------------------------------------*
       vis-ctp-acq-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-ctp-acq-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-acq-des-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Accettazione campo testata : Voce descrittiva ennesima in *
      *    *                              funzione di w-acc-voc-des-ctr*
      *    *-----------------------------------------------------------*
       acc-voc-des-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-vde-fat-nvt    =    zero
                     go to acc-voc-des-999.
      *                  *---------------------------------------------*
      *                  * Preparazione indice per la voce             *
      *                  *---------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-acc-voc-des-ctr)   to   w-acc-voc-des-inx      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-voc-des-400.
       acc-voc-des-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-yvf-ope      .
           move      w-acc-voc-des-inx    to   w-cod-cod-yvf-voc      .
           move      "I  "                to   w-cod-cod-yvf-lng      .
           move      w-tes-voc-des
                    (1, w-acc-voc-des-inx)
                                          to   w-cod-cod-yvf-cod      .
           add       15
                     w-acc-voc-des-ctr  giving w-cod-cod-yvf-lin      .
           move      30                   to   w-cod-cod-yvf-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-yvf-cll-000  thru cod-cod-yvf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-yvf-foi-000  thru cod-cod-yvf-foi-999    .
       acc-voc-des-110.
           perform   cod-cod-yvf-cll-000  thru cod-cod-yvf-cll-999    .
           if        w-cod-cod-yvf-ope    =    "F+"
                     go to acc-voc-des-115.
           if        w-cod-cod-yvf-ope    =    "AC"
                     go to acc-voc-des-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-voc-des-115.
           perform   cod-cod-yvf-foi-000  thru cod-cod-yvf-foi-999    .
           go to     acc-voc-des-110.
       acc-voc-des-120.
           move      w-cod-cod-yvf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-voc-des-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-voc-des-999.
       acc-voc-des-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-voc-des
                                              (1, w-acc-voc-des-inx)  .
       acc-voc-des-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [yvf]                      *
      *                  *---------------------------------------------*
           move      w-acc-voc-des-inx    to   w-let-arc-yvf-num      .
           move      w-tes-voc-des
                    (1, w-acc-voc-des-inx)
                                          to   w-let-arc-yvf-cod      .
           perform   let-arc-yvf-000      thru let-arc-yvf-999        .
           move      w-let-arc-yvf-des    to   w-tes-voc-des-des
                                              (1, w-acc-voc-des-inx)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-acc-voc-des-ctr    to   w-vis-voc-des-ctr      .
           perform   vis-des-vde-000      thru vis-des-vde-999        .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-yvf-flg    not  = spaces
                     go to acc-voc-des-100.
       acc-voc-des-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-voc-des-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-voc-des-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-voc-des-100.
       acc-voc-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Voce descrittiva ennesima *
      *    * in funzione di w-vis-voc-des-ctr                          *
      *    *-----------------------------------------------------------*
       vis-voc-des-000.
      *              *-------------------------------------------------*
      *              * Preparazione indice per la voce                 *
      *              *-------------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-vis-voc-des-ctr)   to   w-vis-voc-des-inx      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           add       15
                     w-vis-voc-des-ctr  giving v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-voc-des
                    (1, w-vis-voc-des-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-voc-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione voce descrit- *
      *    * tiva ennesima in funzione di w-vis-voc-des-ctr            *
      *    *-----------------------------------------------------------*
       vis-des-vde-000.
      *              *-------------------------------------------------*
      *              * Preparazione indice per la voce                 *
      *              *-------------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-vis-voc-des-ctr)   to   w-vis-voc-des-inx      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           add       15
                     w-vis-voc-des-ctr  giving v-lin                  .
           move      35                   to   v-pos                  .
           move      w-tes-voc-des-des
                    (1, w-vis-voc-des-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-vde-999.
           exit.

