      *    *===========================================================*
      *    * Accettazione campo testata : Codice responsabile ordine   *
      *    *-----------------------------------------------------------*
       acc-cod-rsp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore attuale                  *
      *                  *---------------------------------------------*
           move      w-tes-cod-rsp (1)    to   w-sav-cod-rsp          .
      *                  *---------------------------------------------*
      *                  * Test se modificabile                        *
      *                  *---------------------------------------------*
           if        w-def-tas-rsp        not  = "F"
                     go to acc-cod-rsp-050.
           if        w-tes-cod-rsp (1)    =    zero
                     go to acc-cod-rsp-050.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-cod-rsp-999.
       acc-cod-rsp-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-rsp-400.
       acc-cod-rsp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-yro-ope      .
           move      w-tes-cod-rsp (1)    to   w-cod-mne-yro-cod      .
           move      09                   to   w-cod-mne-yro-lin      .
           move      30                   to   w-cod-mne-yro-pos      .
           move      09                   to   w-cod-mne-yro-dln      .
           move      37                   to   w-cod-mne-yro-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-yro-cll-000  thru cod-mne-yro-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-yro-foi-000  thru cod-mne-yro-foi-999    .
       acc-cod-rsp-110.
           perform   cod-mne-yro-cll-000  thru cod-mne-yro-cll-999    .
           if        w-cod-mne-yro-ope    =    "F+"
                     go to acc-cod-rsp-115.
           if        w-cod-mne-yro-ope    =    "AC"
                     go to acc-cod-rsp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-rsp-115.
           perform   cod-mne-yro-foi-000  thru cod-mne-yro-foi-999    .
           go to     acc-cod-rsp-110.
       acc-cod-rsp-120.
           move      w-cod-mne-yro-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-rsp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-rsp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-rsp (1)      .
       acc-cod-rsp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [yro]                       *
      *                  *---------------------------------------------*
           move      w-tes-cod-rsp (1)    to   w-let-arc-yro-cod      .
           perform   let-arc-yro-000      thru let-arc-yro-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore letto                *
      *                  *---------------------------------------------*
           move      w-let-arc-yro-des    to   w-tes-cod-rsp-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-rsp-des-000  thru vis-cod-rsp-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso                       *
      *                  *---------------------------------------------*
           if        w-let-arc-yro-flg    =    spaces
                     go to acc-cod-rsp-450.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Responsabile ordine non esistente !               
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-rsp-100.
       acc-cod-rsp-450.
      *                  *---------------------------------------------*
      *                  * Se valore non modificabile                  *
      *                  *---------------------------------------------*
           if        w-def-tas-rsp        not  = "F"
                     go to acc-cod-rsp-600.
           if        w-tes-cod-rsp (1)    =    w-sav-cod-rsp
                     go to acc-cod-rsp-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Responsabile ordine non modificabile !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-rsp-100.
       acc-cod-rsp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-rsp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-rsp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-rsp-100.
       acc-cod-rsp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice responsabile or-   *
      *    * dine                                                      *
      *    *-----------------------------------------------------------*
       vis-cod-rsp-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-rsp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-rsp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione responsabile  *
      *    * ordine                                                    *
      *    *-----------------------------------------------------------*
       vis-cod-rsp-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-rsp-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-rsp-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data consegna prevista       *
      *    *-----------------------------------------------------------*
       acc-dat-cns-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-sav-dat-cns          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dat-cns-400.
       acc-dat-cns-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      ">"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-dat-cns (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dat-cns-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dat-cns-999.
       acc-dat-cns-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dat-cns (1)      .
       acc-dat-cns-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-dat-cns (1)    not  = zero
                     go to acc-dat-cns-600.
      *                      *-----------------------------------------*
      *                      * Forzatura da data documento             *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   w-tes-dat-cns (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-dat-cns-000      thru vis-dat-cns-999        .
       acc-dat-cns-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-dat-cns (1)    =    w-sav-dat-cns
                     go to acc-dat-cns-800.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           perform   acc-dat-cns-mod-000  thru acc-dat-cns-mod-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-dcn-mod-sce    =    01
                     go to acc-dat-cns-800.
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           perform   agg-dcn-rig-000      thru agg-dcn-rig-999        .
       acc-dat-cns-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dat-cns-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-cns-100.
       acc-dat-cns-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data consegna prevista       *
      *    *                                                           *
      *    * Routine di avviso per cambio Data consegna prevista       *
      *    *-----------------------------------------------------------*
       acc-dat-cns-mod-000.
      *              *-------------------------------------------------*
      *              * Se corpo ancora da accettare : uscita           *
      *              *-------------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to acc-dat-cns-mod-900.
       acc-dat-cns-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica della data di consegna richiesta potre
      -              "bbe comportare"     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "la variazione delle condizioni stabilite nelle sin
      -              "gole righe.   "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-dcn-mod-sce      .
       acc-dat-cns-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-dcn-mod-lun    to   v-car                  .
           move      w-exp-dcn-mod-num    to   v-ldt                  .
           move      "IPRE#"              to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-dcn-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-dcn-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-dat-cns-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02 and
                     v-num                not  = 03 and
                     v-num                not  = 04
                     go to acc-dat-cns-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-dcn-mod-sce      .
       acc-dat-cns-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-dat-cns-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-dat-cns-mod-999.
       acc-dat-cns-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento date consegna nelle righe        *
      *    *-----------------------------------------------------------*
       agg-dcn-rig-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       agg-dcn-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to agg-dcn-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to agg-dcn-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to agg-dcn-rig-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to agg-dcn-rig-100.
       agg-dcn-rig-150.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della scelta effettuata  *
      *              *-------------------------------------------------*
           if        w-exp-dcn-mod-sce    =    01
                     go to agg-dcn-rig-900
           else if   w-exp-dcn-mod-sce    =    02
                     go to agg-dcn-rig-200
           else if   w-exp-dcn-mod-sce    =    03
                     go to agg-dcn-rig-300
           else if   w-exp-dcn-mod-sce    =    04
                     go to agg-dcn-rig-400
           else      go to agg-dcn-rig-900.
       agg-dcn-rig-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento data consegna prevista            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-prv (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento                            *
      *                  *---------------------------------------------*
           go to     agg-dcn-rig-800.
       agg-dcn-rig-300.
      *              *-------------------------------------------------*
      *              * Aggiornamento data consegna richiesta           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data consegna richiesta                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-ric (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento                            *
      *                  *---------------------------------------------*
           go to     agg-dcn-rig-800.
       agg-dcn-rig-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento di entrambe le date               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-prv (1)      .
      *                  *---------------------------------------------*
      *                  * Data consegna richiesta                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-ric (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento                            *
      *                  *---------------------------------------------*
           go to     agg-dcn-rig-800.
       agg-dcn-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     agg-dcn-rig-100.
       agg-dcn-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       agg-dcn-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data consegna prevista    *
      *    *-----------------------------------------------------------*
       vis-dat-cns-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dat-cns (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-cns-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Formato di stampa data cons. *
      *    *-----------------------------------------------------------*
       acc-fds-dtc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-fds-dtc-400.
       acc-fds-dtc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fds-dtc-lun    to   v-car                  .
           move      w-exp-fds-dtc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fds-dtc-tbl    to   v-txt                  .
           move      w-tes-fds-dtc (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fds-dtc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fds-dtc-999.
       acc-fds-dtc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-fds-dtc (1)      .
       acc-fds-dtc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-fds-dtc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fds-dtc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fds-dtc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fds-dtc-100.
       acc-fds-dtc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Formato di stampa data    *
      *    * consegna                                                  *
      *    *-----------------------------------------------------------*
       vis-fds-dtc-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fds-dtc-lun    to   v-car                  .
           move      w-exp-fds-dtc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fds-dtc-tbl    to   v-txt                  .
           move      w-tes-fds-dtc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fds-dtc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo di evasione ordine      *
      *    *-----------------------------------------------------------*
       acc-tip-eva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-eva-400.
       acc-tip-eva-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-eva-lun    to   v-car                  .
           move      w-exp-tip-eva-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-eva-tbl    to   v-txt                  .
           move      w-tes-tip-eva (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-eva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-eva-999.
       acc-tip-eva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-eva (1)      .
       acc-tip-eva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tip-eva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-eva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-eva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-eva-100.
       acc-tip-eva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo di evasione ordine   *
      *    *-----------------------------------------------------------*
       vis-tip-eva-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-eva-lun    to   v-car                  .
           move      w-exp-tip-eva-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-eva-tbl    to   v-txt                  .
           move      w-tes-tip-eva (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-eva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Priorita' di evasione ordine *
      *    *-----------------------------------------------------------*
       acc-pri-eva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pri-eva-400.
       acc-pri-eva-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pri-eva (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pri-eva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pri-eva-999.
       acc-pri-eva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-pri-eva (1)      .
       acc-pri-eva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pri-eva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pri-eva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pri-eva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pri-eva-100.
       acc-pri-eva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Priorita' di evasione or- *
      *    * dine                                                      *
      *    *-----------------------------------------------------------*
       vis-pri-eva-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-pri-eva (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pri-eva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice condizioni di acqui-  *
      *    * sto                                                       *
      *    *-----------------------------------------------------------*
       acc-cod-cda-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-cda (1)    to   w-sav-cod-cda          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cda-400.
       acc-cod-cda-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-yca-ope      .
           move      w-tes-cod-cda (1)    to   w-cod-mne-yca-cod      .
           move      18                   to   w-cod-mne-yca-lin      .
           move      30                   to   w-cod-mne-yca-pos      .
           move      18                   to   w-cod-mne-yca-dln      .
           move      37                   to   w-cod-mne-yca-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-yca-cll-000  thru cod-mne-yca-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-yca-foi-000  thru cod-mne-yca-foi-999    .
       acc-cod-cda-110.
           perform   cod-mne-yca-cll-000  thru cod-mne-yca-cll-999    .
           if        w-cod-mne-yca-ope    =    "F+"
                     go to acc-cod-cda-115.
           if        w-cod-mne-yca-ope    =    "AC"
                     go to acc-cod-cda-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cda-115.
           perform   cod-mne-yca-foi-000  thru cod-mne-yca-foi-999    .
           go to     acc-cod-cda-110.
       acc-cod-cda-120.
           move      w-cod-mne-yca-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cda-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cda-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cda (1)      .
       acc-cod-cda-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [yca]                       *
      *                  *---------------------------------------------*
           move      w-tes-cod-cda (1)    to   w-let-arc-yca-cod      .
           perform   let-arc-yca-000      thru let-arc-yca-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso                       *
      *                  *---------------------------------------------*
           if        w-let-arc-yca-flg    =    spaces
                     go to acc-cod-cda-500.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice condizioni d'acquisto non esistente !      
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-cda-100.
       acc-cod-cda-500.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-cod-cda (1)    not  = zero
                     go to acc-cod-cda-550.
      *                      *-----------------------------------------*
      *                      * Se valore precedente a zero : oltre     *
      *                      *-----------------------------------------*
           if        w-sav-cod-cda        =    zero
                     go to acc-cod-cda-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti : normalizzazione e rivisua- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-des-cda (1)      .
           perform   vis-des-cda-000      thru vis-des-cda-999        .
           go to     acc-cod-cda-600.
       acc-cod-cda-550.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valore letto            *
      *                      *-----------------------------------------*
           move      w-let-arc-yca-des    to   w-tes-des-cda (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione condizioni  *
      *                      * di acquisto                             *
      *                      *-----------------------------------------*
           perform   vis-des-cda-000      thru vis-des-cda-999        .
       acc-cod-cda-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cda-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cda-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cda-100.
       acc-cod-cda-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice condizioni di ac-  *
      *    * quisto                                                    *
      *    *-----------------------------------------------------------*
       vis-cod-cda-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cda (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cda-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Descrizione condizioni di    *
      *    * acquisto                                                  *
      *    *-----------------------------------------------------------*
       acc-des-cda-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-des-cda (1)    to   w-sav-des-cda          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-des-cda-400.
       acc-des-cda-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      18                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-des-cda (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-des-cda-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-des-cda-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-tes-des-cda (1)      .
       acc-des-cda-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-des-cda-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-des-cda (1)    =    w-sav-des-cda
                     go to acc-des-cda-800.
      *                  *---------------------------------------------*
      *                  * Trattamento codice annotazioni              *
      *                  *---------------------------------------------*
           if        w-tes-cod-cda (1)    =    zero
                     go to acc-des-cda-800.
           move      zero                 to   w-tes-cod-cda (1)      .
           perform   vis-cod-cda-000      thru vis-cod-cda-999        .
       acc-des-cda-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-des-cda-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-des-cda-100.
       acc-des-cda-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione condizioni di *
      *    * acquisto                                                  *
      *    *-----------------------------------------------------------*
       vis-des-cda-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      18                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-des-cda (1)    to   v-txt                  .
