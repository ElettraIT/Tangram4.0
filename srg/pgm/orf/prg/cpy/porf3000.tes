      *    *===========================================================*
      *    * Visualizzazione prompt : Voci descrittive                 *
      *    *-----------------------------------------------------------*
       pmt-voc-des-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella voci descrittive  *
      *              *-------------------------------------------------*
           move      zero                 to   w-pmt-voc-des-ctr      .
       pmt-voc-des-100.
           add       1                    to   w-pmt-voc-des-ctr      .
           if        w-pmt-voc-des-ctr    >    w-prs-vde-fat-nvt
                     go to pmt-voc-des-999.
       pmt-voc-des-110.
      *                  *---------------------------------------------*
      *                  * Se prima linea                              *
      *                  *---------------------------------------------*
           if        w-pmt-voc-des-ctr    not  = 1
                     go to pmt-voc-des-120.
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      53                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "-------------- Condizioni di fornitura -----------
      -              "---"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-voc-des-120.
      *                  *---------------------------------------------*
      *                  * Voce                                        *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           add       15
                     w-pmt-voc-des-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      w-prs-vde-fat-dve
                    (w-pmt-voc-des-ctr)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * ':'                                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       15
                     w-pmt-voc-des-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     pmt-voc-des-100.
       pmt-voc-des-999.
           exit.

