      *    *-----------------------------------------------------------*
       acc-cod-ime-000.
       acc-cod-ime-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice intermediario      *
      *    *-----------------------------------------------------------*
       vis-cod-ime-000.
       vis-cod-ime-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Importo provvigioni a forfait*
      *    * per l'intermediario                                       *
      *    *-----------------------------------------------------------*
       acc-pvf-ime-000.
       acc-pvf-ime-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Importo provvigioni a for-*
      *    * fait per l'intermediario                                  *
      *    *-----------------------------------------------------------*
       vis-pvf-ime-000.
       vis-pvf-ime-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice pagamento             *
      *    *-----------------------------------------------------------*
       acc-cod-fop-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio percentuale di sconto pagamento *
      *                  * associata alla forma di pagamento           *
      *                  *---------------------------------------------*
           move      w-tes-scp-aap (1)    to   w-sav-scp-aap          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-fop-400.
       acc-cod-fop-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-yfp-ope      .
           move      w-tes-cod-fop (1)    to   w-cod-mne-yfp-cod      .
           move      05                   to   w-cod-mne-yfp-lin      .
           move      30                   to   w-cod-mne-yfp-pos      .
           move      05                   to   w-cod-mne-yfp-dln      .
           move      41                   to   w-cod-mne-yfp-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-yfp-cll-000  thru cod-mne-yfp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-yfp-foi-000  thru cod-mne-yfp-foi-999    .
       acc-cod-fop-110.
           perform   cod-mne-yfp-cll-000  thru cod-mne-yfp-cll-999    .
           if        w-cod-mne-yfp-ope    =    "F+"
                     go to acc-cod-fop-115.
           if        w-cod-mne-yfp-ope    =    "AC"
                     go to acc-cod-fop-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fop-115.
           perform   cod-mne-yfp-foi-000  thru cod-mne-yfp-foi-999    .
           go to     acc-cod-fop-110.
       acc-cod-fop-120.
           move      w-cod-mne-yfp-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
       acc-cod-fop-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-fop (1)      .
       acc-cod-fop-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [yfp]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-let-arc-yfp-cod      .
           perform   let-arc-yfp-000      thru let-arc-yfp-999        .
           move      w-let-arc-yfp-des    to   w-tes-cod-fop-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-fop-000      thru vis-des-fop-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-yfp-flg    not  = spaces
                     go to acc-cod-fop-100.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [yfp]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-yfp-000      thru det-vlt-yfp-999        .
       acc-cod-fop-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione sconto pagamento            *
      *                  *---------------------------------------------*
           perform   vis-scp-aap-000      thru vis-scp-aap-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento % sconto pagamento per piede    *
      *                  *                                             *
      *                  * - Se w-tes-scp-aap # 0                      *
      *                  *   - Se w-pie-per-scp = 0 => bufferizzazione *
      *                  *   - Se w-pie-per-scp # 0                    *
      *                  *     - Se w-pie-per-scp = w-sav-scp-aap =>   *
      *                  *       => bufferizzazione                    *
      *                  *     - Se w-pie-per-scp # w-sav-scp-aap =>   *
      *                  *       => nessuna azione                     *
      *                  * - Se w-tes-scp-aap = 0                      *
      *                  *   - Se w-pie-per-scp = 0 => nessuna azione  *
      *                  *   - Se w-pie-per-scp # 0 => nessuna azione  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se % sconto pagamento associata alla    *
      *                      * forma di pagamento a zero : oltre       *
      *                      *-----------------------------------------*
           if        w-tes-scp-aap (1)    =    zero
                     go to acc-cod-fop-602.
      *                      *-----------------------------------------*
      *                      * Se % sconto pagamento per piede a zero, *
      *                      * bufferizzazione % sconto pagamento as-  *
      *                      * sociata alla forma di pagamento in %    *
      *                      * sconto pagamento per piede e oltre      *
      *                      *-----------------------------------------*
           if        w-pie-per-scp (1)    =    zero
                     move  w-tes-scp-aap (1)
                                          to   w-pie-per-scp (1)
                     go to acc-cod-fop-602.
      *                      *-----------------------------------------*
      *                      * Se % sconto pagamento per piede diverso *
      *                      * da zero                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se % per piede pari alla % associa- *
      *                          * ta alla forma di pagamento prece-   *
      *                          * dentemente salvata, aggiornamento   *
      *                          *-------------------------------------*
           if        w-sav-scp-aap        =    w-pie-per-scp (1)
                     move  w-tes-scp-aap (1)
                                          to   w-pie-per-scp (1)      .
       acc-cod-fop-602.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostra banca             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-nsb (1)    not  = "S"
                     go to acc-cod-fop-604.
           if        w-tes-nos-ban (1)    not  = spaces
                     go to acc-cod-fop-608.
           move      w-tes-nsb-aaf (1)    to   w-tes-nos-ban (1)      .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-608.
       acc-cod-fop-604.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ban (1)    =    spaces
                     go to acc-cod-fop-608.
           move      spaces               to   w-tes-nos-ban (1)      .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-608.
       acc-cod-fop-608.
      *                  *---------------------------------------------*
      *                  * Trattamento codici Abi, Cab e c/c bancario  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-bnb (1)    not  = "S"
                     go to acc-cod-fop-610.
           if        w-tes-cod-abi (1)    not  = zero
                     go to acc-cod-fop-620.
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
           go to     acc-cod-fop-620.
       acc-cod-fop-610.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-fop-620.
           move      zero                 to   w-tes-cod-abi (1)      .
           move      spaces               to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           move      spaces               to   w-tes-ccc-app (1)      .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
       acc-cod-fop-620.
      *                  *---------------------------------------------*
      *                  * Trattamento c/c postale fornitore           *
      *                  *---------------------------------------------*
           if        w-tes-snx-ccp (1)    =    spaces   and
                     w-tes-ccp-app (1)    not  = spaces
                     move  spaces         to   w-tes-ccp-app (1)
                     perform vis-ccp-app-000
                                          thru vis-ccp-app-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento data scadenza pagamento manuale *
      *                  *---------------------------------------------*
           if        w-tes-snx-spm (1)    =    spaces and
                     w-tes-pag-dsm (1)    not  = zero
                     move  zero           to   w-tes-pag-dsm (1)
                     perform vis-pag-dsm-000
                                          thru vis-pag-dsm-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento quota a forfait                 *
      *                  *---------------------------------------------*
           if        w-tes-snx-qaf (1)    =    spaces and
                     w-tes-pag-qaf (1)    not  = zero
                     move  zero           to   w-tes-pag-qaf (1)
                     perform vis-pag-qaf-000
                                          thru vis-pag-qaf-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento acconto                         *
      *                  *---------------------------------------------*
           if        w-tes-snx-act (1)    =    spaces and
                     w-tes-pag-act (1)    not  = zero
                     move  zero           to   w-tes-pag-act (1)
                     perform vis-pag-act-000
                                          thru vis-pag-act-999        .
       acc-cod-fop-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fop-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fop-100.
       acc-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice forma di pagamento *
      *    *-----------------------------------------------------------*
       vis-cod-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-fop (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione forma di paga-*
      *    * mento                                                     *
      *    *-----------------------------------------------------------*
       vis-des-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-fop-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : % sconto pagamento        *
      *    *-----------------------------------------------------------*
       vis-scp-aap-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BD"                to   v-edm                  .
           move      w-tes-scp-aap (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-scp-aap-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostra banca          *
      *    *-----------------------------------------------------------*
       acc-nos-ban-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-nos-ban-400.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-nsb (1)    =    spaces
                     go to acc-nos-ban-999.
       acc-nos-ban-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      02                   to   w-cod-des-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-cod-des-cbp-cod      .
           move      08                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      08                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-nos-ban-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-nos-ban-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-nos-ban-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-nos-ban-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-nos-ban-110.
       acc-nos-ban-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
       acc-nos-ban-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nos-ban (1)      .
       acc-nos-ban-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-nos-ban-100.
       acc-nos-ban-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nos-ban-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nos-ban-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nos-ban-100.
       acc-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostra banca       *
      *    *-----------------------------------------------------------*
       vis-nos-ban-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nos-ban (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice nostra banca, descrizione  *
      *    *-----------------------------------------------------------*
       vis-nos-ban-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-nos-ban-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice ABI banca d'appoggio  *
      *    *-----------------------------------------------------------*
       acc-cod-abi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-bnb (1)    =    spaces
                     go to acc-cod-abi-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-sav-cod-abi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-abi-400.
       acc-cod-abi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-abi-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-abi-cod      .
           move      10                   to   w-cod-mne-abi-lin      .
           move      30                   to   w-cod-mne-abi-pos      .
           move      10                   to   w-cod-mne-abi-dln      .
           move      41                   to   w-cod-mne-abi-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
       acc-cod-abi-110.
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           if        w-cod-mne-abi-ope    =    "F+"
                     go to acc-cod-abi-115.
           if        w-cod-mne-abi-ope    =    "AC"
                     go to acc-cod-abi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-abi-115.
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
           go to     acc-cod-abi-110.
       acc-cod-abi-120.
           move      w-cod-mne-abi-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
       acc-cod-abi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-abi (1)      .
       acc-cod-abi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica istituti                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-den-abi-000      thru vis-den-abi-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita da lettura           *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to acc-cod-abi-100.
       acc-cod-abi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se variato codice ABI                       *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    w-sav-cod-abi
                     go to acc-cod-abi-800.
           if        w-tes-cod-cab (1)    =    zero
                     go to acc-cod-abi-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione C/C bancario            *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-ccc-app (1)      .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
       acc-cod-abi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-abi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-abi-100.
       acc-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice ABI banca          *
      *    *-----------------------------------------------------------*
       vis-cod-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-abi (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione banca       *
      *    *-----------------------------------------------------------*
       vis-den-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-abi-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-abi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice CAB                   *
      *    *-----------------------------------------------------------*
       acc-cod-cab-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-cab-999.
            if       w-tes-snx-bnb (1)    =    spaces
                     go to acc-cod-cab-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cab-400.
       acc-cod-cab-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cab-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-cab-abi      .
           move      w-tes-cod-cab (1)    to   w-cod-mne-cab-cab      .
           move      11                   to   w-cod-mne-cab-lin      .
           move      30                   to   w-cod-mne-cab-pos      .
           move      11                   to   w-cod-mne-cab-dln      .
           move      41                   to   w-cod-mne-cab-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
       acc-cod-cab-110.
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           if        w-cod-mne-cab-ope    =    "F+"
                     go to acc-cod-cab-115.
           if        w-cod-mne-cab-ope    =    "AC"
                     go to acc-cod-cab-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cab-115.
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
           go to     acc-cod-cab-110.
       acc-cod-cab-120.
           move      w-cod-mne-cab-cab    to   v-num                  .
       acc-cod-cab-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
       acc-cod-cab-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cab (1)      .
       acc-cod-cab-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-cod-cab-100.
       acc-cod-cab-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cab-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cab-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cab-100.
       acc-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice CAB                *
      *    *-----------------------------------------------------------*
       vis-cod-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cab (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione sportello   *
      *    *-----------------------------------------------------------*
       vis-den-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cab-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-cab-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Conto corrente bancario      *
      *    *-----------------------------------------------------------*
       acc-ccc-app-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-ccc-app-999.
            if       w-tes-snx-bnb (1)    =    spaces
                     go to acc-ccc-app-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ccc-app-400.
       acc-ccc-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ccc-app (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
       acc-ccc-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ccc-app (1)      .
       acc-ccc-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ccc-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccc-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ccc-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ccc-app-100.
       acc-ccc-app-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Conto corrente bancario   *
      *    *-----------------------------------------------------------*
       vis-ccc-app-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ccc-app (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccc-app-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Conto corrente postale       *
      *    *-----------------------------------------------------------*
       acc-ccp-app-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-ccp (1)    =    spaces
                     go to acc-ccp-app-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ccp-app-400.
       acc-ccp-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ccp-app (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ccp-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ccp-app-999.
       acc-ccp-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ccp-app (1)      .
       acc-ccp-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ccp-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccp-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ccp-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ccp-app-100.
       acc-ccp-app-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Conto corrente postale    *
      *    *-----------------------------------------------------------*
       vis-ccp-app-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ccp-app (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccp-app-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Addebito spese incasso       *
      *    *-----------------------------------------------------------*
       acc-add-spi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-add-spi-400.
       acc-add-spi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-yin-ope      .
           move      w-tes-add-spi (1)    to   w-cod-cod-yin-cod      .
           move      16                   to   w-cod-cod-yin-lin      .
           move      30                   to   w-cod-cod-yin-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-cod-spi-cll-000  thru cod-cod-spi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-spi-foi-000  thru cod-cod-spi-foi-999    .
       acc-add-spi-110.
           perform   cod-cod-spi-cll-000  thru cod-cod-spi-cll-999    .
           if        w-cod-cod-yin-ope    =    "F+"
                     go to acc-add-spi-115.
           if        w-cod-cod-yin-ope    =    "AC"
                     go to acc-add-spi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spi-115.
           perform   cod-cod-spi-foi-000  thru cod-cod-spi-foi-999    .
           go to     acc-add-spi-110.
       acc-add-spi-120.
           move      w-cod-cod-yin-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spi-999.
       acc-add-spi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-add-spi (1)      .
       acc-add-spi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-add-spi (1)    to   w-let-arc-yin-cod      .
           move      00                   to   w-let-arc-yin-tpg      .
           perform   let-arc-yin-000      thru let-arc-yin-999        .
           move      w-let-arc-yin-des    to   w-tes-add-spi-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-spi-000      thru vis-des-spi-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-yin-flg    not  = spaces
                     go to acc-add-spi-100.
       acc-add-spi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-add-spi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-add-spi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-add-spi-100.
       acc-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Addebito spese incasso    *
      *    *-----------------------------------------------------------*
       vis-add-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-add-spi (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descriz. spese incasso    *
      *    *-----------------------------------------------------------*
       vis-des-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-add-spi-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-spi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Addebito spese bollo         *
      *    *-----------------------------------------------------------*
       acc-add-spb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-add-spb-400.
       acc-add-spb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-ybo-ope      .
           move      w-tes-add-spb (1)    to   w-cod-cod-ybo-cod      .
           move      17                   to   w-cod-cod-ybo-lin      .
           move      30                   to   w-cod-cod-ybo-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-cod-spb-cll-000  thru cod-cod-spb-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-spb-foi-000  thru cod-cod-spb-foi-999    .
       acc-add-spb-110.
           perform   cod-cod-spb-cll-000  thru cod-cod-spb-cll-999    .
           if        w-cod-cod-ybo-ope    =    "F+"
                     go to acc-add-spb-115.
           if        w-cod-cod-ybo-ope    =    "AC"
                     go to acc-add-spb-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spb-115.
           perform   cod-cod-spb-foi-000  thru cod-cod-spb-foi-999    .
           go to     acc-add-spb-110.
       acc-add-spb-120.
           move      w-cod-cod-ybo-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spb-999.
       acc-add-spb-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-add-spb (1)      .
       acc-add-spb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-add-spb (1)    to   w-let-arc-ybo-cod      .
           move      00                   to   w-let-arc-ybo-tpg      .
           perform   let-arc-ybo-000      thru let-arc-ybo-999        .
           move      w-let-arc-ybo-des    to   w-tes-add-spb-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-spb-000      thru vis-des-spb-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-ybo-flg    not  = spaces
                     go to acc-add-spb-100.
       acc-add-spb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-add-spb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-add-spb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-add-spb-100.
       acc-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Addebito spese bollo      *
      *    *-----------------------------------------------------------*
       vis-add-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-add-spb (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descriz. spese bollo      *
      *    *-----------------------------------------------------------*
       vis-des-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-add-spb-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-spb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data scadenza pagamento      *
      *    *-----------------------------------------------------------*
       acc-pag-dsm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-spm (1)    =    spaces
                     go to acc-pag-dsm-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pag-dsm-400.
       acc-pag-dsm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      ">"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-dsm (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-dsm-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-dsm-999.
       acc-pag-dsm-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-pag-dsm (1)      .
       acc-pag-dsm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se inferiore a data documento          *
      *                  *---------------------------------------------*
           if        w-tes-pag-dsm (1)    <    w-tes-dat-doc
                     go to acc-pag-dsm-100.
       acc-pag-dsm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pag-dsm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-dsm-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-dsm-100.
       acc-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data scadenza pagamento   *
      *    *-----------------------------------------------------------*
       vis-pag-dsm-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-pag-dsm (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-dsm-999.
           exit.

