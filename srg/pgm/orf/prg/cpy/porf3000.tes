           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
