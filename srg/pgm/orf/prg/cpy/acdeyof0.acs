      *    *===========================================================*
      *    * Subroutines per l'accettazione tipo movimento per ordini  *
      *    * fornitori                                                 *
      *    *-----------------------------------------------------------*
       cod-des-yof-opn-000.
           move      "pgm/orf/prg/obj/acdeyof0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-des-yof-pth      .
           move      "OP"                 to   w-cod-des-yof-ope      .
           perform   cod-des-yof-cll-000  thru cod-des-yof-cll-999    .
       cod-des-yof-opn-999.
           exit.
       cod-des-yof-cls-000.
           move      "CL"                 to   w-cod-des-yof-ope      .
           perform   cod-des-yof-cll-000  thru cod-des-yof-cll-999    .
           move      "C?"                 to   w-cod-des-yof-ope      .
           perform   cod-des-yof-cll-000  thru cod-des-yof-cll-999    .
           if        w-cod-des-yof-ope    not  = spaces
                     go to cod-des-yof-cls-999.
           cancel    w-cod-des-yof-pth                                .
       cod-des-yof-cls-999.
           exit.
       cod-des-yof-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-des-yof-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "porf0100"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-des-yof-foi-999.
           move      "pgm/orf/prg/obj/porf0100"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-des-yof-ope      .
           go to     cod-des-yof-foi-999.
       cod-des-yof-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-des-yof-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "porf0110"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-des-yof-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/orf/prg/obj/porf0110"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-des-yof-ope      .
           go to     cod-des-yof-foi-999.
       cod-des-yof-foi-999.
           exit.
       cod-des-yof-cll-000.
           call      w-cod-des-yof-pth   using w-cod-des-yof
                                               v
                                               s                      .
       cod-des-yof-cll-999.
           exit.

