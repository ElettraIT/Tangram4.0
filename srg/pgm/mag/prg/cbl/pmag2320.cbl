      *    *===========================================================*
      *    * Determinazione anno e mese di esercizio da una data       *
      *    *                                                           *
      *    * N.B.: Per ottenere l'anno e il mese di esercizio e'       *
      *    *       necessario conoscere la personalizzazione relativa  *
      *    *       al mese di chiusura esercizio 'w-prs-mes-che'       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * In input  : w-det-aem-ese-dat = Data per la determinazio- *
      *    *                                 ne                        *
      *    *                                                           *
      *    * In output : w-det-aem-ese-ann = Anno di esercizio         *
      *    *             w-det-aem-ese-mes = Mese di esercizio         *
      *    *-----------------------------------------------------------*
       det-aem-ese-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione iniziale                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-aem-ese-ann      .
           move      zero                 to   w-det-aem-ese-mes      .
       det-aem-ese-100.
      *              *-------------------------------------------------*
      *              * Test iniziale                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data a zero : uscita                     *
      *                  *---------------------------------------------*
           if        w-det-aem-ese-dat    =    zero
                     go to det-aem-ese-999.
       det-aem-ese-200.
      *              *-------------------------------------------------*
      *              * Anno di esercizio                               *
      *              *-------------------------------------------------*
           move      w-det-aem-ese-dat    to   s-dat                  .
           if        w-prs-mes-che        =    12             or
                     s-mes                >    w-prs-mes-che
                     move  s-saa          to   w-det-aem-ese-ann
                     go to det-aem-ese-300.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-det-aem-ese-ann      .
       det-aem-ese-300.
      *              *-------------------------------------------------*
      *              * Mese di esercizio                               *
      *              *-------------------------------------------------*
           move      s-mes                to   w-det-aem-ese-mes      .
           if        w-prs-mes-che        =    12
                     go to det-aem-ese-999.
           if        s-mes                >    w-prs-mes-che
                     subtract w-prs-mes-che
                                          from w-det-aem-ese-mes
                     go to det-aem-ese-999.
           if        s-mes                <    w-prs-mes-che
                     add   12             to   w-det-aem-ese-mes
                     subtract w-prs-mes-che
                                          from w-det-aem-ese-mes
                     go to det-aem-ese-999.
           move      12                   to   w-det-aem-ese-mes      .
       det-aem-ese-999.
           exit.

      *    *===========================================================*
      *    * Determinazione castelletto mesi di esercizio in base      *
      *    * all'anno di esercizio                                     *
      *    *-----------------------------------------------------------*
       det-cst-mes-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
           if        w-prs-mes-che        not  = 12
                     go to det-cst-mes-200.
      *              *-------------------------------------------------*
      *              * Se il mese di chiusura e' l'ultimo dell'anno    *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cst-mes-ctr      .
       det-cst-mes-100.
           add       1                    to   w-det-cst-mes-ctr      .
           if        w-det-cst-mes-ctr    >    12
                     go to det-cst-mes-999.
           move      w-det-cst-mes-ctr    to   w-det-cst-mes-mes
                                              (w-det-cst-mes-ctr)     .
           move      w-det-cst-mes-ann    to   w-det-cst-mes-aes
                                              (w-det-cst-mes-ctr)     .
           go to     det-cst-mes-100.
       det-cst-mes-200.
      *              *-------------------------------------------------*
      *              * Se il mese di chiusura non e' l'ultimo dell'an- *
      *              * no                                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di determinazione di mese ed anno     *
      *                  * di esercizio                                *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-cst-mes-ctr      .
       det-cst-mes-300.
           add       1                    to   w-det-cst-mes-ctr      .
           if        w-det-cst-mes-ctr    >    12
                     go to det-cst-mes-999.
      *                      *-----------------------------------------*
      *                      * Spostamento di :                        *
      *                      *  - contatore nel mese                   *
      *                      *  - anno di esercizio nell'anno          *
      *                      *-----------------------------------------*
           move      w-det-cst-mes-ctr    to   w-det-cst-mes-mes
                                              (w-det-cst-mes-ctr)     .
           move      w-det-cst-mes-ann    to   w-det-cst-mes-aes
                                              (w-det-cst-mes-ctr)     .
      *                      *-----------------------------------------*
      *                      * Incremento del mese con il mese di      *
      *                      * chiusura esercizio                      *
      *                      *-----------------------------------------*
           add       w-prs-mes-che        to   w-det-cst-mes-mes
                                              (w-det-cst-mes-ctr)     .
      *                      *-----------------------------------------*
      *                      * Test se il risultato supera o meno il   *
      *                      * 12                                      *
      *                      *-----------------------------------------*
           if        w-det-cst-mes-mes
                    (w-det-cst-mes-ctr)   not  > 12
                     go to det-cst-mes-900.
           subtract  12                   from w-det-cst-mes-mes
                                              (w-det-cst-mes-ctr)     .
           add       1                    to   w-det-cst-mes-aes
                                              (w-det-cst-mes-ctr)     .
       det-cst-mes-900.
      *                  *---------------------------------------------*
      *                  * Riciclo a mese successivo                   *
      *                  *---------------------------------------------*
           go to     det-cst-mes-300.
       det-cst-mes-999.
           exit.

