      *    *                                            numerico       *
      *    *-----------------------------------------------------------*
       acc-cod-sem-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-alf-sem        to   w-sav-alf-sem          .
       acc-cod-sem-100.
      *              *-------------------------------------------------*
      *              * Ripristino valore precedente                    *
      *              *-------------------------------------------------*
           move      w-sav-alf-sem        to   w-rig-alf-sem          .
       acc-cod-sem-125.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri generali di accettazione          *
      *                  *---------------------------------------------*
           move      "AC"                 to   w-cod-cod-dps-ope      .
           move      "L"                  to   w-cod-cod-dps-tac      .
           move      w-rig-num-sem        to   w-cod-cod-dps-num      .
           move      w-rig-alf-sem        to   w-cod-cod-dps-alf      .
           move      19                   to   w-cod-cod-dps-lin      .
           move      21                   to   w-cod-cod-dps-pos      .
           move      zero                 to   w-cod-cod-dps-dln      .
           move      zero                 to   w-cod-cod-dps-dps      .
           move      spaces               to   v-edm                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso, a meno che non   *
      *                      *        si sia alla riga numero 1        *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    >    1
                     move  "UP  "         to   v-pfk (01)
           else      move  spaces         to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : mai ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : mai ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)
           else      move  spaces         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : mai ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso, a meno che non   *
      *                      *        si sia alla pagina numero 1      *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    >    w-lin-num-lin-vis
                     move  "PRSC"         to   v-pfk (07)
           else      move  spaces         to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)
           else      move  spaces         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = w-rlt-sup-max
                     move  "TAB "         to   v-pfk (10)
           else      move  spaces         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-rlt-sup-max        not  < 2
                     move  "SLCT"         to   v-pfk (11)
           else      move  spaces         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Expd : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "EXPD"               to   v-pfk (12)             .
       acc-cod-sem-150.
      *                  *---------------------------------------------*
      *                  * Esecuzione accettazione                     *
      *                  *---------------------------------------------*
           perform   cod-cod-dps-cll-000  thru cod-cod-dps-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dps-foi-000  thru cod-cod-dps-foi-999    .
       acc-cod-sem-152.
           perform   cod-cod-dps-cll-000  thru cod-cod-dps-cll-999    .
           if        w-cod-cod-dps-ope    =    "F+"
                     go to acc-cod-sem-154.
           if        w-cod-cod-dps-ope    =    "AC"
                     go to acc-cod-sem-156.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-sem-154.
           perform   cod-cod-dps-foi-000  thru cod-cod-dps-foi-999    .
           go to     acc-cod-sem-152.
       acc-cod-sem-156.
           move      w-cod-cod-dps-alf    to   v-alf                  .
       acc-cod-sem-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
       acc-cod-sem-225.
      *              *-------------------------------------------------*
      *              * Test se Return                                  *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-cod-sem-400.
       acc-cod-sem-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-cod-sem-300.
       acc-cod-sem-255.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore impostato in comodo per tratta-  *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
      *                      *-----------------------------------------*
      *                      * Se nel movimento e' avvenuto un tronca- *
      *                      * mento : a reimpostazione                *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-alf    not  = v-alf
                     go to acc-cod-sem-100.
       acc-cod-sem-260.
      *                      *-----------------------------------------*
      *                      * Conversione vera e propria; se errori : *
      *                      * a reimpostazione                        *
      *                      *-----------------------------------------*
           move      zero                 to   w-cnt-slc-rap-num      .
           move      zero                 to   w-cnt-wrk-ctr-001      .
       acc-cod-sem-262.
           add       1                    to   w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001    >    5
                     go to acc-cod-sem-270.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   =    spaces
                     go to acc-cod-sem-264.
           if       (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-cod-sem-100.
           multiply  10                   by   w-cnt-slc-rap-num      .
           add       w-cnt-slc-rap-chn
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-num      .
           go to     acc-cod-sem-262.
       acc-cod-sem-264.
           add       1                    to   w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001    >    5
                     go to acc-cod-sem-270.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   =    spaces
                     go to acc-cod-sem-264
           else      go to acc-cod-sem-100.
       acc-cod-sem-270.
      *                      *-----------------------------------------*
      *                      * Se conversione senza errori             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se numero riga minore di 1 oppure   *
      *                          * maggiore del massimo : reimposta-   *
      *                          * zione                               *
      *                          *-------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-rlt-sup-max
                     go to acc-cod-sem-100.
      *                          *-------------------------------------*
      *                          * Se numero riga impostato pari a nu- *
      *                          * numero riga attuale : reimpostazio- *
      *                          * ne                                  *
      *                          *-------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-cod-sem-100.
      *                          *-------------------------------------*
      *                          * Preparazione parametri e uscita     *
      *                          *-------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-cod-sem-999.
       acc-cod-sem-300.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo di imposta-  *
      *              * zione                                           *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-cod-sem-100.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-cod-sem-320.
      *                  *---------------------------------------------*
      *                  * Routine di visualizzazione castelletto con  *
      *                  * i valori di tutti e dodici i mesi di eser-  *
      *                  * cizio                                       *
      *                  *---------------------------------------------*
           perform   esp-cst-cos-000      thru esp-cst-cos-999        .
      *                  *---------------------------------------------*
      *                  * E reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-cod-sem-100.
       acc-cod-sem-320.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-sem-999
                     else    go to acc-cod-sem-100.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-cod-sem-999.
       acc-cod-sem-400.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se variazione del valore di default : a re- *
      *                  * impostazione                                *
      *                  *---------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-cod-sem-100.
       acc-cod-sem-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice semilavorato alfanumerico  *
      *    *-----------------------------------------------------------*
       vis-cod-sem-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-alf-sem        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-sem-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione semilavorato          *
      *    *-----------------------------------------------------------*
       vis-des-sem-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-rig-des-sem        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-sem-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Unita' di misura                  *
      *    *-----------------------------------------------------------*
       vis-umi-prd-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      w-rig-umi-prd        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-umi-prd-999.
           exit.

      *    *===========================================================*
      *    * Routine di espansione castelletto costi                   *
      *    *-----------------------------------------------------------*
       esp-cst-cos-000.
      *              *-------------------------------------------------*
      *              * Richiesta della data di sistema                 *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      48                   to   v-pos                  .
           move      21                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       esp-cst-cos-100.
      *              *-------------------------------------------------*
      *              * Inizio ciclo di visualizzazione                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cst-mes-ctr      .
       esp-cst-cos-200.
           add       1                    to   w-det-cst-mes-ctr      .
      *              *-------------------------------------------------*
      *              * Test sul contatore                              *
      *              *-------------------------------------------------*
           if        w-det-cst-mes-ctr    >    12
                     go to esp-cst-cos-900.
      *                  *---------------------------------------------*
      *                  * Test che l'elemento richiesto non sia       *
      *                  * superiore alla data di sistema              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-det-cst-mes-aes
                    (w-det-cst-mes-ctr)   <    s-saa
                     go to esp-cst-cos-210.
           if        w-det-cst-mes-mes
                    (w-det-cst-mes-ctr)   not  > s-mes
                     go to esp-cst-cos-210
           else      go to esp-cst-cos-900.
       esp-cst-cos-210.
      *              *-------------------------------------------------*
      *              * Indicatore di posizione esterno al box          *
      *              *-------------------------------------------------*
           if        w-tes-mes-ese        not  = w-det-cst-mes-ctr
                     go to esp-cst-cos-220.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      08                   to   v-lin                  .
           add       w-det-cst-mes-ctr    to   v-lin                  .
           move      47                   to   v-pos                  .
           move      ">"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       esp-cst-cos-220.
      *              *-------------------------------------------------*
      *              * Visualizzazione literal del mese                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione del puntatore alla tabella dei *
      *                  * nomi dei mesi determinata                   *
      *                  *---------------------------------------------*
           move      w-det-cst-mes-mes
                    (w-det-cst-mes-ctr)   to   w-det-cst-mes-pnt      .
      *                  *---------------------------------------------*
      *                  * Literal del mese, da segreteria             *
      *                  *---------------------------------------------*
           move      "LM"                 to   s-ope                  .
           move      "E"                  to   s-tip                  .
           move      w-det-cst-mes-pnt    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      08                   to   v-lin                  .
           add       w-det-cst-mes-ctr    to   v-lin                  .
           move      50                   to   v-pos                  .
           move      s-alf                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione anno di esercizio               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      08                   to   v-lin                  .
           add       w-det-cst-mes-ctr    to   v-lin                  .
           move      60                   to   v-pos                  .
           move      w-det-cst-mes-aes
                    (w-det-cst-mes-ctr)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione separatore ':'                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      08                   to   v-lin                  .
           add       w-det-cst-mes-ctr    to   v-lin                  .
           move      63                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione costo standard                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           add       02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BGD"                to   v-edm                  .
           move      08                   to   v-lin                  .
           add       w-det-cst-mes-ctr    to   v-lin                  .
           move      65                   to   v-pos                  .
           if        w-tes-tip-cos        =    01
                     move  w-rig-ust-mns
                          (w-det-cst-mes-ctr)
                                          to   v-num
           else      move  w-rig-ucu-mns
                          (w-det-cst-mes-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     esp-cst-cos-200.
       esp-cst-cos-900.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      20                   to   v-lin                  .
           move      79                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       esp-cst-cos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo espansa : Costo attuale     *
      *    *-----------------------------------------------------------*
       acc-att-cos-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-att-cos-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           add       02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-rig-att-cos        to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-att-cos-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-att-cos          .
       acc-att-cos-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-att-cos-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-att-cos-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-att-cos-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-att-cos-100.
       acc-att-cos-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Costo attuale                     *
      *    *-----------------------------------------------------------*
