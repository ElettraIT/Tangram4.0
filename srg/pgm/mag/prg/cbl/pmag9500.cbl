      *    *===========================================================*
      *    * Accettazione campo selezione : Anno di esercizio          *
      *    *-----------------------------------------------------------*
       acc-ann-ese-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        rr-ann-ese-fda       not  = spaces
                     go to acc-ann-ese-100.
      *                      *-----------------------------------------*
      *                      * Richiesta data attuale                  *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Preparazione                            *
      *                      *-----------------------------------------*
           move      s-ann                to   rr-ann-ese             .
       acc-ann-ese-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-ann-ese           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-ann-ese-999.
       acc-ann-ese-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-ann-ese             .
       acc-ann-ese-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo che l'anno di esercizio impostato *
      *                  * non sia superiore a quello odierno          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Richiesta data attuale                  *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-ann-ese           >    s-saa
                     go to acc-ann-ese-100.
       acc-ann-ese-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           move      "#"                  to   rr-ann-ese-fda         .
       acc-ann-ese-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-ann-ese-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-ann-ese-100.
       acc-ann-ese-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Mese iniziale              *
      *    *-----------------------------------------------------------*
       acc-mes-ini-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        rr-mes-ini           not  = zero
                     go to acc-mes-ini-100.
           move      01                   to   rr-mes-ini             .
       acc-mes-ini-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-mes-ini           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-mes-ini-999.
       acc-mes-ini-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-mes-ini             .
       acc-mes-ini-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        rr-mes-ini           not  = zero
                     go to acc-mes-ini-500.
           if        v-key                =    "UP  "
                     go to acc-mes-ini-600
           else      go to acc-mes-ini-100.
       acc-mes-ini-500.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia superiore a 12        *
      *                  *---------------------------------------------*
           if        rr-mes-ini           >    12
                     go to acc-mes-ini-100.
       acc-mes-ini-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-mes-ini-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-mes-ini-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-mes-ini-100.
       acc-mes-ini-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Mese finale                *
      *    *-----------------------------------------------------------*
       acc-mes-fin-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        rr-mes-fin           not  = zero
                     go to acc-mes-fin-100.
           if        rr-mes-ini           not  = 01
                     go to acc-mes-fin-100.
           move      12                   to   rr-mes-fin             .
       acc-mes-fin-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-mes-fin           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-mes-fin-999.
       acc-mes-fin-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-mes-fin             .
       acc-mes-fin-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * dia in Up                                   *
      *                  *---------------------------------------------*
           if        rr-mes-fin           not  = zero
                     go to acc-mes-fin-500.
           if        v-key                =    "UP  "
                     go to acc-mes-fin-600
           else      go to acc-mes-fin-100.
       acc-mes-fin-500.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia superiore a 12        *
      *                  *---------------------------------------------*
           if        rr-mes-fin           >    12
                     go to acc-mes-fin-100.
       acc-mes-fin-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-mes-fin-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-mes-fin-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-mes-fin-100.
       acc-mes-fin-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Test su anno di esercizio                       *
      *              *-------------------------------------------------*
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su mese iniziale                      *
      *              *-------------------------------------------------*
           if        rr-mes-ini           not  = zero
                     go to tdo-ric-sel-300.
           move      "Manca il mese iniziale !                          
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo su mese finale                        *
      *              *-------------------------------------------------*
           if        rr-mes-fin           not  = zero
                     go to tdo-ric-sel-400.
           move      "Manca il mese finale !                            
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Controllo su mese iniziale e finale             *
      *              *-------------------------------------------------*
           if        rr-mes-fin           not  < rr-mes-ini
                     go to tdo-ric-sel-500.
           move      "Il mese finale non puo' essere inferiore al mese i
      -              "niziale !      "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione messaggio                   *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Regolazizzazione anno di esercizio              *
      *              *-------------------------------------------------*
           move      "NS"                 to   s-ope                  .
           move      zero                 to   s-dat                  .
           move      rr-ann-ese           to   s-saa                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   rr-ann-ese             .
       reg-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Determinazione data iniziale                    *
      *              *-------------------------------------------------*
           move      01                   to   s-gio                  .
           move      rr-mes-ini           to   s-mes                  .
           move      rr-ann-ese           to   s-saa                  .
           move      s-dat                to   rr-dat-ini             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Determinazione data finale                      *
      *              *-------------------------------------------------*
           move      31                   to   s-gio                  .
           move      rr-mes-fin           to   s-mes                  .
           move      rr-ann-ese           to   s-saa                  .
       reg-ric-sel-220.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  =    spaces
                     subtract 1           from s-gio
                     go to reg-ric-sel-220.
           move      s-dat                to   rr-dat-fin             .
       reg-ric-sel-999.
           exit.

