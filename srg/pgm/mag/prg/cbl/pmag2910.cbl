           move      "#"                  to   w-exe-srt-out-flg      .
           go to     exe-srt-out-999.
       exe-srt-out-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
           return    srt    at end
                            go to exe-srt-out-999.
      *              *-------------------------------------------------*
      *              * Scrittura record [mmc]                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [mmc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmc                 .
      *                  *---------------------------------------------*
      *                  * Composizione record                         *
      *                  *---------------------------------------------*
           move      srt-tip-mag          to   rf-mmc-tip-mag         .
           move      srt-num-mag          to   rf-mmc-num-mag         .
           move      rr-dat-con           to   rf-mmc-dat-con         .
           move      99999999             to   rf-mmc-dat-rev         .
           if        rf-mmc-dat-con       not  = zero
                     subtract 19000000    from rf-mmc-dat-rev
                     subtract rf-mmc-dat-con
                                          from rf-mmc-dat-rev         .
           move      srt-dat-ulr          to   rf-mmc-dat-ulr         .
           move      srt-qta-gia          to   rf-mmc-gia-ddc         .
           move      srt-val-cmc          to   rf-mmc-cmc-ddc         .
      *                  *---------------------------------------------*
      *                  * Put record [mmc]                            *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmc                 .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale archivio sortato *
      *              * [srt]                                           *
      *              *-------------------------------------------------*
           go to     exe-srt-out-100.
       exe-srt-out-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento numerazione [duccmc]             *
      *    *-----------------------------------------------------------*
       exe-duc-cmc-000.
      *              *-------------------------------------------------*
      *              * Ottenimento record [duccmc]                     *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to exe-duc-cmc-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [duccmc]             *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
      *                  *---------------------------------------------*
      *                  * Scrittura record [duccmc]                   *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
      *                  *---------------------------------------------*
      *                  * Riciclo a inizio operazione                 *
      *                  *---------------------------------------------*
           go to     exe-duc-cmc-000.
       exe-duc-cmc-100.
      *              *-------------------------------------------------*
      *              * Composizione record [duccmc]                    *
      *              *-------------------------------------------------*
           move      rr-dat-con           to   rn-duc-cmc-dat-con     .
      *              *-------------------------------------------------*
      *              * Update record [duccmc]                          *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
      *              *-------------------------------------------------*
      *              * Release record [duccmc]                         *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
       exe-duc-cmc-999.
           exit.

