      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione consolidamento costo medio continuo            *
      *    *-----------------------------------------------------------*
       exe-con-cmc-000.
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   exe-srt-inp-000
                                          thru exe-srt-inp-999
                     output procedure     is   exe-srt-out-000
                                          thru exe-srt-out-999        .
      *              *-------------------------------------------------*
      *              * Test su flag di uscita da Output procedure      *
      *              *-------------------------------------------------*
           if        w-exe-srt-out-flg    not  = spaces
                     go to exe-con-cmc-999.
      *              *-------------------------------------------------*
      *              * Aggiornamento numerazione [duccmc]              *
      *              *-------------------------------------------------*
           perform   exe-duc-cmc-000      thru exe-duc-cmc-999        .
       exe-con-cmc-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione input procedure per sort                       *
      *    *-----------------------------------------------------------*
       exe-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-exe-srt-inp-flg      .
      *              *-------------------------------------------------*
      *              * Start su file [dcp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRO    "         to   f-key                  .
           move      zero                 to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se Start errata : uscita                        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-srt-inp-999.
       exe-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [dcp]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se fine file : uscita                           *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Selezione su record letto                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo prodotto non indica una merce :  *
      *                  * si ignora il record                         *
      *                  *---------------------------------------------*
           if        rf-dcp-tip-pro       not  = 01
                     go to exe-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura record [mmc] della data dell'ultimo     *
      *              * consolidamento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [mmc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmc                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [mmc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDAT    "         to   f-key                  .
           move      01                   to   rf-mmc-tip-mag         .
           move      rf-dcp-num-pro       to   rf-mmc-num-mag         .
           move      rn-duc-cmc-dat-con   to   rf-mmc-dat-con         .
           move      "pgm/mag/fls/ioc/obj/iofmmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmc                 .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori letti                    *
      *              *-------------------------------------------------*
           move      rf-mmc-dat-ulr       to   w-exe-srt-inp-dur      .
           move      rf-mmc-gia-ddc       to   w-exe-srt-inp-gia      .
           move      rf-mmc-cmc-ddc       to   w-exe-srt-inp-cmc      .
      *              *-------------------------------------------------*
      *              * Inizializzazione quantita' e valore giacenza    *
      *              * significativi                                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-srt-inp-qgs      .
           move      zero                 to   w-exe-srt-inp-vgs      .
       exe-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione file [mmr]                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [mmr]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      01                   to   rf-mmr-tip-mag         .
           move      rf-dcp-num-pro       to   rf-mmr-num-mag         .
           move      rn-duc-cmc-dat-con   to   rf-mmr-dat-reg         .
           move      99999999999          to   rf-mmr-num-prt         .
           move      99999                to   rf-mmr-num-prg         .
           move      "pgm/mag/fls/ioc/obj/iofmmr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-srt-inp-300.
       exe-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Indicatore di programma in esecuzione       *
      *                  *---------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mmr]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-mmr-tip-mag       not  = 01 or
                     rf-mmr-num-mag       not  = rf-dcp-num-pro or
                     rf-mmr-dat-reg       >    rr-dat-con
                     go to exe-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se movimentazione interna : riciclo     *
      *                      *-----------------------------------------*
           if        rf-mmr-tip-mdm       =    03
                     go to exe-srt-inp-220.
      *                      *-----------------------------------------*
      *                      * Se movimento di solo conto merce : ri-  *
      *                      * ciclo                                   *
      *                      *-----------------------------------------*
           if        rf-mmr-trt-mic       =    03
                     go to exe-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Se movimento in attesa di valorizzazione :  *
      *                  * set del flag ad errore e uscita             *
      *                  *---------------------------------------------*
           if        rf-mmr-trt-val       =    "I" and
                     rf-mmr-val-mov       =    zero
                     move  "#"            to   w-exe-srt-inp-flg
                     go to exe-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori attuali di giacenza e    *
      *                  * costo medio                                 *
      *                  *---------------------------------------------*
           move      w-exe-srt-inp-gia    to   w-exe-srt-inp-sgi      .
           move      w-exe-srt-inp-cmc    to   w-exe-srt-inp-scm      .
       exe-srt-inp-230.
      *                  *---------------------------------------------*
      *                  * Aggiornamento giacenza                      *
      *                  *---------------------------------------------*
           if        rf-mmr-tip-mdm       =    01
                     add      rf-mmr-qta-mov
                                          to   w-exe-srt-inp-gia
           else if   rf-mmr-tip-mdm       =    02
                     subtract rf-mmr-qta-mov
                                          from w-exe-srt-inp-gia      .
      *                  *---------------------------------------------*
      *                  * Determinazione valore significativo di gia- *
      *                  * cenza e valore totale giacenza              *
      *                  *---------------------------------------------*
           if        w-exe-srt-inp-gia    >    zero and
                     w-exe-srt-inp-sgi    >    zero
                     go to exe-srt-inp-232
           else      go to exe-srt-inp-240.
       exe-srt-inp-232.
           move      w-exe-srt-inp-gia    to   w-exe-srt-inp-qgs      .
           multiply  w-exe-srt-inp-cmc    by   w-exe-srt-inp-gia
                                        giving w-exe-srt-inp-vgs      .
       exe-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Aggiornamento costo medio continuo          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se movimento di Scarico : No        *
      *                          *-------------------------------------*
           if        rf-mmr-tip-mdm       =    02
                     go to exe-srt-inp-260.
      *                          *-------------------------------------*
      *                          * Se quantita' movimento non positi-  *
      *                          * va : No                             *
      *                          *-------------------------------------*
           if        rf-mmr-qta-mov       not  > zero
                     go to exe-srt-inp-260.
      *                      *-----------------------------------------*
      *                      * Determinazione valore movimento per ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        rf-mmr-trt-val       =    "N" or
                     rf-mmr-trt-val       =    "S"
                     move  zero           to   w-exe-srt-inp-w01
           else if   rf-mmr-trt-val       =    "I"
                     move  rf-mmr-val-mov to   w-exe-srt-inp-w01
           else if   rf-mmr-trt-val       =    "C" or
                     rf-mmr-trt-val       =    "X"
                     move  rf-mmr-val-mov to   w-exe-srt-inp-w01
           else if   rf-mmr-trt-val       =    "R" or
                     rf-mmr-trt-val       =    "Y"
                     move  rf-mmr-val-mov to   w-exe-srt-inp-w01
                     multiply -1          by   w-exe-srt-inp-w01      .
      *                      *-----------------------------------------*
      *                      * Se valore movimento a zero : oltre      *
      *                      *-----------------------------------------*
           if        w-exe-srt-inp-w01    =    zero
                     go to exe-srt-inp-260.
      *                      *-----------------------------------------*
      *                      * Aggiornamento costo medio continuo      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione a seconda che la quanti- *
      *                          * ta' in giacenza precedentemente     *
      *                          * salvata sia a positiva o meno       *
      *                          *-------------------------------------*
           if        w-exe-srt-inp-sgi    <    zero
                     go to exe-srt-inp-244
           else      go to exe-srt-inp-242.
       exe-srt-inp-242.
      *                          *-------------------------------------*
      *                          * Se giacenza precedentemente salvata *
      *                          * zero o positiva                     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Calcolo                         *
      *                              *---------------------------------*
           multiply  w-exe-srt-inp-sgi    by   w-exe-srt-inp-scm
                                        giving w-exe-srt-inp-w02      .
      *                              *---------------------------------*
      *                              * Applicazione decimali gestione  *
      *                              * magazzino                       *
      *                              *---------------------------------*
           divide    100                  into w-exe-srt-inp-w02      .
      *                              *---------------------------------*
      *                              * Calcolo - segue                 *
      *                              *---------------------------------*
           add       rf-mmr-val-mov       to   w-exe-srt-inp-w02      .
           divide    w-exe-srt-inp-gia    into w-exe-srt-inp-w02
                                        giving w-exe-srt-inp-cmc
                                               rounded                .
      *                              *---------------------------------*
      *                              * Applicazione decimali gestione  *
      *                              * magazzino                       *
      *                              *---------------------------------*
           multiply  100                  by   w-exe-srt-inp-cmc      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     exe-srt-inp-250.
       exe-srt-inp-244.
      *                          *-------------------------------------*
      *                          * Se giacenza precedentemente salvata *
      *                          * negativa                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento progressivi quan- *
      *                              * tita' e valore giacenza signi-  *
      *                              * ficativi                        *
      *                              *---------------------------------*
           add       rf-mmr-qta-mov       to   w-exe-srt-inp-qgs      .
           add       rf-mmr-val-mov       to   w-exe-srt-inp-vgs      .
      *                              *---------------------------------*
      *                              * Calcolo                         *
      *                              *---------------------------------*
           divide    w-exe-srt-inp-qgs    into w-exe-srt-inp-vgs
                                        giving w-exe-srt-inp-cmc
                                               rounded                .
      *                              *---------------------------------*
      *                              * Applicazione decimali gestione  *
      *                              * magazzino                       *
      *                              *---------------------------------*
           multiply  100                  by   w-exe-srt-inp-cmc      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     exe-srt-inp-250.
       exe-srt-inp-250.
      *                      *-----------------------------------------*
      *                      * Aggiornamento data ultimo rilevamento   *
      *                      *-----------------------------------------*
           move      rf-mmr-dat-reg       to   w-exe-srt-inp-dur      .
       exe-srt-inp-260.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione file [mmr]                 *
      *              *-------------------------------------------------*
           go to     exe-srt-inp-220.
       exe-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione record di Sort                     *
      *              *-------------------------------------------------*
           move      01                   to   srt-tip-mag            .
           move      rf-dcp-num-pro       to   srt-num-mag            .
           move      w-exe-srt-inp-dur    to   srt-dat-ulr            .
           move      w-exe-srt-inp-gia    to   srt-qta-gia            .
           move      w-exe-srt-inp-cmc    to   srt-val-cmc            .
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale file [dcp]       *
      *              *-------------------------------------------------*
           go to     exe-srt-inp-100.
       exe-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione output procedure per sort                      *
      *    *-----------------------------------------------------------*
       exe-srt-out-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-exe-srt-out-flg      .
       exe-srt-out-050.
      *              *-------------------------------------------------*
      *              * Test su flag di uscita da input procedure       *
      *              *-------------------------------------------------*
           if        w-exe-srt-inp-flg    =    spaces
                     go to exe-srt-out-100.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
