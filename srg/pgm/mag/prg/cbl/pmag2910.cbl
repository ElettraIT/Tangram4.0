           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
           move      "RD"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
           move      "CL"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/induccmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-duc-cmc             .
       pre-exe-pgm-100.
      *              *-------------------------------------------------*
      *              * Determinazione default data consolidamento pari *
      *              * alla fine del secondo mese precedente a partire *
      *              * da oggi                                         *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           subtract  1                    from s-mes                  .
           if        s-mes                =    zero
                     move  12             to   s-mes
                     subtract 1           from s-saa                  .
           subtract  1                    from s-mes                  .
           if        s-mes                =    zero
                     move  12             to   s-mes
                     subtract 1           from s-saa                  .
           move      31                   to   s-gio                  .
       pre-exe-pgm-110.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to pre-exe-pgm-110.
           move      s-dat                to   w-def-dat-con          .
      *              *-------------------------------------------------*
