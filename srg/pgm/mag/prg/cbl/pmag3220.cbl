       vis-snx-srf-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-srf-lun    to   v-car                  .
           move      w-exp-snx-srf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-snx-srf-tbl    to   v-txt                  .
           move      rr-snx-srf           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-srf-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Test su data minima movimenti da stampare       *
      *              *-------------------------------------------------*
           if        rr-dat-min           not  = zero
                     go to tdo-ric-sel-150.
           move      "Manca la data iniziale dei movimenti da stampare !
      -              "          "         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-150.
      *              *-------------------------------------------------*
      *              * Test su data massima movimenti da stampare      *
      *              *-------------------------------------------------*
           if        rr-dat-max           not  = zero
                     go to tdo-ric-sel-200.
           move      "Manca la data finale dei movimenti da stampare !  
      -              "          "         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Test su data minima/massima movimenti da stam-  *
      *              * pare                                            *
      *              *-------------------------------------------------*
           if        rr-dat-max           not  < rr-dat-min
                     go to tdo-ric-sel-250.
           move      "La data finale non puo' essere inferiore di quella
      -              " iniziale!"         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-250.
      *              *-------------------------------------------------*
      *              * Test su Si/No solo se esiste almeno un movimen- *
      *              * to nel periodo selezionato                      *
      *              *-------------------------------------------------*
           if        rr-snx-aum           not  = zero
                     go to tdo-ric-sel-255.
           move      "Manca la selezione su 'Almeno un movimento' !     
      -              "          "         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-255.
           if        rr-snx-aum           =    01 or
                     rr-snx-aum           =    02
                     go to tdo-ric-sel-300.
           move      "Selezione su 'Almeno un movimento' errata !       
      -              "          "         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Test su Si/No solo se esiste almeno un movimen- *
      *              * to nel periodo selezionato                      *
      *              *-------------------------------------------------*
           if        rr-snx-srf           not  = zero
                     go to tdo-ric-sel-305.
           move      "Manca la scelta di 'Stampa riepilogo finale' !    
      -              "          "         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-305.
           if        rr-snx-srf           =    01 or
                     rr-snx-srf           =    02
                     go to tdo-ric-sel-350.
           move      "Scelta di 'Stampa riepilogo finale' errata !      
      -              "          "         to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-350.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio d'errore                *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       tdo-ric-sel-950.
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

