      *              *-------------------------------------------------*
       acc-dat-max-425.
      *                  *---------------------------------------------*
      *                  * Valore zero non ammesso, a meno che non si  *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        rr-dat-max           not  = zero
                     go to acc-dat-max-450.
           if        v-key                =    "UP  "
                     go to acc-dat-max-600
           else      go to acc-dat-max-100.
       acc-dat-max-450.
      *                  *---------------------------------------------*
      *                  * Valore massimo minore del valore minimo non *
      *                  * ammesso                                     *
      *                  *---------------------------------------------*
           if        rr-dat-max           <    rr-dat-min
                     go to acc-dat-max-100.
       acc-dat-max-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-max-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-max-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-max-100.
       acc-dat-max-999.
           exit.

