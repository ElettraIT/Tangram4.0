      *    *                per ogni elemento                          *
      *    *-----------------------------------------------------------*
       acc-snx-srf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-snx-srf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-srf-lun    to   v-car                  .
           move      w-exp-snx-srf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-snx-srf-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
