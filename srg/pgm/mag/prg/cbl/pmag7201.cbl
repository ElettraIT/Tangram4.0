           move      "CL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Filtro per selezione ed ordinamento [dcp]       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Close                                       *
      *                  *---------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Cancel                                      *
      *                  *---------------------------------------------*
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       prn-cls-fls-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore records letti dal    *
      *              * filtro di ordinamento e selezione               *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-srt-inp-ctr      .
      *              *-------------------------------------------------*
      *              * Start filtro di ordinamento e selezione         *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      rr-fso-dcp           to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se errore su Start : ad uscita                  *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read Next filtro di ordinamento e selezione     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se At End : ad uscita                           *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Incremento contatore records letti da filtro di *
      *              * ordinamento e selezione                         *
      *              *-------------------------------------------------*
           add       1                    to   w-stp-srt-inp-ctr      .
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo giacenza di proprieta'     *
      *              * alla data, relativo al codice di magazzino      *
      *              *-------------------------------------------------*
       stp-srt-inp-210.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo                        *
      *                  *---------------------------------------------*
           move      "SL"                 to   d-sld-mag-tip-ope      .
           move      0100                 to   d-sld-mag-tip-sld      .
           move      rr-dat-sit           to   d-sld-mag-dat-sld      .
           move      "T"                  to   d-sld-mag-uot-dpz      .
           move      zero                 to   d-sld-mag-cod-dpz      .
           move      01                   to   d-sld-mag-tip-mag      .
           move      rf-dcp-num-pro       to   d-sld-mag-num-mag      .
           move      "T"                  to   d-sld-mag-uot-var      .
           move      spaces               to   d-sld-mag-var-mag      .
           perform   det-sld-mag-cll-000  thru det-sld-mag-cll-999    .
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Se errore di esecuzione nella determinazio- *
      *                  * ne del saldo si ignora il record            *
      *                  *---------------------------------------------*
           if        d-sld-mag-exi-sts    =    spaces
                     go to stp-srt-inp-230.
           go to     stp-srt-inp-800.
       stp-srt-inp-230.
      *                  *---------------------------------------------*
      *                  * Se saldo uguale a zero si procede solamente *
      *                  * se e' stata fatta esplicita richiesta, al-  *
      *                  * trimenti si ignora il record                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione delle richieste  *
      *                      *-----------------------------------------*
           if        rr-snx-zer           =    01
                     go to stp-srt-inp-232
           else if   rr-snx-zer           =    02
                     go to stp-srt-inp-234
           else      go to stp-srt-inp-240.
       stp-srt-inp-232.
      *                      *-----------------------------------------*
      *                      * Solo giacenze positive                  *
      *                      *-----------------------------------------*
           if        d-sld-mag-sld-mag    >    zero
                     go to stp-srt-inp-240
           else      go to stp-srt-inp-800.
       stp-srt-inp-234.
      *                      *-----------------------------------------*
      *                      * Solo giacenze negative                  *
      *                      *-----------------------------------------*
           if        d-sld-mag-sld-mag    <    zero
                     go to stp-srt-inp-240
           else      go to stp-srt-inp-800.
       stp-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Determinazione del costo L.i.f.o. alla data,    *
      *              * relativo al codice di magazzino                 *
      *              *-------------------------------------------------*
       stp-srt-inp-310.
      *                  *---------------------------------------------*
      *                  * Determinazione costo L.i.f.o.               *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0004                 to   d-vun-mag-tip-val      .
           move      rr-dat-sit           to   d-vun-mag-dat-val      .
           move      01                   to   d-vun-mag-tip-mag      .
           move      rf-dcp-num-pro       to   d-vun-mag-num-mag      .
           move      d-sld-mag-sld-mag    to   d-vun-mag-gia-prp      .
           perform   det-vun-mag-cll-000  thru det-vun-mag-cll-999    .
       stp-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se errore di esecuzione nella determinazio- *
      *                  * ne si ignora il record                      *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    not  = "#"
                     go to stp-srt-inp-330.
           go to     stp-srt-inp-800.
       stp-srt-inp-330.
      *                  *---------------------------------------------*
      *                  * Se determinazione non eseguibile per rima-  *
      *                  * nenze finali negative si ignora il record   *
      *                  *---------------------------------------------*
       stp-srt-inp-340.
      *                  *---------------------------------------------*
      *                  * Se determinazione eseguita ma rimanenza fi- *
      *                  * nale a zero si procede solamente se e' sta- *
      *                  * ta fatta esplicita richiesta, altrimenti si *
      *                  * ignora il record                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione delle richieste  *
      *                      *-----------------------------------------*
           if        rr-snx-zer           =    01
                     go to stp-srt-inp-342
           else if   rr-snx-zer           =    02
                     go to stp-srt-inp-344
           else      go to stp-srt-inp-350.
       stp-srt-inp-342.
      *                      *-----------------------------------------*
      *                      * Solo giacenze positive                  *
      *                      *-----------------------------------------*
           if        d-vun-mag-exi-sts    not  = "N" and
                     d-vun-mag-exi-sts    not  = "Z"
                     go to stp-srt-inp-350
           else      go to stp-srt-inp-800.
       stp-srt-inp-344.
      *                      *-----------------------------------------*
      *                      * Solo giacenze negative                  *
      *                      *-----------------------------------------*
           if        d-vun-mag-exi-sts    =    "N"   and
                     d-vun-mag-exi-sts    not  = "Z"
                     go to stp-srt-inp-350
           else      go to stp-srt-inp-800.
       stp-srt-inp-350.
      *                  *---------------------------------------------*
      *                  * Se altro errore di esecuzione si ignora il  *
      *                  * record                                      *
      *                  *---------------------------------------------*
           if        d-vun-mag-exi-sts    =    spaces or
                     d-vun-mag-exi-sts    =    "#"    or
                     d-vun-mag-exi-sts    =    "N"    or
                     d-vun-mag-exi-sts    =    "Z"
                     go to stp-srt-inp-360.
           go to     stp-srt-inp-800.
       stp-srt-inp-360.
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Composizione record [srt] dalle aree            *
      *              * - [dcp]                                         *
      *              * - d-sld-mag                                     *
      *              * - d-vun-mag                                     *
      *              *-------------------------------------------------*
           perform   cmp-srt-rec-000      thru cmp-srt-rec-999        .
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale filtro di ordi-  *
      *              * namento e selezione                             *
      *              *-------------------------------------------------*
            go to    stp-srt-inp-100.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Composizione record [srt] prelevando dalle seguenti aree  *
      *    *                                                           *
      *    *   - [dcp]                                                 *
      *    *   - d-sld-mag                                             *
      *    *   - d-vun-mag                                             *
      *    *-----------------------------------------------------------*
       cmp-srt-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare totale del record   *
      *              *-------------------------------------------------*
           move      spaces               to   srt-rec                .
       cmp-srt-rec-100.
      *              *-------------------------------------------------*
      *              * Area chiave di ordinamento                      *
      *              *-------------------------------------------------*
       cmp-srt-rec-200.
      *                  *---------------------------------------------*
      *                  * Subchiave 1 : Per filtro di selezione pro-  *
      *                  * dotti                                       *
      *                  *---------------------------------------------*
       cmp-srt-rec-210.
      *                      *-----------------------------------------*
      *                      * Numero progressivo record letto da fil- *
      *                      * tro di selezione                        *
      *                      *-----------------------------------------*
           move      w-stp-srt-inp-ctr    to   srt-k01-ctr-ldf        .
       cmp-srt-rec-500.
      *              *-------------------------------------------------*
      *              * Area dati                                       *
      *              *-------------------------------------------------*
       cmp-srt-rec-600.
      *                  *---------------------------------------------*
      *                  * Codice di magazzino                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice numerico                         *
      *                      *-----------------------------------------*
           move      rf-dcp-num-pro       to   srt-cod-mag-num        .
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico                     *
      *                      *-----------------------------------------*
           move      rf-dcp-alf-pro       to   srt-cod-mag-alf        .
      *                      *-----------------------------------------*
      *                      * Descrizione                             *
      *                      *-----------------------------------------*
           move      rf-dcp-des-pro       to   srt-cod-mag-des        .
      *                      *-----------------------------------------*
      *                      * Unita' di misura                        *
      *                      *-----------------------------------------*
           move      rf-dcp-umi-ven       to   srt-cod-mag-umi        .
      *                      *-----------------------------------------*
      *                      * Numero decimali quantita'               *
      *                      *-----------------------------------------*
           move      rf-dcp-dec-qta       to   srt-cod-mag-dec       .
      *                      *-----------------------------------------*
      *                      * Classe merceologica                     *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   srt-cod-mag-cla       .
      *                      *-----------------------------------------*
      *                      * Gruppo merceologico                     *
      *                      *-----------------------------------------*
           move      rf-dcp-gru-pro       to   srt-cod-mag-gru        .
      *                      *-----------------------------------------*
      *                      * Sottogruppo merceologico                *
      *                      *-----------------------------------------*
           move      rf-dcp-sgr-pro       to   srt-cod-mag-sgr        .
       cmp-srt-rec-700.
      *                  *---------------------------------------------*
      *                  * Valori L.i.f.o.                             *
      *                  *---------------------------------------------*
       cmp-srt-rec-710.
      *                      *-----------------------------------------*
      *                      * Flag di uscita dalla determinazione     *
      *                      * L.i.f.o.                                *
      *                      *-----------------------------------------*
           move      d-vun-mag-exi-sts    to   srt-val-lif-flg        .
      *                      *-----------------------------------------*
      *                      * Rimanenza finale                        *
      *                      *-----------------------------------------*
           move      d-vun-mag-gia-prp    to   srt-val-lif-rim        .
      *                      *-----------------------------------------*
      *                      * Valore della rimanenza finale           *
      *                      *-----------------------------------------*
           move      d-vun-mag-lif-val    to   srt-val-lif-val        .
      *                      *-----------------------------------------*
      *                      * Numero di scaglioni che concorrono a    *
      *                      * formare il valore della rimanenza fi-   *
      *                      * nale                                    *
      *                      *-----------------------------------------*
           move      d-vun-mag-lif-nsc    to   srt-val-lif-nsc        .
       cmp-srt-rec-720.
      *                      *-----------------------------------------*
      *                      * Scaglioni L.i.f.o.                      *
      *                      *-----------------------------------------*
       cmp-srt-rec-722.
      *                          *-------------------------------------*
      *                          * Inizializzazione indice 01..11      *
      *                          *-------------------------------------*
           move      zero                 to   w-stp-srt-inx-i0i      .
       cmp-srt-rec-724.
      *                          *-------------------------------------*
      *                          * Incremento indice 01..11            *
      *                          *-------------------------------------*
           add       1                    to   w-stp-srt-inx-i0i      .
      *                          *-------------------------------------*
      *                          * Test se oltre il max                *
      *                          *-------------------------------------*
           if        w-stp-srt-inx-i0i    >    11
                     go to cmp-srt-rec-730.
       cmp-srt-rec-726.
      *                          *-------------------------------------*
      *                          * Quantita'                           *
      *                          *-------------------------------------*
           move      d-vun-mag-lif-qta
                    (w-stp-srt-inx-i0i)   to   srt-val-lif-qta
                                              (w-stp-srt-inx-i0i)     .
      *                          *-------------------------------------*
      *                          * Valore unitario                     *
      *                          *-------------------------------------*
           move      d-vun-mag-lif-vun
                    (w-stp-srt-inx-i0i)   to   srt-val-lif-vun
                                              (w-stp-srt-inx-i0i)     .
      *                          *-------------------------------------*
      *                          * Tipo di valore unitario             *
      *                          *-------------------------------------*
           move      d-vun-mag-lif-tvu
                    (w-stp-srt-inx-i0i)   to   srt-val-lif-tvu
                                              (w-stp-srt-inx-i0i)     .
      *                          *-------------------------------------*
      *                          * Anno, di quattro cifre              *
      *                          *-------------------------------------*
           move      d-vun-mag-lif-ann
                    (w-stp-srt-inx-i0i)   to   srt-val-lif-ann
                                              (w-stp-srt-inx-i0i)     .
      *                          *-------------------------------------*
      *                          * Flag di rivalutazione               *
      *                          *-------------------------------------*
           move      d-vun-mag-lif-riv
                    (w-stp-srt-inx-i0i)   to   srt-val-lif-riv
                                              (w-stp-srt-inx-i0i)     .
       cmp-srt-rec-728.
      *                          *-------------------------------------*
      *                          * Riciclo su elemento successivo      *
      *                          *-------------------------------------*
           go to     cmp-srt-rec-724.
       cmp-srt-rec-730.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     cmp-srt-rec-900.
       cmp-srt-rec-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cmp-srt-rec-999.
       cmp-srt-rec-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessun prodotto da valorizzare !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
           return    srt    at end
                            move  "#"     to   w-cnt-prn-flg-sub
                            go to prn-let-seq-999.
       prn-let-seq-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Test se superamento limiti massimi *
      *    *-----------------------------------------------------------*
       prn-tst-max-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-tst-max-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Composizione area per rotture      *
      *    *-----------------------------------------------------------*
       prn-cmp-rot-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo ordinamento     *
      *              *-------------------------------------------------*
           if        w-tip-ord-tip-ord    =    01 or
                     w-tip-ord-tip-ord    =    02
                     go to prn-cmp-rot-300
           else if   w-tip-ord-tip-ord    =    03 or
                     w-tip-ord-tip-ord    =    04
                     go to prn-cmp-rot-600.
       prn-cmp-rot-300.
      *              *-------------------------------------------------*
      *              * Se tipo ordinamento :                           *
      *              * - Per classe, gruppo, sottogruppo, codice       *
      *              * - Per classe, gruppo, sottogruppo, descrizione  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura classe        *
      *                  *---------------------------------------------*
           move      srt-cod-mag-cla      to   w-rot-l04-cod-cla      .
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura gruppo        *
      *                  *---------------------------------------------*
           move      srt-cod-mag-gru      to   w-rot-l03-cod-gru      .
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura sottogruppo   *
      *                  *---------------------------------------------*
           move      srt-cod-mag-sgr      to   w-rot-l02-cod-sgr      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     prn-cmp-rot-800.
       prn-cmp-rot-600.
      *              *-------------------------------------------------*
      *              * Se tipo ordinamento :                           *
      *              * - Per codice                                    *
      *              * - Per descrizione                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura classe         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l04-cod-cla      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura gruppo         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l03-cod-gru      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura sottogruppo    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l02-cod-sgr      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     prn-cmp-rot-800.
       prn-cmp-rot-800.
      *              *-------------------------------------------------*
      *              * Codice numerico di magazzino                    *
      *              *-------------------------------------------------*
           move      srt-cod-mag-num      to   w-rot-l01-num-mag      .
       prn-cmp-rot-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per inizio ciclo        *
      *    *-----------------------------------------------------------*
       prn-ini-cic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-ini-cic-050.
      *              *-------------------------------------------------*
      *              * Inizializzazione work area per riepilogo        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione anno di esercizio rispetto   *
      *                  * alla data situazione richiesta              *
      *                  *---------------------------------------------*
           move      rr-dat-sit           to   s-dat                  .
           move      s-saa                to   w-rie-ese-ann-att      .
           add       1900                 to   w-rie-ese-ann-att      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione work area                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-rie-ese-rim-tot      .
           move      zero                 to   w-rie-ese-ctr-001      .
       prn-ini-cic-060.
           add       1                    to   w-rie-ese-ctr-001      .
           if        w-rie-ese-ctr-001    >    11
                     go to prn-ini-cic-100.
           move      w-rie-ese-ann-att    to   w-rie-ese-ann-ese
                                              (w-rie-ese-ctr-001)     .
