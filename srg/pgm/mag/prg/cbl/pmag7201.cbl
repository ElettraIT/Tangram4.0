           move      "V"                  to   p-tip                  .
           move      12                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "G"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      076                  to   p-pos                  .
           move      w-stp-sta-tot-vlr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
