      *                  *---------------------------------------------*
           move      w-det-dat-ife-epm    to   s-saa                  .
           move      w-prs-mes-chi        to   s-mes                  .
           move      31                   to   s-gio                  .
       det-dat-ife-120.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to det-dat-ife-120.
      *                  *---------------------------------------------*
      *                  * Data di fine esercizio in uscita            *
      *                  *---------------------------------------------*
           move      s-dat                to   w-det-dat-ife-dfe      .
      *                  *---------------------------------------------*
      *                  * Se l'esercizio relativo alla data attuale   *
      *                  * e' superiore a quello del primo movimento   *
      *                  * di magazzino : si forza a 'F' il flag di    *
      *                  * uscita                                      *
      *                  *---------------------------------------------*
           if        w-det-dat-ife-eda    >     w-det-dat-ife-epm
                     move  "F"            to    w-det-dat-ife-flg     .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-ife-900.
       det-dat-ife-140.
      *                  *---------------------------------------------*
      *                  * Se nessun movimento di magazzino trovato    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-dat-ife-900.
       det-dat-ife-200.
      *              *-------------------------------------------------*
      *              * Determinazione esercizio precedente relativo    *
      *              * alla data attuale                               *
      *              *-------------------------------------------------*
           subtract  1                    from w-det-dat-ife-eda
                                        giving s-saa                  .
      *              *-------------------------------------------------*
      *              * Se diverso da quello dell'ultimo inventario di  *
      *              * fine esercizio eseguito                         *
      *              *-------------------------------------------------*
           if        s-saa                =    rn-dat-ife-ese-ife
                     go to det-dat-ife-300.
      *                  *---------------------------------------------*
      *                  * Determinazione data di fine esercizio per   *
      *                  * l'esercizio successivo a quello dell'ultimo *
      *                  * inventario di fine esercizio eseguito       *
      *                  *---------------------------------------------*
           move      rn-dat-ife-ese-ife   to   s-saa                  .
           add       1                    to   s-saa                  .
           move      w-prs-mes-chi        to   s-mes                  .
           move      31                   to   s-gio                  .
       det-dat-ife-220.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to det-dat-ife-220.
      *                  *---------------------------------------------*
      *                  * Data di fine esercizio in uscita            *
      *                  *---------------------------------------------*
           move      s-dat                to   w-det-dat-ife-dfe      .
      *                  *---------------------------------------------*
      *                  * Flag di uscita a 'F'                        *
      *                  *---------------------------------------------*
           move      "F"                  to   w-det-dat-ife-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-ife-900.
       det-dat-ife-300.
      *              *-------------------------------------------------*
      *              * Determinazione data data di fine esercizio re-  *
      *              * lativa alla data attuale                        *
      *              *-------------------------------------------------*
           move      w-det-dat-ife-eda    to   s-saa                  .
           move      w-prs-mes-chi        to   s-mes                  .
           move      31                   to   s-gio                  .
       det-dat-ife-320.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to det-dat-ife-320.
           move      s-dat                to   w-det-dat-ife-dfe      .
      *              *-------------------------------------------------*
      *              * Determinazione data attuale + 4 mesi            *
      *              *-------------------------------------------------*
           move      w-det-dat-ife-att    to   s-dat                  .
           add       04                   to   s-mes                  .
           if        s-mes                >    12
                     subtract 12          from s-mes
                     add      1           to   s-saa                  .
      *              *-------------------------------------------------*
      *              * Se la data risultante e' inferiore alla data di *
      *              * fine esercizio relativa alla data attuale       *
      *              *-------------------------------------------------*
           if        s-dat                >    w-det-dat-ife-dfe
                     move  "I"            to   w-det-dat-ife-flg
                     go to det-dat-ife-900.
      *                  *---------------------------------------------*
      *                  * La data di fine esercizio fin qui determi-  *
      *                  * nata va' diminuita di un anno, purche' non  *
      *                  * sia gia' stato eseguito l'inventario di     *
      *                  * quell'anno                                  *
      *                  *---------------------------------------------*
           move      w-det-dat-ife-dfe    to   s-dat                  .
           subtract  1                    from s-saa                  .
           if        s-saa                not  = rn-dat-ife-ese-ife
                     move  s-dat          to   w-det-dat-ife-dfe
                     go to det-dat-ife-900.
      *                  *---------------------------------------------*
      *                  * Altrimenti si esce con forzatura ad inven-  *
      *                  * tario infrannuale                           *
      *                  *---------------------------------------------*
           move      "I"                  to   w-det-dat-ife-flg      .
       det-dat-ife-900.
      *              *-------------------------------------------------*
      *              * Close file [mmt]                                *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmt                 .
      *              *-------------------------------------------------*
      *              * Close numerazione [datife]                      *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/indatife"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-ife             .
       det-dat-ife-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-ese-cge-dtr        to   s-dat                  .
           if        w-ese-cge-mce        =    12         or
                     s-mes                >    w-ese-cge-mce
                     move  s-saa          to   w-ese-cge-esa
                     go to det-ese-cge-500.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-ese-cge-esa          .
       det-ese-cge-500.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-ese-cge-esm          .
           if        w-ese-cge-mce        =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-ese-cge-mce
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-ese-cge-mce
                     add   12             to   w-ese-cge-esm
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-ese-cge-esm          .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
