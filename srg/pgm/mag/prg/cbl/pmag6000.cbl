      *              *-------------------------------------------------*
           move      zero                 to   w-det-sld-mdt-sld      .
       det-sld-mdt-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione file [mmz] per individuare   *
      *              * tutti i records utili e scrittura del relativo  *
      *              * record [mim] con quantita' presunta a zero      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [mmz]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGARC    "         to   f-key                  .
           move      w-det-sld-mdt-esa    to   rf-mmz-ann-ese         .
           move      w-det-sld-mdt-dpz    to   rf-mmz-cod-dpz         .
           move      w-det-sld-mdt-tpm    to   rf-mmz-tip-mag         .
           move      w-det-sld-mdt-nrm    to   rf-mmz-num-mag         .
           move      spaces               to   rf-mmz-var-mag         .
           move      "T"                  to   rf-mmz-tip-ctm         .
           move      spaces               to   rf-mmz-cod-ctm         .
           move      spaces               to   rf-mmz-tip-arc         .
           move      zero                 to   rf-mmz-cod-arc         .
           move      spaces               to   rf-mmz-dpz-arc         .
           move      "pgm/mag/fls/ioc/obj/iofmmz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmz                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sld-mdt-500.
       det-sld-mdt-120.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mmz]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmz                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sld-mdt-500.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-mmz-ann-ese       not  = w-det-sld-mdt-esa or
                     rf-mmz-cod-dpz       not  = w-det-sld-mdt-dpz or
                     rf-mmz-tip-mag       not  = w-det-sld-mdt-tpm or
                     rf-mmz-num-mag       not  = w-det-sld-mdt-nrm or
                     rf-mmz-var-mag       not  = spaces            or
                     rf-mmz-tip-ctm       not  = "T"
                     go to det-sld-mdt-500.
      *                  *---------------------------------------------*
      *                  * Scrittura record [mim]                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [mim]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmim"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mim                 .
      *                      *-----------------------------------------*
      *                      * Composizione record [mim]               *
      *                      *-----------------------------------------*
           move      w-det-sld-mdt-dpz    to   rf-mim-cod-dpz         .
           move      w-det-sld-mdt-tpm    to   rf-mim-tip-mag         .
           move      w-det-sld-mdt-nrm    to   rf-mim-num-mag         .
           move      spaces               to   rf-mim-var-mag         .
           move      w-det-sld-mdt-afm    to   rf-mim-alf-mag         .
           move      w-det-sld-mdt-des    to   rf-mim-des-mag         .
           move      w-det-sld-mdt-umi    to   rf-mim-umi-mag         .
           move      w-det-sld-mdt-deq    to   rf-mim-dec-qta         .
           move      spaces               to   rf-mim-tip-ubi         .
           move      spaces               to   rf-mim-prm-ubi (1)     .
           move      spaces               to   rf-mim-prm-ubi (2)     .
           move      spaces               to   rf-mim-prm-ubi (3)     .
           move      spaces               to   rf-mim-prm-ubi (4)     .
           move      02                   to   rf-mim-tip-gia         .
           move      rf-mmz-cod-ctm       to   rf-mim-cod-mic         .
           move      rf-mmz-tip-arc       to   rf-mim-tip-arc         .
           move      rf-mmz-cod-arc       to   rf-mim-cod-arc         .
           move      rf-mmz-dpz-arc       to   rf-mim-dpz-arc         .
           move      zero                 to   rf-mim-qta-prs         .
           move      spaces               to   rf-mim-flg-ril         .
           move      zero                 to   rf-mim-qta-rlv         .
      *                      *-----------------------------------------*
      *                      * Scrittura record [mim]                  *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmim"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mim                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura sequenziale record   *
      *                      * [mmz]                                   *
      *                      *-----------------------------------------*
           go to     det-sld-mdt-120.
       det-sld-mdt-500.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione file [mim] sui records appe- *
      *              * na scritti per determinarne la giacenza ed ag-  *
      *              * giornare il record stesso                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [mim]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGTGC    "         to   f-key                  .
           move      w-det-sld-mdt-dpz    to   rf-mim-cod-dpz         .
           move      w-det-sld-mdt-tpm    to   rf-mim-tip-mag         .
           move      w-det-sld-mdt-nrm    to   rf-mim-num-mag         .
           move      spaces               to   rf-mim-var-mag         .
           move      02                   to   rf-mim-tip-gia         .
           move      spaces               to   rf-mim-tip-arc         .
           move      zero                 to   rf-mim-cod-arc         .
           move      spaces               to   rf-mim-dpz-arc         .
           move      spaces               to   rf-mim-cod-mic         .
           move      "pgm/mag/fls/ioc/obj/iofmim"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mim                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sld-mdt-999.
       det-sld-mdt-520.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mim]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmim"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mim                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sld-mdt-999.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-mim-cod-dpz       not  = w-det-sld-mdt-dpz or
                     rf-mim-tip-mag       not  = w-det-sld-mdt-tpm or
                     rf-mim-num-mag       not  = w-det-sld-mdt-nrm or
                     rf-mim-var-mag       not  = spaces            or
                     rf-mim-tip-gia       not  = 02
                     go to det-sld-mdt-999.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo di magazzino           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione link-area                  *
      *                      *-----------------------------------------*
           move      "SL"                 to   d-sld-mag-tip-ope      .
           move      0300                 to   d-sld-mag-tip-sld      .
           move      w-det-sld-mdt-ddr    to   d-sld-mag-dat-sld      .
           move      "U"                  to   d-sld-mag-uot-dpz      .
           move      w-det-sld-mdt-dpz    to   d-sld-mag-cod-dpz      .
           move      w-det-sld-mdt-tpm    to   d-sld-mag-tip-mag      .
           move      w-det-sld-mdt-nrm    to   d-sld-mag-num-mag      .
           move      "T"                  to   d-sld-mag-uot-var      .
           move      spaces               to   d-sld-mag-var-mag      .
           move      "U"                  to   d-sld-mag-uot-ctm      .
           move      rf-mim-cod-mic       to   d-sld-mag-cod-ctm      .
           move      rf-mim-tip-arc       to   d-sld-mag-tip-arc      .
           move      "U"                  to   d-sld-mag-uot-arc      .
           move      rf-mim-cod-arc       to   d-sld-mag-cod-arc      .
           move      "U"                  to   d-sld-mag-uot-dpa      .
           move      rf-mim-dpz-arc       to   d-sld-mag-dpz-arc      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           perform   det-sld-mag-cll-000  thru det-sld-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [mim]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        d-sld-mag-sld-mag    =    zero
                     go to det-sld-mdt-580.
      *                      *-----------------------------------------*
      *                      * Aggiornamento quantita' presunta        *
      *                      *-----------------------------------------*
           move      d-sld-mag-sld-mag    to   rf-mim-qta-prs         .
      *                      *-----------------------------------------*
      *                      * Riscrittura record [mim]                *
      *                      *-----------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmim"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mim                 .
       det-sld-mdt-580.
      *                  *---------------------------------------------*
      *                  * Aggiornamento merce di terzi totale         *
      *                  *---------------------------------------------*
           add       d-sld-mag-sld-mag    to   w-det-sld-mdt-sld      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [mim] *
      *                  *---------------------------------------------*
           go to     det-sld-mdt-520.
       det-sld-mdt-999.
           exit.

