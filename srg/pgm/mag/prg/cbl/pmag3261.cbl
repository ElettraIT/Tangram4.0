           if        w-ssm-mtv-mov-tmc    =    01
                     go to ssm-mtv-stp-act-475
           else if   w-ssm-mtv-mov-tmc    =    02
                     go to ssm-mtv-stp-act-500
           else if   w-ssm-mtv-mov-tmc    =    03
                     go to ssm-mtv-stp-act-525.
       ssm-mtv-stp-act-475.
      *                  *---------------------------------------------*
      *                  * Se tipo di trattamento merce in conto : 01, *
      *                  * cioe' il movimento puo' riferirsi ad un al- *
      *                  * tro movimento di merce in conto             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se e' citato un codice di merce in con- *
      *                      * to si esegue l'aggiornamento correttivi *
      *                      * di proprieta', altrimenti no            *
      *                      *-----------------------------------------*
           if        w-ssm-mtv-mov-cmc    not  = spaces
                     go to ssm-mtv-stp-act-600
           else      go to ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-500.
      *                  *---------------------------------------------*
      *                  * Se tipo di trattamento merce in conto : 02, *
      *                  * cioe' il movimento non puo' riferirsi a     *
      *                  * merce in conto                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non si esegue alcun aggiornamento       *
      *                      *-----------------------------------------*
           go to     ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-525.
      *                  *---------------------------------------------*
      *                  * Se tipo di trattamento merce in conto : 03, *
      *                  * cioe' il movimento stesso e' una movimenta- *
      *                  * zione di merce in conto                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si esegue l'aggiornamento               *
      *                      *-----------------------------------------*
           go to     ssm-mtv-stp-act-600.
       ssm-mtv-stp-act-600.
      *                  *---------------------------------------------*
      *                  * Aggiornamento correttivi di proprieta'      *
      *                  *---------------------------------------------*
       ssm-mtv-stp-act-650.
      *                      *-----------------------------------------*
      *                      * Se il tipo conto merce non e' tra quel- *
      *                      * li previsti : no aggiornamento          *
      *                      *-----------------------------------------*
           if        w-ssm-mtv-mov-xmc    not  = "N" and
                     w-ssm-mtv-mov-xmc    not  = "T"
                     go to ssm-mtv-stp-act-900.
      *                      *-----------------------------------------*
      *                      * Se manca il codice conto merce : no ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        w-ssm-mtv-mov-cmc    =    spaces
                     go to ssm-mtv-stp-act-900.
      *                      *-----------------------------------------*
      *                      * Se il tipo archivio non e' tra quelli   *
      *                      * previsti : no aggiornamento             *
      *                      *-----------------------------------------*
           if        w-ssm-mtv-mov-ati    not  = "C" and
                     w-ssm-mtv-mov-ati    not  = "F"
                     go to ssm-mtv-stp-act-900.
      *                      *-----------------------------------------*
      *                      * Se il codice archivio e' a zero : no    *
      *                      * aggiornamento                           *
      *                      *-----------------------------------------*
           if        w-ssm-mtv-mov-aco    =    zero
                     go to ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-700.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo movimento *
      *                      *-----------------------------------------*
           if        w-ssm-mtv-mov-tmo    =    01
                     go to ssm-mtv-stp-act-750
           else if   w-ssm-mtv-mov-tmo    =    02
                     go to ssm-mtv-stp-act-800
           else      go to ssm-mtv-stp-act-850.
       ssm-mtv-stp-act-750.
