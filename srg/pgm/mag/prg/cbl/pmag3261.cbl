      *                  * Normalizzazione iniziale del flag a : No    *
      *                  *---------------------------------------------*
           move      spaces               to   w-ssm-mtv-aum-sel      .
       ssm-mtv-sel-150.
      *                  *---------------------------------------------*
      *                  * Start su archivio movimenti di magazzino,   *
      *                  * file [mmr], sull'elemento in esame, rela-   *
      *                  * tivamente alla data minima, per la dipen-   *
      *                  * denza interessata                           *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZMAG    "         to   f-key                  .
           move      w-ssm-mtv-cod-dpz    to   rf-mmr-cod-dpz         .
           move      w-ssm-mtv-tip-mag    to   rf-mmr-tip-mag         .
           move      w-ssm-mtv-num-mag    to   rf-mmr-num-mag         .
           move      w-ssm-mtv-dat-min    to   rf-mmr-dat-reg         .
           move      zero                 to   rf-mmr-num-prt         .
           move      zero                 to   rf-mmr-num-prg         .
           move      "pgm/mag/fls/ioc/obj/iofmmr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmr                 .
      *                  *---------------------------------------------*
