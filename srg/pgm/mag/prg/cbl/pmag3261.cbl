      *                      * Se tipo di movimento 01 : Carico        *
      *                      *-----------------------------------------*
       ssm-mtv-stp-act-755.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo conto *
      *                          * merce                               *
      *                          *-------------------------------------*
           if        w-ssm-mtv-mov-xmc    =    "N"
                     go to ssm-mtv-stp-act-760
           else      go to ssm-mtv-stp-act-765.
       ssm-mtv-stp-act-760.
      *                          *-------------------------------------*
      *                          * Se merce Presso terzi               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Presso terzi'          *
      *                              *---------------------------------*
           if        w-ssm-mtv-mov-tmc    =    01
                     add      w-ssm-mtv-mov-qdm
                                          to   w-ssm-mtv-tpc-pfn
           else      subtract w-ssm-mtv-mov-qdm
                                          from w-ssm-mtv-tpc-pfn      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-765.
      *                          *-------------------------------------*
      *                          * Se merce Di terzi presso di noi     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Di terzi'              *
      *                              *---------------------------------*
           if        w-ssm-mtv-mov-tmc    =    01
                     subtract w-ssm-mtv-mov-qdm
                                          from w-ssm-mtv-tpc-pft
           else      add      w-ssm-mtv-mov-qdm
                                          to   w-ssm-mtv-tpc-pft      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-800.
      *                      *-----------------------------------------*
      *                      * Se tipo di movimento 02 : Scarico       *
      *                      *-----------------------------------------*
       ssm-mtv-stp-act-805.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo conto *
      *                          * merce                               *
      *                          *-------------------------------------*
           if        w-ssm-mtv-mov-xmc    =    "N"
                     go to ssm-mtv-stp-act-810
           else      go to ssm-mtv-stp-act-815.
       ssm-mtv-stp-act-810.
      *                          *-------------------------------------*
      *                          * Se merce Presso terzi               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Presso terzi'          *
      *                              *---------------------------------*
           if        w-ssm-mtv-mov-tmc    =    01
                     subtract w-ssm-mtv-mov-qdm
                                          from w-ssm-mtv-tpc-pfn
           else      add      w-ssm-mtv-mov-qdm
                                          to   w-ssm-mtv-tpc-pfn      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-815.
      *                          *-------------------------------------*
      *                          * Se merce Di terzi presso di noi     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Di terzi'              *
      *                              *---------------------------------*
           if        w-ssm-mtv-mov-tmc    =    01
                     add      w-ssm-mtv-mov-qdm
                                          to   w-ssm-mtv-tpc-pft
           else      subtract w-ssm-mtv-mov-qdm
                                          from w-ssm-mtv-tpc-pft      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-mtv-stp-act-900.
       ssm-mtv-stp-act-850.
      *                      *-----------------------------------------*
      *                      * Se tipo di movimento non riconosciuto   *
