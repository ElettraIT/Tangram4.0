           if        rf-mmr-trt-val       =    "C" or
                     rf-mmr-trt-val       =    "X" or
                     rf-mmr-trt-val       =    "R" or
                     rf-mmr-trt-val       =    "Y"
                     go to ssm-mtv-stp-200.
      *              *-------------------------------------------------*
      *              * Raccolta preliminare dei valori relativi al mo- *
      *              * vimento                                         *
