      *                      *-----------------------------------------*
           move      zero                 to   w-rip-sdo-esu-ctr      .
       rip-sdo-esu-120.
           add       1                    to   w-rip-sdo-esu-ctr      .
           if        w-rip-sdo-esu-ctr    >    12
                     go to rip-sdo-esu-140.
           add       rf-mms-prg-car
                    (w-rip-sdo-esu-ctr)   to   w-rip-sdo-esu-wsd      .
           subtract  rf-mms-prg-sca
                    (w-rip-sdo-esu-ctr)   from w-rip-sdo-esu-wsd      .
           go to     rip-sdo-esu-120.
       rip-sdo-esu-140.
      *                  *---------------------------------------------*
      *                  * Se saldo di fine anno a zero : a riciclo    *
      *                  *---------------------------------------------*
           if        w-rip-sdo-esu-wsd    =    zero
                     go to  rip-sdo-esu-300.
       rip-sdo-esu-200.
      *                  *---------------------------------------------*
      *                  * Riporto su [mms] anno successivo            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ottenimento record [mms]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "DPMGDS    "         to   f-key                  .
           move      rr-ese-ife           to   rf-mms-ann-ese         .
           add       1                    to   rf-mms-ann-ese         .
           move      w-rip-sdo-esu-sdz    to   rf-mms-cod-dpz         .
           move      w-rip-sdo-esu-stm    to   rf-mms-tip-mag         .
           move      w-rip-sdo-esu-snm    to   rf-mms-num-mag         .
           move      w-rip-sdo-esu-svm    to   rf-mms-var-mag         .
           move      w-rip-sdo-esu-sds    to   rf-mms-cod-dsl         .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
      *                      *-----------------------------------------*
      *                      * Se record non trovato                   *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-sdo-esu-220.
      *                          *-------------------------------------*
      *                          * Normalizzazione record [mms]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
      *                          *-------------------------------------*
      *                          * Composizione chiave primaria        *
      *                          *-------------------------------------*
           move      rr-ese-ife           to   rf-mms-ann-ese         .
           add       1                    to   rf-mms-ann-ese         .
           move      w-rip-sdo-esu-sdz    to   rf-mms-cod-dpz         .
           move      w-rip-sdo-esu-stm    to   rf-mms-tip-mag         .
           move      w-rip-sdo-esu-snm    to   rf-mms-num-mag         .
           move      w-rip-sdo-esu-svm    to   rf-mms-var-mag         .
           move      w-rip-sdo-esu-sds    to   rf-mms-cod-dsl         .
      *                          *-------------------------------------*
      *                          * Scrittura record [mms] normalizzato *
      *                          *-------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
      *                          *-------------------------------------*
      *                          * Ripetizione dell'operazione         *
      *                          *-------------------------------------*
           go to     rip-sdo-esu-200.
       rip-sdo-esu-220.
      *                      *-----------------------------------------*
