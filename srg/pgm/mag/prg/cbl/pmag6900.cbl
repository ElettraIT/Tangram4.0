      *                  *---------------------------------------------*
           move      zero                 to   w-rip-sdo-esu-sdz      .
           move      zero                 to   w-rip-sdo-esu-stm      .
           move      zero                 to   w-rip-sdo-esu-snm      .
           move      spaces               to   w-rip-sdo-esu-svm      .
           move      spaces               to   w-rip-sdo-esu-stc      .
           move      spaces               to   w-rip-sdo-esu-scm      .
           move      spaces               to   w-rip-sdo-esu-sta      .
           move      zero                 to   w-rip-sdo-esu-sca      .
           move      spaces               to   w-rip-sdo-esu-sda      .
       rip-sdo-esu-450.
      *                  *---------------------------------------------*
      *                  * Start su file [mmz]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "GT"                 to   f-cfr                  .
           move      "MAGARC    "         to   f-key                  .
           move      rr-ese-ife           to   rf-mmz-ann-ese         .
           move      w-rip-sdo-esu-sdz    to   rf-mmz-cod-dpz         .
