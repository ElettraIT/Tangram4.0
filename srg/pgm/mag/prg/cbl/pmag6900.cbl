      *              * Ciclo per file [mmz]                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [mmz]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MGCMAR    "         to   f-key                  .
           move      rr-ese-ife           to   rf-mmz-ann-ese         .
           move      rf-mmv-tip-mag       to   rf-mmz-tip-mag         .
           move      rf-mmv-num-mag       to   rf-mmz-num-mag         .
           move      spaces               to   rf-mmz-var-mag         .
           move      spaces               to   rf-mmz-tip-ctm         .
           move      spaces               to   rf-mmz-cod-ctm         .
           move      spaces               to   rf-mmz-tip-arc         .
           move      zero                 to   rf-mmz-cod-arc         .
           move      spaces               to   rf-mmz-dpz-arc         .
           move      zero                 to   rf-mmz-cod-dpz         .
           move      "pgm/mag/fls/ioc/obj/iofmmz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmz                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-gcp-fin-999.
       det-gcp-fin-300.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mmz]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmz                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-gcp-fin-999.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-mmz-ann-ese       not  = rr-ese-ife     or
                     rf-mmz-tip-mag       not  = rf-mmv-tip-mag or
                     rf-mmz-num-mag       not  = rf-mmv-num-mag
                     go to det-gcp-fin-999.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo di fine anno           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Saldo a inizio anno                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-gcp-fin-wsq      .
           if        rf-mmz-tip-ctm       =    "N"
                     add      rf-mmz-qta-ini
                                          to   w-det-gcp-fin-wsq
           else      subtract rf-mmz-qta-ini
                                          from w-det-gcp-fin-wsq      .
      *                      *-----------------------------------------*
      *                      * Ciclo di scansione progressivi mensili  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-gcp-fin-ctr      .
       det-gcp-fin-320.
           add       1                    to   w-det-gcp-fin-ctr      .
           if        w-det-gcp-fin-ctr    >    12
                     go to det-gcp-fin-340.
           add       rf-mmz-prg-cre
                    (w-det-gcp-fin-ctr)   to   w-det-gcp-fin-wsq      .
           subtract  rf-mmz-prg-deb
                    (w-det-gcp-fin-ctr)   from w-det-gcp-fin-wsq      .
           go to     det-gcp-fin-320.
       det-gcp-fin-340.
      *                  *---------------------------------------------*
      *                  * Aggiornamento giacenza di proprieta'        *
      *                  *---------------------------------------------*
           add       w-det-gcp-fin-wsq    to   w-det-gcp-fin-gcp      .
       det-gcp-fin-360.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [mmz] *
      *                  *---------------------------------------------*
           go to     det-gcp-fin-300.
       det-gcp-fin-999.
           exit.

      *    *===========================================================*
      *    * Determinazione costo medio ponderato di fine esercizio    *
      *    * in chiusura                                               *
      *    *                                                           *
      *    * Input  : rf-mmv, record valori letto                      *
      *    *                                                           *
      *    * Output : w-det-cmp-fin-cmp, costo medio ponderato         *
      *    *-----------------------------------------------------------*
       det-cmp-fin-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cmp-fin-cmp      .
      *              *-------------------------------------------------*
      *              * Normalizzazione work per progressivi            *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cmp-fin-wpq      .
           move      zero                 to   w-det-cmp-fin-wpv      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione progressivi mensili          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cmp-fin-ctr      .
       det-cmp-fin-100.
           add       1                    to   w-det-cmp-fin-ctr      .
           if        w-det-cmp-fin-ctr    >    12
                     go to det-cmp-fin-600.
       det-cmp-fin-200.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivi con valori ad im- *
      *                  * postazione diretta                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Progressivo quantita'                   *
      *                      *-----------------------------------------*
           add       rf-mmv-qtv-mns
                    (w-det-cmp-fin-ctr)   to   w-det-cmp-fin-wpq      .
      *                      *-----------------------------------------*
      *                      * Progressivo valore                      *
      *                      *-----------------------------------------*
           add       rf-mmv-vlv-mns
                    (w-det-cmp-fin-ctr)   to   w-det-cmp-fin-wpv      .
           add       rf-mmv-pca-mns
                    (w-det-cmp-fin-ctr)   to   w-det-cmp-fin-wpv      .
           subtract  rf-mmv-prc-mns
                    (w-det-cmp-fin-ctr)   from w-det-cmp-fin-wpv      .
       det-cmp-fin-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivi con valori a co-  *
      *                  * sto standard                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se quantita' mensile da valorizzare a   *
      *                      * costo standard a zero : a riciclo       *
      *                      *-----------------------------------------*
           if        rf-mmv-qcs-mns
                    (w-det-cmp-fin-ctr)   =    zero
                     go to det-cmp-fin-500.
      *                      *-----------------------------------------*
      *                      * Progressivo quantita'                   *
      *                      *-----------------------------------------*
           add       rf-mmv-qcs-mns
                    (w-det-cmp-fin-ctr)   to   w-det-cmp-fin-wpq      .
      *                      *-----------------------------------------*
      *                      * Progressivo valore                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione costo unitario stan- *
      *                          * dard per valorizzazione             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Ciclo di scansione progressivi  *
      *                              * mensili da quello attuale fino  *
      *                              * al primo                        *
      *                              *---------------------------------*
           move      w-det-cmp-fin-ctr    to   w-det-cmp-fin-c02      .
           add       1                    to   w-det-cmp-fin-c02      .
       det-cmp-fin-320.
           subtract  1                    from w-det-cmp-fin-c02      .
           if        w-det-cmp-fin-c02    =    zero
                     go to det-cmp-fin-340.
           if        rf-mmv-ust-mns
                    (w-det-cmp-fin-c02)   =    zero
                     go to det-cmp-fin-320.
           move      rf-mmv-ust-mns
                    (w-det-cmp-fin-c02)   to   w-det-cmp-fin-wcs      .
           go to     det-cmp-fin-400.
       det-cmp-fin-340.
      *                              *---------------------------------*
      *                              * Se non trovato tra i costi stan-*
      *                              * dard mensili si prova con il co-*
      *                              * sto standard valido per tutto   *
      *                              * l'esercizio                     *
      *                              *---------------------------------*
           if        rf-mmv-ust-gea       =    zero
                     go to det-cmp-fin-360.
           move      rf-mmv-ust-gea       to   w-det-cmp-fin-wcs      .
           go to     det-cmp-fin-400.
       det-cmp-fin-360.
      *                              *---------------------------------*
      *                              * Altrimenti e' il costo standard *
      *                              * ad inizio esercizio             *
      *                              *---------------------------------*
           move      rf-mmv-ust-ies       to   w-det-cmp-fin-wcs      .
           go to     det-cmp-fin-400.
       det-cmp-fin-400.
      *                          *-------------------------------------*
      *                          * Determinazione valore globale al co-*
      *                          * sto standard                        *
      *                          *-------------------------------------*
           multiply  rf-mmv-qcs-mns
                    (w-det-cmp-fin-ctr)   by   w-det-cmp-fin-wcs
                                        giving w-det-cmp-fin-wsv      .
      *                          *-------------------------------------*
      *                          * Aggiornamento progressivo valore    *
      *                          *-------------------------------------*
           add       w-det-cmp-fin-wsv    to   w-det-cmp-fin-wpv      .
       det-cmp-fin-500.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione progressivi mensili        *
      *              *-------------------------------------------------*
           go to     det-cmp-fin-100.
       det-cmp-fin-600.
      *              *-------------------------------------------------*
      *              * Determinazione valore in uscita                 *
      *              *-------------------------------------------------*
           divide    w-det-cmp-fin-wpq    into w-det-cmp-fin-wpv
                                        giving w-det-cmp-fin-cmp
                                                         rounded      .
      *              *-------------------------------------------------*
      *              * Applicazione decimali gestione magazzino        *
      *              *-------------------------------------------------*
           multiply  100                  by   w-det-cmp-fin-cmp      .
       det-cmp-fin-999.
           exit.

      *    *===========================================================*
      *    * Determinazione data e valore costo ultimo di fine eserci- *
      *    * zio in chiusura                                           *
      *    *                                                           *
      *    * Input  : rf-mmv, record valori letto                      *
      *    *                                                           *
      *    * Output : w-det-dcu-fin-dcu, data costo ultimo             *
      *    *          w-det-dcu-fin-ucu, valore costo ultimo           *
      *    *-----------------------------------------------------------*
       det-dcu-fin-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dcu-fin-dcu      .
           move      zero                 to   w-det-dcu-fin-ucu      .
      *              *-------------------------------------------------*
      *              * Valori di inizio esercizio                      *
      *              *-------------------------------------------------*
           move      rf-mmv-dcu-ies       to   w-det-dcu-fin-dcu      .
           move      rf-mmv-ucu-ies       to   w-det-dcu-fin-ucu      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione progressivi mensili          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dcu-fin-ctr      .
       det-dcu-fin-100.
           add       1                    to   w-det-dcu-fin-ctr      .
           if        w-det-dcu-fin-ctr    >    12
                     go to det-dcu-fin-999.
      *                  *---------------------------------------------*
      *                  * Test su data aggiornamento costo ultimo     *
      *                  *---------------------------------------------*
           if        rf-mmv-dcu-mns
                    (w-det-dcu-fin-ctr)   <    w-det-dcu-fin-dcu
                     go to det-dcu-fin-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento data costo ultimo             *
      *                  *---------------------------------------------*
           move      rf-mmv-dcu-mns
                    (w-det-dcu-fin-ctr)   to   w-det-dcu-fin-dcu      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento valore costo ultimo           *
      *                  *---------------------------------------------*
           move      rf-mmv-ucu-mns
                    (w-det-dcu-fin-ctr)   to   w-det-dcu-fin-ucu      .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione progressivi mensili        *
      *              *-------------------------------------------------*
           go to     det-dcu-fin-100.
       det-dcu-fin-999.
           exit.

      *    *===========================================================*
      *    * Determinazione data e valore costo standard di fine eser- *
      *    * cizio in chiusura                                         *
      *    *                                                           *
      *    * Input  : rf-mmv, record valori letto                      *
      *    *                                                           *
      *    * Output : w-det-dst-fin-dst, data costo ultimo             *
      *    *          w-det-dst-fin-ust, valore costo ultimo           *
      *    *-----------------------------------------------------------*
       det-dst-fin-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dst-fin-dst      .
           move      zero                 to   w-det-dst-fin-ust      .
      *              *-------------------------------------------------*
      *              * Valori di inizio esercizio                      *
      *              *-------------------------------------------------*
           move      rf-mmv-dst-ies       to   w-det-dst-fin-dst      .
           move      rf-mmv-ust-ies       to   w-det-dst-fin-ust      .
      *              *-------------------------------------------------*
      *              * Test su valori globali per tutto l'anno         *
      *              *-------------------------------------------------*
           if        rf-mmv-dst-gea       <    w-det-dst-fin-dst
                     go to det-dst-fin-050.
           move      rf-mmv-dst-gea       to   w-det-dst-fin-dst      .
           move      rf-mmv-ust-gea       to   w-det-dst-fin-ust      .
       det-dst-fin-050.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione progressivi mensili          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dst-fin-ctr      .
       det-dst-fin-100.
           add       1                    to   w-det-dst-fin-ctr      .
           if        w-det-dst-fin-ctr    >    12
                     go to det-dst-fin-999.
      *                  *---------------------------------------------*
      *                  * Test su data aggiornamento costo ultimo     *
      *                  *---------------------------------------------*
           if        rf-mmv-dst-mns
                    (w-det-dst-fin-ctr)   <    w-det-dst-fin-dst
                     go to det-dst-fin-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento data costo ultimo             *
      *                  *---------------------------------------------*
           move      rf-mmv-dst-mns
                    (w-det-dst-fin-ctr)   to   w-det-dst-fin-dst      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento valore costo ultimo           *
      *                  *---------------------------------------------*
           move      rf-mmv-ust-mns
                    (w-det-dst-fin-ctr)   to   w-det-dst-fin-ust      .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione progressivi mensili        *
      *              *-------------------------------------------------*
           go to     det-dst-fin-100.
       det-dst-fin-999.
           exit.

