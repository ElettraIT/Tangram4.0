           move      "SK"                 to   f-ope                  .
           move      "GT"                 to   f-cfr                  .
           move      "DPMGDS    "         to   f-key                  .
           move      rr-ese-ife           to   rf-mms-ann-ese         .
           move      w-rip-sdo-esu-sdz    to   rf-mms-cod-dpz         .
           move      w-rip-sdo-esu-stm    to   rf-mms-tip-mag         .
           move      w-rip-sdo-esu-snm    to   rf-mms-num-mag         .
