      *              *-------------------------------------------------*
           move      w-tes-qta-ini (1)    to   rf-mms-qta-ini         .
           move      w-tes-flg-zer (1)    to   rf-mms-flg-zer         .
      *              *-------------------------------------------------*
      *              * Ciclo 1..12                                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cst-mes-ctr      .
       agg-rec-mms-200.
           add       1                    to   w-det-cst-mes-ctr      .
           if        w-det-cst-mes-ctr    >    12
                     go to agg-rec-mms-900.
           move      w-tes-prg-car
                    (1, w-det-cst-mes-ctr)
                                          to   rf-mms-prg-car
                                              (w-det-cst-mes-ctr)     .
           move      w-tes-prg-sca
                    (1, w-det-cst-mes-ctr)
                                          to   rf-mms-prg-sca
                                              (w-det-cst-mes-ctr)     .
           go to     agg-rec-mms-200.
       agg-rec-mms-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-rec-mms-999.
       agg-rec-mms-999.
