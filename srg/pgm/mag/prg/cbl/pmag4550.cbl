      *    * Visualizzazione campo : Scarichi                          *
      *    *-----------------------------------------------------------*
       vis-prg-sca-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GD"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           add       w-det-cst-mes-ctr    to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-tes-prg-sca
                    (1, w-det-cst-mes-ctr)
