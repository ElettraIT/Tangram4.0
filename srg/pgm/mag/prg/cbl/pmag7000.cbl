      *                  *---------------------------------------------*
           move      11                   to   w-ind-lin-att          .
           add       w-tes-ctr-pre        to   w-ind-lin-att          .
           perform   vis-ind-lin-000      thru vis-ind-lin-999        .
       acc-fdr-pre-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      11                   to   v-lin                  .
           add       w-tes-ctr-pre        to   v-lin                  .
           move      72                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-fdr-pre
                    (1, w-tes-ctr-pre)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fdr-pre-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fdr-pre-999.
       acc-fdr-pre-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-fdr-pre
                                              (1, w-tes-ctr-pre)      .
       acc-fdr-pre-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore accettabile                  *
      *                  *---------------------------------------------*
           if        w-tes-vnb-pre
                    (1, w-tes-ctr-pre)    =    zero
                     go to acc-fdr-pre-420
           else      go to acc-fdr-pre-600.
       acc-fdr-pre-420.
      *                      *-----------------------------------------*
      *                      * Se valore del bene a zero               *
      *                      *-----------------------------------------*
           if        w-tes-fdr-pre
                    (1, w-tes-ctr-pre)    =    spaces
                     go to acc-fdr-pre-600
           else      go to acc-fdr-pre-100.
       acc-fdr-pre-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale conversione del valore in 'S'     *
      *                  *---------------------------------------------*
           if        w-tes-fdr-pre
                    (1, w-tes-ctr-pre)    =    spaces
                     go to acc-fdr-pre-800.
           if        w-tes-fdr-pre
                    (1, w-tes-ctr-pre)    =    "S"
                     go to acc-fdr-pre-800.
           move      "S"                  to   w-tes-fdr-pre
                                              (1, w-tes-ctr-pre)      .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione flag di rivalutazione     *
      *                  *---------------------------------------------*
           perform   vis-fdr-pre-000      thru vis-fdr-pre-999        .
       acc-fdr-pre-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fdr-pre-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fdr-pre-100.
       acc-fdr-pre-999.
           exit.

      *    *===========================================================*
