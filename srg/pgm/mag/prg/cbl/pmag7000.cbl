      *              * Lettura                                         *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "ESECOD    "         to   f-key                  .
           move      w-tes-ann-ese        to   rf-mmv-ann-ese         .
           move      w-tes-tip-mag        to   rf-mmv-tip-mag         .
           move      w-tes-num-mag        to   rf-mmv-num-mag         .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-100.
       rou-let-reg-040.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           if        w-tes-tip-mag        =    01
                     go to rou-let-reg-041
           else if   w-tes-tip-mag        =    02
                     go to rou-let-reg-042
           else if   w-tes-tip-mag        =    03
                     go to rou-let-reg-043
           else if   w-tes-tip-mag        =    04
                     go to rou-let-reg-044.
       rou-let-reg-041.
      *                          *-------------------------------------*
      *                          * Se prodotto                         *
      *                          *-------------------------------------*
           move      "Scheda L.I.F.O. relativa al codice prodotto non es
      -              "istente !      "    to   w-err-box-err-msg      .
      *                              *---------------------------------*
      *                              * A box di errore                 *
      *                              *---------------------------------*
           go to     rou-let-reg-050.
       rou-let-reg-042.
      *                          *-------------------------------------*
      *                          * Se semilavorato                     *
      *                          *-------------------------------------*
           move      "Scheda L.I.F.O. relativa al codice semilavorato no
      -              "n esistente !  "    to   w-err-box-err-msg      .
      *                              *---------------------------------*
      *                              * A box di errore                 *
      *                              *---------------------------------*
           go to     rou-let-reg-050.
       rou-let-reg-043.
      *                          *-------------------------------------*
      *                          * Se materia prima                    *
      *                          *-------------------------------------*
           move      "Scheda L.I.F.O. relativa alla materia prima non es
      -              "istente !      "    to   w-err-box-err-msg      .
      *                              *---------------------------------*
      *                              * A box di errore                 *
      *                              *---------------------------------*
           go to     rou-let-reg-050.
       rou-let-reg-044.
      *                          *-------------------------------------*
      *                          * Se materiale vario                  *
      *                          *-------------------------------------*
           move      "Scheda L.I.F.O. relativa al codice del materiale n
      -              "on esistente ! "    to   w-err-box-err-msg      .
      *                              *---------------------------------*
      *                              * A box di errore                 *
      *                              *---------------------------------*
           go to     rou-let-reg-050.
       rou-let-reg-050.
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Flag di errore                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     rou-let-reg-900.
       rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
