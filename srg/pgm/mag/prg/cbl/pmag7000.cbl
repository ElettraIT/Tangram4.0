                                              (1, w-tes-ctr-pre)      .
           move      zero                 to   w-tes-ump-pre
                                              (1, w-tes-ctr-pre)      .
           move      zero                 to   w-tes-vnb-pre
                                              (1, w-tes-ctr-pre)      .
           move      spaces               to   w-tes-fdr-pre
                                              (1, w-tes-ctr-pre)      .
