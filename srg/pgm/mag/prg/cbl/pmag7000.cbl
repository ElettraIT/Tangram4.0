                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-vnb-pre-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-vnb-pre-100.
       acc-vnb-pre-999.
           exit.

