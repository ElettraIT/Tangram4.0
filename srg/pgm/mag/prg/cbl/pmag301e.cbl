      *    *===========================================================*
      *    * Accettazione : Codice magazzino                           *
      *    *-----------------------------------------------------------*
       acc-cod-mag-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale default da i.p.c.                 *
      *                  *---------------------------------------------*
           if        w-ipc-cod-pro-val    =    zero
                     go to acc-cod-mag-100.
      *                  *---------------------------------------------*
      *                  * Preparazione work-area richieste            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice prodotto numerico                *
      *                      *-----------------------------------------*
           move      w-ipc-cod-pro-val    to   rr-cod-mag             .
      *                      *-----------------------------------------*
      *                      * Lettura record [dcp]                    *
      *                      *-----------------------------------------*
           move      rr-cod-mag           to   w-let-arc-dcp-num      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-cod-mag-100.
      *                      *-----------------------------------------*
      *                      * Codice prodotto alfanumerico            *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-alf    to   rr-alf-mag             .
      *                      *-----------------------------------------*
      *                      * Visualizzazione codice                  *
      *                      *-----------------------------------------*
           perform   vis-cod-mag-000      thru vis-cod-mag-999        .
      *                      *-----------------------------------------*
      *                      * Descrizione prodotto                    *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   rr-cod-mag-des         .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-cod-mag-des-000  thru vis-cod-mag-des-999    .
       acc-cod-mag-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      rr-cod-mag           to   w-cod-cod-dcp-num      .
           move      rr-alf-mag           to   w-cod-cod-dcp-alf      .
           move      05                   to   w-cod-cod-dcp-lin      .
           move      25                   to   w-cod-cod-dcp-pos      .
           move      05                   to   w-cod-cod-dcp-dln      .
           move      41                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cod-mag-999.
       acc-cod-mag-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-cod-mag             .
           move      v-alf                to   rr-alf-mag             .
       acc-cod-mag-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-mag-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rr-cod-mag           to   w-let-arc-dcp-num      .
           move      rr-alf-mag           to   w-let-arc-dcp-alf      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione magazzino        *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-des    to   rr-cod-mag-des         .
      *                  *---------------------------------------------*
      *                  * Memorizzazione unita' di misura             *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-umi    to   rr-cod-mag-umi         .
      *                  *---------------------------------------------*
      *                  * Memorizzazione numero decimali quantita'    *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-ndq    to   rr-cod-mag-ndq         .
       acc-cod-mag-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione magazzino       *
      *                  *---------------------------------------------*
           perform   vis-cod-mag-des-000  thru vis-cod-mag-des-999    .
       acc-cod-mag-430.
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-cod-mag-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        rr-cod-mag           =    zero
                     go to acc-cod-mag-100.
       acc-cod-mag-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-mag-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cod-mag-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cod-mag-100.
       acc-cod-mag-999.
           exit.

