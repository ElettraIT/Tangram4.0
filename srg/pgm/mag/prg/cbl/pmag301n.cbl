           if        w-ipc-cod-sem-snx    =    "N"
                     go to pre-tip-fun-500.
       pre-tip-fun-100.
      *              *-------------------------------------------------*
      *              * Se variabile esistente                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : come per non esistente   *
      *                  *---------------------------------------------*
           if        w-ipc-cod-sem-val    =    zero
                     go to pre-tip-fun-500.
      *                  *---------------------------------------------*
      *                  * Preparazione work-area richieste            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice semilavorato numerico            *
      *                      *-----------------------------------------*
           move      w-ipc-cod-sem-val    to   rr-cod-sem             .
      *                      *-----------------------------------------*
      *                      * Lettura record [dps]                    *
      *                      *-----------------------------------------*
           move      rr-cod-sem           to   w-let-arc-dps-num      .
           perform   let-arc-dps-000      thru let-arc-dps-999        .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        w-let-arc-dps-flg    not  = spaces
                     go to pre-tip-fun-500.
      *                      *-----------------------------------------*
      *                      * Codice semilavorato alfanumerico        *
      *                      *-----------------------------------------*
           move      w-let-arc-dps-alf    to   rr-alf-sem             .
      *                      *-----------------------------------------*
      *                      * Descrizione semilavorato                *
      *                      *-----------------------------------------*
           move      w-let-arc-dps-des    to   rr-cod-sem-des         .
      *                      *-----------------------------------------*
      *                      * Unita' di misura                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dps-umi    to   rr-cod-sem-umi         .
      *                      *-----------------------------------------*
      *                      * Numero decimali quantita'               *
      *                      *-----------------------------------------*
           move      w-let-arc-dps-ndq    to   rr-cod-sem-ndq         .
      *                      *-----------------------------------------*
      *                      * Data disponibilita'                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se esiste una variabile di i.p.c. e *
      *                          * questa non e' zero : data disponi-  *
      *                          * bilita' pari al valore letto        *
      *                          *-------------------------------------*
           if        w-ipc-dat-dsp-snx    =    "S" and
                     w-ipc-dat-dsp-val    not  = zero
                     move  w-ipc-dat-dsp-val
                                          to   rr-dat-dsp
                     go to pre-tip-fun-120.
      *                          *-------------------------------------*
      *                          * Altrimenti : data disponibilita'    *
      *                          * pari a data attuale                 *
      *                          *-------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rr-dat-dsp             .
       pre-tip-fun-120.
      *                  *---------------------------------------------*
      *                  * Preparazione tipo funzionamento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si/No richieste ad utente : No          *
      *                      *-----------------------------------------*
           move      "N"                  to   w-cnt-fun-snx-ric      .
      *                      *-----------------------------------------*
      *                      * Si/No funzionamento ciclico : No        *
      *                      *-----------------------------------------*
           move      "N"                  to   w-cnt-fun-snx-cic      .
      *                      *-----------------------------------------*
      *                      * Si/No funzionamento automatico : Si     *
      *                      *-----------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-aut      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-tip-fun-999.
       pre-tip-fun-500.
      *              *-------------------------------------------------*
      *              * Se variabile non esistente                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Si/No richieste ad utente : Si              *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-ric      .
      *                  *---------------------------------------------*
      *                  * Si/No funzionamento ciclico : Si            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-cic      .
      *                  *---------------------------------------------*
      *                  * Si/No funzionamento automatico : Si         *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-fun-snx-aut      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-tip-fun-999.
       pre-tip-fun-999.
           exit.

      *    *===========================================================*
      *    * Open files per richieste                                  *
      *    *-----------------------------------------------------------*
       rou-opn-fls-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-opn-fls      .
