           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      rr-dat-dsp           to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
