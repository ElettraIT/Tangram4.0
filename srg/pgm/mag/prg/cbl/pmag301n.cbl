      *    *===========================================================*
      *    * Interrogazione : Trattamento Function-key selezionata     *
      *    *-----------------------------------------------------------*
       qry-trt-fun-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-qry-flg-int      .
       qry-trt-fun-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda della function-key         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXPD"
                     go to qry-trt-fun-300
           else      go to qry-trt-fun-900.
       qry-trt-fun-300.
      *              *-------------------------------------------------*
      *              * Se function-key Expd                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Estrazione contenuto del mark-point         *
      *                  *---------------------------------------------*
           move      v-cnt                to   w-mpn                  .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del contenuto del    *
      *                  * mark-point                                  *
      *                  *---------------------------------------------*
           if        w-mpn-tip-det        =    "cdp"
                     go to qry-trt-fun-340
           else      go to qry-trt-fun-999.
       qry-trt-fun-340.
      *                  *---------------------------------------------*
      *                  * Se selezionato dettaglio : q.ta' in produ-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se programma di interrogazione su  *
      *                      * commesse di produzione gia' attivo      *
      *                      *-----------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pcdp3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to qry-trt-fun-999.
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * codice dipendenza                       *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-dpz"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      rr-dpz-inu           to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * ammissibilita' del tasto Slct           *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-slc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "N"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * tipo di interrogazione                  *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "tip-int"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      10                   to   s-car                  .
           move      "INTDSM    "         to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * codice semilavorato                     *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-sem"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      07                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      rr-cod-sem           to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * data emissione minima                   *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "drg-min"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "D"                  to   s-tip                  .
           move      zero                 to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * data emissione massima                  *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "drg-max"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "D"                  to   s-tip                  .
           move      rr-dat-dsp           to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Scrittura della variabile di i.p.c. per *
      *                      * stato commesse : solo quelle inevase    *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "sts-cdp"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      01                   to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Richiamo del programma di interrogazio- *
      *                      * ne                                      *
      *                      *-----------------------------------------*
           move      "pgm/cdp/prg/obj/pcdp3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     qry-trt-fun-999.
       qry-trt-fun-900.
      *              *-------------------------------------------------*
      *              * Se function-key non riconosciuta                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Uscita senza alcuna azione                  *
      *                  *---------------------------------------------*
           go to     qry-trt-fun-999.
       qry-trt-fun-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [dps]                            *
      *    *-----------------------------------------------------------*
       let-arc-dps-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dps-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice semilavorato a zero              *
      *              *-------------------------------------------------*
           if        w-let-arc-dps-num    =    zero
                     go to let-arc-dps-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSEM    "         to   f-key                  .
           move      w-let-arc-dps-num    to   rf-dps-num-sem         .
           move      "pgm/dps/fls/ioc/obj/iofdps"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dps                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-dps-400.
       let-arc-dps-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-dps-alf-sem       to   w-let-arc-dps-alf      .
           move      rf-dps-des-sem       to   w-let-arc-dps-des      .
           move      rf-dps-umi-prd       to   w-let-arc-dps-umi      .
           move      rf-dps-dec-qta       to   w-let-arc-dps-ndq      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-dps-999.
       let-arc-dps-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-dps-flg      .
           move      all   "."            to   w-let-arc-dps-des      .
           go to     let-arc-dps-600.
       let-arc-dps-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dps-des      .
       let-arc-dps-600.
           move      spaces               to   w-let-arc-dps-alf      .
           move      spaces               to   w-let-arc-dps-umi      .
           move      zero                 to   w-let-arc-dps-ndq      .
       let-arc-dps-999.
           exit.

      *    *===========================================================*
      *    * Routine per la determinazione, relativamente ad una com-  *
      *    * messa di produzione, di :                                 *
      *    *                                                           *
      *    *    - Quantita' da produrre                                *
      *    *    - Quantita' prodotta                                   *
      *    *    - Quantita' in corso di produzione                     *
      *    *                                                           *
      *    * e, di conseguenza, di :                                   *
      *    *                                                           *
      *    *    - Quantita' ancora da produrre                         *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [cdp] relativo alla commessa di produzione *
      *    *      a disposizione in rf-cdp                             *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-cdp-ogi-qta-dap : Quantita' da produrre            *
      *    *                                                           *
      *    *    - w-cdp-ogi-qta-pdt : Quantita' prodotta               *
      *    *                                                           *
      *    *    - w-cdp-ogi-qta-icp : Quantita' in corso di produzione *
      *    *                                                           *
      *    *    - w-cdp-ogi-qta-dpr : Quantita' ancora da produrre     *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       rpd-cdp-ogi-000.
      *              *-------------------------------------------------*
      *              * Determinazione della quantita' da produrre      *
      *              *-------------------------------------------------*
           perform   rpd-cdp-dap-000      thru rpd-cdp-dap-999        .
           move      w-cdp-qdp-qta-dap    to   w-cdp-ogi-qta-dap      .
       rpd-cdp-ogi-200.
      *              *-------------------------------------------------*
      *              * Determinazione della quantita' prodotta         *
      *              *-------------------------------------------------*
           perform   rpd-cdp-pdt-000      thru rpd-cdp-pdt-999        .
           move      w-cdp-gpr-qta-pdt    to   w-cdp-ogi-qta-pdt      .
       rpd-cdp-ogi-300.
      *              *-------------------------------------------------*
      *              * Determinazione della quantita' in corso di pro- *
      *              * duzione                                         *
      *              *-------------------------------------------------*
           perform   rpd-cdp-icp-000      thru rpd-cdp-icp-999        .
           move      w-cdp-icp-qta-icp    to   w-cdp-ogi-qta-icp      .
       rpd-cdp-ogi-400.
      *              *-------------------------------------------------*
      *              * Determinazione della quantita' ancora da pro-   *
      *              * durre                                           *
      *              *-------------------------------------------------*
       rpd-cdp-ogi-405.
      *                  *---------------------------------------------*
      *                  * Se riga comunque da considerarsi saldata :  *
      *                  * quantita' da produrre a zero                *
      *                  *---------------------------------------------*
           if        rf-cdp-sdc-ccs       not  = spaces
                     move  zero           to   w-cdp-ogi-qta-dpr
                     go to rpd-cdp-ogi-999.
       rpd-cdp-ogi-410.
      *                  *---------------------------------------------*
      *                  * Differenza algebrica tra :                  *
      *                  *   - Quantita' da produrre                   *
      *                  * e                                           *
      *                  *   - Quantita' prodotta                      *
      *                  *   - Quantita' in corso di produzione        *
      *                  *---------------------------------------------*
           move      w-cdp-ogi-qta-dap    to   w-cdp-ogi-qta-dpr      .
           subtract  w-cdp-ogi-qta-pdt    from w-cdp-ogi-qta-dpr      .
           subtract  w-cdp-ogi-qta-icp    from w-cdp-ogi-qta-dpr      .
      *                  *---------------------------------------------*
      *                  * Riduzione a zero del residuo eventualmente  *
      *                  * negativo, tenendo conto del segno algebri-  *
      *                  * co della quantita' in ordine                *
      *                  *---------------------------------------------*
           if        w-cdp-ogi-qta-dap    >    zero and
                     w-cdp-ogi-qta-dpr    <    zero
                     move  zero           to   w-cdp-ogi-qta-dpr      .
           if        w-cdp-ogi-qta-dap    <    zero and
                     w-cdp-ogi-qta-dpr    >    zero
                     move  zero           to   w-cdp-ogi-qta-dpr      .
       rpd-cdp-ogi-999.
           exit.

      *    *===========================================================*
      *    * Routine per la determinazione, relativamente ad una com-  *
      *    * messa di produzione, di :                                 *
      *    *                                                           *
      *    *    - Quantita' da produrre                                *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [cdp] relativo alla commessa di produzione *
      *    *      a disposizione in rf-cdp                             *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-cdp-qdp-qta-dap : Quantita' da produrre            *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       rpd-cdp-dap-000.
      *              *-------------------------------------------------*
      *              * Si considera come 'Quantita' da produrre' il    *
      *              * campo 'qta-dap' del record di [cdp] in esame    *
      *              *-------------------------------------------------*
           move      rf-cdp-qta-dap       to   w-cdp-qdp-qta-dap      .
       rpd-cdp-dap-999.
           exit.

      *    *===========================================================*
      *    * Routine per la determinazione, relativamente ad una com-  *
      *    * messa di produzione, di :                                 *
      *    *                                                           *
      *    *    - Quantita' prodotta                                   *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [cdp] relativo alla commessa di produzione *
      *    *      a disposizione in rf-cdp                             *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-cdp-gpr-qta-pdt : Quantita' prodotta               *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       rpd-cdp-pdt-000.
      *              *-------------------------------------------------*
      *              * Inizializzazioni preliminari                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Quantita' gia' prodotta : a zero            *
      *                  *---------------------------------------------*
           move      zero                 to   w-cdp-gpr-qta-pdt      .
      *              *-------------------------------------------------*
      *              * Test se gestione versamenti da produzione atti- *
      *              * va                                              *
      *              *-------------------------------------------------*
           if        w-prs-vdp-snx        not  = "S"
                     go to rpd-cdp-pdt-999.
       rpd-cdp-pdt-100.
      *              *-------------------------------------------------*
      *              * Start iniziale su [vpt]                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "RIFCDP    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      rf-cdp-num-prt       to   rf-vpt-prt-cdp         .
           move      zero                 to   rf-vpt-num-prt         .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rpd-cdp-pdt-999.
       rpd-cdp-pdt-200.
      *              *-------------------------------------------------*
      *              * Read Next su [vpt]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Read Next                                   *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
      *                  *---------------------------------------------*
      *                  * Se At end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rpd-cdp-pdt-999.
       rpd-cdp-pdt-300.
      *              *-------------------------------------------------*
      *              * Test Max su [vpt]                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su :                                   *
      *                  *    - Numero protocollo commessa di produ-   *
      *                  *      zione                                  *
      *                  *---------------------------------------------*
           if        rf-vpt-prt-cdp       =    rf-cdp-num-prt
                     go to rpd-cdp-pdt-400.
      *                  *---------------------------------------------*
      *                  * Se oltre il Max : uscita                    *
      *                  *---------------------------------------------*
           go to     rpd-cdp-pdt-999.
       rpd-cdp-pdt-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record di [vpt] rispetto al re-   *
      *              * cord di [cdp]                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione                                   *
      *                  *---------------------------------------------*
           perform   sel-vpt-cdp-000      thru sel-vpt-cdp-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non superata : si ignora il    *
      *                  * record letto                                *
      *                  *---------------------------------------------*
           if        w-sel-vpt-cdp-flg    not  = spaces
                     go to rpd-cdp-pdt-800.
       rpd-cdp-pdt-500.
      *              *-------------------------------------------------*
      *              * Considerazioni sul record di [vpt] letto e se-  *
      *              * lezionato rispetto ad [cdp]                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Si somma la 'Quantita' prodotta' contenuta  *
      *                  * ta nel record alla 'Quantita' prodotta' che *
      *                  * si sta determinando                         *
      *                  *---------------------------------------------*
           add       rf-vpt-qta-pdt       to   w-cdp-gpr-qta-pdt      .
       rpd-cdp-pdt-800.
      *              *-------------------------------------------------*
      *              * Riciclo a Read Next su [vpt]                    *
      *              *-------------------------------------------------*
           go to     rpd-cdp-pdt-200.
       rpd-cdp-pdt-999.
           exit.

      *    *===========================================================*
      *    * Routine per la determinazione, relativamente ad una com-  *
      *    * messa di produzione, di :                                 *
      *    *                                                           *
      *    *    - Quantita' in corso di produzione                     *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [cdp] relativo alla commessa di produzione *
      *    *      a disposizione in rf-cdp                             *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-cdp-icp-qta-icp : Quantita' in corso di produzione *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       rpd-cdp-icp-000.
      *              *-------------------------------------------------*
      *              * Quantita' in corso di produzione : a zero       *
      *              *-------------------------------------------------*
           move      zero                 to   w-cdp-icp-qta-icp      .
       rpd-cdp-icp-999.
           exit.

      *    *===========================================================*
      *    * Routine per la selezione sul record [vpt] relativamente   *
      *    * al record di [cdp], per compatibilita'                    *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [vpt] relativo al versamento da produzione *
      *    *      a disposizione in rf-vpt                             *
      *    *                                                           *
      *    *    - Record di [cdp] relativo alla commessa di produzione *
      *    *      a disposizione in rf-cdp                             *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-sel-vpt-cdp-flg : Esito della selezione            *
      *    *                            - Spaces : Ok                  *
      *    *                            - #      : Ko                  *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-vpt-cdp-000.
      *              *-------------------------------------------------*
      *              * Selezione su : Destinazione della produzione    *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-dsz-prd       not  = rf-cdp-dsz-prd
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-025.
      *              *-------------------------------------------------*
      *              * Selezione su : Codice per la destinazione della *
      *              * produzione                                      *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-dsz-cod       not  = rf-cdp-dsz-cod
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-050.
      *              *-------------------------------------------------*
      *              * Selezione su : Codice dipendenza per la desti-  *
      *              * nazione della produzione                        *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-dsz-dpz       not  = rf-cdp-dsz-dpz
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-075.
      *              *-------------------------------------------------*
      *              * Selezione su : Tipo codice di magazzino         *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-tip-mag       not  = rf-cdp-tip-mag
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-100.
      *              *-------------------------------------------------*
      *              * Selezione su : Codice prodotto numerico         *
      *              *                                                 *
      *              * Deve essere pari a quello della commessa di     *
      *              * produzione che si sta esaminando.               *
      *              *-------------------------------------------------*
           if        rf-vpt-num-mag       not  = rf-cdp-num-mag
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-125.
      *              *-------------------------------------------------*
      *              * Selezione su : Codice prodotto alfanumerico     *
      *              *                                                 *
      *              * Non viene fatta alcuna selezione su questo cam- *
      *              * po, in quanto si prevede che possa essere nel   *
      *              * frattempo variato l'identificatore alfanumerico *
      *              * del prodotto. In ogni caso l'identificatore e-  *
      *              * sposto sara' l'identificatore alfanumerico at-  *
      *              * tuale.                                          *
      *              *-------------------------------------------------*
       sel-vpt-cdp-150.
      *              *-------------------------------------------------*
      *              * Selezione su : Sigla della variante per il pro- *
      *              *                dotto                            *
      *              *                                                 *
      *              * Non viene fatta alcuna selezione su questo cam- *
      *              * po, in quanto si permette di spedire una va-    *
      *              * riante diversa da quanto stabilito in ordine    *
      *              * fornitore.                                      *
      *              *-------------------------------------------------*
       sel-vpt-cdp-175.
      *              *-------------------------------------------------*
      *              * Selezione su : Quantita' prodotta               *
      *              *                                                 *
      *              * Deve essere diversa da Zero, non si prendono in *
      *              * considerazione versamenti da produzione con     *
      *              * quantita' a Zero.                               *
      *              *-------------------------------------------------*
           if        rf-vpt-qta-pdt       =    zero
                     go to sel-vpt-cdp-900.
       sel-vpt-cdp-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezione : Ok                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-sel-vpt-cdp-flg      .
           go to     sel-vpt-cdp-999.
       sel-vpt-cdp-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezione : Ko                       *
      *              *-------------------------------------------------*
           move      "#"                  to   w-sel-vpt-cdp-flg      .
           go to     sel-vpt-cdp-999.
       sel-vpt-cdp-999.
           exit.

      *    *===========================================================*
      *    * Memorizzazione sottoprogramma in attivita'                *
      *    *-----------------------------------------------------------*
       mem-spg-att-000.
      *              *-------------------------------------------------*
      *              * Se numero elementi in tabella gia' pari al mas- *
      *              * simo numero di elementi possibili : uscita per  *
      *              * memorizzazione non avvenuta                     *
      *              *-------------------------------------------------*
           if        w-spg-ele-num        =    w-spg-ele-max
                     move  "N"            to   w-spg-snx-gat
                     go to mem-spg-att-999.
      *              *-------------------------------------------------*
      *              * Incremento numero elementi in tabella           *
      *              *-------------------------------------------------*
           add       1                    to   w-spg-ele-num          .
      *              *-------------------------------------------------*
      *              * Memorizzazione codice alfanumerico del tipo di  *
      *              * interrogazione                                  *
      *              *-------------------------------------------------*
           move      w-spg-alf-gat        to   w-spg-alf-tin
                                              (w-spg-ele-num)         .
      *              *-------------------------------------------------*
      *              * Uscita per memorizzazione avvenuta              *
      *              *-------------------------------------------------*
           move      spaces               to   w-spg-snx-gat          .
       mem-spg-att-999.
           exit.

      *    *===========================================================*
      *    * Eliminazione sottoprogramma in attivita'                  *
      *    *-----------------------------------------------------------*
       eli-spg-att-000.
      *              *-------------------------------------------------*
      *              * Se numero elementi in tabella a zero : uscita   *
      *              *-------------------------------------------------*
           if        w-spg-ele-num        =    zero
                     go to eli-spg-att-999.
      *              *-------------------------------------------------*
      *              * Se l'ultimo elemento in tabella non e' pari a   *
      *              * quello da eliminare : uscita                    *
      *              *-------------------------------------------------*
           if        w-spg-alf-tin
                    (w-spg-ele-num)       not  = w-spg-alf-gat
                     go to eli-spg-att-999.
      *              *-------------------------------------------------*
      *              * Decremento numero elementi in tabella           *
      *              *-------------------------------------------------*
           subtract  1                    from w-spg-ele-num          .
       eli-spg-att-999.
           exit.

      *    *===========================================================*
      *    * Test se sottoprogramma gia' attivo                        *
      *    *-----------------------------------------------------------*
       tst-spg-gat-000.
      *              *-------------------------------------------------*
      *              * Risposta a : non gia' attivo                    *
      *              *-------------------------------------------------*
           move      spaces               to   w-spg-snx-gat          .
      *              *-------------------------------------------------*
      *              * Se codice alfanumerico del tipo di interroga-   *
      *              * zione a spaces : uscita                         *
      *              *-------------------------------------------------*
           if        w-spg-alf-gat        =    spaces
                     go to tst-spg-gat-999.
      *              *-------------------------------------------------*
      *              * Indice per scansione su tabella a zero          *
      *              *-------------------------------------------------*
           move      zero                 to   w-spg-ele-inx          .
       tst-spg-gat-200.
      *              *-------------------------------------------------*
      *              * Incremento indice per scansione su tabella      *
      *              *-------------------------------------------------*
           add       1                    to   w-spg-ele-inx          .
      *              *-------------------------------------------------*
      *              * Se oltre numero elementi memorizzati : uscita   *
      *              *-------------------------------------------------*
           if        w-spg-ele-inx        >    w-spg-ele-num
                     go to tst-spg-gat-999.
      *              *-------------------------------------------------*
      *              * Se l'elemento non e' quello cercato : riciclo   *
      *              * su elemento successivo                          *
      *              *-------------------------------------------------*
           if        w-spg-alf-tin
                    (w-spg-ele-inx)       not  = w-spg-alf-gat
                     go to tst-spg-gat-200.
       tst-spg-gat-400.
      *              *-------------------------------------------------*
      *              * Risposta a : gia' attivo                        *
      *              *-------------------------------------------------*
           move      "S"                  to   w-spg-snx-gat          .
       tst-spg-gat-999.
           exit.

