      *                      *-----------------------------------------*
           if        rr-snx-zer           =    01 and
                     w-sdp-flg-zer        =    spaces
                     go to prn-sel-rec-900.
      *                      *-----------------------------------------*
      *                      * Test sul flag di tutti i saldi negativi *
      *                      *-----------------------------------------*
           if        rr-snx-zer           =    02 and
                     w-sdp-flg-neg        =    spaces
                     go to prn-sel-rec-900.
      *                      *-----------------------------------------*
      *                      * Uscita per selezione superata           *
      *                      *-----------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-500.
      *                  *---------------------------------------------*
