      *                      *-----------------------------------------*
           move      zero                 to   w-sdp-tot-dpz          .
      *                      *-----------------------------------------*
      *                      * Inizio scansione                        *
      *                      *-----------------------------------------*
           move      zero                 to   w-sdp-ctr-001          .
       prn-sel-rec-110.
           add       1                    to   w-sdp-ctr-001          .
           if        w-sdp-ctr-001        >    99
                     go to prn-sel-rec-200.
           if        w-sdp-ctr-001        >    rr-dpz-ctr-sel
                     go to prn-sel-rec-200.
      *                      *-----------------------------------------*
