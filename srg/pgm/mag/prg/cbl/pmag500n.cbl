                     move  "DO  "         to   v-pfk (05)             .
           move      rr-tip-slp           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-tip-slp-999.
       acc-tip-slp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-tip-slp             .
       acc-tip-slp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore zero non ammesso, a meno che non si  *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        rr-tip-slp           not  = zero
                     go to acc-tip-slp-600.
           if        v-key                =    "UP  "
                     go to acc-tip-slp-600
           else      go to acc-tip-slp-999.
       acc-tip-slp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-slp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-tip-slp-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-tip-slp-100.
       acc-tip-slp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzaz. campo selezione : Tipo salto pagina          *
      *    *-----------------------------------------------------------*
       vis-tip-slp-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-slp-lun    to   v-car                  .
           move      w-exp-tip-slp-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-slp-tbl    to   v-txt                  .
           move      rr-tip-slp           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-slp-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
      *              *-------------------------------------------------*
      *              * Test su data situazione                         *
      *              *-------------------------------------------------*
           if        rr-dat-sit           not  = zero
                     go to tdo-ric-sel-100.
           move      "Manca la data situazione !"
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio d'errore                *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo salto pagina               *
      *              *-------------------------------------------------*
           if        rr-tip-slp           =    zero
                     move  01             to   rr-tip-slp             .
      *              *-------------------------------------------------*
      *              * Normalizzazione Si/No solo se saldo diverso da  *
      *              * zero                                            *
      *              *-------------------------------------------------*
           if        rr-snx-zer           =    zero
                     move  1              to   rr-snx-zer             .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Precaricamento tabella dipendenze selezionate   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Contatore globale dipendenze letto in pre-  *
      *                  * esecuzione del programma                    *
      *                  *---------------------------------------------*
           move      w-dpz-ctr-dpz        to   rr-dpz-ctr-dpz         .
      *                  *---------------------------------------------*
      *                  * Test se selezionata una sola dipendenza     *
      *                  *---------------------------------------------*
           if        rr-dpz-inu           not  = zero
                     go to nor-ric-sel-100.
      *                  *---------------------------------------------*
      *                  * Preparazione contatori                      *
      *                  *---------------------------------------------*
           move      zero                 to   rr-dpz-ctr-sel         .
           move      zero                 to   w-cix-ctr-001          .
       nor-ric-sel-010.
           add       1                    to   w-cix-ctr-001          .
           if        w-cix-ctr-001        >    99
                     go to nor-ric-sel-100.
           if        w-dpz-ele-flg
                    (w-cix-ctr-001)       =    spaces
                     go to nor-ric-sel-010.
           add       1                    to   rr-dpz-ctr-sel         .
           if        rr-dpz-ctr-sel       >    99
                     go to nor-ric-sel-100.
           move      w-cix-ctr-001        to   rr-dpz-ele-cod
                                              (rr-dpz-ctr-sel)        .
           move      w-dpz-ele-den
                    (w-cix-ctr-001)       to   rr-dpz-ele-den
                                              (rr-dpz-ctr-sel)        .
      *                  *---------------------------------------------*
      *                  * Riciclo su elemento successivo              *
      *                  *---------------------------------------------*
           go to     nor-ric-sel-010.
       nor-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Normalizzazioni altri campi                     *
      *              *-------------------------------------------------*
           move      zero                 to   rr-cod-age             .
           move      spaces               to   rr-cod-age-nom         .
           move      zero                 to   rr-snx-zer             .
           move      spaces               to   rr-cod-mic             .
           move      spaces               to   rr-cod-mic-des         .
           move      spaces               to   rr-alf-pro             .
           move      zero                 to   rr-num-pro             .
           move      spaces               to   rr-num-pro-des         .
           move      zero                 to   rr-tip-slp             .
           move      zero                 to   rr-dat-sit             .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Preparazione parametri per selezione stampa               *
      *    *-----------------------------------------------------------*
       pre-prm-stp-000.
      *              *-------------------------------------------------*
      *              * Flags di tipo selezione                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sel      .
      *              *-------------------------------------------------*
      *              * Codice stampante                                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-stp      .
      *              *-------------------------------------------------*
      *              * Tipo di stampa                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sta      .
      *              *-------------------------------------------------*
      *              * Codice modulo                                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-mod      .
      *              *-------------------------------------------------*
      *              * Tipo modulo                                     *
      *              *   - L : Libero                                  *
      *              *   - T : Tipografico                             *
      *              *-------------------------------------------------*
           move      "L"                  to   w-cnt-stp-tip-mod      .
      *              *-------------------------------------------------*
      *              * Ampiezza linea di stampa in caratteri           *
      *              *-------------------------------------------------*
           move      132                  to   w-cnt-stp-amp-lin      .
      *              *-------------------------------------------------*
      *              * Top margin in linee                             *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-top-lin      .
      *              *-------------------------------------------------*
      *              * Numero linee di stampa minimo                   *
      *              *-------------------------------------------------*
           move      30                   to   w-cnt-stp-lin-min      .
      *              *-------------------------------------------------*
      *              * Bottom margin in linee                          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-bot-lin      .
      *              *-------------------------------------------------*
      *              * Ampiezza caratteri                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-amp-car      .
      *              *-------------------------------------------------*
      *              * Altezza interlinea                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-alt-int      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni future            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-esp-fut      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni speciali          *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-fnz-spc      .
       pre-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : No                    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-exe-rou-srt      .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Composizione file di appoggio                             *
      *    *-----------------------------------------------------------*
       cmp-fil-app-000.
      *              *-------------------------------------------------*
      *              * Determinazione mese chiusura esercizio per la   *
      *              * gestione magazzino, mutuandolo dalla contabi-   *
      *              * lita' generale                                  *
      *              *-------------------------------------------------*
           move      "P:"                 to   s-ope                  .
           move      "pgm/cge[mes-chi]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                =    spaces
                     move  s-num          to   w-cmp-fil-app-mce
           else      move  12             to   w-cmp-fil-app-mce      .
           if        w-cmp-fil-app-mce    <    01 or
                     w-cmp-fil-app-mce    >    12
                     move  12             to   w-cmp-fil-app-mce      .
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio relativo alla  *
      *              * data in cui e' stato richiesto il saldo         *
      *              *-------------------------------------------------*
           move      rr-dat-sit           to   s-dat                  .
           if        w-cmp-fil-app-mce    =    12             or
                     s-mes                >    w-cmp-fil-app-mce
                     move  s-saa          to   w-cmp-fil-app-esa
                     go to cmp-fil-app-020.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-cmp-fil-app-esa      .
       cmp-fil-app-020.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio relativo alla  *
      *              * data in cui e' stato richiesto il saldo         *
      *              *-------------------------------------------------*
           move      s-mes                to   w-cmp-fil-app-mea      .
           if        w-cmp-fil-app-mce    =    12
                     go to cmp-fil-app-040.
           if        s-mes                >    w-cmp-fil-app-mce
                     subtract w-cmp-fil-app-mce
                                          from w-cmp-fil-app-mea
                     go to cmp-fil-app-040.
           if        s-mes                <    w-cmp-fil-app-mce
                     add   12             to   w-cmp-fil-app-mea
                     subtract w-cmp-fil-app-mce
                                          from w-cmp-fil-app-mea
                     go to cmp-fil-app-040.
           move      12                   to   w-cmp-fil-app-mea      .
       cmp-fil-app-040.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio precedente a   *
      *              * quello relativo alla data in cui e' stato ri-   *
      *              * chiesto il saldo                                *
      *              *-------------------------------------------------*
           move      zero                 to   s-dat                  .
           move      w-cmp-fil-app-esa    to   s-saa                  .
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-cmp-fil-app-esp      .
       cmp-fil-app-200.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che sia necessario leggere *
      *              * le schede saldi [mmz] dell'anno precedente o no *
      *              *-------------------------------------------------*
           if        w-dnu-ife-ife-ese    =    zero
                     go to cmp-fil-app-300
           else if   w-cmp-fil-app-esa    not  > w-dnu-ife-ife-ese
                     go to cmp-fil-app-400
           else if   w-dnu-ife-ife-flg    not  = spaces
                     go to cmp-fil-app-300
           else if   w-cmp-fil-app-esp    =    w-dnu-ife-ife-ese
                     go to cmp-fil-app-400
                     go to cmp-fil-app-300.
       cmp-fil-app-300.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione file [mmz] per l'anno prece- *
      *              * dente                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero dipenden- *
      *                  * ze selezionato                              *
      *                  *---------------------------------------------*
           if        rr-dpz-inu           =    zero
                     go to cmp-fil-app-320
           else      go to cmp-fil-app-340.
       cmp-fil-app-320.
      *                  *---------------------------------------------*
      *                  * Se selezione di piu' dipendenze             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ciclo di scansione su tabella dipenden- *
      *                      * ze                                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-sdp-ctr-001          .
       cmp-fil-app-330.
           add       1                    to   w-sdp-ctr-001          .
           if        w-sdp-ctr-001        >    99
                     go to cmp-fil-app-400.
           if        w-sdp-ctr-001        >    rr-dpz-ctr-sel
                     go to cmp-fil-app-400.
           move      w-cmp-fil-app-esp    to   w-cmp-fil-app-wes      .
           move      rr-dpz-ele-cod
                    (w-sdp-ctr-001)       to   w-cmp-fil-app-wdz      .
           perform   cmp-fil-app-500      thru cmp-fil-app-599        .
           go to     cmp-fil-app-330.
       cmp-fil-app-340.
      *                  *---------------------------------------------*
      *                  * Se selezione di una sola dipendenza         *
      *                  *---------------------------------------------*
           move      w-cmp-fil-app-esp    to   w-cmp-fil-app-wes      .
           move      rr-dpz-inu           to   w-cmp-fil-app-wdz      .
           perform   cmp-fil-app-500      thru cmp-fil-app-599        .
       cmp-fil-app-400.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione file [mmz] per l'anno rela-  *
      *              * tivo alla data richiesta                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero dipenden- *
      *                  * ze selezionato                              *
      *                  *---------------------------------------------*
           if        rr-dpz-inu           =    zero
                     go to cmp-fil-app-420
           else      go to cmp-fil-app-440.
       cmp-fil-app-420.
      *                  *---------------------------------------------*
      *                  * Se selezione di piu' dipendenze             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ciclo di scansione su tabella dipenden- *
      *                      * ze                                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-sdp-ctr-001          .
       cmp-fil-app-430.
           add       1                    to   w-sdp-ctr-001          .
           if        w-sdp-ctr-001        >    99
                     go to cmp-fil-app-500.
           if        w-sdp-ctr-001        >    rr-dpz-ctr-sel
                     go to cmp-fil-app-500.
           move      w-cmp-fil-app-esa    to   w-cmp-fil-app-wes      .
           move      rr-dpz-ele-cod
                    (w-sdp-ctr-001)       to   w-cmp-fil-app-wdz      .
           perform   cmp-fil-app-500      thru cmp-fil-app-599        .
           go to     cmp-fil-app-430.
       cmp-fil-app-440.
      *                  *---------------------------------------------*
      *                  * Se selezione di una sola dipendenza         *
      *                  *---------------------------------------------*
           move      w-cmp-fil-app-esa    to   w-cmp-fil-app-wes      .
           move      rr-dpz-inu           to   w-cmp-fil-app-wdz      .
           perform   cmp-fil-app-500      thru cmp-fil-app-599        .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cmp-fil-app-999.
       cmp-fil-app-500.
      *              *-------------------------------------------------*
      *              * Sub-routine interna di scansione file [mmz] con *
      *              * eventuale scrittura in file di appoggio [kk0]   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [mmz]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ARCMAG    "         to   f-key                  .
           move      w-cmp-fil-app-wes    to   rf-mmz-ann-ese         .
           move      w-cmp-fil-app-wdz    to   rf-mmz-cod-dpz         .
           move      "A"                  to   rf-mmz-tip-arc         .
           move      rr-cod-age           to   rf-mmz-cod-arc         .
           move      spaces               to   rf-mmz-dpz-arc         .
           move      01                   to   rf-mmz-tip-mag         .
           move      rr-num-pro           to   rf-mmz-num-mag         .
           move      spaces               to   rf-mmz-var-mag         .
           move      "N"                  to   rf-mmz-tip-ctm         .
           move      rr-cod-mic           to   rf-mmz-cod-ctm         .
           move      "pgm/mag/fls/ioc/obj/iofmmz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmz                 .
      *                      *-----------------------------------------*
      *                      * Se start errata : fine scansione        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to cmp-fil-app-599.
       cmp-fil-app-520.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mmz]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmz"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmz                 .
      *                      *-----------------------------------------*
      *                      * Se 'At end' : fine scansione            *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to cmp-fil-app-599.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-mmz-ann-ese       not  = w-cmp-fil-app-wes or
                     rf-mmz-cod-dpz       not  = w-cmp-fil-app-wdz or
                     rf-mmz-tip-arc       not  = "A"               or
                    (rr-cod-age           not  = zero    and
                     rf-mmz-cod-arc       not  = rr-cod-age)
                     go to cmp-fil-app-599.
       cmp-fil-app-530.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su dipendenza archivio             *
      *                      *-----------------------------------------*
           if        rr-cod-age           =    zero
                     go to cmp-fil-app-540.
       cmp-fil-app-540.
      *                      *-----------------------------------------*
      *                      * Test su tipo codice di magazzino        *
      *                      *-----------------------------------------*
           if        rf-mmz-tip-mag       not  = 01
                     go to cmp-fil-app-520.
      *                      *-----------------------------------------*
      *                      * Test su codice di magazzino             *
      *                      *-----------------------------------------*
           if        rr-num-pro           not  = zero   and
                     rf-mmz-num-mag       not  = rr-num-pro
                     go to cmp-fil-app-520.
      *                      *-----------------------------------------*
      *                      * Test su tipo conto merce                *
      *                      *-----------------------------------------*
           if        rf-mmz-tip-ctm       not  = "N"
                     go to cmp-fil-app-520.
      *                      *-----------------------------------------*
      *                      * Test su codice conto merce              *
      *                      *-----------------------------------------*
           if        rr-cod-mic           not  = spaces and
                     rf-mmz-cod-ctm       not  = rr-cod-mic
                     go to cmp-fil-app-520.
      *                  *---------------------------------------------*
      *                  * Lettura record [age]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODAGE    "         to   f-key                  .
           move      rf-mmz-cod-arc       to   rf-age-cod-age         .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-age-rag-key
                     move  all "."        to   rf-age-rag-soc         .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcp]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO    "         to   f-key                  .
           move      rf-mmz-num-mag       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-dcp-alf-pro
                     move  all "."        to   rf-dcp-des-pro         .
      *                      *-----------------------------------------*
      *                      * Test se codice letto                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        rf-dcp-alf-pro       not  = spaces
                     go to cmp-fil-app-550.
      *                          *-------------------------------------*
      *                          * Editing codice numerico prodotto    *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-mmz-num-mag       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Concatenamento con parentesi        *
      *                          *-------------------------------------*
           move      09                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "("                  to   w-all-str-cat (1)      .
           move      p-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   rf-dcp-alf-pro         .
       cmp-fil-app-550.
      *                  *---------------------------------------------*
      *                  * Lettura record file di appoggio [kk0]       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
