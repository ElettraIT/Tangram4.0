      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Lettura numerazione [datife]                    *
      *              *-------------------------------------------------*
           perform   dat-ife-000          thru dat-ife-999            .
      *              *-------------------------------------------------*
      *              * Test se necessaria la lettura di due esercizi   *
      *              *-------------------------------------------------*
           move      spaces               to   w-sar-saa-flg          .
           move      rr-dat-sit-saa       to   w-sar-saa-ese          .
           move      rr-dat-sit-saa       to   w-sar-saa-pre          .
           subtract  1                    from w-sar-saa-pre          .
           if        w-sar-saa-pre        >    w-dnu-ife-ife-ese
                     move  "#"            to   w-sar-saa-flg          .
       int-srt-inp-050.
      *              *-------------------------------------------------*
      *              * Start su file [mmz]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGARC    "         to   f-key                  .
