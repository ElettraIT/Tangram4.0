      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione Piano dei conti              *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-dcp-000  thru  stp-srt-inp-dcp-999   .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Ciclo di scansione anagrafica prodotti                    *
      *    *-----------------------------------------------------------*
       stp-srt-inp-dcp-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
       stp-srt-inp-dcp-100.
      *              *-------------------------------------------------*
      *              * Start su file [dcp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRO    "         to   f-key                  .
           move      zero                 to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  stp-srt-inp-dcp-900.
       stp-srt-inp-dcp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read next da file [dcp]                         *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  stp-srt-inp-dcp-900.
       stp-srt-inp-dcp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
       stp-srt-inp-dcp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura scheda saldo prodotto               *
      *                  *---------------------------------------------*
           move      "P"                  to   w-det-sdo-mag-tar      .
           move      rf-dcp-num-pro       to   w-det-sdo-mag-arc      .
           perform   det-sdo-mag-000      thru det-sdo-mag-999        .
      *                  *---------------------------------------------*
      *                  * Lettura movimenti archivio archivio         *
      *                  *---------------------------------------------*
           move      "P"                  to   w-det-mov-mag-tar      .
           move      rf-dcp-num-pro       to   w-det-mov-mag-arc      .
           perform   det-mov-mag-000      thru det-mov-mag-999        .
       stp-srt-inp-dcp-500.
      *              *-------------------------------------------------*
      *              * Ciclo di confronto                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dif-cge-ctr      .
       stp-srt-inp-dcp-520.
           add       1                    to   w-det-dif-cge-ctr      .
           if        w-det-dif-cge-ctr    >    12
                     go to stp-srt-inp-dcp-800.
      *                  *---------------------------------------------*
      *                  * Determinazione differenze                   *
      *                  *---------------------------------------------*
           perform   det-dif-cge-000      thru det-dif-cge-999        .
           if        w-det-dif-cge-flg    =    spaces
                     go to stp-srt-inp-dcp-750.
       stp-srt-inp-dcp-600.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave                                      *
      *                  *---------------------------------------------*
           move      "P"                  to   srt-tip-arc            .
           move      rf-dcp-alf-pro       to   srt-alf-pro            .
           move      rf-dcp-num-pro       to   srt-num-pro            .
           move      w-det-dif-cge-mes    to   srt-mes-rif            .
      *                  *---------------------------------------------*
      *                  * Dati                                        *
      *                  *---------------------------------------------*
           move      rf-dcp-des-pro       to   srt-des-pro            .
           move      w-det-dif-cge-sdo    to   srt-sdo-mms            .
           move      w-det-dif-cge-mov    to   srt-sdo-mov            .
           move      w-det-dif-cge-dif    to   srt-sdo-dif            .
           move      w-det-dif-cge-fcs    to   srt-car-sca            .
           move      w-det-dif-cge-not    to   srt-not-rig            .
       stp-srt-inp-dcp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-dcp-750.
      *              *-------------------------------------------------*
      *              * Riciclo su controllo differenze                 *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-dcp-520.
       stp-srt-inp-dcp-800.
      *              *-------------------------------------------------*
      *              * Riciclo su Read Next [dcp]                      *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-dcp-200.
       stp-srt-inp-dcp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-dcp-999.
       stp-srt-inp-dcp-999.
           exit.

      *    *===========================================================*
