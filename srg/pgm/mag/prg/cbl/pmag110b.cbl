           move      "pgm/dpm/prg/obj/bzosdpm0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dpm                 .
           if        f-sts                =    "01"
                     move  01             to   rr-fso-dpm-ord
           else if   f-sts                =    "02"
                     move  02             to   rr-fso-dpm-ord
           else if   f-sts                =    "03"
                     move  03             to   rr-fso-dpm-ord
           else if   f-sts                =    "04"
                     move  04             to   rr-fso-dpm-ord
           else      move  01             to   rr-fso-dpm-ord         .
