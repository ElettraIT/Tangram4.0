      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Normalizzazione file [mau]                      *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmau"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mau                 .
      *              *-------------------------------------------------*
      *              * Lettura file [mau]                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "MAGUBI    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-mau-cod-dpz         .
           move      03                   to   rf-mau-tip-mag         .
           move      rf-dpm-num-map       to   rf-mau-num-mag         .
           move      spaces               to   rf-mau-var-mag         .
           move      "pgm/mag/fls/ioc/obj/iofmau"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mau                 .
           if        f-sts                not  = e-not-err
                     move  "N"            to   w-sel-ubi-snx
           else      move  "S"            to   w-sel-ubi-snx          .
       prn-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Se richieste tutte le materie prime             *
      *              *-------------------------------------------------*
           if        rr-snx-ubi           =    01
                     go to prn-sel-rec-999.
       prn-sel-rec-200.
      *              *-------------------------------------------------*
      *              * Se richiesti solo le materie prime con ubica-   *
      *              * zione                                           *
      *              *-------------------------------------------------*
           if        rr-snx-ubi           =    03
                     go to prn-sel-rec-300.
           if        w-sel-ubi-snx        not  = "S"
                     move  "#"            to   w-cnt-prn-flg-sub      .
           go to     prn-sel-rec-999.
       prn-sel-rec-300.
      *              *-------------------------------------------------*
      *              * Se richiesti solo le materie prime senza ubica- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           if        w-sel-ubi-snx        not  = "N"
                     move  "#"            to   w-cnt-prn-flg-sub      .
           go to     prn-sel-rec-999.
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
