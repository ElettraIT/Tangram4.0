      *    * Visualizzazione : Descrizione prodotto                    *
      *    *-----------------------------------------------------------*
       vis-alf-mag-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-rig-alf-mag-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-alf-mag-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo di ubicazione                   *
      *    *-----------------------------------------------------------*
       acc-rig-ubi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-rig-tip-ubi        not  = spaces
                     go to acc-rig-ubi-100.
           if        w-ref-def-tub-cod    =    spaces
                     go to acc-rig-ubi-100.
           move      w-ref-def-tub-cod    to   w-rig-tip-ubi          .
           perform   vis-rig-ubi-000      thru vis-rig-ubi-999        .
           go to     acc-rig-ubi-400.
       acc-rig-ubi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-zmu-ope      .
           move      w-tes-cod-dpz        to   w-cod-des-zmu-dpz      .
           move      w-rig-tip-ubi        to   w-cod-des-zmu-cod      .
           move      18                   to   w-cod-des-zmu-lin      .
           move      22                   to   w-cod-des-zmu-pos      .
           move      18                   to   w-cod-des-zmu-dln      .
           move      33                   to   w-cod-des-zmu-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-zmu-cll-000  thru cod-des-zmu-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-zmu-foi-000  thru cod-des-zmu-foi-999    .
       acc-rig-ubi-110.
           perform   cod-des-zmu-cll-000  thru cod-des-zmu-cll-999    .
           if        w-cod-des-zmu-ope    =    "F+"
                     go to acc-rig-ubi-115.
           if        w-cod-des-zmu-ope    =    "AC"
                     go to acc-rig-ubi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-rig-ubi-115.
           perform   cod-des-zmu-foi-000  thru cod-des-zmu-foi-999    .
           go to     acc-rig-ubi-110.
       acc-rig-ubi-120.
           move      w-cod-des-zmu-cod    to   v-alf                  .
       acc-rig-ubi-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-rig-ubi-999.
       acc-rig-ubi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-tip-ubi          .
       acc-rig-ubi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zmu]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-dpz        to   w-let-arc-zmu-dpz      .
           move      w-rig-tip-ubi        to   w-let-arc-zmu-cod      .
           perform   let-arc-zmu-000      thru let-arc-zmu-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori                       *
      *                  *---------------------------------------------*
           move      w-let-arc-zmu-des    to   w-rig-tip-ubi-des      .
           move      w-let-arc-zmu-pdu    to   w-rig-tip-ubi-pdu      .
           move      w-let-arc-zmu-dpu (1)
                                          to   w-rig-tip-ubi-dpu (1)  .
           move      w-let-arc-zmu-dpu (2)
                                          to   w-rig-tip-ubi-dpu (2)  .
           move      w-let-arc-zmu-dpu (3)
                                          to   w-rig-tip-ubi-dpu (3)  .
           move      w-let-arc-zmu-dpu (4)
                                          to   w-rig-tip-ubi-dpu (4)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-rig-ubi-des-000  thru vis-rig-ubi-des-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione parametri di ubicazione     *
      *                  *---------------------------------------------*
           perform   pmt-rig-ub1-000      thru pmt-rig-ub1-999        .
           perform   pmt-rig-ub2-000      thru pmt-rig-ub2-999        .
           perform   pmt-rig-ub3-000      thru pmt-rig-ub3-999        .
           perform   pmt-rig-ub4-000      thru pmt-rig-ub4-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non trovato : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-zmu-flg    not  = spaces
                     go to acc-rig-ubi-100.
       acc-rig-ubi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione eventuale dei parametri di  *
      *                  * ubicazione                                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-ubi-pdu    =    zero
                     go to acc-rig-ubi-610
           else if   w-rig-tip-ubi-pdu    =    1
                     go to acc-rig-ubi-620
           else if   w-rig-tip-ubi-pdu    =    2
                     go to acc-rig-ubi-630
           else if   w-rig-tip-ubi-pdu    =    3
                     go to acc-rig-ubi-640
           else      go to acc-rig-ubi-800.
       acc-rig-ubi-610.
           move      spaces               to   w-rig-prm-ubi (1)      .
           perform   vis-rig-ub1-000      thru vis-rig-ub1-999        .
       acc-rig-ubi-620.
           move      spaces               to   w-rig-prm-ubi (2)      .
           perform   vis-rig-ub2-000      thru vis-rig-ub2-999        .
       acc-rig-ubi-630.
           move      spaces               to   w-rig-prm-ubi (3)      .
           perform   vis-rig-ub3-000      thru vis-rig-ub3-999        .
       acc-rig-ubi-640.
           move      spaces               to   w-rig-prm-ubi (4)      .
           perform   vis-rig-ub4-000      thru vis-rig-ub4-999        .
       acc-rig-ubi-650.
           move      spaces               to   w-rig-not-ubi          .
           perform   vis-rig-not-000      thru vis-rig-not-999        .
       acc-rig-ubi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-rig-ubi-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-rig-ubi-100.
       acc-rig-ubi-999.
           exit.

