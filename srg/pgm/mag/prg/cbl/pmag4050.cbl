      *    * gazione e parametro relativo                              *
      *    *-----------------------------------------------------------*
       ipc-dlp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione work-area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-ipc-dlp-alf-pro      .
           move      zero                 to   w-ipc-dlp-dat-sit      .
      *              *-------------------------------------------------*
      *              * Estrazione della eventuale variabile di i.p.c.  *
      *              * "tip-int" per tipo interrogazione               *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "alf-pro"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Se variabile non esistente : uscita ad errore   *
      *              *-------------------------------------------------*
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      s-alf                to   w-ipc-dlp-alf-pro      .
      *              *-------------------------------------------------*
      *              * Estrazione variabile di i.p.c. "dat-sit"        *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "dat-sit"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
           if        s-dat                =    zero
                     go to ipc-dlp-900.
           move      s-dat                to   w-ipc-dlp-dat-sit      .
       ipc-dlp-900.
