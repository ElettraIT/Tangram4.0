                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-sin-max-100.
       acc-sin-max-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
      *              *-------------------------------------------------*
      *              * Controllo su tipo ordinamento                   *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = zero
                     go to tdo-ric-sel-005.
           move      "Tipo ordinamento errato !"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-005.
      *              *-------------------------------------------------*
      *              * Controllo su classe merceologica                *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = 4
                     go to tdo-ric-sel-010.
           if        rr-cla-pro           not  = zero
                     go to tdo-ric-sel-010.
           move      "Manca il codice classe merceologica"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-010.
      *              *-------------------------------------------------*
      *              * Controllo su gruppo merceologico                *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = 4
                     go to tdo-ric-sel-020.
           if        rr-cla-pro-sud       =    01
                     go to tdo-ric-sel-020.
           if        rr-gru-pro           not  = zero
                     go to tdo-ric-sel-020.
           move      "Manca il codice gruppo merceologico"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-020.
      *              *-------------------------------------------------*
      *              * Controllo su sottogruppo merceologico           *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = 4
                     go to tdo-ric-sel-040.
           if        rr-cla-pro-sud       =    01
                     go to tdo-ric-sel-040.
           if        rr-gru-pro-sud       =    01
                     go to tdo-ric-sel-040.
           if        rr-sgr-pro           not  = zero
                     go to tdo-ric-sel-040.
           move      "Manca il codice sottogruppo merceologico"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-040.
      *              *-------------------------------------------------*
      *              * Controllo su codice minimo e massimo            *
      *              *-------------------------------------------------*
           if        rr-cod-max           =    spaces
                     go to tdo-ric-sel-050.
           if        rr-cod-max           not  < rr-cod-min
                     go to tdo-ric-sel-050.
           move      "Errore tra i valori minimo e massimo del codice"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-050.
      *              *-------------------------------------------------*
      *              * Controllo su descrizione minima e massima       *
      *              *-------------------------------------------------*
           if        rr-des-max           =    spaces
                     go to tdo-ric-sel-060.
           if        rr-des-max           not  < rr-des-min
                     go to tdo-ric-sel-060.
           move      "Errore tra i valori minimo e massimo della descriz
      -              "ione"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-060.
      *              *-------------------------------------------------*
      *              * Controllo su sinonimo minimo e massimo          *
      *              *-------------------------------------------------*
           if        rr-sin-max           =    spaces
                     go to tdo-ric-sel-070.
           if        rr-sin-max           not  < rr-sin-min
                     go to tdo-ric-sel-070.
           move      "Errore tra i valori minimo e massimo del sinonimo"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-070.
      *              *-------------------------------------------------*
      *              * Test su data situazione                         *
      *              *-------------------------------------------------*
           if        rr-dat-sit           not  = zero
                     go to tdo-ric-sel-100.
           move      "Manca la data situazione !"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Uscita per controlli tutti superati             *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Regolarizzazione codice min - max               *
      *              *-------------------------------------------------*
           if        rr-cod-max           =    spaces
                     move  rr-cod-min     to   rr-cod-max             .
      *
           move      rr-cod-max           to   w-all-str-alf          .
           move      14                   to   w-all-str-lun          .
           perform   all-str-pad-000      thru all-str-pad-999        .
           move      w-all-str-alf        to   rr-cod-max             .
      *              *-------------------------------------------------*
      *              * Regolarizzazione descrizione min - max          *
      *              *-------------------------------------------------*
           if        rr-des-max           =    spaces
                     move  rr-des-min     to   rr-des-max             .
      *
           move      rr-des-max           to   w-all-str-alf          .
           move      40                   to   w-all-str-lun          .
           perform   all-str-pad-000      thru all-str-pad-999        .
           move      w-all-str-alf        to   rr-des-max             .
      *              *-------------------------------------------------*
      *              * Regolarizzazione sinonimo min - max             *
      *              *-------------------------------------------------*
           if        rr-sin-max           =    spaces
                     move  rr-sin-min     to   rr-sin-max             .
      *
           move      rr-sin-max           to   w-all-str-alf          .
           move      13                   to   w-all-str-lun          .
           perform   all-str-pad-000      thru all-str-pad-999        .
           move      w-all-str-alf        to   rr-sin-max             .
      *              *-------------------------------------------------*
      *              * Regolarizzazione Tipo giacenza                  *
      *              * zero                                            *
      *              *-------------------------------------------------*
           if        rr-tip-gia           =    zero
                     move  01             to   rr-tip-gia             .
      *              *-------------------------------------------------*
      *              * Regolarizzazione Si/No solo se saldo diverso da *
      *              * zero                                            *
      *              *-------------------------------------------------*
           if        rr-snx-zer           =    zero
                     move  01             to   rr-snx-zer             .
       reg-ric-sel-999.
           exit.

