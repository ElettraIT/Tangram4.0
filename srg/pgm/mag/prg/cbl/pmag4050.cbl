      *                  *---------------------------------------------*
           if        rr-dpz-inu           not  = zero
                     go to nor-ric-sel-100.
      *                  *---------------------------------------------*
      *                  * Preparazione contatori                      *
      *                  *---------------------------------------------*
           move      zero                 to   rr-dpz-ctr-sel         .
           move      zero                 to   w-cix-ctr-001          .
       nor-ric-sel-010.
           add       1                    to   w-cix-ctr-001          .
           if        w-cix-ctr-001        >    99
                     go to nor-ric-sel-100.
           if        w-dpz-ele-flg
                    (w-cix-ctr-001)       =    spaces
                     go to nor-ric-sel-010.
           add       1                    to   rr-dpz-ctr-sel         .
           if        rr-dpz-ctr-sel       >    99
                     go to nor-ric-sel-100.
           move      w-cix-ctr-001        to   rr-dpz-ele-cod
                                              (rr-dpz-ctr-sel)        .
           move      w-dpz-ele-den
                    (w-cix-ctr-001)       to   rr-dpz-ele-den
                                              (rr-dpz-ctr-sel)        .
      *                  *---------------------------------------------*
      *                  * Riciclo su elemento successivo              *
      *                  *---------------------------------------------*
           go to     nor-ric-sel-010.
       nor-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Normalizzazioni altri campi                     *
      *              *-------------------------------------------------*
           move      zero                 to   rr-tip-ord             .
           move      zero                 to   rr-cla-pro             .
           move      spaces               to   rr-cla-pro-des         .
           move      zero                 to   rr-cla-pro-sud         .
           move      zero                 to   rr-gru-pro             .
           move      spaces               to   rr-gru-pro-des         .
           move      zero                 to   rr-gru-pro-sud         .
           move      zero                 to   rr-sgr-pro             .
           move      spaces               to   rr-sgr-pro-des         .
           move      zero                 to   rr-sgr-pro-sud         .
           move      spaces               to   rr-des-min             .
           move      spaces               to   rr-des-max             .
           move      spaces               to   rr-cod-min             .
           move      spaces               to   rr-cod-max             .
           move      spaces               to   rr-sin-min             .
           move      spaces               to   rr-sin-max             .
           move      zero                 to   rr-dat-sit             .
           move      zero                 to   rr-tip-gia             .
           move      zero                 to   rr-snx-zer             .
       nor-ric-sel-999.
           exit.

