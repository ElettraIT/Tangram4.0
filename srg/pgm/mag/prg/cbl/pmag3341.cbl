      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     ssm-dpm-stp-act-350.
       ssm-dpm-stp-act-350.
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento correttivi di proprieta'   *
      *                  *---------------------------------------------*
           go to     ssm-dpm-stp-act-400.
       ssm-dpm-stp-act-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento Correttivi di proprieta'          *
      *              *-------------------------------------------------*
       ssm-dpm-stp-act-450.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo di trattamen- *
      *                  * to merce in conto                           *
      *                  *---------------------------------------------*
           if        w-ssm-dpm-mov-tmc    =    01
                     go to ssm-dpm-stp-act-475
           else if   w-ssm-dpm-mov-tmc    =    02
                     go to ssm-dpm-stp-act-500
           else if   w-ssm-dpm-mov-tmc    =    03
                     go to ssm-dpm-stp-act-525.
       ssm-dpm-stp-act-475.
      *                  *---------------------------------------------*
      *                  * Se tipo di trattamento merce in conto : 01, *
      *                  * cioe' il movimento puo' riferirsi ad un al- *
      *                  * tro movimento di merce in conto             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se e' citato un codice di merce in con- *
      *                      * to si esegue l'aggiornamento correttivi *
      *                      * di proprieta', altrimenti no            *
      *                      *-----------------------------------------*
           if        w-ssm-dpm-mov-cmc    not  = spaces
                     go to ssm-dpm-stp-act-600
           else      go to ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-500.
      *                  *---------------------------------------------*
      *                  * Se tipo di trattamento merce in conto : 02, *
      *                  * cioe' il movimento non puo' riferirsi a     *
      *                  * merce in conto                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non si esegue alcun aggiornamento       *
      *                      *-----------------------------------------*
           go to     ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-525.
      *                  *---------------------------------------------*
      *                  * Se tipo di trattamento merce in conto : 03, *
      *                  * cioe' il movimento stesso e' una movimenta- *
      *                  * zione di merce in conto                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si esegue l'aggiornamento               *
      *                      *-----------------------------------------*
           go to     ssm-dpm-stp-act-600.
       ssm-dpm-stp-act-600.
      *                  *---------------------------------------------*
      *                  * Aggiornamento correttivi di proprieta'      *
      *                  *---------------------------------------------*
       ssm-dpm-stp-act-650.
      *                      *-----------------------------------------*
      *                      * Se il tipo conto merce non e' tra quel- *
      *                      * li previsti : no aggiornamento          *
      *                      *-----------------------------------------*
           if        w-ssm-dpm-mov-xmc    not  = "N" and
                     w-ssm-dpm-mov-xmc    not  = "T"
                     go to ssm-dpm-stp-act-900.
      *                      *-----------------------------------------*
      *                      * Se manca il codice conto merce : no ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        w-ssm-dpm-mov-cmc    =    spaces
                     go to ssm-dpm-stp-act-900.
      *                      *-----------------------------------------*
      *                      * Se il tipo archivio non e' tra quelli   *
      *                      * previsti : no aggiornamento             *
      *                      *-----------------------------------------*
           if        w-ssm-dpm-mov-ati    not  = "C" and
                     w-ssm-dpm-mov-ati    not  = "F" and
                     w-ssm-dpm-mov-ati    not  = "V"
                     go to ssm-dpm-stp-act-900.
      *                      *-----------------------------------------*
      *                      * Se il codice archivio e' a zero : no    *
      *                      * aggiornamento                           *
      *                      *-----------------------------------------*
           if        w-ssm-dpm-mov-aco    =    zero
                     go to ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-700.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo movimento *
      *                      *-----------------------------------------*
           if        w-ssm-dpm-mov-tmo    =    01
                     go to ssm-dpm-stp-act-750
           else if   w-ssm-dpm-mov-tmo    =    02
                     go to ssm-dpm-stp-act-800
           else      go to ssm-dpm-stp-act-850.
       ssm-dpm-stp-act-750.
      *                      *-----------------------------------------*
      *                      * Se tipo di movimento 01 : Carico        *
      *                      *-----------------------------------------*
       ssm-dpm-stp-act-755.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo conto *
      *                          * merce                               *
      *                          *-------------------------------------*
           if        w-ssm-dpm-mov-xmc    =    "N"
                     go to ssm-dpm-stp-act-760
           else      go to ssm-dpm-stp-act-765.
       ssm-dpm-stp-act-760.
      *                          *-------------------------------------*
      *                          * Se merce Presso terzi               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Presso terzi'          *
      *                              *---------------------------------*
           if        w-ssm-dpm-mov-tmc    =    01
                     add      w-ssm-dpm-mov-qdm
                                          to   w-ssm-dpm-tpc-pfn
           else      subtract w-ssm-dpm-mov-qdm
                                          from w-ssm-dpm-tpc-pfn      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-765.
      *                          *-------------------------------------*
      *                          * Se merce Di terzi presso di noi     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Di terzi'              *
      *                              *---------------------------------*
           if        w-ssm-dpm-mov-tmc    =    01
                     subtract w-ssm-dpm-mov-qdm
                                          from w-ssm-dpm-tpc-pft
           else      add      w-ssm-dpm-mov-qdm
                                          to   w-ssm-dpm-tpc-pft      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-800.
      *                      *-----------------------------------------*
      *                      * Se tipo di movimento 02 : Scarico       *
      *                      *-----------------------------------------*
       ssm-dpm-stp-act-805.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo conto *
      *                          * merce                               *
      *                          *-------------------------------------*
           if        w-ssm-dpm-mov-xmc    =    "N"
                     go to ssm-dpm-stp-act-810
           else      go to ssm-dpm-stp-act-815.
       ssm-dpm-stp-act-810.
      *                          *-------------------------------------*
      *                          * Se merce Presso terzi               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Presso terzi'          *
      *                              *---------------------------------*
           if        w-ssm-dpm-mov-tmc    =    01
                     subtract w-ssm-dpm-mov-qdm
                                          from w-ssm-dpm-tpc-pfn
           else      add      w-ssm-dpm-mov-qdm
                                          to   w-ssm-dpm-tpc-pfn      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-815.
      *                          *-------------------------------------*
      *                          * Se merce Di terzi presso di noi     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Aggiornamento 'Proprieta' fine  *
      *                              * periodo, Di terzi'              *
      *                              *---------------------------------*
           if        w-ssm-dpm-mov-tmc    =    01
                     add      w-ssm-dpm-mov-qdm
                                          to   w-ssm-dpm-tpc-pft
           else      subtract w-ssm-dpm-mov-qdm
                                          from w-ssm-dpm-tpc-pft      .
      *                              *---------------------------------*
      *                              * Continuazione                   *
      *                              *---------------------------------*
           go to     ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-850.
      *                      *-----------------------------------------*
      *                      * Se tipo di movimento non riconosciuto   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     ssm-dpm-stp-act-900.
       ssm-dpm-stp-act-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ssm-dpm-stp-act-999.
       ssm-dpm-stp-act-999.
           exit.

      *    *===========================================================*
      *    * Stampa scheda elemento in esame, calcolo finale totali    *
      *    *-----------------------------------------------------------*
       ssm-dpm-stp-cft-000.
      *              *-------------------------------------------------*
      *              * Totali 'Magazzino fisico'                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 'Fine periodo'                              *
      *                  *---------------------------------------------*
           move      w-ssm-dpm-tpc-mfi    to   w-ssm-dpm-tpc-mff      .
           add       w-ssm-dpm-tpc-mfc    to   w-ssm-dpm-tpc-mff      .
           subtract  w-ssm-dpm-tpc-mfs    from w-ssm-dpm-tpc-mff      .
       ssm-dpm-stp-cft-100.
      *              *-------------------------------------------------*
      *              * Totali 'Proprieta' inizio periodo'              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 'Magazzino fisico'                          *
      *                  *---------------------------------------------*
           move      w-ssm-dpm-tpc-mfi    to   w-ssm-dpm-tpc-pim      .
      *                  *---------------------------------------------*
      *                  * 'Di proprieta''                             *
      *                  *---------------------------------------------*
           move      w-ssm-dpm-tpc-pim    to   w-ssm-dpm-tpc-pip      .
           add       w-ssm-dpm-tpc-pin    to   w-ssm-dpm-tpc-pip      .
           subtract  w-ssm-dpm-tpc-pit    from w-ssm-dpm-tpc-pip      .
       ssm-dpm-stp-cft-200.
      *              *-------------------------------------------------*
      *              * Totali 'Proprieta' fine periodo'                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 'Magazzino fisico'                          *
      *                  *---------------------------------------------*
           move      w-ssm-dpm-tpc-mff    to   w-ssm-dpm-tpc-pfm      .
      *                  *---------------------------------------------*
      *                  * 'Di proprieta''                             *
      *                  *---------------------------------------------*
           move      w-ssm-dpm-tpc-pfm    to   w-ssm-dpm-tpc-pfp      .
           add       w-ssm-dpm-tpc-pfn    to   w-ssm-dpm-tpc-pfp      .
           subtract  w-ssm-dpm-tpc-pft    from w-ssm-dpm-tpc-pfp      .
       ssm-dpm-stp-cft-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [zmc]                            *
      *    *-----------------------------------------------------------*
       let-arc-zmc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zmc-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione descrizione in uscita           *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zmc-des      .
      *              *-------------------------------------------------*
      *              * Se codice a zero : uscita                       *
      *              *-------------------------------------------------*
           if        w-let-arc-zmc-cod    =    zero
                     go to let-arc-zmc-999.
       let-arc-zmc-100.
      *              *-------------------------------------------------*
      *              * Lettura archivio [zmc]                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      w-let-arc-zmc-cod    to   rf-zmc-cod-cau         .
           move      "pgm/mag/fls/ioc/obj/iofzmc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zmc                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-zmc-900.
       let-arc-zmc-200.
      *              *-------------------------------------------------*
      *              * Se record esistente in [zmc]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione da [zmc]         *
      *                  *---------------------------------------------*
           move      rf-zmc-des-cau       to   w-let-arc-zmc-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zmc-999.
       let-arc-zmc-900.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita a : non esistente            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-let-arc-zmc-flg      .
      *                  *---------------------------------------------*
      *                  * Preparazione descrizione per record non e-  *
      *                  * sistente : 'Codice : (99999) ......'        *
      *                  *---------------------------------------------*
           move      w-let-arc-zmc-cod    to   w-let-arc-zmc-e11      .
           move      zero                 to   w-let-arc-zmc-e90      .
           inspect   w-let-arc-zmc-e10
                                      tallying w-let-arc-zmc-e90
                                  for leading spaces                  .
           add       1                    to   w-let-arc-zmc-e90      .
           move      spaces               to   w-let-arc-zmc-e20      .
           move      w-let-arc-zmc-e10
                    (w-let-arc-zmc-e90 :) to   w-let-arc-zmc-e20      .
           move      all   "."            to   w-let-arc-zmc-e30      .
           move      spaces               to   w-let-arc-zmc-des      .
           string    "Codice : ("
                                delimited by   size
                     w-let-arc-zmc-e20
                                delimited by   spaces
                     ") "
                                delimited by   size
                     w-let-arc-zmc-e30
                                delimited by   size
                                          into w-let-arc-zmc-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zmc-999.
       let-arc-zmc-999.
           exit.

