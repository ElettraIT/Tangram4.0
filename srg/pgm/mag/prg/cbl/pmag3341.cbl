                                  for leading spaces                  .
           add       1                    to   w-let-arc-dcx-e90      .
           move      spaces               to   w-let-arc-dcx-e20      .
           move      w-let-arc-dcx-e10
                    (w-let-arc-dcx-e90 :) to   w-let-arc-dcx-e20      .
           move      all   "."            to   w-let-arc-dcx-e30      .
           move      spaces               to   w-let-arc-dcx-rag      .
           string    "Codice : ("
                                delimited by   size
                     w-let-arc-dcx-e20
                                delimited by   spaces
                     ") "
                                delimited by   size
                     w-let-arc-dcx-e30
                                delimited by   size
                                          into w-let-arc-dcx-rag      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-dcx-999.
       let-arc-dcx-999.
           exit.

      *    *===========================================================*
      *    * Lettura archivio [dcf] o [fnt]                            *
      *    *-----------------------------------------------------------*
       let-arc-dfx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dfx-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione ragione sociale in uscita       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dfx-rag      .
      *              *-------------------------------------------------*
      *              * Se codice a zero : uscita                       *
      *              *-------------------------------------------------*
           if        w-let-arc-dfx-cod    =    zero
                     go to let-arc-dfx-999.
       let-arc-dfx-100.
      *              *-------------------------------------------------*
      *              * Lettura archivio [dcf]                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-let-arc-dfx-cod    to   rf-dcf-cod-fnt         .
           move      w-let-arc-dfx-dpz    to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-dfx-300.
       let-arc-dfx-200.
      *              *-------------------------------------------------*
      *              * Se record esistente in [dcf]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione ragione sociale da [dcf]     *
      *                  *---------------------------------------------*
           move      rf-dcf-rag-soc       to   w-let-arc-dfx-rag      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-dfx-999.
       let-arc-dfx-300.
      *              *-------------------------------------------------*
      *              * Se record non esistente in [dcf]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tentativo di lettura da [dcf] si ri-  *
      *                  * feriva ad una dipendenza, allora si prova   *
      *                  * a leggere l'anagrafica principale da [dcf], *
      *                  * altrimenti si prova a leggere l'anagrafica  *
      *                  * da [fnt]                                    *
      *                  *---------------------------------------------*
           if        w-let-arc-dfx-dpz    =    spaces
                     go to let-arc-dfx-700.
       let-arc-dfx-400.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcf], per l'anagrafica    *
      *                  * principale                                  *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-let-arc-dfx-cod    to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-dfx-600.
       let-arc-dfx-500.
      *                  *---------------------------------------------*
      *                  * Se record esistente in [dcf]                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Memorizzazione ragione sociale da [dcf] *
      *                      *-----------------------------------------*
           move      rf-dcf-rag-soc       to   w-let-arc-dfx-rag      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-dfx-999.
       let-arc-dfx-600.
      *                  *---------------------------------------------*
      *                  * Se record non esistente in [dcf]            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A lettura record da [fnt]               *
      *                      *-----------------------------------------*
           go to     let-arc-dfx-700.
       let-arc-dfx-700.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [fnt]                      *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-let-arc-dfx-cod    to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-dfx-900.
       let-arc-dfx-800.
      *                  *---------------------------------------------*
      *                  * Se record esistente in [fnt]                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Memorizzazione ragione sociale da [fnt] *
      *                      *-----------------------------------------*
           move      rf-fnt-rag-soc       to   w-let-arc-dfx-rag      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-dfx-999.
       let-arc-dfx-900.
      *                  *---------------------------------------------*
      *                  * Se record non esistente in [fnt]            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita a : non esistente        *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-dfx-flg      .
      *                      *-----------------------------------------*
      *                      * Preparazione ragione sociale per record *
      *                      * non esistente : 'Codice : (9999999) ..' *
      *                      *-----------------------------------------*
           move      w-let-arc-dfx-cod    to   w-let-arc-dfx-e11      .
           move      zero                 to   w-let-arc-dfx-e90      .
           inspect   w-let-arc-dfx-e10
                                      tallying w-let-arc-dfx-e90
                                  for leading spaces                  .
           add       1                    to   w-let-arc-dfx-e90      .
           move      spaces               to   w-let-arc-dfx-e20      .
           move      w-let-arc-dfx-e10
                    (w-let-arc-dfx-e90 :) to   w-let-arc-dfx-e20      .
           move      all   "."            to   w-let-arc-dfx-e30      .
           move      spaces               to   w-let-arc-dfx-rag      .
           string    "Codice : ("
                                delimited by   size
                     w-let-arc-dfx-e20
                                delimited by   spaces
                     ") "
                                delimited by   size
                     w-let-arc-dfx-e30
                                delimited by   size
                                          into w-let-arc-dfx-rag      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-dfx-999.
       let-arc-dfx-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [dpz]                            *
      *    *                                                           *
      *    * Si presume che il programma chiamante abbia preventiva-   *
      *    * mente richiamato la funzione di  "determinazione dipen-   *
      *    * denze esistenti per l'azienda" e che pertanto la tabel-   *
      *    * la dipendenze w-dpz-tbl-dpz risulti carica di valori      *
      *    *-----------------------------------------------------------*
       let-arc-dpz-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dpz-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione descrizione in uscita           *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dpz-des      .
      *              *-------------------------------------------------*
      *              * Se codice a zero : uscita                       *
      *              *-------------------------------------------------*
           if        w-let-arc-dpz-cod    =    zero
                     go to let-arc-dpz-999.
       let-arc-dpz-100.
      *              *-------------------------------------------------*
      *              * Se codice dipendenza non accettabile : come per *
      *              * record non esistente                            *
      *              *-------------------------------------------------*
           if        w-let-arc-dpz-cod    <    01 or
                     w-let-arc-dpz-cod    >    99
                     go to let-arc-dpz-900.
      *              *-------------------------------------------------*
      *              * Se dipendenza non memorizzata : come per record *
      *              * non esistente                                   *
      *              *-------------------------------------------------*
           if        w-dpz-ele-flg
                    (w-let-arc-dpz-cod)   =    spaces
                     go to let-arc-dpz-900.
       let-arc-dpz-200.
      *              *-------------------------------------------------*
      *              * Record esistente                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione da tabella pre-  *
      *                  * caricata                                    *
      *                  *---------------------------------------------*
           move      w-dpz-ele-den
                    (w-let-arc-dpz-cod)   to   w-let-arc-dpz-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-dpz-999.
       let-arc-dpz-900.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita a : non esistente            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-let-arc-dpz-flg      .
      *                  *---------------------------------------------*
      *                  * Preparazione descrizione per record non e-  *
      *                  * sistente : 'Codice : (99) ......'           *
      *                  *---------------------------------------------*
           move      w-let-arc-dpz-cod    to   w-let-arc-dpz-e11      .
           move      zero                 to   w-let-arc-dpz-e90      .
           inspect   w-let-arc-dpz-e10
                                      tallying w-let-arc-dpz-e90
                                  for leading spaces                  .
           add       1                    to   w-let-arc-dpz-e90      .
           move      spaces               to   w-let-arc-dpz-e20      .
           move      w-let-arc-dpz-e10
                    (w-let-arc-dpz-e90 :) to   w-let-arc-dpz-e20      .
           move      all   "."            to   w-let-arc-dpz-e30      .
           move      spaces               to   w-let-arc-dpz-des      .
           string    "Codice : ("
                                delimited by   size
                     w-let-arc-dpz-e20
                                delimited by   spaces
                     ") "
                                delimited by   size
                     w-let-arc-dpz-e30
                                delimited by   size
                                          into w-let-arc-dpz-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-dpz-999.
       let-arc-dpz-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per la stampa di una quantita'                 *
      *    *-----------------------------------------------------------*
       stp-qta-mag-000.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        w-stp-qta-qta        >    99999999 or
                     w-stp-qta-qta        <   -99999999
                     move  10             to   p-car
                     move  "D"            to   p-edm
           else      move  08             to   p-car
                     move  "G"            to   p-edm                  .
           move      w-stp-qta-dec        to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-qta-pos        to   p-pos                  .
           move      w-stp-qta-qta        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-qta-mag-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-qta-mag-999.
       stp-qta-mag-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [age]                         *
      *    *-----------------------------------------------------------*
       let-arc-age-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-age-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a zero                           *
      *              *-------------------------------------------------*
           if        w-let-arc-age-cod    =    zero
                     go to let-arc-age-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODAGE"             to   f-key                  .
           move      w-let-arc-age-cod    to   rf-age-cod-age         .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-age-400.
       let-arc-age-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-age-nom-age       to   w-let-arc-age-nom      .
           move      rf-age-rag-soc       to   w-let-arc-age-rag      .
           move      rf-age-via-age       to   w-let-arc-age-via      .
           move      rf-age-loc-age       to   w-let-arc-age-loc      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-age-999.
       let-arc-age-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-age-flg      .
           move      all   "."            to   w-let-arc-age-nom      .
           go to     let-arc-age-600.
       let-arc-age-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-age-nom      .
       let-arc-age-600.
           move      spaces               to   w-let-arc-age-rag      .
           move      spaces               to   w-let-arc-age-via      .
           move      spaces               to   w-let-arc-age-loc      .
       let-arc-age-999.
           exit.

