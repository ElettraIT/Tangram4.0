      *    *===========================================================*
      *    * Subroutines per determinazione valore unitario di magaz-  *
      *    * zino                                                      *
      *    *-----------------------------------------------------------*
       det-vun-mag-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-vun-mag-tip-ope      .
           perform   det-vun-mag-cll-000  thru det-vun-mag-cll-999    .
       det-vun-mag-opn-999.
           exit.

       det-vun-mag-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-vun-mag-tip-ope      .
           perform   det-vun-mag-cll-000  thru det-vun-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-vun-mag-tip-ope      .
           perform   det-vun-mag-cll-000  thru det-vun-mag-cll-999    .
           if        d-vun-mag-exi-sts    not  = spaces
                     go to det-vun-mag-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       det-vun-mag-cls-999.
           exit.

       det-vun-mag-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/mag/prg/obj/pmag300v"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-vun-mag              .
       det-vun-mag-cll-999.
           exit.

