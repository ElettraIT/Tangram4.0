      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice provincia       *
      *    *-----------------------------------------------------------*
       cod-des-prv-opn-000.
           move      "pgm/geo/prg/obj/acdeprv0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-des-prv-pth      .
           move      "OP"                 to   w-cod-des-prv-ope      .
           perform   cod-des-prv-cll-000  thru cod-des-prv-cll-999    .
       cod-des-prv-opn-999.
           exit.
       cod-des-prv-cls-000.
           move      "CL"                 to   w-cod-des-prv-ope      .
           perform   cod-des-prv-cll-000  thru cod-des-prv-cll-999    .
           move      "C?"                 to   w-cod-des-prv-ope      .
           perform   cod-des-prv-cll-000  thru cod-des-prv-cll-999    .
           if        w-cod-des-prv-ope    not  = spaces
                     go to cod-des-prv-cls-999.
           cancel    w-cod-des-prv-pth                                .
       cod-des-prv-cls-999.
           exit.
       cod-des-prv-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-des-prv-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pgeo3000"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-des-prv-foi-999.
           move      "pgm/geo/prg/obj/pgeo3000"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-des-prv-ope      .
           go to     cod-des-prv-foi-999.
       cod-des-prv-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-des-prv-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pgeo3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-des-prv-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/geo/prg/obj/pgeo3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-des-prv-ope      .
           go to     cod-des-prv-foi-999.
       cod-des-prv-foi-999.
           exit.
       cod-des-prv-cll-000.
           call      w-cod-des-prv-pth   using w-cod-des-prv
                                               v
                                               s                      .
       cod-des-prv-cll-999.
           exit.

