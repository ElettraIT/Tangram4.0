      *              *-------------------------------------------------*
           perform   ric-cnf-man-000      thru ric-cnf-man-999        .
      *              *-------------------------------------------------*
      *              * Se non confermato : ad uscita                   *
      *              *-------------------------------------------------*
           if        f-xxx-sts            not  = "S"
                     go to exe-agg-cli-999.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Numero records letti e scritti a zero           *
      *              *-------------------------------------------------*
           move      zero                 to   f-xxx-nrl              .
           move      zero                 to   f-xxx-nrs              .
       exe-agg-cli-050.
      *              *-------------------------------------------------*
      *              * [cli]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-xxx-opf              .
           perform   exe-agg-cli-opf-000  thru exe-agg-cli-opf-999    .
       exe-agg-cli-100.
      *              *-------------------------------------------------*
      *              * Start su [cli]                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Operazione                                  *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-xxx-opf              .
           move      "NL"                 to   f-cfr                  .
           move      "CODCLI    "         to   f-key                  .
           move      zero                 to   rf-cli-cod-cli         .
           perform   exe-agg-cli-opf-000  thru exe-agg-cli-opf-999    .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a close file              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-agg-cli-800.
       exe-agg-cli-200.
      *              *-------------------------------------------------*
      *              * Get next su [cli]                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Operazione                                  *
      *                  *---------------------------------------------*
           move      "GN"                 to   f-xxx-opf              .
           perform   exe-agg-cli-opf-000  thru exe-agg-cli-opf-999    .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a close file                  *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to exe-agg-cli-300.
      *                  *---------------------------------------------*
      *                  * Rilascio del record                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-xxx-opf              .
           perform   exe-agg-cli-opf-000  thru exe-agg-cli-opf-999    .
      *                  *---------------------------------------------*
      *                  * A close                                     *
      *                  *---------------------------------------------*
           go to     exe-agg-cli-800.
       exe-agg-cli-300.
      *              *-------------------------------------------------*
      *              * Max su [cli], se non superato : a close file    *
      *              *-------------------------------------------------*
       exe-agg-cli-400.
      *              *-------------------------------------------------*
      *              * Sel su [cli]                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
