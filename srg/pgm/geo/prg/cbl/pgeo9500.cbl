      *                  *---------------------------------------------*
           if        rf-cli-cod-naz       =    "IT "
                     go to exe-agg-cli-420.
      *                  *---------------------------------------------*
      *                  * A riciclo con release                       *
      *                  *---------------------------------------------*
           go to     exe-agg-cli-690.
       exe-agg-cli-420.
      *                  *---------------------------------------------*
      *                  * Test se CAP nella stringa localita'         *
      *                  *---------------------------------------------*
           move      rf-cli-loc-cli       to   w-wrk-cap-str          .
           if        w-wrk-cap-num        numeric
                     go to exe-agg-cli-500.
      *                  *---------------------------------------------*
      *                  * A riciclo con release                       *
      *                  *---------------------------------------------*
           go to     exe-agg-cli-690.
       exe-agg-cli-500.
      *              *-------------------------------------------------*
      *              * Incremento numero records letti                 *
      *              *-------------------------------------------------*
           perform   inc-rec-let-000      thru inc-rec-let-999        .
       exe-agg-cli-510.
      *              *-------------------------------------------------*
      *              * Trattamento localita'                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se presenti coordinate 'geo'           *
      *                  *---------------------------------------------*
           if        rf-cli-cod-cmn       =   zero and
                     rf-cli-cod-fzn       =   zero and
                     rf-cli-cod-lct       =   zero
                     go to exe-agg-cli-600.
      *                  *---------------------------------------------*
      *                  * Lettura [gxc]                               *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      rf-cli-cod-cmn       to   rf-gxc-cod-cmn         .
           move      rf-cli-cod-fzn       to   rf-gxc-cod-fzn         .
           move      rf-cli-cod-lct       to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-agg-cli-600.
       exe-agg-cli-520.
      *                  *---------------------------------------------*
      *                  * Esclusione elementi con stradario           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su sigla stradario                 *
      *                      *-----------------------------------------*
           if        rf-gxc-sgl-std       =    spaces
                     go to exe-agg-cli-540.
      *                      *-----------------------------------------*
      *                      * Test su CAP                             *
      *                      *-----------------------------------------*
           if        rf-cli-loc-cli
                    (04 : 02)             not = "00"
                     go to exe-agg-cli-690.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore stradario           *
      *                      *-----------------------------------------*
           move      "cli"                to   w-ide-tip              .
           move      rf-cli-cod-cli       to   w-ide-num              .
           move      rf-cli-loc-cli       to   w-ide-lc1              .
           perform   exe-err-str-msg-000  thru exe-err-str-msg-999    .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     exe-agg-cli-690.
       exe-agg-cli-540.
      *                  *---------------------------------------------*
      *                  * Esclusione elementi senza CAP               *
      *                  *---------------------------------------------*
           if        rf-gxc-cap-avp       =    spaces
                     go to exe-agg-cli-690.
      *                  *---------------------------------------------*
      *                  * Confronto del CAP                           *
      *                  *---------------------------------------------*
           if        rf-gxc-cap-avp       =    w-wrk-cap-str
                     go to exe-agg-cli-690.
      *                  *---------------------------------------------*
      *                  * Aggiornamento CAP                           *
      *                  *---------------------------------------------*
           move      rf-cli-loc-cli       to   w-wrk-sav-loc          .
           move      rf-gxc-cap-avp       to   rf-cli-loc-cli
                                              (01 : 05)               .
      *                  *---------------------------------------------*
      *                  * A update                                    *
      *                  *---------------------------------------------*
           go to     exe-agg-cli-680.
       exe-agg-cli-600.
      *                  *---------------------------------------------*
      *                  * Se non presenti coordinate 'geo'            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tentativo di lettura delle coordinate   *
      *                      * geografiche in base alla descrizione    *
      *                      * del comune pulita con controllo sul     *
      *                      * codice provincia                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione codice provincia     *
      *                          *-------------------------------------*
           move      spaces               to   w-det-cap-cfl-prv      .
           move      40                   to   w-wrk-ctr-004          .
           move      zero                 to   w-wrk-ctr-003          .
           inspect   rf-cli-loc-cli   tallying w-wrk-ctr-003
                                  for trailing spaces                 .
           subtract  w-wrk-ctr-003        from w-wrk-ctr-004          .
           subtract  2                    from w-wrk-ctr-004
                                        giving w-wrk-ctr-005          .
           if        rf-cli-loc-cli
                    (w-wrk-ctr-005 : 01)  not  = spaces
                     go to exe-agg-cli-690.
           add       1                    to   w-wrk-ctr-005          .
           move      rf-cli-loc-cli
                    (w-wrk-ctr-005 : 02)  to   w-det-cap-cfl-prv      .
           if        w-det-cap-cfl-prv    =    spaces
                     go to exe-agg-cli-690.
      *                          *-------------------------------------*
      *                          * Determinazione CAP                  *
      *                          *-------------------------------------*
           move      rf-cli-loc-cli       to   w-det-cap-cfl-wcp      .
      *                          *-------------------------------------*
      *                          * Determinazione localita'            *
      *                          *-------------------------------------*
           move      rf-cli-loc-cli       to   w-det-cap-cfl-wds      .
           move      spaces               to   w-det-cap-cfl-wds
                                              (w-wrk-ctr-005 : 02)    .
           move      w-det-cap-cfl-wds
                    (07 : 34)             to   w-det-cap-cfl-wds      .
           move      w-det-cap-cfl-wds    to   w-det-cap-cfl-cfl      .
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           perform   det-cap-cfl-000      thru det-cap-cfl-999        .
      *                          *-------------------------------------*
      *                          * Test su esito della lettura         *
      *                          *-------------------------------------*
           if        w-det-cap-cfl-flg    not  = spaces
                     go to exe-agg-cli-690.
      *                          *-------------------------------------*
      *                          * Esclusione elementi senza CAP       *
      *                          *-------------------------------------*
           if        w-det-cap-cfl-wcp    =    spaces or
                     w-det-cap-cfl-cap    =    spaces
                     go to exe-agg-cli-690.
      *                          *-------------------------------------*
      *                          * Confronto del CAP                   *
      *                          *-------------------------------------*
           if        w-det-cap-cfl-cap    =    w-det-cap-cfl-wcp
                     go to exe-agg-cli-690.
      *                          *-------------------------------------*
      *                          * Aggiornamento CAP                   *
      *                          *-------------------------------------*
           move      rf-cli-loc-cli       to   w-wrk-sav-loc          .
           move      w-det-cap-cfl-cap    to   rf-cli-loc-cli
                                              (01 : 05)               .
      *                          *-------------------------------------*
      *                          * A update                            *
      *                          *-------------------------------------*
           go to     exe-agg-cli-680.
       exe-agg-cli-680.
      *              *-------------------------------------------------*
      *              * Update record [cli]                             *
      *              *-------------------------------------------------*
