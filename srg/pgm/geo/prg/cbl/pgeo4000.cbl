      *              * cuote anche su frazioni e localita' : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-cod-prv (1)    not  = w-tes-cod-prv (2)
                     go to nor-fra-loc-100.
           if        w-tes-cap-avp (1)    not  = w-tes-cap-avp (2)
                     go to nor-fra-loc-100.
           if        w-tes-sgl-std (1)    not  = w-tes-sgl-std (2)
                     go to nor-fra-loc-100.
           if        w-tes-pre-tel (1, 1) not  = w-tes-pre-tel (2, 1)
                     go to nor-fra-loc-100.
           if        w-tes-pre-tel (1, 2) not  = w-tes-pre-tel (2, 2)
                     go to nor-fra-loc-100.
           go to     nor-fra-loc-999.
       nor-fra-loc-100.
      *              *-------------------------------------------------*
      *              * Start                                           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      "GT"                 to   f-cfr                  .
           move      w-tes-cod-cmn        to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
