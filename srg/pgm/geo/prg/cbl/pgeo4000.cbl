      *    *===========================================================*
      *    * Accettazione campo : Prefissi telefonici                  *
      *    *-----------------------------------------------------------*
       acc-pre-tel-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-pre-tel-025.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti               *
      *                  *---------------------------------------------*
           move      w-tes-pre-tel (1, 1) to   w-sav-pre-tel (1)      .
           move      w-tes-pre-tel (1, 2) to   w-sav-pre-tel (2)      .
       acc-pre-tel-050.
      *                  *---------------------------------------------*
      *                  * Preparazione default                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non Inserimento, no default          *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-tel-075.
      *                      *-----------------------------------------*
      *                      * Se valori gia' presenti, no default     *
      *                      *-----------------------------------------*
           if        w-tes-pre-tel (1, 1) not  = spaces or
                     w-tes-pre-tel (1, 2) not  = spaces
                     go to acc-pre-tel-075.
      *                      *-----------------------------------------*
      *                      * Se tipo elemento 'C', no default        *
      *                      *-----------------------------------------*
           if        w-tes-tip-ele        =    "C"
                     go to acc-pre-tel-075.
      *                      *-----------------------------------------*
      *                      * Se tipo elemento 'F' o 'L' si propongo- *
      *                      * no i prefissi telefonici del comune di  *
      *                      * appartenenza                            *
      *                      *-----------------------------------------*
           move      w-tes-cod-cmn        to   w-let-arc-gxc-cmn      .
           move      zero                 to   w-let-arc-gxc-fzn      .
           move      zero                 to   w-let-arc-gxc-lct      .
           perform   let-arc-gxc-000      thru let-arc-gxc-999        .
           if        w-let-arc-gxc-flg    not  = spaces
                     go to acc-pre-tel-075.
           move      w-let-arc-gxc-pte (1)
                                          to   w-tes-pre-tel (1, 1)   .
           move      w-let-arc-gxc-pte (2)
                                          to   w-tes-pre-tel (1, 2)   .
           perform   vis-pre-tel-000      thru vis-pre-tel-999        .
       acc-pre-tel-075.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..02           *
      *                  *---------------------------------------------*
           move      01                   to   w-edt-ctr-001          .
       acc-pre-tel-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      w-edt-ctr-001        to   v-pos                  .
           if        w-edt-ctr-001        >    02
                     subtract  02         from v-pos                  .
           multiply  06                   by   v-pos                  .
           add       28                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-pre-tel
                    (1, w-edt-ctr-001)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-tel-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-tel-999.
       acc-pre-tel-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-pre-tel
                                              (1, w-edt-ctr-001)      .
       acc-pre-tel-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se spaces : nessun controllo                *
      *                  *---------------------------------------------*
           if        w-tes-pre-tel
                    (1, w-edt-ctr-001)    =    spaces
                     go to acc-pre-tel-600.
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-pre-tel
                    (1, w-edt-ctr-001)    to   w-all-str-alf          .
           move      30                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-pre-tel-100.
      *                  *---------------------------------------------*
      *                  * Test che il prefisso sia numerico           *
      *                  *---------------------------------------------*
           move      w-tes-pre-tel
                    (1, w-edt-ctr-001)    to   w-ctl-cap-avp-alf      .
           inspect   w-ctl-cap-avp-alf
                                     replacing all spaces by "0"      .
           if        w-ctl-cap-avp-num    not  numeric
                     go to acc-pre-tel-100.
      *                  *---------------------------------------------*
      *                  * Test che il prefisso non sia a zero         *
      *                  *---------------------------------------------*
           if        w-ctl-cap-avp-alf    =    "00000"
                     go to acc-pre-tel-100.
       acc-pre-tel-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pre-tel-650
           else if   v-key                =    "DOWN"
                     go to acc-pre-tel-700
           else if   v-key                =    "DO  "
                     go to acc-pre-tel-800
           else      go to acc-pre-tel-710.
       acc-pre-tel-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-edt-ctr-001        =    1
                     go to acc-pre-tel-999.
           subtract  1                    from w-edt-ctr-001          .
           go to     acc-pre-tel-100.
       acc-pre-tel-700.
      *              *-------------------------------------------------*
      *              * Se Down : uscita                                *
      *              *-------------------------------------------------*
           go to     acc-pre-tel-999.
       acc-pre-tel-710.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        w-edt-ctr-001        =    02
                     go to acc-pre-tel-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-edt-ctr-001          .
           go to     acc-pre-tel-100.
       acc-pre-tel-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-tel-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-tel-100.
       acc-pre-tel-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Prefissi telefonici               *
      *    *-----------------------------------------------------------*
       vis-pre-tel-000.
           move      spaces               to   w-edt-pre-tel          .
           move      zero                 to   w-edt-ctr-001          .
       vis-pre-tel-200.
           add       1                    to   w-edt-ctr-001          .
           if        w-edt-ctr-001        >    02
                     go to vis-pre-tel-500.
           move      w-tes-pre-tel 
                    (1, w-edt-ctr-001)    to   w-edt-cst-ele
                                              (w-edt-ctr-001)         .
           go to     vis-pre-tel-200.
       vis-pre-tel-500.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      22                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      w-edt-pre-tel        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-pre-tel-999.
           exit.

