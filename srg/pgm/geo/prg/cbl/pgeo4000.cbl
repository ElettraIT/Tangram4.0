      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
       nor-fra-loc-300.
      *              *-------------------------------------------------*
      *              * Get next                                        *
      *              *-------------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *              *-------------------------------------------------*
      *              * Se fine file : uscita                           *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to nor-fra-loc-900.
       nor-fra-loc-400.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
           if        rf-gxc-cod-cmn       not  = w-tes-cod-cmn
                     go to nor-fra-loc-900.
       nor-fra-loc-500.
      *              *-------------------------------------------------*
      *              * Selezione                                       *
      *              *-------------------------------------------------*
       nor-fra-loc-525.
      *                  *---------------------------------------------*
      *                  * Se comune : ignora                          *
      *                  *---------------------------------------------*
           if        rf-gxc-cod-fzn       =    zero and
                     rf-gxc-cod-lct       =    zero
                     go to nor-fra-loc-200.
       nor-fra-loc-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento record                            *
      *              *-------------------------------------------------*
       nor-fra-loc-610.
      *                  *---------------------------------------------*
      *                  * Numero campi aggiornati a zero              *
      *                  *---------------------------------------------*
           move      zero                 to   w-nor-fra-loc-ctr      .
       nor-fra-loc-620.
      *                  *---------------------------------------------*
      *                  * Codice provincia                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il valore e' comunque gia diverso    *
      *                      * dal valore precedente : no aggiorna-    *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        rf-gxc-cod-prv       not  = w-tes-cod-prv (2)
                     go to nor-fra-loc-630.
      *                      *-----------------------------------------*
      *                      * Se gia' pari al valore attuale : no ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        rf-gxc-cod-prv       =    w-tes-cod-prv (1)
                     go to nor-fra-loc-630.
      *                      *-----------------------------------------*
      *                      * Incremento numero campi aggiornati      *
      *                      *-----------------------------------------*
           add       1                    to   w-nor-fra-loc-ctr      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           move      w-tes-cod-prv (1)    to   rf-gxc-cod-prv         .
       nor-fra-loc-630.
      *                  *---------------------------------------------*
      *                  * C.a.p.                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il valore e' comunque gia diverso    *
      *                      * dal valore precedente : no aggiorna-    *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        rf-gxc-cap-avp       not  = w-tes-cap-avp (2)
                     go to nor-fra-loc-640.
      *                      *-----------------------------------------*
      *                      * Se gia' pari al valore attuale : no ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        rf-gxc-cap-avp       =    w-tes-cap-avp (1)
                     go to nor-fra-loc-640.
      *                      *-----------------------------------------*
      *                      * Incremento numero campi aggiornati      *
      *                      *-----------------------------------------*
           add       1                    to   w-nor-fra-loc-ctr      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           move      w-tes-cap-avp (1)    to   rf-gxc-cap-avp         .
       nor-fra-loc-640.
      *                  *---------------------------------------------*
      *                  * Sigla dello stradario                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il valore e' comunque gia diverso    *
      *                      * dal valore precedente : no aggiorna-    *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        rf-gxc-sgl-std       not  = w-tes-sgl-std (2)
                     go to nor-fra-loc-650.
      *                      *-----------------------------------------*
      *                      * Se gia' pari al valore attuale : no ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        rf-gxc-sgl-std       =    w-tes-sgl-std (1)
                     go to nor-fra-loc-650.
      *                      *-----------------------------------------*
      *                      * Incremento numero campi aggiornati      *
      *                      *-----------------------------------------*
           add       1                    to   w-nor-fra-loc-ctr      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           move      w-tes-sgl-std (1)    to   rf-gxc-sgl-std         .
       nor-fra-loc-650.
      *                  *---------------------------------------------*
      *                  * Prefissi telefonici                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il valore e' comunque gia diverso    *
      *                      * dal valore precedente : no aggiorna-    *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        rf-gxc-pre-tel (1)   not  = w-tes-pre-tel (2, 1)
                     go to nor-fra-loc-700.
           if        rf-gxc-pre-tel (2)   not  = w-tes-pre-tel (2, 2)
                     go to nor-fra-loc-700.
      *                      *-----------------------------------------*
      *                      * Se gia' pari al valore attuale : no ag- *
      *                      * giornamento                             *
      *                      *-----------------------------------------*
           if        rf-gxc-pre-tel (1)   not  = w-tes-pre-tel (1, 1)
                     go to nor-fra-loc-655.
           if        rf-gxc-pre-tel (2)   not  = w-tes-pre-tel (1, 2)
                     go to nor-fra-loc-655.
           go to     nor-fra-loc-700.
       nor-fra-loc-655.
      *                      *-----------------------------------------*
      *                      * Incremento numero campi aggiornati      *
      *                      *-----------------------------------------*
           add       1                    to   w-nor-fra-loc-ctr      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           move      w-tes-pre-tel (1, 1) to   rf-gxc-pre-tel (1)     .
           move      w-tes-pre-tel (1, 2) to   rf-gxc-pre-tel (2)     .
       nor-fra-loc-700.
      *              *-------------------------------------------------*
      *              * Se nessun campo aggiornato : ignora             *
      *              *-------------------------------------------------*
           if        w-nor-fra-loc-ctr    =    zero
                     go to nor-fra-loc-200.
