           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
      *              *-------------------------------------------------*
      *              * Deviazione secondo il tipo elemento             *
      *              *-------------------------------------------------*
           if        w-tes-tip-ele        =    "C"
                     go to cnt-tdo-key-200
           else if   w-tes-tip-ele        =    "F"
                     go to cnt-tdo-key-400
           else if   w-tes-tip-ele        =    "L"
                     go to cnt-tdo-key-600
           else      go to cnt-tdo-key-900.
       cnt-tdo-key-200.
      *              *-------------------------------------------------*
      *              * Se tipo elemento 'C'                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se manca il codice comune : errore          *
      *                  *---------------------------------------------*
           if        w-tes-cod-cmn        =    zero
                     go to cnt-tdo-key-900.
      *                  *---------------------------------------------*
      *                  * Altrimenti : Ok                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Defaults per ciclo successivo           *
      *                      *-----------------------------------------*
           move      "C"                  to   w-def-tip-ele          .
           move      zero                 to   w-def-cod-cmn          .
           move      zero                 to   w-def-cod-fzn          .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     cnt-tdo-key-999.
       cnt-tdo-key-400.
      *              *-------------------------------------------------*
      *              * Se tipo elemento 'F'                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se manca il codice comune : errore          *
      *                  *---------------------------------------------*
           if        w-tes-cod-cmn        =    zero
                     go to cnt-tdo-key-900.
      *                  *---------------------------------------------*
      *                  * Se codice comune non esistente : errore     *
      *                  *---------------------------------------------*
           move      w-tes-cod-cmn        to   w-let-arc-gxc-cmn      .
           move      zero                 to   w-let-arc-gxc-fzn      .
           move      zero                 to   w-let-arc-gxc-lct      .
           perform   let-arc-gxc-000      thru let-arc-gxc-999        .
           move      w-let-arc-gxc-des    to   w-tes-cod-cmn-des      .
           if        w-let-arc-gxc-flg    not  = spaces
                     go to cnt-tdo-key-900.
      *                  *---------------------------------------------*
      *                  * Se manca il codice frazione : errore        *
      *                  *---------------------------------------------*
           if        w-tes-cod-fzn        =    zero
                     go to cnt-tdo-key-900.
      *                  *---------------------------------------------*
      *                  * Altrimenti : Ok                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Defaults per ciclo successivo           *
      *                      *-----------------------------------------*
           move      "F"                  to   w-def-tip-ele          .
           move      w-tes-cod-cmn        to   w-def-cod-cmn          .
           move      zero                 to   w-def-cod-fzn          .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     cnt-tdo-key-999.
       cnt-tdo-key-600.
      *              *-------------------------------------------------*
      *              * Se tipo elemento 'L'                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se manca il codice comune : errore          *
      *                  *---------------------------------------------*
           if        w-tes-cod-cmn        =    zero
                     go to cnt-tdo-key-900.
      *                  *---------------------------------------------*
      *                  * Se codice comune non esistente : errore     *
      *                  *---------------------------------------------*
           move      w-tes-cod-cmn        to   w-let-arc-gxc-cmn      .
           move      zero                 to   w-let-arc-gxc-fzn      .
           move      zero                 to   w-let-arc-gxc-lct      .
           perform   let-arc-gxc-000      thru let-arc-gxc-999        .
           move      w-let-arc-gxc-des    to   w-tes-cod-cmn-des      .
           if        w-let-arc-gxc-flg    not  = spaces
                     go to cnt-tdo-key-900.
      *                  *---------------------------------------------*
      *                  * Se manca il codice frazione si escludono i  *
      *                  * controlli sulla frazione, in quanto puo' e- *
      *                  * sistere localita' diretta di un comune, non *
      *                  * necessariamente di una frazione             *
      *                  *---------------------------------------------*
           if        w-tes-cod-fzn        =    zero
                     go to cnt-tdo-key-625.
      *                  *---------------------------------------------*
      *                  * Se codice frazione non esistente : errore   *
      *                  *---------------------------------------------*
           move      w-tes-cod-cmn        to   w-let-arc-gxc-cmn      .
