      *    *===========================================================*
      *    * Accettazione campo testata : Tipo elemento                *
      *    *-----------------------------------------------------------*
       acc-tip-ele-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-ele-025.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tip-ele        to   w-sav-tip-ele          .
       acc-tip-ele-050.
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-ele        not  = spaces
                     go to acc-tip-ele-100.
           if        w-def-tip-ele        not  = "C" and
                     w-def-tip-ele        not  = "F" and
                     w-def-tip-ele        not  = "L"
                     go to acc-tip-ele-100.
           move      w-def-tip-ele        to   w-tes-tip-ele          .
       acc-tip-ele-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ele-lun    to   v-car                  .
           move      w-exp-tip-ele-num    to   v-ldt                  .
           move      "CFL#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      04                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      w-exp-tip-ele-tbl    to   v-txt                  .
           if        w-tes-tip-ele        =    "C"
                     move  01             to   v-num
           else if   w-tes-tip-ele        =    "F"
                     move  02             to   v-num
           else if   w-tes-tip-ele        =    "L"
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-tip-ele-999.
       acc-tip-ele-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "C"            to   w-tes-tip-ele    
           else if   v-num                =    02
                     move  "F"            to   w-tes-tip-ele    
           else if   v-num                =    03
                     move  "L"            to   w-tes-tip-ele    
           else      move  spaces         to   w-tes-tip-ele          .
       acc-tip-ele-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che sia un valore ammesso              *
      *                  *---------------------------------------------*
           if        w-tes-tip-ele        not  = "C" and
                     w-tes-tip-ele        not  = "F" and
                     w-tes-tip-ele        not  = "L"
                     go to acc-tip-ele-100.
       acc-tip-ele-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del valore           *
      *                  *---------------------------------------------*
           if        w-tes-tip-ele        =    "C"
                     go to acc-tip-ele-625
           else if   w-tes-tip-ele        =    "F"
                     go to acc-tip-ele-675
           else if   w-tes-tip-ele        =    "L"
                     go to acc-tip-ele-725.
       acc-tip-ele-625.
      *                  *---------------------------------------------*
      *                  * Se tipo elemento 'C'                        *
      *                  *---------------------------------------------*
       acc-tip-ele-630.
      *                      *-----------------------------------------*
      *                      * Normalizzazione frazione                *
      *                      *-----------------------------------------*
           if        w-tes-cod-fzn        =    zero
                     go to acc-tip-ele-635.
           move      zero                 to   w-tes-cod-fzn          .
           move      spaces               to   w-tes-cod-fzn-des      .
           perform   vis-cod-fzn-000      thru vis-cod-fzn-999        .
           perform   vis-des-fzn-000      thru vis-des-fzn-999        .
       acc-tip-ele-635.
      *                      *-----------------------------------------*
      *                      * Normalizzazione default frazione        *
      *                      *-----------------------------------------*
           move      zero                 to   w-def-cod-fzn          .
       acc-tip-ele-640.
      *                      *-----------------------------------------*
      *                      * Normalizzazione localita'               *
      *                      *-----------------------------------------*
