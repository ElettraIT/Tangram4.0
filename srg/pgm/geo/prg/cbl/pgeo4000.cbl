      *                      *-----------------------------------------*
           if        w-tes-sgl-std (1)    not  = spaces
                     go to acc-sgl-std-100.
      *                      *-----------------------------------------*
      *                      * Se tipo elemento 'C', no default        *
      *                      *-----------------------------------------*
           if        w-tes-tip-ele        =    "C"
                     go to acc-sgl-std-100.
      *                      *-----------------------------------------*
      *                      * Se tipo elemento 'F' o 'L' si propone   *
      *                      * lo stradario del comune di appartenenza *
      *                      *-----------------------------------------*
           move      w-tes-cod-cmn        to   w-let-arc-gxc-cmn      .
           move      zero                 to   w-let-arc-gxc-fzn      .
           move      zero                 to   w-let-arc-gxc-lct      .
           perform   let-arc-gxc-000      thru let-arc-gxc-999        .
           if        w-let-arc-gxc-flg    not  = spaces
                     go to acc-sgl-std-100.
           move      w-let-arc-gxc-sgs    to   w-tes-sgl-std (1)      .
       acc-sgl-std-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-sgl-std (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-std-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-std-999.
       acc-sgl-std-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-sgl-std (1)      .
       acc-sgl-std-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-sgl-std (1)    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-sgl-std-100.
       acc-sgl-std-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sgl-std-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sgl-std-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sgl-std-100.
       acc-sgl-std-999.
           exit.

