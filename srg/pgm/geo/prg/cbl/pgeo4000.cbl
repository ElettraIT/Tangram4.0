           move      w-let-arc-gxp-des    to   w-tes-cod-prv-des (1)  .
           move      w-let-arc-gxp-cmi    to   w-tes-cod-prv-cmi (1)  .
           move      w-let-arc-gxp-cma    to   w-tes-cod-prv-cma (1)  .
           move      w-let-arc-gxp-cpl    to   w-tes-cod-prv-cpl (1)  .
           move      w-let-arc-gxp-ist    to   w-tes-cod-prv-ist (1)  .
       acc-cod-prv-058.
