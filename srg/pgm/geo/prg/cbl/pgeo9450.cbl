      *                          * Estrazione                          *
      *                          *-------------------------------------*
           perform   prn-liv-det-ext-000  thru prn-liv-det-ext-999    .
      *                          *-------------------------------------*
      *                          * Eliminazione doppi apici CAP        *
      *                          *-------------------------------------*
           move      w-det-cap-str-alf
                    (02 : 99)             to   w-det-cap-str-alf      .
      *
           inspect   w-det-cap-str-alf
                                     replacing all """"
                                               by  " "                .
      *                          *-------------------------------------*
      *                          * In campo di destinazione            *
      *                          *-------------------------------------*
           move      w-det-cap-str-alf    to   w-cap-num-cap          .
       prn-liv-det-140.
      *                  *---------------------------------------------*
      *                  * Test su valori estratti                     *
      *                  *---------------------------------------------*
       prn-liv-det-200.
      *              *-------------------------------------------------*
      *              * Eventuale rottura per codice provincia          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-det-cap-str-rot    =    spaces
                     go to prn-liv-det-220.
           if        w-det-cap-str-rot    =    w-cap-cod-prv
                     go to prn-liv-det-400.
       prn-liv-det-220.
      *                  *---------------------------------------------*
      *                  * Rottura su codice provincia                 *
      *                  *---------------------------------------------*
           move      w-cap-cod-prv        to   w-det-cap-str-rot      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record                      *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxs                 .
      *                  *---------------------------------------------*
      *                  * Composizione record di intestazione         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Campi chiave                            *
      *                      *-----------------------------------------*
           move      w-cap-cod-prv        to   rf-gxs-sgl-std         .
           move      spaces               to   rf-gxs-des-key         .
           move      spaces               to   rf-gxs-spc-key         .
      *                      *-----------------------------------------*
      *                      * Campi non chiave                        *
      *                      *-----------------------------------------*
           move      w-cap-cod-prv        to   w-det-cod-cmn-prv      .
           perform   det-cod-cmn-000      thru det-cod-cmn-999        .
           move      w-det-cod-cmn-des    to   rf-gxs-des-str         .
           move      w-det-cod-cmn-cod    to   rf-gxs-cod-cmn         .
           move      spaces               to   rf-gxs-cap-avp         .
           move      zero                 to   rf-gxs-cod-fzn         .
           move      zero                 to   rf-gxs-cod-lct         .
           move      spaces               to   rf-gxs-alx-exp         .
      *                  *---------------------------------------------*
      *                  * Test se scrittura da eseguire               *
      *                  *---------------------------------------------*
           if        rr-tip-exe           not  = 02
                     go to prn-liv-det-400.
      *                  *---------------------------------------------*
      *                  * Scrittura                                   *
      *                  *---------------------------------------------*
           perform   wrt-rec-gxs-000      thru wrt-rec-gxs-999        .
       prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxs                 .
       prn-liv-det-420.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Campi chiave                                *
      *                  *---------------------------------------------*
           move      w-cap-cod-prv        to   rf-gxs-sgl-std         .
           move      w-cap-top-ele        to   rf-gxs-des-key         .
      *                      *-----------------------------------------*
      *                      * Assemblaggio specifica via              *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-cap-dug-ele        to   w-all-str-cat (1)      .
      *
           if        w-cap-des-frz        not  = spaces and
                     w-cap-num-civ        =    spaces
                     move  w-cap-des-frz  to   w-cap-num-civ          .
      *
           if        w-cap-num-civ        =    spaces
                     move  spaces         to   w-all-str-cat (2)
           else      move  ","            to   w-all-str-cat (2)      .
      *
           move      w-cap-num-civ        to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   rf-gxs-spc-key         .
      *                  *---------------------------------------------*
      *                  * Campi non chiave                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assemblaggio descrizione via            *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-cap-dug-ele        to   w-all-str-cat (1)      .
           move      w-cap-top-ele        to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   rf-gxs-des-str         .
      *                      *-----------------------------------------*
      *                      * Capitalize descrizione via              *
      *                      *-----------------------------------------*
           move      rf-gxs-des-str       to   w-all-str-alf          .
           move      30                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   rf-gxs-des-str         .
      *                      *-----------------------------------------*
      *                      * CAP                                     *
      *                      *-----------------------------------------*
           move      w-cap-num-cap        to   rf-gxs-cap-avp         .
      *                      *-----------------------------------------*
      *                      * Codice Comune                           *
      *                      *-----------------------------------------*
           move      w-cap-cod-prv        to   w-det-cod-cmn-prv      .
           perform   det-cod-cmn-000      thru det-cod-cmn-999        .
           move      w-det-cod-cmn-cod    to   rf-gxs-cod-cmn         .
      *                      *-----------------------------------------*
      *                      * Altri dati                              *
      *                      *-----------------------------------------*
           move      zero                 to   rf-gxs-cod-fzn         .
           move      zero                 to   rf-gxs-cod-lct         .
           move      spaces               to   rf-gxs-alx-exp         .
       prn-liv-det-700.
      *              *-------------------------------------------------*
      *              * Incremento contatore elementi inseriti          *
      *              *-------------------------------------------------*
           add       1                    to   w-gen-ele-ins          .
      *              *-------------------------------------------------*
      *              * Rullino messaggi                                *
      *              *-------------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Nuovo stradario :"  to   w-all-str-cat (1)      .
           move      w-cap-des-cmn        to   w-all-str-cat (2)      .
           move      "["                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           move      05                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      w-cap-num-cap        to   w-all-str-cat (2)      .
           move      "]-("                to   w-all-str-cat (3)      .
           move      w-cap-cod-prv        to   w-all-str-cat (4)      .
           move      ")"                  to   w-all-str-cat (5)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *
           move      w-all-str-alf        to   w-wrt-msg-err-msg      .
           perform   wrt-msg-err-000      thru wrt-msg-err-999        .
      *              *-------------------------------------------------*
      *              * Test se scrittura da eseguire                   *
      *              *-------------------------------------------------*
           if        rr-tip-exe           not  = 02
                     go to prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Scrittura                                       *
      *              *-------------------------------------------------*
           perform   wrt-rec-gxs-000      thru wrt-rec-gxs-999        .
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *                                                           *
      *    * Estrazione campi                                          *
      *    *-----------------------------------------------------------*
       prn-liv-det-ext-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cap-num-ctr      .
           move      spaces               to   w-det-cap-str-al1      .
           move      spaces               to   w-det-cap-str-al2      .
           move      spaces               to   w-det-cap-str-ext      .
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           inspect   w-det-cap-str-alf
                                      tallying w-det-cap-num-ctr
                     for    all ";"                                   .
           if        w-det-cap-num-ctr    =    zero
                     move  w-det-cap-str-alf
                                          to   w-det-cap-str-ext
                     go to prn-liv-det-ext-999.
      *              *-------------------------------------------------*
      *              * Estrazione                                      *
      *              *-------------------------------------------------*
           unstring  w-det-cap-str-alf
                                delimited by ";"
                                          into w-det-cap-str-al1
                                    count in   w-det-cap-num-ctr      .
           add       2                    to   w-det-cap-num-ctr      .
      *              *-------------------------------------------------*
      *              * Estrazione stringa rimanente                    *
      *              *-------------------------------------------------*
           unstring  w-det-cap-str-alf    into w-det-cap-str-al2
                                  with pointer w-det-cap-num-ctr      .
      *              *-------------------------------------------------*
      *              * Valori estratti                                 *
      *              *-------------------------------------------------*
           move      w-det-cap-str-al1    to   w-det-cap-str-ext      .
           move      w-det-cap-str-al2    to   w-det-cap-str-alf      .
      *              *-------------------------------------------------*
      *              * Eliminazione doppi apici                        *
      *              *-------------------------------------------------*
           move      w-det-cap-str-ext
                    (02 : 99)             to   w-det-cap-str-ext      .
      *
           inspect   w-det-cap-str-ext
                                     replacing all """"
                                               by  " "                .
      *              *-------------------------------------------------*
      *              * Eventuali normalizzazioni                       *
      *              *-------------------------------------------------*
           if        w-det-cap-str-ext
                    (01 : 03)             =    "---"
                     move  zero           to   w-det-cap-str-inx
                     move  spaces         to   w-det-cap-str-ext      .
       prn-liv-det-ext-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-ext-999.
       prn-liv-det-ext-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Scrittura messaggio di errore                             *
      *    *-----------------------------------------------------------*
       wrt-msg-err-000.
           move      "WR"                 to   m-ope                  .
           move      w-wrt-msg-err-msg    to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       wrt-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [gxs]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-gxs-000.
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxs                 .
       wrt-rec-gxs-999.
           exit.

      *    *===========================================================*
      *    * Determinazione codice Comune                              *
      *    *-----------------------------------------------------------*
       det-cod-cmn-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-cod-cmn-cod      .
           move      spaces               to   w-det-cod-cmn-des      .
       det-cod-cmn-100.
      *              *-------------------------------------------------*
      *              * Start su file [gxc]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PRVCFL    "         to   f-key                  .
           move      w-det-cod-cmn-prv    to   rf-gxc-cod-prv         .
           move      zero                 to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cod-cmn-900.
       det-cod-cmn-200.
      *              *-------------------------------------------------*
      *              * Next su [gxc]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : ad uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-cod-cmn-900.
       det-cod-cmn-300.
      *              *-------------------------------------------------*
      *              * Max su [gxc], se non superato : ad uscita       *
      *              *-------------------------------------------------*
           if        rf-gxc-cod-prv       not  = w-det-cod-cmn-prv
                     go to det-cod-cmn-900.
       det-cod-cmn-400.
      *              *-------------------------------------------------*
      *              * Sel su [gxc], se non superato : a riciclo       *
      *              *-------------------------------------------------*
           if        rf-gxc-sgl-std       not  = w-det-cod-cmn-prv
                     go to det-cod-cmn-200.
       det-cod-cmn-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione dell'elemento letto             *
      *              *-------------------------------------------------*
           move      rf-gxc-cod-cmn       to   w-det-cod-cmn-cod      .
           move      rf-gxc-des-cfl       to   w-det-cod-cmn-des      .
       det-cod-cmn-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-cod-cmn-999.
       det-cod-cmn-999.
           exit.

