           move      srt-est-doc-ddo      to   s-dat                  .
           if        srt-val-sta-sn3      =    "S"
                     if    srt-val-sta-pon
                                          not  = "N"
                           add      srt-val-sta-val
                                          to   w-liv-fnt-mes-p3r
                                              (s-mes)
                     else  subtract srt-val-sta-val
