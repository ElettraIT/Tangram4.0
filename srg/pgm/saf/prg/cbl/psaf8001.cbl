      *                      *-----------------------------------------*
           if        rf-sff-tip-ftf       =    01
                     move  "FT"           to   srt-k02-tip-doc
           else if   rf-sff-tip-ftf       =    02
                     move  "ND"           to   srt-k02-tip-doc
           else if   rf-sff-tip-ftf       =    03
                     move  "NC"           to   srt-k02-tip-doc
           else      move  "FT"           to   srt-k02-tip-doc        .
