           else if   rf-sff-tip-ftf       =    02
                     move  "N.ADD"        to   srt-est-doc-tdo
           else if   rf-sff-tip-ftf       =    03
                     move  "N.ACC"        to   srt-est-doc-tdo
           else      move  "?    "        to   srt-est-doc-tdo        .
      *                      *-----------------------------------------*
