      *
           move      w-all-str-alf        to   m-gen-grf-tit-grf      .
           move      "saf800"             to   m-gen-grf-fil-nam      .
       exe-sqz-grf-fnt-200.
      *              *-------------------------------------------------*
      *              * Emissione dati mensili per periodo              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione date periodi                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-fnt-cst-ct1      .
       exe-sqz-grf-fnt-300.
           add       1                    to   w-liv-fnt-cst-ct1      .
           if        w-liv-fnt-cst-ct1    >    rr-num-pdr
