      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se i tipi di ordinamento   *
      *              * includono almeno una opzione in ABC oppure no.  *
      *              * Si intende necessaria una opzione in ABC anche  *
      *              * se la statistica e' sul nuovo fatturato o sul   *
      *              * non fatturato.                                  *
      *              *-------------------------------------------------*
           if        rr-num-pdr           =    11 or
                     rr-num-pdr           =    12
                     go to stp-srt-inp-400.
           if        rr-tor-fnt           =    01 or
                     rr-tor-fnt           =    02
                     go to stp-srt-inp-400.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Se i tipi di ordinamento non includono alcuna   *
      *              * opzione in ABC                                  *
      *              *-------------------------------------------------*
       stp-srt-inp-150.
      *                  *---------------------------------------------*
      *                  * Inizializzazione lettura sequenziale archi- *
      *                  * vio [sff]                                   *
      *                  *---------------------------------------------*
           perform   fil-sff-ing-000      thru fil-sff-ing-999        .
       stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [sff]          *
      *                  *---------------------------------------------*
           perform   fil-sff-get-000      thru fil-sff-get-999        .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-flg    not  = spaces
                     go to stp-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Se il valore fatturato e' a zero : si igno- *
      *                  * ra il record                                *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-val    =    zero
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Se il valore fatturato non incide  ne' in   *
      *                  * positivo ne' in negativo sulla statistica : *
      *                  * si ignora il record                         *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-pon    not  = "P" and
                     w-mod-scf-sff-pon    not  = "N"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Se il valore fatturato non incide su nessu- *
      *                  * no dei periodi della statistica : si igno-  *
      *                  * ra il record                                *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-sn1    not  = "S" and
                     w-mod-scf-sff-sn2    not  = "S" and
                     w-mod-scf-sff-sn3    not  = "S"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezione sul record [sff] in esame         *
      *                  *---------------------------------------------*
           perform   sel-sff-rec-000      thru sel-sff-rec-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non superata : si  ignora il   *
      *                  * record                                      *
      *                  *---------------------------------------------*
           if        w-sel-sff-flg-exi    not  = spaces
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Composizione record [srt] dall' area record *
      *                  * [sff], dall'area 'w-sel-sff', dalle aree    *
      *                  * 'w-mod-scf-sff' e 'w-not-fat-sff' e 'rr'    *
      *                  *---------------------------------------------*
           perform   cmp-srt-rec-000      thru cmp-srt-rec-999        .
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * Riciclo alla lettura sequenziale archivio   *
      *                  * [sff]                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Se i tipi di ordinamento includono almeno una   *
      *              * opzione in ABC.                                 *
      *              * Si intende necessaria una opzione in ABC anche  *
      *              * se la statistica e' sul nuovo fatturato o sul   *
      *              * non fatturato.                                  *
      *              *-------------------------------------------------*
       stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Open file di appoggio sequenziale [sqz]     *
      *                  *---------------------------------------------*
           perform   opn-fil-sqz-000      thru opn-fil-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Open file di appoggio ad indici [kk0]       *
      *                  *---------------------------------------------*
           perform   opn-fil-kk0-000      thru opn-fil-kk0-999        .
       stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Inizializzazione lettura sequenziale archi- *
      *                  * vio [sff]                                   *
      *                  *---------------------------------------------*
           perform   fil-sff-ing-000      thru fil-sff-ing-999        .
       stp-srt-inp-550.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [sff]          *
      *                  *---------------------------------------------*
           perform   fil-sff-get-000      thru fil-sff-get-999        .
      *                  *---------------------------------------------*
      *                  * Se fine file : a chiusura/riapertura        *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-flg    not  = spaces
                     go to stp-srt-inp-600.
      *                  *---------------------------------------------*
      *                  * Se il valore fatturato e' a zero : si igno- *
      *                  * ra il record                                *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-val    =    zero
                     go to stp-srt-inp-550.
      *                  *---------------------------------------------*
      *                  * Se il valore fatturato non incide  ne' in   *
      *                  * positivo ne' in negativo sulla statistica : *
      *                  * si ignora il record                         *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-pon    not  = "P" and
                     w-mod-scf-sff-pon    not  = "N"
                     go to stp-srt-inp-550.
      *                  *---------------------------------------------*
      *                  * Se il valore fatturato non incide su nessu- *
      *                  * no dei periodi della statistica : si igno-  *
      *                  * ra il record                                *
      *                  *---------------------------------------------*
           if        w-mod-scf-sff-sn1    not  = "S" and
                     w-mod-scf-sff-sn2    not  = "S" and
                     w-mod-scf-sff-sn3    not  = "S"
                     go to stp-srt-inp-550.
      *                  *---------------------------------------------*
      *                  * Selezione sul record [sff] in esame         *
      *                  *---------------------------------------------*
           perform   sel-sff-rec-000      thru sel-sff-rec-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non superata : si  ignora il   *
      *                  * record                                      *
      *                  *---------------------------------------------*
           if        w-sel-sff-flg-exi    not  = spaces
                     go to stp-srt-inp-550.
      *                  *---------------------------------------------*
      *                  * Composizione record [srt] dall' area record *
      *                  * [sff], dall'area 'w-sel-sff', dalle aree    *
      *                  * 'w-mod-scf-sff' e 'w-not-fat-sff' e 'rr'    *
      *                  *---------------------------------------------*
           perform   cmp-srt-rec-000      thru cmp-srt-rec-999        .
      *                  *---------------------------------------------*
      *                  * Da area record [srt] ad area record file    *
      *                  * sequenziale [sqz]                           *
      *                  *---------------------------------------------*
           move      srt-rec              to   sqz-rec                .
      *                  *---------------------------------------------*
      *                  * Scrittura record file sequenziale [sqz]     *
      *                  *---------------------------------------------*
           perform   wrt-fil-sqz-000      thru wrt-fil-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Aggiornamento valori ABC su file di appog-  *
      *                  * gio ad indici                               *
      *                  *---------------------------------------------*
           perform   agg-abc-kk0-000      thru agg-abc-kk0-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo alla lettura sequenziale archivio   *
      *                  * [sff]                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-550.
       stp-srt-inp-600.
      *                  *---------------------------------------------*
      *                  * Close file di appoggio sequenziale [sqz]    *
      *                  *---------------------------------------------*
           perform   cls-fil-sqz-000      thru cls-fil-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Open file di appoggio sequenziale [sqz]     *
      *                  *---------------------------------------------*
           perform   opn-fil-sqz-000      thru opn-fil-sqz-999        .
       stp-srt-inp-650.
      *                  *---------------------------------------------*
      *                  * Read file di appoggio sequenziale [sqz]     *
      *                  *---------------------------------------------*
           perform   rea-fil-sqz-000      thru rea-fil-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sqz-sts            not  = e-not-err
                     go to stp-srt-inp-700.
      *                  *---------------------------------------------*
      *                  * Da area record file sequenziale [kk0] ad a- *
      *                  * rea record [sqz]                            *
      *                  *---------------------------------------------*
           move      sqz-rec              to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Aggiornamento valori ABC su file di appog-  *
      *                  * gio sequenziale                             *
      *                  *---------------------------------------------*
           perform   agg-abc-sqz-000      thru agg-abc-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * Riciclo alla lettura sequenziale archivio   *
      *                  * [sqz]                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-650.
       stp-srt-inp-700.
      *                  *---------------------------------------------*
      *                  * Close file di appoggio sequenziale [sqz]    *
      *                  *---------------------------------------------*
           perform   cls-fil-sqz-000      thru cls-fil-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Close file di appoggio ad indici [kk0]      *
      *                  *---------------------------------------------*
           perform   cls-fil-kk0-000      thru cls-fil-kk0-999        .
      *                  *---------------------------------------------*
      *                  * Delete file di appoggio sequenziale [sqz]   *
      *                  *---------------------------------------------*
           perform   del-fil-sqz-000      thru del-fil-sqz-999        .
      *                  *---------------------------------------------*
      *                  * Delete file di appoggio ad indici [kk0]     *
      *                  *---------------------------------------------*
           perform   del-fil-kk0-000      thru del-fil-kk0-999        .
       stp-srt-inp-750.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Inizializzazione lettura sequenziale archivio [sff]       *
      *    *-----------------------------------------------------------*
       fil-sff-ing-000.
      *              *-------------------------------------------------*
      *              * Richiamo funzione 'GS' del modulo 'mscfsff0'    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero periodi di riferimento           *
      *                      *-----------------------------------------*
           if        rr-num-pdr           =    11 or
                     rr-num-pdr           =    12
                     move  02             to   w-mod-scf-sff-npr
           else      move  rr-num-pdr     to   w-mod-scf-sff-npr      .
      *                      *-----------------------------------------*
      *                      * 1. periodo, data min                    *
      *                      *-----------------------------------------*
           move      rr-p1d-min           to   w-mod-scf-sff-p1i      .
      *                      *-----------------------------------------*
      *                      * 1. periodo, data max                    *
      *                      *-----------------------------------------*
           move      rr-p1d-max           to   w-mod-scf-sff-p1f      .
      *                      *-----------------------------------------*
      *                      * 2. periodo, data min                    *
      *                      *-----------------------------------------*
           move      rr-p2d-min           to   w-mod-scf-sff-p2i      .
      *                      *-----------------------------------------*
      *                      * 2. periodo, data max                    *
      *                      *-----------------------------------------*
           move      rr-p2d-max           to   w-mod-scf-sff-p2f      .
      *                      *-----------------------------------------*
      *                      * 3. periodo, data min                    *
      *                      *-----------------------------------------*
           move      rr-p3d-min           to   w-mod-scf-sff-p3i      .
      *                      *-----------------------------------------*
      *                      * 3. periodo, data max                    *
      *                      *-----------------------------------------*
           move      rr-p3d-max           to   w-mod-scf-sff-p3f      .
      *                  *---------------------------------------------*
      *                  * Chiamata modulo                             *
      *                  *---------------------------------------------*
           perform   mod-scf-sff-gts-000  thru mod-scf-sff-gts-999    .
       fil-sff-ing-999.
           exit.

      *    *===========================================================*
      *    * Lettura sequenziale archivio [sff]                        *
      *    *-----------------------------------------------------------*
       fil-sff-get-000.
      *              *-------------------------------------------------*
      *              * Richiamo funzione 'GT' del modulo 'mscfsff0'    *
      *              *-------------------------------------------------*
           perform   mod-scf-sff-get-000  thru mod-scf-sff-get-999    .
       fil-sff-get-999.
           exit.

      *    *===========================================================*
      *    * Selezioni su record [sff] in esame                        *
      *    *-----------------------------------------------------------*
       sel-sff-rec-000.
      *              *-------------------------------------------------*
      *              * Selezione su codice dipendenza                  *
      *              *-------------------------------------------------*
       sel-sff-rec-100.
      *              *-------------------------------------------------*
      *              * Selezione su codice fornitore                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se un solo codice fornitore da selezionare  *
      *                  * e il codice fornitore non corrisponde a     *
      *                  * quello da selezionare : uscita per selezio- *
      *                  * ne non superata                             *
      *                  *---------------------------------------------*
           if        rr-cod-fnt           not  = zero   and
                     rf-sff-cod-fnt       not  = rr-cod-fnt
                     go to sel-sff-rec-900.
       sel-sff-rec-200.
      *              *-------------------------------------------------*
      *              * Lettura anagrafica [fnt] e [dcf]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      rf-sff-cod-fnt       to   w-let-fnt-dcf-fnt      .
           move      rf-sff-dpz-fnt       to   w-let-fnt-dcf-dpz      .
           perform   let-fnt-dcf-000      thru let-fnt-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Dati letti in area di comodo                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice fornitore                        *
      *                      *-----------------------------------------*
           move      w-let-fnt-dcf-fnt    to   w-sel-sff-cod-fnt      .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza per il fornitore      *
      *                      *-----------------------------------------*
           move      w-let-fnt-dcf-dpz    to   w-sel-sff-dpz-fnt      .
      *                      *-----------------------------------------*
      *                      * Ragione sociale per il fornitore        *
      *                      *-----------------------------------------*
           move      w-let-fnt-dcf-rag    to   w-sel-sff-rag-fnt      .
      *                      *-----------------------------------------*
      *                      * Mnemonico per il fornitore              *
      *                      *-----------------------------------------*
           move      w-let-fnt-dcf-mne    to   w-sel-sff-mne-fnt      .
       sel-sff-rec-400.
      *              *-------------------------------------------------*
      *              * Uscita per selezione superata                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita a : selezione superata       *
      *                  *---------------------------------------------*
           move      spaces               to   w-sel-sff-flg-exi      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     sel-sff-rec-999.
       sel-sff-rec-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezione non superata               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita a : selezione non superata   *
      *                  *---------------------------------------------*
           move      "#"                  to   w-sel-sff-flg-exi      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     sel-sff-rec-999.
       sel-sff-rec-999.
           exit.

      *    *===========================================================*
      *    * Composizione record [srt] prelevando dalle seguenti aree  *
      *    *                                                           *
      *    *   - area record [sff]                                     *
      *    *   - area w-sel-sff                                        *
      *    *   - area w-mod-scf-sff                                    *
      *    *   - area w-not-fat-sff                                    *
      *    *   - area rr                                               *
      *    *-----------------------------------------------------------*
       cmp-srt-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare totale del record   *
      *              *-------------------------------------------------*
           move      spaces               to   srt-rec                .
       cmp-srt-rec-100.
      *              *-------------------------------------------------*
      *              * Area chiave di ordinamento                      *
      *              *-------------------------------------------------*
       cmp-srt-rec-200.
      *                  *---------------------------------------------*
      *                  * Subchiave 1 : Per fornitore                 *
      *                  *---------------------------------------------*
       cmp-srt-rec-210.
      *                      *-----------------------------------------*
      *                      * Valore ABC                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzato a zero                      *
      *                          *-------------------------------------*
           move      zero                 to   srt-k01-val-abc        .
       cmp-srt-rec-215.
      *                      *-----------------------------------------*
      *                      * Flag di codice diverso da zero ma non   *
      *                      * trovato in archivio codici fornitori    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Solo se tipo ordinamento fornitori  *
      *                          *  - ABC decrescente                  *
      *                          *  - ABC crescente                    *
      *                          *  - Per ragione sociale              *
      *                          *  - Per mnemonico                    *
      *                          * altrimenti forzato a zero           *
      *                          *-------------------------------------*
           if        rr-tor-fnt           not  = 01 and
                     rr-tor-fnt           not  = 02 and
                     rr-tor-fnt           not  = 03 and
                     rr-tor-fnt           not  = 05
                     move  zero           to   srt-k01-flg-eon
                     go to cmp-srt-rec-220.
      *                          *-------------------------------------*
      *                          * Se codice a zero : si forza '9'     *
      *                          *-------------------------------------*
           if        w-sel-sff-cod-fnt    =    zero
                     move  9              to   srt-k01-flg-eon
                     go to cmp-srt-rec-220.
      *                          *-------------------------------------*
      *                          * Se codice diverso da zero : si pone *
      *                          * a seconda del valore della ragione  *
      *                          * sociale                             *
      *                          *-------------------------------------*
           if        w-sel-sff-rag-fnt    not  = spaces
                     move  1              to   srt-k01-flg-eon
           else      move  5              to   srt-k01-flg-eon        .
       cmp-srt-rec-220.
      *                      *-----------------------------------------*
      *                      * Ragione sociale per il fornitore        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Solo se tipo ordinamento fornitore :*
      *                          *  - ABC decrescente                  *
      *                          *  - ABC crescente                    *
      *                          *  - Per ragione sociale              *
      *                          * altrimenti forzato a spaces         *
      *                          *-------------------------------------*
           if        rr-tor-fnt           not  = 01 and
                     rr-tor-fnt           not  = 02 and
                     rr-tor-fnt           not  = 03
