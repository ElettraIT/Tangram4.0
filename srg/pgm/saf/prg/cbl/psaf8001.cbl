      *                      *-----------------------------------------*
           if        p-vpm                =    "0"
                     if    p-res          >    2
                           go to prn-liv-det-640
                     else  go to prn-liv-det-635
           else      if    p-res          >    0
                           go to prn-liv-det-640
                     else  go to prn-liv-det-635.
       prn-liv-det-635.
      *                      *-----------------------------------------*
      *                      * Intestazione pagina                     *
      *                      *-----------------------------------------*
           perform   stp-int-pag-000      thru stp-int-pag-999        .
      *                      *-----------------------------------------*
      *                      * Se flag di interruzione forzata: uscita *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di fincatura verti- *
      *                      * cale della pagina                       *
      *                      *-----------------------------------------*
           perform   stp-fnc-vrt-000      thru stp-fnc-vrt-999        .
      *                      *-----------------------------------------*
      *                      * Se flag di interruzione forzata: uscita *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-640.
      *                      *-----------------------------------------*
      *                      * Due interlinee                          *
      *                      *-----------------------------------------*
           move      "L+"                 to   p-ope                  .
           move      2                    to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-650.
      *                      *-----------------------------------------*
      *                      * Subroutine per la stampa del codice del *
      *                      * fornitore e della sua ragione sociale   *
      *                      *-----------------------------------------*
       prn-liv-det-651.
      *                          *-------------------------------------*
      *                          * Preparazione                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Codice fornitore                *
      *                              *---------------------------------*
           move      w-liv-fnt-cod-fnt    to   w-stp-ccl-rsc-cod      .
      *                              *---------------------------------*
      *                              * Mnemonico fornitore             *
      *                              *---------------------------------*
           move      w-liv-fnt-mne-fnt    to   w-stp-ccl-rsc-mne      .
      *                              *---------------------------------*
      *                              * Dipendenza fornitore            *
      *                              *---------------------------------*
           move      w-liv-fnt-dpz-fnt    to   w-stp-ccl-rsc-dpz      .
      *                              *---------------------------------*
      *                              * Ragione sociale fornitore       *
      *                              *---------------------------------*
           move      w-liv-fnt-rag-fnt    to   w-stp-ccl-rsc-rag      .
       prn-liv-det-652.
      *                          *-------------------------------------*
      *                          * Esecuzione                          *
      *                          *-------------------------------------*
           perform   stp-ccl-rsc-000      thru stp-ccl-rsc-999        .
       prn-liv-det-660.
      *                      *-----------------------------------------*
      *                      * A stampa fatturato ed estremi documento *
      *                      *-----------------------------------------*
           go to     prn-liv-det-900.
       prn-liv-det-670.
      *                  *---------------------------------------------*
      *                  * Se non e' il primo documento trattato per   *
      *                  * il fornitore, bensi' uno successivo         *
      *                  *---------------------------------------------*
       prn-liv-det-680.
      *                      *-----------------------------------------*
      *                      * Test se linee residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-vpm                =    "0"
                     if    p-res          >    1
                           go to prn-liv-det-690
                     else  go to prn-liv-det-685
           else      go to prn-liv-det-690.
       prn-liv-det-685.
      *                      *-----------------------------------------*
      *                      * Intestazione pagina                     *
      *                      *-----------------------------------------*
           perform   stp-int-pag-000      thru stp-int-pag-999        .
      *                      *-----------------------------------------*
      *                      * Se flag di interruzione forzata: uscita *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di fincatura verti- *
      *                      * cale della pagina                       *
      *                      *-----------------------------------------*
           perform   stp-fnc-vrt-000      thru stp-fnc-vrt-999        .
      *                      *-----------------------------------------*
      *                      * Se flag di interruzione forzata: uscita *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-690.
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-900.
      *                  *---------------------------------------------*
      *                  * Stampa fatturato ed estremi documento       *
      *                  *---------------------------------------------*
       prn-liv-det-901.
      *                      *-----------------------------------------*
      *                      * Preparazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valore fatturato                    *
      *                          *-------------------------------------*
           move      srt-val-sta-val      to   w-stp-sta-fee-fat      .
      *                          *-------------------------------------*
      *                          * Incidenza in Positivo o Negativo    *
      *                          *-------------------------------------*
           move      srt-val-sta-pon      to   w-stp-sta-fee-pon      .
      *                          *-------------------------------------*
      *                          * Tipo documento                      *
      *                          *-------------------------------------*
           move      srt-est-doc-tdo      to   w-stp-sta-fee-tdo      .
      *                          *-------------------------------------*
      *                          * Data documento                      *
      *                          *-------------------------------------*
           move      srt-est-doc-ddo      to   w-stp-sta-fee-ddo      .
      *                          *-------------------------------------*
      *                          * Numero documento, s.aa.xx.nnnnnn    *
      *                          *-------------------------------------*
           move      srt-est-doc-ndo      to   w-stp-sta-fee-ndo      .
      *                          *-------------------------------------*
      *                          * Valore del campo note               *
      *                          *-------------------------------------*
           move      srt-est-doc-not      to   w-stp-sta-fee-not      .
       prn-liv-det-902.
      *                      *-----------------------------------------*
      *                      * Esecuzione                              *
      *                      *-----------------------------------------*
           perform   stp-sta-fee-000      thru stp-sta-fee-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale sequenziale                   *
      *                      *-----------------------------------------*
           perform   exe-gen-fil-doc-000  thru exe-gen-fil-doc-999    .
       prn-liv-det-910.
