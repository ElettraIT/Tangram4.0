      *              * tura generale                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Totale fatturato 1. periodo di riferimento  *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-tot-p1r      .
      *                  *---------------------------------------------*
      *                  * Totale fatturato 2. periodo di riferimento  *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-tot-p2r      .
      *                  *---------------------------------------------*
      *                  * Totale fatturato 3. periodo di riferimento  *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-tot-p3r      .
      *                  *---------------------------------------------*
      *                  * Numero di fornitori trattati                *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-num-fnt      .
      *                  *---------------------------------------------*
      *                  * Flag di fine ciclo in esecuzione : No       *
      *                  *---------------------------------------------*
           move      spaces               to   w-liv-gen-flg-end      .
      *                  *---------------------------------------------*
      *                  * Castelletto mesi                            *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-cst-ctr      .
       prn-ini-cic-120.
           add       1                    to   w-liv-gen-cst-ctr      .
           if        w-liv-gen-cst-ctr    >    12
                     go to prn-ini-cic-200.
           move      zero                 to   w-liv-gen-mes-p1r
                                              (w-liv-gen-cst-ctr)     .
           move      zero                 to   w-liv-gen-mes-p2r
                                              (w-liv-gen-cst-ctr)     .
           move      zero                 to   w-liv-gen-mes-p3r
                                              (w-liv-gen-cst-ctr)     .
           go to     prn-ini-cic-120.
       prn-ini-cic-200.
      *              *-------------------------------------------------*
