      *    *===========================================================*
      *    * Subroutine per stampa totali                              *
      *    *                                                           *
      *    * - Parametri in input                                      *
      *    *                                                           *
      *    *   - w-stp-sta-tot-lit : Literal per il totale             *
      *    *                                                           *
      *    *   - w-stp-sta-tot-f01 : Valore fatturato 1                *
      *    *                                                           *
      *    *   - w-stp-sta-tot-f02 : Valore fatturato 2                *
      *    *                                                           *
      *    *   - w-stp-sta-tot-p01 : Valore % di variazione 1          *
      *    *                                                           *
      *    *   - w-stp-sta-tot-f03 : Valore fatturato 3                *
      *    *                                                           *
      *    *   - w-stp-sta-tot-p02 : Valore % di variazione 2          *
      *    *                                                           *
      *    *   - w-stp-sta-tot-not : Valore del campo 'Note'           *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       stp-sta-tot-000.
      *              *-------------------------------------------------*
      *              * Test se numero linee residue sufficienti        *
      *              *-------------------------------------------------*
           if        p-res                >    1
                     go to stp-sta-tot-050.
      *              *-------------------------------------------------*
      *              * Reintestazione                                  *
      *              *-------------------------------------------------*
           perform   stp-int-pag-000      thru stp-int-pag-999        .
      *              *-------------------------------------------------*
      *              * Se flag di interruzione forzata in On : si esce *
      *              * immediatamente                                  *
      *              *-------------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-sta-tot-999.
       stp-sta-tot-050.
      *              *-------------------------------------------------*
      *              * Interlinea di separazione                       *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-100.
      *              *-------------------------------------------------*
      *              * Literal per il totale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione della lunghezza del literal  *
      *                  * per il totale, allineato a sinistra, senza  *
      *                  * considerare gli spazi in coda               *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-sta-tot-c02      .
           inspect   w-stp-sta-tot-lit
                                      tallying w-stp-sta-tot-c02
                                  for trailing spaces                 .
           move      56                   to   w-stp-sta-tot-c01      .
           subtract  w-stp-sta-tot-c02    from w-stp-sta-tot-c01      .
      *                  *---------------------------------------------*
      *                  * Determinazione della posizione di stampa    *
      *                  * per il literal per il totale, in modo da    *
      *                  * allinearlo a destra                         *
      *                  *---------------------------------------------*
           move      56                   to   w-stp-sta-tot-c02      .
           subtract  w-stp-sta-tot-c01    from w-stp-sta-tot-c02      .
           add       1                    to   w-stp-sta-tot-c02      .
      *                  *---------------------------------------------*
      *                  * Stampa literal                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-sta-tot-c01    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-sta-tot-c02    to   p-pos                  .
           move      w-stp-sta-tot-lit    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-200.
      *              *-------------------------------------------------*
      *              * Valore fatturato 1                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-tot-f01    to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      061                  to   p-pos                  .
           move      w-stp-edt-fat-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-300.
      *              *-------------------------------------------------*
      *              * Se numero periodi di riferimento non superiore  *
      *              * a 1 : a stampa Note                             *
      *              *-------------------------------------------------*
           if        rr-num-pdr           not  = 02 and
                     rr-num-pdr           not  = 03
                     go to stp-sta-tot-900.
       stp-sta-tot-400.
      *              *-------------------------------------------------*
      *              * Valore fatturato 2                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-tot-f02    to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      079                  to   p-pos                  .
           move      w-stp-edt-fat-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-500.
      *              *-------------------------------------------------*
      *              * Valore % di variazione 1                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-tot-f01    to   w-stp-edt-pdv-1ov      .
           move      w-stp-sta-tot-f02    to   w-stp-edt-pdv-2ov      .
           move      w-stp-sta-tot-p01    to   w-stp-edt-pdv-pdv      .
           perform   stp-edt-pdv-000      thru stp-edt-pdv-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      098                  to   p-pos                  .
           move      w-stp-edt-pdv-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-600.
      *              *-------------------------------------------------*
      *              * Se numero periodi di riferimento non superiore  *
      *              * a 2 : a stampa Note                             *
      *              *-------------------------------------------------*
           if        rr-num-pdr           not  = 03
                     go to stp-sta-tot-900.
       stp-sta-tot-700.
      *              *-------------------------------------------------*
      *              * Valore fatturato 3                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-tot-f03    to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      107                  to   p-pos                  .
           move      w-stp-edt-fat-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-800.
      *              *-------------------------------------------------*
      *              * Valore % di variazione 2                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-tot-f02    to   w-stp-edt-pdv-1ov      .
           move      w-stp-sta-tot-f03    to   w-stp-edt-pdv-2ov      .
           move      w-stp-sta-tot-p02    to   w-stp-edt-pdv-pdv      .
           perform   stp-edt-pdv-000      thru stp-edt-pdv-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      126                  to   p-pos                  .
           move      w-stp-edt-pdv-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-900.
      *              *-------------------------------------------------*
      *              * Valore del campo 'Note'                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se lunghezza campo 'Note' a zero : uscita   *
      *                  *---------------------------------------------*
           if        w-stp-clc-not-lun    =    zero or
                     w-stp-clc-not-pos    =    zero
                     go to stp-sta-tot-999.
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-clc-not-lun    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-clc-not-pos    to   p-pos                  .
           move      w-stp-sta-tot-not    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-tot-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per editing voce 'Fatturato'                   *
      *    *-----------------------------------------------------------*
           copy      "pgm/saf/prg/cpy/psafedn0.cpy"                   .

      *    *===========================================================*
      *    * Subroutine per editing voce '% di variazione'             *
      *    *-----------------------------------------------------------*
       stp-edt-pdv-000.
      *              *-------------------------------------------------*
      *              * Se i due parametri sono entrambi a zero : usci- *
      *              * ta con spaces                                   *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-1ov    =    zero and
                     w-stp-edt-pdv-2ov    =    zero
                     move  "       "      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Se i due parametri sono uguali : uscita con '=' *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-1ov    =    w-stp-edt-pdv-2ov
                     move  "      ="      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Se il primo dei due parametri e' positivo ed il *
      *              * secondo e' negativo o zero : uscita con '-'     *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-1ov    >    zero  and
                     w-stp-edt-pdv-2ov    not  > zero
                     move  "      -"      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Se il primo dei due parametri e' negativo ed il *
      *              * secondo e' positivo o zero : uscita con '+'     *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-1ov    <    zero  and
                     w-stp-edt-pdv-2ov    not  < zero
                     move  "      +"      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Se il secondo dei due parametri e' positivo ed  *
      *              * il primo e' negativo o zero : uscita con '+'    *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-2ov    >    zero  and
                     w-stp-edt-pdv-1ov    not  > zero
                     move  "      +"      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Se il secondo dei due parametri e' negativo ed  *
      *              * il primo e' positivo o zero : uscita con '-'    *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-2ov    <    zero  and
                     w-stp-edt-pdv-1ov    not  < zero
                     move  "      -"      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Se la % di variazione supera il limite del die- *
      *              * cimila per cento : uscita con '!'               *
      *              *-------------------------------------------------*
           if        w-stp-edt-pdv-pdv    >    9999,9 or
                     w-stp-edt-pdv-pdv    <   -9999,9
                     move  "      !"      to   w-stp-edt-pdv-edt
                     go to stp-edt-pdv-999.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      01                   to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      w-stp-edt-pdv-pdv    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Valore editato in campo di destinazione         *
      *              *-------------------------------------------------*
           move      p-edt                to   w-stp-edt-pdv-edt      .
       stp-edt-pdv-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per editing voce 'Estremi del documento'       *
      *    *-----------------------------------------------------------*
       stp-edt-edo-000.
      *              *-------------------------------------------------*
      *              * Se mancano tutti i valori : uscita con spaces   *
      *              *-------------------------------------------------*
           if        w-stp-edt-edo-tdo    =    spaces and
                     w-stp-edt-edo-ddo    =    zero   and
                     w-stp-edt-edo-ndo    =    spaces
                     move  spaces         to   w-stp-edt-edo-edt
                     go to stp-edt-edo-999.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare area editata        *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-edt-edo-edt      .
      *              *-------------------------------------------------*
      *              * Tipo documento                                  *
      *              *-------------------------------------------------*
           move      w-stp-edt-edo-tdo    to   w-stp-edt-edo-e01      .
      *              *-------------------------------------------------*
      *              * Data documento                                  *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-stp-edt-edo-ddo    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-stp-edt-edo-e02      .
      *              *-------------------------------------------------*
      *              * Numero documento                                *
      *              *-------------------------------------------------*
           move      w-stp-edt-edo-ndo    to   w-stp-edt-edo-e03      .
       stp-edt-edo-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per calcolo percentuali di variazione          *
      *    *-----------------------------------------------------------*
       stp-clc-pdv-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di periodi di   *
      *              * riferimento                                     *
      *              *-------------------------------------------------*
           if        rr-num-pdr           =    01 or
                     rr-num-pdr           =    11 or
                     rr-num-pdr           =    12
                     go to stp-clc-pdv-100
           else if   rr-num-pdr           =    02
                     go to stp-clc-pdv-200
           else if   rr-num-pdr           =    03
                     go to stp-clc-pdv-300.
       stp-clc-pdv-100.
      *              *-------------------------------------------------*
      *              * Se numero di periodi di riferimento : 01        *
      *              *-------------------------------------------------*
       stp-clc-pdv-110.
      *                  *---------------------------------------------*
      *                  * % di variazione 1 : a zero                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-clc-pdv-p01      .
       stp-clc-pdv-120.
      *                  *---------------------------------------------*
      *                  * % di variazione 2 : a zero                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-clc-pdv-p02      .
       stp-clc-pdv-130.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-clc-pdv-999.
       stp-clc-pdv-200.
      *              *-------------------------------------------------*
      *              * Se numero di periodi di riferimento : 02        *
      *              *-------------------------------------------------*
       stp-clc-pdv-210.
      *                  *---------------------------------------------*
      *                  * Calcolo % di variazione 1                   *
      *                  *---------------------------------------------*
           if        w-stp-clc-pdv-v01    =    zero or
                     w-stp-clc-pdv-v02    =    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-220.
           if        w-stp-clc-pdv-v01    >    zero and
                     w-stp-clc-pdv-v02    <    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-220.
           if        w-stp-clc-pdv-v01    <    zero and
                     w-stp-clc-pdv-v02    >    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-220.
           move      w-stp-clc-pdv-v02    to   w-stp-clc-pdv-p01      .
           subtract  w-stp-clc-pdv-v01    from w-stp-clc-pdv-p01      .
           multiply  100                  by   w-stp-clc-pdv-p01      .
           divide    w-stp-clc-pdv-v01    into w-stp-clc-pdv-p01
                                                         rounded      .
       stp-clc-pdv-220.
      *                  *---------------------------------------------*
      *                  * % di variazione 2 : a zero                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-clc-pdv-p02      .
       stp-clc-pdv-230.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-clc-pdv-999.
       stp-clc-pdv-300.
      *              *-------------------------------------------------*
      *              * Se numero di periodi di riferimento : 03        *
      *              *-------------------------------------------------*
       stp-clc-pdv-310.
      *                  *---------------------------------------------*
      *                  * Calcolo % di variazione 1                   *
      *                  *---------------------------------------------*
           if        w-stp-clc-pdv-v01    =    zero or
                     w-stp-clc-pdv-v02    =    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-320.
           if        w-stp-clc-pdv-v01    >    zero and
                     w-stp-clc-pdv-v02    <    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-320.
           if        w-stp-clc-pdv-v01    <    zero and
                     w-stp-clc-pdv-v02    >    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-320.
           move      w-stp-clc-pdv-v02    to   w-stp-clc-pdv-p01      .
           subtract  w-stp-clc-pdv-v01    from w-stp-clc-pdv-p01      .
           multiply  100                  by   w-stp-clc-pdv-p01      .
           divide    w-stp-clc-pdv-v01    into w-stp-clc-pdv-p01
                                                         rounded      .
       stp-clc-pdv-320.
      *                  *---------------------------------------------*
      *                  * Calcolo % di variazione 2                   *
      *                  *---------------------------------------------*
           if        w-stp-clc-pdv-v02    =    zero or
                     w-stp-clc-pdv-v03    =    zero
                     move  zero           to   w-stp-clc-pdv-p02
                     go to stp-clc-pdv-330.
           if        w-stp-clc-pdv-v02    >    zero and
                     w-stp-clc-pdv-v03    <    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-330.
           if        w-stp-clc-pdv-v02    <    zero and
                     w-stp-clc-pdv-v03    >    zero
                     move  zero           to   w-stp-clc-pdv-p01
                     go to stp-clc-pdv-330.
           move      w-stp-clc-pdv-v03    to   w-stp-clc-pdv-p02      .
           subtract  w-stp-clc-pdv-v02    from w-stp-clc-pdv-p02      .
           multiply  100                  by   w-stp-clc-pdv-p02      .
           divide    w-stp-clc-pdv-v02    into w-stp-clc-pdv-p02
                                                         rounded      .
       stp-clc-pdv-330.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-clc-pdv-999.
       stp-clc-pdv-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per calcolo caratteristiche campo 'Note'       *
      *    *-----------------------------------------------------------*
       stp-clc-not-000.
      *              *-------------------------------------------------*
      *              * Lunghezza del campo                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo di stampa con dettaglio documenti   *
      *                  *---------------------------------------------*
           if        rr-tip-dts           =    02
                     move  025            to   w-stp-clc-not-lun
                     go to stp-clc-not-500.
      *                  *---------------------------------------------*
      *                  * Altrimenti in funzione del numero di perio- *
      *                  * di di riferimento                           *
      *                  *---------------------------------------------*
           if        rr-num-pdr           =    02
                     move  026            to   w-stp-clc-not-lun
           else if   rr-num-pdr           =    03
                     move  000            to   w-stp-clc-not-lun
           else      move  054            to   w-stp-clc-not-lun      .
       stp-clc-not-500.
      *              *-------------------------------------------------*
      *              * Posizione di stampa per il campo                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo di stampa con dettaglio documenti   *
      *                  *---------------------------------------------*
           if        rr-tip-dts           =    02
                     move  108            to   w-stp-clc-not-pos
                     go to stp-clc-not-999.
      *                  *---------------------------------------------*
      *                  * Altrimenti in funzione del numero di perio- *
      *                  * di di riferimento                           *
      *                  *---------------------------------------------*
           if        rr-num-pdr           =    02
                     move  107            to   w-stp-clc-not-pos
           else if   rr-num-pdr           =    03
                     move  000            to   w-stp-clc-not-pos
           else      move  079            to   w-stp-clc-not-pos      .
       stp-clc-not-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [fnt] e [dcf]                 *
      *    *-----------------------------------------------------------*
       let-fnt-dcf-000.
      *              *-------------------------------------------------*
      *              * Test se codice fornitore a zero                 *
      *              *-------------------------------------------------*
           if        w-let-fnt-dcf-fnt    =    zero
                     go to let-fnt-dcf-800.
      *              *-------------------------------------------------*
      *              * Test se codice e dipendenza pari ai valori pre- *
      *              * cedenti : ad uscita                             *
      *              *-------------------------------------------------*
           if        w-let-fnt-dcf-fnt    =    w-let-fnt-dcf-exc and
                     w-let-fnt-dcf-dpz    =    w-let-fnt-dcf-exd
                     go to let-fnt-dcf-900.
       let-fnt-dcf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione iniziale                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ragione sociale                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-rag      .
      *                  *---------------------------------------------*
      *                  * Mnemonico                                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-mne      .
      *                  *---------------------------------------------*
      *                  * Codice nazione                              *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-naz      .
      *                  *---------------------------------------------*
      *                  * Codice comune                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-let-fnt-dcf-cmn      .
      *                  *---------------------------------------------*
      *                  * Codice regione                              *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-rgn      .
      *                  *---------------------------------------------*
      *                  * Codice provincia                            *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-prv      .
       let-fnt-dcf-200.
      *              *-------------------------------------------------*
      *              * Lettura da archivio [fnt]                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT"             to   f-key                  .
           move      w-let-fnt-dcf-fnt    to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                  *---------------------------------------------*
      *                  * Memorizzazione di :                         *
      *                  *   - ragione sociale                         *
      *                  *   - mnemonico                               *
      *                  *   - codice nazione                          *
      *                  *   - codice comune                           *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     move  rf-fnt-rag-soc to   w-let-fnt-dcf-rag
                     move  rf-fnt-cod-mne to   w-let-fnt-dcf-mne
                     move  rf-fnt-cod-naz to   w-let-fnt-dcf-naz
                     move  rf-fnt-cod-cmn to   w-let-fnt-dcf-cmn      .
       let-fnt-dcf-300.
      *              *-------------------------------------------------*
      *              * Lettura da archivio [dcf] principale            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT"             to   f-key                  .
           move      w-let-fnt-dcf-fnt    to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                  *---------------------------------------------*
      *                  * Memorizzazione di :                         *
      *                  *   - ragione sociale                         *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     move  rf-dcf-rag-soc to   w-let-fnt-dcf-rag      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione codici :                     *
      *                  *  - Nazione                                  *
      *                  *  - Comune                                   *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     move  rf-dcf-cod-naz to   w-let-fnt-dcf-naz
                     move  rf-dcf-cod-cmn to   w-let-fnt-dcf-cmn      .
       let-fnt-dcf-400.
      *              *-------------------------------------------------*
      *              * Lettura da archivio [dcf] per la dipendenza     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non c'e' dipendenza : nessuna azione     *
      *                  *---------------------------------------------*
           if        w-let-fnt-dcf-dpz    =    spaces
                     go to let-fnt-dcf-500.
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT"             to   f-key                  .
           move      w-let-fnt-dcf-fnt    to   rf-dcf-cod-fnt         .
           move      w-let-fnt-dcf-dpz    to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                  *---------------------------------------------*
      *                  * Memorizzazione codice :                     *
      *                  *  - Comune                                   *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     move  rf-dcf-cod-cmn to   w-let-fnt-dcf-cmn      .
       let-fnt-dcf-500.
      *              *-------------------------------------------------*
      *              * Ad uscita                                       *
      *              *-------------------------------------------------*
           go to     let-fnt-dcf-900.
       let-fnt-dcf-800.
      *              *-------------------------------------------------*
      *              * Se codice fornitore a zero                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ragione sociale                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-rag      .
      *                  *---------------------------------------------*
      *                  * Mnemonico                                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-mne      .
      *                  *---------------------------------------------*
      *                  * Codice nazione                              *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-fnt-dcf-naz      .
      *                  *---------------------------------------------*
      *                  * Codice comune                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-let-fnt-dcf-cmn      .
       let-fnt-dcf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice e dipendenza letti su valori prece-  *
      *                  * denti                                       *
      *                  *---------------------------------------------*
           move      w-let-fnt-dcf-fnt    to   w-let-fnt-dcf-exc      .
           move      w-let-fnt-dcf-dpz    to   w-let-fnt-dcf-exd      .
       let-fnt-dcf-999.
           exit.

      *    *===========================================================*
      *    * Emissione sequenziale dati per grafico                    *
      *    *-----------------------------------------------------------*
       exe-sqz-grf-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        rr-gen-grf           not  = "S"
                     go to exe-sqz-grf-900.
           if        rr-tip-dts           not  = 03
                     go to exe-sqz-grf-900.
           if        rr-num-pdr           >    03
                     go to exe-sqz-grf-900.
           if        rr-cod-fnt           not  = zero
                     go to exe-sqz-grf-900.
       exe-sqz-grf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare valori grafico      *
      *              *-------------------------------------------------*
           move      "NO"                 to   m-gen-grf-tip-ope      .
           move      "pgm/svf/prg/obj/mgengrf0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using m-gen-grf              .
       exe-sqz-grf-150.
      *              *-------------------------------------------------*
      *              * Preparazione dati di generazione grafico        *
      *              *-------------------------------------------------*
           move      "EG"                 to   m-gen-grf-tip-ope      .
           move      "C"                  to   m-gen-grf-tip-grf      .
           move      spaces               to   m-gen-grf-tip-arc      .
           move      zero                 to   m-gen-grf-cod-arc      .
           move      spaces               to   m-gen-grf-mne-arc      .
           move      rr-num-pdr           to   m-gen-grf-num-prd      .
           move      "Statistica di acquisto "
                                          to   m-gen-grf-tit-grf      .
           move      "saf800"             to   m-gen-grf-fil-nam      .
       exe-sqz-grf-200.
      *              *-------------------------------------------------*
      *              * Emissione dati mensili per periodo              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione date periodi                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-cst-ct1      .
       exe-sqz-grf-300.
           add       1                    to   w-liv-gen-cst-ct1      .
           if        w-liv-gen-cst-ct1    >    rr-num-pdr
                     go to exe-sqz-grf-800.
           if        w-liv-gen-cst-ct1    =    01
                     move  rr-p1d-min     to   m-gen-grf-prd-min
                                              (w-liv-gen-cst-ct1)
                     move  rr-p1d-max     to   m-gen-grf-prd-max
                                              (w-liv-gen-cst-ct1)
           else if   w-liv-gen-cst-ct1    =    02
                     move  rr-p2d-min     to   m-gen-grf-prd-min
                                              (w-liv-gen-cst-ct1)
                     move  rr-p2d-max     to   m-gen-grf-prd-max
                                              (w-liv-gen-cst-ct1)
           else      move  rr-p3d-min     to   m-gen-grf-prd-min
                                              (w-liv-gen-cst-ct1)
                     move  rr-p3d-max     to   m-gen-grf-prd-max
                                              (w-liv-gen-cst-ct1)     .
       exe-sqz-grf-400.
      *              *-------------------------------------------------*
      *              * Ciclo dati mensili                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-liv-gen-cst-ctr      .
       exe-sqz-grf-500.
           add       1                    to   w-liv-gen-cst-ctr      .
           if        w-liv-gen-cst-ctr    >    12
                     go to exe-sqz-grf-600.
      *                  *---------------------------------------------*
      *                  * Preparazione dato mensile                   *
      *                  *---------------------------------------------*
           if        w-liv-gen-cst-ct1    =    01
                     move  w-liv-gen-mes-p1r
                          (w-liv-gen-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-gen-cst-ct1,
                                               w-liv-gen-cst-ctr)
           else if   w-liv-gen-cst-ct1    =    02
                     move  w-liv-gen-mes-p2r
                          (w-liv-gen-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-gen-cst-ct1,
                                               w-liv-gen-cst-ctr)
           else      move  w-liv-gen-mes-p3r
                          (w-liv-gen-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-gen-cst-ct1,
                                               w-liv-gen-cst-ctr)     .
      *                  *---------------------------------------------*
      *                  * Riciclo a mese successivo                   *
      *                  *---------------------------------------------*
           go to     exe-sqz-grf-500.
       exe-sqz-grf-600.
      *                  *---------------------------------------------*
      *                  * Riciclo a periodo successivo                *
      *                  *---------------------------------------------*
           go to     exe-sqz-grf-300.
       exe-sqz-grf-800.
      *              *-------------------------------------------------*
      *              * Chiamata modulo generazione grafico             *
      *              *-------------------------------------------------*
           move      "pgm/svf/prg/obj/mgengrf0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using m-gen-grf              .
       exe-sqz-grf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-sqz-grf-999.
       exe-sqz-grf-999.
           exit.

      *    *===========================================================*
      *    * Emissione sequenziale dati per grafico                    *
      *    *                                                           *
      *    * Ciclo di emissione grafico per un fornitore               *
