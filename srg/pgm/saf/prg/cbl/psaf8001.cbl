                     move  rr-p1d-min     to   m-gen-grf-prd-min
                                              (w-liv-fnt-cst-ct1)
                     move  rr-p1d-max     to   m-gen-grf-prd-max
                                              (w-liv-fnt-cst-ct1)
           else if   w-liv-fnt-cst-ct1    =    02
                     move  rr-p2d-min     to   m-gen-grf-prd-min
                                              (w-liv-fnt-cst-ct1)
                     move  rr-p2d-max     to   m-gen-grf-prd-max
                                              (w-liv-fnt-cst-ct1)
           else      move  rr-p3d-min     to   m-gen-grf-prd-min
                                              (w-liv-fnt-cst-ct1)
                     move  rr-p3d-max     to   m-gen-grf-prd-max
                                              (w-liv-fnt-cst-ct1)     .
       exe-sqz-grf-fnt-400.
      *              *-------------------------------------------------*
      *              * Ciclo dati mensili                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-liv-fnt-cst-ctr      .
       exe-sqz-grf-fnt-500.
           add       1                    to   w-liv-fnt-cst-ctr      .
           if        w-liv-fnt-cst-ctr    >    12
                     go to exe-sqz-grf-fnt-600.
      *                  *---------------------------------------------*
      *                  * Preparazione dato mensile                   *
      *                  *---------------------------------------------*
           if        w-liv-fnt-cst-ct1    =    01
                     move  w-liv-fnt-mes-p1r
                          (w-liv-fnt-cst-ctr)
                                          to   m-gen-grf-mes-val
