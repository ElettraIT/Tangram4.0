           move      "PF"                 to   x-ope                  .
           move      "D"                  to   x-tip                  .
           move      srt-est-doc-ddo      to   x-dat                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "A"                  to   x-tip                  .
           move      20                   to   x-car                  .
           move      srt-est-doc-ndo      to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
      *                  * Valore fatturato                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      srt-val-sta-val      to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                      *-----------------------------------------*
      *                      * In campo di uscita                      *
      *                      *-----------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "A"                  to   x-tip                  .
           move      16                   to   x-car                  .
           move      w-stp-edt-fat-edt    to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
       exe-gen-fil-doc-800.
      *              *-------------------------------------------------*
      *              * Emissione riga                                  *
