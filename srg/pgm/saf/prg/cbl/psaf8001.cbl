                     move  w-liv-fnt-mes-p2r
                          (w-liv-fnt-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-fnt-cst-ct1,
                                               w-liv-fnt-cst-ctr)
           else      move  w-liv-fnt-mes-p3r
                          (w-liv-fnt-cst-ctr)
