      *                  * Test se presenti tutti gli elementi         *
      *                  *---------------------------------------------*
           if        w-tes-abi-ban        =    zero or
                     w-tes-cab-ban        =    zero or
                     w-tes-sgl-ccb        =    spaces
                     go to acc-sgl-ccb-640.
      *                  *---------------------------------------------*
      *                  * Verifica di congruenza sul codice CIN       *
      *                  *---------------------------------------------*
           move      "VC"                 to   w-cod-cod-cin-ope      .
           move      w-tes-abi-ban        to   w-cod-cod-cin-abi      .
           move      w-tes-cab-ban        to   w-cod-cod-cin-cab      .
           move      w-tes-sgl-ccb        to   w-cod-cod-cin-ccc      .
           move      w-tes-cin-ita        to   w-cod-cod-cin-cod      .
           perform   cod-cod-cin-cll-000  thru cod-cod-cin-cll-999    .
      *                  *---------------------------------------------*
      *                  * Valore determinato                          *
      *                  *---------------------------------------------*
           move      w-cod-cod-cin-cod    to   w-tes-cin-ita          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-cin-ita-000      thru vis-cin-ita-999        .
      *                  *---------------------------------------------*
      *                  * Verifica di congruenza sul codice CIN       *
      *                  *---------------------------------------------*
           move      "VE"                 to   w-cod-cod-cin-ope      .
           move      "IT"                 to   w-cod-cod-cin-naz      .
           move      w-tes-cin-ita        to   w-cod-cod-cin-cod      .
           move      w-tes-abi-ban        to   w-cod-cod-cin-abi      .
           move      w-tes-cab-ban        to   w-cod-cod-cin-cab      .
           move      w-tes-sgl-ccb        to   w-cod-cod-cin-ccc      .
           move      "00"                 to   w-cod-cod-cin-chd      .
           perform   cod-cod-cin-cll-000  thru cod-cod-cin-cll-999    .
      *                  *---------------------------------------------*
      *                  * Valore determinato                          *
      *                  *---------------------------------------------*
           move      w-cod-cod-cin-chd    to   w-tes-cin-eur          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-cin-eur-000      thru vis-cin-eur-999        .
       acc-sgl-ccb-640.
      *                  *---------------------------------------------*
      *                  * Visualizzazione IBAN                        *
      *                  *---------------------------------------------*
           perform   vis-cod-ibn-000      thru vis-cod-ibn-999        .
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-sgl-ccb        to   w-all-str-alf          .
           move      12                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-sgl-ccb-700.
      *                  *---------------------------------------------*
      *                  * Controllo se di 12 caratteri                *
      *                  *---------------------------------------------*
           if        w-tes-sgl-ccb        =    spaces
                     go to acc-sgl-ccb-800.
      *
           move      w-tes-sgl-ccb        to   w-all-str-alf          .
           perform   all-str-lun-000      thru all-str-lun-999        .
      *
           if        w-all-str-lun        =    12
                     go to acc-sgl-ccb-800.
       acc-sgl-ccb-700.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "La sigla del conto corrente non dovrebbe contenere
      -              " spazi vuoti!  "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-ccb-100.
       acc-sgl-ccb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-sgl-ccb-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-sgl-ccb-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-sgl-ccb-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-sgl-ccb-999.
       acc-sgl-ccb-999.
           exit.

      *    *===========================================================*
