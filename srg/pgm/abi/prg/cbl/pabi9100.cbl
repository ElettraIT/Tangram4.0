      *    *-----------------------------------------------------------*
       vis-sgl-ccb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      18                   to   v-pos                  .
           move      w-tes-sgl-ccb        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-ccb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : CIN europeo                       *
      *    *-----------------------------------------------------------*
       vis-cin-eur-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      43                   to   v-pos                  .
           move      w-tes-cin-eur        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
