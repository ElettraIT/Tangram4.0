                     go to acc-cod-abi-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cod-abi-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-cod-abi-sos-600.
       acc-cod-abi-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-cod-abi-so2-000  thru acc-cod-abi-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cod-abi-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cod-abi-sos-200.
       acc-cod-abi-sos-600.
      *              *-------------------------------------------------*
