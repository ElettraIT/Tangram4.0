      *                  * Lunghezza della stringa                     *
      *                  *---------------------------------------------*
           move      50                   to   w-all-str-lun          .
      *                  *---------------------------------------------*
      *                  * Numero elementi da concatenare              *
      *                  *---------------------------------------------*
           move      4                    to   w-all-str-num          .
      *                  *---------------------------------------------*
      *                  * 1. elemento da concatenare                  *
      *                  *                                             *
      *                  * Codice categoria provvigione editato        *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      5                    to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-stp-ccp-cod-cpv    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (1)      .
      *                  *---------------------------------------------*
      *                  * 2. elemento da concatenare                  *
      *                  *                                             *
      *                  * Mnemonico categoria provvigione             *
      *                  *---------------------------------------------*
           move      w-stp-ccp-mne-cpv    to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
      *                  * 3. elemento da concatenare                  *
      *                  *                                             *
      *                  * Due punti di separazione                    *
      *                  *---------------------------------------------*
           move      ":"                  to   w-all-str-cat (3)      .
      *                  *---------------------------------------------*
      *                  * 4. elemento da concatenare                  *
      *                  *                                             *
      *                  * Descrizione categoria provvigione           *
      *                  *---------------------------------------------*
           move      w-stp-ccp-des-cpv    to   w-all-str-cat (4)      .
      *                  *---------------------------------------------*
      *                  * Richiamo routine di concatenazione che la-  *
      *                  * scia uno spazio di separazione fra ognuno   *
      *                  * degli elementi                              *
      *                  *---------------------------------------------*
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Richiamo routine di allineamento della      *
      *                  * stringa al centro                           *
      *                  *---------------------------------------------*
           perform   all-str-cen-000      thru all-str-cen-999        .
      *              *-------------------------------------------------*
      *              * Stampa del risultato                            *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      50                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      16                   to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-fnc-ccp-l02-999.
           exit.

