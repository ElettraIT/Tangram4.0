           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa linea                                *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      80                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      01                   to   p-pos                  .
           move      w-stp-det-lin-stp
                    (w-stp-det-inx-000)   to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
