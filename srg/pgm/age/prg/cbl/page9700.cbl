                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su [gpm] per numero conteggio             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CTGMTZ    "         to   f-key                  .
           move      zero                 to   rf-gpm-num-ctg         .
           move      zero                 to   rf-gpm-num-mtz         .
           move      "pgm/age/fls/ioc/obj/iofgpm"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gpm                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Next su [gpm]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofgpm"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gpm                 .
      *                  *---------------------------------------------*
      *                  * Se At end : ad uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Max su [gpm]                                    *
      *              *-------------------------------------------------*
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [gpm]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data maturazione                    *
      *                  *---------------------------------------------*
           if        rf-gpm-dat-mtz       >    rr-dat-max or
                     rf-gpm-dat-mtz       <    rr-dat-min
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su codice agente                       *
      *                  *---------------------------------------------*
           if        rr-cod-age           =    zero
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [gpc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofgpc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gpc                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [gpc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMCTG"             to   f-key                  .
           move      rf-gpm-num-ctg       to   rf-gpc-num-ctg         .
           move      "pgm/age/fls/ioc/obj/iofgpc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gpc                 .
      *                      *-----------------------------------------*
      *                      * Test se record [gpc] trovato            *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su codice agente                       *
      *                  *---------------------------------------------*
           if        rf-gpc-cod-age       not  = rr-cod-age
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Composizione record [srt]                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Numero maturazione                          *
      *                  *---------------------------------------------*
           move      rf-gpm-num-mtz       to   srt-num-mtz            .
      *                  *---------------------------------------------*
      *                  * Numero conteggio                            *
      *                  *---------------------------------------------*
           move      rf-gpm-num-ctg       to   srt-num-ctg            .
      *                  *---------------------------------------------*
      *                  * Data maturazione                            *
      *                  *---------------------------------------------*
           move      rf-gpm-dat-mtz       to   srt-dat-mtz            .
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

