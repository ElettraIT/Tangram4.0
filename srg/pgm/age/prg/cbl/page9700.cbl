      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su data minima documenti              *
      *              *-------------------------------------------------*
       tdo-ric-sel-105.
           if        rr-dat-min           not  = zero
                     go to tdo-ric-sel-200.
           move      "Manca la data minima fatture !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su data massima documenti             *
      *              *-------------------------------------------------*
       tdo-ric-sel-205.
           if        rr-dat-max           not  = zero
                     go to tdo-ric-sel-300.
           move      "Manca la data massima fatture !                   
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo su data minima/massima documenti      *
      *              *-------------------------------------------------*
           if        rr-dat-max           not  < rr-dat-min
                     go to tdo-ric-sel-400.
           move      "La data massima e' inferiore della minima !       
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
