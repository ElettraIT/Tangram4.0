      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vpg-100.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vpg-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vpg-100.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata e accet-  *
      *                  * tazione presa visione                       *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vpg-200.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo conteggio                       *
      *    *-----------------------------------------------------------*
       acc-tip-ctg-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-ctg-025.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del default          *
      *                  *---------------------------------------------*
           if        w-tes-tip-ctg (1)    not  = zero
                     go to acc-tip-ctg-100.
      *                  *---------------------------------------------*
      *                  * Conteggio a fronte fattura                  *
      *                  *---------------------------------------------*
           move      01                   to   w-tes-tip-ctg (1)      .
       acc-tip-ctg-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ctg-lun    to   v-car                  .
           move      w-exp-tip-ctg-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-ctg-tbl    to   v-txt                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (08)             .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           if        w-tes-tip-ctg (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-ctg (1)    =    02
                     move  02             to   v-num
           else if   w-tes-tip-ctg (1)    =    03
                     move  03             to   v-num
           else if   w-tes-tip-ctg (1)    =    11
                     move  04             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ctg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ctg-999.
       acc-tip-ctg-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-ctg (1)
           else if   v-num                =    02
                     move  02             to   w-tes-tip-ctg (1)
           else if   v-num                =    03
                     move  03             to   w-tes-tip-ctg (1)
           else if   v-num                =    04
                     move  11             to   w-tes-tip-ctg (1)
           else      move  zero           to   w-tes-tip-ctg (1)      .
       acc-tip-ctg-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tip-ctg-425.
      *                  *---------------------------------------------*
      *                  * Test che il valore sia accettabile          *
      *                  *---------------------------------------------*
           if        w-tes-tip-ctg (1)    =    zero           or
                     w-tes-tip-ctg (1)    >    11
                     go to acc-tip-ctg-100.
       acc-tip-ctg-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuali normalizzazioni se conteggio in   *
      *                  * relazione a nota di accredito               *
      *                  *---------------------------------------------*
           if        w-tes-tip-ctg (1)    not  = 03 and
                     w-tes-tip-ctg (1)    not  = 11
                     go to acc-tip-ctg-800.
       acc-tip-ctg-620.
      *                  *---------------------------------------------*
      *                  * Trattamento della data minima di maturazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-tes-ddm-min (1)    =    zero
                     go to acc-tip-ctg-640.
      *                  *---------------------------------------------*
      *                  * Normalizzazione della data minima di matu-  *
      *                  * razione                                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-ddm-min (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione della data minima di matu-  *
      *                  * razione                                     *
      *                  *---------------------------------------------*
           perform   vis-ddm-min-000      thru vis-ddm-min-999        .
       acc-tip-ctg-640.
      *                  *---------------------------------------------*
      *                  * Trattamento del tipo di maturazione         *
      *                  *---------------------------------------------*
           if        w-tes-tip-mat (1)    =    01
                     go to acc-tip-ctg-660.
      *                  *---------------------------------------------*
      *                  * Normalizzazione del tipo di maturazione     *
      *                  *---------------------------------------------*
           move      01                   to   w-tes-tip-mat (1)      .
       acc-tip-ctg-660.
      *                  *---------------------------------------------*
      *                  * Trattamento maturazione bloccata            *
      *                  *---------------------------------------------*
           if        w-tes-mat-blo (1)    =    01
                     go to acc-tip-ctg-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione maturazione bloccata        *
      *                  *---------------------------------------------*
           move      01                   to   w-tes-mat-blo (1)      .
       acc-tip-ctg-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-ctg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-ctg-100.
       acc-tip-ctg-999.
           exit.

