      *                  *---------------------------------------------*
      *                  * Se numero movimento attuale contenuto nel   *
      *                  * record numerazioni uguale al valore post-   *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento del valore attuale  *
      *                      * contenuto nel record numerazioni, ri-   *
      *                      * portandolo al valore pre-incremento     *
      *                      *-----------------------------------------*
           move      w-num-gpc-val-pre    to   w-num-gpc-num-gpc      .
           move      w-num-gpc-num-gpc    to   rn-num-gpc-num-gpc     .
      *                      *-----------------------------------------*
      *                      * Update record numerazioni               *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/age/num/ioc/obj/innumgpc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-gpc             .
      *                      *-----------------------------------------*
      *                      * Unlock record numerazioni               *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/age/num/ioc/obj/innumgpc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-gpc             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-num-gpc-999.
       rip-num-gpc-999.
           exit.

