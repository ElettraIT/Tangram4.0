       scl-pvg-acc-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione indice su elementi 1..max      *
      *              *-------------------------------------------------*
           move      1                    to   w-scl-pvg-wac-iel      .
       scl-pvg-acc-100.
      *              *-------------------------------------------------*
      *              * Accettazione elemento                           *
      *              *-------------------------------------------------*
       scl-pvg-acc-200.
      *                  *---------------------------------------------*
      *                  * Sconti                                      *
      *                  *---------------------------------------------*
       scl-pvg-acc-205.
      *                      *-----------------------------------------*
      *                      * Inizializzazione indice 1..3            *
      *                      *-----------------------------------------*
           move      1                    to   w-scl-pvg-wac-ioc      .
       scl-pvg-acc-210.
      *                      *-----------------------------------------*
      *                      * Accettazione sconto                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      "AC"                 to   v-ope                  .
      *                          *-------------------------------------*
      *                          * Tipo campo                          *
      *                          *-------------------------------------*
           move      "N"                  to   v-tip                  .
      *                          *-------------------------------------*
      *                          * Caratteri                           *
      *                          *-------------------------------------*
           move      02                   to   v-car                  .
      *                          *-------------------------------------*
      *                          * Decimali                            *
      *                          *-------------------------------------*
           move      1                    to   v-dec                  .
      *                          *-------------------------------------*
      *                          * Segno algebrico                     *
      *                          *-------------------------------------*
           move      spaces               to   v-sgn                  .
      *                          *-------------------------------------*
      *                          * Edit mask                           *
      *                          *-------------------------------------*
           move      "BD"                 to   v-edm                  .
      *                          *-------------------------------------*
      *                          * Linea                               *
      *                          *-------------------------------------*
           move      w-scl-pvg-inp-lin    to   v-lin                  .
           add       w-scl-pvg-wac-iel    to   v-lin                  .
           add       01                   to   v-lin                  .
      *                          *-------------------------------------*
      *                          * Posizione                           *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-ioc    to   v-pos                  .
           subtract  1                    from v-pos                  .
           multiply  6                    by   v-pos                  .
           add       w-scl-pvg-inp-pos    to   v-pos                  .
           add       7                    to   v-pos                  .
      *                          *-------------------------------------*
      *                          * Function keys                       *
      *                          *-------------------------------------*
           if        w-scl-pvg-inp-pfk (01)
                                          =    "UP  " or
                     w-scl-pvg-wac-iel    >    1      or
                     w-scl-pvg-wac-ioc    >    1
                     move  "UP  "         to   v-pfk (01)             .
           if        w-scl-pvg-inp-pfk (02)
                                          =    "DOWN" or
                     w-scl-pvg-wac-iel    <    6
                     move  "DOWN"         to   v-pfk (02)             .
           if        w-scl-pvg-wac-ioc    >    1
                     move  spaces         to   v-pfk (02)             .
           if        w-scl-pvg-wac-iel    <    6 and
                     w-scl-pvg-wac-ioc    =    1
                     move  "INSR"         to   v-pfk (04)             .
           if        w-scl-pvg-inp-pfk (05)
                                          =    "DO  " and
                     w-scl-pvg-wac-ioc    =    1
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           if        w-scl-pvg-inp-pfk (07)
                                          =    "PRSC" and
                     w-scl-pvg-wac-ioc    =    1
                     move  "PRSC"         to   v-pfk (07)             .
           if        w-scl-pvg-inp-pfk (08)
                                          =    "NXSC" and
                     w-scl-pvg-wac-ioc    =    1
                     move  "NXSC"         to   v-pfk (08)             .
           move      "TAB "               to   v-pfk (10)             .
      *                          *-------------------------------------*
      *                          * Valore                              *
      *                          *-------------------------------------*
           move      w-scl-pvg-inp-sco
                    (w-scl-pvg-wac-iel,
                     w-scl-pvg-wac-ioc)   to   v-num                  .
      *                          *-------------------------------------*
      *                          * Accettazione                        *
      *                          *-------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       scl-pvg-acc-215.
      *                      *-----------------------------------------*
      *                      * Se Exit o Delt                          *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT" or
                     v-key                =    "DELT"
                     go to scl-pvg-acc-999.
       scl-pvg-acc-220.
      *                      *-----------------------------------------*
      *                      * Valore impostato in campo di destina-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      v-num                to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wac-iel,
                                               w-scl-pvg-wac-ioc)     .
       scl-pvg-acc-225.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda della function key *
      *                      * impostata                               *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to scl-pvg-acc-230
           else if   v-key                =    "DOWN"
                     go to scl-pvg-acc-240
           else if   v-key                =    "INSR"
                     go to scl-pvg-acc-250
           else if   v-key                =    "DO  "
                     go to scl-pvg-acc-255
           else if   v-key                =    "REMV"
                     go to scl-pvg-acc-260
           else if   v-key                =    "PRSC"
                     go to scl-pvg-acc-265
           else if   v-key                =    "NXSC"
                     go to scl-pvg-acc-270
           else if   v-key                =    "TAB "
                     go to scl-pvg-acc-280
           else      go to scl-pvg-acc-300.
       scl-pvg-acc-230.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se non si e' sulla prima occorren-  *
      *                          * za : a Backtab                      *
      *                          *-------------------------------------*
           if        w-scl-pvg-wac-ioc    not  = 1
                     go to scl-pvg-acc-290.
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Rimozione elemento attuale se vuoto *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      "V"                  to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                          *-------------------------------------*
      *                          * Se non si e' sul primo elemento :   *
      *                          * si decrementa l'indice e si rici-   *
      *                          * cla sull'elemento precedente        *
      *                          *-------------------------------------*
           if        w-scl-pvg-wac-iel    not  = 1
                     subtract  1          from w-scl-pvg-wac-iel
                     go to scl-pvg-acc-100.
      *                          *-------------------------------------*
      *                          * Se si e' sul primo elemento : si    *
      *                          * controlla il formato interno della  *
      *                          * scaletta                            *
      *                          *-------------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta non e' corretto : si torna a re- *
      *                          * impostare                           *
      *                          *-------------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta e' corretto : uscita con Up      *
      *                          *-------------------------------------*
           move      "UP  "               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-240.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
       scl-pvg-acc-241.
      *                          *-------------------------------------*
      *                          * Se non si e' sulla prima occorren-  *
      *                          * za : a Tab                          *
      *                          *-------------------------------------*
           if        w-scl-pvg-wac-ioc    not  = 1
                     go to scl-pvg-acc-280.
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda se l'elemento  *
      *                          * attuale e' vuoto oppure no          *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-acc-243
           else      go to scl-pvg-acc-245.
       scl-pvg-acc-243.
      *                          *-------------------------------------*
      *                          * Se l'elemento attuale e' vuoto      *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se si e' sull'ultimo elemento : *
      *                              * ci si riaggancia al trattamento *
      *                              * per l'ultimo elemento           *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-iel    =    w-scl-pvg-inp-max
                     go to scl-pvg-acc-246.
      *                              *---------------------------------*
      *                              * Se anche l'elemento successivo  *
      *                              * e' vuoto : ci si riaggancia al  *
      *                              * trattamento per l'ultimo ele-   *
      *                              * mento                           *
      *                              *---------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           add       1                    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-acc-246.
      *                              *---------------------------------*
      *                              * Altrimenti si rimuove l'elemen- *
      *                              * to attuale                      *
      *                              *---------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      spaces               to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                              *---------------------------------*
      *                              * E si torna a reimpostare        *
      *                              *---------------------------------*
           go to     scl-pvg-acc-210.
       scl-pvg-acc-245.
      *                          *-------------------------------------*
      *                          * Se l'elemento attuale non e' vuoto  *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se non si e' sull'ultimo ele-   *
      *                              * mento : si incrementa l'indice  *
      *                              * e si ricicla sull'elemento suc- *
      *                              * cessivo                         *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-iel    not  = w-scl-pvg-inp-max
                     add   1              to   w-scl-pvg-wac-iel
                     go to scl-pvg-acc-100.
       scl-pvg-acc-246.
      *                              *---------------------------------*
      *                              * Se si e' sull'ultimo elemento : *
      *                              * si controlla il formato interno *
      *                              * della scaletta                  *
      *                              *---------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                              *---------------------------------*
      *                              * Se il formato interno della     *
      *                              * scaletta non e' corretto : si   *
      *                              * torna a reimpostare             *
      *                              *---------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                              *---------------------------------*
      *                              * Se il formato interno della     *
      *                              * scaletta e' corretto : uscita   *
      *                              * con Down                        *
      *                              *---------------------------------*
           move      "DOWN"               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-250.
      *                      *-----------------------------------------*
      *                      * Se Insr                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Se se l'elemento attuale e' vuoto : *
      *                          * si torna a reimpostare              *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Inserimento di un elemento          *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           perform   scl-pvg-ins-000      thru scl-pvg-ins-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a impostazione stesso ele-  *
      *                          * mento                               *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-210.
       scl-pvg-acc-255.
      *                      *-----------------------------------------*
      *                      * Se Do                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Rimozione elemento attuale se vuoto *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      "V"                  to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                          *-------------------------------------*
      *                          * Controllo del formato interno della *
      *                          * scaletta                            *
      *                          *-------------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta non e' corretto : si torna a re- *
      *                          * impostare                           *
      *                          *-------------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta e' corretto : uscita con Do      *
      *                          *-------------------------------------*
           move      "DO  "               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-260.
      *                      *-----------------------------------------*
      *                      * Se Remv                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rimozione di un elemento            *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      spaces               to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a impostazione stesso ele-  *
      *                          * mento                               *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-210.
       scl-pvg-acc-265.
      *                      *-----------------------------------------*
      *                      * Se Prsc                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Rimozione elemento attuale se vuoto *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      "V"                  to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                          *-------------------------------------*
      *                          * Controllo del formato interno della *
      *                          * scaletta                            *
      *                          *-------------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta non e' corretto : si torna a re- *
      *                          * impostare                           *
      *                          *-------------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta e' corretto : uscita con Prsc    *
      *                          *-------------------------------------*
           move      "PRSC"               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-270.
      *                      *-----------------------------------------*
      *                      * Se Nxsc                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Rimozione elemento attuale se vuoto *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      "V"                  to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                          *-------------------------------------*
      *                          * Controllo del formato interno della *
      *                          * scaletta                            *
      *                          *-------------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta non e' corretto : si torna a re- *
      *                          * impostare                           *
      *                          *-------------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-210.
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta e' corretto : uscita con Nxsc    *
      *                          *-------------------------------------*
           move      "NXSC"               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-280.
      *                      *-----------------------------------------*
      *                      * Se Tab                                  *
      *                      *-----------------------------------------*
       scl-pvg-acc-281.
      *                          *-------------------------------------*
      *                          * Se si e' sulla prima occorrenza     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-ioc    not  = 1
                     go to scl-pvg-acc-282.
      *                              *---------------------------------*
      *                              * Se si e' sul primo elemento :   *
      *                              * come per occorrenza successiva  *
      *                              * alla prima                      *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-iel    =    1
                     go to scl-pvg-acc-282.
      *                              *---------------------------------*
      *                              * Se l'elemento non e' vuoto :    *
      *                              * come per occorrenza successiva  *
      *                              * alla prima                      *
      *                              *---------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    not  = "V"
                     go to scl-pvg-acc-282.
      *                              *---------------------------------*
      *                              * Se si e' sull'ultimo elemento : *
      *                              * come per Down                   *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-iel    =    w-scl-pvg-inp-max
                     go to scl-pvg-acc-240.
      *                              *---------------------------------*
      *                              * Se anche l'elemento successivo  *
      *                              * e' vuoto : come per Down        *
      *                              *---------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           add       1                    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-acc-240.
       scl-pvg-acc-282.
      *                          *-------------------------------------*
      *                          * Se non si e' sulla prima occorrenza *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Incremento indice su occorrenza *
      *                              *---------------------------------*
           add       1                    to   w-scl-pvg-wac-ioc      .
      *                              *---------------------------------*
      *                              * Se entro il massimo numero di   *
      *                              * occorrenza : riciclo su occor-  *
      *                              * renza successiva                *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-ioc    not  > 3
                     go to scl-pvg-acc-210.
      *                              *---------------------------------*
      *                              * Altrimenti : come per Return    *
      *                              *---------------------------------*
           go to     scl-pvg-acc-300.
       scl-pvg-acc-290.
      *                      *-----------------------------------------*
      *                      * Se Backtab                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Decremento indice su occorrenza     *
      *                          *-------------------------------------*
           subtract  1                    from w-scl-pvg-wac-ioc      .
      *                          *-------------------------------------*
      *                          * Riciclo su occorrenza precedente    *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-210.
       scl-pvg-acc-300.
      *                      *-----------------------------------------*
      *                      * Se Return                               *
      *                      *-----------------------------------------*
       scl-pvg-acc-301.
      *                          *-------------------------------------*
      *                          * Se si e' sulla prima occorrenza     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-ioc    not  = 1
                     go to scl-pvg-acc-302.
      *                              *---------------------------------*
      *                              * Se si e' sul primo elemento :   *
      *                              * come per occorrenza successiva  *
      *                              * alla prima                      *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-iel    =    1
                     go to scl-pvg-acc-302.
      *                              *---------------------------------*
      *                              * Se l'elemento non e' vuoto :    *
      *                              * come per occorrenza successiva  *
      *                              * alla prima                      *
      *                              *---------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    not  = "V"
                     go to scl-pvg-acc-302.
      *                              *---------------------------------*
      *                              * Se si e' sull'ultimo elemento : *
      *                              * come per Down                   *
      *                              *---------------------------------*
           if        w-scl-pvg-wac-iel    =    w-scl-pvg-inp-max
                     go to scl-pvg-acc-240.
      *                              *---------------------------------*
      *                              * Se anche l'elemento successivo  *
      *                              * e' vuoto : come per Down        *
      *                              *---------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           add       1                    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-acc-240.
       scl-pvg-acc-302.
      *                          *-------------------------------------*
      *                          * Se non si e' sulla prima occorrenza *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Ad accettazione provvigione     *
      *                              *---------------------------------*
           go to     scl-pvg-acc-400.
       scl-pvg-acc-400.
      *                  *---------------------------------------------*
      *                  * Provvigione                                 *
      *                  *---------------------------------------------*
       scl-pvg-acc-405.
      *                      *-----------------------------------------*
      *                      * Inizializzazione indice 1..1            *
      *                      *-----------------------------------------*
           move      1                    to   w-scl-pvg-wac-ioc      .
       scl-pvg-acc-410.
      *                      *-----------------------------------------*
      *                      * Accettazione provvigione                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      "AC"                 to   v-ope                  .
      *                          *-------------------------------------*
      *                          * Tipo campo                          *
      *                          *-------------------------------------*
           move      "N"                  to   v-tip                  .
      *                          *-------------------------------------*
      *                          * Caratteri                           *
      *                          *-------------------------------------*
           move      02                   to   v-car                  .
      *                          *-------------------------------------*
      *                          * Decimali                            *
      *                          *-------------------------------------*
           move      1                    to   v-dec                  .
      *                          *-------------------------------------*
      *                          * Segno algebrico                     *
      *                          *-------------------------------------*
           move      spaces               to   v-sgn                  .
      *                          *-------------------------------------*
      *                          * Edit mask                           *
      *                          *-------------------------------------*
           move      "BD"                 to   v-edm                  .
      *                          *-------------------------------------*
      *                          * Linea                               *
      *                          *-------------------------------------*
           move      w-scl-pvg-inp-lin    to   v-lin                  .
           add       w-scl-pvg-wac-iel    to   v-lin                  .
           add       01                   to   v-lin                  .
      *                          *-------------------------------------*
      *                          * Posizione                           *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-ioc    to   v-pos                  .
           subtract  1                    from v-pos                  .
           multiply  6                    by   v-pos                  .
           add       w-scl-pvg-inp-pos    to   v-pos                  .
           add       38                   to   v-pos                  .
      *                          *-------------------------------------*
      *                          * Function keys                       *
      *                          *-------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
      *                          *-------------------------------------*
      *                          * Valore                              *
      *                          *-------------------------------------*
           move      w-scl-pvg-inp-pvg
                    (w-scl-pvg-wac-iel, 1)
                                          to   v-num                  .
      *                          *-------------------------------------*
      *                          * Accettazione                        *
      *                          *-------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       scl-pvg-acc-415.
      *                      *-----------------------------------------*
      *                      * Se Exit o Delt                          *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT" or
                     v-key                =    "DELT"
                     go to scl-pvg-acc-999.
       scl-pvg-acc-420.
      *                      *-----------------------------------------*
      *                      * Valore impostato in campo di destina-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      v-num                to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wac-iel, 1)  .
       scl-pvg-acc-425.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda della function key *
      *                      * impostata                               *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to scl-pvg-acc-430
           else if   v-key                =    "DOWN"
                     go to scl-pvg-acc-440
           else if   v-key                =    "REMV"
                     go to scl-pvg-acc-460
           else if   v-key                =    "TAB "
                     go to scl-pvg-acc-480
           else      go to scl-pvg-acc-500.
       scl-pvg-acc-430.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ad accettazione sconti              *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-200.
       scl-pvg-acc-440.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Come per Return                     *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-500.
       scl-pvg-acc-460.
      *                      *-----------------------------------------*
      *                      * Se Remv                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rimozione di un elemento            *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wir-inx      .
           move      spaces               to   w-scl-pvg-wir-fsv      .
           perform   scl-pvg-rem-000      thru scl-pvg-rem-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a impostazione stesso ele-  *
      *                          * mento                               *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-100.
       scl-pvg-acc-480.
      *                      *-----------------------------------------*
      *                      * Se Tab                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Come per Return                     *
      *                          *-------------------------------------*
           go to     scl-pvg-acc-500.
       scl-pvg-acc-500.
      *                      *-----------------------------------------*
      *                      * Se Return                               *
      *                      *-----------------------------------------*
       scl-pvg-acc-501.
      *                          *-------------------------------------*
      *                          * Controllo sul singolo elemento      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wdr-inx      .
           perform   scl-pvg-tdr-000      thru scl-pvg-tdr-999        .
      *                          *-------------------------------------*
      *                          * Se controllo non superato : si ri-  *
      *                          * cicla a reimpostare                 *
      *                          *-------------------------------------*
           if        w-scl-pvg-wdr-flg    not  = spaces
                     go to scl-pvg-acc-410.
      *                          *-------------------------------------*
      *                          * Se se l'elemento attuale non e'     *
      *                          * vuoto : si continua                 *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    not  = "V"
                     go to scl-pvg-acc-502.
      *                          *-------------------------------------*
      *                          * Se se l'elemento attuale non e' il  *
      *                          * primo elemento : si torna a reimpo- *
      *                          * stare                               *
      *                          *-------------------------------------*
           if        w-scl-pvg-wac-iel    not  = 1
                     go to scl-pvg-acc-410.
      *                          *-------------------------------------*
      *                          * Se se l'elemento successivo non e'  *
      *                          * vuoto : si torna a reimpostare      *
      *                          *-------------------------------------*
           move      w-scl-pvg-wac-iel    to   w-scl-pvg-wtv-inx      .
           add       1                    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    not  = "V"
                     go to scl-pvg-acc-410.
      *                          *-------------------------------------*
      *                          * Si controlla il formato interno     *
      *                          * della scaletta                      *
      *                          *-------------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                          *-------------------------------------*
      *                          * Se il formato interno della sca-    *
      *                          * letta non e' corretto : si torna a  *
      *                          * reimpostare                         *
      *                          *-------------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-410.
      *                          *-------------------------------------*
      *                          * Se il formato interno della sca-    *
      *                          * letta e' corretto : uscita con      *
      *                          * Down                                *
      *                          *-------------------------------------*
           move      "DOWN"               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-502.
      *                          *-------------------------------------*
      *                          * Se non si e' sull'ultimo elemento : *
      *                          * si incrementa l'indice e si rici-   *
      *                          * cla sull'elemento successivo        *
      *                          *-------------------------------------*
           if        w-scl-pvg-wac-iel    not  = w-scl-pvg-inp-max
                     add   1              to   w-scl-pvg-wac-iel
                     go to scl-pvg-acc-100.
      *                          *-------------------------------------*
      *                          * Se si e' sull'ultimo elemento : si  *
      *                          * controlla il formato interno della  *
      *                          * scaletta                            *
      *                          *-------------------------------------*
           perform   scl-pvg-ctl-000      thru scl-pvg-ctl-999        .
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta non e' corretto : si torna a re- *
      *                          * impostare                           *
      *                          *-------------------------------------*
           if        w-scl-pvg-wct-flg    not  = spaces
                     go to scl-pvg-acc-410.
      *                          *-------------------------------------*
      *                          * Se il formato interno della scalet- *
      *                          * ta e' corretto : uscita con Return  *
      *                          *-------------------------------------*
           move      spaces               to   v-key                  .
           go to     scl-pvg-acc-999.
       scl-pvg-acc-999.
           exit.

      *    *-----------------------------------------------------------*
      *    * Test se elemento visibile della scaletta vuoto            *
      *    *-----------------------------------------------------------*
       scl-pvg-tsv-000.
      *              *-------------------------------------------------*
      *              * Test su sconti                                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-scl-pvg-wtv-ix0      .
       scl-pvg-tsv-010.
           add       1                    to   w-scl-pvg-wtv-ix0      .
           if        w-scl-pvg-wtv-ix0    >    3
                     go to scl-pvg-tsv-100.
           if        w-scl-pvg-inp-sco
                    (w-scl-pvg-wtv-inx,
                     w-scl-pvg-wtv-ix0)   =    zero
                     go to scl-pvg-tsv-010
           else      go to scl-pvg-tsv-900.
       scl-pvg-tsv-100.
      *              *-------------------------------------------------*
      *              * Test su provvigioni                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-scl-pvg-wtv-ix0      .
       scl-pvg-tsv-110.
           add       1                    to   w-scl-pvg-wtv-ix0      .
           if        w-scl-pvg-wtv-ix0    >    1
                     go to scl-pvg-tsv-800.
           if        w-scl-pvg-inp-pvg
                    (w-scl-pvg-wtv-inx,
                     w-scl-pvg-wtv-ix0)   =    zero
                     go to scl-pvg-tsv-110
           else      go to scl-pvg-tsv-900.
       scl-pvg-tsv-800.
      *              *-------------------------------------------------*
      *              * Se elemento vuoto                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di risposta                            *
      *                  *---------------------------------------------*
           move      "V"                  to   w-scl-pvg-wtv-fev      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-tsv-999.
       scl-pvg-tsv-900.
      *              *-------------------------------------------------*
      *              * Se elemento non vuoto                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di risposta                            *
      *                  *---------------------------------------------*
           move      spaces               to   w-scl-pvg-wtv-fev      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-tsv-999.
       scl-pvg-tsv-999.
           exit.

      *    *-----------------------------------------------------------*
      *    * Inserimento di un elemento nella scaletta                 *
      *    *-----------------------------------------------------------*
       scl-pvg-ins-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione indice su elemento di destina- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           move      6                    to   w-scl-pvg-wir-iz0      .
       scl-pvg-ins-100.
      *              *-------------------------------------------------*
      *              * Determinazione indice elemento di origine       *
      *              *-------------------------------------------------*
           move      w-scl-pvg-wir-iz0    to   w-scl-pvg-wir-ia0      .
           subtract  1                    from w-scl-pvg-wir-ia0      .
       scl-pvg-ins-200.
      *              *-------------------------------------------------*
      *              * Spostamento elemento di origine su elemento di  *
      *              * destinazione                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-ins-205.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    5
                     go to scl-pvg-ins-210.
           move      w-scl-pvg-inp-sco
                    (w-scl-pvg-wir-ia0,
                     w-scl-pvg-wir-ix0)   to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wir-iz0,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-ins-205.
       scl-pvg-ins-210.
           move      w-scl-pvg-inp-scu
                    (w-scl-pvg-wir-ia0)   to   w-scl-pvg-inp-scu
                                              (w-scl-pvg-wir-iz0)     .
       scl-pvg-ins-215.
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-ins-220.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    3
                     go to scl-pvg-ins-300.
           move      w-scl-pvg-inp-pvg
                    (w-scl-pvg-wir-ia0,
                     w-scl-pvg-wir-ix0)   to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wir-iz0,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-ins-220.
       scl-pvg-ins-300.
      *              *-------------------------------------------------*
      *              * Decremento indice su elemento di destinazione   *
      *              *-------------------------------------------------*
           subtract  1                    from w-scl-pvg-wir-iz0      .
      *              *-------------------------------------------------*
      *              * Se l'indice sull'elementi di origine non e' an- *
      *              * cora pari all'indice sull'elemento attuale : si *
      *              * ricicla                                         *
      *              *-------------------------------------------------*
           if        w-scl-pvg-wir-ia0    not  = w-scl-pvg-wir-inx
                     go to scl-pvg-ins-100.
       scl-pvg-ins-400.
      *              *-------------------------------------------------*
      *              * Azzeramento elemento attuale                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-ins-405.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    5
                     go to scl-pvg-ins-410.
           move      zero                 to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wir-inx,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-ins-405.
       scl-pvg-ins-410.
           move      zero                 to   w-scl-pvg-inp-scu
                                              (w-scl-pvg-wir-inx)     .
       scl-pvg-ins-415.
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-ins-420.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    3
                     go to scl-pvg-ins-500.
           move      zero                 to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wir-inx,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-ins-420.
       scl-pvg-ins-500.
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione valori relativi alla scaletta   *
      *              *-------------------------------------------------*
           perform   scl-pvg-vis-000      thru scl-pvg-vis-999        .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       scl-pvg-ins-999.
           exit.

      *    *-----------------------------------------------------------*
      *    * Rimozione di un elemento nella scaletta                   *
      *    *-----------------------------------------------------------*
       scl-pvg-rem-000.
      *              *-------------------------------------------------*
      *              * Flag di risposta di rimozione a : eseguita      *
      *              *-------------------------------------------------*
           move      "R"                  to   w-scl-pvg-wir-fre      .
      *              *-------------------------------------------------*
      *              * Se la rimozione non e' subordinata al fatto     *
      *              * che l'elemento sia vuoto : ad esecuzione        *
      *              *-------------------------------------------------*
           if        w-scl-pvg-wir-fsv    not  = "V"
                     go to scl-pvg-rem-100.
      *              *-------------------------------------------------*
      *              * Test se l'elemento e' vuoto                     *
      *              *-------------------------------------------------*
           move      w-scl-pvg-wir-inx    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
      *              *-------------------------------------------------*
      *              * Se l'elemento e' vuoto : ad esecuzione          *
      *              *-------------------------------------------------*
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-rem-100.
      *              *-------------------------------------------------*
      *              * Flag di risposta di rimozione a : non eseguita  *
      *              *-------------------------------------------------*
           move      spaces               to   w-scl-pvg-wir-fre      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     scl-pvg-rem-999.
       scl-pvg-rem-100.
      *              *-------------------------------------------------*
      *              * Inizializzazione indice su elemento di destina- *
      *              * zione                                           *
      *              *-------------------------------------------------*
           move      w-scl-pvg-wir-inx    to   w-scl-pvg-wir-iz0      .
       scl-pvg-rem-200.
      *              *-------------------------------------------------*
      *              * Determinazione indice elemento di origine       *
      *              *-------------------------------------------------*
           move      w-scl-pvg-wir-iz0    to   w-scl-pvg-wir-ia0      .
           add       1                    to   w-scl-pvg-wir-ia0      .
      *              *-------------------------------------------------*
      *              * Se l'indice elemento di origine e' superiore    *
      *              * al massimo : ad azzeramento ultimo elemento     *
      *              *-------------------------------------------------*
           if        w-scl-pvg-wir-ia0    >    w-scl-pvg-inp-max
                     go to scl-pvg-rem-500.
       scl-pvg-rem-300.
      *              *-------------------------------------------------*
      *              * Spostamento elemento di origine su elemento di  *
      *              * destinazione                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-rem-305.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    5
                     go to scl-pvg-rem-310.
           move      w-scl-pvg-inp-sco
                    (w-scl-pvg-wir-ia0,
                     w-scl-pvg-wir-ix0)   to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wir-iz0,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-rem-305.
       scl-pvg-rem-310.
           move      w-scl-pvg-inp-scu
                    (w-scl-pvg-wir-ia0)   to   w-scl-pvg-inp-scu
                                              (w-scl-pvg-wir-iz0)     .
       scl-pvg-rem-315.
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-rem-320.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    3
                     go to scl-pvg-rem-400.
           move      w-scl-pvg-inp-pvg
                    (w-scl-pvg-wir-ia0,
                     w-scl-pvg-wir-ix0)   to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wir-iz0,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-rem-320.
       scl-pvg-rem-400.
      *              *-------------------------------------------------*
      *              * Incremento indice su elemento di destinazione   *
      *              *-------------------------------------------------*
           add       1                    to   w-scl-pvg-wir-iz0      .
      *              *-------------------------------------------------*
      *              * Riciclo su elemento                             *
      *              *-------------------------------------------------*
           go to     scl-pvg-rem-200.
       scl-pvg-rem-500.
      *              *-------------------------------------------------*
      *              * Azzeramento ultimo elemento                     *
      *              *-------------------------------------------------*
           move      w-scl-pvg-inp-max    to   w-scl-pvg-wir-inx      .
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-rem-505.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    5
                     go to scl-pvg-rem-510.
           move      zero                 to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wir-inx,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-rem-505.
       scl-pvg-rem-510.
           move      zero                 to   w-scl-pvg-inp-scu
                                              (w-scl-pvg-wir-inx)     .
       scl-pvg-rem-515.
           move      zero                 to   w-scl-pvg-wir-ix0      .
       scl-pvg-rem-520.
           add       1                    to   w-scl-pvg-wir-ix0      .
           if        w-scl-pvg-wir-ix0    >    3
                     go to scl-pvg-rem-600.
           move      zero                 to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wir-inx,
                                               w-scl-pvg-wir-ix0)     .
           go to     scl-pvg-rem-520.
       scl-pvg-rem-600.
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione valori relativi alla scaletta   *
      *              *-------------------------------------------------*
           perform   scl-pvg-vis-000      thru scl-pvg-vis-999        .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       scl-pvg-rem-999.
           exit.

      *    *-----------------------------------------------------------*
      *    * Controllo formato interno singolo elemento, con calcolo   *
      *    * dei valori derivati                                       *
      *    *-----------------------------------------------------------*
       scl-pvg-tdr-000.
      *              *-------------------------------------------------*
      *              * Se l'elemento e' vuoto                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           move      w-scl-pvg-wdr-inx    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    not  = "V"
                     go scl-pvg-tdr-200.
      *                  *---------------------------------------------*
      *                  * Azzeramento componenti non visibili         *
      *                  *---------------------------------------------*
           move      zero                 to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wdr-inx,
                                               4                )     .
           move      zero                 to   w-scl-pvg-inp-sco
                                              (w-scl-pvg-wdr-inx,
                                               5                )     .
           move      zero                 to   w-scl-pvg-inp-scu
                                              (w-scl-pvg-wdr-inx)     .
           move      zero                 to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wdr-inx,
                                               2                )     .
           move      zero                 to   w-scl-pvg-inp-pvg
                                              (w-scl-pvg-wdr-inx,
                                               3                )     .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione singolo elemento          *
      *                  *---------------------------------------------*
           move      w-scl-pvg-wdr-inx    to   w-scl-pvg-wvi-iel      .
           perform   scl-pvg-vix-000      thru scl-pvg-vix-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita a Ok                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-scl-pvg-wdr-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-tdr-999.
       scl-pvg-tdr-200.
      *              *-------------------------------------------------*
      *              * Controlli su sconti, che non ci siano buchi     *
      *              *-------------------------------------------------*
       scl-pvg-tdr-210.
           if        w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     1                )
                                          not  = zero
                     go to scl-pvg-tdr-220.
           if        w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     2                )
                                          =    zero and
                     w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     3                )
                                          =    zero
                     go to scl-pvg-tdr-220
           else      go to scl-pvg-tdr-900.
       scl-pvg-tdr-220.
           if        w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     2                )
                                          not  = zero
                     go to scl-pvg-tdr-230.
           if        w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     3                )
                                          =    zero
                     go to scl-pvg-tdr-230
           else      go to scl-pvg-tdr-900.
       scl-pvg-tdr-230.
           go to     scl-pvg-tdr-400.
       scl-pvg-tdr-400.
      *              *-------------------------------------------------*
      *              * Uscita per controllo superato                   *
      *              *-------------------------------------------------*
       scl-pvg-tdr-405.
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione singolo elemento          *
      *                  *---------------------------------------------*
           move      w-scl-pvg-wdr-inx    to   w-scl-pvg-wvi-iel      .
           perform   scl-pvg-vix-000      thru scl-pvg-vix-999        .
       scl-pvg-tdr-410.
      *                  *---------------------------------------------*
      *                  * Flag di uscita a Ok                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-scl-pvg-wdr-flg      .
       scl-pvg-tdr-415.
      *                  *---------------------------------------------*
      *                  * Determinazione della percentuale di sconto  *
      *                  * unica a fronte delle tre percentuali di     *
      *                  * sconto                                      *
      *                  *---------------------------------------------*
           move      100,0                to   w-scl-pvg-wdr-711      .
      *
           multiply  w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     1                )   by   w-scl-pvg-wdr-711
                                        giving w-scl-pvg-wdr-712      .
           divide    100                  into w-scl-pvg-wdr-712      .
           subtract  w-scl-pvg-wdr-712    from w-scl-pvg-wdr-711      .
      *
           multiply  w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     2                )   by   w-scl-pvg-wdr-711
                                        giving w-scl-pvg-wdr-712      .
           divide    100                  into w-scl-pvg-wdr-712      .
           subtract  w-scl-pvg-wdr-712    from w-scl-pvg-wdr-711      .
      *
           multiply  w-scl-pvg-inp-sco
                    (w-scl-pvg-wdr-inx,
                     3                )   by   w-scl-pvg-wdr-711
                                        giving w-scl-pvg-wdr-712      .
           divide    100                  into w-scl-pvg-wdr-712      .
           subtract  w-scl-pvg-wdr-712    from w-scl-pvg-wdr-711      .
      *
           subtract  w-scl-pvg-wdr-711    from 100,0
                                        giving w-scl-pvg-inp-scu
                                              (w-scl-pvg-wdr-inx)     .
       scl-pvg-tdr-420.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-tdr-999.
       scl-pvg-tdr-900.
      *              *-------------------------------------------------*
      *              * Uscita per controllo non superato               *
      *              *-------------------------------------------------*
       scl-pvg-tdr-905.
      *                  *---------------------------------------------*
      *                  * Flag di uscita a Ko                         *
      *                  *---------------------------------------------*
           move      "#"                  to   w-scl-pvg-wdr-flg      .
       scl-pvg-tdr-910.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-tdr-999.
       scl-pvg-tdr-999.
           exit.

      *    *-----------------------------------------------------------*
      *    * Controllo formato interno della scaletta                  *
      *    *-----------------------------------------------------------*
       scl-pvg-ctl-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione flag di primo passaggio su e-  *
      *              * lemento non vuoto                               *
      *              *-------------------------------------------------*
           move      spaces               to   w-scl-pvg-wct-f1p      .
      *              *-------------------------------------------------*
      *              * Indice su elementi : a zero                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-scl-pvg-wct-iel      .
       scl-pvg-ctl-100.
      *              *-------------------------------------------------*
      *              * Incremento indice su elementi                   *
      *              *-------------------------------------------------*
           add       1                    to   w-scl-pvg-wct-iel      .
      *              *-------------------------------------------------*
      *              * Se oltre il max : uscita per Ok                 *
      *              *-------------------------------------------------*
           if        w-scl-pvg-wct-iel    >    w-scl-pvg-inp-max
                     go to scl-pvg-ctl-800.
       scl-pvg-ctl-200.
      *              *-------------------------------------------------*
      *              * Se elemento vuoto lo si ignora                  *
      *              *-------------------------------------------------*
           move      w-scl-pvg-wct-iel    to   w-scl-pvg-wtv-inx      .
           perform   scl-pvg-tsv-000      thru scl-pvg-tsv-999        .
           if        w-scl-pvg-wtv-fev    =    "V"
                     go to scl-pvg-ctl-100.
       scl-pvg-ctl-300.
      *              *-------------------------------------------------*
      *              * Se primo elemento non vuoto incontrato          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-scl-pvg-wct-f1p    not  = spaces
                     go to scl-pvg-ctl-400.
      *                  *---------------------------------------------*
      *                  * Assestamento flag di primo passaggio su e-  *
      *                  * lemento non vuoto                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-scl-pvg-wct-f1p      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione ultimo sconto unico          *
      *                  *---------------------------------------------*
           move      w-scl-pvg-inp-scu
                    (w-scl-pvg-wct-iel)   to   w-scl-pvg-wct-usc      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione ultima % provvigione         *
      *                  *---------------------------------------------*
           move      w-scl-pvg-inp-pvg
                    (w-scl-pvg-wct-iel,
                     1                )   to   w-scl-pvg-wct-upv      .
      *                  *---------------------------------------------*
      *                  * Riciclo su elemento successivo              *
      *                  *---------------------------------------------*
           go to     scl-pvg-ctl-100.
       scl-pvg-ctl-400.
      *              *-------------------------------------------------*
      *              * Se incontrato un elemento non vuoto successivo  *
      *              * al primo                                        *
      *              *-------------------------------------------------*
       scl-pvg-ctl-450.
      *                  *---------------------------------------------*
      *                  * Controllo sullo sconto unico, che sia cre-  *
      *                  * scente                                      *
      *                  *---------------------------------------------*
       scl-pvg-ctl-455.
      *                      *-----------------------------------------*
      *                      * Test e deviazione                       *
      *                      *-----------------------------------------*
           if        w-scl-pvg-inp-scu
                    (w-scl-pvg-wct-iel)   >    w-scl-pvg-wct-usc
                     go to scl-pvg-ctl-460
           else      go to scl-pvg-ctl-470.
       scl-pvg-ctl-460.
      *                      *-----------------------------------------*
      *                      * Se test superato                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Memorizzazione ultimo sconto unico  *
      *                          *-------------------------------------*
           move      w-scl-pvg-inp-scu
                    (w-scl-pvg-wct-iel)   to   w-scl-pvg-wct-usc      .
      *                          *-------------------------------------*
      *                          * Continuazione controlli             *
      *                          *-------------------------------------*
           go to     scl-pvg-ctl-500.
       scl-pvg-ctl-470.
      *                      *-----------------------------------------*
      *                      * Se test non superato                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Le % di sconto in tabella non sono in ordine cresc
      -              "ente !         "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Ad uscita per errore                *
      *                          *-------------------------------------*
           go to     scl-pvg-ctl-900.
       scl-pvg-ctl-500.
      *                  *---------------------------------------------*
      *                  * Controllo sulla provvigione, che sia decre- *
      *                  * scente                                      *
      *                  *---------------------------------------------*
       scl-pvg-ctl-505.
      *                      *-----------------------------------------*
      *                      * Test e deviazione                       *
      *                      *-----------------------------------------*
           if        w-scl-pvg-inp-pvg
                    (w-scl-pvg-wct-iel,
                     1                )   <    w-scl-pvg-wct-upv
                     go to scl-pvg-ctl-510
           else      go to scl-pvg-ctl-520.
       scl-pvg-ctl-510.
      *                      *-----------------------------------------*
      *                      * Se test superato                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Memorizzazione ultima provvigione   *
      *                          *-------------------------------------*
           move      w-scl-pvg-inp-pvg
                    (w-scl-pvg-wct-iel,
                     1                )   to   w-scl-pvg-wct-upv      .
      *                          *-------------------------------------*
      *                          * Continuazione controlli             *
      *                          *-------------------------------------*
           go to     scl-pvg-ctl-550.
       scl-pvg-ctl-520.
      *                      *-----------------------------------------*
      *                      * Se test non superato                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Le % di provvigione in tabella non sono in ordine 
      -              "decrescente !  "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Ad uscita per errore                *
      *                          *-------------------------------------*
           go to     scl-pvg-ctl-900.
       scl-pvg-ctl-550.
      *                  *---------------------------------------------*
      *                  * Riciclo su elemento successivo              *
      *                  *---------------------------------------------*
           go to     scl-pvg-ctl-100.
       scl-pvg-ctl-800.
      *              *-------------------------------------------------*
      *              * Uscita per Ok                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita per Ok                       *
      *                  *---------------------------------------------*
           move      spaces               to   w-scl-pvg-wct-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-ctl-999.
       scl-pvg-ctl-900.
      *              *-------------------------------------------------*
      *              * Uscita per Ko                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita per Ko                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-scl-pvg-wct-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scl-pvg-ctl-999.
       scl-pvg-ctl-999.
           exit.

      *    *-----------------------------------------------------------*
      *    * Fine subroutines per il trattamento della scaletta prov-  *
      *    * vigioni                                                   *
      *    *===========================================================*

      *    *===========================================================*
      *    * Routine di attribuzione codice automatico progressivo     *
      *    *-----------------------------------------------------------*
       att-cod-aut-000.
      *              *-------------------------------------------------*
      *              * Lettura codice automatico per [zpv] parte 01    *
      *              *-------------------------------------------------*
           move      "Eg"                 to   s-ope                  .
           move      "zpv1"               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to att-cod-aut-400.
       att-cod-aut-200.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "Ep"                 to   s-ope                  .
           move      "zpv1"               to   s-nam                  .
           move      zero                 to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-cod-aut-000.
       att-cod-aut-400.
      *              *-------------------------------------------------*
      *              * Record esistente                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione del valore pre incremento    *
      *                  *---------------------------------------------*
           move      s-num                to   w-enc-cod-val-pre      .
      *                  *---------------------------------------------*
      *                  * Incremento del valore                       *
      *                  *---------------------------------------------*
           move      w-enc-cod-val-pre    to   w-enc-cod-val-pos      .
           add       1                    to   w-enc-cod-val-pos      .
       att-cod-aut-500.
      *                  *---------------------------------------------*
      *                  * Se l'incremento porta a zero si forza il    *
      *                  * valore a 1                                  *
      *                  *---------------------------------------------*
           if        w-enc-cod-val-pos    =    zero
                     move  1              to   w-enc-cod-val-pos      .
      *                  *---------------------------------------------*
      *                  * Controllo se esiste gia' un record con il   *
      *                  * codice pari al valore incrementato          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCPV    "         to   f-key                  .
           move      01                   to   rf-zpv-tip-cpv         .
           move      w-enc-cod-val-pos    to   rf-zpv-cod-cpv         .
           move      "pgm/age/fls/ioc/obj/iofzpv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpv                 .
           if        f-sts                =    e-not-err
                     go to att-cod-aut-600
           else      go to att-cod-aut-700.
       att-cod-aut-600.
      *                  *---------------------------------------------*
      *                  * Se esiste gia' un record con il codice pari *
      *                  * al valore incrementato                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ulteriore incremento del valore         *
      *                      *-----------------------------------------*
           add       1                    to   w-enc-cod-val-pos      .
      *                      *-----------------------------------------*
      *                      * Riciclo a controllo di esistenza        *
      *                      *-----------------------------------------*
           go to     att-cod-aut-500.
       att-cod-aut-700.
      *                  *---------------------------------------------*
      *                  * Se non esiste gia' un record con il codice  *
      *                  * pari al valore incrementato                 *
      *                  *---------------------------------------------*
           move      "Eu"                 to   s-ope                  .
           move      "zpv1"               to   s-nam                  .
           move      w-enc-cod-val-pos    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione di *
      *                      * attribuzione                            *
      *                      *-----------------------------------------*
           if        s-sts                not  = spaces
                     go to att-cod-aut-000.
       att-cod-aut-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino codice automatico progressivo       *
      *    *-----------------------------------------------------------*
       rip-cod-aut-000.
      *              *-------------------------------------------------*
      *              * Lettura codice automatico per [zpv]             *
      *              *-------------------------------------------------*
           move      "Eg"                 to   s-ope                  .
           move      "zpv1"               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to rip-cod-aut-400.
       rip-cod-aut-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rip-cod-aut-999.
       rip-cod-aut-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra il valore attuale ed il valo- *
      *                  * re post incremento                          *
      *                  *---------------------------------------------*
           if        s-num                =    w-enc-cod-val-pos
                     go to rip-cod-aut-600.
       rip-cod-aut-500.
      *                  *---------------------------------------------*
      *                  * Se il valore attuale non e' uguale al valo- *
      *                  * re post incremento                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "Er"                 to   s-ope                  .
           move      "zpv1"               to   s-nam                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-cod-aut-999.
       rip-cod-aut-600.
      *                  *---------------------------------------------*
      *                  * Se il valore attuale e' uguale al valore    *
      *                  * post incremento                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento del codice automatico con *
      *                      * il valore pre incremento                *
      *                      *-----------------------------------------*
           move      "Eu"                 to   s-ope                  .
           move      "zpv1"               to   s-nam                  .
           move      w-enc-cod-val-pre    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione di *
      *                      * attribuzione                            *
      *                      *-----------------------------------------*
           if        s-sts                not  = spaces
                     go to rip-cod-aut-000.
       rip-cod-aut-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per allineamenti a destra o a sinistra oppure *
      *    * al centro di campi alfanumerici di varia lunghezza, fi-   *
      *    * no ad un massimo di 240 caratteri, oppure per il conca-   *
      *    * tenamento, con o senza separazione, di max 10 substrin-   *
      *    * ghe in una unica substringa                               *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wallstr0.cps"                   .

      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice categoria prov- *
      *    * vigioni legate all'agente                                 *
      *    *-----------------------------------------------------------*
           copy      "pgm/age/prg/cpy/acmnzpv1.acs"                   .


