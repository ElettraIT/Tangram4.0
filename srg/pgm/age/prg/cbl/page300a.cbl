           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      50                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      003                  to   p-pos                  .
           move      w-stp-srr-rdr-pmt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Contatore righe                                 *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "B"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      056                  to   p-pos                  .
           move      w-stp-srr-rdr-ctr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Lordo standard                                  *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           add       w-fir-vlb-dec-prz    to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BG"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      061                  to   p-pos                  .
           move      w-stp-srr-rdr-lrs    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Netto standard                                  *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           add       w-fir-vlb-dec-prz    to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BG"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      075                  to   p-pos                  .
           move      w-stp-srr-rdr-nts    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Netto effettivo                                 *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           add       w-fir-vlb-dec-prz    to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BG"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      089                  to   p-pos                  .
           move      w-stp-srr-rdr-nte    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Imponibile provvigionale                        *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           add       w-fir-vlb-dec-prz    to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BG"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      103                  to   p-pos                  .
           move      w-stp-srr-rdr-ipr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Delta                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione della % delta scostamento    *
      *                  * tra lordo standard e netto standard         *
      *                  *---------------------------------------------*
           if        w-stp-srr-rdr-lrs    =    zero or
                     w-stp-srr-rdr-ipr    =    zero
                     move  zero           to   w-det-pme-sop-per
                     go to stp-ctg-pvg-rdr-900.
      *                  *---------------------------------------------*
      *                  * L'operazione e' cosi' composta :            *
      *                  *                                             *
      *                  *         (Lordo standard - Imp. provv.)*100  *
      *                  * Delta = ----------------------------------  *
      *                  *               (Lordo standard)              *
      *                  *---------------------------------------------*
           move      w-stp-srr-rdr-lrs    to   w-det-pme-sop-ibl      .
           subtract  w-stp-srr-rdr-ipr    from w-det-pme-sop-ibl      .
           multiply  100                  by   w-det-pme-sop-ibl      .
           divide    w-stp-srr-rdr-lrs    into w-det-pme-sop-ibl
                                        giving w-det-pme-sop-per      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      01                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<DB"                to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      117                  to   p-pos                  .
           move      w-det-pme-sop-per    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-rdr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-ctg-pvg-rdr-999.
       stp-ctg-pvg-rdr-999.
           exit.

