      *                  * Tipo documento                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Concatenamento del codice tipo documen- *
      *                      * to con la sua descrizione               *
      *                      *-----------------------------------------*
           move      31                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-fit-tmo-cod-tmo    to   w-all-str-cat (01)     .
           move      "-"                  to   w-all-str-cat (02)     .
           move      w-fit-tmo-des-stp    to   w-all-str-cat (03)     .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                      *-----------------------------------------*
      *                      * Allineamento al centro                  *
      *                      *-----------------------------------------*
           perform   all-str-cen-000      thru all-str-cen-999        .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      31                   to   p-car                  .
           move      10                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      094                  to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-060.
      *                  *---------------------------------------------*
      *                  * Codice cliente                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing del codice numerico e conca-    *
      *                      * tenamento con codice dipendenza         *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-gpc-cod-cli       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Concatenamento con codice dipendenza    *
      *                      *-----------------------------------------*
           move      12                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      p-edt                to   w-all-str-cat (01)     .
           move      rf-gpc-dpz-cli       to   w-all-str-cat (02)     .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      12                   to   p-car                  .
           move      12                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      011                  to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-100.
      *                  *---------------------------------------------*
      *                  * Numero conteggio                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero conteggio, editato tra parentesi *
      *                      * tonde o quadre, a seconda se a fronte   *
      *                      * incasso oppure no                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing                             *
      *                          *-------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
      *
           if        rf-gpc-tip-mat       =    02
                     move  "["            to   w-all-str-cat (01)
           else      move  "("            to   w-all-str-cat (01)     .
      *
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      9                    to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-gpc-num-ctg       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (02)     .
      *
           if        rf-gpc-tip-mat       =    02
                     move  "]"            to   w-all-str-cat (03)
           else      move  ")"            to   w-all-str-cat (03)     .
      *
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                          *-------------------------------------*
      *                          * Allineamento a sinistra             *
      *                          *-------------------------------------*
           perform   all-str-asx-000      thru all-str-asx-999        .
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      12                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      058                  to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-120.
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Allineamento a sinistra                 *
      *                      *-----------------------------------------*
           move      10                   to   w-all-str-lun          .
           move      rf-gpc-num-doc       to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      10                   to   p-car                  .
           move      12                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      100                  to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-140.
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      12                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      122                  to   p-pos                  .
           move      rf-gpc-dat-doc       to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-ctg-pvg-sd1-999.
       stp-ctg-pvg-sd1-999.
           exit.

