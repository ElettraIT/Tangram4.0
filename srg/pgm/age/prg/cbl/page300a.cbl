      *                      *-----------------------------------------*
           move      rf-fir-ocl-dat       to   w-rrf-ocl-dat          .
           move      rf-fir-ocl-num       to   w-rrf-ocl-num          .
      *                      *-----------------------------------------*
      *                      * Preparazione stringa da stampare        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing data ordine cliente         *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      rf-fir-ocl-dat       to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
