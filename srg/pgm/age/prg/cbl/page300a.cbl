      *                          *-------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      "*** Vs. ord."       to   w-all-str-cat (01)     .
           move      rf-fir-ocl-num       to   w-all-str-cat (02)     .
           move      "del"                to   w-all-str-cat (03)     .
           move      p-edt                to   w-all-str-cat (04)     .
           move      "***"                to   w-all-str-cat (05)     .
           perform   all-str-csb-000      thru all-str-csb-999        .
       stp-ctg-pvg-eco-300.
