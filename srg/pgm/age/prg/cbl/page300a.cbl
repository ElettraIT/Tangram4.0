      *    *-----------------------------------------------------------*
      *    * Stampa del conteggio provvigionale                        *
      *    *                                                           *
      *    * Sottoclasse : 011                                         *
      *    *                                                           *
      *    * Subroutine per l'accumulo totali speciali righe           *
      *    *-----------------------------------------------------------*
       stp-ctg-pvg-atr-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        rr-age-300-ppe
                    (04 : 01)             =    spaces
                     go to stp-ctg-pvg-atr-900.
       stp-ctg-pvg-atr-100.
      *              *-------------------------------------------------*
      *              * Totale 01 : righe elaborate                     *
      *              *-------------------------------------------------*
           move      01                   to   w-stp-srr-ctr-inx      .
           move      "Righe elaborate                                   
      -              ""                   to   w-stp-srr-tot-pmt
                                              (w-stp-srr-ctr-inx)     .
           perform   stp-ctg-pvg-atx-000  thru stp-ctg-pvg-atx-999    .
       stp-ctg-pvg-atr-200.
      *              *-------------------------------------------------*
      *              * Totale 02 : righe che contribuiscono            *
      *              *-------------------------------------------------*
           if        w-fir-ctg-snx-inf    not  = "S"
                     go to stp-ctg-pvg-atr-300.
           move      02                   to   w-stp-srr-ctr-inx      .
           move      "Righe che contribuiscono alla provvigione         
      -              ""                   to   w-stp-srr-tot-pmt
                                              (w-stp-srr-ctr-inx)     .
           perform   stp-ctg-pvg-atx-000  thru stp-ctg-pvg-atx-999    .
       stp-ctg-pvg-atr-300.
      *              *-------------------------------------------------*
      *              * Totale 03 : righe che non contribuiscono        *
      *              *-------------------------------------------------*
           if        w-fir-ctg-snx-inf    not  = "N"
                     go to stp-ctg-pvg-atr-400.
           move      03                   to   w-stp-srr-ctr-inx      .
           move      "Righe che non contribuiscono alla provvigione     
      -              ""                   to   w-stp-srr-tot-pmt
                                              (w-stp-srr-ctr-inx)     .
           perform   stp-ctg-pvg-atx-000  thru stp-ctg-pvg-atx-999    .
       stp-ctg-pvg-atr-400.
      *              *-------------------------------------------------*
      *              * Totale 04 : righe con provvigione a forfait     *
      *              *-------------------------------------------------*
           if        w-fir-vlb-pvf-rig    =    zero
                     go to stp-ctg-pvg-atr-500.
           move      05                   to   w-stp-srr-ctr-inx      .
           move      "Righe con provvigione a forfait                   
      -              ""                   to   w-stp-srr-tot-pmt
                                              (w-stp-srr-ctr-inx)     .
           perform   stp-ctg-pvg-atx-000  thru stp-ctg-pvg-atx-999    .
       stp-ctg-pvg-atr-500.
      *              *-------------------------------------------------*
