                     if    p-res          >    3
                           go to stp-ctg-pvg-ste-150
                     else  go to stp-ctg-pvg-ste-130
           else      if    p-res          >    7
                           go to stp-ctg-pvg-ste-140
                     else  go to stp-ctg-pvg-ste-130.
       stp-ctg-pvg-ste-130.
