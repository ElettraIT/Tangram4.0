      *                      * [fir]                                   *
      *                      *-----------------------------------------*
           move      rlt-rec-dat-fir      to   rf-fir                 .
      *                      *-----------------------------------------*
      *                      * w-fir                                   *
      *                      *-----------------------------------------*
           move      rlt-rec-dat-wfi      to   w-fir                  .
      *                      *-----------------------------------------*
      *                      * Totale lordo standard                   *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-imp-sco-iml      .
           multiply  w-fir-ctg-qta-ven    by   w-fir-vlb-prz-lrs
                                        giving w-det-imp-sco-iml      .
           if        w-fir-vlb-dec-prz    =    1
                     divide    10         into w-det-imp-sco-iml
           else if   w-fir-vlb-dec-prz    =    2
                     divide    100        into w-det-imp-sco-iml
           else if   w-fir-vlb-dec-prz    =    3
                     divide    1000       into w-det-imp-sco-iml      .
           add       w-det-imp-sco-iml    to   w-fit-vlb-tot-lrs      .
      *                      *-----------------------------------------*
      *                      * Totale netto standard                   *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-imp-sco-iml      .
           multiply  w-fir-ctg-qta-ven    by   w-fir-vlb-prz-nts
                                        giving w-det-imp-sco-iml      .
           if        w-fir-vlb-dec-prz    =    1
                     divide    10         into w-det-imp-sco-iml
           else if   w-fir-vlb-dec-prz    =    2
                     divide    100        into w-det-imp-sco-iml
           else if   w-fir-vlb-dec-prz    =    3
                     divide    1000       into w-det-imp-sco-iml      .
           add       w-det-imp-sco-iml    to   w-fit-vlb-tot-nts      .
      *                      *-----------------------------------------*
      *                      * Totale netto effettivo                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-imp-sco-iml      .
           multiply  w-fir-ctg-qta-ven    by   w-fir-vlb-prz-net
                                        giving w-det-imp-sco-iml      .
           if        w-fir-vlb-dec-prz    =    1
                     divide    10         into w-det-imp-sco-iml
           else if   w-fir-vlb-dec-prz    =    2
                     divide    100        into w-det-imp-sco-iml
           else if   w-fir-vlb-dec-prz    =    3
                     divide    1000       into w-det-imp-sco-iml      .
           add       w-det-imp-sco-iml    to   w-fit-vlb-tot-nte      .
       gen-ctg-pvg-dne-800.
      *                  *---------------------------------------------*
