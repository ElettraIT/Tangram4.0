           move      rf-fir-num-prt       to   rf-fix-num-prt         .
           move      rf-fir-num-prg       to   rf-fix-num-prg         .
           move      01                   to   rf-fix-tip-rec         .
           move      "pgm/fat/fls/ioc/obj/ioffix"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fix                 .
           if        f-sts                =    e-not-err
                     move  rf-fix-des-400 to   w-stp-rig-des-der
           else      move  spaces         to   w-stp-rig-des-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-600.
