      *    *                                                           *
      *    * Subroutine per la stampa dati di testata                  *
      *    *                                                           *
      *    * Parte 1                                                   *
      *    *-----------------------------------------------------------*
       stp-ctg-pvg-sd1-000.
      *              *-------------------------------------------------*
      *              * Stampa valori di testata                        *
      *              *-------------------------------------------------*
       stp-ctg-pvg-sd1-020.
      *                  *---------------------------------------------*
      *                  * Agente                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nominativo                              *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      10                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      011                  to   p-pos                  .
           move      w-stp-age-cod-des    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "B"                  to   p-edm                  .
           move      10                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      035                  to   p-pos                  .
           move      w-stp-age-cod-num    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-030.
      *                  *---------------------------------------------*
      *                  * Segnale di vendita diretta/indiretta        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da stampare                     *
      *                      *-----------------------------------------*
           if        rr-age-300-ppe
                    (05 : 01)             not  = spaces
                     go to stp-ctg-pvg-sd1-040.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      17                   to   p-car                  .
           move      10                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      047                  to   p-pos                  .
           if        rf-gpc-tip-vpa       =    01
                     move  "Vendita diretta  "
                                          to   p-alf
           else if   rf-gpc-tip-vpa       =    02
                     move  "Vendita indiretta"
                                          to   p-alf
           else      move  spaces         to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-040.
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da stampare                     *
      *                      *-----------------------------------------*
           if        w-fit-sdb-sgl-vpf    =    spaces or
                     w-fit-sdb-sgl-vpf    =    c-sgl
                     go to stp-ctg-pvg-sd1-050.
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      14                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "(Valuta :"          to   w-all-str-cat (01)     .
           move      w-fit-sdb-sgl-vpf    to   w-all-str-cat (02)     .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           move      w-all-str-alf        to   w-all-str-cat (01)     .
           move      ")"                  to   w-all-str-cat (02)     .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      10                   to   p-lin                  .
           add       w-dsp-dsp-vrt        to   p-lin                  .
           move      71                   to   p-pos                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ctg-pvg-sd1-050.
