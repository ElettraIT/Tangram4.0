      *    *===========================================================*
      *    * Stampa importo in riga                                    *
      *    *-----------------------------------------------------------*
       stp-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero caratteri e maschera di   *
      *              * editing                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero decimali  *
      *                  * valuta                                      *
      *                  *---------------------------------------------*
           go to     stp-imp-rig-100
                     stp-imp-rig-200
                     stp-imp-rig-300
                     depending            on   w-stp-rig-imp-dcv      .
      *                  *---------------------------------------------*
      *                  * Numero decimali : 0                         *
      *                  *---------------------------------------------*
           if        w-stp-rig-imp-imp    >    999999999 or
                     w-stp-rig-imp-imp    <   -999999999
                     move  11             to   w-stp-rig-imp-car
                     move  spaces         to   w-stp-rig-imp-edm
           else      move  09             to   w-stp-rig-imp-car
                     move  "G"            to   w-stp-rig-imp-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-100.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 1                         *
      *                  *---------------------------------------------*
           if        w-stp-rig-imp-imp    >    99999999 or
                     w-stp-rig-imp-imp    <   -99999999
                     move  09             to   w-stp-rig-imp-car
                     move  spaces         to   w-stp-rig-imp-edm
           else      move  07             to   w-stp-rig-imp-car
                     move  "G"            to   w-stp-rig-imp-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-200.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 2                         *
      *                  *---------------------------------------------*
           if        w-stp-rig-imp-imp    >    99999999 or
                     w-stp-rig-imp-imp    <   -99999999
                     move  08             to   w-stp-rig-imp-car
                     move  spaces         to   w-stp-rig-imp-edm
           else      move  06             to   w-stp-rig-imp-car
                     move  "G"            to   w-stp-rig-imp-edm
                     add   1              to   w-stp-rig-imp-pos      .
           go to     stp-imp-rig-500.
       stp-imp-rig-300.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 3                         *
      *                  *---------------------------------------------*
           if        w-stp-rig-imp-imp    >    999999999 or
                     w-stp-rig-imp-imp    <   -999999999
                     move  07             to   w-stp-rig-imp-car
                     move  spaces         to   w-stp-rig-imp-edm
           else      move  06             to   w-stp-rig-imp-car
                     move  "G"            to   w-stp-rig-imp-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-500.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      w-stp-rig-imp-car    to   p-car                  .
           move      w-stp-rig-imp-dcv    to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      w-stp-rig-imp-edm    to   p-edm                  .
           move      w-stp-rig-imp-lin    to   p-lin                  .
           move      w-stp-rig-imp-pos    to   p-pos                  .
           move      w-stp-rig-imp-imp    to   p-num                  .
           if        w-stp-rig-imp-dcv    =    1
                     divide 10            into p-num
           else if   w-stp-rig-imp-dcv    =    2
                     divide 100           into p-num
           else if   w-stp-rig-imp-dcv    =    3
                     divide 1000          into p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-imp-rig-999.
           exit.

