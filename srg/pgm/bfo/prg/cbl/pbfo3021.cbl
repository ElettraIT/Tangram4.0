                     go to prn-liv-det-rag-200
           else if   srt-tip-arc          =    "F"
                     go to prn-liv-det-rag-300
           else if   srt-tip-arc          =    "D"
                     go to prn-liv-det-rag-400
           else      go to prn-liv-det-rag-500.
       prn-liv-det-rag-200.
