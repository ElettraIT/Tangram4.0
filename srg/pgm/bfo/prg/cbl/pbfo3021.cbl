      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su archivio [bft] per data registrazione  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dtr-min           to   rf-bft-dat-reg         .
           move      zero                 to   rf-bft-cod-dpz         .
           move      spaces               to   rf-bft-cod-tmb         .
           move      zero                 to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read-next su archivio [bft]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-bft-dat-reg       >    rr-dtr-max
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [bft]                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-bft-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
           if        rr-cod-tmb           not  = spaces and
                     rf-bft-cod-tmb       not  = rr-cod-tmb
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione minima           *
      *                  *---------------------------------------------*
           if        rf-bft-dat-reg       <    rr-dtr-min
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione massima          *
      *                  *---------------------------------------------*
           if        rf-bft-dat-reg       >    rr-dtr-max
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su numero protocollo minimo            *
      *                  *---------------------------------------------*
           if        rf-bft-num-prt       <    rr-prt-min
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su numero protocollo massimo           *
      *                  *---------------------------------------------*
           if        rf-bft-num-prt       >    rr-prt-max
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        rr-tip-arc           =    01
                     go to stp-srt-inp-450
           else if   rr-tip-arc           =    02  and
                     rf-bft-tip-arc       =    "F"
                     go to stp-srt-inp-450
           else if   rr-tip-arc           =    03  and
                     rf-bft-tip-arc       =    "C"
                     go to stp-srt-inp-450
           else if   rr-tip-arc           =    04  and
                     rf-bft-tip-arc       =    "D"
                     go to stp-srt-inp-450
           else if   rr-tip-arc           =    05  and
                     rf-bft-tip-arc       =    " "
                     go to stp-srt-inp-450
           else      go to stp-srt-inp-200.
       stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Test su codice archivio                     *
      *                  *---------------------------------------------*
           if        rr-cod-arc           not  = zero   and
                     rf-bft-cod-arc       not  = rr-cod-arc
                     go to stp-srt-inp-200.
       stp-srt-inp-460.
      *              *-------------------------------------------------*
      *              * Lettura record archivio                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        rf-bft-tip-arc       =    "F"
                     go to stp-srt-inp-462
           else if   rf-bft-tip-arc       =    "C"
                     go to stp-srt-inp-464
           else if   rf-bft-tip-arc       =    "D"
                     go to stp-srt-inp-466
           else      go to stp-srt-inp-468.
