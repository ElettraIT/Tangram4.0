      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *-----------------------------------------------------------*
       prn-liv-det-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-liv-det-100.
      *              *-------------------------------------------------*
      *              * Ciclo di stampa per quantita'                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-prn-qta-eti          .
       prn-liv-det-200.
           add       1                    to   w-prn-qta-eti          .
           if        w-prn-qta-eti        >    rf-bfr-qta-acq
                     go to prn-liv-det-900.
       prn-liv-det-300.
      *              *-------------------------------------------------*
      *              * Test se pagina da stampare                      *
      *              *-------------------------------------------------*
           if        w-prn-ctr-eti        not  = 40
                     go to prn-liv-det-400.
      *                  *---------------------------------------------*
      *                  * Avanzamento pagina                          *
      *                  *---------------------------------------------*
           move      "PA"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Se errore grave di i-o su stampa si esce    *
      *                  * con status di errore                        *
      *                  *---------------------------------------------*
           if        p-rsc                not  = spaces
                     move   "#"           to   w-cnt-prn-flg-int
                     go to  prn-liv-det-999.
      *                  *---------------------------------------------*
      *                  * Reinizializzazione a zero contatore eti-    *
      *                  * chette                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-prn-ctr-eti          .
       prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Incremento contatore etichette                  *
      *              *-------------------------------------------------*
           add       1                    to   w-prn-ctr-eti          .
      *              *-------------------------------------------------*
      *              * Determinazione linea su cui posizionarsi        *
      *              *-------------------------------------------------*
           subtract  1                    from w-prn-ctr-eti
                                        giving p-lin                  .
           divide    4                    into p-lin                  .
           multiply  7                    by   p-lin                  .
           add       1                    to   p-lin                  .
      *              *-------------------------------------------------*
      *              * Determinazione posizione su cui posizionarsi    *
      *              *-------------------------------------------------*
           subtract  1                    from w-prn-ctr-eti
                                        giving w-prn-liv-det-pos      .
           move      w-prn-liv-det-pos    to   p-pos                  .
           divide    4                    into p-pos                  .
           multiply  4                    by   p-pos                  .
           subtract  p-pos                from w-prn-liv-det-pos      .
           multiply  21                   by   w-prn-liv-det-pos      .
           add       1                    to   w-prn-liv-det-pos      .
           move      w-prn-liv-det-pos    to   p-pos                  .
      *              *-------------------------------------------------*
      *              * Vertical Position                               *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Inizializzazione linea e posizione al punto     *
      *              * zero dell'etichetta                             *
      *              *-------------------------------------------------*
           subtract  1                    from p-lin
                                        giving w-prn-liv-det-lin      .
           subtract  1                    from p-pos
                                        giving w-prn-liv-det-pos      .
       prn-liv-det-500.
      *              *-------------------------------------------------*
      *              * Stampa etichetta                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico prodotto                *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      w-prn-liv-det-lin    to   p-lin                  .
           add       5                    to   p-lin                  .
           move      w-prn-liv-det-pos    to   p-pos                  .
           add       5                    to   p-pos                  .
           move      rf-bfr-alf-mag       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-800.
      *              *-------------------------------------------------*
      *              * Riciclo a etichetta successiva                  *
      *              *-------------------------------------------------*
           go to     prn-liv-det-200.
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

