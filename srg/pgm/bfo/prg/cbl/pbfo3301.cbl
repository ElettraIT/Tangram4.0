      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [bfr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHARC    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bfr-cod-dpz         .
           move      spaces               to   rf-bfr-flg-rch         .
           move      "F"                  to   rf-bfr-tip-arc         .
           move      rr-cod-fnt           to   rf-bfr-cod-arc         .
           move      zero                 to   rf-bfr-num-prt         .
           move      zero                 to   rf-bfr-num-prg         .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bfr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-bfr-cod-dpz       not  = rr-dpz-inu or
                     rf-bfr-flg-rch       not  = spaces     or
                     rf-bfr-tip-arc       not  = "F"
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * Test su codice archivio                     *
      *                  *---------------------------------------------*
           if        rr-cod-fnt           not  = zero   and
                     rf-bfr-cod-arc       not  = rr-cod-fnt
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        rr-snx-rdc           not  = "N"
                     go to stp-srt-inp-105.
           if        rf-bfr-tip-rig
                    (01 : 01)             =    "C"
                     go to stp-srt-inp-100.
       stp-srt-inp-105.
      *                  *---------------------------------------------*
      *                  * Test su dipendenza archivio                 *
      *                  *---------------------------------------------*
           if        rr-cod-fnt           =    zero
                     go to stp-srt-inp-110.
           if        rr-dpz-fnt           =    "*   "
                     go to stp-srt-inp-110.
           if        rf-bfr-dpz-arc       not  = rr-dpz-fnt
                     go to stp-srt-inp-100.
       stp-srt-inp-110.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione minima           *
      *                  *---------------------------------------------*
           if        rf-bfr-dat-reg       <    rr-dtr-min
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione massima          *
      *                  *---------------------------------------------*
           if        rf-bfr-dat-reg       >    rr-dtr-max
                     go to stp-srt-inp-100.
       stp-srt-inp-120.
