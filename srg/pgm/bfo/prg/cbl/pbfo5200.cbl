      *    *===========================================================*
      *    * Accettazione campo : Si/no documento verificato           *
      *    *-----------------------------------------------------------*
       acc-snx-dav-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-snx-dav        to   w-sav-snx-dav          .
       acc-snx-dav-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-dav-lun    to   v-car                  .
           move      w-exp-snx-dav-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-exp-snx-dav-tbl    to   v-txt                  .
      *
           if        w-rig-snx-dav        =    "#"
                     move  1              to   v-num
           else if   w-rig-snx-dav        =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-snx-dav-999.
       acc-snx-dav-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "#"            to   w-rig-snx-dav
           else if   v-num                =    2
                     move  spaces         to   w-rig-snx-dav
           else      move  spaces         to   w-rig-snx-dav          .
       acc-snx-dav-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se modificato                          *
      *                  *---------------------------------------------*
           if        w-rig-snx-dav        =    w-sav-snx-dav
                     go to acc-snx-dav-600.
      *                  *---------------------------------------------*
      *                  * Test se precedentemente 'da verificare'     *
      *                  *---------------------------------------------*
           if        w-sav-snx-dav        not  = spaces
                     go to acc-snx-dav-600.
      *                  *---------------------------------------------*
      *                  * Test se attualmente 'da verificare'         *
      *                  *---------------------------------------------*
           if        w-rig-snx-dav        =    spaces
                     go to acc-snx-dav-600.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "ATTENZIONE : opzione non piu' modificabile !      
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-snx-dav-100.
       acc-snx-dav-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-dav-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
