      *    *===========================================================*
      *    * Accettazione campo selezione : Data registrazione bolle   *
      *    *-----------------------------------------------------------*
       acc-dat-bfo-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        rr-dat-bfo           not  = zero
                     go to acc-dat-bfo-100.
      *                      *-----------------------------------------*
      *                      * Richiesta data attuale                  *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Forzatura al mese precedente            *
      *                      *-----------------------------------------*
           if        s-mes                >    1
                     subtract 1           from s-mes
           else      move     12          to   s-mes
                     subtract 1           from s-saa                  .
      *                      *-----------------------------------------*
      *                      * Se giorno superiore a 15 : a controllo  *
      *                      * data                                    *
      *                      *-----------------------------------------*
           if        s-gio                >    15
                     go to acc-dat-bfo-020.
      *                      *-----------------------------------------*
      *                      * Forzatura al mese ancora precedente     *
      *                      *-----------------------------------------*
           if        s-mes                >    1
                     subtract 1           from s-mes
           else      move     12          to   s-mes
                     subtract 1           from s-saa                  .
       acc-dat-bfo-020.
      *                      *-----------------------------------------*
      *                      * Forzatura giorno di fine mese           *
      *                      *-----------------------------------------*
           move      31                   to   s-gio                  .
       acc-dat-bfo-040.
      *                      *-----------------------------------------*
      *                      * Controllo data                          *
      *                      *-----------------------------------------*
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  =    spaces
                     subtract 1           from s-gio
                     go to acc-dat-bfo-040.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valore di default       *
      *                      *-----------------------------------------*
           move      s-dat                to   rr-dat-bfo             .
       acc-dat-bfo-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-dat-bfo           to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-dat-bfo-999.
       acc-dat-bfo-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   rr-dat-bfo             .
       acc-dat-bfo-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso                   *
      *                  *---------------------------------------------*
           if        rr-dat-bfo           =    zero
                     go to acc-dat-bfo-100.
       acc-dat-bfo-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-bfo-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-bfo-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-bfo-100.
       acc-dat-bfo-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Si/No consolidamento documenti non emessi  *
      *    * da fornitori                                              *
      *    *-----------------------------------------------------------*
       acc-snx-dnf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        rr-snx-dnf           =    spaces
                     move  "S"            to   rr-snx-dnf             .
       acc-snx-dnf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-dnf-lun    to   v-car                  .
           move      w-exp-snx-dnf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-snx-dnf-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           if        rr-snx-dnf           =    "S"
                     move  01             to   v-num
           else if   rr-snx-dnf           =    "N"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-snx-dnf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-snx-dnf-999.
       acc-snx-dnf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "S"            to   rr-snx-dnf
           else if   v-num                =    02
                     move  "N"            to   rr-snx-dnf
           else      move  spaces         to   rr-snx-dnf             .
       acc-snx-dnf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso a meno che non  *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        rr-snx-dnf           not  = spaces
                     go to acc-snx-dnf-500.
           if        v-key                =    "UP  "
                     go to acc-snx-dnf-600
           else      go to acc-snx-dnf-100.
       acc-snx-dnf-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        rr-snx-dnf           not  = "S" and
                     rr-snx-dnf           not  = "N"
                     go to acc-snx-dnf-100.
       acc-snx-dnf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-dnf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-snx-dnf-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-snx-dnf-100.
       acc-snx-dnf-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Regolarizzazioni                                *
      *              *-------------------------------------------------*
           if        rr-snx-dnf           =    spaces
                     move  "S"            to   rr-snx-dnf             .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per contatori           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattini a linea 12                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Prompt per documenti da consolidare         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Documenti da consolidare   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Prompt per documenti consolidati            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Documenti consolidati      :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       reg-ric-sel-999.
           exit.

