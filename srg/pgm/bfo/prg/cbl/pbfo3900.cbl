      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore records da consolida- *
      *              * re                                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-prn-ctr-rdc          .
      *              *-------------------------------------------------*
      *              * Start su file [bft]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZBCH    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bft-cod-dpz         .
           move      spaces               to   rf-bft-flg-bch         .
           move      zero                 to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bft]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-110.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Su codice dipendenza                        *
      *                  *---------------------------------------------*
           if        rf-bft-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Su flag di chiusura                         *
      *                  *---------------------------------------------*
           if        rf-bft-flg-bch       not  = spaces
                     go to stp-srt-inp-900.
       stp-srt-inp-115.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data emissione                      *
      *                  *---------------------------------------------*
           if        rf-bft-dat-reg       >    rr-dat-bfo
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su segnale di documento che interessa  *
      *                  * la fatturazione                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se interessa la fatturazione : a start  *
      *                      * su righe                                *
      *                      *-----------------------------------------*
           if        rf-bft-int-ftr       =    02
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Se non interessa la fatturazione        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su richiesta se consolidamento *
      *                          * documenti non emessi da fornitori   *
      *                          *                                     *
      *                          * N.B.: se 'si' si superano tutte le  *
      *                          *       selezioni successive, se 'no' *
      *                          *       si ricicla                    *
      *                          *-------------------------------------*
           if        rr-snx-dnf           not  = "S"
                     go to stp-srt-inp-100.
      *                          *-------------------------------------*
      *                          * Se consolidamento documenti non     *
      *                          * emessi da fornitori : a composi-    *
      *                          * zione record di sort                *
      *                          *-------------------------------------*
           go to     stp-srt-inp-600.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Normalizzazione comodi per scansione righe      *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-srt-inp-rde      .
           move      zero                 to   w-stp-srt-inp-rsp      .
           move      zero                 to   w-stp-srt-inp-rso      .
           move      zero                 to   w-stp-srt-inp-roc      .
       stp-srt-inp-210.
      *              *-------------------------------------------------*
      *              * Start su file [bfr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bft-num-prt       to   rf-bfr-num-prt         .
