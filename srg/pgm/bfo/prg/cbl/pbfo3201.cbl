      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
           move      rf-bfr-dat-reg       to   srt-dat-reg            .
           move      rf-bfr-num-prt       to   srt-num-prt            .
           move      rf-bfr-num-prg       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
           move      rf-bfr-cod-tmb       to   srt-cod-tmb            .
           move      rf-bfr-tip-arc       to   srt-tip-arc            .
           move      rf-bfr-cod-arc       to   srt-cod-arc            .
           move      rf-bfr-dpz-arc       to   srt-dpz-arc            .
           move      w-stp-srt-inp-rag    to   srt-rag-arc            .
           move      rf-bfr-dat-doc       to   srt-dat-doc            .
           move      rf-bfr-num-doc       to   srt-num-doc            .
           move      rf-bft-prt-mag       to   srt-prt-mag            .
           move      rf-bfr-alf-mag       to   srt-alf-mag            .
           if        w-stp-srt-inp-wtf    =    "N"
                     move  spaces         to   srt-alf-mag            .
           move      w-det-des-rig-des    to   srt-des-rig            .
           if        rf-bfr-snx-tum       =    "S"
                     move  rf-bfr-umf-tum to   srt-uni-mis
           else      move  rf-bfr-umi-acq to   srt-uni-mis            .
           move      rf-bfr-sgl-vpf       to   srt-sgl-vpf            .
           move      rf-bfr-dec-vpf       to   srt-dec-vpf            .
           move      rf-bfr-tdc-vpf       to   srt-tdc-vpf            .
           move      rf-bfr-cdc-vpf       to   srt-cdc-vpf            .
           if        rf-bfr-snx-tum       =    "P"
                     move  rf-bfr-qta-acq to   srt-qta-acq
           else      move  rf-bfr-qta-fda to   srt-qta-acq            .
           move      rf-bfr-dec-prz       to   srt-dec-prz            .
           move      rf-bfr-prz-acq       to   srt-prz-acq            .
           move      rf-bfr-per-scr (1)   to   srt-per-scr (1)        .
           move      rf-bfr-per-scr (2)   to   srt-per-scr (2)        .
           move      rf-bfr-per-scr (3)   to   srt-per-scr (3)        .
           move      rf-bfr-per-scr (4)   to   srt-per-scr (4)        .
           move      rf-bfr-per-scr (5)   to   srt-per-scr (5)        .
           move      rf-bfr-imp-rig       to   srt-imp-rig            .
      *
           if        rf-bfr-snx-tum       =    "P"
                     move  rf-bfr-umf-tum to   srt-umi-prz
           else      move  spaces         to   srt-umi-prz            .
      *
           move      rf-bfr-lot-sgl       to   srt-lot-sgl            .
