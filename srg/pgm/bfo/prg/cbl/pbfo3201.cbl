      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        rf-bft-tip-arc       =    "F"
                     go to stp-srt-inp-162
           else if   rf-bft-tip-arc       =    "C"
                     go to stp-srt-inp-164
           else if   rf-bft-tip-arc       =    "D"
                     go to stp-srt-inp-166
           else      go to stp-srt-inp-168.
       stp-srt-inp-162.
      *                  *---------------------------------------------*
      *                  * Tipo archivio : Fornitori                   *
      *                  *---------------------------------------------*
           if        rf-bft-dpz-arc       =    spaces
                     move  "C"            to   w-let-arc-dcf-tle
           else      move  "D"            to   w-let-arc-dcf-tle      .
           move      rf-bft-cod-arc       to   w-let-arc-dcf-cod      .
           move      rf-bft-dpz-arc       to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           move      w-let-arc-dcf-rag    to   w-stp-srt-inp-rag      .
           go to     stp-srt-inp-170.
       stp-srt-inp-164.
      *                  *---------------------------------------------*
      *                  * Tipo archivio : Clienti                     *
      *                  *---------------------------------------------*
           if        rf-bft-dpz-arc       =    spaces
                     move  "C"            to   w-let-arc-dcc-tle
           else      move  "D"            to   w-let-arc-dcc-tle      .
           move      rf-bft-cod-arc       to   w-let-arc-dcc-cod      .
           move      rf-bft-dpz-arc       to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-rag    to   w-stp-srt-inp-rag      .
           go to     stp-srt-inp-170.
       stp-srt-inp-166.
      *                  *---------------------------------------------*
