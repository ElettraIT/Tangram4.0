      *    *===========================================================*
      *    * Accettazione campo selezione : Tipo movimento             *
      *    *-----------------------------------------------------------*
       acc-tip-mov-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        rr-tip-mov           not  = spaces
                     go to acc-tip-mov-100.
           if        w-tmb-ctr-ele        not  = 1
                     go to acc-tip-mov-100.
           if        w-tmb-cod-tmb        =    spaces
                     go to acc-tip-mov-100.
           move      w-tmb-cod-tmb        to   rr-tip-mov             .
           move      w-tmb-des-tmb        to   rr-tip-mov-des         .
           perform   vis-cod-mov-000      thru vis-cod-mov-999        .
           perform   vis-des-mov-000      thru vis-des-mov-999        .
           go to     acc-tip-mov-999.
       acc-tip-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-ybf-ope      .
           move      rr-tip-mov           to   w-cod-des-ybf-cod      .
           move      05                   to   w-cod-des-ybf-lin      .
           move      30                   to   w-cod-des-ybf-pos      .
           move      05                   to   w-cod-des-ybf-dln      .
           move      37                   to   w-cod-des-ybf-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-ybf-cll-000  thru cod-des-ybf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-ybf-foi-000  thru cod-des-ybf-foi-999    .
       acc-tip-mov-110.
           perform   cod-des-ybf-cll-000  thru cod-des-ybf-cll-999    .
           if        w-cod-des-ybf-ope    =    "F+"
                     go to acc-tip-mov-115.
           if        w-cod-des-ybf-ope    =    "AC"
                     go to acc-tip-mov-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-mov-115.
           perform   cod-des-ybf-foi-000  thru cod-des-ybf-foi-999    .
           go to     acc-tip-mov-110.
       acc-tip-mov-120.
           move      w-cod-des-ybf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-tip-mov-999.
       acc-tip-mov-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   rr-tip-mov             .
       acc-tip-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [ybf]                       *
      *                  *---------------------------------------------*
           move      rr-tip-mov           to   w-let-arc-ybf-cod      .
           perform   let-arc-ybf-000      thru let-arc-ybf-999        .
           move      w-let-arc-ybf-des    to   rr-tip-mov-des         .
           move      w-let-arc-ybf-vld    to   rr-tip-mov-vld         .
           move      w-let-arc-ybf-dpz    to   rr-tip-mov-dpz         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-mov-000      thru vis-des-mov-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-ybf-flg    not  = spaces
                     go to acc-tip-mov-100.
      *                  *---------------------------------------------*
      *                  * Se a spaces : reimpostazione                *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces
                     go to acc-tip-mov-100.
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rr-tip-mov-vld       not  = 02
                     go to acc-tip-mov-600.
           if        rr-cod-dpz           =    rr-tip-mov-dpz
                     go to acc-tip-mov-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Tipo movimento incompatibile con il codice dipende
      -              "nza   "             to   w-box-msg-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-tip-mov-100.
       acc-tip-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-mov-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-tip-mov-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-tip-mov-100.
       acc-tip-mov-999.
           exit.

