                     go to acc-prt-bfo-mag-900.
       acc-prt-bfo-mag-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [bfs]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to acc-prt-bfo-mag-900.
       acc-prt-bfo-mag-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su protocollo                          *
      *                  *---------------------------------------------*
           if        rf-bfs-num-prt       not  = w-det-prt-mag-prw
                     go to acc-prt-bfo-mag-900.
       acc-prt-bfo-mag-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
           if        rf-bfs-prt-mag       not  numeric
                     go to acc-prt-bfo-mag-200.
           if        rf-bfs-prt-mag       =    zero
                     go to acc-prt-bfo-mag-200.
       acc-prt-bfo-mag-500.
      *              *-------------------------------------------------*
