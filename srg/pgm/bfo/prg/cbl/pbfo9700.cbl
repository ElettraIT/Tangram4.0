      *                  *---------------------------------------------*
           if        rf-bft-cod-arc       not  = 0003239
                     go to acc-prt-bfo-mag-900.
       acc-prt-bfo-mag-100.
      *              *-------------------------------------------------*
      *              * Start su [bfs]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-det-prt-mag-prw    to   rf-bfs-num-prt         .
           move      zero                 to   rf-bfs-num-prg         .
           move      zero                 to   rf-bfs-num-prr         .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
