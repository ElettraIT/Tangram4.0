      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Cancellazione spunte                            *
      *              *-------------------------------------------------*
           perform   del-rec-bfs-000      thru del-rec-bfs-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione record [bfu]                      *
      *              *-------------------------------------------------*
           perform   del-rec-bfu-000      thru del-rec-bfu-999        .
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record [bfu]                                *
      *    *-----------------------------------------------------------*
       del-rec-bfu-000.
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        rr-snx-cgm           not  = 02
                     go to del-rec-bfu-900.
      *              *-------------------------------------------------*
      *              * Test su tipo record                             *
      *              *-------------------------------------------------*
           if        srt-tip-rec          not  = "bfu"
                     go to del-rec-bfu-900.
       del-rec-bfu-100.
      *              *-------------------------------------------------*
      *              * Composizione chiave primaria                    *
      *              *-------------------------------------------------*
           move      srt-num-prt          to   rf-bfu-num-prt         .
           move      srt-num-pro          to   rf-bfu-num-pro         .
           move      srt-cod-ubi          to   rf-bfu-cod-ubi         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfu                 .
      *              *-------------------------------------------------*
      *              * Messaggio di esecuzione                         *
      *              * ___                                             *
      *              *-------------------------------------------------*
       del-rec-bfu-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     del-rec-bfu-999.
       del-rec-bfu-999.
           exit.

      *    *===========================================================*
      *    * Ciclo di cancellazione spunte [bfs]                       *
      *    *-----------------------------------------------------------*
       del-rec-bfs-000.
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        rr-snx-csp           not  = 02
                     go to del-rec-bfs-900.
      *              *-------------------------------------------------*
      *              * Test su tipo record                             *
      *              *-------------------------------------------------*
           if        srt-tip-rec          not  = "bfs"
                     go to del-rec-bfs-900.
       del-rec-bfs-100.
      *              *-------------------------------------------------*
      *              * Eventuale cancellazione protocolli di magazzino *
      *              * legati alla spunta (ABB)                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if        rr-snx-cgm           not  = 02
                     go to del-rec-bfs-500.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [bfs]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [bfs]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      srt-num-key          to   rf-bfs-num-prt         .
           move      srt-prg-key          to   rf-bfs-num-prg         .
           move      srt-prr-key          to   rf-bfs-num-prr         .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato: ad uscita            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to del-rec-bfs-900.
       del-rec-bfs-200.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione di magazzino     *
      *                  *---------------------------------------------*
           if        rf-bfs-drg-mag       not  numeric or
                     rf-bfs-drg-mag       =    zero
                     go to del-rec-bfs-500.
      *                  *---------------------------------------------*
      *                  * Test su protocollo di magazzino             *
      *                  *---------------------------------------------*
           if        rf-bfs-prt-mag       not  numeric or
                     rf-bfs-prt-mag       =    zero
                     go to del-rec-bfs-500.
       del-rec-bfs-300.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di magazzino        *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      rf-bfs-drg-mag       to   l-mag-300-dat-reg      .
           move      rf-bfs-prt-mag       to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Messaggio di esecuzione                     *
      *                  *---------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Movimento di magazzino cancellato con successo (AB
      -              "B) !"               to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       del-rec-bfs-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [bfs]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *              *-------------------------------------------------*
      *              * Composizione chiave [bfs]                       *
      *              *-------------------------------------------------*
           move      srt-num-key          to   rf-bfs-num-prt         .
           move      srt-prg-key          to   rf-bfs-num-prg         .
           move      srt-prr-key          to   rf-bfs-num-prr         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *              *-------------------------------------------------*
      *              * Messaggio di esecuzione                         *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Spunte cancellate con successo !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       del-rec-bfs-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     del-rec-bfs-999.
       del-rec-bfs-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimento di magazzino                      *
      *    *-----------------------------------------------------------*
       agg-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        rr-snx-cgm           not  = 02
                     go to agg-mov-mag-900.
       agg-mov-mag-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
       agg-mov-mag-200.
      *              *-------------------------------------------------*
      *              * Lettura per protocollo                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rr-prt-bfo           to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Test se protocollo di magazzino esiste      *
      *                  *---------------------------------------------*
           if        rf-bft-pr2-mag       =    zero
                     go to agg-mov-mag-900.
       agg-mov-mag-300.
      *              *-------------------------------------------------*
      *              * Cancellazione movimento di magazzino            *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      rf-bft-dat-reg       to   l-mag-300-dat-reg      .
           move      rf-bft-pr2-mag       to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Messaggio di esecuzione                         *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      "Movimento di magazzino cancellato con successo !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       agg-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-mov-mag-999.
       agg-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Find su archivio [bft]                                    *
      *    *-----------------------------------------------------------*
       fnd-arc-bft-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-arc-bft-sel      .
       fnd-arc-bft-010.
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pbfo3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-arc-bft-sel
                     go to  fnd-arc-bft-999.
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per codice di- *
      *              * pendenza                                        *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-dpz"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      01                   to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "pgm/bfo/prg/obj/pbfo3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
       fnd-arc-bft-999.
           exit.

