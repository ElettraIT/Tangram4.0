           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo movimento     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tip-mpb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Numero protocollo             *
      *    *-----------------------------------------------------------*
       acc-num-prt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione work per accettazione          *
      *                  *---------------------------------------------*
           move      w-tes-num-prt-saa    to   w-acc-num-prt-saa      .
           move      w-tes-num-prt-prg    to   w-acc-num-prt-prg      .
       acc-num-prt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      04                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-acc-num-prt-num    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
       acc-num-prt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-acc-num-prt-num      .
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Decomposizione work di accettazione         *
      *                  *---------------------------------------------*
           if        w-acc-num-prt-num    =    zero
                     go to acc-num-prt-300.
           move      w-acc-num-prt-saa    to   w-tes-num-prt-saa      .
           move      w-tes-cod-dpz        to   w-tes-num-prt-dpz      .
           move      w-acc-num-prt-prg    to   w-tes-num-prt-prg      .
       acc-num-prt-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-prt-400.
      *                  *---------------------------------------------*
      *                  * Find su archivio [bft]                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-fnd-arc-bft-tmb      .
           move      zero                 to   w-fnd-arc-bft-dat      .
           move      zero                 to   w-fnd-arc-bft-prt      .
           perform   fnd-arc-bft-000      thru fnd-arc-bft-999        .
           if        w-fnd-arc-bft-sel    not  = spaces
                     go to acc-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-num-prt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il protocollo e' diverso da zero : simu- *
      *                  * lazione della ricerca                       *
      *                  *---------------------------------------------*
           if        w-acc-num-prt-num    =    zero
                     go to acc-num-prt-600.
      *                  *---------------------------------------------*
      *                  * Lettura testata tramite protocollo          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-tes-num-prt        to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                      *-----------------------------------------*
      *                      * Se registrazione non esistente : mes-   *
      *                      * saggio di errore                        *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to acc-num-prt-420.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Documento non esistente in archivio !             
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-num-prt-100.
       acc-num-prt-420.
      *                  *---------------------------------------------*
      *                  * Find precablato su archivio [bft]           *
      *                  *---------------------------------------------*
           move      rf-bft-cod-tmb       to   w-fnd-arc-bft-tmb      .
           move      rf-bft-dat-reg       to   w-fnd-arc-bft-dat      .
           move      rf-bft-num-prt       to   w-fnd-arc-bft-prt      .
           perform   fnd-arc-bft-000      thru fnd-arc-bft-999        .
           if        w-fnd-arc-bft-sel    not  = spaces
                     go to acc-num-prt-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-num-prt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-prt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-num-prt-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-num-prt-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-num-prt-999.
       acc-num-prt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Numero protocollo          *
      *    *-----------------------------------------------------------*
       vis-num-prt-000.
      *              *-------------------------------------------------*
      *              * Composizione work per visualizzazione           *
      *              *-------------------------------------------------*
           move      w-tes-num-prt-saa    to   w-vis-num-prt-saa      .
           move      w-tes-num-prt-prg    to   w-vis-num-prt-prg      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      04                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-vis-num-prt-num    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-prt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Data registrazione            *
      *    *-----------------------------------------------------------*
       acc-dat-reg-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del valore di de-    *
      *                  * fault                                       *
      *                  *---------------------------------------------*
           if        w-tes-dat-reg        =    zero
                     move  w-def-dat-reg  to   w-tes-dat-reg          .
       acc-dat-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      04                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      w-tes-dat-reg        to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-dat-reg-999.
       acc-dat-reg-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dat-reg          .
       acc-dat-reg-250.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-dat-reg-300.
      *                  *---------------------------------------------*
      *                  * Find su archivio [bft]                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-fnd-arc-bft-tmb      .
           move      zero                 to   w-fnd-arc-bft-dat      .
           move      zero                 to   w-fnd-arc-bft-prt      .
           perform   fnd-arc-bft-000      thru fnd-arc-bft-999        .
           if        w-fnd-arc-bft-sel    not  = spaces
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A controllo valore impostato                *
      *                  *---------------------------------------------*
           go to     acc-dat-reg-400.
       acc-dat-reg-300.
      *              *-------------------------------------------------*
      *              * Se Previous screen                              *
      *              *-------------------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-dat-reg-400.
      *                  *---------------------------------------------*
      *                  * Preparazione dei parametri per la selezione *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-buf-doc-mvm-drc      .
           move      s-ute                to   w-buf-doc-mvm-ute      .
      *
           if        w-tes-dat-reg        not  = zero
                     move  w-tes-dat-reg  to   w-buf-doc-mvm-drc      .
      *                  *---------------------------------------------*
      *                  * Routine di ricerca                          *
      *                  *---------------------------------------------*
           perform   buf-doc-mvm-000      thru buf-doc-mvm-999        .
      *                      *-----------------------------------------*
      *                      * Test sul flag di uscita                 *
      *                      *-----------------------------------------*
           if        w-buf-doc-mvm-fds    not  = spaces
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Valori selezionati                          *
      *                  *---------------------------------------------*
           move      w-buf-doc-mvm-tds    to   w-tes-cod-tmb          .
           move      w-buf-doc-mvm-nds    to   w-tes-num-prt          .
           move      w-buf-doc-mvm-dds    to   w-tes-dat-reg          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione data registrazione e numero *
      *                  * protocollo selezionati                      *
      *                  *---------------------------------------------*
           perform   vis-cod-tmb-000      thru vis-cod-tmb-999        .
           perform   vis-num-prt-000      thru vis-num-prt-999        .
           perform   vis-dat-reg-000      thru vis-dat-reg-999        .
      *                  *---------------------------------------------*
      *                  * Test su valori estratti                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb        =    spaces   or
                     w-tes-dat-reg        =    zero     or
                     w-tes-num-prt        =    zero
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Find precablato su archivio [bft]           *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmb        to   w-fnd-arc-bft-tmb      .
           move      w-tes-dat-reg        to   w-fnd-arc-bft-dat      .
           move      w-tes-num-prt        to   w-fnd-arc-bft-prt      .
           perform   fnd-arc-bft-000      thru fnd-arc-bft-999        .
           if        w-fnd-arc-bft-sel    not  = spaces
                     go to acc-dat-reg-100.
      *                  *---------------------------------------------*
      *                  * Forzatura function-key Do                   *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
       acc-dat-reg-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione, a meno   *
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-tes-dat-reg        not  = zero
                     go to acc-dat-reg-600.
           if        v-key                =    "UP  "
                     go to acc-dat-reg-600
           else      go to acc-dat-reg-100.
       acc-dat-reg-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-reg-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-dat-reg-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-dat-reg-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-dat-reg-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-dat-reg-999.
       acc-dat-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Data documento             *
      *    *-----------------------------------------------------------*
       vis-dat-reg-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      04                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-tes-dat-reg        to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-reg-999.
           exit.

      *    *===========================================================*
