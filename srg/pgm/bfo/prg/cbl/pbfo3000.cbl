      *              * Se codice dipendenza a spazi : uscita           *
      *              *-------------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     go to det-vlt-dcd-999.
      *              *-------------------------------------------------*
      *              * Codice e descrizione ABI dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * Codice e descrizione CAB dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-dpz (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * C/c bancario della dipendenza                   *
      *              *-------------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-cca-dpz (1)      .
      *              *-------------------------------------------------*
      *              * C/c postale della dipendenza                    *
      *              *-------------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-dpz (1)      .
       det-vlt-dcd-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da inoltro pagamento*
      *    *-----------------------------------------------------------*
       det-vlt-ipg-000.
      *              *-------------------------------------------------*
      *              * Se dipendenza non esistente                     *
      *              *-------------------------------------------------*
           if        w-tes-dpz-arc (1)    not  = spaces
                     go to det-vlt-ipg-500.
       det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-fnt (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-fnt-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-fnt (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-fnt-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-fnt (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-fnt (1)    to   w-tes-ccp-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-500.
      *              *-------------------------------------------------*
      *              * Se dipendenza esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inoltro pagamento alla sede o alla sede  *
      *                  * legale : valori derivati da [dcf] principale*
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    01 or
                     w-tes-inl-pgt (1)    =    02
                     go to det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-dpz (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-dpz-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-dpz (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-dpz-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-dpz (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-dpz (1)    to   w-tes-ccp-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata dipendenti dalla forma di   *
      *    * pagamento                                                 *
      *    *-----------------------------------------------------------*
       det-vlt-yfp-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre solo in tipo funzionamento : *
      *              * 'inserimento'                                   *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-vlt-yfp-050.
       det-vlt-yfp-050.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione sconto pagamento associato  *
      *                  * alla forma di pagamento                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * alle impostazioni dei campi relativi ai pa- *
      *                  * pagamenti                                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-snx-nsb (1)      .
           move      spaces               to   w-tes-snx-bnb (1)      .
           move      spaces               to   w-tes-snx-ccp (1)      .
           move      spaces               to   w-tes-snx-spm (1)      .
           move      spaces               to   w-tes-snx-qaf (1)      .
           move      spaces               to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata associati al-*
      *                  * la forma pagamento                          *
      *                  *---------------------------------------------*
           perform   nor-cpg-ass-000      thru nor-cpg-ass-999        .
      *                  *---------------------------------------------*
      *                  * Se forma di pagamento a zero : uscita       *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to det-vlt-yfp-999.
      *                  *---------------------------------------------*
      *                  * Sconto pagamento associato alla forma di    *
      *                  * pagamento                                   *
      *                  *---------------------------------------------*
           move      rf-yfp-sco-fat       to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Ciclo per tre codici pagamento possibili    *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vlt-yfp-ctr      .
       det-vlt-yfp-100.
           add       1                    to   w-det-vlt-yfp-ctr      .
           if        w-det-vlt-yfp-ctr    >    3
                     go to det-vlt-yfp-999.
           if        rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   =    zero
                     go to det-vlt-yfp-100.
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [yfp]  *
      *                      *-----------------------------------------*
           move      rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   to   w-tes-cod-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   to   w-tes-tip-amm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-per-toi
                    (w-det-vlt-yfp-ctr)   to   w-tes-per-toi
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   to   w-tes-dim-act
                                              (1, w-det-vlt-yfp-ctr)  .
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [zpg]  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record [zpg]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zpg]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODPAG"             to   f-key                  .
           move      w-tes-cod-pag
                    (1, w-det-vlt-yfp-ctr)
                                          to   rf-zpg-cod-pag         .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
           move      rf-zpg-tip-pag       to   w-tes-tip-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-num-sca       to   w-tes-num-sca
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dec-prs       to   w-tes-dec-prs
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dap-mes       to   w-tes-dap-mes
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dap-gio       to   w-tes-dap-gio
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-ggg-int       to   w-tes-ggg-int
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-tip-scm       to   w-tes-tip-scm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-gio-scm       to   w-tes-gio-scm
                                              (1, w-det-vlt-yfp-ctr)  .
       det-vlt-yfp-200.
      *                  *---------------------------------------------*
      *                  * Valori testata di appoggio alle successive  *
      *                  * impostazioni                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice nostra banca     *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    02 or
                     rf-zpg-tip-pag       =    03 or
                     rf-zpg-tip-pag       =    04 or
                     rf-zpg-tip-pag       =    05 or
                     rf-zpg-tip-pag       =    06 or
                     rf-zpg-tip-pag       =    09 or
                     rf-zpg-tip-pag       =    10 or
                     rf-zpg-tip-pag       =    11
                     move  "S"            to   w-tes-snx-nsb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice ABI, CAB e C/C/  *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    07
                     move  "S"            to   w-tes-snx-bnb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no richiesta C/C postale             *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    08
                     move  "S"            to   w-tes-snx-ccp (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no data scadenza pagamento manuale   *
      *                      *-----------------------------------------*
           if        rf-zpg-dec-prs       =    01
                     move  "S"            to   w-tes-snx-spm (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione quota a forfait      *
      *                      *-----------------------------------------*
           if        rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    06 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    07 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    08 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    09
                     move  "S"            to   w-tes-snx-qaf (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione acconto              *
      *                      *-----------------------------------------*
           if        rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   =    02
                     move  "S"            to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-yfp-100.
       det-vlt-yfp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata relativi alle spese incasso *
      *    *-----------------------------------------------------------*
       det-vlt-yin-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella spese incasso           *
      *              *-------------------------------------------------*
           perform   nor-tbl-spi-000      thru nor-tbl-spi-999        .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-yin-c01      .
           move      zero                 to   w-det-vlt-yin-c02      .
           move      zero                 to   w-det-vlt-yin-c03      .
      *              *-------------------------------------------------*
      *              * Se codice spesa incasso non esistente : uscita  *
      *              *-------------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to det-vlt-yin-900.
      *              *-------------------------------------------------*
      *              * Ciclo per tre codici pagamento possibili        *
      *              *-------------------------------------------------*
       det-vlt-yin-100.
           add       1                    to   w-det-vlt-yin-c01      .
           if        w-det-vlt-yin-c01    >    3
                     go to det-vlt-yin-900.
           if        w-tes-cod-pag
                    (1, w-det-vlt-yin-c01)
                                          =    zero
                     go to det-vlt-yin-100.
      *              *-------------------------------------------------*
      *              * Ciclo su elementi tabella gia' presenti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-yin-c02      .
       det-vlt-yin-200.
           add       1                    to   w-det-vlt-yin-c02      .
           if        w-det-vlt-yin-c02    >    w-det-vlt-yin-c03
                     go to det-vlt-yin-300.
           if        w-tes-tpg-spi
                    (1, w-det-vlt-yin-c02)
                                          =    w-tes-tip-pag
                                              (1, w-det-vlt-yin-c01)
                     go to det-vlt-yin-100.
       det-vlt-yin-300.
      *                  *---------------------------------------------*
      *                  * Lettura record [yin]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPI    "         to   f-key                  .
           move      w-tes-add-spi (1)    to   rf-yin-cod-spi         .
           move      w-tes-tip-pag
                    (1, w-det-vlt-yin-c01)
                                          to   rf-yin-tip-pag         .
           move      "pgm/dcf/fls/ioc/obj/iofyin"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yin                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vlt-yin-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi in tabella    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vlt-yin-c03      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori                      *
      *                  *---------------------------------------------*
           move      rf-yin-tip-pag       to   w-tes-tpg-spi
                                              (1, w-det-vlt-yin-c03)  .
           move      rf-yin-tfu-spi       to   w-tes-tfu-spi
                                              (1, w-det-vlt-yin-c03)  .
           move      rf-yin-amm-spi       to   w-tes-amm-spi
                                              (1, w-det-vlt-yin-c03)  .
           move      rf-yin-per-spi       to   w-tes-per-spi
                                              (1, w-det-vlt-yin-c03)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-yin-100.
       det-vlt-yin-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero elementi in tabella spe- *
      *              * se incasso                                      *
      *              *-------------------------------------------------*
           move      w-det-vlt-yin-c03    to   w-tes-eit-spi (1)      .
       det-vlt-yin-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata relativi alle spese bollo   *
      *    *-----------------------------------------------------------*
       det-vlt-ybo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella spese bollo             *
      *              *-------------------------------------------------*
           perform   nor-tbl-spb-000      thru nor-tbl-spb-999        .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-ybo-c01      .
           move      zero                 to   w-det-vlt-ybo-c02      .
           move      zero                 to   w-det-vlt-ybo-c03      .
      *              *-------------------------------------------------*
      *              * Se codice spesa bollo non esistente : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-add-spb (1)    =    spaces
                     go to det-vlt-ybo-900.
      *              *-------------------------------------------------*
      *              * Ciclo per tre codici pagamento possibili        *
      *              *-------------------------------------------------*
       det-vlt-ybo-100.
           add       1                    to   w-det-vlt-ybo-c01      .
           if        w-det-vlt-ybo-c01    >    3
                     go to det-vlt-ybo-900.
           if        w-tes-cod-pag
                    (1, w-det-vlt-ybo-c01)
                                          =    zero
                     go to det-vlt-ybo-100.
      *              *-------------------------------------------------*
      *              * Ciclo su elementi tabella gia' presenti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-ybo-c02      .
       det-vlt-ybo-200.
           add       1                    to   w-det-vlt-ybo-c02      .
           if        w-det-vlt-ybo-c02    >    w-det-vlt-ybo-c03
                     go to det-vlt-ybo-300.
           if        w-tes-tpg-spb
                    (1, w-det-vlt-ybo-c02)
                                          =    w-tes-tip-pag
                                              (1, w-det-vlt-ybo-c01)
                     go to det-vlt-ybo-100.
       det-vlt-ybo-300.
      *                  *---------------------------------------------*
      *                  * Lettura record [ybo]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPB    "         to   f-key                  .
           move      w-tes-add-spb (1)    to   rf-ybo-cod-spb         .
           move      w-tes-tip-pag
                    (1, w-det-vlt-ybo-c01)
                                          to   rf-ybo-tip-pag         .
           move      "pgm/dcf/fls/ioc/obj/iofybo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ybo                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vlt-ybo-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi in tabella    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vlt-ybo-c03      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori                      *
      *                  *---------------------------------------------*
           move      rf-ybo-tip-pag       to   w-tes-tpg-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-tau-spb       to   w-tes-tau-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-per-spb       to   w-tes-per-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      zero                 to   w-det-vlt-ybo-c04      .
       det-vlt-ybo-320.
           add       1                    to   w-det-vlt-ybo-c04      .
           if        w-det-vlt-ybo-c04    >    10
                     go to det-vlt-ybo-340.
           move      rf-ybo-tbe-scg
                    (w-det-vlt-ybo-c04)   to   w-tes-tbe-scg
                                              (1,
                                               w-det-vlt-ybo-c03,
                                               w-det-vlt-ybo-c04)     .
           move      rf-ybo-tbe-asc
                    (w-det-vlt-ybo-c04)   to   w-tes-tbe-asc
                                              (1,
                                               w-det-vlt-ybo-c03,
                                               w-det-vlt-ybo-c04)     .
           move      rf-ybo-tbe-psc
                    (w-det-vlt-ybo-c04)   to   w-tes-tbe-psc
                                              (1,
                                               w-det-vlt-ybo-c03,
                                               w-det-vlt-ybo-c04)     .
           go to     det-vlt-ybo-320.
       det-vlt-ybo-340.
           move      rf-ybo-tet-spb       to   w-tes-tet-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-min-spb       to   w-tes-min-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-max-spb       to   w-tes-max-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-tar-spb       to   w-tes-tar-spb
                                              (1, w-det-vlt-ybo-c03)  .
           move      rf-ybo-var-spb       to   w-tes-var-spb
                                              (1, w-det-vlt-ybo-c03)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-ybo-100.
       det-vlt-ybo-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero elementi in tabella spe- *
      *              * se incasso                                      *
      *              *-------------------------------------------------*
           move      w-det-vlt-ybo-c03    to   w-tes-eit-spb (1)      .
       det-vlt-ybo-999.
           exit.

      *    *===========================================================*
      *    * Determinazione flag di estensione alla descrizione        *
      *    *-----------------------------------------------------------*
       det-des-ext-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe occupate            *
      *              *-------------------------------------------------*
           move      11                   to   w-det-des-ext-ctr      .
       det-des-ext-100.
           subtract  1                    from w-det-des-ext-ctr      .
           if        w-det-des-ext-ctr    =    zero
                     go to det-des-ext-200.
           if        w-rig-der-rig
                    (1, w-det-des-ext-ctr)
                                          =    spaces
                     go to det-des-ext-100.
       det-des-ext-200.
      *              *-------------------------------------------------*
      *              * Se numero righe non superiore a 1               *
      *              *-------------------------------------------------*
           if        w-det-des-ext-ctr    not  > 1
                     move  0              to   w-rig-des-ext (1)
                     go to det-des-ext-999.
      *              *-------------------------------------------------*
      *              * Se numero righe maggiore di 1                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se descrizione impostata diversa da descri- *
      *                  * zione prodotto originale                    *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = w-rig-des-por (1)
                     move  1              to   w-rig-des-ext (1)
                     go to det-des-ext-999.
      *                  *---------------------------------------------*
      *                  * Se descrizione impostata uguale a descri-   *
      *                  * zione prodotto                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A seconda che esista o meno un formato  *
      *                      * di acquisizione                         *
      *                      *-----------------------------------------*
           if        w-rig-snx-dep (1)    =    "S"
                     move  3              to   w-rig-des-ext (1)
           else      move  2              to   w-rig-des-ext (1)      .
       det-des-ext-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo di acquisto                         *
      *    *-----------------------------------------------------------*
       det-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Solo se riga di tipo 'new'                      *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to det-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di prezzo associato al forni-  *
      *              * tore/prodotto                                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-rig-per-scr-ffp (1)  .
       det-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione link-area                      *
      *                  *---------------------------------------------*
           move      "PA"                 to   d-prz-acq-tip-ope      .
           move      w-tes-cod-arc (1)    to   d-prz-acq-cod-fnt      .
           move      w-rig-tip-mag (1)    to   d-prz-acq-tip-mag      .
           move      w-rig-num-mag (1)    to   d-prz-acq-num-mag      .
           move      w-rig-fda-pif (1)    to   d-prz-acq-fda-pif      .
           move      w-let-arc-dcp-plb    to   d-prz-acq-prz-lsb      .
           move      w-let-arc-dcp-dlb    to   d-prz-acq-dec-vlb      .
           move      w-rig-dec-prz (1)    to   d-prz-acq-dec-prz      .
           move      w-det-prz-qta-att    to   d-prz-acq-qta-rif      .
      *
           if        w-tes-dat-doc (1)    =    zero
                     move  w-tes-dat-reg  to   d-prz-acq-dat-rfp
           else      move  w-tes-dat-doc (1)
                                          to   d-prz-acq-dat-rfp      .
      *                  *---------------------------------------------*
      *                  * Richiamo del sottoprogramma                 *
      *                  *---------------------------------------------*
           perform   det-prz-acq-cll-000  thru det-prz-acq-cll-999    .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori determinati           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo di acquisto                      *
      *                      *-----------------------------------------*
           move      d-prz-acq-prz-acq    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto                   *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-det (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-prz-acq-psr-det (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-prz-acq-psr-det (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-prz-acq-psr-det (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-prz-acq-psr-det (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Segnale di percentuali sconto determi-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-snx    to   w-rig-per-scr-ffp (1)  .
       det-prz-acq-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prz-acq-999.
       det-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuali di sconto in riga              *
      *    *-----------------------------------------------------------*
       det-per-scr-000.
      *              *-------------------------------------------------*
      *              * Solo se riga di tipo 'new'                      *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to det-per-scr-999.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento sconti in riga 001           *
      *              *-------------------------------------------------*
           perform   det-psr-001-000      thru det-psr-001-999        .
           go to     det-per-scr-999.
       det-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Determinazione percentuali di sconto in riga tipo 001     *
      *    *                                                           *
      *    * N.B.: La determinazione degli sconti in riga segue la se- *
      *    *       guente scaletta di prevalenza:                      *
      *    *       - Quelli diretti dall'incrocio Fornitore/Prodotto   *
      *    *         contenuti nel record [aaq]                        *
      *    *       - Quelli contenuti direttamente in [dcf]            *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-psr-001-000.
      *              *-------------------------------------------------*
      *              * Se gli sconti sono associati alla combinazione  *
      *              * fornitore/prodotto, questi sono gia' stati memo-*
      *              * rizzati e quindi si esce                        *
      *              *-------------------------------------------------*
           if        w-rig-per-scr-ffp (1)
                                          not  = spaces
                     go to det-psr-001-999.
       det-psr-001-200.
      *              *-------------------------------------------------*
      *              * Test se sconti diretti da record [dcf]          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se percentuali di sconto in riga associate  *
      *                  * al fornitore sono tutte a zero : oltre      *
      *                  *---------------------------------------------*
           if        w-tes-psr-aaf (1, 1) =    zero and
                     w-tes-psr-aaf (1, 2) =    zero and
                     w-tes-psr-aaf (1, 3) =    zero and
                     w-tes-psr-aaf (1, 4) =    zero and
                     w-tes-psr-aaf (1, 5) =    zero
                     go to det-psr-001-700.
      *                  *---------------------------------------------*
      *                  * Altrimenti si memorizzano                   *
      *                  *---------------------------------------------*
           move      w-tes-psr-aaf (1, 1) to   w-rig-per-scr (1, 1)   .
           move      w-tes-psr-aaf (1, 2) to   w-rig-per-scr (1, 2)   .
           move      w-tes-psr-aaf (1, 3) to   w-rig-per-scr (1, 3)   .
           move      w-tes-psr-aaf (1, 4) to   w-rig-per-scr (1, 4)   .
           move      w-tes-psr-aaf (1, 5) to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-psr-001-999.
       det-psr-001-700.
      *              *-------------------------------------------------*
      *              * A questo punto nessuno dei possibili tipi di de-*
      *              * terminazione si ' verificato, per cui non resta *
      *              * che normalizzare le percentuali di sconto in ri-*
      *              * ga ed uscire                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
           go to     det-psr-001-999.
       det-psr-001-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' secondaria per l'acquisto        *
      *    *-----------------------------------------------------------*
           copy      "pgm/ffo/prg/cpy/wdetqts0.wks"                   .

      *    *===========================================================*
      *    * Determinazione importo in riga                            *
      *    *-----------------------------------------------------------*
       det-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per la determinazione    *
      *              *-------------------------------------------------*
           move      "IR"                 to   d-imp-acq-tip-ope      .
           move      w-rig-qta-fda (1)    to   d-imp-acq-qta-acq      .
           move      w-rig-prz-acq (1)    to   d-imp-acq-prz-uni      .
           move      w-rig-dec-prz (1)    to   d-imp-acq-dec-prz      .
           move      w-rig-per-scr (1, 1) to   d-imp-acq-per-scr (1)  .
           move      w-rig-per-scr (1, 2) to   d-imp-acq-per-scr (2)  .
           move      w-rig-per-scr (1, 3) to   d-imp-acq-per-scr (3)  .
           move      w-rig-per-scr (1, 4) to   d-imp-acq-per-scr (4)  .
           move      w-rig-per-scr (1, 5) to   d-imp-acq-per-scr (5)  .
           move      w-tes-tip-mci (1)    to   d-imp-acq-tip-clc      .
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           perform   det-imp-acq-cll-000  thru det-imp-acq-cll-999    .
      *              *-------------------------------------------------*
      *              * In campo di uscita                              *
      *              *-------------------------------------------------*
           move      d-imp-acq-imp-rig    to   w-rig-imp-rig (1)      .
       det-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali da righe prima del trattamento piede*
      *    *-----------------------------------------------------------*
       det-tot-rig-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione totalizzatori per tipo prodotto *
      *              *-------------------------------------------------*
           perform   nor-tot-rig-000      thru nor-tot-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione castelletto iva                 *
      *              *-------------------------------------------------*
           perform   nor-iva-cst-000      thru nor-iva-cst-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione castelletto contropartite       *
      *              *-------------------------------------------------*
           perform   nor-iva-ctp-000      thru nor-iva-ctp-999        .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : uscita                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento totalizzatori per tipo prodotto   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga P o PN                         *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to det-tot-rig-120.
           if        w-rig-tip-pro (1)    =    01
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 01)
           else if   w-rig-tip-pro (1)    =    02
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 02)
           else if   w-rig-tip-pro (1)    =    03
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 03)
           else if   w-rig-tip-pro (1)    =    09
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 09)  .
           go to     det-tot-rig-180.
       det-tot-rig-120.
      *                  *---------------------------------------------*
      *                  * Se tipo riga M o V                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to det-tot-rig-140.
           add       w-rig-imp-rig (1)    to   w-pie-tot-rig (1, 01)  .
           go to     det-tot-rig-180.
       det-tot-rig-140.
      *                  *---------------------------------------------*
      *                  * Se tipo riga A                              *
      *                  *---------------------------------------------*
           add       w-rig-imp-rig (1)    to   w-pie-tot-rta (1)      .
       det-tot-rig-180.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-rig-ctr      .
       det-tot-rig-200.
           add       1                    to   w-det-tot-rig-ctr      .
           if        w-det-tot-rig-ctr    >    12
                     move  12             to   w-det-tot-rig-ctr
                     go to det-tot-rig-240.
           if        w-pie-iva-cod        
                    (1, w-det-tot-rig-ctr)
                                          =    zero
                     go to det-tot-rig-220.
           if        w-rig-civ-rig (1)    =    w-pie-iva-cod
                                              (1, w-det-tot-rig-ctr)
                     go to det-tot-rig-240.
           go to     det-tot-rig-200.
       det-tot-rig-220.
           add       1                    to   w-pie-iva-ele (1)      .
           move      w-rig-civ-rig (1)    to   w-pie-iva-cod
                                              (1, w-det-tot-rig-ctr)  .
       det-tot-rig-240.
           add       w-rig-imp-rig (1)    to   w-pie-iva-ibl
                                              (1, w-det-tot-rig-ctr)  .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-rig-ctr      .
       det-tot-rig-300.
           add       1                    to   w-det-tot-rig-ctr      .
           if        w-det-tot-rig-ctr    >    20
                     move  20             to   w-det-tot-rig-ctr
                     go to det-tot-rig-340.
           if        w-pie-ctp-cod        
                    (1, w-det-tot-rig-ctr)
                                          =    zero
                     go to det-tot-rig-320.
           if        w-rig-ctp-rig (1)    =    w-pie-ctp-cod
                                              (1, w-det-tot-rig-ctr)
                     go to det-tot-rig-340.
           go to     det-tot-rig-300.
       det-tot-rig-320.
           add       1                    to   w-pie-ctp-ele (1)      .
           move      w-rig-ctp-rig (1)    to   w-pie-ctp-cod
                                              (1, w-det-tot-rig-ctr)  .
       det-tot-rig-340.
           add       w-rig-imp-rig (1)    to   w-pie-ctp-imp
                                              (1, w-det-tot-rig-ctr)  .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione righe                      *
      *              *-------------------------------------------------*
           go to     det-tot-rig-100.
       det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Determinazione totale lordo                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 01)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 02)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 03)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 09)
                                          to   w-pie-tot-lor (1)      .
      *              *-------------------------------------------------*
      *              * Salvataggio castelletto iva                     *
      *              *-------------------------------------------------*
           move      w-pie-iva-cst (1)    to   w-sav-iva-cst          .
      *              *-------------------------------------------------*
      *              * Salvataggio castelletto contropartite           *
      *              *-------------------------------------------------*
           move      w-pie-ctp-cst (1)    to   w-sav-ctp-cst          .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       det-tot-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione codici iva per piede documento             *
      *    *-----------------------------------------------------------*
       det-civ-pie-000.
      *              *-------------------------------------------------*
      *              * Se fornitore soggetto iva : uscita              *
      *              *-------------------------------------------------*
           if        w-tes-ass-iva (1)    =    zero
                     go to det-civ-pie-999.
      *                  *---------------------------------------------*
      *                  * Codice iva sconto in chiusura               *
      *                  *---------------------------------------------*
           move      w-pie-civ-scc (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-pie-civ-scc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva sconto pagamento                 *
      *                  *---------------------------------------------*
           move      w-pie-civ-scp (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-pie-civ-scp (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva spese in fattura                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-civ-pie-ctr      .
       det-civ-pie-010.
           add       1                    to   w-det-civ-pie-ctr      .
           if        w-det-civ-pie-ctr    >    w-prs-spe-fat-nst
                     go to det-civ-pie-020.
           move      w-prs-spe-fat-npt
                    (w-det-civ-pie-ctr)   to   w-det-civ-pie-inx      .
      *
           move      w-pie-spe-civ
                    (1, w-det-civ-pie-inx)
                                          to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-pie-spe-civ
                                              (1, w-det-civ-pie-inx)  .
           go to     det-civ-pie-010.
       det-civ-pie-020.
      *                  *---------------------------------------------*
      *                  * Codice iva spese incasso                    *
      *                  *---------------------------------------------*
           move      w-tes-civ-spi (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-tes-civ-spi (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva spese bollo                      *
      *                  *---------------------------------------------*
           move      w-tes-civ-spb (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     move  w-tes-ass-iva (1)
                                          to   w-tes-civ-spb (1)      .
       det-civ-pie-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali riepilogo documento                 *
      *    *-----------------------------------------------------------*
       det-tri-doc-000.
      *              *-------------------------------------------------*
      *              * Ripristino castelletto iva originario           *
      *              *-------------------------------------------------*
           move      w-sav-iva-cst        to   w-pie-iva-cst (1)      .
      *              *-------------------------------------------------*
      *              * Ripristino castelletto contropartite originario *
      *              *-------------------------------------------------*
           move      w-sav-ctp-cst        to   w-pie-ctp-cst (1)      .
      *              *-------------------------------------------------*
      *              * Normalizzazione totale spese incasso calcolate  *
      *              *-------------------------------------------------*
           perform   nor-tot-sic-000      thru nor-tot-sic-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione spese bollo                     *
      *              *-------------------------------------------------*
           perform   nor-tot-spb-000      thru nor-tot-spb-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale sconto in chiusura        *
      *              *-------------------------------------------------*
           perform   det-tot-scc-000      thru det-tot-scc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale al netto dello sconto in  *
      *              * chiusura                                        *
      *              *-------------------------------------------------*
           perform   det-tot-nsc-000      thru det-tot-nsc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione importi spese                    *
      *              *-------------------------------------------------*
           perform   det-imp-spe-000      thru det-imp-spe-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale al netto delle spese in   *
      *              * fattura                                         *
      *              *-------------------------------------------------*
           perform   det-tot-nsf-000      thru det-tot-nsf-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale sconto pagamento          *
      *              *-------------------------------------------------*
           perform   det-tot-scp-000      thru det-tot-scp-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale netto                     *
      *              *-------------------------------------------------*
           perform   det-tot-net-000      thru det-tot-net-999        .
      *              *-------------------------------------------------*
      *              * Determinazione spese incasso aggiuntive         *
      *              *-------------------------------------------------*
           perform   det-tot-sia-000      thru det-tot-sia-999        .
      *              *-------------------------------------------------*
      *              * Determinazione di:                              *
      *              * - totale imponibile                             *
      *              * - totale imposta                                *
      *              * - totale documento                              *
      *              * - castelletto scadenze                          *
      *              * prima del calcolo spese incasso e spese bollo   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale imponibile            *
      *                  *---------------------------------------------*
           perform   det-tot-ibl-000      thru det-tot-ibl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale imposta               *
      *                  *---------------------------------------------*
           perform   det-tot-imp-000      thru det-tot-imp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione scadenze del documento       *
      *                  *---------------------------------------------*
           perform   det-sca-doc-000      thru det-sca-doc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione spese incasso calcolate          *
      *              *-------------------------------------------------*
           perform   det-tot-sic-000      thru det-tot-sic-999        .
      *              *-------------------------------------------------*
      *              * Determinazione di:                              *
      *              * - totale imponibile                             *
      *              * - totale imposta                                *
      *              * - totale documento                              *
      *              * - castelletto scadenze                          *
      *              * prima del calcolo spese bollo                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale imponibile            *
      *                  *---------------------------------------------*
           perform   det-tot-ibl-000      thru det-tot-ibl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale imposta               *
      *                  *---------------------------------------------*
           perform   det-tot-imp-000      thru det-tot-imp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione scadenze del documento       *
      *                  *---------------------------------------------*
           perform   det-sca-doc-000      thru det-sca-doc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione spese bollo                      *
      *              *-------------------------------------------------*
           perform   det-tot-spb-000      thru det-tot-spb-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totale spese                     *
      *              *-------------------------------------------------*
           perform   det-tot-spe-000      thru det-tot-spe-999        .
      *              *-------------------------------------------------*
      *              * Determinazione di:                              *
      *              * - totale imponibile                             *
      *              * - totale imposta                                *
      *              * - totale documento                              *
      *              * dopo la determinazione di spese incasso e bollo *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale imponibile            *
      *                  *---------------------------------------------*
           perform   det-tot-ibl-000      thru det-tot-ibl-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale imposta               *
      *                  *---------------------------------------------*
           perform   det-tot-imp-000      thru det-tot-imp-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-tri-doc-999.
       det-tri-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto in chiusura                  *
      *    *-----------------------------------------------------------*
       det-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-pie-tot-scc (1)    =    zero and
                     w-pie-per-scc (1)    =    zero
                     go to det-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to in chiusura e' stato impostato manualmente   *
      *              * nel piede                                       *
      *              *-------------------------------------------------*
           if        w-pie-per-scc (1)    =    zero
                     go to det-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-pie-per-scc (1)    by   w-pie-tot-lor (1)
                                        giving w-pie-tot-scc (1)      .
           divide    100                  into w-pie-tot-scc (1)
                                       rounded                        .
       det-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-iva-tip      .
           move      w-pie-civ-scc (1)    to   w-agg-cst-iva-coi      .
           move      w-pie-tot-scc (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-ctp-tip      .
           move      w-pie-ccp-scc (1)    to   w-agg-cst-ctp-cod      .
           move      w-pie-tot-scc (1)    to   w-agg-cst-ctp-imp      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto dello sonto in chiusura    *
      *    *-----------------------------------------------------------*
       det-tot-nsc-000.
           subtract  w-pie-tot-scc (1)    from w-pie-tot-lor (1)
                                        giving w-pie-tot-nsc (1)      .
       det-tot-nsc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo spese in fattura                   *
      *    *-----------------------------------------------------------*
       det-imp-spe-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-spe-c01      .
       det-imp-spe-050.
           add       1                    to   w-det-imp-spe-c01      .
           if        w-det-imp-spe-c01    >    w-prs-spe-fat-nst
                     go to det-imp-spe-999.
      *              *-------------------------------------------------*
      *              * Determinazione indice per la spesa              *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-imp-spe-c01)   to   w-det-imp-spe-inx      .
      *              *-------------------------------------------------*
      *              * Se spesa da non addebitare : riciclo            *
      *              *-------------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-imp-spe-inx)
                                          =    0
                     go to det-imp-spe-050.
      *              *-------------------------------------------------*
      *              * Se modalita' di addebito ad importo : ad aggior-*
      *              * namenti                                         *
      *              *-------------------------------------------------*
           if        w-pie-spe-mad
                    (1, w-det-imp-spe-inx)
                                          =    3 or
                     w-pie-spe-mad
                    (1, w-det-imp-spe-inx)
                                          =    4
                     go to det-imp-spe-500.
       det-imp-spe-100.
      *              *-------------------------------------------------*
      *              * Se modalita' di addebito a percentuale          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione imponibile per la spesa     *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-spe-ibl      .
      *                  *---------------------------------------------*
      *                  * Determinazione imponibile per la spesa      *
      *                  *---------------------------------------------*
           if        w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    01
                     move w-pie-tot-lor (1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    02
                     move w-pie-tot-nsc (1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    03
                     go to det-imp-spe-220
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    11
                     move w-pie-tot-rig (1, 1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    12
                     move w-pie-tot-rig (1, 2)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    13
                     move w-pie-tot-rig (1, 3)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    14
                     move w-pie-tot-rig (1, 4)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    15
                     move w-pie-tot-rig (1, 5)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    16
                     move w-pie-tot-rig (1, 6)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    17
                     move w-pie-tot-rig (1, 7)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    18
                     move w-pie-tot-rig (1, 8)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    19
                     move w-pie-tot-rig (1, 9)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-250.
       det-imp-spe-220.
      *                      *-----------------------------------------*
      *                      * Se risulta da una combinazione di tota- *
      *                      * li                                      *
      *                      *-----------------------------------------*
           move      w-pie-spe-ibt
                    (1, w-det-imp-spe-inx)
                                          to   w-det-imp-spe-ibt      .
           move      zero                 to   w-det-imp-spe-c02      .
       det-imp-spe-225.
           add       1                    to   w-det-imp-spe-c02      .
           if        w-det-imp-spe-c02    >    9
                     go to det-imp-spe-250.
           if        w-det-imp-spe-ibx
                    (w-det-imp-spe-c02)   not  = "S"
                     go to det-imp-spe-225.
           add       w-pie-tot-rig
                    (1, w-det-imp-spe-c02)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-225.
       det-imp-spe-250.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  w-pie-spe-per
                    (1, w-det-imp-spe-inx)
                                          by   w-det-imp-spe-ibl
                                        giving w-pie-spe-imp
                                              (1, w-det-imp-spe-inx)  .
           divide    100                  into w-pie-spe-imp
                                              (1, w-det-imp-spe-inx)
                                                            rounded   .
       det-imp-spe-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-pie-spe-civ
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-iva-coi      .
           move      w-pie-spe-imp
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-pie-spe-ccp
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-ctp-cod      .
           move      w-pie-spe-imp
                    (1, w-det-imp-spe-inx)
                                          to   w-agg-cst-ctp-imp      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella                    *
      *              *-------------------------------------------------*
           go to     det-imp-spe-050.
       det-imp-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto delle spese in fattura     *
      *    *-----------------------------------------------------------*
       det-tot-nsf-000.
      *              *-------------------------------------------------*
      *              * Azzeramento work per accumulo spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-was      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-ctr      .
       det-tot-nsf-100.
           add       1                    to   w-det-tot-nsf-ctr      .
           if        w-det-tot-nsf-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-nsf-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-nsf-ctr)   to   w-det-tot-nsf-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-tot-nsf-inx)
                                          =    0
                     go to det-tot-nsf-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-pie-spe-imp
                    (1, w-det-tot-nsf-inx)
                                          to   w-det-tot-nsf-was      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-nsf-100.
       det-tot-nsf-200.
      *              *-------------------------------------------------*
      *              * Determinazione valore                           *
      *              *-------------------------------------------------*
           move      w-pie-tot-nsc (1)    to    w-pie-tot-nsf (1)     .
           add       w-det-tot-nsf-was    to    w-pie-tot-nsf (1)     .
       det-tot-nsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto pagamento                    *
      *    *-----------------------------------------------------------*
       det-tot-scp-000.
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-pie-tot-scp (1)    =    zero and
                     w-pie-per-scp (1)    =    zero
                     go to det-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to pagamento e' stato impostato manualmente nel *
      *              * piede                                           *
      *              *-------------------------------------------------*
           if        w-pie-per-scp (1)    =    zero
                     go to det-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-pie-per-scp (1)    by   w-pie-tot-nsf (1)
                                        giving w-pie-tot-scp (1)      .
           divide    100                  into w-pie-tot-scp (1)
                                       rounded                        .
       det-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-iva-tip      .
           move      w-pie-civ-scp (1)    to   w-agg-cst-iva-coi      .
           move      w-pie-tot-scp (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "-"                  to   w-agg-cst-ctp-tip      .
           move      w-pie-ccp-scp (1)    to   w-agg-cst-ctp-cod      .
           move      w-pie-tot-scp (1)    to   w-agg-cst-ctp-imp      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale netto                               *
      *    *-----------------------------------------------------------*
       det-tot-net-000.
           subtract  w-pie-tot-scc (1)    from w-pie-tot-lor (1)
                                        giving w-pie-tot-net (1)      .
           subtract  w-pie-tot-scp (1)    from w-pie-tot-net (1)      .
       det-tot-net-999.
           exit.

      *    *===========================================================*
      *    * Determinazione spese incasso calcolate                    *
      *    *-----------------------------------------------------------*
       det-tot-sic-000.
      *              *-------------------------------------------------*
      *              * Se codice spesa incasso non esistente : uscita  *
      *              *-------------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to det-tot-sic-999.
      *              *-------------------------------------------------*
      *              * Se valuta del documento non e' quella di base : *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = c-sgl
                     go to det-tot-sic-999.
      *              *-------------------------------------------------*
      *              * Azzeramento accumulatore spese incasso          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-sic-wpa      .
      *              *-------------------------------------------------*
      *              * Ciclo su tabella scadenze                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-sic-c01      .
       det-tot-sic-100.
           add       1                    to   w-det-tot-sic-c01      .
           if        w-det-tot-sic-c01    >    w-pie-scd-ele (1)
                     go to det-tot-sic-500.
      *                  *---------------------------------------------*
      *                  * Test se esistono spese incasso per il tipo  *
      *                  * scadenza in esame                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Scansione tabella spese incasso         *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-sic-c02      .
       det-tot-sic-200.
           add       1                    to   w-det-tot-sic-c02      .
           if        w-det-tot-sic-c02    >    w-tes-eit-spi (1)
                     go to det-tot-sic-100.
      *                      *-----------------------------------------*
      *                      * Se tipo pagamento non corrisponde a     *
      *                      * quello della scadenza in esame : rici-  *
      *                      * clo su prossima scadenza                *
      *                      *-----------------------------------------*
           if        w-tes-tpg-spi
                    (1, w-det-tot-sic-c02)
                                          not  = w-pie-scd-tip
                                                (1, w-det-tot-sic-c01)
                     go to det-tot-sic-200.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo funzio- *
      *                      * namento spesa incasso                   *
      *                      *-----------------------------------------*
           if        w-tes-tfu-spi
                    (1, w-det-tot-sic-c02)
                                          =    01
                     go to det-tot-sic-220
           else if   w-tes-tfu-spi
                    (1, w-det-tot-sic-c02)
                                          =    02
                     go to det-tot-sic-240.
       det-tot-sic-220.
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : automatico         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento accumulatore importo  *
      *                          * spese incasso                       *
      *                          *-------------------------------------*
           add       w-tes-amm-spi
                    (1, w-det-tot-sic-c02)
                                          to   w-det-tot-sic-wpa      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-sic-100.
       det-tot-sic-240.
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : manuale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-sic-100.
       det-tot-sic-500.
      *              *-------------------------------------------------*
      *              * Memorizzazione totale spese incasso calcolate   *
      *              *-------------------------------------------------*
           move      w-det-tot-sic-wpa    to   w-pie-tot-sic (1)      .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-tes-civ-spi (1)    to   w-agg-cst-iva-coi      .
           move      w-pie-tot-sic (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-tes-ccp-spi (1)    to   w-agg-cst-ctp-cod      .
           move      w-pie-tot-sic (1)    to   w-agg-cst-ctp-imp      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-sic-999.
           exit.

      *    *===========================================================*
      *    * Determinazione spese incasso aggiuntive                   *
      *    *-----------------------------------------------------------*
       det-tot-sia-000.
      *              *-------------------------------------------------*
      *              * Se spese incasso aggiuntive zero : uscita       *
      *              *-------------------------------------------------*
           if        w-pie-tot-sia (1)    =    zero
                     go to det-tot-sia-999.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-tes-civ-spi (1)    to   w-agg-cst-iva-coi      .
           move      w-pie-tot-sia (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-tes-ccp-spi (1)    to   w-agg-cst-ctp-cod      .
           move      w-pie-tot-sia (1)    to   w-agg-cst-ctp-imp      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-sia-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale spese bollo                         *
      *    *-----------------------------------------------------------*
       det-tot-spb-000.
      *              *-------------------------------------------------*
      *              * Azzeramento accumulatore spese bollo            *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spb-wpa      .
      *              *-------------------------------------------------*
      *              * Se codice spesa bollo non esistente : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to det-tot-spb-999.
      *              *-------------------------------------------------*
      *              * Se valuta del documento non e' quella di base : *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    not  = c-sgl
                     go to det-tot-spb-999.
      *              *-------------------------------------------------*
      *              * Ciclo su tabella scadenze                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spb-c01      .
       det-tot-spb-100.
           add       1                    to   w-det-tot-spb-c01      .
           if        w-det-tot-spb-c01    >    w-pie-scd-ele (1)
                     go to det-tot-spb-500.
      *                  *---------------------------------------------*
      *                  * Test se esistono spese bollo per il tipo    *
      *                  * scadenza in esame                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Scansione tabella spese bollo           *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spb-c02      .
       det-tot-spb-200.
           add       1                    to   w-det-tot-spb-c02      .
           if        w-det-tot-spb-c02    >    w-tes-eit-spb (1)
                     go to det-tot-spb-100.
      *                      *-----------------------------------------*
      *                      * Se tipo pagamento non corrisponde a     *
      *                      * quello della scadenza in esame : riciclo*
      *                      *-----------------------------------------*
           if        w-tes-tpg-spb
                    (1, w-det-tot-spb-c02)
                                          not  = w-pie-scd-tip
                                                (1, w-det-tot-spb-c01)
                     go to det-tot-spb-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per importo spesa      *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tot-spb-wis      .
      *                  *---------------------------------------------*
      *                  * Se importo scadenza non e' maggiore del     *
      *                  * tetto di esenzione : riciclo su prossima    *
      *                  * scadenza                                    *
      *                  *---------------------------------------------*
           if        w-pie-scd-imp
                    (1, w-det-tot-spb-c01)
                                          not  > w-tes-tet-spb
                                                (1, w-det-tot-spb-c02)
                     go to det-tot-spb-100.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo automatismo *
      *                  * spesa bollo                                 *
      *                  *---------------------------------------------*
           if        w-tes-tau-spb
                    (1, w-det-tot-spb-c02)
                                          =    01
                     go to det-tot-spb-220
           else if   w-tes-tau-spb
                    (1, w-det-tot-spb-c02)
                                          =    02
                     go to det-tot-spb-240
           else if   w-tes-tau-spb
                    (1, w-det-tot-spb-c02)
                                          =    03
                     go to det-tot-spb-260.
       det-tot-spb-220.
      *                  *---------------------------------------------*
      *                  * Tipo automatismo : in percentuale sul tota- *
      *                  * le scadenza                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione importo spesa            *
      *                      *-----------------------------------------*
           multiply  w-tes-per-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-pie-scd-imp
                                              (1, w-det-tot-spb-c01)
                                        giving w-det-tot-spb-s13      .
           divide    100                  into w-det-tot-spb-s13
                                        giving w-det-tot-spb-wis
                                                         rounded      .
      *                      *-----------------------------------------*
      *                      * A trattamento arrotondamento            *
      *                      *-----------------------------------------*
           go to     det-tot-spb-300.
       det-tot-spb-240.
      *                  *---------------------------------------------*
      *                  * Tipo automatismo : a scaglioni              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ciclo per 10 scaglioni                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spb-c03      .
       det-tot-spb-242.
           add       1                    to   w-det-tot-spb-c03      .
           if        w-det-tot-spb-c03    >    10
                     go to det-tot-spb-244.
           if        w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   =    zero
                     go to det-tot-spb-242.
           if        w-pie-scd-imp
                    (1, w-det-tot-spb-c01)
                                          >    w-tes-tbe-scg
                                              (                1,
                                               w-det-tot-spb-c02,
                                               w-det-tot-spb-c03)
                     go to det-tot-spb-242.
           move      w-tes-tbe-asc
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   to   w-det-tot-spb-wis      .
       det-tot-spb-244.
      *                      *-----------------------------------------*
      *                      * A trattamento arrotondamento            *
      *                      *-----------------------------------------*
           go to     det-tot-spb-300.
       det-tot-spb-260.
      *                  *---------------------------------------------*
      *                  * Tipo automatismo : a scaglioni in percentua-*
      *                  *                    le                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione work per progressivo   *
      *                      * imponibile                              *
      *                      *-----------------------------------------*
           move      w-pie-scd-imp
                    (1, w-det-tot-spb-c01)
                                          to   w-det-tot-spb-wpi      .
      *                      *-----------------------------------------*
      *                      * Ciclo per 10 scaglioni                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-tot-spb-c03      .
       det-tot-spb-262.
           add       1                    to   w-det-tot-spb-c03      .
           if        w-det-tot-spb-c03    >    10
                     go to det-tot-spb-270.
           if        w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   =    zero
                     go to det-tot-spb-262.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che l'importo sca- *
      *                      * glione sia maggiore o meno dell'importo *
      *                      * scadenza                                *
      *                      *-----------------------------------------*
           if        w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   >    w-pie-scd-imp
                                              (1, w-det-tot-spb-c01)
                     go to det-tot-spb-270
           else      go to det-tot-spb-264.
       det-tot-spb-264.
      *                      *-----------------------------------------*
      *                      * Se l'importo scaglione e' minore o u-   *
      *                      * guale dell'importo scadenza             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Calcolo quota spesa bollo relativa  *
      *                          * allo scaglione                      *
      *                          *-------------------------------------*
           multiply  w-tes-tbe-psc
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)
                                          by   w-tes-tbe-scg
                                              (                1,
                                               w-det-tot-spb-c02,
                                               w-det-tot-spb-c03)
                                        giving w-det-tot-spb-s13      .
           divide    100                  into w-det-tot-spb-s13
                                        giving w-det-tot-spb-wss
                                                         rounded      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo spesa         *
      *                          *-------------------------------------*
           add       w-det-tot-spb-wss    to   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * Aggiornamento progressivo imponibile*
      *                          *-------------------------------------*
           subtract  w-tes-tbe-scg
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)   from w-det-tot-spb-wpi      .
      *                          *-------------------------------------*
      *                          * Riciclo su prossimo scaglione       *
      *                          *-------------------------------------*
           go to     det-tot-spb-262.
       det-tot-spb-270.
      *                      *-----------------------------------------*
      *                      * Se l'importo scaglione e' superiore al- *
      *                      * l'importo scadenza                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Calcolo quota spesa bollo relativa  *
      *                          * al residuo, cioe' il progressivo im-*
      *                          * ponibile sin qui determinato        *
      *                          *-------------------------------------*
           multiply  w-tes-tbe-psc
                    (                1,
                     w-det-tot-spb-c02,
                     w-det-tot-spb-c03)
                                          by   w-det-tot-spb-wpi
                                        giving w-det-tot-spb-s13      .
           divide    100                  into w-det-tot-spb-s13
                                        giving w-det-tot-spb-wss
                                                         rounded      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo spesa         *
      *                          *-------------------------------------*
           add       w-det-tot-spb-wss    to   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A trattamento arrotondamento        *
      *                          *-------------------------------------*
           go to     det-tot-spb-300.
       det-tot-spb-300.
      *                  *---------------------------------------------*
      *                  * Trattamento arrotondamento                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se esiste un valore minimo per la spesa *
      *                      *-----------------------------------------*
           if        w-tes-min-spb
                    (1, w-det-tot-spb-c02)
                                          =    zero
                     go to det-tot-spb-302.
      *                      *-----------------------------------------*
      *                      * Se l'importo spesa sin qui determinato  *
      *                      * e' inferiore al minimo valore, si forza *
      *                      * il valore minimo                        *
      *                      *-----------------------------------------*
           if        w-det-tot-spb-wis    <    w-tes-min-spb
                                              (1, w-det-tot-spb-c02)
                     move  w-tes-min-spb
                          (1, w-det-tot-spb-c02)
                                          to   w-det-tot-spb-wis      .
       det-tot-spb-302.
      *                      *-----------------------------------------*
      *                      * Se esiste un valore massimo per la spesa*
      *                      *-----------------------------------------*
           if        w-tes-max-spb
                    (1, w-det-tot-spb-c02)
                                          =    zero
                     go to det-tot-spb-304.
      *                      *-----------------------------------------*
      *                      * Se l'importo spesa sin qui determinato  *
      *                      * e' superiore al massimo valore, si forza*
      *                      * il valore massimo                       *
      *                      *-----------------------------------------*
           if        w-det-tot-spb-wis    >    w-tes-max-spb
                                              (1, w-det-tot-spb-c02)
                     move  w-tes-max-spb
                          (1, w-det-tot-spb-c02)
                                          to   w-det-tot-spb-wis      .
       det-tot-spb-304.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo arroton-*
      *                      * damento                                 *
      *                      *-----------------------------------------*
           go to     det-tot-spb-310
                     det-tot-spb-320
                     det-tot-spb-330
                     det-tot-spb-340
                                depending on   w-tes-tar-spb
                                              (1, w-det-tot-spb-c02)  .
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : nessuno           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scadenze       *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-310.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : al valore superio-*
      *                      *                       re                *
      *                      *-----------------------------------------*
           if        w-det-tot-spb-wis    >    zero
                     add      w-tes-var-spb
                             (1, w-det-tot-spb-c02)
                                          to   w-det-tot-spb-wis
                     subtract 1           from w-det-tot-spb-wis
           else      subtract w-tes-var-spb
                             (1, w-det-tot-spb-c02)
                                          from w-det-tot-spb-wis
                     add      1           to   w-det-tot-spb-wis      .
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-320.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : al valore inferio-*
      *                      *                       re                *
      *                      *-----------------------------------------*
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-330.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : commerciale       *
      *                      *-----------------------------------------*
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis
                                                         rounded      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-340.
      *                      *-----------------------------------------*
      *                      * Tipo arrotondamento : statale           *
      *                      *-----------------------------------------*
           divide    2                    into w-tes-var-spb
                                              (1, w-det-tot-spb-c02)
                                        giving w-det-tot-spb-wpc
                                                          rounded     .
           if        w-det-tot-spb-wis    >    zero
                     add      w-det-tot-spb-wpc
                                          to   w-det-tot-spb-wis
                     subtract 1           from w-det-tot-spb-wis
           else      subtract w-det-tot-spb-wpc
                                          from w-det-tot-spb-wis
                     add      1           to   w-det-tot-spb-wis      .
           divide    w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          into w-det-tot-spb-wis      .
           multiply  w-tes-var-spb
                    (1, w-det-tot-spb-c02)
                                          by   w-det-tot-spb-wis      .
      *                          *-------------------------------------*
      *                          * A riciclo su tabella scdenze        *
      *                          *-------------------------------------*
           go to     det-tot-spb-400.
       det-tot-spb-400.
      *                  *---------------------------------------------*
      *                  * Aggiornamento accumulatore spese bollo      *
      *                  *---------------------------------------------*
           add       w-det-tot-spb-wis    to   w-det-tot-spb-wpa      .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossima scadenza                *
      *                  *---------------------------------------------*
           go to     det-tot-spb-100.
       det-tot-spb-500.
      *              *-------------------------------------------------*
      *              * Memorizzazione totale spese bollo calcolate     *
      *              *-------------------------------------------------*
           move      w-det-tot-spb-wpa    to   w-pie-tot-spb (1)      .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-iva-tip      .
           move      w-tes-civ-spb (1)    to   w-agg-cst-iva-coi      .
           move      w-pie-tot-spb (1)    to   w-agg-cst-iva-imp      .
           perform   agg-cst-iva-000      thru agg-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
           move      "+"                  to   w-agg-cst-ctp-tip      .
           move      w-tes-ccp-spb (1)    to   w-agg-cst-ctp-cod      .
           move      w-pie-tot-spb (1)    to   w-agg-cst-ctp-imp      .
           perform   agg-cst-ctp-000      thru agg-cst-ctp-999        .
       det-tot-spb-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale spese                               *
      *    *-----------------------------------------------------------*
       det-tot-spe-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-spe (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spe-ctr      .
       det-tot-spe-100.
           add       1                    to   w-det-tot-spe-ctr      .
           if        w-det-tot-spe-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-spe-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-spe-ctr)   to   w-det-tot-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-tot-spe-inx)
                                          =    0
                     go to det-tot-spe-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-pie-spe-imp
                    (1, w-det-tot-spe-inx)
                                          to   w-pie-tot-spe (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-spe-100.
       det-tot-spe-200.
      *              *-------------------------------------------------*
      *              * Spese incasso calcolate                         *
      *              *-------------------------------------------------*
           add       w-pie-tot-sic (1)    to   w-pie-tot-spe (1)      .
      *              *-------------------------------------------------*
      *              * Spese incasso aggiuntive                        *
      *              *-------------------------------------------------*
           add       w-pie-tot-sia (1)    to   w-pie-tot-spe (1)      .
      *              *-------------------------------------------------*
      *              * Spese bollo                                     *
      *              *-------------------------------------------------*
           add       w-pie-tot-spb (1)    to   w-pie-tot-spe (1)      .
       det-tot-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale imponibile                          *
      *    *-----------------------------------------------------------*
       det-tot-ibl-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-ibl (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-ibl-ctr      .
       det-tot-ibl-100.
           add       1                    to   w-det-tot-ibl-ctr      .
           if        w-det-tot-ibl-ctr    >    6
                     go to det-tot-ibl-999.
           add       w-pie-iva-ibl
                    (1, w-det-tot-ibl-ctr)
                                          to   w-pie-tot-ibl (1)      .
           go to     det-tot-ibl-100.
       det-tot-ibl-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale imposta                             *
      *    *-----------------------------------------------------------*
       det-tot-imp-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-imp (1)      .
           move      zero                 to   w-det-tot-imp-wpa      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-imp-ctr      .
       det-tot-imp-100.
           add       1                    to   w-det-tot-imp-ctr      .
           if        w-det-tot-imp-ctr    >    6
                     go to det-tot-imp-999.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      "DI"                 to   d-imp-iva-tip-ope      .
           move      w-pie-iva-ibl
                    (1, w-det-tot-imp-ctr)
                                          to   d-imp-iva-ibl-iva      .
           move      w-pie-iva-cod
                    (1, w-det-tot-imp-ctr)
                                          to   d-imp-iva-cod-iva      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
      *                  *---------------------------------------------*
      *                  * Aggiornamento accumulatore                  *
      *                  *---------------------------------------------*
           add       d-imp-iva-ims-iva    to   w-pie-tot-imp (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-imp-100.
       det-tot-imp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
           add       w-pie-tot-ibl (1)
                     w-pie-tot-imp (1)  giving w-pie-tot-doc (1)      .
       det-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione scadenze per il documento                  *
      *    *-----------------------------------------------------------*
       det-sca-doc-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri in input                 *
      *              *-------------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-clc-tbl-scd-fdp      .
           move      w-tes-dat-reg        to   w-clc-tbl-scd-ddo      .
           move      w-pie-tot-ibl (1)    to   w-clc-tbl-scd-ibl      .
           move      w-pie-tot-imp (1)    to   w-clc-tbl-scd-iva      .
           move      w-tes-pag-qaf (1)    to   w-clc-tbl-scd-qaf      .
           move      w-tes-pag-act (1)    to   w-clc-tbl-scd-acc      .
           move      w-tes-pag-dsm (1)    to   w-clc-tbl-scd-ddp      .
           move      zero                 to   w-det-sca-doc-ctr      .
       det-sca-doc-100.
           add       1                    to   w-det-sca-doc-ctr      .
           if        w-det-sca-doc-ctr    >    3
                     go to det-sca-doc-120.
           move      w-tes-cod-pag
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-cdp
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-tip-amm
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-tam
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-per-toi
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-pti
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dim-act
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dda
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-tip-pag
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-tpg
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-num-sca
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-nsp
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dec-prs
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dps
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dap-mes
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dpm
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-dap-gio
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-dpg
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-ggg-int
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-gdi
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-tip-scm
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-tsm
                                              (w-det-sca-doc-ctr)     .
           move      w-tes-gio-scm
                    (1, w-det-sca-doc-ctr)
                                          to   w-clc-tbl-scd-gfs
                                              (w-det-sca-doc-ctr)     .
           move      zero                 to   w-clc-tbl-scd-ccp
                                              (w-det-sca-doc-ctr)     .
           go to     det-sca-doc-100.
       det-sca-doc-120.
           move      zero                 to   w-clc-tbl-scd-esm      .
           move      zero                 to   w-clc-tbl-scd-alt      .
           move      zero                 to   w-clc-tbl-scd-e01      .
           move      zero                 to   w-clc-tbl-scd-e02      .
       det-sca-doc-200.
      *              *-------------------------------------------------*
      *              * Richiamo routine di calcolo                     *
      *              *-------------------------------------------------*
           perform   clc-tbl-scd-000      thru clc-tbl-scd-999        .
       det-sca-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da work locale a work piede           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sca-doc-ctr      .
       det-sca-doc-310.
           add       1                    to   w-det-sca-doc-ctr      .
           if        w-det-sca-doc-ctr    >    w-clc-tbl-scd-nts
                     go to det-sca-doc-320.
           move      w-clc-tbl-scd-tds
                    (w-det-sca-doc-ctr)   to   w-pie-scd-tip
                                              (1, w-det-sca-doc-ctr)  .
           move      w-clc-tbl-scd-dds
                    (w-det-sca-doc-ctr)   to   w-pie-scd-dat
                                              (1, w-det-sca-doc-ctr)  .
           move      w-clc-tbl-scd-ccs
                    (w-det-sca-doc-ctr)   to   w-pie-scd-cau
                                              (1, w-det-sca-doc-ctr)  .
           move      w-clc-tbl-scd-ids
                    (w-det-sca-doc-ctr)   to   w-pie-scd-imp
                                              (1, w-det-sca-doc-ctr)  .
           go to     det-sca-doc-310.
       det-sca-doc-320.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero totale scadenze          *
      *              *-------------------------------------------------*
           move      w-clc-tbl-scd-nts    to   w-pie-scd-ele (1)      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-sca-doc-999.
       det-sca-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importi in valuta base                     *
      *    *                                                           *
      *    * N.B.: questa routine e' identica a quella usate nell'area *
      *    *       vendite (wbolfat0.wks)                              *
      *    *-----------------------------------------------------------*
       det-imp-vlb-000.
      *              *-------------------------------------------------*
      *              * Trattamento castelletto iva                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Azzeramento totalizzatori                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ivb-tot-ibl          .
           move      zero                 to   w-ivb-tot-imp          .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su castelletto originale *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-vlb-ctr      .
       det-imp-vlb-100.
           add       1                    to   w-det-imp-vlb-ctr      .
           if        w-det-imp-vlb-ctr    >    w-pie-iva-ele (1)
                     go to det-imp-vlb-200.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione imponibile originale        *
      *                  *---------------------------------------------*
           move      w-pie-iva-ibl
                    (1, w-det-imp-vlb-ctr)
                                          to   w-ivb-iva-ibl
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Conversione imponibile in valuta base       *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-ivb-iva-ibl
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-iva-ibl
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Calcolo imposta                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           move      w-pie-iva-cod
                    (1, w-det-imp-vlb-ctr)
                                          to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    0 or
                     w-edt-iva-cod-003    =    9
                     go to det-imp-vlb-150
           else      move  zero           to   w-ivb-iva-imp
                                              (w-det-imp-vlb-ctr)  
                     go to det-imp-vlb-180.
       det-imp-vlb-150.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che si tratti di   *
      *                      * un aliquota di sola iva (omaggio) o no  *
      *                      *-----------------------------------------*
           if        w-edt-iva-cod-003    =    9
                     go to det-imp-vlb-152
           else      go to det-imp-vlb-154.
       det-imp-vlb-152.
      *                      *-----------------------------------------*
      *                      * Se aliquota di sola iva (omaggio)       *
      *                      *-----------------------------------------*
           move      w-pie-iva-cod
                    (1, w-det-imp-vlb-ctr)
                                          to   w-det-imp-vlb-wci      .
           subtract  900                  from w-det-imp-vlb-wci      .
           go to     det-imp-vlb-160.
       det-imp-vlb-154.
      *                      *-----------------------------------------*
      *                      * Se aliquota normale                     *
      *                      *-----------------------------------------*
           move      w-pie-iva-cod
                    (1, w-det-imp-vlb-ctr)
                                          to   w-det-imp-vlb-wci      .
           go to     det-imp-vlb-160.
       det-imp-vlb-160.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      "DI"                 to   d-imp-iva-tip-ope      .
           move      w-ivb-iva-ibl
                    (w-det-imp-vlb-ctr)   to   d-imp-iva-ibl-iva      .
           move      w-det-imp-vlb-wci    to   d-imp-iva-cod-iva      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
      *                  *---------------------------------------------*
      *                  * Aggiornamento imposta relativa all'aliquota *
      *                  *---------------------------------------------*
           move      d-imp-iva-ims-iva    to   w-ivb-iva-imp
                                              (w-det-imp-vlb-ctr)     .
       det-imp-vlb-180.
      *                  *---------------------------------------------*
      *                  * Aggiustamento imponibile in caso di aliquo- *
      *                  * ta di sola iva (Omaggi)                     *
      *                  *---------------------------------------------*
           if        w-edt-iva-cod-003    =    9
                     move  zero           to   w-ivb-iva-ibl
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale imponibile             *
      *                  *---------------------------------------------*
           add       w-ivb-iva-ibl
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-ibl          .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale imposta                *
      *                  *---------------------------------------------*
           add       w-ivb-iva-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-imp          .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione castelletto originale  *
      *                  *---------------------------------------------*
           go to     det-imp-vlb-100.
       det-imp-vlb-200.
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           add       w-ivb-tot-ibl
                     w-ivb-tot-imp      giving w-ivb-tot-doc          .
       det-imp-vlb-300.
      *              *-------------------------------------------------*
      *              * Trattamento castelletto contropartite           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Azzeramento totalizzatori                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ivb-tot-ctp          .
      *                  *---------------------------------------------*
      *                  * Test se almeno un elemento presente         *
      *                  *---------------------------------------------*
           if        w-pie-ctp-ele (1)    =    zero
                     go to det-imp-vlb-400.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su castelletto originale *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-vlb-ctr      .
       det-imp-vlb-320.
           add       1                    to   w-det-imp-vlb-ctr      .
      *                  *---------------------------------------------*
      *                  * Test su numero elementi castelletto         *
      *                  *---------------------------------------------*
           if        w-det-imp-vlb-ctr    >    w-pie-ctp-ele (1)
                     go to det-imp-vlb-340.
      *                  *---------------------------------------------*
      *                  * Test su numero massimo elementi castelletto *
      *                  *---------------------------------------------*
           if        w-det-imp-vlb-ctr    >    20
                     go to det-imp-vlb-340.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione importo originale           *
      *                  *---------------------------------------------*
           move      w-pie-ctp-imp
                    (1, w-det-imp-vlb-ctr)
                                          to   w-ivb-ctp-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Conversione importo in valuta base          *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-ivb-ctp-imp
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-ctp-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale contropartite          *
      *                  *---------------------------------------------*
           add       w-ivb-ctp-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-ctp          .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione castelletto originale  *
      *                  *---------------------------------------------*
           go to     det-imp-vlb-320.
       det-imp-vlb-340.
      *                  *---------------------------------------------*
      *                  * Aggiustamento dell'eventuale differenza tra *
      *                  * il castelletto iva e il castelletto contro- *
      *                  * partite                                     *
      *                  *---------------------------------------------*
           subtract  w-ivb-tot-ctp        from w-ivb-tot-ibl
                                        giving w-det-imp-vlb-s11      .
           add       w-det-imp-vlb-s11    to   w-ivb-ctp-imp (1)      .
           add       w-det-imp-vlb-s11    to   w-ivb-tot-ctp          .
       det-imp-vlb-400.
      *              *-------------------------------------------------*
      *              * Trattamento castelletto scadenze                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Azzeramento totalizzatori                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ivb-tot-scb          .
           move      zero                 to   w-ivb-tot-scv          .
      *                  *---------------------------------------------*
      *                  * Test se almeno un elemento presente         *
      *                  *---------------------------------------------*
           if        w-pie-scd-ele (1)    =    zero
                     go to det-imp-vlb-500.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su castelletto originale *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-vlb-ctr      .
       det-imp-vlb-420.
           add       1                    to   w-det-imp-vlb-ctr      .
           if        w-det-imp-vlb-ctr    >    w-pie-scd-ele (1)
                     go to det-imp-vlb-440.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione importo scadenza originale  *
      *                  *---------------------------------------------*
           move      w-pie-scd-imp
                    (1, w-det-imp-vlb-ctr)
                                          to   w-ivb-scd-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze in valuta do- *
      *                  * cumento                                     *
      *                  *---------------------------------------------*
           add       w-pie-scd-imp
                    (1, w-det-imp-vlb-ctr)
                                          to   w-ivb-tot-scv          .
      *                  *---------------------------------------------*
      *                  * Conversione importo scadenza in valuta base *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-ivb-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-scd-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze in valuta ba- *
      *                  * se                                          *
      *                  *---------------------------------------------*
           add       w-ivb-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-scb          .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione castelletto originale  *
      *                  *---------------------------------------------*
           go to     det-imp-vlb-420.
       det-imp-vlb-440.
      *                  *---------------------------------------------*
      *                  * Aggiustamento dell'eventuale differenza tra *
      *                  * il totale scadenze in valuta base e in va-  *
      *                  * luta documento                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Conversione totale scadenze in valuta   *
      *                      * documento nella valuta base             *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-ivb-tot-scv        to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-tot-scv          .
      *                      *-----------------------------------------*
      *                      * Addebito della differenza sulla prima   *
      *                      * scadenza                                *
      *                      *-----------------------------------------*
           subtract  w-ivb-tot-scb        from w-ivb-tot-scv
                                        giving w-det-imp-vlb-s11      .
           add       w-det-imp-vlb-s11    to   w-ivb-scd-imp (1)      .
           add       w-det-imp-vlb-s11    to   w-ivb-tot-scb          .
       det-imp-vlb-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-imp-vlb-999.
       det-imp-vlb-999.
           exit.

      *    *===========================================================*
      *    * Calcolo prezzo netto                                      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcalprz0.cps"                   .

      *    *===========================================================*
      *    * Aggiornamento castelletto iva                             *
      *    *-----------------------------------------------------------*
       agg-cst-iva-000.
      *              *-------------------------------------------------*
      *              * Se importo a zero : uscita                      *
      *              *-------------------------------------------------*
           if        w-agg-cst-iva-imp    =    zero
                     go to agg-cst-iva-999.
      *              *-------------------------------------------------*
      *              * Inversione del segno in caso di aggiornamento   *
      *              * negativo                                        *
      *              *-------------------------------------------------*
           if        w-agg-cst-iva-tip    =    "-"
                     multiply -1          by   w-agg-cst-iva-imp      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che il campo abbia un'ali- *
      *              * quota propria oppure debba essere sventagliato  *
      *              * su tutto il castelletto iva                     *
      *              *-------------------------------------------------*
           if        w-agg-cst-iva-coi    not  = zero
                     go to agg-cst-iva-200
           else      go to agg-cst-iva-300.
       agg-cst-iva-200.
      *                  *---------------------------------------------*
      *                  * Caso in cui abbia un'aliquota propria       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento riga castelletto iva      *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-cst-iva-ctr      .
       agg-cst-iva-220.
           add       1                    to   w-agg-cst-iva-ctr      .
           if        w-agg-cst-iva-ctr    >    12
                     move  12             to   w-agg-cst-iva-ctr
                     go to agg-cst-iva-260.
           if        w-pie-iva-cod        
                    (1, w-agg-cst-iva-ctr)
                                          =    zero
                     go to agg-cst-iva-240.
           if        w-agg-cst-iva-coi    =    w-pie-iva-cod
                                              (1, w-agg-cst-iva-ctr)
                     go to agg-cst-iva-260.
           go to     agg-cst-iva-220.
       agg-cst-iva-240.
           add       1                    to   w-pie-iva-ele (1)      .
           move      w-agg-cst-iva-coi    to   w-pie-iva-cod
                                              (1, w-agg-cst-iva-ctr)  .
       agg-cst-iva-260.
           add       w-agg-cst-iva-imp    to   w-pie-iva-ibl
                                              (1, w-agg-cst-iva-ctr)  .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     agg-cst-iva-999.
       agg-cst-iva-300.
      *                  *---------------------------------------------*
      *                  * Caso in cui debba essere sventagliato sul   *
      *                  * castelletto iva gia' esistente              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione del numero di elementi   *
      *                      * presenti in castelletto iva e del tota- *
      *                      * le imponibile                           *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-cst-iva-tot      .
           move      zero                 to   w-agg-cst-iva-ctr      .
       agg-cst-iva-320.
           add       1                    to   w-agg-cst-iva-ctr      .
           if        w-pie-iva-cod        
                    (1, w-agg-cst-iva-ctr)
                                          =    zero
                     go to agg-cst-iva-330.
           add       w-pie-iva-ibl
                    (1, w-agg-cst-iva-ctr)
                                          to   w-agg-cst-iva-tot      .
           go to     agg-cst-iva-320.
       agg-cst-iva-330.
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero elementi in ca-   *
      *                      * stelletto iva                           *
      *                      *-----------------------------------------*
           move      w-agg-cst-iva-ctr    to   w-agg-cst-iva-max      .
      *                      *-----------------------------------------*
      *                      * Ciclo di aggiornamento castelletto iva  *
      *                      * fino all'elemento  w-agg-cst-iva-max    *
      *                      * escluso                                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-cst-iva-wpa      .
           move      zero                 to   w-agg-cst-iva-ctr      .
       agg-cst-iva-340.
           add       1                    to   w-agg-cst-iva-ctr      .
           if        w-agg-cst-iva-ctr    =    w-agg-cst-iva-max
                     go to agg-cst-iva-360.
      *                          *-------------------------------------*
      *                          * Determinazione porzione dell'impor- *
      *                          * to relativa alla riga di castelletto*
      *                          * iva                                 *
      *                          *-------------------------------------*
           multiply  w-agg-cst-iva-imp    by   w-pie-iva-ibl
                                              (1, w-agg-cst-iva-ctr)
                                        giving w-agg-cst-iva-s18      .
           divide    w-agg-cst-iva-tot    into w-agg-cst-iva-s18
                                       rounded                        .
           add       w-agg-cst-iva-s18    to   w-pie-iva-ibl
                                              (1, w-agg-cst-iva-ctr)  .
           add       w-agg-cst-iva-s18    to   w-agg-cst-iva-wpa      .
           go to     agg-cst-iva-340.
       agg-cst-iva-360.
      *                      *-----------------------------------------*
      *                      * Trattamento ultimo elemento castelletto *
      *                      *-----------------------------------------*
           subtract  w-agg-cst-iva-wpa    from w-agg-cst-iva-imp
                                        giving w-agg-cst-iva-s11      .
           add       w-agg-cst-iva-s11    to   w-pie-iva-ibl
                                              (1, w-agg-cst-iva-max)  .
       agg-cst-iva-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento castelletto contropartite                   *
      *    *-----------------------------------------------------------*
       agg-cst-ctp-000.
      *              *-------------------------------------------------*
      *              * Se importo a zero : uscita                      *
      *              *-------------------------------------------------*
           if        w-agg-cst-ctp-imp    =    zero
                     go to agg-cst-ctp-999.
      *              *-------------------------------------------------*
      *              * Inversione del segno in caso di aggiornamento   *
      *              * negativo                                        *
      *              *-------------------------------------------------*
           if        w-agg-cst-ctp-tip    =    "-"
                     multiply -1          by   w-agg-cst-ctp-imp      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che il campo abbia una con-*
      *              * tropartita propria oppure debba essere sventa-  *
      *              * gliato su tutto il castelletto contropartite    *
      *              *-------------------------------------------------*
           if        w-agg-cst-ctp-cod    not  = zero
                     go to agg-cst-ctp-200
           else      go to agg-cst-ctp-300.
       agg-cst-ctp-200.
      *                  *---------------------------------------------*
      *                  * Caso in cui abbia una contropartita propria *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento riga castelletto contro-  *
      *                      * partite                                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-cst-ctp-ctr      .
       agg-cst-ctp-220.
           add       1                    to   w-agg-cst-ctp-ctr      .
           if        w-agg-cst-ctp-ctr    >    20
                     move  20             to   w-agg-cst-ctp-ctr
                     go to agg-cst-ctp-260.
           if        w-pie-ctp-cod        
                    (1, w-agg-cst-ctp-ctr)
                                          =    zero
                     go to agg-cst-ctp-240.
           if        w-agg-cst-ctp-cod    =    w-pie-ctp-cod
                                              (1, w-agg-cst-ctp-ctr)
                     go to agg-cst-ctp-260.
           go to     agg-cst-ctp-220.
       agg-cst-ctp-240.
           add       1                    to   w-pie-ctp-ele (1)      .
           move      w-agg-cst-ctp-cod    to   w-pie-ctp-cod
                                              (1, w-agg-cst-ctp-ctr)  .
       agg-cst-ctp-260.
           add       w-agg-cst-ctp-imp    to   w-pie-ctp-imp
                                              (1, w-agg-cst-ctp-ctr)  .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     agg-cst-ctp-999.
       agg-cst-ctp-300.
      *                  *---------------------------------------------*
      *                  * Caso in cui debba essere sventagliato sul   *
      *                  * castelletto contropartite gia' esistente    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione del numero di elementi   *
      *                      * presenti in castelletto contropartite e *
      *                      * del totale                              *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-cst-ctp-tot      .
           move      zero                 to   w-agg-cst-ctp-ctr      .
       agg-cst-ctp-320.
           add       1                    to   w-agg-cst-ctp-ctr      .
           if        w-pie-ctp-cod        
                    (1, w-agg-cst-ctp-ctr)
                                          =    zero
                     go to agg-cst-ctp-330.
           add       w-pie-ctp-imp
                    (1, w-agg-cst-ctp-ctr)
                                          to   w-agg-cst-ctp-tot      .
           go to     agg-cst-ctp-320.
       agg-cst-ctp-330.
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero elementi in ca-   *
      *                      * stelletto contropartite                 *
      *                      *-----------------------------------------*
           move      w-agg-cst-ctp-ctr    to   w-agg-cst-ctp-max      .
      *                      *-----------------------------------------*
      *                      * Ciclo di aggiornamento castelletto con- *
      *                      * tropartite fino all'elemento            *
      *                      * w-agg-cst-ctp-max escluso               *
      *                      *-----------------------------------------*
           move      zero                 to   w-agg-cst-ctp-wpa      .
           move      zero                 to   w-agg-cst-ctp-ctr      .
       agg-cst-ctp-340.
           add       1                    to   w-agg-cst-ctp-ctr      .
           if        w-agg-cst-ctp-ctr    =    w-agg-cst-ctp-max
                     go to agg-cst-ctp-360.
      *                          *-------------------------------------*
      *                          * Determinazione porzione sconto in   *
      *                          * chiusura relativa alla riga di ca-  *
      *                          * stelletto contropartite             *
      *                          *-------------------------------------*
           multiply  w-agg-cst-ctp-imp    by   w-pie-ctp-imp
                                              (1, w-agg-cst-ctp-ctr)
                                        giving w-agg-cst-ctp-s18      .
           divide    w-agg-cst-ctp-tot    into w-agg-cst-ctp-s18
                                       rounded                        .
           add       w-agg-cst-ctp-s18    to   w-pie-ctp-imp
                                              (1, w-agg-cst-ctp-ctr)  .
           add       w-agg-cst-ctp-s18    to   w-agg-cst-ctp-wpa      .
           go to     agg-cst-ctp-340.
       agg-cst-ctp-360.
      *                      *-----------------------------------------*
      *                      * Trattamento ultimo elemento castelletto *
      *                      *-----------------------------------------*
           subtract  w-agg-cst-ctp-wpa    from w-agg-cst-ctp-imp
                                        giving w-agg-cst-ctp-s11      .
           add       w-agg-cst-ctp-s11    to   w-pie-ctp-imp
                                              (1, w-agg-cst-ctp-max)  .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     agg-cst-ctp-999.
       agg-cst-ctp-999.
           exit.

      *    *===========================================================*
      *    * Controllo tipo riga                                       *
      *    *-----------------------------------------------------------*
       ctl-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-tip-rig-flg      .
      *              *-------------------------------------------------*
      *              * Test che non ci siano blanks embedded           *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-tri    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Controllo se ci sono asterischi                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-tip-rig-inx      .
           inspect   w-ctl-tip-rig-tri
                                      tallying w-ctl-tip-rig-inx
                                          for  all "*"                .
      *               *------------------------------------------------*
      *               * Deviazione in funzione del numero di asterischi*
      *               * trovati                                        *
      *               *------------------------------------------------*
           if        w-ctl-tip-rig-inx    =    zero
                     go to ctl-tip-rig-200
           else if   w-ctl-tip-rig-inx    =    1
                     go to ctl-tip-rig-100
           else      go to ctl-tip-rig-900.
       ctl-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se c'e' un asterisco                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sostituzione con carattere spazio           *
      *                  *---------------------------------------------*
           inspect   w-ctl-tip-rig-tri
                                     replacing all "*" by   spaces    .
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-ctl-tip-rig-tri    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to ctl-tip-rig-900.
      *                  *---------------------------------------------*
      *                  * Segnale di presenza di asterisco            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-rig-tip-rig-ast (1)  .
      *                  ***********************************************
      *                  * Non essendo ancora attivata la gestione a   *
      *                  * blocchi, la presenza dell'asterisco viene   *
      *                  * considerata errore                          *
      *                  ***********************************************
           go to     ctl-tip-rig-900.
       ctl-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Test se valore ammesso                          *
      *              *-------------------------------------------------*
           if        w-ctl-tip-rig-tri    not  = "P    " and
                     w-ctl-tip-rig-tri    not  = "PN   " and
                     w-ctl-tip-rig-tri    not  = "M    " and
                     w-ctl-tip-rig-tri    not  = "V    " and
                     w-ctl-tip-rig-tri    not  = "C    " and
                     w-ctl-tip-rig-tri    not  = "A    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Se gestione materie prime non attiva : il tipo  *
      *              * riga non puo' essere 'M'                        *
      *              *-------------------------------------------------*
           if        w-prs-dpm-snx        not  = "S"   and
                     w-ctl-tip-rig-tri    =    "M    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Se gestione materialmi vari non attiva : il ti- *
      *              * po riga non puo' essere 'V'                     *
      *              *-------------------------------------------------*
           if        w-prs-mtv-snx        not  = "S"   and
                     w-ctl-tip-rig-tri    =    "V    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo riga                        *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (1)
                                          to   w-rig-tip-rig-tpr (1)  .
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo funzionamento               *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (2)
                                          to   w-rig-tip-rig-tfu (1)  .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-tip-rig-999.
       ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita con errore                               *
      *              *-------------------------------------------------*
           move      "#"                  to   w-ctl-tip-rig-flg      .
       ctl-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Controllo codice iva                                      *
      *    *-----------------------------------------------------------*
       ctl-cod-iva-000.
      *              *-------------------------------------------------*
      *              * Controllo                                       *
      *              *-------------------------------------------------*
           move      "CT"                 to   d-imp-iva-tip-ope      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
       ctl-cod-iva-999.
           exit.

      *    *===========================================================*
      *    * Routine di composizione tipo riga                         *
      *    *                                                           *
      *    * Input  : w-rig-tip-rig (1) e relativi valori di w-rig con-*
      *    *          nessi                                            *
      *    *                                                           *
      *    * Output : rf-bfr-tip-rig                                   *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       cmp-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione puntatore per string           *
      *              *-------------------------------------------------*
           move      01                   to   w-cmp-tip-rig-pnt      .
      *              *-------------------------------------------------*
      *              * Tipo riga                                       *
      *              *-------------------------------------------------*
           move      w-rig-tip-rig-tpr (1)
                                          to   rf-bfr-tip-rig         .
      *              *-------------------------------------------------*
      *              * Tipo funzionamento                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se a spazi : oltre                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    spaces
                     go to cmp-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * String del tipo funzionamento               *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-tip-rig-pnt      .
           string    w-rig-tip-rig-tfu (1)
                                delimited by   spaces
                                          into rf-bfr-tip-rig
                                  with pointer w-cmp-tip-rig-pnt      .
       cmp-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Codice addebito o commento                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se tipo riga 'A' o 'C'                 *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "C"
                     go to cmp-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Se codice addebito o commento a zero : oltre*
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    zero
                     go to cmp-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Editing codice addebito o commento          *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * String codice addebito o commento           *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-tip-rig-pnt      .
           string    v-edt      delimited by   spaces
                                          into rf-bfr-tip-rig
                                  with pointer w-cmp-tip-rig-pnt      .
       cmp-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Asterisco                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non presente : oltre                     *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-ast (1)
                                          =    spaces
                     go to cmp-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * String asterisco                            *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-tip-rig-pnt      .
           string    "*"        delimited by   size
                                          into rf-bfr-tip-rig
                                  with pointer w-cmp-tip-rig-pnt      .
       cmp-tip-rig-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cmp-tip-rig-999.
       cmp-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di decomposizione tipo riga                       *
      *    *                                                           *
      *    * Input  : rf-bfr-tip-rig                                   *
      *    *                                                           *
      *    * Output : w-rig-tip-rig (1) e relativi valori di w-rig con-*
      *    *          nessi                                            *
      *    *-----------------------------------------------------------*
       dec-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Tipo riga in comodo di lavoro ridefinito        *
      *              *-------------------------------------------------*
           move      rf-bfr-tip-rig       to    w-dec-tip-rig-str     .
      *              *-------------------------------------------------*
      *              * Normalizzazione area di w-rig relativa al tipo  *
      *              * riga                                            *
      *              *-------------------------------------------------*
           move      spaces               to    w-rig-tip-rig (1)     .
           move      spaces               to    w-rig-tip-rig-tpr (1) .
           move      spaces               to    w-rig-tip-rig-tfu (1) .
           move      zero                 to    w-rig-tip-rig-cac (1) .
           move      spaces               to    w-rig-tip-rig-ast (1) .
      *              *-------------------------------------------------*
      *              * Presenza o assenza dell'asterisco               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ispezione stringa                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-dec-tip-rig-inx      .
           inspect   w-dec-tip-rig-str
                                      tallying w-dec-tip-rig-inx
                                          for  all "*"                .
      *                  *---------------------------------------------*
      *                  * Se nessun asterisco trovato : oltre         *
      *                  *---------------------------------------------*
           if        w-dec-tip-rig-inx    =    zero
                     go to dec-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Segnale di presenza asterisco               *
      *                  *---------------------------------------------*
           move      "#"                  to   w-rig-tip-rig-ast (1)  .
      *                  *---------------------------------------------*
      *                  * Pulizia stringa da asterisco                *
      *                  *---------------------------------------------*
           inspect   w-dec-tip-rig-str
                                     replacing all "*" by   spaces    .
       dec-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo riga                        *
      *              *-------------------------------------------------*
           move      w-dec-tip-rig-chr (1)
                                          to   w-rig-tip-rig-tpr (1)  .
      *              *-------------------------------------------------*
      *              * Test se esiste un tipo funzionamento            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo per tipi riga P o L                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "L"
                     go to dec-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Se secondo carattere della stringa a spazi :*
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-dec-tip-rig-chr (2)
                                          =    spaces
                     go to dec-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Memorizzazione tipo funzionamento           *
      *                  *---------------------------------------------*
           move      w-dec-tip-rig-chr (2)
                                          to   w-rig-tip-rig-tfu (1)  .
       dec-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Ricerca di un codice addebito o commento        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se tipo riga A o C                     *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "C"
                     go to dec-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione stringa a ritroso        *
      *                  *---------------------------------------------*
           move      zero                 to   w-dec-tip-rig-cod      .
           move      6                    to   w-dec-tip-rig-c01      .
           move      3                    to   w-dec-tip-rig-c02      .
       dec-tip-rig-210.
           subtract  1                    from w-dec-tip-rig-c01      .
           if        w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   =    w-rig-tip-rig-tpr (1)
                     go to dec-tip-rig-220.
           if        w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   =    spaces or
                     w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   <    "0"    or
                     w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   >    "9"
                     go to dec-tip-rig-210.
           move      w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   to   w-dec-tip-rig-num
                                              (w-dec-tip-rig-c02)     .
           subtract  1                    from w-dec-tip-rig-c02      .
           go to     dec-tip-rig-210.
       dec-tip-rig-220.
           move      w-dec-tip-rig-cod    to   w-rig-tip-rig-cac (1)  .
       dec-tip-rig-300.
      *              *-------------------------------------------------*
      *              * Preparazione stringa tipo riga per accettazione *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione puntatore per string       *
      *                  *---------------------------------------------*
           move      01                   to   w-dec-tip-rig-pnt      .
      *                  *---------------------------------------------*
      *                  * Tipo riga                                   *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig-tpr (1)
                                          to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se a spazi : oltre                      *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    spaces
                     go to dec-tip-rig-320.
      *                      *-----------------------------------------*
      *                      * String del tipo funzionamento           *
      *                      *-----------------------------------------*
           add       1                    to   w-dec-tip-rig-pnt      .
           string    w-rig-tip-rig-tfu (1)
                                delimited by   spaces
                                          into w-rig-tip-rig (1) 
                                  with pointer w-dec-tip-rig-pnt      .
       dec-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Asterisco                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non presente : oltre                 *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-ast (1)
                                          =    spaces
                     go to dec-tip-rig-400.
      *                      *-----------------------------------------*
      *                      * String asterisco                        *
      *                      *-----------------------------------------*
           add       1                    to   w-dec-tip-rig-pnt      .
           string    "*"        delimited by   size
                                          into w-rig-tip-rig (1) 
                                  with pointer w-dec-tip-rig-pnt      .
       dec-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     dec-tip-rig-999.
       dec-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di visualizzazione note durante l'impostazione    *
      *    * delle righe documento                                     *
      *    *-----------------------------------------------------------*
       vis-not-rgd-000.
      *              *-------------------------------------------------*
      *              * Se personalizzazione indica, nessuna visualiz-  *
      *              * zazione : uscita                                *
      *              *-------------------------------------------------*
           if        w-prs-tvn-rgd        =    zero
                     go to vis-not-rgd-999.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo operazione ri-    *
      *              * chiesto                                         *
      *              *-------------------------------------------------*
           if        w-vis-not-rgd-top    =    "NO"
                     go to vis-not-rgd-100
           else if   w-vis-not-rgd-top    =    "PM"
                     go to vis-not-rgd-200
           else if   w-vis-not-rgd-top    =    "NT"
                     go to vis-not-rgd-300
           else      go to vis-not-rgd-999.
       vis-not-rgd-100.
      *              *-------------------------------------------------*
      *              * Tipo operazione richiesto : Abblencamento area  *
      *              * note                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Abblencamento totale area note              *
      *                  *---------------------------------------------*
           move      spaces               to   v-not                  .
      *                  *---------------------------------------------*
      *                  * A visualizzazione note operative            *
      *                  *---------------------------------------------*
           go to     vis-not-rgd-900.
       vis-not-rgd-200.
      *              *-------------------------------------------------*
      *              * Tipo operazione richiesto : Visualizzazione dei *
      *              * soli prompts                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga; se non superato si   *
      *                      * procede con l'abblencamento note        *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"   or
                     w-rig-tip-rig-tpr (1)
                                          =    "C"   or
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   or
                     w-cat-rig-new        not  = spaces
                     go to vis-not-rgd-100.
       vis-not-rgd-210.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo visualizza-   *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-prs-tvn-rgd        =   11
                     go to vis-not-rgd-220
           else      go to vis-not-rgd-999.
       vis-not-rgd-220.
      *                  *---------------------------------------------*
      *                  * Se tipo visualizzazione : 11                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione prima riga                 *
      *                      *-----------------------------------------*
           move      "Ns. ordine        :"
                                          to   v-nt1                  .
      *                      *-----------------------------------------*
      *                      * Composizione seconda riga               *
      *                      *-----------------------------------------*
           move      "Fattura           :"
                                          to   v-nt2                  .
      *                      *-----------------------------------------*
      *                      * A visualizzazione note operative        *
      *                      *-----------------------------------------*
           go to     vis-not-rgd-280.
       vis-not-rgd-280.
      *                  *---------------------------------------------*
      *                  * A visualizzazione note operative            *
      *                  *---------------------------------------------*
           go to     vis-not-rgd-900.
       vis-not-rgd-300.
      *              *-------------------------------------------------*
      *              * Tipo operazione richiesto : Visualizzazione no- *
      *              * te complete                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A" or
                     w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to vis-not-rgd-999.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo visualizza-   *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-prs-tvn-rgd        =   11
                     go to vis-not-rgd-400
           else      go to vis-not-rgd-999.
       vis-not-rgd-400.
      *                  *---------------------------------------------*
      *                  * Se tipo visualizzazione : 11                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test preliminare se presenti riferimen- *
      *                      * ti ordine fornitore                     *
      *                      *-----------------------------------------*
           if        w-rig-orf-num (1)    =    zero   and
                     w-rig-orf-dat (1)    =    zero
                     move  spaces         to   v-nt1
                     go to vis-not-rgd-450.
       vis-not-rgd-410.
      *                      *-----------------------------------------*
      *                      * Composizione prima riga                 *
      *                      *-----------------------------------------*
           move      w-rig-orf-num (1)    to   w-num-prt-num-num      .
      *                      *-----------------------------------------*
      *                      * Editing ns. numero conferma ordine      *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-num-prt-num-prg    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (3)      .
      *                      *-----------------------------------------*
      *                      * Editing ns. data conferma ordine        *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-rig-orf-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (5)      .
      *                      *-----------------------------------------*
      *                      * Concatenamento ns. numero conferma      *
      *                      *-----------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      "Ns. ordine        :"
                                          to   w-all-str-cat (1)      .
           move      w-rig-orf-tip (1)    to   w-all-str-cat (2)      .
      *
           if        w-rig-orf-dat (1)    =    zero
                     move  spaces         to   w-all-str-cat (4)
           else      move  "del"          to   w-all-str-cat (4)      .
      *
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione prima riga composta     *
      *                      *-----------------------------------------*
           move      w-all-str-alf        to   v-nt1                  .
       vis-not-rgd-450.
      *                      *-----------------------------------------*
      *                      * Test preliminare se riga bolla fattura- *
      *                      * ta                                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Start su file [ffr]                 *
      *                          *-------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFBFO    "         to   f-key                  .
           move      w-tes-cod-dpz        to   rf-ffr-cod-dpz         .
           move      w-tes-num-prt        to   rf-ffr-bfo-prt         .
           move      w-rig-num-prg (1)    to   rf-ffr-bfo-prg         .
           move      zero                 to   rf-ffr-num-prt         .
           move      zero                 to   rf-ffr-num-prg         .
           move      "pgm/ffo/fls/ioc/obj/iofffr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
