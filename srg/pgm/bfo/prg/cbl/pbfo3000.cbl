      *    * nitore                                                    *
      *    *-----------------------------------------------------------*
       acc-cod-tmb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb        not  = spaces
                     go to acc-cod-tmb-100.
      *                  *---------------------------------------------*
      *                  * Preparazione e visualizzazione default      *
      *                  *---------------------------------------------*
           move      w-def-cod-tmb        to   w-tes-cod-tmb          .
           move      w-def-cod-tmb-des    to   w-tes-cod-tmb-des      .
           perform   vis-cod-tmb-des-000  thru vis-cod-tmb-des-999    .
       acc-cod-tmb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-ybf-ope      .
           move      w-tes-cod-tmb        to   w-cod-des-ybf-cod      .
           move      05                   to   w-cod-des-ybf-lin      .
           move      22                   to   w-cod-des-ybf-pos      .
           move      05                   to   w-cod-des-ybf-dln      .
           move      28                   to   w-cod-des-ybf-dps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-ybf-cll-000  thru cod-des-ybf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-ybf-foi-000  thru cod-des-ybf-foi-999    .
       acc-cod-tmb-110.
           perform   cod-des-ybf-cll-000  thru cod-des-ybf-cll-999    .
           if        w-cod-des-ybf-ope    =    "F+"
                     go to acc-cod-tmb-115.
           if        w-cod-des-ybf-ope    =    "AC"
                     go to acc-cod-tmb-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-tmb-115.
           perform   cod-des-ybf-foi-000  thru cod-des-ybf-foi-999    .
           go to     acc-cod-tmb-110.
       acc-cod-tmb-120.
           move      w-cod-des-ybf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-tmb-999.
       acc-cod-tmb-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-tmb          .
       acc-cod-tmb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmb        to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-cod-tmb-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [ybf] generale             *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmb        to   w-let-arc-ybf-cod      .
           move      zero                 to   w-let-arc-ybf-dpz      .
           perform   let-arc-ybf-000      thru let-arc-ybf-999        .
           move      w-let-arc-ybf-des    to   w-tes-cod-tmb-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-tmb-des-000  thru vis-cod-tmb-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-ybf-flg    not  = spaces
                     go to acc-cod-tmb-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione, a meno *
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb        not  = spaces
                     go to acc-cod-tmb-405.
           if        v-key                =    "UP  "
                     go to acc-cod-tmb-405
           else      go to acc-cod-tmb-100.
       acc-cod-tmb-405.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori associati al tipo    *
      *                  * movimento                                   *
      *                  *---------------------------------------------*
           move      w-let-arc-ybf-mif    to   w-tes-cod-tmb-mif      .
           move      w-let-arc-ybf-tmf    to   w-tes-cod-tmb-tmf      .
           move      w-let-arc-ybf-cam    to   w-tes-cod-tmb-cam      .
           move      w-let-arc-ybf-ctm    to   w-tes-cod-tmb-ctm      .
           move      w-let-arc-ybf-dfa    to   w-tes-cod-tmb-dfa      .
           move      w-let-arc-ybf-vaa    to   w-tes-cod-tmb-vaa      .
           move      w-let-arc-ybf-lsa    to   w-tes-cod-tmb-lsa      .
           move      w-let-arc-ybf-ord    to   w-tes-cod-tmb-ord      .
           move      w-let-arc-ybf-prd    to   w-tes-cod-tmb-prd      .
           move      w-let-arc-ybf-maf    to   w-tes-cod-tmb-maf      .
           move      w-let-arc-ybf-dmf    to   w-tes-cod-tmb-dmf      .
           move      w-let-arc-ybf-tvd    to   w-tes-cod-tmb-tvd      .
           move      w-let-arc-ybf-dsl    to   w-tes-cod-tmb-ddd      .
           move      w-let-arc-ybf-dtr    to   w-tes-cod-tmb-dtr      .
      *                  *---------------------------------------------*
      *                  * Lettura archivio [ybf] relativo alla dipen- *
      *                  * denza                                       *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmb        to   w-let-arc-ybf-cod      .
           move      w-tes-cod-dpz        to   w-let-arc-ybf-dpz      .
           perform   let-arc-ybf-000      thru let-arc-ybf-999        .
       acc-cod-tmb-410.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo validita'   *
      *                  * per le dipendenze                           *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-tvd    =    spaces
                     go to acc-cod-tmb-411
           else if   w-tes-cod-tmb-tvd    =    "S"
                     go to acc-cod-tmb-412
           else if   w-tes-cod-tmb-tvd    =    "D"
                     go to acc-cod-tmb-413
           else if   w-tes-cod-tmb-tvd    =    "X"
                     go to acc-cod-tmb-414.
       acc-cod-tmb-411.
      *                  *---------------------------------------------*
      *                  * Tipo validita' per le dipendenze : Tutte    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-tmb-420.
       acc-cod-tmb-412.
      *                  *---------------------------------------------*
      *                  * Tipo validita' per le dipendenze : Solo la  *
      *                  * Sede                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza in uso        *
      *                      *-----------------------------------------*
           if        w-tes-cod-dpz       not  = 1
                     go to acc-cod-tmb-418.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-tmb-420.
       acc-cod-tmb-413.
      *                  *---------------------------------------------*
      *                  * Tipo validita' per le dipendenze : Solo le  *
      *                  * Dipendenze                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza in uso        *
      *                      *-----------------------------------------*
           if        w-tes-cod-dpz       =    1
                     go to acc-cod-tmb-418.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-tmb-420.
       acc-cod-tmb-414.
      *                  *---------------------------------------------*
      *                  * Tipo validita' per le dipendenze : Solo le  *
      *                  * Dipendenze indicate                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se record esistente                *
      *                      *-----------------------------------------*
           if        w-let-arc-ybf-flg    not  = spaces
                     go to acc-cod-tmb-418.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-tmb-420.
       acc-cod-tmb-418.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Tipo movimento incompatibile con la dipendenza in 
      -              "uso !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-cod-tmb-100.
       acc-cod-tmb-420.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice dislocazione         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record esistente si bufferizza il    *
      *                      * codice dislocazione in esso contenuto,  *
      *                      * altrimenti si bufferizza quello di de-  *
      *                      * fault                                   *
      *                      *-----------------------------------------*
           if        w-let-arc-ybf-flg    =    spaces
                     move  w-let-arc-ybf-dsl
                                          to   w-tes-cod-tmb-dsl
           else      move  w-tes-cod-tmb-ddd
                                          to   w-tes-cod-tmb-dsl      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo movimento per fattura  *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmb-tmf    to   w-tes-tmo-ftr          .
       acc-cod-tmb-500.
      *                  *---------------------------------------------*
      *                  * Parametri associati alla causale di magaz-  *
      *                  * zino                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa il ma-   *
      *                      * gazzino : oltre                         *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmb-cam    =    zero
                     go to acc-cod-tmb-600.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zmc]                  *
      *                      *-----------------------------------------*
           move      w-tes-cod-tmb-cam    to   w-let-arc-zmc-cod      .
           perform   let-arc-zmc-000      thru let-arc-zmc-999        .
           if        w-let-arc-zmc-flg    =    spaces
                     go to acc-cod-tmb-520.
      *                      *-----------------------------------------*
      *                      * Se il record relativo alla causale di   *
      *                      * magazzino non e' stato trovato          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Causale di magazzino associata non esistente !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-cod-tmb-100.
       acc-cod-tmb-520.
      *                      *-----------------------------------------*
      *                      * Controllo causale di magazzino          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Trattamento valore                  *
      *                          *-------------------------------------*
           if        w-let-arc-zmc-trv    not  = "C" and
                     w-let-arc-zmc-trv    not  = "X" and
                     w-let-arc-zmc-trv    not  = "R" and
                     w-let-arc-zmc-trv    not  = "Y"
                     go to acc-cod-tmb-530.
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "Trattamento valore della causale di magazzino erra
      -              "to             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                              *---------------------------------*
      *                              * A reimpostazione                *
      *                              *---------------------------------*
           go to     acc-cod-tmb-100.
       acc-cod-tmb-530.
      *                          *-------------------------------------*
      *                          * Tipo movimento di magazzino         *
      *                          *-------------------------------------*
           if        w-let-arc-zmc-tip    =    01
                     go to acc-cod-tmb-540.
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "La causale di magazzino associata non e' di 'Caric
      -              "o'             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                              *---------------------------------*
      *                              * Comunque oltre                  *
      *                              *---------------------------------*
           go to     acc-cod-tmb-540.
       acc-cod-tmb-540.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori                  *
      *                      *-----------------------------------------*
           move      w-let-arc-zmc-tmc    to   w-tes-cod-tmb-cam-tmc  .
           move      w-let-arc-zmc-dtm    to   w-tes-cod-tmb-cam-dtm  .
           move      w-let-arc-zmc-vtm    to   w-tes-cod-tmb-cam-vtm  .
           move      w-let-arc-zmc-ltm    to   w-tes-cod-tmb-cam-ltm  .
       acc-cod-tmb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-tmb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cod-tmb-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cod-tmb-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cod-tmb-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cod-tmb-999.
       acc-cod-tmb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : tipo movimento per la bolla*
      *    *-----------------------------------------------------------*
       vis-cod-tmb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-tes-cod-tmb        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-tmb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : descrizione tipo movimento *
      *    *-----------------------------------------------------------*
       vis-cod-tmb-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-tes-cod-tmb-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-tmb-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campi non chiave della registrazione         *
      *    *-----------------------------------------------------------*
       acc-nok-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-nok      .
      *              *-------------------------------------------------*
      *              * Visualizzazione tipo funzionamento              *
      *              *-------------------------------------------------*
           perform   vis-tip-fun-000      thru vis-tip-fun-999        .
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione se in modi- *
      *              * fica o visualizzazione, per testata, corpo e    *
      *              * piede                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M" or
                     w-cnt-mfu-tip-fun    =    "V"
                     move  "#"            to   w-cnt-sts-imp-tes
                     move  all "#"        to   w-cnt-sts-imp-pte
                     move  all "#"        to   w-cnt-sts-ing-pte
                     move  "#"            to   w-cnt-sts-imp-cor
                     move  "#"            to   w-cnt-sts-imp-pie
                     move  all "#"        to   w-cnt-sts-imp-ppi
                     move  all "#"        to   w-cnt-sts-ing-ppi      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di funzionamento testata   *
      *              * con Tab                                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-mfu-fky-tab      .
       acc-nok-reg-200.
      *              *-------------------------------------------------*
      *              * Trattamento testata                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del numero di pagine che     *
      *                  * compongono la testata                       *
      *                  *---------------------------------------------*
           perform   dmp-tes-reg-000      thru dmp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione titolo programma            *
      *                  *---------------------------------------------*
           perform   vis-tit-pgm-000      thru vis-tit-pgm-999        .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-cor      
                                               w-cnt-sts-vis-cor      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo             *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rig      
                                               w-cnt-sts-vis-rig      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati piede                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-pie
                                               w-cnt-sts-pmt-ppi
                                               w-cnt-sts-vis-pie
                                               w-cnt-sts-vis-ppi      .
      *                  *---------------------------------------------*
      *                  * Prompts per campi chiave                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-key    =    spaces
                     perform pmt-key-reg-000
                                          thru pmt-key-reg-999
                     move    "#"          to   w-cnt-sts-pmt-key      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati campi chiave           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-key    =    spaces
                     perform vis-key-reg-000
                                          thru vis-key-reg-999
                     move    "#"          to   w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Prompts per pagina di testata               *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-ptx
                    (w-cnt-sts-imp-npt)   =    spaces
                     perform pmt-tes-reg-000
                                          thru pmt-tes-reg-999
                     move    "#"          to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati pagina testata         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"      or
                     w-cnt-mfu-tip-fun    =    "V"      or
                     w-cnt-sts-imp-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces or
                     w-cnt-sts-ing-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces
                     if    w-cnt-sts-vis-ptx
                          (w-cnt-sts-imp-npt)
                                          =    spaces
                           perform vis-tes-reg-000
                                          thru vis-tes-reg-999
                           move    "#"    to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Flag di ingresso in pagina di testata       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati testata                   *
      *                  *---------------------------------------------*
           perform   acc-tes-reg-000      thru acc-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "S" or
                     w-cnt-tus-acc-tes    =    "X" or
                     w-cnt-tus-acc-tes    =    "E"
                     move  w-cnt-tus-acc-tes
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se spostamento di pagina                    *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "-"
                     go to acc-nok-reg-225
           else      go to acc-nok-reg-250.
       acc-nok-reg-225.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' 1 si ignora *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  > 1
                     go to acc-nok-reg-200.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della chiave a : no            *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      .
           move      spaces               to   w-cnt-sts-vis-key      .
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina attuale a : no    *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
           move      spaces               to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
       acc-nok-reg-230.
      *                          *-------------------------------------*
      *                          * Decremento numero pagina attuale    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-sts-imp-npt      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : decremento ulteriore        *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces and
                     w-cnt-sts-imp-npt    >    1
                     go to acc-nok-reg-230.
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione testata     *
      *                          *-------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-250.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina successiva      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio numero pagina attuale   *
      *                          *-------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-nok-reg-260.
      *                          *-------------------------------------*
      *                          * Status di impostazione dati della   *
      *                          * della pagina attuale a : si'        *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si pone lo status di impostazione   *
      *                          * dati generale testata a si'         *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  "#"            to   w-cnt-sts-imp-tes      .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si va' ad accettazione corpo        *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-nok-reg-300.
      *                          *-------------------------------------*
      *                          * Incremento numero pagina attuale    *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : a re-incremento             *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-nok-reg-260.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della chiave a : no            *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      .
           move      spaces               to   w-cnt-sts-vis-key      .
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina impostata a : no  *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-svp)     .
           move      spaces               to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-svp)     .
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione testata     *
      *                          *-------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-300.
      *                  *---------------------------------------------*
      *                  * Numero riga corpo da accettare : 1          *
      *                  *---------------------------------------------*
           move       1                   to   w-cnt-cor-nrg-dac      .
       acc-nok-reg-400.
      *              *-------------------------------------------------*
      *              * Trattamento corpo                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione titolo programma            *
      *                  *---------------------------------------------*
           perform   vis-tit-pgm-000      thru vis-tit-pgm-999        .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati chiave                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      
                                               w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati testata                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-tes
                                               w-cnt-sts-pmt-pte
                                               w-cnt-sts-vis-tes
                                               w-cnt-sts-vis-pte      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati piede                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-pie
                                               w-cnt-sts-pmt-ppi
                                               w-cnt-sts-vis-pie
                                               w-cnt-sts-vis-ppi      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati corpo                     *
      *                  *---------------------------------------------*
           perform   acc-cor-reg-000      thru acc-cor-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-cor    =    "S" or
                     w-cnt-tus-acc-cor    =    "X" or
                     w-cnt-tus-acc-cor    =    "E"
                     move  w-cnt-tus-acc-cor
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se tipo uscita "-"                          *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-cor    =    "-"
                     go to acc-nok-reg-200.
       acc-nok-reg-600.
      *              *-------------------------------------------------*
      *              * Trattamento piede                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Routine pre-trattamento piede               *
      *                  *---------------------------------------------*
           perform   pre-pie-reg-000      thru pre-pie-reg-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione del numero di pagine che     *
      *                  * compongono il piede                         *
      *                  *---------------------------------------------*
           perform   dmp-pie-reg-000      thru dmp-pie-reg-999        .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati chiave                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      
                                               w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati testata                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-tes
                                               w-cnt-sts-pmt-pte
                                               w-cnt-sts-vis-tes
                                               w-cnt-sts-vis-pte      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati corpo                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-cor      
                                               w-cnt-sts-vis-cor      .
      *                  *---------------------------------------------*
      *                  * Assestamento flags di controllo visualizza- *
      *                  * zione prompts e dati riga corpo             *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-rig      
                                               w-cnt-sts-vis-rig      .
      *                  *---------------------------------------------*
      *                  * Test se pagina piede da trattare            *
      *                  *---------------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a incremento numero pagina piede    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snx    not  = spaces
                     go to acc-nok-reg-650.
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione titolo programma            *
      *                  *---------------------------------------------*
           perform   vis-tit-pgm-000      thru vis-tit-pgm-999        .
      *                  *---------------------------------------------*
      *                  * Prompts per pagina piede                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-ppx
                    (w-cnt-sts-imp-npp)   =    spaces
                     perform pmt-pie-reg-000
                                          thru pmt-pie-reg-999
                     move    "#"          to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati pagina piede           *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"      or
                     w-cnt-mfu-tip-fun    =    "V"      or
                     w-cnt-sts-imp-ppx
                    (w-cnt-sts-imp-npp)   not  = spaces or
                     w-cnt-sts-ing-ppx
                    (w-cnt-sts-imp-npp)   not  = spaces
                     if    w-cnt-sts-vis-ppx
                          (w-cnt-sts-imp-npp)
                                          =    spaces
                           perform vis-pie-reg-000
                                          thru vis-pie-reg-999
                           move    "#"    to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Flag di ingresso in pagina piede            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati piede                     *
      *                  *---------------------------------------------*
           perform   acc-pie-reg-000      thru acc-pie-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-pie    =    "S" or
                     w-cnt-tus-acc-pie    =    "X" or
                     w-cnt-tus-acc-pie    =    "E"
                     move  w-cnt-tus-acc-pie
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se spostamento di pagina                    *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-pie    =    "-"
                     go to acc-nok-reg-610
           else      go to acc-nok-reg-650.
       acc-nok-reg-610.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' 1 : ad ac-  *
      *                          * cettazione corpo                    *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    >    1
                     go to acc-nok-reg-620.
      *                              *---------------------------------*
      *                              * Nr riga corpo da accettare :    *
      *                              * max + 1                         *
      *                              *---------------------------------*
           move      w-cat-rig-max        to   w-cnt-cor-nrg-dac      .
           if        w-cat-rig-app        =    spaces
                     add   1              to   w-cnt-cor-nrg-dac      .
           go to     acc-nok-reg-400.
       acc-nok-reg-620.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina attuale a : no    *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-npp)     .
           move      spaces               to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-npp)     .
       acc-nok-reg-630.
      *                          *-------------------------------------*
      *                          * Decremento numero pagina attuale    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-sts-imp-npp      .
       acc-nok-reg-640.
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : decremento ulteriore, a me- *
      *                          *         no di non essere a pagina 1 *
      *                          *         caso in cui si va' ad ac-   *
      *                          *         cettazione corpo            *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snx    not  = spaces
                     go to acc-nok-reg-610.
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione piede       *
      *                          *-------------------------------------*
           go to     acc-nok-reg-600.
       acc-nok-reg-650.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina successiva      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio numero pagina attuale   *
      *                          *-------------------------------------*
           move      w-cnt-sts-imp-npp    to   w-cnt-sts-imp-spp      .
       acc-nok-reg-660.
      *                          *-------------------------------------*
      *                          * Status di impostazione dati della   *
      *                          * della pagina attuale a : si'        *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si pone lo status di impostazione   *
      *                          * dati generale piede a si'           *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    not  < w-cnt-sts-imp-mpp
                     move  "#"            to   w-cnt-sts-imp-pie      .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si va' a conferma impostazioni      *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    not  < w-cnt-sts-imp-mpp
                     move  w-cnt-sts-imp-spp
                                          to   w-cnt-sts-imp-npp
                     go to acc-nok-reg-800.
      *                          *-------------------------------------*
      *                          * Incremento numero pagina attuale    *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-sts-imp-npp      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : a re-incremento             *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snx    not  = spaces
                     go to acc-nok-reg-660.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina impostata a : no  *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-spp)     .
           move      spaces               to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-spp)     .
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione piede       *
      *                          *-------------------------------------*
           go to     acc-nok-reg-600.
       acc-nok-reg-800.
      *              *-------------------------------------------------*
      *              * Conferma impostazioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Se attualmente visualizzato il corpo si e-  *
      *                  * segue la visualizzazione dei prompts della  *
      *                  * riga corpo espansa                          *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-cor    =    spaces
                     go to acc-nok-reg-805.
           perform   pmt-rig-cor-000      thru pmt-rig-cor-999        .
       acc-nok-reg-805.
      *                  *---------------------------------------------*
      *                  * Cancellazione eventuali note operative      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-nok-reg-810.
      *                  *---------------------------------------------*
      *                  * Test se sola visualizzazione                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-nok-reg-820
           else      go to acc-nok-reg-830.
       acc-nok-reg-820.
      *                      *-----------------------------------------*
      *                      * Accettazione se sola visualizzazione    *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#VIS"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "E"                  to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "E"
                     move  "EXIT"         to   v-key                  .
           go to     acc-nok-reg-840.
       acc-nok-reg-830.
      *                      *-----------------------------------------*
      *                      * Accettazione se inserimento o modifica  *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "#SAP"         to   v-not
                     move  "SNEP"         to   v-msk
                     move  "DO  "         to   v-pfk (05)
           else      move  "#SAV"         to   v-not
                     move  "SNE"          to   v-msk                  .
           move      spaces               to   v-alf                  .
      *
           move      "UP  "               to   v-pfk (01)             .
      *                          *-------------------------------------*
      *                          * Tasto Print                         *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-mst-flg          .
           if        w-cnt-mst-sel        not  = "S"
                     go to acc-nok-reg-835.
           if        w-cnt-mfu-tip-imp    =    "K"
                     go to acc-nok-reg-835.
           if        w-cnt-mfu-tip-fun    =    "M" or
                     w-cnt-mfu-tip-fun    =    "V"
                     move  "PRNT"         to   v-pfk (18)
                     go to acc-nok-reg-835.
           if        v-pfk (05)           =    "DO  "
                     move  "PRNT"         to   v-pfk (18)             .
       acc-nok-reg-835.
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "E"           to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key
           else if   v-alf                =    "P"
                     move   "PRNT"        to   v-key                  .
       acc-nok-reg-840.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to acc-nok-reg-850
           else if   v-key                =    "EXIT"
                     go to acc-nok-reg-860
           else if   v-key                =    "UP  "
                     go to acc-nok-reg-870
           else if   v-key                =    "PRNT"
                     go to acc-nok-reg-880
           else      go to acc-nok-reg-810.
       acc-nok-reg-850.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-tus-acc-nok      .
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    not  = spaces
                     go to acc-nok-reg-870.
           go to     acc-nok-reg-999.
       acc-nok-reg-860.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine di controllo per Exit        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se Exit non attivato : come 'Up'    *
      *                          *-------------------------------------*
           perform   exe-acc-cmp-exi-000  thru exe-acc-cmp-exi-999    .
           if        w-cnt-acc-flg-exi    not  = spaces
                     go to acc-nok-reg-870.
      *                          *-------------------------------------*
      *                          * Se Exit attivato                    *
      *                          *-------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-nok      .
           go to     acc-nok-reg-999.
       acc-nok-reg-870.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione function-key            *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Se il documento non interessa la fat-   *
      *                      * turazione si va alle righe corpo altri- *
      *                      * menti al piede                          *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-nok-reg-300.
      *                      *-----------------------------------------*
      *                      * Ad accettazione piede                   *
      *                      *-----------------------------------------*
           go to     acc-nok-reg-600.
       acc-nok-reg-880.
      *                  *---------------------------------------------*
      *                  * Se Print                                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-mst-flg          .
      *                      *-----------------------------------------*
      *                      * Se in funzione di 'Visualizzazione' :   *
      *                      * uscita come per 'Exit', altrimenti u-   *
      *                      * scita come per 'Do'                     *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-nok-reg-860
           else      go to acc-nok-reg-850.
       acc-nok-reg-999.
           exit.

      *    *===========================================================*
      *    * Trattamento testata registrazione                         *
      *    *-----------------------------------------------------------*
           copy      "pgm/bfo/prg/cpy/pbfo3000.tes"                   .

      *    *===========================================================*
      *    * Trattamento corpo registrazione                           *
      *    *-----------------------------------------------------------*
           copy      "pgm/bfo/prg/cpy/pbfo3000.cor"                   .

      *    *===========================================================*
      *    * Trattamento piede registrazione                           *
      *    *-----------------------------------------------------------*
           copy      "pgm/bfo/prg/cpy/pbfo3000.pie"                   .

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
      *              *-------------------------------------------------*
      *              * Test su tipo movimento                          *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmb        not  = spaces
                     go to cnt-tdo-key-100.
           move      "Manca il tipo movimento !                         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-100.
      *              *-------------------------------------------------*
      *              * Test su data registrazione                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se mancante                            *
      *                  *---------------------------------------------*
           if        w-tes-dat-reg        not  = zero
                     go to cnt-tdo-key-150.
           move      "Manca la data registrazione !                     
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-150.
      *                  *---------------------------------------------*
      *                  * Se numero protocollo a zero                 *
      *                  *---------------------------------------------*
           if        w-tes-num-prt        not  = zero
                     go to cnt-tdo-key-200.
      *                  *---------------------------------------------*
      *                  * Se causale di magazzino non esistente : ol- *
      *                  * tre                                         *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-cam    =    zero
                     go to cnt-tdo-key-200.
      *                      *-----------------------------------------*
      *                      * Test sulla data di registrazione, che   *
      *                      * non sia inferiore alla data di regi-    *
      *                      * strazione minima di MAG                 *
      *                      *-----------------------------------------*
           if        w-tes-dat-reg        not  < w-gen-dtr-min
                     go to cnt-tdo-key-200.
           move      "Data di registrazione non accettabile !           
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-200.
      *              *-------------------------------------------------*
      *              * Test su sottoconto iva acquisti                 *
      *              *-------------------------------------------------*
           if        w-ref-stc-iac-cod    not  = zero
                     go to cnt-tdo-key-300.
           move      "Sottoconto iva acquisti indeterminato !           
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-300.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       cnt-tdo-key-400.
      *              *-------------------------------------------------*
      *              * Dichiarazione di inizio ciclo evasione ordini   *
      *              * fornitori                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se gestione ordini fornitori attiva    *
      *                  *---------------------------------------------*
           if        w-prs-orf-snx        not  = "S"
                     go to cnt-tdo-key-800.
      *                  *---------------------------------------------*
      *                  * Test se tipo movimento per la bolla lo pre- *
      *                  * vede                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-maf    not  = 02
                     go to cnt-tdo-key-800.
      *                  *---------------------------------------------*
      *                  * Esecuzione                                  *
      *                  *---------------------------------------------*
           move      "DI"                 to   l-eva-orf-tip-ope      .
           move      "pgm/bfo/prg/obj/pbfo300a"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-orf
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
       cnt-tdo-key-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     cnt-tdo-key-999.
       cnt-tdo-key-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
      *              *-------------------------------------------------*
      *              * Test : tipo movimento                           *
      *              *-------------------------------------------------*
           if        w-tes-cod-tmb        =    spaces and
                     w-tes-dat-reg        =    zero   and
                     w-tes-num-prt        =    zero
                     move  "#"            to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
      *              *-------------------------------------------------*
      *              * Controllo su : Coefficiente di cambio           *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to cnt-tdo-nok-010.
           if        w-tes-cdc-vpf (1)    not  = zero
                     go to cnt-tdo-nok-010.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-010.
      *              *-------------------------------------------------*
      *              * Controllo righe del documento                   *
      *              *-------------------------------------------------*
           perform   ctl-rig-doc-000      thru ctl-rig-doc-999        .
           if        w-ctl-rig-doc-flg    not  = spaces
                     go to cnt-tdo-nok-950.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se il tipo movimento inte- *
      *              * ressa la fatturazione o no                      *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to cnt-tdo-nok-100
           else if   w-tes-int-ftr        =    02
                     go to cnt-tdo-nok-200
           else if   w-tes-int-ftr        =    03
                     go to cnt-tdo-nok-300.
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Tipo movimento : non interessa la fatturazione  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessun controllo                            *
      *                  *---------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-200.
      *              *-------------------------------------------------*
      *              * Tipo movimento : da fatturare                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale righe                 *
      *                  *---------------------------------------------*
           perform   det-tot-rig-000      thru det-tot-rig-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione codici iva per piede         *
      *                  *---------------------------------------------*
           perform   det-civ-pie-000      thru det-civ-pie-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totali riepilogo documento   *
      *                  *---------------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                  *---------------------------------------------*
      *                  * Compattamento castelletto iva               *
      *                  *---------------------------------------------*
           perform   cmp-cst-iva-000      thru cmp-cst-iva-999        .
      *                  *---------------------------------------------*
      *                  * Compattamento castelletto contropartite     *
      *                  *---------------------------------------------*
           perform   cmp-cst-ctp-000      thru cmp-cst-ctp-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione inoltro pagamenti           *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    zero
                     move  01             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-300.
      *              *-------------------------------------------------*
      *              * Tipo movimento : e' anche una fattura           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessun controllo, in quanto non sono gesti- *
      *                  * te le fatture accompagnatorie per i forni-  *
      *                  * tori                                        *
      *                  *---------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       cnt-tdo-nok-950.
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo righe del documento                             *
      *    *-----------------------------------------------------------*
       ctl-rig-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-rig-doc-flg      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione risposta da operatore           *
      *              *-------------------------------------------------*
           move      spaces               to    w-ctl-rig-doc-tro     .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to ctl-rig-doc-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to ctl-rig-doc-100.
       ctl-rig-doc-200.
      *              *-------------------------------------------------*
      *              * Richiamo routine di controllo impostazioni su   *
      *              * riga corpo                                      *
      *              *-------------------------------------------------*
           perform   ctl-imp-rig-000      thru ctl-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Se zero errori riscontrati : riciclo su lettura *
      *              * catena                                          *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-ele    =    zero
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer errori                *
      *              *-------------------------------------------------*
           move      zero                 to    w-ctl-imp-rig-ctr     .
       ctl-rig-doc-220.
           add       1                    to    w-ctl-imp-rig-ctr     .
      *                  *---------------------------------------------*
      *                  * Se fine scansione : riciclo su lettura ca-  *
      *                  * tena                                        *
      *                  *---------------------------------------------*
           if        w-ctl-imp-rig-ctr    >     w-ctl-imp-rig-ele
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che si tratti o meno di un *
      *              * errore bloccante                                *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "B"
                     go to ctl-rig-doc-300
           else if   w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "N"
                     go to ctl-rig-doc-400.
       ctl-rig-doc-300.
      *              *-------------------------------------------------*
      *              * Se errore bloccante                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione messaggio completo             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing numero riga                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Errore a riga "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " : "      delimited by   size
                     w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)
                                delimited by   size
                                          into w-err-box-err-msg      .
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ctl-rig-doc-flg      .
      *                  *---------------------------------------------*
      *                  * A uscita                                    *
      *                  *---------------------------------------------*
           go to     ctl-rig-doc-900.
       ctl-rig-doc-400.
      *              *-------------------------------------------------*
      *              * Se errore non bloccante                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se flag di risposta operatore a X : riciclo *
      *                  * su scansione buffer errori                  *
      *                  *---------------------------------------------*
           if        w-ctl-rig-doc-tro    =    "X"
                     go to ctl-rig-doc-220.
       ctl-rig-doc-420.
      *                  *---------------------------------------------*
      *                  * Box di avviso con conferma impostazioni     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Messaggio nel box                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Linea 01                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing numero riga             *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Composizione stringa            *
      *                              *---------------------------------*
           move      spaces               to   v-alf                  .
           string    "Avviso per riga "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " : "      delimited by   size
                     w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)
                                delimited by   size
                                          into v-alf                  .
      *                              *---------------------------------*
      *                              * Visualizzazione stringa         *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Linea 02                            *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      "Si confermano ugualmente le impostazioni (S/N) ? [
      -              " ]"                 to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Accettazione della risposta             *
      *                      *-----------------------------------------*
           move      "S"                  to   v-alf                  .
       ctl-rig-doc-422.
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Set del tipo risposta da operatore      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su function-key impostata      *
      *                          *-------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-key                =    "DO  "
                     move  "X"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-key                =    spaces
                     go to ctl-rig-doc-424
           else      go to ctl-rig-doc-422.
       ctl-rig-doc-424.
      *                          *-------------------------------------*
      *                          * Test su valore impostato se Return  *
      *                          *-------------------------------------*
           if        v-alf                =    "N"
                     move  "N"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-alf                =    "S"
                     move  "S"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else      go to ctl-rig-doc-422.
       ctl-rig-doc-426.
      *                      *-----------------------------------------*
      *                      * Ripristino immagine video               *
      *                      *-----------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       ctl-rig-doc-440.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di risposta *
      *                  * da operatore                                *
      *                  *---------------------------------------------*
           if        w-ctl-rig-doc-tro    =    "N"
                     go to ctl-rig-doc-442
           else if   w-ctl-rig-doc-tro    =    "S"
                     go to ctl-rig-doc-444
           else if   w-ctl-rig-doc-tro    =    "X"
                     go to ctl-rig-doc-446.
       ctl-rig-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : No                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-rig-doc-flg      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-900.
       ctl-rig-doc-444.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : Si                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer errori      *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-220.
       ctl-rig-doc-446.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : Si, e con omissione di   *
      *                  * altri messaggi                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer errori      *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-220.
       ctl-rig-doc-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       ctl-rig-doc-999.
           exit.

      *    *===========================================================*
      *    * Routine di compattamento castelletto iva                  *
      *    *-----------------------------------------------------------*
       cmp-cst-iva-000.
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-cmp-cst-iva-ctr      .
           move      zero                 to   w-cmp-cst-iva-num      .
       cmp-cst-iva-100.
           add       1                    to   w-cmp-cst-iva-ctr      .
           if        w-cmp-cst-iva-ctr    >    w-pie-iva-ele (1)
                     go to cmp-cst-iva-900.
           if        w-cmp-cst-iva-ctr    >    12
                     go to cmp-cst-iva-900.
           if        w-pie-iva-ibl
                    (1, w-cmp-cst-iva-ctr)
                                          =    zero
                     go to cmp-cst-iva-100.
           add       1                    to   w-cmp-cst-iva-num      .
           move      w-pie-iva-cod
                    (1, w-cmp-cst-iva-ctr)
                                          to   w-pie-iva-cod
                                              (1, w-cmp-cst-iva-num)  .
           move      w-pie-iva-ibl
                    (1, w-cmp-cst-iva-ctr)
                                          to   w-pie-iva-ibl
                                              (1, w-cmp-cst-iva-num)  .

           go to     cmp-cst-iva-100.
       cmp-cst-iva-900.
           move      w-cmp-cst-iva-num    to   w-pie-iva-ele (1)      .
       cmp-cst-iva-999.
           exit.

      *    *===========================================================*
      *    * Routine di compattamento castelletto contropartite        *
      *    *-----------------------------------------------------------*
       cmp-cst-ctp-000.
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-cmp-cst-ctp-ctr      .
           move      zero                 to   w-cmp-cst-ctp-num      .
       cmp-cst-ctp-100.
           add       1                    to   w-cmp-cst-ctp-ctr      .
           if        w-cmp-cst-ctp-ctr    >    w-pie-ctp-ele (1)
                     go to cmp-cst-ctp-900.
           if        w-cmp-cst-ctp-ctr    >    20
                     go to cmp-cst-ctp-900.
           if        w-pie-ctp-imp
                    (1, w-cmp-cst-ctp-ctr)
                                          =    zero
                     go to cmp-cst-ctp-100.
           add       1                    to   w-cmp-cst-ctp-num      .
           move      w-pie-ctp-cod
                    (1, w-cmp-cst-ctp-ctr)
                                          to   w-pie-ctp-cod
                                              (1, w-cmp-cst-ctp-num)  .
           move      w-pie-ctp-imp
                    (1, w-cmp-cst-ctp-ctr)
                                          to   w-pie-ctp-imp
                                              (1, w-cmp-cst-ctp-num)  .

           go to     cmp-cst-ctp-100.
       cmp-cst-ctp-900.
           move      w-cmp-cst-ctp-num    to   w-pie-ctp-ele (1)      .
       cmp-cst-ctp-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do riga corpo             *
      *    *-----------------------------------------------------------*
       cnt-tdo-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-100.
      *              *-------------------------------------------------*
      *              * Richiamo routine di controllo impostazioni su   *
      *              * riga corpo                                      *
      *              *-------------------------------------------------*
           perform   ctl-imp-rig-000      thru ctl-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di errori ri-   *
      *              * scontrati                                       *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-ele    =    zero
                     go to cnt-tdo-rig-120
           else      go to cnt-tdo-rig-140.
       cnt-tdo-rig-120.
      *              *-------------------------------------------------*
      *              * Se zero errori riscontrati                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * A normalizzazioni                           *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-200.
       cnt-tdo-rig-140.
      *              *-------------------------------------------------*
      *              * Se riscontrati errori                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer                   *
      *                  *---------------------------------------------*
           move      zero                 to    w-ctl-imp-rig-ctr     .
       cnt-tdo-rig-142.
           add       1                    to    w-ctl-imp-rig-ctr     .
      *                      *-----------------------------------------*
      *                      * Se fine scansione e non sono stati tro- *
      *                      * vati errori Bloccanti : a normalizza-   *
      *                      * zioni                                   *
      *                      *-----------------------------------------*
           if        w-ctl-imp-rig-ctr    >     w-ctl-imp-rig-ele
                     go to cnt-tdo-rig-200.
      *                      *-----------------------------------------*
      *                      * Emissione messaggio                     *
      *                      *-----------------------------------------*
           move      w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)   to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo errore    *
      *                      *-----------------------------------------*
           if        w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "B"
                     go to cnt-tdo-rig-144
           else if   w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "N"
                     go to cnt-tdo-rig-146.
       cnt-tdo-rig-144.
      *                      *-----------------------------------------*
      *                      * Se tipo errore : Bloccante              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A uscita con errore                 *
