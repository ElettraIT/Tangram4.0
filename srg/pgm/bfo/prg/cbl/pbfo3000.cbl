      *                  * mento espresso in [dcf]                     *
      *                  *---------------------------------------------*
           if        rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    03
                     go to det-fun-spe-151
           else if   rf-dcf-snm-spe
                    (w-det-fun-spe-inx)   =    04
                     go to det-fun-spe-152.
