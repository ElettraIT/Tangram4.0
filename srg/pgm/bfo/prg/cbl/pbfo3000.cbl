      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "num-prt"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-arc-bft-sel
                     go to fnd-arc-bft-999.
           move      s-num                to   w-fnd-arc-bft-prt      .
       fnd-arc-bft-080.
