           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           move      w-tes-cod-tmb-cam    to   l-mag-300-cod-cau      .
           move      w-tes-cod-tmb-ctm    to   l-mag-300-cod-ctm      .
           move      w-tes-dat-doc (1)    to   l-mag-300-dat-doc      .
           move      w-tes-num-doc (1)    to   l-mag-300-num-doc      .
           move      w-tes-cod-tmb-ddd    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           move      w-tes-tip-arc (1)    to   l-mag-300-tip-arc      .
           move      w-tes-cod-arc (1)    to   l-mag-300-cod-arc      .
           move      w-tes-dpz-arc (1)    to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Scrittura righe                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore righe scritte    *
      *                  *---------------------------------------------*
           move      zero                 to   w-wrt-mov-mag-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su catena movimenti                   *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale catena movimenti        *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to wrt-mov-mag-800.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * di lavoro                                   *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Se tipo riga a spazi : uscita               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to wrt-mov-mag-800.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo riga                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to wrt-mov-mag-100.
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo prodotto                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-pro (1)    not  = 01
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Selezione su flag di scrittura movimenti di *
      *                  * magazzino                                   *
      *                  *---------------------------------------------*
           if        w-rig-snx-mag (1)    not  = "S"
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore righe scritte          *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-mag-ctr      .
      *                  *---------------------------------------------*
      *                  * Determinazione valore movimento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento in work di comodo           *
      *                      *-----------------------------------------*
           move      w-rig-imp-rig (1)    to   w-wrt-mov-mag-wvm      .
      *                      *-----------------------------------------*
      *                      * Conversione in valuta base              *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-wrt-mov-mag-wvm    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-wrt-mov-mag-wvm      .
       wrt-mov-mag-200.
      *                  *---------------------------------------------*
      *                  * Determinazione costo unitario movimento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa      *
      *                      * all'espressione dei costi unitari in    *
      *                      * unita' di misura diversa                *
      *                      *-----------------------------------------*
           if        w-prs-arg-mag-ecu    =    "N"
                     go to wrt-mov-mag-220.
      *                      *-----------------------------------------*
      *                      * Questo punto andrebbe perfezionato per  *
      *                      * confronto tra il tipo di trasformazione *
      *                      * unita' di misura e i coefficienti       *
      *                      *                                         *
      *                      * ___ MIGLIORARE !!! ___                  *
      *                      *                                         *
      *                      * Bisogna tenere conto dei coefficienti   *
      *                      * di trasformazione                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test solo per 1000                  *
      *                          *-------------------------------------*
           if        w-prs-arg-mag-ecu    not  = "K"
                     go to wrt-mov-mag-220.
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           divide    w-rig-qta-fda (1)    into w-wrt-mov-mag-wvm
                                        giving w-wrt-mov-mag-wcu
                                               rounded                .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     wrt-mov-mag-250.
       wrt-mov-mag-220.
      *                      *-----------------------------------------*
      *                      * Normale trattamento                     *
      *                      *-----------------------------------------*
           divide    w-rig-qta-acq (1)    into w-wrt-mov-mag-wvm
                                        giving w-wrt-mov-mag-wcu
                                               rounded                .
       wrt-mov-mag-250.
      *                  *---------------------------------------------*
      *                  * Applicazione della % maggiorazione prezzo   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da applicare                    *
      *                      *-----------------------------------------*
           if        w-prs-snx-mpa        not  = "S"
                     go to wrt-mov-mag-260.
           if        w-wrt-mov-mag-wcu    =    zero
                     go to wrt-mov-mag-260.
           if        w-rig-per-mpa (1)    =    zero
                     go to wrt-mov-mag-260.
      *                      *-----------------------------------------*
      *                      * Calcolo                                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-wrt-mov-mag-mpa      .
           multiply  w-rig-per-mpa (1)    by   w-wrt-mov-mag-wcu
                                        giving w-wrt-mov-mag-mpa      .
           divide    100                  into w-wrt-mov-mag-mpa
                                       rounded                        .
           add       w-wrt-mov-mag-mpa    to   w-wrt-mov-mag-wcu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento valore                    *
      *                      *-----------------------------------------*
           multiply  w-rig-qta-acq (1)    by   w-wrt-mov-mag-wcu
                                        giving w-wrt-mov-mag-wvm      .
       wrt-mov-mag-260.
      *                  *---------------------------------------------*
      *                  * Preparazione data e numero riferimento      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-wrt-mov-mag-wdr      .
           move      spaces               to   w-wrt-mov-mag-wnr      .
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-prs-trp-ttm        not  = "S"
                     go to wrt-mov-mag-300.
      *                      *-----------------------------------------*
      *                      * Data                                    *
      *                      *-----------------------------------------*
           move      w-rig-orf-dat (1)    to   w-wrt-mov-mag-wdr      .
      *                      *-----------------------------------------*
      *                      * Numero                                  *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-rig-orf-num (1) (6:6)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-wrt-mov-mag-wnr      .
       wrt-mov-mag-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      w-rig-tip-mag (1)    to   l-mag-300-tip-mag      .
           move      w-rig-num-mag (1)    to   l-mag-300-num-mag      .
           move      w-rig-alf-mag (1)    to   l-mag-300-alf-mag      .
           move      w-rig-sgl-vrn (1)    to   l-mag-300-var-mag      .
           move      w-rig-umi-acq (1)    to   l-mag-300-udm-ana      .
           move      w-rig-umi-acq (1)    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      w-wrt-mov-mag-wdr    to   l-mag-300-ddo-rif      .
           move      w-wrt-mov-mag-wnr    to   l-mag-300-ndo-rif      .
           move      w-rig-qta-acq (1)    to   l-mag-300-qta-mov      .
           move      w-wrt-mov-mag-wcu    to   l-mag-300-cun-mov      .
           move      w-wrt-mov-mag-wvm    to   l-mag-300-val-mov      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena movimenti         *
      *                  *---------------------------------------------*
           go to     wrt-mov-mag-100.
       wrt-mov-mag-800.
      *              *-------------------------------------------------*
      *              * Test su numero righe scritte                    *
      *              *-------------------------------------------------*
           if        w-wrt-mov-mag-ctr    not  = zero
                     go to wrt-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Se nessuna riga scritta : cancellazione della   *
      *              * registrazione di magazzino per eliminare la     *
      *              * testata scritta                                 *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-tes-prt-mag (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-mov-mag-999.
       wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : aggiornamenti di magazzino non esegui
      -              "ti !           "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       wrt-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimento di MAG                            *
      *    *-----------------------------------------------------------*
       del-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Test se necessario                              *
      *              *-------------------------------------------------*
           if        w-tes-prt-mag (2)    =    zero
                     go to del-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Esecuzione operazione                           *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-tes-prt-mag (2)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe          *
      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-aav = Ammontare da convertire, espres- *
      *    *                          so nell'altra valuta             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-avb = Ammontare convertito, espresso   *
      *    *                          nella valuta base                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta base ad altra valuta     *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-avb = Ammontare da convertire, espres- *
      *    *                          so nella valuta base             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-aav = Ammontare convertito, espresso   *
      *    *                          nell'altra valuta                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Find su archivio [bft]                                    *
      *    *-----------------------------------------------------------*
       fnd-arc-bft-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-fnd-arc-bft-sel      .
       fnd-arc-bft-010.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se sono stati preparati i valori in input   *
      *                  * si procede come se ricerca gia' effettuata  *
      *                  *---------------------------------------------*
           if        w-fnd-arc-bft-tmb    not  = spaces or
                     w-fnd-arc-bft-dat    not  = zero   or
                     w-fnd-arc-bft-prt    not  = zero
                     go to fnd-arc-bft-080.
       fnd-arc-bft-030.
      *              *-------------------------------------------------*
      *              * Test se programma di interrogazione gia' attivo *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pbfo3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     move  "#"            to   w-fnd-arc-bft-sel
                     go to  fnd-arc-bft-999.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'snx-slc' per il  *
      *              * livello successivo per l'ammissibilita' del ta- *
      *              * sto Slct                                        *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-slc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "S"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Preparazione variabile di i.p.c. per codice di- *
      *              * pendenza                                        *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-dpz"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-tes-cod-dpz        to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Richiamo programma di interrogazione            *
      *              *-------------------------------------------------*
           move      "pgm/bfo/prg/obj/pbfo3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
       fnd-arc-bft-050.
      *              *-------------------------------------------------*
      *              * Estrazione di eventuali variabili di i.p.c. de- *
      *              * terminate da function-key "SLCT" durante l'in-  *
      *              * terrogazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo movimento                              *
