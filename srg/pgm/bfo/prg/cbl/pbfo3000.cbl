      *                      *-----------------------------------------*
      *                      * Test se nuova valuta, valuta base       *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to rcl-vlt-prz-cmb-640.
      *                      *-----------------------------------------*
      *                      * Conversione prezzo in valuta            *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-rig-prz-acq (1)    to   w-cvs-vlt-avb
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
           move      w-cvs-vlt-aav        to   w-rig-prz-acq (1)      .
       rcl-vlt-prz-cmb-640.
      *                      *-----------------------------------------*
      *                      * Determinazione prezzo netto             *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                      *-----------------------------------------*
      *                      * Calcolo importo                         *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena                 *
      *                      *-----------------------------------------*
           go to     rcl-vlt-prz-cmb-700.
       rcl-vlt-prz-cmb-700.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-vlt-prz-cmb-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-vlt-prz-cmb-200.
       rcl-vlt-prz-cmb-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-vlt-prz-cmb-999.
       rcl-vlt-prz-cmb-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo prezzi in riga a cambio valuta       *
      *    *                                                           *
      *    * Subroutine di rilettura prezzi in riga da listino         *
      *    *-----------------------------------------------------------*
       rcl-vlt-prz-lst-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-vlt-prz-lst-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-vlt-prz-lst-900.
      *                  *---------------------------------------------*
      *                  * Se buffer catena movimenti spaces : riciclo *
      *                  *---------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-vlt-prz-lst-200.
       rcl-vlt-prz-lst-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-vlt-prz-lst-200.
       rcl-vlt-prz-lst-400.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento o addebito : riciclo    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-vlt-prz-lst-200.
       rcl-vlt-prz-lst-500.
      *              *-------------------------------------------------*
      *              * Lettura listino in valuta                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-vlt-prz-lst-800.
      *                      *-----------------------------------------*
      *                      * Se manca codice prodotto                *
      *                      *-----------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to rcl-vlt-prz-lst-800.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dcp-cod      .
           move      w-tes-cod-lng (1)    to   w-let-arc-dcp-lng      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
      *
           if        w-rig-tip-mag (1)    =    01
                     move  w-let-arc-dcp-des
                                          to   w-let-arc-aaf-dmg      .
      *
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : riciclo             *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to rcl-vlt-prz-lst-200.
       rcl-vlt-prz-lst-600.
      *                  *---------------------------------------------*
      *                  * Codice prodotto secondo il fornitore        *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-csf    to   w-rig-cop-sfn (1)      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto secondo il fornitore   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se diversa da spaces               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-des    =    spaces
                     go to rcl-vlt-prz-lst-620.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-des    to   w-rig-des-por (1)      .
           move      w-let-arc-aaf-des    to   w-rig-des-rig (1)      .
       rcl-vlt-prz-lst-620.
      *                  *---------------------------------------------*
      *                  * Parametri associati all'unita' di misura    *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-snu    to   w-rig-snx-tum (1)      .
           move      w-let-arc-aaf-umf    to   w-rig-umf-tum (1)      .
           move      w-let-arc-aaf-ndu    to   w-rig-nde-tum (1)      .
           move      w-let-arc-aaf-cmu    to   w-rig-cmo-tum (1)      .
           move      w-let-arc-aaf-cdu    to   w-rig-cdi-tum (1)      .
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni                                   *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaf-dcv    not  = w-tes-dec-vpf (1)
                     go to rcl-vlt-prz-lst-680.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo d'acquisto           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-ndp    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione quantita'                  *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   w-sav-qta-psx
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx          .
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-sav-qta-psx        to   w-det-prz-qta-pre      .
           move      w-sav-qta-cfr        to   w-det-prz-qta-att      .
      *                      *-----------------------------------------*
      *                      * Preparazione link-area                  *
      *                      *-----------------------------------------*
           move      "PA"                 to   d-prz-acq-tip-ope      .
           move      w-tes-cod-arc (1)    to   d-prz-acq-cod-fnt      .
           move      w-rig-tip-mag (1)    to   d-prz-acq-tip-mag      .
           move      w-rig-num-mag (1)    to   d-prz-acq-num-mag      .
           move      w-rig-fda-pif (1)    to   d-prz-acq-fda-pif      .
           move      w-let-arc-dcp-plb    to   d-prz-acq-prz-lsb      .
           move      w-let-arc-dcp-dlb    to   d-prz-acq-dec-vlb      .
           move      w-rig-dec-prz (1)    to   d-prz-acq-dec-prz      .
           move      w-det-prz-qta-att    to   d-prz-acq-qta-rif      .
      *
           if        w-tes-dat-doc (1)    =    zero
                     move  w-tes-dat-reg  to   d-prz-acq-dat-rfp
           else      move  w-tes-dat-doc (1)
                                          to   d-prz-acq-dat-rfp      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           perform   det-prz-acq-cll-000  thru det-prz-acq-cll-999    .
      *                      *-----------------------------------------*
      *                      * Prezzo di acquisto                      *
      *                      *-----------------------------------------*
           move      d-prz-acq-prz-acq    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto                   *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-det (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-prz-acq-psr-det (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-prz-acq-psr-det (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-prz-acq-psr-det (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-prz-acq-psr-det (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Segnale di percentuali sconto determi-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           move      d-prz-acq-psr-snx    to   w-rig-per-scr-ffp (1)  .
       rcl-vlt-prz-lst-650.
      *                  *---------------------------------------------*
      *                  * Parametri associati al legame valutario     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to rcl-vlt-prz-lst-660.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to rcl-vlt-prz-lst-660.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-lvv    to   w-rig-sgl-vpl (1)      .
           move      w-let-arc-aaf-lvd    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-aaf-lvt    to   w-rig-tdc-vpl (1)      .
           move      w-let-arc-aaf-lvc    to   w-rig-ccr-vpl (1)      .
           move      w-let-arc-aaf-lvp    to   w-rig-plm-vpl (1)      .
           move      "F"                  to   w-rig-tlm-vpl (1)      .
       rcl-vlt-prz-lst-660.
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
       rcl-vlt-prz-lst-680.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                  *---------------------------------------------*
      *                  * Calcolo importo                             *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
       rcl-vlt-prz-lst-700.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-vlt-prz-lst-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-vlt-prz-lst-200.
       rcl-vlt-prz-lst-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-vlt-prz-lst-999.
       rcl-vlt-prz-lst-999.
           exit.

      *    *===========================================================*
      *    * Ricerca su buffer documenti movimentati                   *
      *    *-----------------------------------------------------------*
       buf-doc-mvm-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-doc-mvm-fds      .
           move      spaces               to   w-buf-doc-mvm-tds      .
           move      zero                 to   w-buf-doc-mvm-nds      .
           move      zero                 to   w-buf-doc-mvm-dds      .
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-doc-mvm-crb      .
       buf-doc-mvm-100.
      *              *-------------------------------------------------*
      *              * Start su [bft]                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATSYS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-buf-doc-mvm-drc    to   rf-bft-ide-dat         .
           move      zero                 to   rf-bft-dat-reg         .
           move      zero                 to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-buf-doc-mvm-fds
                     go to  buf-doc-mvm-999.
       buf-doc-mvm-200.
      *              *-------------------------------------------------*
      *              * Lettura [bft]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                  *---------------------------------------------*
      *                  * Se at end : a controllo contatore           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to buf-doc-mvm-500.
       buf-doc-mvm-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : a controllo contatore     *
      *              *-------------------------------------------------*
           if        rf-bft-ide-dat       not  = w-buf-doc-mvm-drc
                     go to buf-doc-mvm-500.
       buf-doc-mvm-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [bft]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice utente                       *
      *                  *---------------------------------------------*
           if        rf-bft-ide-ute       not  = w-buf-doc-mvm-ute
                     go to buf-doc-mvm-200.
       buf-doc-mvm-410.
      *              *-------------------------------------------------*
      *              * Incremento numero records nel buffer            *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-doc-mvm-crb      .
      *              *-------------------------------------------------*
      *              * Test se buffer oltre il numero previsto         *
      *              *-------------------------------------------------*
           if        w-buf-doc-mvm-crb    >    w-buf-doc-mvm-max
                     go to buf-doc-mvm-500.
       buf-doc-mvm-420.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo movimento                              *
      *                  *---------------------------------------------*
           move      rf-bft-cod-tmb       to   w-buf-doc-mvm-tmo
                                              (w-buf-doc-mvm-crb)     .
      *                  *---------------------------------------------*
      *                  * Numero fattura fornitore                    *
      *                  *---------------------------------------------*
           move      rf-bft-num-prt       to   w-buf-doc-mvm-num
                                              (w-buf-doc-mvm-crb)     .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      rf-bft-num-doc       to   w-buf-doc-mvm-ndo
                                              (w-buf-doc-mvm-crb)     .
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
           move      rf-bft-dat-reg       to   w-buf-doc-mvm-ddo
                                              (w-buf-doc-mvm-crb)     .
      *                  *---------------------------------------------*
      *                  * Intestatario documento                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura [fnt]                           *
      *                      *-----------------------------------------*
           move      rf-bft-cod-arc       to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
           move      w-let-arc-fnt-rag    to   w-buf-doc-mvm-rsa
                                              (w-buf-doc-mvm-crb)     .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura                           *
      *                  *---------------------------------------------*
           go to     buf-doc-mvm-200.
       buf-doc-mvm-500.
      *                  *---------------------------------------------*
      *                  * Controllo numero records letti con lo stes- *
      *                  * so valore                                   *
      *                  *---------------------------------------------*
           if        w-buf-doc-mvm-crb    =    zero
                     go to buf-doc-mvm-999.
      *                      *-----------------------------------------*
      *                      * Determinazione numero pagine nel buffer *
      *                      *-----------------------------------------*
           move      w-buf-doc-mvm-crb    to   w-buf-doc-mvm-cpb      .
           subtract  1                    from w-buf-doc-mvm-cpb      .
           divide    6                    into w-buf-doc-mvm-cpb      .
           add       1                    to   w-buf-doc-mvm-cpb      .
      *                      *-----------------------------------------*
      *                      * Inizializzazione numero record nel buf- *
      *                      * fer attualmente trattato                *
      *                      *-----------------------------------------*
           move      1                    to   w-buf-doc-mvm-c01      .
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione box vuoto               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      11                   to   v-pos                  .
