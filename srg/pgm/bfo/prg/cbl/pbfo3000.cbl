      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     go to fnd-tlm-vpl-900.
       fnd-tlm-vpl-300.
      *              *-------------------------------------------------*
      *              * Valore in campo di destinazione                 *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "T"            to   w-fnd-tlm-vpl-tlm
           else if   v-num                =    02
                     move  "F"            to   w-fnd-tlm-vpl-tlm
           else if   v-num                =    03
                     move  "M"            to   w-fnd-tlm-vpl-tlm
           else      move  spaces         to   w-fnd-tlm-vpl-tlm      .
       fnd-tlm-vpl-900.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fnd-tlm-vpl-999.
       fnd-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [ybf]                         *
