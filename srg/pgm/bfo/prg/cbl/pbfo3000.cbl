      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "dat-reg"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     move  "#"            to   w-fnd-arc-bft-sel
                     go to fnd-arc-bft-999.
           move      s-dat                to   w-fnd-arc-bft-dat      .
      *                  *---------------------------------------------*
