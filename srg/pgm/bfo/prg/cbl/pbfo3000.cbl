      *              *-------------------------------------------------*
           move      3                    to   w-pie-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      spaces               to   w-pie-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           move      w-prs-spe-fat-imp
                    (w-det-fun-spe-ctr)   to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
       det-fun-spe-140.
      *              *-------------------------------------------------*
      *              * Tipo funzionamento : importo variabile          *
      *              *-------------------------------------------------*
           move      4                    to   w-pie-spe-mad
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-per
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-ibl
                                              (1, w-det-fun-spe-inx)  .
           move      spaces               to   w-pie-spe-ibt
                                              (1, w-det-fun-spe-inx)  .
           move      zero                 to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           move      rf-dcf-imp-spe
                    (w-det-fun-spe-inx)   to   w-pie-spe-imp
                                              (1, w-det-fun-spe-inx)  .
           go to     det-fun-spe-200.
