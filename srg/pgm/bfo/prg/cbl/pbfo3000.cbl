      *    *===========================================================*
      *    * Routine di attribuzione protocollo bolle fornitori        *
      *    *-----------------------------------------------------------*
       att-bfo-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [bfoprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-bfo-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-bfo-prt-saa      .
           move      w-att-bfo-prt-saa    to   rn-bfo-prt-scl-ann     .
           move      w-att-bfo-prt-dpz    to   rn-bfo-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [bfoprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-bfo-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-bfo-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-bfo-prt-000.
       att-bfo-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-bfo-prt-num-prt   to   w-att-bfo-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-bfo-prt-wpr      .
           if        w-att-bfo-prt-wpr    =    zero
                     move  1              to   w-att-bfo-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-bfo-prt-saa    to   w-att-bfo-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-bfo-prt-dpz    to   w-att-bfo-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-bfo-prt-wnu    to   rn-bfo-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-bfo-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-bfo-prt-num-prt   to   w-att-bfo-prt-num      .
       att-bfo-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino protocollo bolle fornitori          *
      *    *-----------------------------------------------------------*
       rip-bfo-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [bfoprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-bfo-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-bfo-prt-saa      .
           move      w-att-bfo-prt-saa    to   rn-bfo-prt-scl-ann     .
           move      w-att-bfo-prt-dpz    to   rn-bfo-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [bfoprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-bfo-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-bfo-prt-num-prt   not  = w-att-bfo-prt-num
                     go to  rip-bfo-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           move      w-att-bfo-prt-num    to   w-att-bfo-prt-wnu      .
           subtract  1                    from w-att-bfo-prt-wpr      .
           if        w-att-bfo-prt-wpr    =    zero
                     move  zero           to   w-att-bfo-prt-wnu      .
           move      w-att-bfo-prt-wnu    to   rn-bfo-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
       rip-bfo-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bfo/num/ioc/obj/inbfoprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bfo-prt             .
       rip-bfo-prt-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se in modifica : cancellazione movimenti prece- *
      *              *                  denti                          *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to scr-mov-fil-050.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di MAG precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-mag-000      thru del-mov-mag-999        .
       scr-mov-fil-050.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [bfr]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-bfr-000      thru del-rec-bfr-999        .
      *              *-------------------------------------------------*
      *              * Delete [bfx]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-bfx-000      thru del-rec-bfx-999        .
      *              *-------------------------------------------------*
      *              * Delete [bfk]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-bfk-000      thru del-rec-bfk-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento record [ofr] per Delete           *
      *              *-------------------------------------------------*
           perform   agg-ofr-del-000      thru agg-ofr-del-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = w-tes-tip-arc (2) or
                     w-tes-cod-arc (1)    not  = w-tes-cod-arc (2) or
                     w-tes-dpz-arc (1)    not  = w-tes-dpz-arc (2) or
                     w-tes-dat-doc (1)    not  = w-tes-dat-doc (2) or
                     w-tes-num-doc (1)    not  = w-tes-num-doc (2) or
                     w-tes-cod-lng (1)    not  = w-tes-cod-lng (2) or
                     w-tes-sgl-vpf (1)    not  = w-tes-sgl-vpf (2) or
                     w-tes-dec-vpf (1)    not  = w-tes-dec-vpf (2) or
                     w-tes-tdc-vpf (1)    not  = w-tes-tdc-vpf (2) or
                     w-tes-cdc-vpf (1)    not  = w-tes-cdc-vpf (2) or
                     w-tes-flg-nbx (1, 1) not  = w-tes-flg-nbx (2, 1)
                     move  "#"            to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento file righe [bfr]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [bfr]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bfr-000      thru wrt-rec-bfr-999        .
      *                      *-----------------------------------------*
      *                      * Write record [bfx]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bfx-000      thru wrt-rec-bfx-999        .
      *                      *-----------------------------------------*
      *                      * Write record [bfk]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bfk-000      thru wrt-rec-bfk-999        .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [ofr] per Write    *
      *                      *-----------------------------------------*
           perform   agg-ofr-wrt-000      thru agg-ofr-wrt-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig (2)    =    spaces
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-cnt-var-tes-cor    not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [bfr]                       *
      *                          *-------------------------------------*
           perform   rew-rec-bfr-000      thru rew-rec-bfr-999        .
      *                          *-------------------------------------*
      *                          * Rewrite [bfx]                       *
      *                          *-------------------------------------*
           perform   rew-rec-bfx-000      thru rew-rec-bfx-999        .
      *                          *-------------------------------------*
      *                          * Rewrite [bfk]                       *
      *                          *-------------------------------------*
           perform   rew-rec-bfk-000      thru rew-rec-bfk-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento record [ofr] per Re-  *
      *                          * write                               *
      *                          *-------------------------------------*
           perform   agg-ofr-rew-000      thru agg-ofr-rew-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Trattamento file testata [bft]                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-800.
      *                      *-----------------------------------------*
      *                      * Write record [bft]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bft-000      thru wrt-rec-bft-999        .
      *                      *-----------------------------------------*
      *                      * Write record [bfx] di appoggio alla te- *
      *                      * stata                                   *
      *                      *-----------------------------------------*
           perform   wrt-bfx-tes-000      thru wrt-bfx-tes-999        .
           go to     scr-mov-fil-900.
       scr-mov-fil-800.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Rewrite record [bft]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-bft-000      thru rew-rec-bft-999        .
      *                      *-----------------------------------------*
      *                      * Delete record [bfx] di appoggio alla te-*
      *                      * stata                                   *
      *                      *-----------------------------------------*
           perform   del-bfx-tes-000      thru del-bfx-tes-999        .
      *                      *-----------------------------------------*
      *                      * Write record [bfx] di appoggio alla te- *
      *                      * stata                                   *
      *                      *-----------------------------------------*
           perform   wrt-bfx-tes-000      thru wrt-bfx-tes-999        .
       scr-mov-fil-900.
      *              *-------------------------------------------------*
      *              * Determinazione importi in valuta base           *
      *              *-------------------------------------------------*
           perform   det-imp-vlb-000      thru det-imp-vlb-999        .
      *              *-------------------------------------------------*
      *              * Scrittura movimenti di MAG                      *
      *              *-------------------------------------------------*
           perform   wrt-mov-mag-000      thru wrt-mov-mag-999        .
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
