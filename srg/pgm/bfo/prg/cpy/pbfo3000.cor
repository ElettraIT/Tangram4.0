      *                  *---------------------------------------------*
           perform   pmt-lot-dat-000      thru pmt-lot-dat-999        .
      *                  *---------------------------------------------*
      *                  * Legame valutario                            *
      *                  *---------------------------------------------*
           perform   pmt-leg-val-000      thru pmt-leg-val-999        .
      *                  *---------------------------------------------*
      *                  * % sconto                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "% sconto          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Importo                                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      "Importo :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice iva        :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Contropartita                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Contropartita     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per note in righe docu- *
      *              * mento                                           *
      *              *-------------------------------------------------*
           move      "PM"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Codice prodotto                                           *
      *    *-----------------------------------------------------------*
       pmt-cod-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      01                   to   v-pos                  .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  "Codice addebito   :"
                                          to   v-alf
           else if   w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento   :"
                                          to   v-alf
           else      move  "Codice prodotto   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione :  *
      *    * Formato di acquisizione per il fornitore                  *
      *    *-----------------------------------------------------------*
       pmt-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to pmt-fda-pif-999.
           if        w-prs-snx-fda        =    "N"
                     go to pmt-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "Formato :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per descrizione                   *
      *    *-----------------------------------------------------------*
       pmt-des-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Descrizione       :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per quantita'                     *
      *    *-----------------------------------------------------------*
       pmt-qta-pri-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Quantita'         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Terza quantita'                  *
      *    *-----------------------------------------------------------*
       pmt-qta-a03-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-col-rig-snx    not  = "S"
                     go to pmt-qta-a03-999.
       pmt-qta-a03-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "Numero colli :"     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-qta-a03-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per prezzo d'acquisto             *
      *    *-----------------------------------------------------------*
       pmt-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Preparazione literal                            *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    not  = "P"
                     move  "Prezzo            :"
                                          to   v-alf
                     go to pmt-prz-acq-100.
           if        w-rig-umf-tum (1)    =    spaces
                     move  "Prezzo            :"
                                          to   v-alf
                     go to pmt-prz-acq-100.
           move      spaces               to   v-alf                  .
           string    "Prezzo/"
                                delimited by   size
                     w-rig-umf-tum (1)
                                delimited by   size
                     "        :"
                                delimited by   size
                                          into v-alf                  .
       pmt-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione literal                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : sigla lotto                      *
      *    *-----------------------------------------------------------*
       pmt-lot-sgl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to pmt-lot-sgl-999.
       pmt-lot-sgl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "Lotto   :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-lot-sgl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : data lotto                       *
      *    *-----------------------------------------------------------*
       pmt-lot-dat-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to pmt-lot-dat-999.
       pmt-lot-dat-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "del:"               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-lot-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts : legame valutario                *
      *    *-----------------------------------------------------------*
       pmt-leg-val-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to pmt-leg-val-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to pmt-leg-val-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Legame valutario:"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      "+/-"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-leg-val-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : tipo    *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       acc-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-rig-025.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del default          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    not  = spaces
                     go to acc-tip-rig-050.
           if        w-tes-cod-tmb-dtr    not  = spaces
                     if    w-tes-cod-tmb-dtr
                                          =    "-----"
                           move  spaces   to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050
                     else  move  w-tes-cod-tmb-dtr
                                          to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050.
           if        w-tes-cod-tmb-cam    =    zero
                     go to acc-tip-rig-050.
           move      w-tes-cod-tmb-cam-dtm
                                          to   w-rig-tip-rig (1)      .
       acc-tip-rig-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig (1)    to   w-sav-tip-rig          .
       acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-rig        to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Pf2  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend                             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  "[2] "         to   v-pfk (15)             .
      *                      *-----------------------------------------*
      *                      * Pf3  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend                             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  "[3] "         to   v-pfk (16)             .
      *                      *-----------------------------------------*
      *                      * Pf4  : ammesso solo se gestione ordini  *
      *                      *        fornitori attiva e il tipo movi- *
      *                      *        mento per la bolla lo consente   *
      *                      *        e si e' in un record New         *
      *                      *-----------------------------------------*
           if       (w-prs-orf-snx        =    "S" and
                     w-tes-cod-tmb-maf    =    02    ) and
                     w-cat-rig-new        not  = spaces
                     move  "[4] "         to   v-pfk (17)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   v-alf                  .
       acc-tip-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-rig-210.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-rig-250.
      *                  *---------------------------------------------*
      *                  * Test se ricerca per prodotto                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : find su tipi riga       *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-tip-rig-220.
           if        v-alf                =    spaces
                     go to acc-tip-rig-220.
           move      v-alf                to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    = spaces
                     go to acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su righe per codice prodotto           *
      *                  *---------------------------------------------*
           move      v-alf                to   w-fnd-mag-rig-alf      .
           move      w-cat-rig-cur        to   w-fnd-mag-rig-cur      .
           perform   fnd-mag-rig-000      thru fnd-mag-rig-999        .
           if        w-fnd-mag-rig-num    =    zero
                     go to acc-tip-rig-100.
           move      w-fnd-mag-rig-num    to   w-cnt-slc-rap-num      .
           go to     acc-tip-rig-320.
       acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su tipi riga                           *
      *                  *---------------------------------------------*
           perform   fnd-tip-rig-000      thru fnd-tip-rig-999        .
           if        w-fnd-tip-rig-sel    not  = spaces
                     go to acc-tip-rig-100.
           move      w-fnd-tip-rig-tri    to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo riga                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-rig-425.
       acc-tip-rig-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-rig-300
           else      go to acc-tip-rig-350.
       acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-rig-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-rig-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-rig-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-rig-310.
       acc-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-rig-999.
       acc-tip-rig-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-rig-999
                     else    go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf2                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[2] "
                     move  "2"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf3                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[3] "
                     move  "3"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "4"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
       acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-tip-rig (1)      .
       acc-tip-rig-425.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo tipo riga impostato           *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    not  = spaces
                     go to acc-tip-rig-100.
      *                      *-----------------------------------------*
      *                      * Se documento non per fatturazione : tipo*
      *                      * riga 'A' non ammesso                    *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        not  = 01
                     go to acc-tip-rig-430.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-tip-rig-430.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "Tipo riga non ammesso per questo tipo documento ! 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-tip-rig-100.
       acc-tip-rig-430.
      *                      *-----------------------------------------*
      *                      * Test che il tipo riga impostato sia am- *
      *                      * messo tra quelli della causale di ma-   *
      *                      * gazzino                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se causale di magazzino a zero : ol-*
      *                          * tre                                 *
      *                          *-------------------------------------*
           if        w-tes-cod-tmb-cam    =    zero
                     go to acc-tip-rig-450.
      *                          *-------------------------------------*
      *                          * Se tipo riga A o C : oltre          *
      *                          *-------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A" or
                     w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-tip-rig-450.
      *                          *-------------------------------------*
      *                          * Se valore attuale come precedente : *
      *                          * oltre                               *
      *                          *-------------------------------------*
           if        w-rig-tip-rig (1)    =    w-sav-tip-rig
                     go to acc-tip-rig-450.
      *                          *-------------------------------------*
      *                          * Se tipo magazzino di default non mo-*
      *                          * dificabile                          *
      *                          *-------------------------------------*
           if        w-tes-cod-tmb-cam-vtm
                                          =    "S"
                     go to acc-tip-rig-440.
      *                              *---------------------------------*
      *                              * Se tipo riga diverso da quello  *
      *                              * di default : errore             *
      *                              *---------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = w-tes-cod-tmb-cam-dtm
                     move  w-tes-cod-tmb-cam-dtm
                                          to   w-rig-tip-rig-tpr (1)
                     go to acc-tip-rig-445.
      *                              *---------------------------------*
      *                              * Altrimenti : oltre              *
      *                              *---------------------------------*
           go to     acc-tip-rig-450.
       acc-tip-rig-440.
      *                          *-------------------------------------*
      *                          * Se tipo magazzino di default modi-  *
      *                          * ficabile                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se lista tipi magazzino impo-   *
      *                              * stabili a spazi : oltre         *
      *                              *---------------------------------*
           if        w-tes-cod-tmb-cam-ltm
                                          =    spaces
                     go to acc-tip-rig-450.
      *                              *---------------------------------*
      *                              * Se il tipo riga impostato non   *
      *                              * risulta tra quelli ammessi: er- *
      *                              * rore                            *
      *                              *---------------------------------*
           move      zero                 to   w-acc-tip-rig-inx      .
           inspect   w-tes-cod-tmb-cam-ltm
                                      tallying w-acc-tip-rig-inx
                                     for all   w-rig-tip-rig-tpr (1)  .
           if        w-acc-tip-rig-inx    =    zero
                     go to acc-tip-rig-445.
      *                              *---------------------------------*
      *                              * Altrimenti : oltre              *
      *                              *---------------------------------*
           go to     acc-tip-rig-450.
       acc-tip-rig-445.
      *                          *-------------------------------------*
      *                          * Trattamento errore                  *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "Tipo riga non ammesso dalla causale di magazzino !
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                              *---------------------------------*
      *                              * A reimpostazione                *
      *                              *---------------------------------*
           go to     acc-tip-rig-100.
       acc-tip-rig-450.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-rig-999
                     else  go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-rig-100.
       acc-tip-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo magazzino               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     move  01             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     move  03             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     move  04             to   w-rig-tip-mag (1)
           else      move  zero           to   w-rig-tip-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura codice iva              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se il documento interessa la fat-  *
      *                      * turazione                               *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto 'P', 'M' o 'V'   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to acc-tip-rig-620.
           if        w-tes-ass-iva (1)    =    zero
                     go to acc-tip-rig-620.
           move      w-tes-ass-iva (1)    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-tes-ass-iva-des (1)
                                          to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-tip-rig-620.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura contropartita acquisti  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se il documento interessa la fat-  *
      *                      * turazione                               *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-tip-rig-800.
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto 'P', 'M' o 'V'   *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "V"
                     go to acc-tip-rig-700.
           if        w-tes-ctp-acq (1)    =    zero
                     go to acc-tip-rig-700.
           move      w-tes-ctp-acq (1)    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-tes-ctp-acq-des (1)
                                          to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-tip-rig-700.
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt per codice prodotto  *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
       acc-tip-rig-800.
       acc-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo riga                         *
      *    *-----------------------------------------------------------*
       vis-tip-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Ricerca riga da codice di magazzino                       *
      *    *-----------------------------------------------------------*
       fnd-mag-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-fnd-mag-rig-num      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      w-fnd-mag-rig-cur    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to fnd-mag-rig-100.
       fnd-mag-rig-200.
      *              *-------------------------------------------------*
      *              * Confronto con il numero riga in corso di trat-  *
      *              * tamento                                         *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-cur    =    w-cat-rig-cur
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Confronto con il codice alfanumerico contenuto  *
      *              * nella riga                                      *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-alf    not  = w-rig-alf-mag (1)
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Riga trovata in campo do comodo                 *
      *              *-------------------------------------------------*
           move      w-cat-rig-cur        to   w-fnd-mag-rig-num      .
       fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       fnd-mag-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice addebito o commen- *
      *    *                                 to                        *
      *    *-----------------------------------------------------------*
       acc-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-cod-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig-cac (1)
                                          to   w-sav-cod-aoc          .
       acc-cod-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zac-ope      .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-cod-mne-zac-tip
           else      move  02             to   w-cod-mne-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-cod-mne-zac-cod      .
           move      15                   to   w-cod-mne-zac-lin      .
           move      21                   to   w-cod-mne-zac-pos      .
           move      16                   to   w-cod-mne-zac-dln      .
           move      21                   to   w-cod-mne-zac-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "<B"                 to   v-edm                  .
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
       acc-cod-aoc-110.
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           if        w-cod-mne-zac-ope    =    "F+"
                     go to acc-cod-aoc-115.
           if        w-cod-mne-zac-ope    =    "AC"
                     go to acc-cod-aoc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aoc-115.
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
           go to     acc-cod-aoc-110.
       acc-cod-aoc-120.
           move      w-cod-mne-zac-cod    to   v-num                  .
       acc-cod-aoc-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-tip-rig-cac (1)  .
       acc-cod-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zac]                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-let-arc-zac-tip
           else      move  02             to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato                            *
      *                  *---------------------------------------------*
           if        w-let-arc-zac-flg    =    spaces
                     go to acc-cod-aoc-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento non esistente !"
                                          to   w-err-box-err-msg
           else      move  "Codice addebito non esistente !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-aoc-100.
       acc-cod-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    w-sav-cod-aoc
                     go to acc-cod-aoc-800.
      *                  *---------------------------------------------*
      *                  * Descrizione addebito o commento             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-cod-aoc-800.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-civ    to   w-edt-iva-cod          .
      *
           if        w-tes-ass-iva (1)    not  = zero
                     if    w-edt-iva-cod-003
                                          =    zero
                           move  w-tes-ass-iva (1)
                                          to   w-rig-civ-rig (1)
                     else  move  w-let-arc-zac-civ
                                          to   w-rig-civ-rig (1)
           else      move  w-let-arc-zac-civ
                                          to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-aoc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-aoc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-aoc-100.
       acc-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Codice addebito o com- *
      *    *                                    mento                  *
      *    *-----------------------------------------------------------*
       vis-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to vis-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto           *
      *    *-----------------------------------------------------------*
       acc-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-cod-pro-999.
      *                      *-----------------------------------------*
      *                      * Test se campo gia' accettato            *
      *                      *-----------------------------------------*
           if        w-rig-num-mag (1)    not  = zero
                     go to acc-cod-pro-999.
       acc-cod-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     perform   acc-cod-dcp-000
                                          thru acc-cod-dcp-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     perform   acc-cod-dpm-000
                                          thru acc-cod-dpm-999
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     perform   acc-cod-mtv-000
                                          thru acc-cod-mtv-999        .
       acc-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto                   *
      *    *-----------------------------------------------------------*
       vis-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cod-pro-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-alf-mag (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-dcp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      w-rig-num-mag (1)    to   w-cod-cod-dcp-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-dcp-alf      .
           move      15                   to   w-cod-cod-dcp-lin      .
           move      21                   to   w-cod-cod-dcp-pos      .
           move      16                   to   w-cod-cod-dcp-dln      .
           move      21                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dcp-cod      .
           move      w-tes-cod-lng (1)    to   w-let-arc-dcp-lng      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dcp-flg    not  = spaces
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-dcp-450.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto prodo
      -              "tto !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-100.
       acc-cod-dcp-450.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del prodotto     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcp-tus    =    01
                     go to acc-cod-dcp-600.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cod-dcp-bsp-000  thru acc-cod-dcp-bsp-999    .
       acc-cod-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-610.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dcp]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dcp] in descrizione per documento      *
      *                      *-----------------------------------------*
           move      w-let-arc-dcp-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-dcp-610.
      *                  *---------------------------------------------*
      *                  * Tipo prodotto                               *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-tpr    to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si/No aggiornamento di magazzino            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-rig-snx-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-cod-dcp-630.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-dcp-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-dcp-620.
      *                  *---------------------------------------------*
      *                  * Prezzo di listino base                      *
      *                  *---------------------------------------------*
           move      w-let-arc-dcp-dlb    to   w-rig-num-mag-dlb (1)  .
           move      w-let-arc-dcp-plb    to   w-rig-num-mag-plb (1)  .
       acc-cod-dcp-630.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-let-arc-dcp-des    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-dcp-640.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-dcp-640.
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-cod-dcp-680.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dcp-660.
      *                      *-----------------------------------------*
      *                      * Se codice iva contenuto in [aaq] questo *
      *                      * prevale, altrimenti e' quello contenuto *
      *                      * in [dcp]                                *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-civ    not  = zero
                     move  w-let-arc-aaq-civ
                                          to   w-rig-civ-rig (1)
           else      move  w-let-arc-dcp-civ
                                          to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-dcp-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-dcp-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-dcp-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dcp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dcp-100.
       acc-cod-dcp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del prodotto, se diverso da 'normale'                     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-bsp-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il prodotto impostato si rileva la seguente co
      -              "ndizione :  "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcp-tus    =    11
                     move  "[Prodotto ad esaurimento]                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcp-tus    =    21
                     move  "[Sostituito da ns. nuovo prodotto]          
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcp-tus    =    51
                     move  "[Cessata commercializzazione]               
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcp-tus    =    52
                     move  "[Cessata commercializzazione, ma sostituito 
      -                    "da ns. prodotto]  "
                                          to   v-alf
           else if   w-let-arc-dcp-tus    =    71
                     move  "[Obsoleto]                                  
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcp-tus    =    72
                     move  "[Obsoleto, ma sostituito da ns. nuovo prodot
      -                    "to]               "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcp-tud    =    zero
                     go to acc-cod-dcp-bsp-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-arc-dcp-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcp-tuc    =    zero
                     go to acc-cod-dcp-bsp-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il prodotto utilizzabile in alternativa e' il segu
      -              "ente :       "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice prodotto alternativo         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Lettura record [dcp]            *
      *                              *---------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-arc-dcp-tuc    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-dcp-alf-pro
                     move  all "."        to   rf-dcp-des-pro         .
      *                              *---------------------------------*
      *                              * Visualizzazione codice prodotto *
      *                              *---------------------------------*

           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      rf-dcp-alf-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Visualizzazione descrizione     *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      rf-dcp-des-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Lettura record [dcp] di ripris- *
      *                              * tino                            *
      *                              *---------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-arc-dcp-cod    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       acc-cod-dcp-bsp-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dpm]     *
      *    *-----------------------------------------------------------*
       acc-cod-dpm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-dpm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaq-ope      .
           move      "A"                  to   w-cod-cod-aaq-tac      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaq-tco      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaq-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaq-alf      .
           move      15                   to   w-cod-cod-aaq-lin      .
           move      21                   to   w-cod-cod-aaq-pos      .
           move      16                   to   w-cod-cod-aaq-dln      .
           move      21                   to   w-cod-cod-aaq-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
       acc-cod-dpm-110.
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           if        w-cod-cod-aaq-ope    =    "F+"
                     go to acc-cod-dpm-115.
           if        w-cod-cod-aaq-ope    =    "AC"
                     go to acc-cod-dpm-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dpm-115.
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
           go to     acc-cod-dpm-110.
       acc-cod-dpm-120.
           move      w-cod-cod-aaq-alf    to   v-alf                  .
           move      w-cod-cod-aaq-num    to   v-num                  .
       acc-cod-dpm-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpm-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-dpm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dpm]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-dpm-cod      .
           perform   let-arc-dpm-000      thru let-arc-dpm-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-dpm-flg    not  = spaces
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-dpm-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-dpm-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-dpm-100.
       acc-cod-dpm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [dpm]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione ad uso in-   *
      *                      * terno                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-dpm-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Tipo prodotto : forzato a Merce             *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-dpm-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si/No aggiornamento di magazzino            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-rig-snx-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-cod-dpm-620.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-dpm-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-dpm-620.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dpm-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-let-arc-dpm-des    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-dpm-640.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-dpm-640.
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-cod-dpm-680.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dpm-660.
           move      w-let-arc-aaq-civ    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-dpm-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-dpm-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-dpm-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dpm-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dpm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dpm-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dpm-100.
       acc-cod-dpm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [mtv]     *
      *    *-----------------------------------------------------------*
       acc-cod-mtv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-sav-num-mag          .
       acc-cod-mtv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaq-ope      .
           move      "A"                  to   w-cod-cod-aaq-tac      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaq-tco      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaq-num      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaq-alf      .
           move      15                   to   w-cod-cod-aaq-lin      .
           move      21                   to   w-cod-cod-aaq-pos      .
           move      16                   to   w-cod-cod-aaq-dln      .
           move      21                   to   w-cod-cod-aaq-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
       acc-cod-mtv-110.
           perform   cod-cod-aaq-cll-000  thru cod-cod-aaq-cll-999    .
           if        w-cod-cod-aaq-ope    =    "F+"
                     go to acc-cod-mtv-115.
           if        w-cod-cod-aaq-ope    =    "AC"
                     go to acc-cod-mtv-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-mtv-115.
           perform   cod-cod-aaq-foi-000  thru cod-cod-aaq-foi-999    .
           go to     acc-cod-mtv-110.
       acc-cod-mtv-120.
           move      w-cod-cod-aaq-alf    to   v-alf                  .
           move      w-cod-cod-aaq-num    to   v-num                  .
       acc-cod-mtv-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-mtv-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-mtv-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-mag (1)      .
           move      v-num                to   w-rig-num-mag (1)      .
       acc-cod-mtv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [mtv]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-mag (1)    to   w-let-arc-mtv-cod      .
           perform   let-arc-mtv-000      thru let-arc-mtv-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-mtv-flg    not  = spaces
                     go to acc-cod-mtv-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-mag (1)    =    zero
                     go to acc-cod-mtv-100.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaq]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaq-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaq-cdm      .
           perform   let-arc-aaq-000      thru let-arc-aaq-999        .
      *                  *---------------------------------------------*
      *                  * Test se lettura errata                      *
      *                  *---------------------------------------------*
           if        w-let-arc-aaq-flg    =    spaces
                     go to acc-cod-mtv-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica dati generali di acquisto !    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-mtv-100.
       acc-cod-mtv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione prodotto    *
      *                      * [mtv]                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-mtv-des    to   w-rig-des-por (1)      .
      *                      *-----------------------------------------*
      *                      * Memorizzazione descrizione ad uso in-   *
      *                      * terno                                   *
      *                      *-----------------------------------------*
           move      w-let-arc-mtv-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione prodotto    *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Tipo prodotto : forzato a Merce             *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-tip-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-umi    to   w-rig-umi-acq (1)      .
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Decimali quantita'                          *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-deq    to   w-rig-dec-qta (1)      .
      *                  *---------------------------------------------*
      *                  * Si/No aggiornamento di magazzino            *
      *                  *---------------------------------------------*
           move      w-let-arc-mtv-snm    to   w-rig-snx-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-cod-mtv-620.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo                      *
      *                  *---------------------------------------------*
           move      w-let-arc-aaq-dep    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto di riferimento           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta diversa da quella di    *
      *                      * fatturazione : oltre                    *
      *                      *-----------------------------------------*
           if        w-let-arc-aaq-svl    not  = w-tes-sgl-vpf (1) or
                     w-let-arc-aaq-dvl    not  = w-tes-dec-vpf (1)
                     go to acc-cod-mtv-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-let-arc-aaq-prz    to   w-rig-prz-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
       acc-cod-mtv-620.
      *                  *---------------------------------------------*
      *                  * Dati relativi al formato di acquisizione    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-mtv-640.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [aaf]                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
           move      w-let-arc-mtv-des    to   w-let-arc-aaf-dmg      .
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : oltre               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-flg    not  = spaces
                     go to acc-cod-mtv-640.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine                     *
      *                      *-----------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-cod-mtv-640.
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-cod-mtv-680.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-mtv-660.
           move      w-let-arc-aaq-civ    to   w-rig-civ-rig (1)      .
           perform   vis-civ-rig-000      thru vis-civ-rig-999        .
           move      w-rig-civ-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-civ-rig-des (1)  .
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
       acc-cod-mtv-660.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti in  riga             *
      *                  *---------------------------------------------*
           if        w-tes-ctp-acq (1)    not  = zero
                     go to acc-cod-mtv-680.
           move      w-let-arc-aaq-ctp    to   w-rig-ctp-rig (1)      .
           perform   vis-ctp-rig-000      thru vis-ctp-rig-999        .
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
       acc-cod-mtv-680.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-mtv-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-mtv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-mtv-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-mtv-100.
       acc-cod-mtv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Unita' di misura                  *
      *    *-----------------------------------------------------------*
       vis-umi-acq-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      15                   to   v-pos                  .
           if        w-rig-snx-tum (1)    not  = "S"
                     move  w-rig-umi-acq (1)
                                          to   v-alf
           else      move  w-rig-umf-tum (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-umi-acq-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di acquisizione   *
      *    *-----------------------------------------------------------*
       acc-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-fda        =    "N"
                     go to acc-fda-pif-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo archivio diverso da 'F' : usci- *
      *                      * ta                                      *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to acc-fda-pif-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-fda-pif-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo funzionamento              *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-fda-pif-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-fda-pif (1)    to   w-sav-fda-pif          .
       acc-fda-pif-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-aaf-ope      .
           move      w-rig-tip-mag (1)    to   w-cod-cod-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-cod-cod-aaf-nrm      .
           move      w-rig-alf-mag (1)    to   w-cod-cod-aaf-afm      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-aaf-dcf      .
           move      w-rig-fda-pif (1)    to   w-cod-cod-aaf-fda      .
           move      15                   to   w-cod-cod-aaf-lin      .
           move      47                   to   w-cod-cod-aaf-pos      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-aaf-cll-000  thru cod-cod-aaf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-aaf-foi-000  thru cod-cod-aaf-foi-999    .
       acc-fda-pif-110.
           perform   cod-cod-aaf-cll-000  thru cod-cod-aaf-cll-999    .
           if        w-cod-cod-aaf-ope    =    "F+"
                     go to acc-fda-pif-115.
           if        w-cod-cod-aaf-ope    =    "AC"
                     go to acc-fda-pif-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fda-pif-115.
           perform   cod-cod-aaf-foi-000  thru cod-cod-aaf-foi-999    .
           go to     acc-fda-pif-110.
       acc-fda-pif-120.
           move      w-cod-cod-aaf-fda    to   v-alf                  .
       acc-fda-pif-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-fda-pif (1)      .
       acc-fda-pif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [aaf]                      *
      *                  *---------------------------------------------*
           move      w-rig-tip-mag (1)    to   w-let-arc-aaf-tpm      .
           move      w-rig-num-mag (1)    to   w-let-arc-aaf-cdm      .
           move      w-tes-cod-arc (1)    to   w-let-arc-aaf-fnt      .
           move      w-rig-fda-pif (1)    to   w-let-arc-aaf-fda      .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     move  w-let-arc-dcp-des
                                          to   w-let-arc-aaf-dmg
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     move  w-let-arc-dpm-des
                                          to   w-let-arc-aaf-dmg
           else if   w-rig-tip-rig-tpr (1)
                                          =    "V"
                     move  w-let-arc-mtv-des
                                          to   w-let-arc-aaf-dmg      .
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           perform   let-arc-aaf-000      thru let-arc-aaf-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-flg    =    spaces
                     go to acc-fda-pif-600.
           if        w-rig-fda-pif (1)    =    spaces
                     go to acc-fda-pif-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Formato di acquisizione non esistente !           
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-fda-pif-100.
       acc-fda-pif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-fda-pif (1)    =    w-sav-fda-pif
                     go to acc-fda-pif-700.
      *                  *---------------------------------------------*
      *                  * Richiamo subroutine                         *
      *                  *---------------------------------------------*
           perform   acc-fda-pif-ddi-000  thru acc-fda-pif-ddi-999    .
       acc-fda-pif-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-fda-pif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-fda-pif-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-fda-pif-100.
       acc-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Formato di acquisizione   *
      *    *                                                           *
      *    * Subroutine per dipendenze dall'impostazione               *
      *    *-----------------------------------------------------------*
       acc-fda-pif-ddi-000.
       acc-fda-pif-ddi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione si/no esistenza di un forma- *
      *                  * to di acquisizione                          *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-flg    =    spaces
                     move  "S"            to   w-rig-snx-fda (1)
           else      move  "N"            to   w-rig-snx-fda (1)      .
           if        w-let-arc-aaf-des    =    spaces
                     move  "N"            to   w-rig-snx-dep (1)
           else      move  "S"            to   w-rig-snx-dep (1)      .
      *                  *---------------------------------------------*
      *                  * Valori da bufferizzare se formato di acqui- *
      *                  * sizione esistente                           *
      *                  *---------------------------------------------*
           if        w-rig-snx-fda (1)    =    "N"
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Codice prodotto secondo il fornitore        *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-csf    to   w-rig-cop-sfn (1)      .
           perform   vis-cop-sfn-000      thru vis-cop-sfn-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto secondo il fornitore   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se diversa da spaces               *
      *                      *-----------------------------------------*
           if        w-let-arc-aaf-des    =    spaces
                     go to acc-fda-pif-ddi-605.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione                         *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-des    to   w-rig-des-por (1)      .
           move      w-let-arc-aaf-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-fda-pif-ddi-605.
      *                  *---------------------------------------------*
      *                  * Parametri associati all'unita' di misura    *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-snu    to   w-rig-snx-tum (1)      .
           move      w-let-arc-aaf-umf    to   w-rig-umf-tum (1)      .
           move      w-let-arc-aaf-ndu    to   w-rig-nde-tum (1)      .
           move      w-let-arc-aaf-cmu    to   w-rig-cmo-tum (1)      .
           move      w-let-arc-aaf-cdu    to   w-rig-cdi-tum (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione unita' di misura            *
      *                  *---------------------------------------------*
           perform   vis-umi-acq-000      thru vis-umi-acq-999        .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione prompt prezzo di acquisto *
      *                  *---------------------------------------------*
           perform   pmt-prz-acq-000      thru pmt-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni                                   *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1)
                     go to acc-fda-pif-ddi-800.
      *                  *---------------------------------------------*
      *                  * Numero decimali prezzo d'acquisto           *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-ndp    to   w-rig-dec-prz (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo d'acquisto                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione work-area                  *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-tpa    to   w-det-prz-acq-tpa      .
           move      w-let-arc-aaf-tap    to   w-det-prz-acq-tap      .
           move      zero                 to   w-acc-fda-pif-c01      .
       acc-fda-pif-ddi-610.
           add       1                    to   w-acc-fda-pif-c01      .
           if        w-acc-fda-pif-c01    >    6
                     go to acc-fda-pif-ddi-620.
           move      w-let-arc-aaf-qtp
                    (w-acc-fda-pif-c01)   to   w-det-prz-acq-qtp
                                              (w-acc-fda-pif-c01)     .
           move      w-let-arc-aaf-pzp
                    (w-acc-fda-pif-c01)   to   w-det-prz-acq-pzp
                                              (w-acc-fda-pif-c01)     .
           move      w-let-arc-aaf-csp
                    (w-acc-fda-pif-c01)   to   w-det-prz-acq-csp
                                              (w-acc-fda-pif-c01)     .
           move      zero                 to   w-acc-fda-pif-c02      .
       acc-fda-pif-ddi-612.
           add       1                    to   w-acc-fda-pif-c02      .
           if        w-acc-fda-pif-c02    >    5
                     go to acc-fda-pif-ddi-614.
           move      w-let-arc-aaf-psp
                    (w-acc-fda-pif-c01,
                     w-acc-fda-pif-c02)
                                          to   w-det-prz-acq-psp
                                              (w-acc-fda-pif-c01
                                               w-acc-fda-pif-c02)     .
           go to     acc-fda-pif-ddi-612.
       acc-fda-pif-ddi-614.
           go to     acc-fda-pif-ddi-610.
       acc-fda-pif-ddi-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-prz-qta-pre      .
           move      zero                 to   w-det-prz-qta-att      .
           perform   det-prz-acq-000      thru det-prz-acq-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Parametri associati al legame valutario     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-fda-pif-ddi-680.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-fda-pif-ddi-680.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione e visualizzazione       *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-lvv    to   w-rig-sgl-vpl (1)      .
           move      w-let-arc-aaf-lvd    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-aaf-lvt    to   w-rig-tdc-vpl (1)      .
           move      w-let-arc-aaf-lvc    to   w-rig-ccr-vpl (1)      .
           move      w-let-arc-aaf-lvp    to   w-rig-plm-vpl (1)      .
           move      "F"                  to   w-rig-tlm-vpl (1)      .
           perform   vis-sgl-vpl-000      thru vis-sgl-vpl-999        .
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
       acc-fda-pif-ddi-680.
      *                  *---------------------------------------------*
      *                  * % di maggiorazione prezzo di acquisto       *
      *                  *---------------------------------------------*
           move      w-let-arc-aaf-mpa    to   w-rig-per-mpa (1)      .
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-fda-pif-ddi-800.
       acc-fda-pif-ddi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Formato di acquisizione           *
      *    *-----------------------------------------------------------*
       vis-fda-pif-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to vis-fda-pif-999.
           if        w-prs-snx-fda        =    "N"
                     go to vis-fda-pif-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-rig-fda-pif (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fda-pif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto secondo fornitore *
      *    *-----------------------------------------------------------*
       vis-cop-sfn-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to vis-cop-sfn-999.
           if        w-rig-cop-sfn (1)    =    spaces
                     go to vis-cop-sfn-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "[F]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-rig-cop-sfn (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cop-sfn-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Descrizione in riga       *
      *    *-----------------------------------------------------------*
       acc-des-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-des-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-des-rig (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-rig-des-rig (1)      .
       acc-des-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spazi ammesso solo per tipi riga   *
      *                  * 'C', a meno che non si sia in Up            *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = spaces
                     go to acc-des-rig-600.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-des-rig-600.
           if        v-key                =    "UP  "
                     go to acc-des-rig-600
           else      go to acc-des-rig-100.
       acc-des-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-des-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-des-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-des-rig-100.
       acc-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione in riga               *
      *    *-----------------------------------------------------------*
       vis-des-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-des-rig (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' primaria        *
      *    *-----------------------------------------------------------*
       acc-qta-pri-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-pri-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   w-sav-qta-psx
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx          .
       acc-qta-pri-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   v-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           if        w-prs-orf-snx        =    "S"    and
                     w-rig-orf-prt (1)    not  = zero and
                     w-rig-orf-prg (1)    not  = zero
                     move  "[1] "         to   v-pfk (14)             .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   v-num
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-fda (1)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-pri-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-pri-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  v-num          to   w-rig-qta-acq (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  v-num          to   w-rig-qta-fda (1)
           else      move  v-num          to   w-rig-qta-fda (1)      .
      *              *-------------------------------------------------*
      *              * Valore impostato in comodo per confronti        *
      *              *-------------------------------------------------*
           move      v-num                to   w-sav-qta-cfr          .
       acc-qta-pri-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-pri-425.
      *                  *---------------------------------------------*
      *                  * Quantita' a zero non ammessa, a meno che    *
      *                  * non si sia in Up                            *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        not  = zero
                     go to acc-qta-pri-450.
           if        v-key                not  = "UP  "
                     go to acc-qta-pri-100.
       acc-qta-pri-450.
      *                  *---------------------------------------------*
      *                  * Fine controlli                              *
      *                  *---------------------------------------------*
           go to     acc-qta-pri-600.
       acc-qta-pri-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento flag di saldo forzato           *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to  acc-qta-pri-602.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           if        w-rig-orf-fzs (1)    =    spaces
                     move  "S"            to   w-rig-orf-fzs (1)
           else      move  spaces         to   w-rig-orf-fzs (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-orf-fzs-000      thru vis-orf-fzs-999        .
       acc-qta-pri-602.
      *                  *---------------------------------------------*
      *                  * Trattamento quantita' secondaria            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore inalterato rispetto al valore *
      *                      * precedente : nessuna azione             *
      *                      *-----------------------------------------*
           if        w-sav-qta-cfr        =    w-sav-qta-psx
                     go to acc-qta-pri-605.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' secondaria     *
      *                      *-----------------------------------------*
           move      w-sav-qta-cfr        to   w-det-qta-sec-qim      .
           move      w-rig-dec-qta (1)    to   w-det-qta-sec-dgm      .
           move      w-rig-snx-tum (1)    to   w-det-qta-sec-snu      .
           move      w-rig-umf-tum (1)    to   w-det-qta-sec-umf      .
           move      w-rig-nde-tum (1)    to   w-det-qta-sec-ndu      .
           move      w-rig-cmo-tum (1)    to   w-det-qta-sec-cmu      .
           move      w-rig-cdi-tum (1)    to   w-det-qta-sec-cdu      .
           perform   det-qta-sec-000      thru det-qta-sec-999        .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-det-qta-sec-qts
                                          to   w-rig-qta-fda (1)
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-det-qta-sec-qts
                                          to   w-rig-qta-acq (1)
           else      move  w-det-qta-sec-qts
                                          to   w-rig-qta-acq (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione quantita' secondaria    *
      *                      *-----------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
       acc-qta-pri-605.
      *                  *---------------------------------------------*
      *                  * Si trattano i campi seguenti solo se il     *
      *                  * documento interessa la fatturazione         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-qta-pri-800.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta secondo il formato di ac-   *
      *                  * quisizione diversa da sigla valuta di te-   *
      *                  * stata, non si eseguono le successive deter- *
      *                  * minazioni, tranne che quella dell'importo   *
      *                  * in riga                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-aaf-vlt    not  = w-tes-sgl-vpf (1)
                     go to acc-qta-pri-700.
      *                  *---------------------------------------------*
      *                  * Prezzo di acquisto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione work-area                  *
      *                      *-----------------------------------------*
           move      w-let-arc-aaf-tpa    to   w-det-prz-acq-tpa      .
           move      w-let-arc-aaf-tap    to   w-det-prz-acq-tap      .
           move      zero                 to   w-acc-qta-psx-c01      .
       acc-qta-pri-610.
           add       1                    to   w-acc-qta-psx-c01      .
           if        w-acc-qta-psx-c01    >    6
                     go to acc-qta-pri-620.
           move      w-let-arc-aaf-qtp
                    (w-acc-qta-psx-c01)   to   w-det-prz-acq-qtp
                                              (w-acc-qta-psx-c01)     .
           move      w-let-arc-aaf-pzp
                    (w-acc-qta-psx-c01)   to   w-det-prz-acq-pzp
                                              (w-acc-qta-psx-c01)     .
           move      w-let-arc-aaf-csp
                    (w-acc-qta-psx-c01)   to   w-det-prz-acq-csp
                                              (w-acc-qta-psx-c01)     .
           move      zero                 to   w-acc-qta-psx-c02      .
       acc-qta-pri-612.
           add       1                    to   w-acc-qta-psx-c02      .
           if        w-acc-qta-psx-c02    >    5
                     go to acc-qta-pri-614.
           move      w-let-arc-aaf-psp
                    (w-acc-qta-psx-c01,
                     w-acc-qta-psx-c02)
                                          to   w-det-prz-acq-psp
                                              (w-acc-qta-psx-c01
                                               w-acc-qta-psx-c02)     .
           go to     acc-qta-pri-612.
       acc-qta-pri-614.
           go to     acc-qta-pri-610.
       acc-qta-pri-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-sav-qta-psx        to   w-det-prz-qta-pre      .
           move      w-sav-qta-cfr        to   w-det-prz-qta-att      .
           perform   det-prz-acq-000      thru det-prz-acq-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-per-scr-000      thru det-per-scr-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-qta-pri-640.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-qta-pri-700.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-pri-720.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-qta-pri-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-pri-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-pri-100.
       acc-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' primaria                *
      *    *-----------------------------------------------------------*
       vis-qta-pri-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-dec-qta (1)
                                          to   v-dec
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
      *
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-acq (1)
                                          to   v-num
           else if   w-rig-snx-tum (1)    =    "S"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-fda (1)
                                          to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-pri-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag di saldo riga ordine forni-  *
      *    * tore                                                      *
      *    *-----------------------------------------------------------*
       vis-orf-fzs-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-orf-snx        not  = "S" or
                     w-rig-orf-prt (1)    =    zero  or
                     w-rig-orf-prg (1)    =    zero
                     go to vis-orf-fzs-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      55                   to   v-pos                  .
           if        w-rig-orf-fzs (1)    =    "S"
                     move  "[S]"          to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-orf-fzs-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' secondaria      *
      *    *-----------------------------------------------------------*
       acc-qta-sec-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-qta-sec-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "F"
                     go to acc-qta-sec-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-sec-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"  and
                     w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-qta-sec-999.
      *                      *-----------------------------------------*
      *                      * Test su trasformazione unita' di misura *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    not  = "S" and
                     w-rig-snx-tum (1)    not  = "P"
                     go to acc-qta-sec-999.
       acc-qta-sec-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-psx
           else      move  w-rig-qta-acq (1)
                                          to   w-sav-qta-psx          .
       acc-qta-sec-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-umf-tum (1)
                                          to   w-sav-umi-sec
           else      move  w-rig-umi-acq (1)
                                          to   w-sav-umi-sec          .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "("
                                delimited by   size
                     w-sav-umi-sec
                                delimited by   size
                     "             )"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   v-num
           else      move  w-rig-qta-acq (1)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-sec-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-sec-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  v-num          to   w-rig-qta-fda (1)
           else      move  v-num          to   w-rig-qta-acq (1)      .
      *              *-------------------------------------------------*
      *              * Valore impostato in comodo per confronti        *
      *              *-------------------------------------------------*
           move      v-num                to   w-sav-qta-cfr          .
      *              *-------------------------------------------------*
      *              * Visualizzazione quantita' secondaria            *
      *              *-------------------------------------------------*
           perform   vis-qta-sec-000      thru vis-qta-sec-999        .
       acc-qta-sec-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-sec-425.
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        not  = zero
                     go to acc-qta-sec-450.
           if        v-key                not  = "UP  "
                     go to acc-qta-sec-100.
       acc-qta-sec-450.
      *                  *---------------------------------------------*
      *                  * Fine controlli                              *
      *                  *---------------------------------------------*
           go to     acc-qta-sec-600.
       acc-qta-sec-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-sec-625.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-sec-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-qta-sec-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-sec-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-sec-100.
       acc-qta-sec-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' secondaria              *
      *    *-----------------------------------------------------------*
       vis-qta-sec-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-rig-snx-tum (1)    not  = "S" and
                     w-rig-snx-tum (1)    not  = "P"
                     go to vis-qta-sec-999.
       vis-qta-sec-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
       vis-qta-sec-200.
      *                  *---------------------------------------------*
      *                  * Preparazione valore numerico da editare     *
      *                  *---------------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-qta-fda (1)
                                          to   w-sav-qta-cfr
           else      move  w-rig-qta-acq (1)
                                          to   w-sav-qta-cfr          .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore da editare  *
      *                  *---------------------------------------------*
           if        w-sav-qta-cfr        =    zero
                     go to vis-qta-sec-300
           else      go to vis-qta-sec-400.
       vis-qta-sec-300.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione a spaces                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-sec-999.
       vis-qta-sec-400.
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-nde-tum (1)
                                          to   v-dec
           else      move  w-rig-dec-qta (1)
                                          to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      w-sav-qta-cfr        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione unita' di misura           *
      *                      *-----------------------------------------*
           if        w-rig-snx-tum (1)    =    "P"
                     move  w-rig-umf-tum (1)
                                          to   w-sav-umi-sec
           else      move  w-rig-umi-acq (1)
                                          to   w-sav-umi-sec          .
      *                      *-----------------------------------------*
      *                      * Composizione area editata completa      *
      *                      *-----------------------------------------*
           move      spaces               to   v-alf                  .
           string    "("
                                delimited by   size
                     w-sav-umi-sec
                                delimited by   size
                     " "
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into v-alf                  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      37                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-sec-999.
       vis-qta-sec-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Terza quantita'                            *
      *    *-----------------------------------------------------------*
       acc-qta-a03-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-col-rig-snx    not  = "S"
                     go to acc-qta-a03-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-a03-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-a03 (1)    to   w-sav-qta-a03          .
       acc-qta-a03-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
      *
           move      w-prs-col-rig-car    to   v-car                  .
           if        v-car                >    03
                     move  03             to   v-car                  .
      *
           move      w-prs-col-rig-dec    to   v-dec                  .
           if        v-dec                >    03
                     move  03             to   v-dec                  .
      *
           move      spaces               to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-rig-qta-a03 (1)    >    zero
                     move  "FIND"         to   v-pfk (03)             .
      *
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-qta-a03 (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-a03-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-a03-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-a03 (1)      .
       acc-qta-a03-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-qta-a03-400
           else      go to acc-qta-a03-420.
       acc-qta-a03-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non superi max elementi            *
      *                  *---------------------------------------------*
           if        w-rig-qta-a03 (1)    not  > w-prs-col-rig-max
                     go to acc-qta-a03-410.
      *                  *---------------------------------------------*
      *                  * Editing massimo elementi                    *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-prs-col-rig-max    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      65                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Il massimo numero colli accettabile e'"
                                          to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "!"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      w-all-str-alf        to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Reimpostazione                              *
      *                  *---------------------------------------------*
           go to     acc-qta-a03-100.
       acc-qta-a03-410.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-qta-a03 (1)    =    w-sav-qta-a03
                     go to acc-qta-a03-800.
       acc-qta-a03-420.
      *                  *---------------------------------------------*
      *                  * Subroutine di accettazione castelletto      *
      *                  * colli                                       *
      *                  *---------------------------------------------*
           perform   exe-exp-col-000      thru exe-exp-col-999        .
       acc-qta-a03-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-a03-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-a03-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-a03-100.
       acc-qta-a03-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Terza quantita'                         *
      *    *-----------------------------------------------------------*
       vis-qta-a03-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-col-rig-snx    not  = "S"
                     go to vis-qta-a03-999.
       vis-qta-a03-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
      *
           move      w-prs-col-rig-car    to   v-car                  .
           if        v-car                >    03
                     move  03             to   v-car                  .
      *
           move      w-prs-col-rig-dec    to   v-dec                  .
           if        v-dec                >    03
                     move  03             to   v-dec                  .
      *
           move      spaces               to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      w-rig-qta-a03 (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-a03-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo di acquisto        *
      *    *-----------------------------------------------------------*
       acc-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-prz-acq-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-acq-999.
       acc-prz-acq-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-prz-acq (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-prz-acq-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-acq (1)      .
       acc-prz-acq-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-prz-acq-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-prz-acq-610.
      *                      *-----------------------------------------*
      *                      * Se percentuali di sconto gia' tutte a   *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-acq-610.
      *                      *-----------------------------------------*
      *                      * Trattamento percentuali di sconto       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-prz-acq-610.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-acq-620.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-acq-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-prz-acq-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-acq-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-acq-100.
       acc-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Prezzo di acquisto                *
      *    *-----------------------------------------------------------*
       vis-prz-acq-000.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      w-rig-prz-acq (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      v-edt                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-acq-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Sigla lotto                          *
      *    *-----------------------------------------------------------*
       acc-lot-sgl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to acc-lot-sgl-999.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M"
                     go to acc-lot-sgl-999.
       acc-lot-sgl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-lot-sgl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-lot-sgl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-lot-sgl-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-lot-sgl (1)      .
       acc-lot-sgl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-lot-sgl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-lot-sgl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-lot-sgl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-lot-sgl-100.
       acc-lot-sgl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla lotto                       *
      *    *-----------------------------------------------------------*
       vis-lot-sgl-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to vis-lot-sgl-999.
       vis-lot-sgl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-rig-lot-sgl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-lot-sgl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data lotto                           *
      *    *-----------------------------------------------------------*
       acc-lot-dat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to acc-lot-dat-999.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M"
                     go to acc-lot-dat-999.
       acc-lot-dat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      18                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-lot-dat (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-lot-dat-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-lot-dat-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-lot-dat (1)      .
       acc-lot-dat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-lot-dat-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-lot-dat-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-lot-dat-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-lot-dat-100.
       acc-lot-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data lotto (sigla variante)       *
      *    *-----------------------------------------------------------*
       vis-lot-dat-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-sgl-lot-snx    not  = "S"
                     go to vis-lot-dat-999.
       vis-lot-dat-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-rig-lot-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-lot-dat-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per legame   *
      *    * valutario                                                 *
      *    *-----------------------------------------------------------*
       acc-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa al   *
      *                      * legame valutario                        *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-sgl-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-sgl-vpl-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-sav-sgl-vpl          .
       acc-sgl-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpl (1)    to   w-cod-cod-zvl-cod      .
           move      18                   to   w-cod-cod-zvl-lin      .
           move      54                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpl-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpl-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpl-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpl-110.
       acc-sgl-vpl-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
       acc-sgl-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpl (1)      .
       acc-sgl-vpl-400.
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpl-100.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per fatturazione                            *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-tes-sgl-vpf (1)
                     go to acc-sgl-vpl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per fatturazione del documento 
      -              "!              "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-500.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta per legame valutario uguale *
      *                  * a sigla vauta base : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    c-sgl
                     go to acc-sgl-vpl-100.
       acc-sgl-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    w-sav-sgl-vpl
                     go to acc-sgl-vpl-800.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che il valore sia esi- *
      *                  * stente o no                                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-sgl-vpl-620
           else      go to acc-sgl-vpl-640.
       acc-sgl-vpl-620.
      *                  *---------------------------------------------*
      *                  * Se valore non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori connessi         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-dec-vpl (1)      .
           move      spaces               to   w-rig-tdc-vpl (1)      .
           move      zero                 to   w-rig-prz-vpl (1)      .
           move      zero                 to   w-rig-cdc-vpl (1)      .
           move      zero                 to   w-rig-ccr-vpl (1)      .
           move      zero                 to   w-rig-plm-vpl (1)      .
           move      spaces               to   w-rig-tlm-vpl (1)      .
           move      spaces               to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori connessi         *
      *                      *-----------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-700.
       acc-sgl-vpl-640.
      *                  *---------------------------------------------*
      *                  * Se valore esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori connessi         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Prezzo di riferimento               *
      *                          *-------------------------------------*
           move      w-rig-prz-acq (1)    to   w-rig-prz-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio                                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           if        w-tes-dat-doc (1)    not  = zero
                     move  w-tes-dat-doc (1)
                                          to   w-coe-cmb-vlt-drc
           else      move  w-tes-dat-reg  to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpl-642.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-642.
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio                              *
      *                          *-------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Tipo di limitazione                 *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-tlm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Momento di applicazione cambio      *
      *                          *-------------------------------------*
           move      "F"                  to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-700.
       acc-sgl-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-sgl-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpl-100.
       acc-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Sigla valuta per *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       vis-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-rig-sgl-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Coefficiente di cambio    *
      *    * di riferimento per legame valutario                       *
      *    *-----------------------------------------------------------*
       acc-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-ccr-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-ccr-vpl-999.
       acc-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           if        w-tes-dat-doc (1)    not  = zero
                     move  w-tes-dat-doc (1)
                                          to   w-coe-cmb-vlt-drc
           else      move  w-tes-dat-reg  to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           move      "N"                  to   w-coe-cmb-vlt-snd      .
           move      w-rig-ccr-vpl (1)    to   w-coe-cmb-vlt-cdc      .
           move      18                   to   w-coe-cmb-vlt-lin      .
           move      58                   to   w-coe-cmb-vlt-pos      .
           move      zero                 to   w-coe-cmb-vlt-dln      .
           move      zero                 to   w-coe-cmb-vlt-dps      .
           move      "BD"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-ccr-vpl-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-ccr-vpl-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-ccr-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ccr-vpl-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-ccr-vpl-110.
       acc-ccr-vpl-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-ccr-vpl-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
       acc-ccr-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ccr-vpl (1)      .
       acc-ccr-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore zero non ammesso a meno che non si   *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    not  = zero
                     go to acc-ccr-vpl-600.
           if        v-key                =    "UP  "
                     go to acc-ccr-vpl-600
           else      go to acc-ccr-vpl-100.
       acc-ccr-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccr-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-ccr-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ccr-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ccr-vpl-100.
       acc-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Coefficiente di  *
      *    * cambio per legame valutario                               *
      *    *-----------------------------------------------------------*
       vis-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-rig-ccr-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuale di tolleranza *
      *    * per legame valutario                                      *
      *    *-----------------------------------------------------------*
       acc-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-plm-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta                    *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-plm-vpl-999.
       acc-plm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
       acc-plm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-plm-vpl (1)      .
       acc-plm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-plm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    not  = zero
                     go to acc-plm-vpl-700.
      *                  *---------------------------------------------*
      *                  * Normalizzazione tipo di limitazione per le- *
      *                  * game valutario                              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     move  spaces         to   w-rig-tlm-vpl (1)
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999        .
       acc-plm-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-plm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-plm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-plm-vpl-100.
       acc-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Percentuale di   *
      *    * tolleranza per legame valutario                           *
      *    *-----------------------------------------------------------*
       vis-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Tipo di limitazione per   *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       acc-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to acc-tlm-vpl-999.
           if        w-prs-leg-val        =    "N" and
                     w-rig-snx-fda (1)    not  = "S"
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame         *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su percentuale di limitazione per  *
      *                      * legame                                  *
      *                      *-----------------------------------------*
           if        w-rig-plm-vpl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    =    spaces
                     move  "T"            to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
       acc-tlm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tlm-vpl-400.
      *                  *---------------------------------------------*
      *                  * Find per note operative                     *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-fnd-tlm-vpl-tlm      .
           perform   fnd-tlm-vpl-000      thru fnd-tlm-vpl-999        .
           move      w-fnd-tlm-vpl-tlm    to   w-rig-tlm-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tlm-vpl-100.
       acc-tlm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     go to acc-tlm-vpl-500.
           if        v-key                =    "UP  "
                     go to acc-tlm-vpl-600
           else      go to acc-tlm-vpl-100.
       acc-tlm-vpl-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = "T" and
                     w-rig-tlm-vpl (1)    not  = "F" and
                     w-rig-tlm-vpl (1)    not  = "M"
                     go to acc-tlm-vpl-100.
       acc-tlm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tlm-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-tlm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tlm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-tlm-vpl-100.
       acc-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Tipo di limita-  *
      *    * zione per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-leg-val        =    "*"
                     go to vis-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuali sconto in riga*
      *    *-----------------------------------------------------------*
       acc-per-scr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-per-scr-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-per-scr-ctr      .
       acc-per-scr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           if        w-acc-per-scr-ctr    >    5
                     subtract  5          from v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
       acc-per-scr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-per-scr
                                              (1, w-acc-per-scr-ctr)  .
       acc-per-scr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-acq (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-per-scr-605.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-per-scr-610.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione dell'impostazione        *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-scr-650
           else if   v-key                =    "DOWN"
                     go to acc-per-scr-700
           else if   v-key                =    "TAB "
                     go to acc-per-scr-710
           else if   v-key                =    "[1] "
                     go to acc-per-scr-640
           else if   v-key                =    "DO  "
                     go to acc-per-scr-800
           else      go to acc-per-scr-700.
       acc-per-scr-640.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento prezzo di acquisto            *
      *                  *---------------------------------------------*
           move      w-rig-prz-net (1)    to   w-rig-prz-acq (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Visualizzazione prezzo di acquisto          *
      *                  *---------------------------------------------*
           perform   vis-prz-acq-000      thru vis-prz-acq-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Uscita come per Down                        *
      *                  *---------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr    =    1
                     go to acc-per-scr-999.
           subtract  1                    from w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-700.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-710.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr        =    05
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-per-scr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-per-scr-100.
       acc-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di sconto in riga     *
      *    *-----------------------------------------------------------*
       vis-per-scr-000.
           move      zero                 to   w-acc-per-scr-ctr      .
       vis-per-scr-200.
           add       1                    to   w-acc-per-scr-ctr      .
           if        w-acc-per-scr-ctr    >    5
                     go to vis-per-scr-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      w-rig-per-scr 
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-per-scr-200.
       vis-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Importo in riga           *
      *    *-----------------------------------------------------------*
       acc-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-imp-rig-999.
      *                      *-----------------------------------------*
      *                      * Se in anagrafica Fornitore e' indicato  *
      *                      * che l'importo puo' essere modificato,   *
      *                      * ad accettazione                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-tes-tip-mci (1)    not  = "M"
                     go to acc-imp-rig-050.
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-imp-rig-100.
       acc-imp-rig-050.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-imp-rig-999.
       acc-imp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           subtract  w-tes-dec-vpf (1)    from v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-imp-rig (1)    to   v-num                  .
           if        w-tes-dec-vpf (1)    =    1
                     divide 10            into v-num
           else if   w-tes-dec-vpf (1)    =    2
                     divide 100           into v-num
           else if   w-tes-dec-vpf (1)    =    3
                     divide 1000          into v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           if        w-tes-dec-vpf (1)    =    1
                     multiply 10          by   v-num
           else if   w-tes-dec-vpf (1)    =    2
                     multiply 100         by   v-num
           else if   w-tes-dec-vpf (1)    =    3
                     multiply 1000        by   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-rig (1)      .
       acc-imp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione a meno    *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    not  = zero
                     go to acc-imp-rig-600.
           if        v-key                =    "UP  "
                     go to acc-imp-rig-600
           else      go to acc-imp-rig-100.
       acc-imp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-rig-100.
       acc-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo in riga                   *
      *    *-----------------------------------------------------------*
       vis-imp-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           subtract  w-tes-dec-vpf (1)    from v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      19                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           if        w-tes-dec-vpf (1)    =    1
                     divide 10            into v-num
           else if   w-tes-dec-vpf (1)    =    2
                     divide 100           into v-num
           else if   w-tes-dec-vpf (1)    =    3
                     divide 1000          into v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice iva                *
      *    *-----------------------------------------------------------*
       acc-civ-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-civ-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-civ-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-civ-rig-100.
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-civ-rig-999.
       acc-civ-rig-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-rig-civ-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      20                   to   w-cod-mne-zci-lin      .
           move      21                   to   w-cod-mne-zci-pos      .
           move      20                   to   w-cod-mne-zci-dln      .
           move      32                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-civ-rig-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-civ-rig-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-civ-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-civ-rig-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-civ-rig-110.
       acc-civ-rig-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-civ-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-civ-rig-999.
       acc-civ-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-civ-rig (1)      .
       acc-civ-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-rig-civ-rig (1)    to   d-imp-iva-cod-iva      .
           move      "5"                  to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                      *-----------------------------------------*
      *                      * Se errato : messaggio di errore         *
      *                      *-----------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-civ-rig-500.
      *                          *-------------------------------------*
      *                          * Messaggio di avviso                 *
      *                          *-------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-civ-rig-100.
       acc-civ-rig-500.
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      d-imp-iva-msg-exi    to   w-rig-civ-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-civ-rig-des-000  thru vis-civ-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero : reimpostazione a meno*
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-rig-civ-rig (1)    not  = zero
                     go to acc-civ-rig-600.
           if        v-key                =    "UP  "
                     go to acc-civ-rig-600
           else      go to acc-civ-rig-100.
       acc-civ-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-civ-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-civ-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-civ-rig-100.
       acc-civ-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice iva                *
      *    *-----------------------------------------------------------*
       vis-civ-rig-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-rig-civ-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione codice IVA    *
      *    *-----------------------------------------------------------*
       vis-civ-rig-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-civ-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-civ-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice contropartita      *
      *    *-----------------------------------------------------------*
       acc-ctp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : uscita                      *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-ctp-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ctp-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ctp-rig-100.
       acc-ctp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rig-ctp-rig (1)    to   w-cod-mne-pdc-cod      .
           move      21                   to   w-cod-mne-pdc-lin      .
           move      21                   to   w-cod-mne-pdc-pos      .
           move      21                   to   w-cod-mne-pdc-dln      .
           move      32                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-rig-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-rig-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-rig-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-rig-110.
       acc-ctp-rig-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ctp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ctp-rig-999.
       acc-ctp-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ctp-rig (1)      .
       acc-ctp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-rig-ctp-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctp-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-rig-des-000  thru vis-ctp-rig-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-rig-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-ctp-rig (1)    =    zero
                     go to acc-ctp-rig-100.
      *                  *---------------------------------------------*
      *                  * Se impostata contropartita in testata       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-ctp-acq (1)    =    zero
                     go to acc-ctp-rig-600.
      *                      *-----------------------------------------*
      *                      * Confronto con contropartita impostata   *
      *                      *-----------------------------------------*
           if        w-rig-ctp-rig (1)    =    w-tes-ctp-acq (1)
                     go to acc-ctp-rig-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Attenzione: contropartita diversa da quella impost
      -              "ata per il doc."    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-ctp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ctp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ctp-rig-100.
       acc-ctp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita acquisti in *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       vis-ctp-rig-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rig-ctp-rig (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione contropartita *
      *    * acquisti in riga                                          *
      *    *-----------------------------------------------------------*
       vis-ctp-rig-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-ctp-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Espansione per accettazione contrassegni e quantita' re-  *
      *    * lativi ai colli                                           *
      *    *-----------------------------------------------------------*
       exe-exp-col-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se espansione da accettare             *
      *                  *---------------------------------------------*
           if        w-rig-qta-a03 (1)    =    zero
                     go to exe-exp-col-999.
      *                  *---------------------------------------------*
      *                  * Determinazione massimo elementi in base al  *
      *                  * numero di colli indicato                    *
      *                  *---------------------------------------------*
           move      w-rig-qta-a03 (1)    to   w-acc-cts-col-max      .
      *                  *---------------------------------------------*
      *                  * Salvataggio castelletto contrassegni        *
      *                  *---------------------------------------------*
           perform   exe-exp-col-sav-000  thru exe-exp-col-sav-999    .
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-030.
       exe-exp-col-040.
      *                  *---------------------------------------------*
      *                  * Area impostazione dati                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Titoli all'interno del box              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      " Contrassegno collo     Quantita'  "
                                          to   v-alf                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      "--------------------   ----------- "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      "-----------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-050.
      *                  *---------------------------------------------*
      *                  * Normalizzazioni preliminari                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-acc-cts-col-esc      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione pagina contrassegni a par-  *
      *                  * tire dall'elemento numero 1                 *
      *                  *---------------------------------------------*
           move      1                    to   w-acc-cts-col-n1v      .
           perform   exe-exp-col-900      thru exe-exp-col-909        .
       exe-exp-col-060.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-070.
      *                  *---------------------------------------------*
      *                  * Primo elemento visualizzato : 1             *
      *                  *---------------------------------------------*
           move      1                    to   w-acc-cts-col-pev      .
      *                  *---------------------------------------------*
      *                  * Numero elemento in accettazione : 1         *
      *                  *---------------------------------------------*
           move      1                    to   w-acc-cts-col-nel      .
      *                  *---------------------------------------------*
      *                  * Ad accettazione                             *
      *                  *---------------------------------------------*
           go to     exe-exp-col-100.
       exe-exp-col-080.
      *              *-------------------------------------------------*
      *              * Visualizzazione pagina se necessario            *
      *              *-------------------------------------------------*
       exe-exp-col-082.
           move      w-acc-cts-col-pev    to   w-acc-cts-col-c0a      .
           move      w-acc-cts-col-c0a    to   w-acc-cts-col-c0b      .
           add       w-acc-cts-col-lpp    to   w-acc-cts-col-c0b      .
           subtract  1                    from w-acc-cts-col-c0b      .
      *
           if        w-acc-cts-col-nel    <    w-acc-cts-col-c0a or
                     w-acc-cts-col-nel    >    w-acc-cts-col-c0b
                     go to exe-exp-col-084
           else      go to exe-exp-col-086.
       exe-exp-col-084.
           move      w-acc-cts-col-nel    to   w-acc-cts-col-n1v      .
           subtract  1                    from w-acc-cts-col-n1v      .
           divide    w-acc-cts-col-lpp    into w-acc-cts-col-n1v      .
           multiply  w-acc-cts-col-lpp    by   w-acc-cts-col-n1v      .
           add       1                    to   w-acc-cts-col-n1v      .
           move      w-acc-cts-col-n1v    to   w-acc-cts-col-pev      .
           perform   exe-exp-col-900      thru exe-exp-col-909        .
       exe-exp-col-086.
           go to     exe-exp-col-100.
       exe-exp-col-100.
      *              *-------------------------------------------------*
      *              * Accettazione linea                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento e visualizzazione totale      *
      *                  *---------------------------------------------*
           perform   exe-exp-col-tot-000  thru exe-exp-col-tot-999    .
       exe-exp-col-150.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti linea         *
      *                  *---------------------------------------------*
           move      w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          to   w-acc-cts-col-sst      .
           move      w-rig-col-qta
                    (1, w-acc-cts-col-nel)
                                          to   w-acc-cts-col-ssq      .
       exe-exp-col-200.
      *                  *---------------------------------------------*
      *                  * Calcolo linea video                         *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0r      .
           subtract  w-acc-cts-col-pev    from w-acc-cts-col-c0r      .
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0r      .
      *                  *---------------------------------------------*
      *                  * Accettazione contrassegno collo             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Parametri                               *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-acc-cts-col-c0r    to   v-lin                  .
           move      44                   to   v-pos                  .
      *                      *-----------------------------------------*
      *                      * Tasti funzione                          *
      *                      *-----------------------------------------*
           perform   exe-exp-col-ttf-000  thru exe-exp-col-ttf-999    .
       exe-exp-col-208.
      *                      *-----------------------------------------*
      *                      * Valore accettato                        *
      *                      *-----------------------------------------*
           move      w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Valore in campo di destinazione         *
      *                      *-----------------------------------------*
           move      v-alf                to   w-rig-col-cts
                                              (1, w-acc-cts-col-nel)  .
       exe-exp-col-205.
      *                      *-----------------------------------------*
      *                      * Se Exit e Select                        *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT" or
                     v-key                =    "SLCT"
                     move  "#"            to   w-acc-cts-col-esc
                     go to exe-exp-col-800.
      *                      *-----------------------------------------*
      *                      * Se Return                               *
      *                      *-----------------------------------------*
           if        v-key                =    spaces
                     go to exe-exp-col-425.
      *                      *-----------------------------------------*
      *                      * In ogni altro caso il valore deve esse- *
      *                      * re inalterato                           *
      *                      *-----------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          not  = w-acc-cts-col-sst
                     go to exe-exp-col-200.
       exe-exp-col-210.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to exe-exp-col-225.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Se sul primo : stop                 *
      *                          *-------------------------------------*
           subtract  1                    from w-acc-cts-col-nel      .
           if        w-acc-cts-col-nel    =    zero
                     move  1              to   w-acc-cts-col-nel
                     go to exe-exp-col-100
           else      go to exe-exp-col-080.
       exe-exp-col-225.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "DOWN"
                     go to exe-exp-col-250.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Se sull'ultimo : ad uscita          *
      *                          *-------------------------------------*
           if        w-acc-cts-col-fce    =    spaces
                     add   1              to   w-acc-cts-col-nel      .
           if        w-acc-cts-col-nel    >    w-acc-cts-col-max
                     move  "DOWN"         to   v-key
                     go to exe-exp-col-800.
           if        w-acc-cts-col-nel    =    1
                     go to exe-exp-col-230
           else      go to exe-exp-col-240.
       exe-exp-col-230.
           if        w-rig-col-cts (1, 1) =    spaces and
                     w-rig-col-cts (1, 2) =    spaces
                     move  "DOWN"         to   v-key
                     go to exe-exp-col-800
           else      go to exe-exp-col-080.
       exe-exp-col-240.
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0a      .
           move      w-acc-cts-col-c0a    to   w-acc-cts-col-c0b      .
           subtract  1                    from w-acc-cts-col-c0b      .
           if        w-rig-col-cts
                    (1, w-acc-cts-col-c0a)
                                          =    spaces and
                     w-rig-col-cts
                    (1, w-acc-cts-col-c0b)
                                          =    spaces
                     move  "DOWN"         to   v-key
                     go to exe-exp-col-800
           else      go to exe-exp-col-080.
       exe-exp-col-250.
      *                      *-----------------------------------------*
      *                      * Se Find                                 *
      *                      *-----------------------------------------*
       exe-exp-col-260.
      *                      *-----------------------------------------*
      *                      * Se Insr                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        v-key                not  = "INSR"
                     go to exe-exp-col-275.
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-940      thru exe-exp-col-949        .
      *                          *-------------------------------------*
      *                          * Segnale di almeno una modifica      *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-acc-flg-aum      .
      *                          *-------------------------------------*
      *                          * A reimpostare                       *
      *                          *-------------------------------------*
           go to     exe-exp-col-080.
       exe-exp-col-275.
      *                      *-----------------------------------------*
      *                      * Se Do                                   *
      *                      *-----------------------------------------*
           if        v-key                not  = "DO  "
                     go to exe-exp-col-300.
      *                          *-------------------------------------*
      *                          * Controlli per tasto Do              *
      *                          *-------------------------------------*
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    =    spaces
                     move  "S"            to   w-cnt-tus-acc-pie
                     go to exe-exp-col-280
           else      move  spaces         to   w-cnt-tus-acc-pie
                     go to exe-exp-col-200.
       exe-exp-col-280.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           move      "S"                  to   w-cnt-tus-acc-pie      .
           go to     exe-exp-col-800.
       exe-exp-col-300.
      *                      *-----------------------------------------*
      *                      * Se Remv                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "REMV"
                     go to exe-exp-col-325.
      *                          *-------------------------------------*
      *                          * Compattamento in ogni caso          *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-930      thru exe-exp-col-939        .
      *                          *-------------------------------------*
      *                          * Segnale di almeno una modifica      *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-acc-flg-aum      .
      *                          *-------------------------------------*
      *                          * A reimpostare                       *
      *                          *-------------------------------------*
           go to     exe-exp-col-080.
       exe-exp-col-325.
      *                      *-----------------------------------------*
      *                      * Se Prsc                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "PRSC"
                     go to exe-exp-col-350.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Se su prima facciata : uscita       *
      *                          *-------------------------------------*
           if        w-acc-cts-col-nel    not  > w-acc-cts-col-lpp
                     move  "UP  "         to   v-key
                     go to exe-exp-col-800.
      *                          *-------------------------------------*
      *                          * Al primo elemento della facciata    *
      *                          * precedente                          *
      *                          *-------------------------------------*
           subtract  1                    from w-acc-cts-col-nel      .
           divide    w-acc-cts-col-lpp    into w-acc-cts-col-nel      .
           subtract  1                    from w-acc-cts-col-nel      .
           multiply  w-acc-cts-col-lpp    by   w-acc-cts-col-nel      .
           add       1                    to   w-acc-cts-col-nel      .
           go to     exe-exp-col-080.
       exe-exp-col-350.
      *                      *-----------------------------------------*
      *                      * Se Nxsc                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "NXSC"
                     go to exe-exp-col-375.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Se su ultima pagina : a reimposta-  *
      *                          *                       zione         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0a      .
           subtract  1                    from w-acc-cts-col-c0a      .
           divide    w-acc-cts-col-lpp    into w-acc-cts-col-c0a      .
           add       1                    to   w-acc-cts-col-c0a      .
           multiply  w-acc-cts-col-lpp    by   w-acc-cts-col-c0a      .
           add       1                    to   w-acc-cts-col-c0a      .
      *                          *-------------------------------------*
      *                          * Test se fine tabella                *
      *                          *-------------------------------------*
           if        w-acc-cts-col-c0a    >    w-acc-cts-col-max
                     go to exe-exp-col-100.
      *                          *-------------------------------------*
      *                          * Test se elemento vuoto              *
      *                          *-------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-c0a)
                                          =    spaces
                     go to exe-exp-col-100.
      *                          *-------------------------------------*
      *                          * Al primo elemento della facciata    *
      *                          * successiva                          *
      *                          *-------------------------------------*
           move      w-acc-cts-col-c0a    to   w-acc-cts-col-nel      .
           go to     exe-exp-col-080.
       exe-exp-col-375.
      *                      *-----------------------------------------*
      *                      * Se Back                                 *
      *                      *-----------------------------------------*
           if        v-key                not  = "BACK"
                     go to exe-exp-col-400.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Al primo elemento                   *
      *                          *-------------------------------------*
           move      1                    to   w-acc-cts-col-nel      .
           go to     exe-exp-col-080.
       exe-exp-col-400.
      *                      *-----------------------------------------*
      *                      * Se Tab                                  *
      *                      *-----------------------------------------*
           if        v-key                not  = "TAB "
                     go to exe-exp-col-425.
      *                          *-------------------------------------*
      *                          * Compattamento se necessario         *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-920      thru exe-exp-col-929        .
      *                          *-------------------------------------*
      *                          * Dopo l'ultimo elemento inserito     *
      *                          *-------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-max)
                                          not  = spaces
                     move  w-acc-cts-col-max
                                          to   w-acc-cts-col-nel
                     go to exe-exp-col-080.
           move      w-acc-cts-col-max    to   w-acc-cts-col-nel      .
       exe-exp-col-405.
           if        w-acc-cts-col-nel    =    zero
                     go to exe-exp-col-410.
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          =    spaces
                     subtract  1          from w-acc-cts-col-nel
                     go to     exe-exp-col-405.
       exe-exp-col-410.
           add       1                    to   w-acc-cts-col-nel      .
           go to     exe-exp-col-080.
       exe-exp-col-425.
      *                      *-----------------------------------------*
      *                      * Se Return                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controllo valore impostato          *
      *                          *-------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          =    spaces
                     go to exe-exp-col-450
           else      go to exe-exp-col-500.
       exe-exp-col-450.
      *                          *-------------------------------------*
      *                          * Se impostato spaces                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se il valore precedente era a   *
      *                              * spaces : come per Down          *
      *                              *---------------------------------*
           if        w-acc-cts-col-sst    =    spaces
                     move  "DOWN"         to   v-key
                     go to exe-exp-col-225.
      *                              *---------------------------------*
      *                              * Altrimenti come per Remv        *
      *                              *---------------------------------*
           move      "REMV"               to   v-key                  .
           go to     exe-exp-col-300.
       exe-exp-col-500.
      *                  *=============================================*
      *                  * Accettazione data scadenza                  *
      *                  *---------------------------------------------*
       exe-exp-col-600.
      *                  *=============================================*
      *                  * Accettazione quantita'                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Eventuale default                       *
      *                      *-----------------------------------------*
           move      w-acc-cts-col-dif    to   w-acc-cts-col-dia      .
           if        w-rig-col-qta
                    (1, w-acc-cts-col-nel)
                                          =    zero
                     move  w-acc-cts-col-dia
                                          to   w-rig-col-qta
                                              (1, w-acc-cts-col-nel)  .
      *                      *-----------------------------------------*
      *                      * Preparazione parametri                  *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BG"                 to   v-edm                  .
      *
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0r      .
           subtract  w-acc-cts-col-pev    from w-acc-cts-col-c0r      .
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0r      .
           move      w-acc-cts-col-c0r    to   v-lin                  .
      *
           move      64                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-rig-col-qta
                    (1, w-acc-cts-col-nel)
                                          to   v-num                  .
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Se Exit                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "EXIT"
                     go to exe-exp-col-610.
      *                      *-----------------------------------------*
      *                      * Se Remv                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "REMV"
                     go to exe-exp-col-620.
      *                      *-----------------------------------------*
      *                      * Se Delt                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to exe-exp-col-800.
      *                      *-----------------------------------------*
      *                      * Se Return o Down                        *
      *                      *-----------------------------------------*
           if        v-key                =    spaces or
                     v-key                =    "DOWN"
                     go to exe-exp-col-640.
      *                      *-----------------------------------------*
      *                      * In ogni altro caso il valore deve esse- *
      *                      * re inalterato                           *
      *                      *-----------------------------------------*
           if        v-num                not  = w-acc-cts-col-ssq
                     go to exe-exp-col-600.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     go to exe-exp-col-630.
           go to     exe-exp-col-640.
       exe-exp-col-610.
      *                      *-----------------------------------------*
      *                      * Se Exit                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ripristino valori linea             *
      *                          *-------------------------------------*
           move      w-acc-cts-col-sst    to   w-rig-col-cts
                                              (1, w-acc-cts-col-nel)  .
           move      w-acc-cts-col-ssq    to   w-rig-col-qta
                                              (1, w-acc-cts-col-nel)  .
      *                          *-------------------------------------*
      *                          * Rivisualizzazione linea             *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nev      .
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0r      .
           subtract  w-acc-cts-col-pev    from w-acc-cts-col-c0r      .
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0r      .
           add       1                    to   w-acc-cts-col-c0r      .
           perform   exe-exp-col-910      thru exe-exp-col-919        .
      *                          *-------------------------------------*
      *                          * A reimpostazione linea              *
      *                          *-------------------------------------*
           go to     exe-exp-col-080.
       exe-exp-col-620.
      *                      *-----------------------------------------*
      *                      * Se Remv                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Compattamento in ogni caso          *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nec      .
           perform   exe-exp-col-930      thru exe-exp-col-939        .
      *                          *-------------------------------------*
      *                          * A reimpostazione linea              *
      *                          *-------------------------------------*
           go to     exe-exp-col-080.
       exe-exp-col-630.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ritorno ad impostazione precedente  *
      *                          *-------------------------------------*
           go to     exe-exp-col-500.
       exe-exp-col-640.
      *                      *-----------------------------------------*
      *                      * Se Return o Down                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Controllo valore impostato          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * No zero                         *
      *                              *---------------------------------*
           if        v-num                =    zero
                     go to exe-exp-col-600.
      *                          *-------------------------------------*
      *                          * Valore in campo di destinazione     *
      *                          *-------------------------------------*
           move      v-num                to   w-rig-col-qta
                                              (1, w-acc-cts-col-nel)  .
      *                          *-------------------------------------*
      *                          * Rivisualizzazione linea             *
      *                          *-------------------------------------*
           move      w-acc-cts-col-nel    to   w-acc-cts-col-nev      .
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0r      .
           subtract  w-acc-cts-col-pev    from w-acc-cts-col-c0r      .
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0r      .
           add       1                    to   w-acc-cts-col-c0r      .
           perform   exe-exp-col-910      thru exe-exp-col-919        .
       exe-exp-col-700.
      *                  *---------------------------------------------*
      *                  * Passaggio ad elemento successivo            *
      *                  *---------------------------------------------*
      *                          *-------------------------------------*
      *                          * Incremento numero elemento          *
      *                          *-------------------------------------*
           add       1                    to   w-acc-cts-col-nel      .
      *                          *-------------------------------------*
      *                          * Se fine elementi : uscita           *
      *                          *-------------------------------------*
           if        w-acc-cts-col-nel    >    w-acc-cts-col-max
                     move  spaces         to   v-key
                     go to exe-exp-col-800.
      *                          *-------------------------------------*
      *                          * Altrimenti : ad impostazione linea  *
      *                          *-------------------------------------*
           go to     exe-exp-col-080.
       exe-exp-col-800.
      *              *=================================================*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio v-key e w-cnt-tus-acc-tes       *
      *                  *---------------------------------------------*
           move      v-key                to   w-acc-cts-col-svk      .
           move      w-cnt-tus-acc-tes    to   w-acc-cts-col-stu      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ripristino  immagine video                  *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-825.
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ripristino v-key e w-cnt-tus-acc-tes        *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-svk    to   v-key                  .
           move      w-acc-cts-col-stu    to   w-cnt-tus-acc-tes      .
      *                  *---------------------------------------------*
      *                  * Eventuale segnale di differenze             *
      *                  *---------------------------------------------*
           move      zero                 to   w-acc-cts-col-tot      .
           move      zero                 to   w-acc-cts-col-ctr      .
       exe-exp-col-830.
           add       1                    to   w-acc-cts-col-ctr      .
      *
           if        w-acc-cts-col-ctr    >    w-acc-cts-col-max
                     go to exe-exp-col-840.
      *
           if        w-rig-col-cts
                    (1, w-acc-cts-col-ctr)
                                          =    spaces
                     go to exe-exp-col-830.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze               *
      *                  *---------------------------------------------*
           add       w-rig-col-qta
                    (1, w-acc-cts-col-ctr)
                                          to   w-acc-cts-col-tot      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento contatore scadenze            *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-ctr    to   w-rig-col-ele (1)      .
      *
           go to     exe-exp-col-830.
       exe-exp-col-840.
      *                  *---------------------------------------------*
      *                  * Ricalcolo differenza                        *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-tot    to   w-acc-cts-col-dif      .
           subtract  w-rig-qta-acq (1)    from w-acc-cts-col-dif      .
      *                  *---------------------------------------------*
      *                  * Test su eventuale differenza                *
      *                  *---------------------------------------------*
           if        w-acc-cts-col-dif    =    zero
                     go to exe-exp-col-870.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
           move      "Attenzione : la somma delle quantita' differisce d
      -              "a quella in    "    to   w-err-box-err-msg      .
           move      "riga                                              
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       exe-exp-col-870.
      *                  *---------------------------------------------*
      *                  * Test che il numero elementi castelletto     *
      *                  * corrisponda col numero dei colli            *
      *                  *---------------------------------------------*
           if        w-rig-qta-a03 (1)    =    w-rig-col-ele (1)
                     go to exe-exp-col-890.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
           move      "Attenzione : il numero di contrassegni indicati e'
      -              " diverso dal   "    to   w-err-box-err-msg      .
           move      "numero dei colli impostato!                       
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       exe-exp-col-890.
      *                  *---------------------------------------------*
      *                  * Fine routine                                *
      *                  *---------------------------------------------*
           go to     exe-exp-col-999.
       exe-exp-col-900.
      *              *=================================================*
      *              * Subroutines interne                             *
      *              *-------------------------------------------------*
      *                  *=============================================*
      *                  * Visualizzazione pagina colli a partire      *
      *                  * dall'elemento numero w-acc-cts-col-n1v      *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-n1v    to   w-acc-cts-col-c0p      .
           subtract  1                    from w-acc-cts-col-c0p      .
           move      w-acc-cts-col-c0p    to   w-acc-cts-col-c0q      .
           add       w-acc-cts-col-lpp    to   w-acc-cts-col-c0q      .
       exe-exp-col-901.
           add       1                    to   w-acc-cts-col-c0p      .
           if        w-acc-cts-col-c0p    >    w-acc-cts-col-mxl
                     go to exe-exp-col-905.
           if        w-acc-cts-col-c0p    >    w-acc-cts-col-c0q
                     go to exe-exp-col-909.
           move      w-acc-cts-col-c0p    to   w-acc-cts-col-nev      .
           move      w-acc-cts-col-nev    to   w-acc-cts-col-c0r      .
       exe-exp-col-903.
           if        w-acc-cts-col-c0r    >    w-acc-cts-col-lpp
                     subtract  w-acc-cts-col-lpp
                                          from w-acc-cts-col-c0r
                     go to     exe-exp-col-903.
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0r      .
           perform   exe-exp-col-910      thru exe-exp-col-919        .
           go to     exe-exp-col-901.
       exe-exp-col-905.
           if        w-acc-cts-col-c0p    >    w-acc-cts-col-c0q
                     go to exe-exp-col-909.
           if        w-acc-cts-col-c0r    <    w-acc-cts-col-mxl
                     add  1               to   w-acc-cts-col-c0r      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione linea vuota             *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      w-acc-cts-col-c0r    to   v-lin                  .
           move      44                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           add       1                    to   w-acc-cts-col-c0p      .
           go to     exe-exp-col-905.
       exe-exp-col-909.
           exit.
       exe-exp-col-910.
      *                  *=============================================*
      *                  * Visualizzazione elemento indirizzato da     *
      *                  * w-acc-cts-col-nev a linea w-acc-cts-col-c0r *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione                         *
      *                      *-----------------------------------------*
           move      spaces               to   w-acc-cts-col-led      .
      *                      *-----------------------------------------*
      *                      * Test se vuoto                           *
      *                      *-----------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nev)
                                          =    spaces
                     go to exe-exp-col-916.
      *                      *-----------------------------------------*
      *                      * Contrassegno                            *
      *                      *-----------------------------------------*
           move      w-rig-col-cts
                    (1, w-acc-cts-col-nev)
                                          to   w-acc-cts-col-ced      .
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BG"                 to   v-edm                  .
           move      w-rig-col-qta
                    (1, w-acc-cts-col-nev)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-acc-cts-col-qed      .
       exe-exp-col-916.
      *                      *-----------------------------------------*
      *                      * Visualizzazione stringa composta        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      w-acc-cts-col-c0r    to   v-lin                  .
           subtract  01                   from v-lin                  .
           move      44                   to   v-pos                  .
           move      w-acc-cts-col-led    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-col-919.
       exe-exp-col-919.
           exit.
       exe-exp-col-920.
      *                  *=============================================*
      *                  * Compattamento dell' elemento indirizzato da *
      *                  * w-acc-cts-col-nec se necessario             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione flag fine elementi      *
      *                      *-----------------------------------------*
           move      spaces               to   w-acc-cts-col-fce      .
      *                      *-----------------------------------------*
      *                      * Test se contrassegno a spaces           *
      *                      *-----------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nec)
                                          not  = spaces
                     go to exe-exp-col-929.
      *                      *-----------------------------------------*
      *                      * Compattamento                           *
      *                      *-----------------------------------------*
           move      w-acc-cts-col-nec    to   w-acc-cts-col-c0a      .
           move      w-acc-cts-col-c0a    to   w-acc-cts-col-c0b      .
           add       1                    to   w-acc-cts-col-c0b      .
      *                      *-----------------------------------------*
      *                      * Test se raggiungimento max              *
      *                      *-----------------------------------------*
           if        w-acc-cts-col-c0b    >    w-acc-cts-col-max
                     go to exe-exp-col-929.
      *                      *-----------------------------------------*
      *                      * Test se contrassegno a spaces           *
      *                      *-----------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-c0b)
                                          =    spaces
                     go to exe-exp-col-929.
      *                      *-----------------------------------------*
      *                      * Subroutine di compattamento             *
      *                      *-----------------------------------------*
           perform   exe-exp-col-930      thru exe-exp-col-939        .
           move      "#"                  to   w-acc-cts-col-fce      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     exe-exp-col-929.
       exe-exp-col-929.
           exit.
       exe-exp-col-930.
      *                  *=============================================*
      *                  * Compattamento dell' elemento indirizzato da *
      *                  * w-acc-cts-col-nec in ogni caso              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione contatori                  *
      *                      *-----------------------------------------*
           move      w-acc-cts-col-nec    to   w-acc-cts-col-c0a      .
           move      w-acc-cts-col-c0a    to   w-acc-cts-col-c0b      .
           add       1                    to   w-acc-cts-col-c0b      .
       exe-exp-col-931.
           if        w-acc-cts-col-c0b    >    w-acc-cts-col-max
                     go to exe-exp-col-932.
      *                      *-----------------------------------------*
      *                      * Elemento successivo in precedente       *
      *                      *-----------------------------------------*
           move      w-rig-col-tbl
                    (1, w-acc-cts-col-c0b)
                                          to   w-rig-col-tbl
                                              (1, w-acc-cts-col-c0a)  .
      *                      *-----------------------------------------*
      *                      * Test se contrassegno a spaces           *
      *                      *-----------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-c0b)
                                          =    spaces
                     go to exe-exp-col-933.
      *                      *-----------------------------------------*
      *                      * Incremento contatori                    *
      *                      *-----------------------------------------*
           add       1                    to   w-acc-cts-col-c0a      .
           add       1                    to   w-acc-cts-col-c0b      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     exe-exp-col-931.
       exe-exp-col-932.
      *                      *-----------------------------------------*
      *                      * Normalizzazione elemento                *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-col-cts
                                              (1, w-acc-cts-col-c0a)  .
           move      zero                 to   w-rig-col-qta
                                              (1, w-acc-cts-col-c0a)  .
       exe-exp-col-933.
           move      w-acc-cts-col-nec    to   w-acc-cts-col-c0a      .
       exe-exp-col-934.
           if        w-acc-cts-col-c0a    >    w-acc-cts-col-lpp
                     subtract  w-acc-cts-col-lpp
                                          from w-acc-cts-col-c0a
                     go to     exe-exp-col-934.
           move      w-acc-cts-col-c0a    to   w-acc-cts-col-c0b      .
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0b      .
           subtract  1                    from w-acc-cts-col-c0b      .
           move      w-acc-cts-col-c0b    to   w-acc-cts-col-c0c      .
           add       1                    to   w-acc-cts-col-c0c      .
       exe-exp-col-935.
      *                      *-----------------------------------------*
      *                      * Test se ultima linea                    *
      *                      *-----------------------------------------*
           if        w-acc-cts-col-c0a    =    w-acc-cts-col-lpp
                     go to exe-exp-col-936.
      *                      *-----------------------------------------*
      *                      * Fetch Line                              *
      *                      *-----------------------------------------*
           move      "FL"                 to   v-ope                  .
           move      w-acc-cts-col-c0c    to   v-lin                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-alf                to   w-acc-cts-col-fcl      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      w-acc-cts-col-c0b    to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-acc-cts-col-035    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           add       1                    to   w-acc-cts-col-c0a      .
           add       1                    to   w-acc-cts-col-c0b      .
           add       1                    to   w-acc-cts-col-c0c      .
           go to     exe-exp-col-935.
       exe-exp-col-936.
           move      w-acc-cts-col-nec    to   w-acc-cts-col-c0a      .
       exe-exp-col-937.
           if        w-acc-cts-col-c0a    >    w-acc-cts-col-lpp
                     subtract  w-acc-cts-col-lpp
                                          from w-acc-cts-col-c0a
                     go to     exe-exp-col-937.
           subtract  w-acc-cts-col-c0a    from w-acc-cts-col-lpp
                                        giving w-acc-cts-col-c0b      .
           add       w-acc-cts-col-nec
                     w-acc-cts-col-c0b  giving w-acc-cts-col-c0c      .
           if        w-acc-cts-col-c0c    >    w-acc-cts-col-mxl
                     go to exe-exp-col-938.
           if        w-rig-col-cts
                    (1, w-acc-cts-col-c0c)
                                          =    spaces
                     go to exe-exp-col-938.
           move      w-acc-cts-col-c0c    to   w-acc-cts-col-nev      .
           move      w-acc-cts-col-mxl    to   w-acc-cts-col-c0r      .
           perform   exe-exp-col-910      thru exe-exp-col-919        .
           go to     exe-exp-col-939.
       exe-exp-col-938.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      w-acc-cts-col-mxl    to   v-lin                  .
           move      44                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-939.
           exit.
       exe-exp-col-940.
      *                  *=============================================*
      *                  * Inserimento dell' elemento indirizzato da   *
      *                  * w-acc-cts-col-nec                           *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-max    to   w-acc-cts-col-c0b      .
           move      w-acc-cts-col-c0b    to   w-acc-cts-col-c0a      .
           subtract  1                    from w-acc-cts-col-c0a      .
       exe-exp-col-941.
      *                      *-----------------------------------------*
      *                      * Elemento precedente in successivo       *
      *                      *-----------------------------------------*
           move      w-rig-col-tbl
                    (1, w-acc-cts-col-c0a)
                                          to   w-rig-col-tbl
                                              (1, w-acc-cts-col-c0b)  .
           if        w-acc-cts-col-c0a    =    w-acc-cts-col-nec
                     go to exe-exp-col-942.
           subtract  1                    from w-acc-cts-col-c0a      .
           subtract  1                    from w-acc-cts-col-c0b      .
           go to     exe-exp-col-941.
       exe-exp-col-942.
      *                      *-----------------------------------------*
      *                      * Normalizzazione elemento                *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-col-tbl
                                              (1, w-acc-cts-col-nec)  .
           move      w-acc-cts-col-nec    to   w-acc-cts-col-c0a      .
       exe-exp-col-943.
           if        w-acc-cts-col-c0a    >    w-acc-cts-col-lpp
                     subtract  w-acc-cts-col-lpp
                                          from w-acc-cts-col-c0a
                     go to     exe-exp-col-943.
           add       w-acc-cts-col-inl    to   w-acc-cts-col-c0a      .
           subtract  1                    from w-acc-cts-col-c0a      .
           if        w-acc-cts-col-c0a    =    w-acc-cts-col-mxl
                     go to exe-exp-col-945.
           move      w-acc-cts-col-mxl    to   w-acc-cts-col-c0b      .
           subtract  1                    from w-acc-cts-col-c0b      .
           move      w-acc-cts-col-mxl    to   w-acc-cts-col-c0c      .
       exe-exp-col-944.
      *                      *-----------------------------------------*
      *                      * Fetch Line                              *
      *                      *-----------------------------------------*
           move      "FL"                 to   v-ope                  .
           move      w-acc-cts-col-c0b    to   v-lin                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-alf                to   w-acc-cts-col-fcl      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      w-acc-cts-col-c0c    to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-acc-cts-col-035    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           if        w-acc-cts-col-c0b    =    w-acc-cts-col-c0a
                     go to exe-exp-col-945.
           subtract  1                    from w-acc-cts-col-c0b      .
           subtract  1                    from w-acc-cts-col-c0c      .
           go to     exe-exp-col-944.
       exe-exp-col-945.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      35                   to   v-car                  .
           move      w-acc-cts-col-c0a    to   v-lin                  .
           move      44                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-949.
           exit.
       exe-exp-col-999.
           exit.

      *    *===========================================================*
      *    * Espansione per accettazione contrassegni e quantita' re-  *
      *    * lativi ai colli                                           *
      *    *                                                           *
      *    * Trattamento tasti funzione                                *
      *    *-----------------------------------------------------------*
       exe-exp-col-ttf-000.
      *              *-------------------------------------------------*
      *              * Up   : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *              *-------------------------------------------------*
      *              * Down : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *              *-------------------------------------------------*
      *              * Insr : solo se spazio in tabella                *
      *              *-------------------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          not  = spaces and
                     w-rig-col-cts
                    (1, w-acc-cts-col-max)
                                          =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *              *-------------------------------------------------*
      *              * Do   : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *              *-------------------------------------------------*
      *              * Remove : test                                   *
      *              *-------------------------------------------------*
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          not  = zero
                     go to exe-exp-col-ttf-200.
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0a      .
           add       1                    to   w-acc-cts-col-c0a      .
           if        w-acc-cts-col-c0a    >    w-acc-cts-col-max
                     go to exe-exp-col-ttf-300.
           if        w-rig-col-cts
                    (1, w-acc-cts-col-c0a)
                                          =    zero
                     go to exe-exp-col-ttf-300.
       exe-exp-col-ttf-200.
           move      "REMV"               to   v-pfk (06)             .
       exe-exp-col-ttf-300.
      *              *-------------------------------------------------*
      *              * Previous-screen : sempre accettato              *
      *              *-------------------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *              *-------------------------------------------------*
      *              * Next-screen : sempre accettato                  *
      *              *-------------------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *              *-------------------------------------------------*
      *              * Back : test                                     *
      *              *-------------------------------------------------*
           if        w-acc-cts-col-nel    >    1
                     move  "BACK"         to   v-pfk (09)             .
       exe-exp-col-ttf-400.
      *              *-------------------------------------------------*
      *              * Tab  : test                                     *
      *              *-------------------------------------------------*
           if        w-acc-cts-col-nel    =    w-acc-cts-col-max
                     go to exe-exp-col-ttf-500.
           move      w-acc-cts-col-nel    to   w-acc-cts-col-c0a      .
           add       1                    to   w-acc-cts-col-c0a      .
           if        w-rig-col-cts
                    (1, w-acc-cts-col-nel)
                                          =    spaces and
                     w-rig-col-cts
                    (1, w-acc-cts-col-c0a)
                                          =    spaces
                     go to exe-exp-col-ttf-500.
           move      "TAB "               to   v-pfk (10)             .
      *              *-------------------------------------------------*
      *              * Select : sempre accettato                       *
      *              *-------------------------------------------------*
           move      "SLCT"               to   v-pfk (11)             .
      *              *-------------------------------------------------*
      *              * Exit : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "EXIT"               to   v-pfk (20)             .
       exe-exp-col-ttf-500.
      *              *-------------------------------------------------*
      *              * Inibizione eventuale tasti funzione in caso di  *
      *              * quantita' non modificabili                      *
      *              *-------------------------------------------------*
       exe-exp-col-ttf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-col-ttf-999.
       exe-exp-col-ttf-999.
           exit.

      *    *===========================================================*
      *    * Espansione per accettazione contrassegni e quantita' re-  *
      *    * lativi ai colli                                           *
      *    *                                                           *
      *    * Salvataggio castelletto contrassegni                      *
      *    *-----------------------------------------------------------*
       exe-exp-col-sav-000.
      *              *-------------------------------------------------*
      *              * Ciclo 1..max                                    *
      *              *-------------------------------------------------*
           move      w-rig-col-ele (1)    to   w-sav-col-ele          .
           move      zero                 to   w-acc-cts-col-ctr      .
       exe-exp-col-sav-200.
           add       1                    to   w-acc-cts-col-ctr      .
      *
           if        w-acc-cts-col-ctr    >    w-acc-cts-col-max
                     go to exe-exp-col-sav-900.
      *
           move      w-rig-col-tbl
                    (1, w-acc-cts-col-ctr)
                                          to   w-sav-col-tbl
                                              (w-acc-cts-col-ctr)     .
           go to     exe-exp-col-sav-200.
       exe-exp-col-sav-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-col-sav-999.
       exe-exp-col-sav-999.
           exit.

      *    *===========================================================*
      *    * Espansione per accettazione contrassegni e quantita' re-  *
      *    * lativi ai colli                                           *
      *    *                                                           *
      *    * Determinazione e visualizzazione del totale quantita'     *
      *    *-----------------------------------------------------------*
       exe-exp-col-tot-000.
      *              *-------------------------------------------------*
      *              * Ciclo 1..max                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-acc-cts-col-tot      .
           move      zero                 to   w-acc-cts-col-ctr      .
       exe-exp-col-tot-200.
           add       1                    to   w-acc-cts-col-ctr      .
      *
           if        w-acc-cts-col-ctr    >    w-acc-cts-col-max
                     go to exe-exp-col-tot-400.
      *
           if        w-rig-col-cts
                    (1, w-acc-cts-col-ctr)
                                          =    spaces
                     go to exe-exp-col-tot-200.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze               *
      *                  *---------------------------------------------*
           add       w-rig-col-qta
                    (1, w-acc-cts-col-ctr)
                                          to   w-acc-cts-col-tot      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento contatore scadenze            *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-ctr    to   w-rig-col-ele (1)      .
      *
           go to     exe-exp-col-tot-200.
       exe-exp-col-tot-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BG"                 to   v-edm                  .
           move      14                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-acc-cts-col-tot    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-tot-600.
      *              *-------------------------------------------------*
      *              * Eventuale differenza dalla quantita' in riga    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo differenza                          *
      *                  *---------------------------------------------*
           move      w-acc-cts-col-tot    to   w-acc-cts-col-dif      .
           subtract  w-rig-qta-acq (1)    from w-acc-cts-col-dif      .
      *                  *---------------------------------------------*
      *                  * Editing differenza                          *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      w-acc-cts-col-dif    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Composizione literal                        *
      *                  *---------------------------------------------*
           move      17                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "("                  to   w-all-str-cat (1)      .
      *
           if        w-acc-cts-col-dif    >    zero
                     move  "+"            to   w-all-str-cat (2)
           else if   w-acc-cts-col-dif    =    zero
                     move  "="            to   w-all-str-cat (2)
           else      move  "-"            to   w-all-str-cat (2)      .
      *
           move      v-edt                to   w-all-str-cat (3)      .
           move      ")"                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-col-tot-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-col-tot-999.
       exe-exp-col-tot-999.
           exit.

