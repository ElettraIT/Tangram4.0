       vis-lin-cor-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate sia dall'area per la fin- *
      *              * catura che dall'area delle righe effettive      *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      12                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-200.
      *              *-------------------------------------------------*
      *              * Numero riga                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Fincatura                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-300.
      *              *-------------------------------------------------*
      *              * Descrizione                                     *
      *              *-------------------------------------------------*
       pmt-cor-reg-310.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda della personalizzazio- *
      *                  * di tipo esposizione della descrizione       *
      *                  *---------------------------------------------*
           if        w-prs-rig-scr-des    =    00
                     go to pmt-cor-reg-320
           else if   w-prs-rig-scr-des    =    01 or
                     w-prs-rig-scr-des    =    05
                     go to pmt-cor-reg-330
           else if   w-prs-rig-scr-des    =    02 or
                     w-prs-rig-scr-des    =    06
                     go to pmt-cor-reg-340
           else if   w-prs-rig-scr-des    =    03
                     go to pmt-cor-reg-350
           else if   w-prs-rig-scr-des    =    04
                     go to pmt-cor-reg-360
           else if   w-prs-rig-scr-des    =    11
                     go to pmt-cor-reg-370
           else if   w-prs-rig-scr-des    =    12
                     go to pmt-cor-reg-380
           else if   w-prs-rig-scr-des    =    13
                     go to pmt-cor-reg-390
           else if   w-prs-rig-scr-des    =    14
                     go to pmt-cor-reg-400
           else      go to pmt-cor-reg-320.
       pmt-cor-reg-320.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 00              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "              Descrizione               "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      05                   to   v-pos                  .
           move      "----------------------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     pmt-cor-reg-600.
       pmt-cor-reg-330.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione tipo : 01 oppure 05    *
      *                  *---------------------------------------------*
