      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo archivio                *
      *    *-----------------------------------------------------------*
       acc-tip-arc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da accettare                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo archivio di default 'N' e possibi-  *
      *                  * ta' di variare il tipo archivio a 'N' : no  *
      *                  * accettazione                                *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-dfa    =    "N" and
                     w-tes-cod-tmb-vaa    =    "N"
                     go to acc-tip-arc-600.
      *                  *---------------------------------------------*
      *                  * Se tipo archivio di default 'C' o 'F' o 'D' *
      *                  * e possibilita' di variare il tipo archivio  *
      *                  * 'N' : no accettazione, ma forzatura del     *
      *                  * valore di defualt e poi uscita              *
      *                  *---------------------------------------------*
           if       (w-tes-cod-tmb-dfa    =    "C" or
                     w-tes-cod-tmb-dfa    =    "F" or
                     w-tes-cod-tmb-dfa    =    "D"  ) and
                    (w-tes-cod-tmb-vaa    =    "N"  )
                     go to acc-tip-arc-010
           else      go to acc-tip-arc-025.
       acc-tip-arc-010.
           if        w-tes-tip-arc (1)    =    w-tes-cod-tmb-dfa
                     go to acc-tip-arc-600.
           move      w-tes-cod-tmb-dfa    to   w-tes-tip-arc (1)      .
           perform   vis-tip-arc-000      thru vis-tip-arc-999        .
           go to     acc-tip-arc-600.
       acc-tip-arc-025.
      *                  *---------------------------------------------*
      *                  * Se accettazione gia' effettuata : uscita    *
      *                  *---------------------------------------------*
           if        w-tes-fda-tar (1)    not  = spaces
                     go to acc-tip-arc-999.
      *              *-------------------------------------------------*
      *              * Preparazione area w-exp limitata ai soli tipi   *
      *              * archivio previsti                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se lista tipi archivio ammessi a Spaces :   *
      *                  * si accettano tutti i tipi archivio          *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-lsa    not  = spaces
                     go to acc-tip-arc-035.
       acc-tip-arc-030.
           move      w-exp-tip-arc-num    to   w-exp-tip-aam-num      .
           move      w-exp-tip-arc-tbl    to   w-exp-tip-aam-tbl      .
           move      w-exp-tip-arc-ast    to   w-exp-tip-aam-ass      .
           go to     acc-tip-arc-075.
       acc-tip-arc-035.
      *                  *---------------------------------------------*
      *                  * Altrimenti si prepara l'area con i soli ti- *
      *                  * pi archivio ammessi                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione iniziale                *
      *                      *-----------------------------------------*
           move      spaces               to   w-exp-tip-aam-ass      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'No tipo archivio' :      *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cod-tmb-lsa
                                      tallying w-exp-tip-aam-c01
                     for                  all  "N"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "N"            to   w-exp-tip-aam-tar (1)  .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Clienti' :               *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cod-tmb-lsa
                                      tallying w-exp-tip-aam-c01
                     for                  all  "C"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "C"            to   w-exp-tip-aam-tar (2)  .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Fornitori' :             *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cod-tmb-lsa
                                      tallying w-exp-tip-aam-c01
                     for                  all  "F"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "F"            to   w-exp-tip-aam-tar (3)  .
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Nostre dipendenze' :     *
      *                      * - Se esiste una sola dipendenza non lo  *
      *                      *   si inserisce nella lista              *
      *                      *-----------------------------------------*
           if        w-dpz-ctr-dpz        not  > 1
                     go to acc-tip-arc-040.
      *                      *-----------------------------------------*
      *                      * Tipo archivio 'Nostre dipendenze' :     *
      *                      * - Se presente nella lista dei tipi ar-  *
      *                      *   chivio ammessi per la causale lo si   *
      *                      *   inserisce nella lista, altrimenti no  *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-tes-cod-tmb-lsa
                                      tallying w-exp-tip-aam-c01
                     for                  all  "D"                    .
           if        w-exp-tip-aam-c01    >    zero
                     move  "D"            to   w-exp-tip-aam-tar (4)  .
       acc-tip-arc-040.
      *                      *-----------------------------------------*
      *                      * Se la lista cosi' determinata risulta   *
      *                      * vuota si accettano tutti i tipi di ar-  *
      *                      * chivio                                  *
      *                      *-----------------------------------------*
           if        w-exp-tip-aam-ass    =    spaces
                     go to acc-tip-arc-030.
      *                      *-----------------------------------------*
      *                      * Compattamento della lista dei tipi ar-  *
      *                      * chivio ammessi                          *
      *                      *-----------------------------------------*
           if        w-exp-tip-aam-tar (1)
                                          =    spaces
                     move  w-exp-tip-aam-tar (2)
                                          to   w-exp-tip-aam-tar (1)
                     move  w-exp-tip-aam-tar (3)
                                          to   w-exp-tip-aam-tar (2)
                     move  w-exp-tip-aam-tar (4)
                                          to   w-exp-tip-aam-tar (3)
                     move  spaces         to   w-exp-tip-aam-tar (4)  .
           if        w-exp-tip-aam-tar (2)
                                          =    spaces
                     move  w-exp-tip-aam-tar (3)
                                          to   w-exp-tip-aam-tar (2)
                     move  w-exp-tip-aam-tar (4)
                                          to   w-exp-tip-aam-tar (3)
                     move  spaces         to   w-exp-tip-aam-tar (4)  .
           if        w-exp-tip-aam-tar (3)
                                          =    spaces
                     move  w-exp-tip-aam-tar (4)
                                          to   w-exp-tip-aam-tar (3)
                     move  spaces         to   w-exp-tip-aam-tar (4)  .
      *                      *-----------------------------------------*
      *                      * Preparazione del numero di elementi in  *
      *                      * tabella tipi archivio ammessi           *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-exp-tip-aam-ass
                                      tallying w-exp-tip-aam-c01
                     for                  all  spaces                 .
           move      04                   to   w-exp-tip-aam-num      .
           subtract  w-exp-tip-aam-c01    from w-exp-tip-aam-num      .
       acc-tip-arc-045.
      *                      *-----------------------------------------*
      *                      * Preparazione delle descrizioni relative *
      *                      * ai tipi archivio ammessi                *
      *                      *-----------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
       acc-tip-arc-050.
           add       1                    to   w-exp-tip-aam-c01      .
           if        w-exp-tip-aam-c01    >    04
                     go to acc-tip-arc-075.
           move      zero                 to   w-exp-tip-aam-i01      .
           inspect   w-exp-tip-arc-ast
                                      tallying w-exp-tip-aam-i01
                     for   characters   before
                                       initial w-exp-tip-aam-tar
                                              (w-exp-tip-aam-c01)     .
           if        w-exp-tip-aam-i01    =    w-exp-tip-arc-num
                     move  spaces         to   w-exp-tip-aam-ele
                                              (w-exp-tip-aam-c01)
                     go to acc-tip-arc-050.
           add       01                   to   w-exp-tip-aam-i01      .
           move      w-exp-tip-arc-ele
                    (w-exp-tip-aam-i01)   to   w-exp-tip-aam-ele
                                              (w-exp-tip-aam-c01)     .
           go to     acc-tip-arc-050.
       acc-tip-arc-075.
      *              *-------------------------------------------------*
      *              * Preparazione eventuale del valore di default    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore gia' presente : no preparazione   *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    not  = spaces
                     go to acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Se default a Spaces : no preparazione       *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-dfa    =    spaces
                     go to acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Se default non compreso nella lista dei ti- *
      *                  * pi archivio previsti : no preparazione      *
      *                  *---------------------------------------------*
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-exp-tip-aam-ass
                                      tallying w-exp-tip-aam-c01
                     for                  all  w-tes-cod-tmb-dfa      .
           if        w-exp-tip-aam-c01    =    zero
                     go to acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Preparazione default                        *
      *                  *---------------------------------------------*
           move      w-tes-cod-tmb-dfa    to   w-tes-tip-arc (1)      .
       acc-tip-arc-080.
      *                  *---------------------------------------------*
      *                  * Se la tabella dei tipi archivio ammessi e'  *
      *                  * formata da un solo elemento : si forza il   *
      *                  * valore corrispondente, si visualizza, e si  *
      *                  * esce                                        *
      *                  *---------------------------------------------*
           if        w-exp-tip-aam-num    not  = 1
                     go to acc-tip-arc-100.
           move      w-exp-tip-aam-tar (1)
                                          to   w-tes-tip-arc (1)      .
           perform   vis-tip-arc-000      thru vis-tip-arc-999        .
           go to     acc-tip-arc-999.
       acc-tip-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-aam-lun    to   v-car                  .
           move      w-exp-tip-aam-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-aam-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      zero                 to   w-exp-tip-aam-c01      .
           inspect   w-exp-tip-aam-ass
                                      tallying w-exp-tip-aam-c01
                     for   characters   before
                                       initial w-tes-tip-arc (1)      .
           if        w-exp-tip-aam-c01    not  < w-exp-tip-arc-num
                     move  zero           to   v-num
           else      move  w-exp-tip-aam-c01
                                          to   v-num
                     add   1              to   v-num                  .
           if        w-tes-tip-arc (1)    =    spaces
                     move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-arc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-arc-999.
       acc-tip-arc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-exp-tip-aam-i01      .
           if        w-exp-tip-aam-i01    =    zero
                     move  spaces         to   w-tes-tip-arc (1)
           else      move  w-exp-tip-aam-tar
                          (w-exp-tip-aam-i01)
                                          to   w-tes-tip-arc (1)      .
       acc-tip-arc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se causale di magazzino a zero : oltre      *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-cam    =    zero
                     go to acc-tip-arc-600.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se causale di movimen- *
      *                  * tazione merce in conto oppure no            *
      *                  *---------------------------------------------*
           if        w-tes-cod-tmb-cam-tmc
                                          =    02
                     go to acc-tip-arc-425
           else      go to acc-tip-arc-450.
       acc-tip-arc-425.
      *                  *---------------------------------------------*
      *                  * Se causale non di movimentazione merce in   *
      *                  * conto                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessun controllo, continuazione         *
      *                      *-----------------------------------------*
           go to     acc-tip-arc-600.
       acc-tip-arc-450.
      *                  *---------------------------------------------*
      *                  * Se causale di movimentazione merce in conto *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione ulteriore a seconda se il    *
      *                      * codice merce in conto e' obbligatorio   *
      *                      * o facoltativo                           *
      *                      *-----------------------------------------*
           if        w-tes-cod-tmb-cam-tmc
                                          =    02
                     go to acc-tip-arc-475
           else      go to acc-tip-arc-500.
       acc-tip-arc-475.
      *                      *-----------------------------------------*
      *                      * Se il codice merce in conto e' obbliga- *
      *                      * torio                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il tipo archivio esiste ma non   *
      *                          * e' ne' 'C' ne 'F' : messaggio di    *
      *                          * errore e reimpostazione             *
      *                          *-------------------------------------*
           if        w-tes-tip-arc (1)    not  = spaces and
                     w-tes-tip-arc (1)    not  = "C"    and
                     w-tes-tip-arc (1)    not  = "F"
                     go to acc-tip-arc-477
           else      go to acc-tip-arc-480.
       acc-tip-arc-477.
           move      "Tipo archivio non ammesso per movimentazione di me
      -              "rce in conto   "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-tip-arc-100.
       acc-tip-arc-480.
      *                          *-------------------------------------*
      *                          * Se il tipo archivio manca e non si  *
      *                          * e' in Up : messaggio di errore e    *
      *                          * reimpostazione                      *
      *                          *-------------------------------------*
           if        w-tes-tip-arc (1)    not  = spaces
                     go to acc-tip-arc-485.
           if        v-key                =    "UP  "
                     go to acc-tip-arc-485.
           move      "Il tipo archivio e' obbligatorio per i movimenti m
      -              "erce in conto  "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-tip-arc-100.
       acc-tip-arc-485.
      *                          *-------------------------------------*
      *                          * A dipendenze da impostazione        *
      *                          *-------------------------------------*
           go to     acc-tip-arc-600.
       acc-tip-arc-500.
      *                      *-----------------------------------------*
      *                      * Se il codice merce in conto e' facolta- *
      *                      * tivo                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se e' il tipo movimento conteneva   *
      *                          * un codice di merce in conto, si     *
      *                          * segue la stessa strada descritta    *
      *                          * per il codice merce in conto obbli- *
      *                          * gatorio, altrimenti non si esegue   *
      *                          * alcun controllo e si va' alle di-   *
      *                          * pendenze dall'impostazione          *
      *                          *-------------------------------------*
           if        w-tes-cod-tmb-ctm    not  = spaces
                     go to acc-tip-arc-475
           else      go to acc-tip-arc-600.
       acc-tip-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di accettazione tipo archivio          *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-tar (1)      .
      *                  *---------------------------------------------*
      *                  * Prompt per partita iva                      *
      *                  *---------------------------------------------*
           perform   pmt-piv-cof-000      thru pmt-piv-cof-999        .
       acc-tip-arc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-arc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-arc-100.
       acc-tip-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo archivio             *
      *    *-----------------------------------------------------------*
       vis-tip-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-arc-lun    to   v-car                  .
           move      w-exp-tip-arc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-arc-tbl    to   v-txt                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           if        w-tes-tip-arc (1)    =    "N"
                     move  01             to   v-num
           else if   w-tes-tip-arc (1)    =    "F"
                     move  02             to   v-num
           else if   w-tes-tip-arc (1)    =    "C"
                     move  03             to   v-num
           else if   w-tes-tip-arc (1)    =    "D"
                     move  04             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-arc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "F"
                     perform acc-cod-fnt-000
                                          thru acc-cod-fnt-999
           else if   w-tes-tip-arc (1)    =    "C"
                     perform acc-cod-cli-000
                                          thru acc-cod-cli-999
           else if   w-tes-tip-arc (1)    =    "D"
                     perform acc-cod-dpz-000
                                          thru acc-cod-dpz-999        .
       acc-cod-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice fornitore             *
      *    *-----------------------------------------------------------*
       acc-cod-fnt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-sav-cod-fnt          .
       acc-cod-fnt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcf-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-dcf-cod      .
           move      08                   to   w-cod-mne-dcf-lin      .
           move      27                   to   w-cod-mne-dcf-pos      .
           move      08                   to   w-cod-mne-dcf-rln      .
           move      41                   to   w-cod-mne-dcf-rps      .
           move      09                   to   w-cod-mne-dcf-vln      .
           move      41                   to   w-cod-mne-dcf-vps      .
           move      10                   to   w-cod-mne-dcf-lln      .
           move      41                   to   w-cod-mne-dcf-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
       acc-cod-fnt-110.
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           if        w-cod-mne-dcf-ope    =    "F+"
                     go to acc-cod-fnt-115.
           if        w-cod-mne-dcf-ope    =    "AC"
                     go to acc-cod-fnt-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fnt-115.
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
           go to     acc-cod-fnt-110.
       acc-cod-fnt-120.
           move      w-cod-mne-dcf-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fnt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fnt-999.
       acc-cod-fnt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-fnt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [fnt]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
           move      w-let-arc-fnt-rag    to   w-tes-cod-arc-rag (1)  .
           move      w-let-arc-fnt-via    to   w-tes-cod-arc-via (1)  .
           move      w-let-arc-fnt-loc    to   w-tes-cod-arc-loc (1)  .
           move      w-let-arc-fnt-naz    to   w-tes-cod-arc-naz (1)  .
           move      w-let-arc-fnt-piv    to   w-tes-cod-arc-piv (1)  .
           move      w-let-arc-fnt-cfi    to   w-tes-cod-arc-cfi (1)  .
           move      w-let-arc-fnt-stc    to   w-tes-cod-arc-stc (1)  .
           move      w-let-arc-fnt-ass    to   w-tes-ass-iva (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-flg    not  = spaces or
                     w-tes-cod-arc (1)    =    zero
                     go to acc-cod-fnt-100.
      *                  *---------------------------------------------*
      *                  * Test su codice sottoconto associato al      *
      *                  * fornitore                                   *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-stc (1)
                                          not  = zero
                     go to acc-cod-fnt-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca il sottoconto contabile per il fornitore !  
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-fnt-100.
       acc-cod-fnt-420.
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zci]                       *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcf] principale             *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-fnt      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-cod-fnt-500.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il fornitore ! 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-fnt-100.
       acc-cod-fnt-500.
      *                  *---------------------------------------------*
      *                  * Test su segnale di ordini bloccati          *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-cod-fnt-580.
           if        w-let-arc-dcf-blo    not  = 02
                     go to acc-cod-fnt-580.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : Fornitore con ordini bloccati !      
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A seconda della personalizzazione rela- *
      *                      * tiva alla modalita' di blocco del for-  *
      *                      * nitore si prosegue, oppure si esce si-  *
      *                      * mulando il tasto Exit                   *
      *                      *-----------------------------------------*
           if        w-prs-blo-fnt-t01    =    "B"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fnt-999
           else      go to acc-cod-fnt-580.
       acc-cod-fnt-580.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su fornitore            *
      *                  *---------------------------------------------*
           perform   cod-mne-dcf-not-000  thru cod-mne-dcf-not-999    .
       acc-cod-fnt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-sav-cod-fnt        =    zero
                     go to acc-cod-fnt-610.
           if        w-tes-cod-arc (1)    =    w-sav-cod-fnt
                     go to acc-cod-fnt-800.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           perform   acc-cod-fnt-mod-000  thru acc-cod-fnt-mod-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-arc-mod-sce    =    01
                     go to acc-cod-fnt-100.
       acc-cod-fnt-610.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [dcf] principale                     *
      *                  *---------------------------------------------*
           perform   det-vlt-dcf-000      thru det-vlt-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione funzionamento spese          *
      *                  *---------------------------------------------*
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione se presenti dipendenze per   *
      *                  * il fornitore in corso di trattamento        *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-det-snd-dcf-fnt      .
           perform   det-snd-dcf-000      thru det-snd-dcf-999        .
       acc-cod-fnt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fnt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fnt-100.
       acc-cod-fnt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Routine di avviso per cambio codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-fnt-mod-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       acc-cod-fnt-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica del codice fornitore non comporta alcu
      -              "na variazione  "    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "nelle condizioni gia' presenti nel documento !    
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-arc-mod-sce      .
       acc-cod-fnt-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-arc-mod-lun    to   v-car                  .
           move      w-exp-arc-mod-num    to   v-ldt                  .
           move      "AP#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-arc-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-arc-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-cod-fnt-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02
                     go to acc-cod-fnt-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-arc-mod-sce      .
       acc-cod-fnt-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-fnt-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-fnt-mod-999.
       acc-cod-fnt-mod-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente               *
      *    *-----------------------------------------------------------*
       acc-cod-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcc-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-dcc-cod      .
           move      08                   to   w-cod-mne-dcc-lin      .
           move      27                   to   w-cod-mne-dcc-pos      .
           move      08                   to   w-cod-mne-dcc-rln      .
           move      41                   to   w-cod-mne-dcc-rps      .
           move      09                   to   w-cod-mne-dcc-vln      .
           move      41                   to   w-cod-mne-dcc-vps      .
           move      10                   to   w-cod-mne-dcc-lln      .
           move      41                   to   w-cod-mne-dcc-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
       acc-cod-cli-110.
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           if        w-cod-mne-dcc-ope    =    "F+"
                     go to acc-cod-cli-115.
           if        w-cod-mne-dcc-ope    =    "AC"
                     go to acc-cod-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cli-115.
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
           go to     acc-cod-cli-110.
       acc-cod-cli-120.
           move      w-cod-mne-dcc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
       acc-cod-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [cli]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-tes-cod-arc-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-cod-arc-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-cod-arc-loc (1)  .
           move      w-let-arc-cli-naz    to   w-tes-cod-arc-naz (1)  .
           move      w-let-arc-cli-piv    to   w-tes-cod-arc-piv (1)  .
           move      w-let-arc-cli-cfi    to   w-tes-cod-arc-cfi (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces or
                     w-tes-cod-arc (1)    =    zero
                     go to acc-cod-cli-100.
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc] principale             *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    =    spaces
                     go to acc-cod-cli-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il cliente     
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-100.
       acc-cod-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione se presenti dipendenze per   *
      *                  * il cliente in corso di trattamento          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-det-snd-dcc-cli      .
           perform   det-snd-dcc-000      thru det-snd-dcc-999        .
       acc-cod-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cli-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cli-100.
       acc-cod-cli-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostra dipendenza     *
      *    *-----------------------------------------------------------*
       acc-cod-dpz-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-dpz-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dpz-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dpz-cod      .
           move      08                   to   w-cod-cod-dpz-lin      .
           move      27                   to   w-cod-cod-dpz-pos      .
           move      08                   to   w-cod-cod-dpz-dln      .
           move      41                   to   w-cod-cod-dpz-dps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dpz-cll-000  thru cod-cod-dpz-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dpz-foi-000  thru cod-cod-dpz-foi-999    .
       acc-cod-dpz-110.
           perform   cod-cod-dpz-cll-000  thru cod-cod-dpz-cll-999    .
           if        w-cod-cod-dpz-ope    =    "F+"
                     go to acc-cod-dpz-115.
           if        w-cod-cod-dpz-ope    =    "AC"
                     go to acc-cod-dpz-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dpz-115.
           perform   cod-cod-dpz-foi-000  thru cod-cod-dpz-foi-999    .
           go to     acc-cod-dpz-110.
       acc-cod-dpz-120.
           move      w-cod-cod-dpz-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-dpz-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-dpz-999.
       acc-cod-dpz-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-dpz-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-dpz-410.
      *                  *---------------------------------------------*
      *                  * Lettura dipendenza per l'azienda            *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dpz-cod      .
           perform   let-arc-dpz-000      thru let-arc-dpz-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-dpz-des    to   w-tes-cod-arc-rag (1)  .
           move      spaces               to   w-tes-cod-arc-via (1)  .
           move      spaces               to   w-tes-cod-arc-loc (1)  .
       acc-cod-dpz-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
       acc-cod-dpz-430.
      *                  *---------------------------------------------*
      *                  * Se dipendenza non esistente : reimpostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-let-arc-dpz-flg    not  = spaces
                     go to acc-cod-dpz-100.
       acc-cod-dpz-440.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    =    zero
                     go to acc-cod-dpz-100.
       acc-cod-dpz-450.
      *                  *---------------------------------------------*
      *                  * Controllo che il codice dipendenza non sia  *
      *                  * pari al codice dipendenza in uso            *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    not  = w-tes-cod-dpz
                     go to acc-cod-dpz-600.
           move      "Codice dipendenza non accettabile !               
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-cod-dpz-100.
       acc-cod-dpz-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-dpz-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-dpz-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-dpz-100.
       acc-cod-dpz-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice archivio           *
      *    *-----------------------------------------------------------*
       vis-cod-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-arc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione archivio      *
      *    *-----------------------------------------------------------*
       vis-cod-arc-des-000.
      *              *-------------------------------------------------*
      *              * Ragione sociale                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Indirizzo                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Localita'                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-des-600.
      *              *-------------------------------------------------*
      *              * Partita Iva                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Pulizia preliminare                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Test se archivio estero                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-naz (1)
                                          =    "IT " or
                     w-tes-cod-arc-naz (1)
                                          =    spaces
                     go to vis-cod-arc-des-640.
       vis-cod-arc-des-620.
      *                  *---------------------------------------------*
      *                  * Archivio estero                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      w-tes-cod-arc-cfi (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cod-arc-des-999.
       vis-cod-arc-des-640.
      *                  *---------------------------------------------*
      *                  * Archivio Italia                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      12                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      w-tes-cod-arc-piv (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Dipendenza archivio          *
      *    *-----------------------------------------------------------*
       acc-dpz-arc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dpz-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "C"
                     perform acc-dpz-cli-000
                                          thru acc-dpz-cli-999
           else if   w-tes-tip-arc (1)    =    "F"
                     perform acc-dpz-fnt-000
                                          thru acc-dpz-fnt-999
           else      go to acc-dpz-arc-999.
       acc-dpz-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dpz-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice dipendenza fornitore  *
      *    *-----------------------------------------------------------*
       acc-dpz-fnt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test  se campo da accettare                 *
      *                  *---------------------------------------------*
           if        w-det-snd-dcf-snx    =    "N"
                     go to acc-dpz-fnt-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-sav-dpz-arc          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-fnt-400.
       acc-dpz-fnt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcf-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dcf-fnt      .
           move      w-tes-dpz-arc (1)    to   w-cod-cod-dcf-cod      .
           move      14                   to   w-cod-cod-dcf-lin      .
           move      27                   to   w-cod-cod-dcf-pos      .
           move      14                   to   w-cod-cod-dcf-rln      .
           move      41                   to   w-cod-cod-dcf-rps      .
           move      15                   to   w-cod-cod-dcf-vln      .
           move      41                   to   w-cod-cod-dcf-vps      .
           move      16                   to   w-cod-cod-dcf-lln      .
           move      41                   to   w-cod-cod-dcf-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcf-cll-000  thru cod-cod-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcf-foi-000  thru cod-cod-dcf-foi-999    .
       acc-dpz-fnt-110.
           perform   cod-cod-dcf-cll-000  thru cod-cod-dcf-cll-999    .
           if        w-cod-cod-dcf-ope    =    "F+"
                     go to acc-dpz-fnt-115.
           if        w-cod-cod-dcf-ope    =    "AC"
                     go to acc-dpz-fnt-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-fnt-115.
           perform   cod-cod-dcf-foi-000  thru cod-cod-dcf-foi-999    .
           go to     acc-dpz-fnt-110.
       acc-dpz-fnt-120.
           move      w-cod-cod-dcf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-fnt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-fnt-999.
       acc-dpz-fnt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-arc (1)      .
       acc-dpz-fnt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcf]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcf-fnt      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcf-loc    to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcf-flg    not  = spaces
                     go to acc-dpz-fnt-100.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su dipendenza fornitore *
      *                  *---------------------------------------------*
           perform   cod-cod-dcf-not-000  thru cod-cod-dcf-not-999    .
       acc-dpz-fnt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    w-sav-dpz-arc
                     go to acc-dpz-fnt-800.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcf]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-dpz-fnt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-fnt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-fnt-100.
       acc-dpz-fnt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice dipendenza cliente    *
      *    *-----------------------------------------------------------*
       acc-dpz-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test  se campo da accettare                 *
      *                  *---------------------------------------------*
           if        w-det-snd-dcc-snx    =    "N"
                     go to acc-dpz-cli-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-cli-400.
       acc-dpz-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcc-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dcc-cli      .
           move      w-tes-dpz-arc (1)    to   w-cod-cod-dcc-cod      .
           move      14                   to   w-cod-cod-dcc-lin      .
           move      27                   to   w-cod-cod-dcc-pos      .
           move      14                   to   w-cod-cod-dcc-rln      .
           move      41                   to   w-cod-cod-dcc-rps      .
           move      15                   to   w-cod-cod-dcc-vln      .
           move      41                   to   w-cod-cod-dcc-vps      .
           move      16                   to   w-cod-cod-dcc-lln      .
           move      41                   to   w-cod-cod-dcc-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
       acc-dpz-cli-110.
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           if        w-cod-cod-dcc-ope    =    "F+"
                     go to acc-dpz-cli-115.
           if        w-cod-cod-dcc-ope    =    "AC"
                     go to acc-dpz-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-cli-115.
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
           go to     acc-dpz-cli-110.
       acc-dpz-cli-120.
           move      w-cod-cod-dcc-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-cli-999.
       acc-dpz-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-arc (1)      .
       acc-dpz-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcc]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-dpz-cli-100.
       acc-dpz-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dpz-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-cli-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-cli-100.
       acc-dpz-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza archivio       *
      *    *-----------------------------------------------------------*
       vis-dpz-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-dpz-arc (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    *-----------------------------------------------------------*
       vis-dpz-arc-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-arc-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data documento del fornitore *
      *    *-----------------------------------------------------------*
       acc-dat-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dat-doc-400.
       acc-dat-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-dat-doc (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dat-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dat-doc-999.
       acc-dat-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dat-doc (1)      .
       acc-dat-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dat-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dat-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-doc-100.
       acc-dat-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data documento del forni- *
      *    * tore                                                      *
      *    *-----------------------------------------------------------*
       vis-dat-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-dat-doc (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Numero documento del forni-  *
      *    * tore                                                      *
      *    *-----------------------------------------------------------*
       acc-num-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-num-doc-400.
       acc-num-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-num-doc (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-num-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-num-doc-999.
       acc-num-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-num-doc (1)      .
       acc-num-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-num-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-num-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-num-doc-100.
       acc-num-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero documento del fornitore    *
      *    *-----------------------------------------------------------*
       vis-num-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-num-doc (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Protocollo di magazzino           *
      *    *-----------------------------------------------------------*
       vis-prt-mag-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo funzionamento                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to vis-prt-mag-999.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-tes-prt-mag (1)    =    zero
                     go to vis-prt-mag-999.
       vis-prt-mag-100.
      *              *-------------------------------------------------*
      *              * Preparazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scomposizione protocollo di magazzino       *
      *                  *---------------------------------------------*
           move      w-tes-prt-mag (1)    to   w-vis-big-prt-num      .
           move      w-vis-big-prt-saa    to   w-vis-num-prt-saa      .
           move      w-vis-big-prt-prg    to   w-vis-num-prt-prg      .
      *                  *---------------------------------------------*
      *                  * Editing protocollo di magazzino             *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-vis-num-prt-num    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Test di esistenza                           *
      *                  *---------------------------------------------*
           move      "TE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-tes-prt-mag (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Concatenamento                              *
      *                  *---------------------------------------------*
           move      12                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "("                  to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
      *
           if        l-mag-300-exi-sts    =    spaces
                     move  spaces         to   w-all-str-cat (3)
           else      move  "*"            to   w-all-str-cat (3)      .
      *
           move      ")"                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
       vis-prt-mag-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prt-mag-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Protocollo di magazzino           *
      *    *-----------------------------------------------------------*
       vis-pr2-mag-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo funzionamento                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to vis-pr2-mag-999.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-tes-pr2-mag (1)    =    zero
                     go to vis-pr2-mag-999.
       vis-pr2-mag-100.
      *              *-------------------------------------------------*
      *              * Preparazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scomposizione protocollo di magazzino       *
      *                  *---------------------------------------------*
           move      w-tes-pr2-mag (1)    to   w-vis-big-prt-num      .
           move      w-vis-big-prt-saa    to   w-vis-num-prt-saa      .
           move      w-vis-big-prt-prg    to   w-vis-num-prt-prg      .
      *                  *---------------------------------------------*
      *                  * Editing protocollo di magazzino             *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-vis-num-prt-num    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Test di esistenza                           *
      *                  *---------------------------------------------*
           move      "TE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-reg        to   l-mag-300-dat-reg      .
           move      w-tes-pr2-mag (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Se documento non esistente: uscita          *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to vis-pr2-mag-999.
      *                  *---------------------------------------------*
      *                  * Concatenamento                              *
      *                  *---------------------------------------------*
           move      12                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "["                  to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
      *
           if        l-mag-300-exi-sts    =    spaces
                     move  spaces         to   w-all-str-cat (3)
           else      move  "*"            to   w-all-str-cat (3)      .
      *
           move      "]"                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
       vis-pr2-mag-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pr2-mag-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no documento da verificare        *
      *    *-----------------------------------------------------------*
       acc-snx-dav-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-flg-nbx (1, 1) to   w-sav-snx-dav          .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-snx-dav        not  = "S"
                     go to acc-snx-dav-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-snx-dav-400.
       acc-snx-dav-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-dav-lun    to   v-car                  .
           move      w-exp-snx-dav-num    to   v-ldt                  .
           move      "DE#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-snx-dav-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 1) =    "#"
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 1) =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-snx-dav-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-snx-dav-999.
       acc-snx-dav-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "#"            to   w-tes-flg-nbx (1, 1)
           else if   v-num                =    2
                     move  spaces         to   w-tes-flg-nbx (1, 1)
           else      move  spaces         to   w-tes-flg-nbx (1, 1)   .
       acc-snx-dav-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se in modifica                         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to acc-snx-dav-600.
      *                  *---------------------------------------------*
      *                  * Test se variato                             *
      *                  *---------------------------------------------*
           if        w-tes-flg-nbx (1, 1) =    w-sav-snx-dav
                     go to acc-snx-dav-600.
      *                  *---------------------------------------------*
      *                  * Test se 'da verificare'                     *
      *                  *---------------------------------------------*
           if        w-tes-flg-nbx (1, 1) =    spaces
                     go to acc-snx-dav-600.
      *                  *---------------------------------------------*
      *                  * Box di avvertimento                         *
      *                  *---------------------------------------------*
           perform   acc-snx-dav-mod-000  thru acc-snx-dav-mod-999    .
           if        w-exp-dav-mod-sce    =    01
                     go to acc-snx-dav-420
           else if   w-exp-dav-mod-sce    =    02
                     go to acc-snx-dav-440
           else      go to acc-snx-dav-420.
       acc-snx-dav-420.
      *                  *---------------------------------------------*
      *                  * Se rinuncia della modifica                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ripristino del valore                   *
      *                      *-----------------------------------------*
           move      w-sav-snx-dav        to   w-tes-flg-nbx (1, 1)   .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-snx-dav-000      thru vis-snx-dav-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-snx-dav-600.
       acc-snx-dav-440.
      *                  *---------------------------------------------*
      *                  * Se conferma della modifica                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Cancellazione movimento di magazzino    *
      *                      *-----------------------------------------*
           perform   del-mov-mag-000      thru del-mov-mag-999        .
      *                      *-----------------------------------------*
      *                      * Protocollo di magazzino                 *
      *                      *-----------------------------------------*
           perform   vis-prt-mag-000      thru vis-prt-mag-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-snx-dav-600.
       acc-snx-dav-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-dav-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-dav-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-dav-100.
       acc-snx-dav-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no documento da verificare        *
      *    *                                                           *
      *    * Routine di avviso per ritorno a 'da verificare'           *
      *    *-----------------------------------------------------------*
       acc-snx-dav-mod-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       acc-snx-dav-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica di questo campo, implica la cancellazi
      -              "one del      "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "movimento di magazzino !                          
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-dav-mod-sce      .
       acc-snx-dav-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-dav-mod-lun    to   v-car                  .
           move      w-exp-dav-mod-num    to   v-ldt                  .
           move      "AP#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-dav-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-dav-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-snx-dav-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02
                     go to acc-snx-dav-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-dav-mod-sce      .
       acc-snx-dav-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-snx-dav-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-snx-dav-mod-999.
       acc-snx-dav-mod-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Si/no ordine da verific.  *
      *    *-----------------------------------------------------------*
       vis-snx-dav-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-snx-dav        not  = "S"
                     go to vis-snx-dav-999.
       vis-snx-dav-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-dav-lun    to   v-car                  .
           move      w-exp-snx-dav-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-snx-dav-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 1) =    "#"
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 1) =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-dav-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Distinta di verifica              *
      *    *-----------------------------------------------------------*
       vis-dst-bfe-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-det-dst-num-dst    =    zero
                     go to vis-dst-bfe-999.
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to vis-dst-bfe-999.
       vis-dst-bfe-100.
      *              *-------------------------------------------------*
      *              * Editing distinta                                *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-det-dst-num-dst    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      07                   to   w-all-str-num          .
           move      "[Dist."             to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
      *
           if        w-det-dst-sts-dst    =    spaces
                     move  spaces         to   w-all-str-cat (3)
                     move  spaces         to   w-all-str-cat (4)
           else      move  "-"            to   w-all-str-cat (3)
                     move  w-det-dst-sts-dst
                                          to   w-all-str-cat (4)      .
      *
           if        w-det-dst-nik-nam    =    spaces
                     move  spaces         to   w-all-str-cat (5)
                     move  spaces         to   w-all-str-cat (6)
           else      move  "-"            to   w-all-str-cat (5)
                     move  w-det-dst-nik-nam
                                          to   w-all-str-cat (6)      .
      *
           move      "]"                  to   w-all-str-cat (7)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      23                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dst-bfe-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Inoltro pagamenti            *
      *    *-----------------------------------------------------------*
       acc-inl-pgt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-inl-pgt (1)    to    w-sav-inl-pgt         .
      *                  *---------------------------------------------*
      *                  * Se dipendenza fornitore non esistente, mo-  *
      *                  * difica nr. elementi del pop-up di accetta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     move 02              to   w-exp-inl-pgt-num
           else      move 03              to   w-exp-inl-pgt-num      .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    zero
                     move  02             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-inl-pgt-400.
       acc-inl-pgt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
       acc-inl-pgt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-inl-pgt (1)      .
       acc-inl-pgt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    not  = zero
                     go to acc-inl-pgt-600.
           if        v-key                =    "UP  "
                     go to acc-inl-pgt-600
           else      go to acc-inl-pgt-100.
       acc-inl-pgt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =     w-sav-inl-pgt
                     go to acc-inl-pgt-800.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-inl-pgt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-inl-pgt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-inl-pgt-100.
       acc-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Inoltro pagamenti         *
      *    *-----------------------------------------------------------*
       vis-inl-pgt-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Sigla valuta per fatturazio- *
      *    * ne                                                        *
      *    *-----------------------------------------------------------*
       acc-sgl-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-sav-sgl-vpf          .
           move      w-tes-dec-vpf (1)    to   w-sav-dec-vpf          .
           move      w-tes-tdc-vpf (1)    to   w-sav-tdc-vpf          .
           move      w-tes-cdc-vpf (1)    to   w-sav-cdc-vpf          .
           move      spaces               to   w-sav-sgl-var          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-sgl-vpf-400.
       acc-sgl-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-tes-sgl-vpf (1)    to   w-cod-cod-zvl-cod      .
           move      08                   to   w-cod-cod-zvl-lin      .
           move      30                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpf-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpf-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpf-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpf-110.
       acc-sgl-vpf-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
       acc-sgl-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-sgl-vpf (1)      .
       acc-sgl-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-des    to   w-tes-sgl-vpf-des (1)  .
           move      w-let-arc-zvl-dec    to   w-tes-dec-vpf (1)      .
           move      w-let-arc-zvl-tdc    to   w-tes-tdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione valuta          *
      *                  *---------------------------------------------*
           perform   vis-sgl-vpf-des-000  thru vis-sgl-vpf-des-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-cod    =    spaces   or
                     w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero decimali             *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-dec    to   w-tes-dec-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo di cambio              *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-tes-tdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Se sigla valuta pari a quella base : forza- *
      *                  * tura cambio della valuta base               *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  c-cdc          to   w-tes-cdc-vpf (1)      .
       acc-sgl-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di accettazione sigla valuta           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo prezzi                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vpf (1)    =    w-sav-sgl-vpf
                     go to acc-sgl-vpf-800.
      *                      *-----------------------------------------*
      *                      * Determinazione coefficiente di cambio   *
      *                      * per la nuova valuta                     *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione               *
      *                      *-----------------------------------------*
           if        w-coe-cmb-vlt-cdc    =    zero
                     move  1              to   w-coe-cmb-vlt-cdc      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento coefficiente di cambio    *
      *                      *-----------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione coefficiente di cambio  *
      *                      *-----------------------------------------*
           perform   vis-cdc-vpf-000      thru vis-cdc-vpf-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dei prezzi in riga  *
      *                      * in caso di variazione valuta            *
      *                      *-----------------------------------------*
           perform   rcl-vlt-prz-000      thru rcl-vlt-prz-999        .
      *                      *-----------------------------------------*
      *                      * Test sulla scelta dell'operatore        *
      *                      *-----------------------------------------*
           if        w-exp-rcl-vlt-sce    =    01
                     go to acc-sgl-vpf-100.
      *                      *-----------------------------------------*
      *                      * Attivazione segnale di conversione da   *
      *                      * effettuare                              *
      *                      *-----------------------------------------*
           move      "#"                  to   w-sav-sgl-var          .
       acc-sgl-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sgl-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sgl-vpf-100.
       acc-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sigla valuta              *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione sigla valuta  *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-sgl-vpf-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Coefficiente di cambio       *
      *    *-----------------------------------------------------------*
       acc-cdc-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cdc-vpf (1)    to   w-sav-cdc-vpf          .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  c-cdc          to   w-tes-cdc-vpf (1)
                     go to acc-cdc-vpf-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cdc-vpf-400.
       acc-cdc-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           if        w-tes-dat-doc (1)    not  = zero
                     move  w-tes-dat-doc (1)
                                          to   w-coe-cmb-vlt-drc
           else      move  w-tes-dat-reg  to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           if        w-tes-cdc-vpf (1)    =    zero
                     move  "S"            to   w-coe-cmb-vlt-snd
           else      move  "N"            to   w-coe-cmb-vlt-snd      .
           move      w-tes-cdc-vpf (1)    to   w-coe-cmb-vlt-cdc      .
           move      08                   to   w-coe-cmb-vlt-lin      .
           move      60                   to   w-coe-cmb-vlt-pos      .
           move      08                   to   w-coe-cmb-vlt-dln      .
           move      73                   to   w-coe-cmb-vlt-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-cdc-vpf-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-cdc-vpf-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-cdc-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cdc-vpf-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-cdc-vpf-110.
       acc-cdc-vpf-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-cdc-vpf-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cdc-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cdc-vpf-999.
       acc-cdc-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cdc-vpf (1)      .
       acc-cdc-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-cdc-vpf (1)    not  = zero
                     go to acc-cdc-vpf-600.
           if        v-key                =    "UP  "
                     go to acc-cdc-vpf-600
           else      go to acc-cdc-vpf-100.
       acc-cdc-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo prezzi                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-tes-cdc-vpf (1)    =    w-sav-cdc-vpf
                     go to acc-cdc-vpf-800.
           if        w-sav-sgl-var        =    spaces
                     go to acc-cdc-vpf-800.
      *                      *-----------------------------------------*
      *                      * Disattivazione segnale di conversione   *
      *                      * da effettuare                           *
      *                      *-----------------------------------------*
           move      spaces               to   w-sav-sgl-var          .
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dei prezzi in riga  *
      *                      * in caso di variazione valuta            *
      *                      *-----------------------------------------*
           perform   rcl-vlt-prz-cmb-000  thru rcl-vlt-prz-cmb-999    .
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Effettuato il ricalcolo delle righe documento !   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cdc-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cdc-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cdc-vpf-100.
       acc-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Coefficiente di cambio    *
      *    *-----------------------------------------------------------*
       vis-cdc-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      08                   to   v-lin                  .
           move      60                   to   v-pos                  .
           if        w-tes-cdc-vpf (1)    =    1
                     move  zero           to   v-num
           else      move  w-tes-cdc-vpf (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Assoggettamento iva          *
      *    *-----------------------------------------------------------*
       acc-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fda-aiv (1)    not  = spaces
                     go to acc-ass-iva-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ass-iva-400.
       acc-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      10                   to   w-cod-mne-zci-lin      .
           move      30                   to   w-cod-mne-zci-pos      .
           move      10                   to   w-cod-mne-zci-dln      .
           move      37                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-ass-iva-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-ass-iva-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-ass-iva-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ass-iva-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-ass-iva-110.
       acc-ass-iva-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
       acc-ass-iva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ass-iva (1)      .
       acc-ass-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-des-000  thru vis-ass-iva-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zci-flg    not  = spaces
                     go to acc-ass-iva-100.
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
      *
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     go to acc-ass-iva-100.
       acc-ass-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di accettazione assoggettamento iva    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-aiv (1)      .
       acc-ass-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ass-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ass-iva-100.
       acc-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice di esenzione IVA   *
      *    *-----------------------------------------------------------*
       vis-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione assoggetta-   *
      *    * mento IVA                                                 *
      *    *-----------------------------------------------------------*
       vis-ass-iva-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-ass-iva-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Contropartita acquisti       *
      *    *-----------------------------------------------------------*
       acc-ctp-acq-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ctp-acq-400.
       acc-ctp-acq-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-tes-ctp-acq (1)    to   w-cod-mne-pdc-cod      .
           move      12                   to   w-cod-mne-pdc-lin      .
           move      30                   to   w-cod-mne-pdc-pos      .
           move      12                   to   w-cod-mne-pdc-dln      .
           move      41                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-acq-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-acq-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-acq-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-acq-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-acq-110.
       acc-ctp-acq-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-acq-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-acq-999.
       acc-ctp-acq-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ctp-acq (1)      .
       acc-ctp-acq-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-tes-ctp-acq (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-acq-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-acq-des-000  thru vis-ctp-acq-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-acq-100.
       acc-ctp-acq-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctp-acq-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ctp-acq-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ctp-acq-100.
       acc-ctp-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sottoconto contabile      *
      *    *-----------------------------------------------------------*
       vis-ctp-acq-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-tes-ctp-acq (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-acq-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita acquisti    *
      *    * per testata                                               *
      *    *-----------------------------------------------------------*
       vis-ctp-acq-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-ctp-acq-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-acq-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice pagamento             *
      *    *-----------------------------------------------------------*
       acc-cod-fop-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio percentuale di sconto pagamento *
      *                  * associata alla forma di pagamento           *
      *                  *---------------------------------------------*
           move      w-tes-scp-aap (1)    to   w-sav-scp-aap          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-fop-400.
       acc-cod-fop-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-yfp-ope      .
           move      w-tes-cod-fop (1)    to   w-cod-mne-yfp-cod      .
           move      05                   to   w-cod-mne-yfp-lin      .
           move      30                   to   w-cod-mne-yfp-pos      .
           move      05                   to   w-cod-mne-yfp-dln      .
           move      41                   to   w-cod-mne-yfp-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-yfp-cll-000  thru cod-mne-yfp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-yfp-foi-000  thru cod-mne-yfp-foi-999    .
       acc-cod-fop-110.
           perform   cod-mne-yfp-cll-000  thru cod-mne-yfp-cll-999    .
           if        w-cod-mne-yfp-ope    =    "F+"
                     go to acc-cod-fop-115.
           if        w-cod-mne-yfp-ope    =    "AC"
                     go to acc-cod-fop-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fop-115.
           perform   cod-mne-yfp-foi-000  thru cod-mne-yfp-foi-999    .
           go to     acc-cod-fop-110.
       acc-cod-fop-120.
           move      w-cod-mne-yfp-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
       acc-cod-fop-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-fop (1)      .
       acc-cod-fop-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [yfp]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-let-arc-yfp-cod      .
           perform   let-arc-yfp-000      thru let-arc-yfp-999        .
           move      w-let-arc-yfp-des    to   w-tes-cod-fop-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-fop-000      thru vis-des-fop-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-yfp-flg    not  = spaces
                     go to acc-cod-fop-100.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [yfp]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-yfp-000      thru det-vlt-yfp-999        .
       acc-cod-fop-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione sconto pagamento            *
      *                  *---------------------------------------------*
           perform   vis-scp-aap-000      thru vis-scp-aap-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento % sconto pagamento per piede    *
      *                  *---------------------------------------------*
           if        w-sav-scp-aap        =    w-tes-scp-aap (1)
                     go to acc-cod-fop-602.
           move      w-tes-scp-aap (1)    to   w-pie-per-scp (1)      .
           move      zero                 to   w-pie-tot-scp (1)      .
       acc-cod-fop-602.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostra banca             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-nsb (1)    not  = "S"
                     go to acc-cod-fop-604.
           if        w-tes-nos-ban (1)    not  = spaces
                     go to acc-cod-fop-608.
           move      w-tes-nsb-aaf (1)    to   w-tes-nos-ban (1)      .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-608.
       acc-cod-fop-604.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ban (1)    =    spaces
                     go to acc-cod-fop-608.
           move      spaces               to   w-tes-nos-ban (1)      .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-608.
       acc-cod-fop-608.
      *                  *---------------------------------------------*
      *                  * Trattamento codici Abi, Cab e c/c bancario  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-bnb (1)    not  = "S"
                     go to acc-cod-fop-610.
           if        w-tes-cod-abi (1)    not  = zero
                     go to acc-cod-fop-620.
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
           go to     acc-cod-fop-620.
       acc-cod-fop-610.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-fop-620.
           move      zero                 to   w-tes-cod-abi (1)      .
           move      spaces               to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           move      spaces               to   w-tes-ccc-app (1)      .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
       acc-cod-fop-620.
      *                  *---------------------------------------------*
      *                  * Trattamento c/c postale fornitore           *
      *                  *---------------------------------------------*
           if        w-tes-snx-ccp (1)    =    spaces   and
                     w-tes-ccp-app (1)    not  = spaces
                     move  spaces         to   w-tes-ccp-app (1)
                     perform vis-ccp-app-000
                                          thru vis-ccp-app-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento data scadenza pagamento manuale *
      *                  *---------------------------------------------*
           if        w-tes-snx-spm (1)    =    spaces and
                     w-tes-pag-dsm (1)    not  = zero
                     move  zero           to   w-tes-pag-dsm (1)
                     perform vis-pag-dsm-000
                                          thru vis-pag-dsm-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento quota a forfait                 *
      *                  *---------------------------------------------*
           if        w-tes-snx-qaf (1)    =    spaces and
                     w-tes-pag-qaf (1)    not  = zero
                     move  zero           to   w-tes-pag-qaf (1)
                     perform vis-pag-qaf-000
                                          thru vis-pag-qaf-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento acconto                         *
      *                  *---------------------------------------------*
           if        w-tes-snx-act (1)    =    spaces and
                     w-tes-pag-act (1)    not  = zero
                     move  zero           to   w-tes-pag-act (1)
                     perform vis-pag-act-000
                                          thru vis-pag-act-999        .
       acc-cod-fop-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fop-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fop-100.
       acc-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice forma di pagamento *
      *    *-----------------------------------------------------------*
       vis-cod-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-fop (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione forma di paga-*
      *    * mento                                                     *
      *    *-----------------------------------------------------------*
       vis-des-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-fop-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : % sconto pagamento        *
      *    *-----------------------------------------------------------*
       vis-scp-aap-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BD"                to   v-edm                  .
           move      w-tes-scp-aap (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-scp-aap-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostra banca          *
      *    *-----------------------------------------------------------*
       acc-nos-ban-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-nos-ban-400.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-nsb (1)    =    spaces
                     go to acc-nos-ban-999.
       acc-nos-ban-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      02                   to   w-cod-des-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-cod-des-cbp-cod      .
           move      08                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      08                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-nos-ban-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-nos-ban-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-nos-ban-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-nos-ban-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-nos-ban-110.
       acc-nos-ban-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
       acc-nos-ban-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nos-ban (1)      .
       acc-nos-ban-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-nos-ban-100.
       acc-nos-ban-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nos-ban-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nos-ban-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nos-ban-100.
       acc-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostra banca       *
      *    *-----------------------------------------------------------*
       vis-nos-ban-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nos-ban (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice nostra banca, descrizione  *
      *    *-----------------------------------------------------------*
       vis-nos-ban-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-nos-ban-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice ABI banca d'appoggio  *
      *    *-----------------------------------------------------------*
       acc-cod-abi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-bnb (1)    =    spaces
                     go to acc-cod-abi-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-sav-cod-abi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-abi-400.
       acc-cod-abi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-abi-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-abi-cod      .
           move      10                   to   w-cod-mne-abi-lin      .
           move      30                   to   w-cod-mne-abi-pos      .
           move      10                   to   w-cod-mne-abi-dln      .
           move      41                   to   w-cod-mne-abi-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
       acc-cod-abi-110.
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           if        w-cod-mne-abi-ope    =    "F+"
                     go to acc-cod-abi-115.
           if        w-cod-mne-abi-ope    =    "AC"
                     go to acc-cod-abi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-abi-115.
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
           go to     acc-cod-abi-110.
       acc-cod-abi-120.
           move      w-cod-mne-abi-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
       acc-cod-abi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-abi (1)      .
       acc-cod-abi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica istituti                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-den-abi-000      thru vis-den-abi-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita da lettura           *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to acc-cod-abi-100.
       acc-cod-abi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se variato codice ABI                       *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    w-sav-cod-abi
                     go to acc-cod-abi-800.
           if        w-tes-cod-cab (1)    =    zero
                     go to acc-cod-abi-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione C/C bancario            *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-ccc-app (1)      .
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
       acc-cod-abi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-abi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-abi-100.
       acc-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice ABI banca          *
      *    *-----------------------------------------------------------*
       vis-cod-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-abi (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione banca       *
      *    *-----------------------------------------------------------*
       vis-den-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-abi-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-abi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice CAB                   *
      *    *-----------------------------------------------------------*
       acc-cod-cab-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-cab-999.
            if       w-tes-snx-bnb (1)    =    spaces
                     go to acc-cod-cab-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cab-400.
       acc-cod-cab-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cab-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-cab-abi      .
           move      w-tes-cod-cab (1)    to   w-cod-mne-cab-cab      .
           move      11                   to   w-cod-mne-cab-lin      .
           move      30                   to   w-cod-mne-cab-pos      .
           move      11                   to   w-cod-mne-cab-dln      .
           move      41                   to   w-cod-mne-cab-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
       acc-cod-cab-110.
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           if        w-cod-mne-cab-ope    =    "F+"
                     go to acc-cod-cab-115.
           if        w-cod-mne-cab-ope    =    "AC"
                     go to acc-cod-cab-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cab-115.
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
           go to     acc-cod-cab-110.
       acc-cod-cab-120.
           move      w-cod-mne-cab-cab    to   v-num                  .
       acc-cod-cab-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
       acc-cod-cab-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cab (1)      .
       acc-cod-cab-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-cod-cab-100.
       acc-cod-cab-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cab-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cab-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cab-100.
       acc-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice CAB                *
      *    *-----------------------------------------------------------*
       vis-cod-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cab (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
